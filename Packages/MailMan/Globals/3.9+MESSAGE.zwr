^XMB(3.9,145831,2,928,0)=" Q"
^XMB(3.9,145831,2,929,0)="""RTN"",""EDPVIT"",32,0)"
^XMB(3.9,145831,2,930,0)=" ;"
^XMB(3.9,145831,2,931,0)="""RTN"",""EDPVIT"",33,0)"
^XMB(3.9,145831,2,932,0)="PUT(DFN,DATA) ; -- Save new measurement"
^XMB(3.9,145831,2,933,0)="""RTN"",""EDPVIT"",34,0)"
^XMB(3.9,145831,2,934,0)=" N I,NM,VAL,TIME,LOC,TYPE,X,ERROR"
^XMB(3.9,145831,2,935,0)="""RTN"",""EDPVIT"",35,0)"
^XMB(3.9,145831,2,936,0)=" S DFN=+$G(DFN) I DFN<1 D ERR(""Missing or invalid patient DFN"") Q"
^XMB(3.9,145831,2,937,0)="""RTN"",""EDPVIT"",36,0)"
^XMB(3.9,145831,2,938,0)=" F I=1:1:$L(DATA,""^"") D  ;parse"
^XMB(3.9,145831,2,939,0)="""RTN"",""EDPVIT"",37,0)"
^XMB(3.9,145831,2,940,0)=" . S X=$P(DATA,U,I),NM=$P(X,""=""),VAL=$P(X,""="",2)"
^XMB(3.9,145831,2,941,0)="""RTN"",""EDPVIT"",38,0)"
^XMB(3.9,145831,2,942,0)=" . S:$L(NM) DATA($$UP^XLFSTR(NM))=VAL"
^XMB(3.9,145831,2,943,0)="""RTN"",""EDPVIT"",39,0)"
^XMB(3.9,145831,2,944,0)=" S TIME=$G(DATA(""TIME"")),ERROR=$G(DATA(""ERROR""))"
^XMB(3.9,145831,2,945,0)="""RTN"",""EDPVIT"",40,0)"
^XMB(3.9,145831,2,946,0)=" I TIME<1 D ERR(""Missing or invalid time"") Q"
^XMB(3.9,145831,2,947,0)="""RTN"",""EDPVIT"",41,0)"
^XMB(3.9,145831,2,948,0)=" I ERROR=""true"" D  G PUTQ"
^XMB(3.9,145831,2,949,0)="""RTN"",""EDPVIT"",42,0)"
^XMB(3.9,145831,2,950,0)=" . ;mark all values at TIME as Entered in Error"
^XMB(3.9,145831,2,951,0)="""RTN"",""EDPVIT"",43,0)"
^XMB(3.9,145831,2,952,0)=" S LOC=$$DFLTLOC^EDPLPCE(DFN)"
^XMB(3.9,145831,2,953,0)="""RTN"",""EDPVIT"",44,0)"
^XMB(3.9,145831,2,954,0)=" I LOC<1 D ERR(""Missing default ED Hospital Location"") Q"
^XMB(3.9,145831,2,955,0)="""RTN"",""EDPVIT"",45,0)"
^XMB(3.9,145831,2,956,0)=" F TYPE=""BP"",""T"",""R"",""P"",""HT"",""WT"",""PN"" S X=$G(DATA(TYPE)) I X D"
^XMB(3.9,145831,2,957,0)="""RTN"",""EDPVIT"",46,0)"
^XMB(3.9,145831,2,958,0)=" . N IEN,DATA,EDPY"
^XMB(3.9,145831,2,959,0)="""RTN"",""EDPVIT"",47,0)"
^XMB(3.9,145831,2,960,0)=" . S IEN=+$O(^GMRD(120.51,""C"",TYPE,0))"
^XMB(3.9,145831,2,961,0)="""RTN"",""EDPVIT"",48,0)"
^XMB(3.9,145831,2,962,0)=" . S DATA=TIME_U_DFN_U_IEN_"";""_X_U_LOC_U_DUZ"
^XMB(3.9,145831,2,963,0)="""RTN"",""EDPVIT"",49,0)"
^XMB(3.9,145831,2,964,0)=" . D EN1^GMVDCSAV(.EDPY,DATA) ;IA #4815"
^XMB(3.9,145831,2,965,0)="""RTN"",""EDPVIT"",50,0)"
