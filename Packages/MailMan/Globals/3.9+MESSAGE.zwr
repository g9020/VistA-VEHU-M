^XMB(3.9,144657,2,1133,0)="""RTN"",""IBCNBAA"",270,0)"
^XMB(3.9,144657,2,1134,0)=" S DIR(""?"")=""  to the person who holds this insurance policy (or insured)."""
^XMB(3.9,144657,2,1135,0)="""RTN"",""IBCNBAA"",271,0)"
^XMB(3.9,144657,2,1136,0)=" D ^DIR I +Y S IBVAL=Y_U_$P($P(IBF,Y_"":"",2),"";"")"
