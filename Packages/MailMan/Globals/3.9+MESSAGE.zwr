^XMB(3.9,145834,2,5904,0)=" W !,""--------"",?11,""----------------"",?30,""--------"",?40,""--------"",?51,""------ ------"",?66,""------ ------"""
^XMB(3.9,145834,2,5905,0)="""RTN"",""MAGDSTAA"",147,0)"
^XMB(3.9,145834,2,5906,0)=" I ^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION"")=""RETRIEVE MISSING IMAGES"" D"
