^XMB(3.9,145831,2,991,0)="""RTN"",""EDPVIT"",63,0)"
^XMB(3.9,145831,2,992,0)=" I $P(IDX,"","",3)=DFN S Y=9999999-+$P(IDX,"","",5)"
