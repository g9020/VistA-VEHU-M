^XMB(3.9,145834,2,6513,0)="""RTN"",""MAGDSTAS"",146,0)"
^XMB(3.9,145834,2,6514,0)=" W ! D CONTINUE^MAGDSTQ(1)"
^XMB(3.9,145834,2,6515,0)="""RTN"",""MAGDSTAS"",147,0)"
^XMB(3.9,145834,2,6516,0)=" Q"
