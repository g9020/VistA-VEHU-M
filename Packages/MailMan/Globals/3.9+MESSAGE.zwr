^XMB(3.9,144657,2,2689,0)="""RTN"",""IBCNBLE1"",169,0)"
^XMB(3.9,144657,2,2690,0)=" ..I IB1ST D "
^XMB(3.9,144657,2,2691,0)="""RTN"",""IBCNBLE1"",170,0)"
^XMB(3.9,144657,2,2692,0)=" ...S IB1ST=0"
^XMB(3.9,144657,2,2693,0)="""RTN"",""IBCNBLE1"",171,0)"
^XMB(3.9,144657,2,2694,0)=" ...; Display section header"
^XMB(3.9,144657,2,2695,0)="""RTN"",""IBCNBLE1"",172,0)"
^XMB(3.9,144657,2,2696,0)=" ...D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2697,0)="""RTN"",""IBCNBLE1"",173,0)"
^XMB(3.9,144657,2,2698,0)=" ...S IBY=$J("""",19)_""Eligibility Communicator Notes"""
^XMB(3.9,144657,2,2699,0)="""RTN"",""IBCNBLE1"",174,0)"
^XMB(3.9,144657,2,2700,0)=" ...D SET^IBCNBLE(IBY,""B"") S IBLINE="""""
^XMB(3.9,144657,2,2701,0)="""RTN"",""IBCNBLE1"",175,0)"
^XMB(3.9,144657,2,2702,0)=" ..; Display Notes"
^XMB(3.9,144657,2,2703,0)="""RTN"",""IBCNBLE1"",176,0)"
^XMB(3.9,144657,2,2704,0)=" ..D TXT^IBCNEUT7(""IBTXT"")"
^XMB(3.9,144657,2,2705,0)="""RTN"",""IBCNBLE1"",177,0)"
^XMB(3.9,144657,2,2706,0)=" ..F IBCT=1:1:$O(IBTXT(""""),-1) D SET^IBCNBLE(IBTXT(IBCT))"
^XMB(3.9,144657,2,2707,0)="""RTN"",""IBCNBLE1"",178,0)"
^XMB(3.9,144657,2,2708,0)=" ..Q"
^XMB(3.9,144657,2,2709,0)="""RTN"",""IBCNBLE1"",179,0)"
^XMB(3.9,144657,2,2710,0)=" ;"
^XMB(3.9,144657,2,2711,0)="""RTN"",""IBCNBLE1"",180,0)"
^XMB(3.9,144657,2,2712,0)="ECNOTEX ;"
^XMB(3.9,144657,2,2713,0)="""RTN"",""IBCNBLE1"",181,0)"
^XMB(3.9,144657,2,2714,0)=" Q"
^XMB(3.9,144657,2,2715,0)="""RTN"",""IBCNBLE1"",182,0)"
^XMB(3.9,144657,2,2716,0)=" ;"
^XMB(3.9,144657,2,2717,0)="""RTN"",""IBCNBLE1"",183,0)"
^XMB(3.9,144657,2,2718,0)="SIDERR(BUF,PIEN) ;"
^XMB(3.9,144657,2,2719,0)="""RTN"",""IBCNBLE1"",184,0)"
^XMB(3.9,144657,2,2720,0)=" ; dw/IB*668 updated utility as the logic was using a field that was made "
^XMB(3.9,144657,2,2721,0)="""RTN"",""IBCNBLE1"",185,0)"
^XMB(3.9,144657,2,2722,0)=" ; obsolete many years ago.  It may no longer try to use SSN for the subscriber ID"
^XMB(3.9,144657,2,2723,0)="""RTN"",""IBCNBLE1"",186,0)"
^XMB(3.9,144657,2,2724,0)=" ;"
^XMB(3.9,144657,2,2725,0)="""RTN"",""IBCNBLE1"",187,0)"
^XMB(3.9,144657,2,2726,0)=" ; If Subscriber ID is required and SSN cannot be substituted"
^XMB(3.9,144657,2,2727,0)="""RTN"",""IBCNBLE1"",188,0)"
^XMB(3.9,144657,2,2728,0)=" ; and buffer does not have a sub id -> return error"
^XMB(3.9,144657,2,2729,0)="""RTN"",""IBCNBLE1"",189,0)"
^XMB(3.9,144657,2,2730,0)=" ; BUF = buffer IEN"
^XMB(3.9,144657,2,2731,0)="""RTN"",""IBCNBLE1"",190,0)"
^XMB(3.9,144657,2,2732,0)=" ; PIEN = payer IEN"
^XMB(3.9,144657,2,2733,0)="""RTN"",""IBCNBLE1"",191,0)"
^XMB(3.9,144657,2,2734,0)=" ;"
^XMB(3.9,144657,2,2735,0)="""RTN"",""IBCNBLE1"",192,0)"
^XMB(3.9,144657,2,2736,0)=" N ERR,SID,APPIEN,SIDREQ"
^XMB(3.9,144657,2,2737,0)="""RTN"",""IBCNBLE1"",193,0)"
^XMB(3.9,144657,2,2738,0)=" S ERR="""""
^XMB(3.9,144657,2,2739,0)="""RTN"",""IBCNBLE1"",194,0)"
^XMB(3.9,144657,2,2740,0)=" ;S SID=$P($G(^IBA(355.33,BUF,60)),U,4)  ; Patch 516 - baa"
^XMB(3.9,144657,2,2741,0)="""RTN"",""IBCNBLE1"",195,0)"
^XMB(3.9,144657,2,2742,0)=" S SID=$$GET1^DIQ(355.33,BUF,90.03)  ; Patch 516 - baa"
^XMB(3.9,144657,2,2743,0)="""RTN"",""IBCNBLE1"",196,0)"
^XMB(3.9,144657,2,2744,0)=" I SID]"""" G SIDX  ; Subscriber id is populated, further checking is moot"
^XMB(3.9,144657,2,2745,0)="""RTN"",""IBCNBLE1"",197,0)"
^XMB(3.9,144657,2,2746,0)=" ;IB*668/TAZ - Changed Payer Application from IIV to EIV"
^XMB(3.9,144657,2,2747,0)="""RTN"",""IBCNBLE1"",198,0)"
^XMB(3.9,144657,2,2748,0)=" S APPIEN=$$PYRAPP^IBCNEUT5(""EIV"",PIEN)"
^XMB(3.9,144657,2,2749,0)="""RTN"",""IBCNBLE1"",199,0)"
^XMB(3.9,144657,2,2750,0)=" ;S SIDSTR=$G(^IBE(365.12,PIEN,1,APPIEN,0)) ;dw/668 field was moved"
^XMB(3.9,144657,2,2751,0)="""RTN"",""IBCNBLE1"",200,0)"
^XMB(3.9,144657,2,2752,0)=" ;S SIDREQ=$P(SIDSTR,U,8) I 'SIDREQ G SIDX  ; if sub id is not req'd - ok  "
^XMB(3.9,144657,2,2753,0)="""RTN"",""IBCNBLE1"",201,0)"
^XMB(3.9,144657,2,2754,0)=" ;S SIDSSN=$P(SIDSTR,U,9) I 'SIDSSN S ERR=18 ; if ssn cannot be used -> B15 status (IEN = 18)"
^XMB(3.9,144657,2,2755,0)="""RTN"",""IBCNBLE1"",202,0)"
^XMB(3.9,144657,2,2756,0)=" S SIDREQ=$$GET1^DIQ(365.121,APPIEN_"",""_PIEN_"","",4.02,""I"")"
^XMB(3.9,144657,2,2757,0)="""RTN"",""IBCNBLE1"",203,0)"
^XMB(3.9,144657,2,2758,0)=" I 'SIDREQ G SIDX  ; if sub id is not req'd - ok "
^XMB(3.9,144657,2,2759,0)="""RTN"",""IBCNBLE1"",204,0)"
^XMB(3.9,144657,2,2760,0)=" S ERR=18 ; missing Subscriber ID and it is required -> B15 status (IEN = 18)"
^XMB(3.9,144657,2,2761,0)="""RTN"",""IBCNBLE1"",205,0)"
^XMB(3.9,144657,2,2762,0)="SIDX Q ERR"
^XMB(3.9,144657,2,2763,0)="""RTN"",""IBCNBLE1"",206,0)"
^XMB(3.9,144657,2,2764,0)=" ;"
^XMB(3.9,144657,2,2765,0)="""RTN"",""IBCNBLE1"",207,0)"
^XMB(3.9,144657,2,2766,0)="PIDERR(BUF) ;"
^XMB(3.9,144657,2,2767,0)="""RTN"",""IBCNBLE1"",208,0)"
^XMB(3.9,144657,2,2768,0)=" ; If patient is a dependent and patient id is missing return error"
^XMB(3.9,144657,2,2769,0)="""RTN"",""IBCNBLE1"",209,0)"
^XMB(3.9,144657,2,2770,0)=" ; BUF - buffer ien"
^XMB(3.9,144657,2,2771,0)="""RTN"",""IBCNBLE1"",210,0)"
^XMB(3.9,144657,2,2772,0)=" ;"
^XMB(3.9,144657,2,2773,0)="""RTN"",""IBCNBLE1"",211,0)"
^XMB(3.9,144657,2,2774,0)=" N ERR,PREL"
^XMB(3.9,144657,2,2775,0)="""RTN"",""IBCNBLE1"",212,0)"
^XMB(3.9,144657,2,2776,0)=" S ERR="""""
^XMB(3.9,144657,2,2777,0)="""RTN"",""IBCNBLE1"",213,0)"
^XMB(3.9,144657,2,2778,0)=" S PREL=$P($G(^IBA(355.33,BUF,60)),U,14)"
^XMB(3.9,144657,2,2779,0)="""RTN"",""IBCNBLE1"",214,0)"
^XMB(3.9,144657,2,2780,0)=" I PREL'=18,PREL'="""",$P($G(^IBA(355.33,BUF,62)),U)="""" S ERR=23"
^XMB(3.9,144657,2,2781,0)="""RTN"",""IBCNBLE1"",215,0)"
^XMB(3.9,144657,2,2782,0)=" Q ERR"
^XMB(3.9,144657,2,2783,0)="""RTN"",""IBCNBLE2"")"
^XMB(3.9,144657,2,2784,0)="0^8^B76745962"
^XMB(3.9,144657,2,2785,0)="""RTN"",""IBCNBLE2"",1,0)"
^XMB(3.9,144657,2,2786,0)="IBCNBLE2 ;ALB/ESG - Expand ins buffer - e-Pharmacy entry ;14-Oct-2010"
^XMB(3.9,144657,2,2787,0)="""RTN"",""IBCNBLE2"",2,0)"
^XMB(3.9,144657,2,2788,0)=" ;;2.0;INTEGRATED BILLING;**435**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,2789,0)="""RTN"",""IBCNBLE2"",3,0)"
^XMB(3.9,144657,2,2790,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,144657,2,2791,0)="""RTN"",""IBCNBLE2"",4,0)"
^XMB(3.9,144657,2,2792,0)=" ;"
^XMB(3.9,144657,2,2793,0)="""RTN"",""IBCNBLE2"",5,0)"
^XMB(3.9,144657,2,2794,0)=" ; References to BPS RESPONSES file (#9002313.03) supported by IA 4813"
^XMB(3.9,144657,2,2795,0)="""RTN"",""IBCNBLE2"",6,0)"
^XMB(3.9,144657,2,2796,0)=" ; Called by IBCNBLE when expanding an e-Pharmacy buffer entry"
^XMB(3.9,144657,2,2797,0)="""RTN"",""IBCNBLE2"",7,0)"
^XMB(3.9,144657,2,2798,0)=" ; Variable IB0 is the 0 node of file 355.33"
^XMB(3.9,144657,2,2799,0)="""RTN"",""IBCNBLE2"",8,0)"
^XMB(3.9,144657,2,2800,0)=" ;"
^XMB(3.9,144657,2,2801,0)="""RTN"",""IBCNBLE2"",9,0)"
^XMB(3.9,144657,2,2802,0)="EN ; Entry point"
^XMB(3.9,144657,2,2803,0)="""RTN"",""IBCNBLE2"",10,0)"
^XMB(3.9,144657,2,2804,0)=" N RESPIEN,RSPSUB,ZR,ZM,BPSR,BPSM,BPSMD,BPSMCOB,IBY,IBL,IBLINE,TEXT"
^XMB(3.9,144657,2,2805,0)="""RTN"",""IBCNBLE2"",11,0)"
^XMB(3.9,144657,2,2806,0)=" ;"
^XMB(3.9,144657,2,2807,0)="""RTN"",""IBCNBLE2"",12,0)"
^XMB(3.9,144657,2,2808,0)=" S RESPIEN=+$P(IB0,U,17) I 'RESPIEN G EX"
^XMB(3.9,144657,2,2809,0)="""RTN"",""IBCNBLE2"",13,0)"
^XMB(3.9,144657,2,2810,0)=" I '$D(^BPSR(RESPIEN,0)) G EX"
^XMB(3.9,144657,2,2811,0)="""RTN"",""IBCNBLE2"",14,0)"
^XMB(3.9,144657,2,2812,0)=" S ZR=RESPIEN_"","""
^XMB(3.9,144657,2,2813,0)="""RTN"",""IBCNBLE2"",15,0)"
^XMB(3.9,144657,2,2814,0)=" D GETS^DIQ(9002313.03,ZR,"".01:999"",""IEN"",""BPSR"")   ; get all fields at top level except raw data"
^XMB(3.9,144657,2,2815,0)="""RTN"",""IBCNBLE2"",16,0)"
^XMB(3.9,144657,2,2816,0)=" ;"
^XMB(3.9,144657,2,2817,0)="""RTN"",""IBCNBLE2"",17,0)"
^XMB(3.9,144657,2,2818,0)=" S RSPSUB=+$O(^BPSR(RESPIEN,1000,0)),ZM=0"
^XMB(3.9,144657,2,2819,0)="""RTN"",""IBCNBLE2"",18,0)"
^XMB(3.9,144657,2,2820,0)=" I RSPSUB D"
^XMB(3.9,144657,2,2821,0)="""RTN"",""IBCNBLE2"",19,0)"
^XMB(3.9,144657,2,2822,0)=" . S ZM=RSPSUB_"",""_RESPIEN_"","""
^XMB(3.9,144657,2,2823,0)="""RTN"",""IBCNBLE2"",20,0)"
^XMB(3.9,144657,2,2824,0)=" . D GETS^DIQ(9002313.0301,ZM,""112;503;511*;130.01*;549;550;987"",""IEN"",""BPSM"")  ; get Response Status Segment data"
^XMB(3.9,144657,2,2825,0)="""RTN"",""IBCNBLE2"",21,0)"
^XMB(3.9,144657,2,2826,0)=" . Q"
^XMB(3.9,144657,2,2827,0)="""RTN"",""IBCNBLE2"",22,0)"
^XMB(3.9,144657,2,2828,0)=" ;"
^XMB(3.9,144657,2,2829,0)="""RTN"",""IBCNBLE2"",23,0)"
^XMB(3.9,144657,2,2830,0)=" D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2831,0)="""RTN"",""IBCNBLE2"",24,0)"
^XMB(3.9,144657,2,2832,0)=" S IBY=$J("""",22)_""e-Pharmacy Eligibility Response Data"""
^XMB(3.9,144657,2,2833,0)="""RTN"",""IBCNBLE2"",25,0)"
^XMB(3.9,144657,2,2834,0)=" D SET^IBCNBLE(IBY,""B"")"
^XMB(3.9,144657,2,2835,0)="""RTN"",""IBCNBLE2"",26,0)"
^XMB(3.9,144657,2,2836,0)=" ;"
^XMB(3.9,144657,2,2837,0)="""RTN"",""IBCNBLE2"",27,0)"
^XMB(3.9,144657,2,2838,0)=" S IBL=""Transmission Status: """
^XMB(3.9,144657,2,2839,0)="""RTN"",""IBCNBLE2"",28,0)"
^XMB(3.9,144657,2,2840,0)=" S IBY=$G(BPSR(9002313.03,ZR,501,""E""))"
^XMB(3.9,144657,2,2841,0)="""RTN"",""IBCNBLE2"",29,0)"
^XMB(3.9,144657,2,2842,0)=" S IBLINE=$$SETL^IBCNBLE("""",IBY,IBL,24,55)"
^XMB(3.9,144657,2,2843,0)="""RTN"",""IBCNBLE2"",30,0)"
^XMB(3.9,144657,2,2844,0)=" D SET^IBCNBLE(IBLINE)"
^XMB(3.9,144657,2,2845,0)="""RTN"",""IBCNBLE2"",31,0)"
^XMB(3.9,144657,2,2846,0)=" ;"
^XMB(3.9,144657,2,2847,0)="""RTN"",""IBCNBLE2"",32,0)"
^XMB(3.9,144657,2,2848,0)=" S IBL=""Transaction Status: """
^XMB(3.9,144657,2,2849,0)="""RTN"",""IBCNBLE2"",33,0)"
^XMB(3.9,144657,2,2850,0)=" S IBY=$G(BPSM(9002313.0301,ZM,112,""E""))"
^XMB(3.9,144657,2,2851,0)="""RTN"",""IBCNBLE2"",34,0)"
^XMB(3.9,144657,2,2852,0)=" S IBLINE=$$SETL^IBCNBLE("""",IBY,IBL,24,55)"
^XMB(3.9,144657,2,2853,0)="""RTN"",""IBCNBLE2"",35,0)"
^XMB(3.9,144657,2,2854,0)=" D SET^IBCNBLE(IBLINE)"
^XMB(3.9,144657,2,2855,0)="""RTN"",""IBCNBLE2"",36,0)"
^XMB(3.9,144657,2,2856,0)=" ;"
^XMB(3.9,144657,2,2857,0)="""RTN"",""IBCNBLE2"",37,0)"
^XMB(3.9,144657,2,2858,0)=" S IBL=""Date of Service: """
^XMB(3.9,144657,2,2859,0)="""RTN"",""IBCNBLE2"",38,0)"
^XMB(3.9,144657,2,2860,0)=" S IBY=$G(BPSR(9002313.03,ZR,401,""E""))"
^XMB(3.9,144657,2,2861,0)="""RTN"",""IBCNBLE2"",39,0)"
^XMB(3.9,144657,2,2862,0)=" S IBLINE=$$SETL^IBCNBLE("""",IBY,IBL,24,55)"
^XMB(3.9,144657,2,2863,0)="""RTN"",""IBCNBLE2"",40,0)"
^XMB(3.9,144657,2,2864,0)=" D SET^IBCNBLE(IBLINE)"
^XMB(3.9,144657,2,2865,0)="""RTN"",""IBCNBLE2"",41,0)"
^XMB(3.9,144657,2,2866,0)=" ;"
^XMB(3.9,144657,2,2867,0)="""RTN"",""IBCNBLE2"",42,0)"
^XMB(3.9,144657,2,2868,0)=" ; get 504 Message"
^XMB(3.9,144657,2,2869,0)="""RTN"",""IBCNBLE2"",43,0)"
^XMB(3.9,144657,2,2870,0)=" S TEXT=$G(BPSR(9002313.03,ZR,504,""E""))"
^XMB(3.9,144657,2,2871,0)="""RTN"",""IBCNBLE2"",44,0)"
^XMB(3.9,144657,2,2872,0)=" I TEXT'="""" D"
^XMB(3.9,144657,2,2873,0)="""RTN"",""IBCNBLE2"",45,0)"
^XMB(3.9,144657,2,2874,0)=" . D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2875,0)="""RTN"",""IBCNBLE2"",46,0)"
^XMB(3.9,144657,2,2876,0)=" . N IBZ,J,LEN,PCE,CHS,NEWCHS"
^XMB(3.9,144657,2,2877,0)="""RTN"",""IBCNBLE2"",47,0)"
^XMB(3.9,144657,2,2878,0)=" . S LEN=30   ; break up big words"
^XMB(3.9,144657,2,2879,0)="""RTN"",""IBCNBLE2"",48,0)"
^XMB(3.9,144657,2,2880,0)=" . F PCE=1:1 Q:PCE>$L(TEXT,"" "")  S CHS=$P(TEXT,"" "",PCE) I $L(CHS)>LEN D"
^XMB(3.9,144657,2,2881,0)="""RTN"",""IBCNBLE2"",49,0)"
^XMB(3.9,144657,2,2882,0)=" .. S NEWCHS=$E(CHS,1,LEN)_"" ""_$E(CHS,LEN+1,999)"
^XMB(3.9,144657,2,2883,0)="""RTN"",""IBCNBLE2"",50,0)"
^XMB(3.9,144657,2,2884,0)=" .. S $P(TEXT,"" "",PCE)=NEWCHS"
^XMB(3.9,144657,2,2885,0)="""RTN"",""IBCNBLE2"",51,0)"
^XMB(3.9,144657,2,2886,0)=" .. Q"
^XMB(3.9,144657,2,2887,0)="""RTN"",""IBCNBLE2"",52,0)"
^XMB(3.9,144657,2,2888,0)=" . D FSTRNG^IBJU1(TEXT,71,.IBZ)"
^XMB(3.9,144657,2,2889,0)="""RTN"",""IBCNBLE2"",53,0)"
^XMB(3.9,144657,2,2890,0)=" . S J=0 F  S J=$O(IBZ(J)) Q:'J  D"
^XMB(3.9,144657,2,2891,0)="""RTN"",""IBCNBLE2"",54,0)"
^XMB(3.9,144657,2,2892,0)=" .. S IBLINE=$$SETL^IBCNBLE("""",IBZ(J),"""",2,999)"
^XMB(3.9,144657,2,2893,0)="""RTN"",""IBCNBLE2"",55,0)"
^XMB(3.9,144657,2,2894,0)=" .. D SET^IBCNBLE(IBLINE)"
^XMB(3.9,144657,2,2895,0)="""RTN"",""IBCNBLE2"",56,0)"
^XMB(3.9,144657,2,2896,0)=" .. Q"
^XMB(3.9,144657,2,2897,0)="""RTN"",""IBCNBLE2"",57,0)"
^XMB(3.9,144657,2,2898,0)=" . Q"
^XMB(3.9,144657,2,2899,0)="""RTN"",""IBCNBLE2"",58,0)"
^XMB(3.9,144657,2,2900,0)=" ;"
^XMB(3.9,144657,2,2901,0)="""RTN"",""IBCNBLE2"",59,0)"
^XMB(3.9,144657,2,2902,0)=" ; display reject codes 511 if they exist"
^XMB(3.9,144657,2,2903,0)="""RTN"",""IBCNBLE2"",60,0)"
^XMB(3.9,144657,2,2904,0)=" I $D(BPSM(9002313.03511)) D"
^XMB(3.9,144657,2,2905,0)="""RTN"",""IBCNBLE2"",61,0)"
^XMB(3.9,144657,2,2906,0)=" . N ZJ"
^XMB(3.9,144657,2,2907,0)="""RTN"",""IBCNBLE2"",62,0)"
^XMB(3.9,144657,2,2908,0)=" . D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2909,0)="""RTN"",""IBCNBLE2"",63,0)"
^XMB(3.9,144657,2,2910,0)=" . D SET^IBCNBLE(""  Reject Codes:"")"
^XMB(3.9,144657,2,2911,0)="""RTN"",""IBCNBLE2"",64,0)"
^XMB(3.9,144657,2,2912,0)=" . S ZJ="""" F  S ZJ=$O(BPSM(9002313.03511,ZJ)) Q:ZJ=""""  D SET^IBCNBLE(""     ""_$G(BPSM(9002313.03511,ZJ,.01,""E"")))"
^XMB(3.9,144657,2,2913,0)="""RTN"",""IBCNBLE2"",65,0)"
^XMB(3.9,144657,2,2914,0)=" . Q"
^XMB(3.9,144657,2,2915,0)="""RTN"",""IBCNBLE2"",66,0)"
^XMB(3.9,144657,2,2916,0)=" ;"
^XMB(3.9,144657,2,2917,0)="""RTN"",""IBCNBLE2"",67,0)"
^XMB(3.9,144657,2,2918,0)=" ; display additional messages if they exist"
^XMB(3.9,144657,2,2919,0)="""RTN"",""IBCNBLE2"",68,0)"
^XMB(3.9,144657,2,2920,0)=" I $D(BPSM(9002313.13001)) D"
^XMB(3.9,144657,2,2921,0)="""RTN"",""IBCNBLE2"",69,0)"
^XMB(3.9,144657,2,2922,0)=" . N ZA,TEXT"
^XMB(3.9,144657,2,2923,0)="""RTN"",""IBCNBLE2"",70,0)"
^XMB(3.9,144657,2,2924,0)=" . D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2925,0)="""RTN"",""IBCNBLE2"",71,0)"
^XMB(3.9,144657,2,2926,0)=" . D SET^IBCNBLE(""  Additional Message:"")"
^XMB(3.9,144657,2,2927,0)="""RTN"",""IBCNBLE2"",72,0)"
^XMB(3.9,144657,2,2928,0)=" . S ZA="""" F  S ZA=$O(BPSM(9002313.13001,ZA)) Q:ZA=""""  S TEXT=$G(BPSM(9002313.13001,ZA,526,""E"")) I TEXT'="""" D"
^XMB(3.9,144657,2,2929,0)="""RTN"",""IBCNBLE2"",73,0)"
^XMB(3.9,144657,2,2930,0)=" .. N IBZ,J,LEN,PCE,CHS,NEWCHS"
^XMB(3.9,144657,2,2931,0)="""RTN"",""IBCNBLE2"",74,0)"
^XMB(3.9,144657,2,2932,0)=" .. S LEN=30   ; break up big words"
^XMB(3.9,144657,2,2933,0)="""RTN"",""IBCNBLE2"",75,0)"
^XMB(3.9,144657,2,2934,0)=" .. F PCE=1:1 Q:PCE>$L(TEXT,"" "")  S CHS=$P(TEXT,"" "",PCE) I $L(CHS)>LEN D"
^XMB(3.9,144657,2,2935,0)="""RTN"",""IBCNBLE2"",76,0)"
^XMB(3.9,144657,2,2936,0)=" ... S NEWCHS=$E(CHS,1,LEN)_"" ""_$E(CHS,LEN+1,999)"
^XMB(3.9,144657,2,2937,0)="""RTN"",""IBCNBLE2"",77,0)"
^XMB(3.9,144657,2,2938,0)=" ... S $P(TEXT,"" "",PCE)=NEWCHS"
^XMB(3.9,144657,2,2939,0)="""RTN"",""IBCNBLE2"",78,0)"
^XMB(3.9,144657,2,2940,0)=" ... Q"
^XMB(3.9,144657,2,2941,0)="""RTN"",""IBCNBLE2"",79,0)"
^XMB(3.9,144657,2,2942,0)=" .. D FSTRNG^IBJU1(TEXT,71,.IBZ)"
^XMB(3.9,144657,2,2943,0)="""RTN"",""IBCNBLE2"",80,0)"
^XMB(3.9,144657,2,2944,0)=" .. S J=0 F  S J=$O(IBZ(J)) Q:'J  D"
^XMB(3.9,144657,2,2945,0)="""RTN"",""IBCNBLE2"",81,0)"
^XMB(3.9,144657,2,2946,0)=" ... S IBLINE=$$SETL^IBCNBLE("""",IBZ(J),"""",5,999)"
^XMB(3.9,144657,2,2947,0)="""RTN"",""IBCNBLE2"",82,0)"
^XMB(3.9,144657,2,2948,0)=" ... D SET^IBCNBLE(IBLINE)"
^XMB(3.9,144657,2,2949,0)="""RTN"",""IBCNBLE2"",83,0)"
