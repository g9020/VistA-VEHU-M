^XMB(3.9,144657,2,10821,0)="""RTN"",""IBNCPIV"",118,0)"
^XMB(3.9,144657,2,10822,0)=" W ! D ^DIR K DIR"
^XMB(3.9,144657,2,10823,0)="""RTN"",""IBNCPIV"",119,0)"
^XMB(3.9,144657,2,10824,0)=" I $D(DTOUT)!$D(DUOUT) G SENDX"
^XMB(3.9,144657,2,10825,0)="""RTN"",""IBNCPIV"",120,0)"
