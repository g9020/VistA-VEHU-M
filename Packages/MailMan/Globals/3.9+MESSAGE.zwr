^XMB(3.9,145831,2,1047,0)="""RTN"",""EDPVIT"",91,0)"
^XMB(3.9,145831,2,1048,0)=" .. S EDPX(""abnormal"")=$S($L($P(REC,U,12)):""true"",1:""false"")"
^XMB(3.9,145831,2,1049,0)="""RTN"",""EDPVIT"",92,0)"
^XMB(3.9,145831,2,1050,0)=" .. I '$L($P(REC,U,17)) D XML^EDPX($$XMLA^EDPX(""vitalMsmt"",.EDPX)) Q"
