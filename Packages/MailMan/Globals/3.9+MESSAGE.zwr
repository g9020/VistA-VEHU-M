^XMB(3.9,145832,2,177,0)="""QUES"",""XPF2"",0)"
^XMB(3.9,145832,2,178,0)="Y"
^XMB(3.9,145832,2,179,0)="""QUES"",""XPF2"",""??"")"
^XMB(3.9,145832,2,180,0)="^D DTA^XPDH"
^XMB(3.9,145832,2,181,0)="""QUES"",""XPF2"",""A"")"
^XMB(3.9,145832,2,182,0)="Want my data |FLAG| yours"
^XMB(3.9,145832,2,183,0)="""QUES"",""XPF2"",""B"")"
^XMB(3.9,145832,2,184,0)="YES"
^XMB(3.9,145832,2,185,0)="""QUES"",""XPF2"",""M"")"
^XMB(3.9,145832,2,186,0)="D XPF2^XPDIQ"
^XMB(3.9,145832,2,187,0)="""QUES"",""XPI1"",0)"
^XMB(3.9,145832,2,188,0)="YO"
^XMB(3.9,145832,2,189,0)="""QUES"",""XPI1"",""??"")"
^XMB(3.9,145832,2,190,0)="^D INHIBIT^XPDH"
^XMB(3.9,145832,2,191,0)="""QUES"",""XPI1"",""A"")"
^XMB(3.9,145832,2,192,0)="Want KIDS to INHIBIT LOGONs during the install"
^XMB(3.9,145832,2,193,0)="""QUES"",""XPI1"",""B"")"
^XMB(3.9,145832,2,194,0)="NO"
^XMB(3.9,145832,2,195,0)="""QUES"",""XPI1"",""M"")"
^XMB(3.9,145832,2,196,0)="D XPI1^XPDIQ"
^XMB(3.9,145832,2,197,0)="""QUES"",""XPM1"",0)"
^XMB(3.9,145832,2,198,0)="PO^VA(200,:EM"
^XMB(3.9,145832,2,199,0)="""QUES"",""XPM1"",""??"")"
^XMB(3.9,145832,2,200,0)="^D MG^XPDH"
^XMB(3.9,145832,2,201,0)="""QUES"",""XPM1"",""A"")"
^XMB(3.9,145832,2,202,0)="Enter the Coordinator for Mail Group '|FLAG|'"
^XMB(3.9,145832,2,203,0)="""QUES"",""XPM1"",""B"")"
^XMB(3.9,145832,2,204,0)=""
^XMB(3.9,145832,2,205,0)="""QUES"",""XPM1"",""M"")"
^XMB(3.9,145832,2,206,0)="D XPM1^XPDIQ"
^XMB(3.9,145832,2,207,0)="""QUES"",""XPO1"",0)"
^XMB(3.9,145832,2,208,0)="Y"
^XMB(3.9,145832,2,209,0)="""QUES"",""XPO1"",""??"")"
^XMB(3.9,145832,2,210,0)="^D MENU^XPDH"
^XMB(3.9,145832,2,211,0)="""QUES"",""XPO1"",""A"")"
^XMB(3.9,145832,2,212,0)="Want KIDS to Rebuild Menu Trees Upon Completion of Install"
^XMB(3.9,145832,2,213,0)="""QUES"",""XPO1"",""B"")"
^XMB(3.9,145832,2,214,0)="NO"
^XMB(3.9,145832,2,215,0)="""QUES"",""XPO1"",""M"")"
^XMB(3.9,145832,2,216,0)="D XPO1^XPDIQ"
^XMB(3.9,145832,2,217,0)="""QUES"",""XPZ1"",0)"
^XMB(3.9,145832,2,218,0)="Y"
^XMB(3.9,145832,2,219,0)="""QUES"",""XPZ1"",""??"")"
^XMB(3.9,145832,2,220,0)="^D OPT^XPDH"
^XMB(3.9,145832,2,221,0)="""QUES"",""XPZ1"",""A"")"
^XMB(3.9,145832,2,222,0)="Want to DISABLE Scheduled Options, Menu Options, and Protocols"
^XMB(3.9,145832,2,223,0)="""QUES"",""XPZ1"",""B"")"
^XMB(3.9,145832,2,224,0)="NO"
^XMB(3.9,145832,2,225,0)="""QUES"",""XPZ1"",""M"")"
^XMB(3.9,145832,2,226,0)="D XPZ1^XPDIQ"
^XMB(3.9,145832,2,227,0)="""QUES"",""XPZ2"",0)"
^XMB(3.9,145832,2,228,0)="Y"
^XMB(3.9,145832,2,229,0)="""QUES"",""XPZ2"",""??"")"
^XMB(3.9,145832,2,230,0)="^D RTN^XPDH"
^XMB(3.9,145832,2,231,0)="""QUES"",""XPZ2"",""A"")"
^XMB(3.9,145832,2,232,0)="Want to MOVE routines to other CPUs"
^XMB(3.9,145832,2,233,0)="""QUES"",""XPZ2"",""B"")"
^XMB(3.9,145832,2,234,0)="NO"
^XMB(3.9,145832,2,235,0)="""QUES"",""XPZ2"",""M"")"
^XMB(3.9,145832,2,236,0)="D XPZ2^XPDIQ"
^XMB(3.9,145832,2,237,0)="""RTN"")"
^XMB(3.9,145832,2,238,0)=1
^XMB(3.9,145832,2,239,0)="""RTN"",""VAFCTFU1"")"
^XMB(3.9,145832,2,240,0)="0^1^B16172152"
^XMB(3.9,145832,2,241,0)="""RTN"",""VAFCTFU1"",1,0)"
^XMB(3.9,145832,2,242,0)="VAFCTFU1 ;BHM/RGY-Utilities for the Treating Facility file 391.91, CONTINUED ;6 May 2021  1:56 PM"
^XMB(3.9,145832,2,243,0)="""RTN"",""VAFCTFU1"",2,0)"
^XMB(3.9,145832,2,244,0)=" ;;5.3;Registration;**261,392,448,449,800,856,1042,1055**;Aug 13, 1993;Build 0"
^XMB(3.9,145832,2,245,0)="""RTN"",""VAFCTFU1"",3,0)"
^XMB(3.9,145832,2,246,0)="TFL(LIST,DFN) ;for dfn get list of treating facilities"
^XMB(3.9,145832,2,247,0)="""RTN"",""VAFCTFU1"",4,0)"
^XMB(3.9,145832,2,248,0)=" NEW X,ICN,DA,DR,VAFCTFU1,DIC,DIQ,VAFC"
^XMB(3.9,145832,2,249,0)="""RTN"",""VAFCTFU1"",5,0)"
^XMB(3.9,145832,2,250,0)=" S X=""MPIF001"" X ^%ZOSF(""TEST"") I '$T S LIST(1)=""-1^MPI Not Installed"" Q"
^XMB(3.9,145832,2,251,0)="""RTN"",""VAFCTFU1"",6,0)"
^XMB(3.9,145832,2,252,0)=" S DR="".01;13;99"",DIC=4,DIQ(0)=""E"",DIQ=""VAFCTFU1"" ;**448"
^XMB(3.9,145832,2,253,0)="""RTN"",""VAFCTFU1"",7,0)"
^XMB(3.9,145832,2,254,0)=" S ICN=$$GETICN^MPIF001(DFN)"
^XMB(3.9,145832,2,255,0)="""RTN"",""VAFCTFU1"",8,0)"
^XMB(3.9,145832,2,256,0)=" I ICN<0 S LIST(1)=ICN Q"
^XMB(3.9,145832,2,257,0)="""RTN"",""VAFCTFU1"",9,0)"
^XMB(3.9,145832,2,258,0)=" S X=$$QUERYTF($P(ICN,""V""),""LIST"",0)"
^XMB(3.9,145832,2,259,0)="""RTN"",""VAFCTFU1"",10,0)"
^XMB(3.9,145832,2,260,0)=" I $P(X,U)=""1"" S LIST(1)=""-1""_U_$P(X,U,2) Q"
^XMB(3.9,145832,2,261,0)="""RTN"",""VAFCTFU1"",11,0)"
^XMB(3.9,145832,2,262,0)=" F VAFC=0:0 S VAFC=$O(LIST(VAFC)) Q:VAFC=""""  D"
^XMB(3.9,145832,2,263,0)="""RTN"",""VAFCTFU1"",12,0)"
^XMB(3.9,145832,2,264,0)=" .K VAFCTFU1"
^XMB(3.9,145832,2,265,0)="""RTN"",""VAFCTFU1"",13,0)"
^XMB(3.9,145832,2,266,0)=" .S DA=+LIST(VAFC)"
^XMB(3.9,145832,2,267,0)="""RTN"",""VAFCTFU1"",14,0)"
^XMB(3.9,145832,2,268,0)=" .D EN^DIQ1"
^XMB(3.9,145832,2,269,0)="""RTN"",""VAFCTFU1"",15,0)"
^XMB(3.9,145832,2,270,0)=" .S LIST(VAFC)=VAFCTFU1(4,+LIST(VAFC),99,""E"")_""^""_VAFCTFU1(4,+LIST(VAFC),.01,""E"")_""^""_$P(LIST(VAFC),""^"",2)_""^""_$P(LIST(VAFC),""^"",3)_""^""_VAFCTFU1(4,+LIST(VAFC),13,""E"") ;**448"
^XMB(3.9,145832,2,271,0)="""RTN"",""VAFCTFU1"",16,0)"
^XMB(3.9,145832,2,272,0)=" .Q"
^XMB(3.9,145832,2,273,0)="""RTN"",""VAFCTFU1"",17,0)"
^XMB(3.9,145832,2,274,0)=" Q"
^XMB(3.9,145832,2,275,0)="""RTN"",""VAFCTFU1"",18,0)"
^XMB(3.9,145832,2,276,0)="GETICN(RESULT,DFN) ;"
^XMB(3.9,145832,2,277,0)="""RTN"",""VAFCTFU1"",19,0)"
^XMB(3.9,145832,2,278,0)=" S RESULT=$$GETICN^MPIF001(DFN)"
^XMB(3.9,145832,2,279,0)="""RTN"",""VAFCTFU1"",20,0)"
^XMB(3.9,145832,2,280,0)=" Q"
^XMB(3.9,145832,2,281,0)="""RTN"",""VAFCTFU1"",21,0)"
^XMB(3.9,145832,2,282,0)="GETDFN(RESULT,ICN) ;"
^XMB(3.9,145832,2,283,0)="""RTN"",""VAFCTFU1"",22,0)"
^XMB(3.9,145832,2,284,0)=" S RESULT=$$GETDFN^MPIF001(ICN)"
^XMB(3.9,145832,2,285,0)="""RTN"",""VAFCTFU1"",23,0)"
^XMB(3.9,145832,2,286,0)=" Q"
^XMB(3.9,145832,2,287,0)="""RTN"",""VAFCTFU1"",24,0)"
^XMB(3.9,145832,2,288,0)="IFLOCAL(RESULT,DFN) ;"
^XMB(3.9,145832,2,289,0)="""RTN"",""VAFCTFU1"",25,0)"
^XMB(3.9,145832,2,290,0)=" S RESULT=$$IFLOCAL^MPIF001(DFN)"
^XMB(3.9,145832,2,291,0)="""RTN"",""VAFCTFU1"",26,0)"
^XMB(3.9,145832,2,292,0)=" Q"
^XMB(3.9,145832,2,293,0)="""RTN"",""VAFCTFU1"",27,0)"
^XMB(3.9,145832,2,294,0)=" ;"
^XMB(3.9,145832,2,295,0)="""RTN"",""VAFCTFU1"",28,0)"
^XMB(3.9,145832,2,296,0)="SET(TFIEN,ARY,CTR) ;This sets the array with the treating facility list."
^XMB(3.9,145832,2,297,0)="""RTN"",""VAFCTFU1"",29,0)"
^XMB(3.9,145832,2,298,0)=" ; Returns: treating facility ^ treatment date ^ event reason (if any)"
^XMB(3.9,145832,2,299,0)="""RTN"",""VAFCTFU1"",30,0)"
^XMB(3.9,145832,2,300,0)=" ; *261 gjc@120899 (formerly part of VAFCTFU prior to DG*5.3*261)"
^XMB(3.9,145832,2,301,0)="""RTN"",""VAFCTFU1"",31,0)"
^XMB(3.9,145832,2,302,0)=" N DGCN,INSTIEN,LSTA S DGCN(0)=$G(^DGCN(391.91,TFIEN,0))"
^XMB(3.9,145832,2,303,0)="""RTN"",""VAFCTFU1"",32,0)"
^XMB(3.9,145832,2,304,0)=" ;** DG*5.3*800 - (ckn) - Quit if IPP field is not set for 200MH record"
^XMB(3.9,145832,2,305,0)="""RTN"",""VAFCTFU1"",33,0)"
^XMB(3.9,145832,2,306,0)=" S INSTIEN=$P($G(DGCN(0)),""^"",2),LSTA=$$STA^XUAF4(INSTIEN)"
^XMB(3.9,145832,2,307,0)="""RTN"",""VAFCTFU1"",34,0)"
^XMB(3.9,145832,2,308,0)=" I $E(LSTA,1,5)=""200MH"",$P($G(DGCN(0)),""^"",8)'=1 Q"
^XMB(3.9,145832,2,309,0)="""RTN"",""VAFCTFU1"",35,0)"
^XMB(3.9,145832,2,310,0)=" S CTR=CTR+1,@ARY@(CTR)=$P(DGCN(0),U,2,3)_U_$P(DGCN(0),U,7)"
^XMB(3.9,145832,2,311,0)="""RTN"",""VAFCTFU1"",36,0)"
^XMB(3.9,145832,2,312,0)=" Q"
^XMB(3.9,145832,2,313,0)="""RTN"",""VAFCTFU1"",37,0)"
^XMB(3.9,145832,2,314,0)=" ;"
^XMB(3.9,145832,2,315,0)="""RTN"",""VAFCTFU1"",38,0)"
^XMB(3.9,145832,2,316,0)="QUERYTF(PAT,ARY,INDX) ;a query for Treating Facility."
^XMB(3.9,145832,2,317,0)="""RTN"",""VAFCTFU1"",39,0)"
^XMB(3.9,145832,2,318,0)=" ;INPUT   PAT - The patient's ICN"
^XMB(3.9,145832,2,319,0)="""RTN"",""VAFCTFU1"",40,0)"
^XMB(3.9,145832,2,320,0)=" ;        ARY - The array in which to return the Treating facility info."
^XMB(3.9,145832,2,321,0)="""RTN"",""VAFCTFU1"",41,0)"
^XMB(3.9,145832,2,322,0)=" ;        INDX (optional) - the index to $O through.  APAT for patient"
^XMB(3.9,145832,2,323,0)="""RTN"",""VAFCTFU1"",42,0)"
^XMB(3.9,145832,2,324,0)=" ;        information linked to treating facilities, AEVN for patient"
^XMB(3.9,145832,2,325,0)="""RTN"",""VAFCTFU1"",43,0)"
^XMB(3.9,145832,2,326,0)=" ;        info linked with an event reason.  INDX=1 if AEVN is used,"
^XMB(3.9,145832,2,327,0)="""RTN"",""VAFCTFU1"",44,0)"
^XMB(3.9,145832,2,328,0)=" ;        else APAT is used. *261 gjc@120399"
^XMB(3.9,145832,2,329,0)="""RTN"",""VAFCTFU1"",45,0)"
^XMB(3.9,145832,2,330,0)=" ;"
^XMB(3.9,145832,2,331,0)="""RTN"",""VAFCTFU1"",46,0)"
^XMB(3.9,145832,2,332,0)=" ;OUTPUT  A list of the Treating Facilities in the array provided from"
^XMB(3.9,145832,2,333,0)="""RTN"",""VAFCTFU1"",47,0)"
^XMB(3.9,145832,2,334,0)=" ;        the parameter.  It will be in the structure of x(1), x(2) etc."
^XMB(3.9,145832,2,335,0)="""RTN"",""VAFCTFU1"",48,0)"
^XMB(3.9,145832,2,336,0)=" ;  Ex  X(1)=500^2960101^ptr to ADT/HL7 Event Reason file (if exists)"
^XMB(3.9,145832,2,337,0)="""RTN"",""VAFCTFU1"",49,0)"
^XMB(3.9,145832,2,338,0)=" ;    Where the first piece is the IEN of the institution, the second"
^XMB(3.9,145832,2,339,0)="""RTN"",""VAFCTFU1"",50,0)"
^XMB(3.9,145832,2,340,0)=" ;    piece is the current date on record for that institution and the"
^XMB(3.9,145832,2,341,0)="""RTN"",""VAFCTFU1"",51,0)"
^XMB(3.9,145832,2,342,0)=" ;    third piece is the event reason (if it exists).  Note: A04 & A08"
^XMB(3.9,145832,2,343,0)="""RTN"",""VAFCTFU1"",52,0)"
^XMB(3.9,145832,2,344,0)=" ;    events do not file an event reason when adding to the TREATING"
^XMB(3.9,145832,2,345,0)="""RTN"",""VAFCTFU1"",53,0)"
^XMB(3.9,145832,2,346,0)=" ;    FACILITY LIST (#391.91) file, thus returning null in the third"
^XMB(3.9,145832,2,347,0)="""RTN"",""VAFCTFU1"",54,0)"
^XMB(3.9,145832,2,348,0)=" ;    piece. *261 gjc@120199"
^XMB(3.9,145832,2,349,0)="""RTN"",""VAFCTFU1"",55,0)"
^XMB(3.9,145832,2,350,0)=" ;"
^XMB(3.9,145832,2,351,0)="""RTN"",""VAFCTFU1"",56,0)"
^XMB(3.9,145832,2,352,0)=" ;    This is also a function call.  If there is an error then a"
^XMB(3.9,145832,2,353,0)="""RTN"",""VAFCTFU1"",57,0)"
^XMB(3.9,145832,2,354,0)=" ;    1^error description will be returned."
^XMB(3.9,145832,2,355,0)="""RTN"",""VAFCTFU1"",58,0)"
^XMB(3.9,145832,2,356,0)=" ;"
^XMB(3.9,145832,2,357,0)="""RTN"",""VAFCTFU1"",59,0)"
^XMB(3.9,145832,2,358,0)=" ;  *** If no data is found the array will not be populated and"
^XMB(3.9,145832,2,359,0)="""RTN"",""VAFCTFU1"",60,0)"
^XMB(3.9,145832,2,360,0)=" ;  a 1^error description will be returned."
^XMB(3.9,145832,2,361,0)="""RTN"",""VAFCTFU1"",61,0)"
^XMB(3.9,145832,2,362,0)=" ;"
^XMB(3.9,145832,2,363,0)="""RTN"",""VAFCTFU1"",62,0)"
^XMB(3.9,145832,2,364,0)=" N PDFN,VAFCER,LP,CTR,ZTFIEN,ZDLT,ZTDLT"
^XMB(3.9,145832,2,365,0)="""RTN"",""VAFCTFU1"",63,0)"
^XMB(3.9,145832,2,366,0)=" I '$G(PAT)!('$D(ARY)) S VAFCER=""1^Parameter missing."" G QUERYTFQ"
^XMB(3.9,145832,2,367,0)="""RTN"",""VAFCTFU1"",64,0)"
^XMB(3.9,145832,2,368,0)=" S VAFCER=0,CTR=0,INDX=$G(INDX)"
^XMB(3.9,145832,2,369,0)="""RTN"",""VAFCTFU1"",65,0)"
^XMB(3.9,145832,2,370,0)=" S X=""MPIF001"" X ^%ZOSF(""TEST"") I '$T G QUERYTFQ"
^XMB(3.9,145832,2,371,0)="""RTN"",""VAFCTFU1"",66,0)"
^XMB(3.9,145832,2,372,0)=" S PDFN=$$GETDFN^MPIF001(PAT)"
^XMB(3.9,145832,2,373,0)="""RTN"",""VAFCTFU1"",67,0)"
^XMB(3.9,145832,2,374,0)=" I PDFN<0 S VAFCER=""1^No patient DFN."" G QUERYTFQ"
^XMB(3.9,145832,2,375,0)="""RTN"",""VAFCTFU1"",68,0)"
^XMB(3.9,145832,2,376,0)=" ; determine the index to $O through, based on the value of INDX"
^XMB(3.9,145832,2,377,0)="""RTN"",""VAFCTFU1"",69,0)"
^XMB(3.9,145832,2,378,0)=" ;I 'INDX F LP=0:0 S LP=$O(^DGCN(391.91,""APAT"",PDFN,LP)) Q:'LP  S TFIEN=$O(^(LP,"""")) D SET(TFIEN,ARY,.CTR)"
^XMB(3.9,145832,2,379,0)="""RTN"",""VAFCTFU1"",70,0)"
^XMB(3.9,145832,2,380,0)=" ;**856 - MVI 1371 (ckn)"
^XMB(3.9,145832,2,381,0)="""RTN"",""VAFCTFU1"",71,0)"
^XMB(3.9,145832,2,382,0)=" ;Now that Treating Facility file can have multiple entries for"
^XMB(3.9,145832,2,383,0)="""RTN"",""VAFCTFU1"",72,0)"
^XMB(3.9,145832,2,384,0)=" ;one site, enhanced the code to loop through all TFIENs for each SITE"
^XMB(3.9,145832,2,385,0)="""RTN"",""VAFCTFU1"",73,0)"
^XMB(3.9,145832,2,386,0)=" ;and return the record which have latest Date Last Treated. If none"
^XMB(3.9,145832,2,387,0)="""RTN"",""VAFCTFU1"",74,0)"
^XMB(3.9,145832,2,388,0)=" ;of the entries have DLT populated, return the first record for site."
^XMB(3.9,145832,2,389,0)="""RTN"",""VAFCTFU1"",75,0)"
^XMB(3.9,145832,2,390,0)=" I 'INDX F LP=0:0 S LP=$O(^DGCN(391.91,""APAT"",PDFN,LP)) Q:'LP  D"
^XMB(3.9,145832,2,391,0)="""RTN"",""VAFCTFU1"",76,0)"
^XMB(3.9,145832,2,392,0)=" .Q:'$$ISVAMC(LP)  ;**1042,VAMPI-8212 (mko): Skip non-VAMCs"
^XMB(3.9,145832,2,393,0)="""RTN"",""VAFCTFU1"",77,0)"
^XMB(3.9,145832,2,394,0)=" .S ZTDLT=0,ZTFIEN=$O(^DGCN(391.91,""APAT"",PDFN,LP,"""")) Q:'ZTFIEN"
^XMB(3.9,145832,2,395,0)="""RTN"",""VAFCTFU1"",78,0)"
^XMB(3.9,145832,2,396,0)=" .S TFIEN=0 F  S TFIEN=$O(^DGCN(391.91,""APAT"",PDFN,LP,TFIEN)) Q:'TFIEN  D"
^XMB(3.9,145832,2,397,0)="""RTN"",""VAFCTFU1"",79,0)"
^XMB(3.9,145832,2,398,0)=" ..Q:'$$ISPATIEN(TFIEN)  ;**1042,VAMPI-8212 (mko): Skip if not a patient record (not ""PI"" or null)"
^XMB(3.9,145832,2,399,0)="""RTN"",""VAFCTFU1"",80,0)"
^XMB(3.9,145832,2,400,0)=" ..S ZDLT=$P(^DGCN(391.91,TFIEN,0),""^"",3) ;Date last treated"
^XMB(3.9,145832,2,401,0)="""RTN"",""VAFCTFU1"",81,0)"
^XMB(3.9,145832,2,402,0)=" ..I ZDLT>ZTDLT S ZTDLT=ZDLT,ZTFIEN=TFIEN"
^XMB(3.9,145832,2,403,0)="""RTN"",""VAFCTFU1"",82,0)"
^XMB(3.9,145832,2,404,0)=" .D SET(ZTFIEN,ARY,.CTR)"
^XMB(3.9,145832,2,405,0)="""RTN"",""VAFCTFU1"",83,0)"
^XMB(3.9,145832,2,406,0)=" I INDX S LP=0 F  S LP=$O(^DGCN(391.91,""AEVN"",PDFN,LP)) Q:'LP  D"
^XMB(3.9,145832,2,407,0)="""RTN"",""VAFCTFU1"",84,0)"
^XMB(3.9,145832,2,408,0)=" .; please note the following: the AEVN xref is subscripted by pat. dfn"
^XMB(3.9,145832,2,409,0)="""RTN"",""VAFCTFU1"",85,0)"
^XMB(3.9,145832,2,410,0)=" .; event reason ptr, and the ien of the TFL file.  It is possible"
^XMB(3.9,145832,2,411,0)="""RTN"",""VAFCTFU1"",86,0)"
^XMB(3.9,145832,2,412,0)=" .; that a patient may have numerous admission/discharges at different"
^XMB(3.9,145832,2,413,0)="""RTN"",""VAFCTFU1"",87,0)"
^XMB(3.9,145832,2,414,0)=" .; treating facilities, thus the looping through the TFIEN (TFL ien)"
^XMB(3.9,145832,2,415,0)="""RTN"",""VAFCTFU1"",88,0)"
^XMB(3.9,145832,2,416,0)=" .; subscript. *261 gjc@120399"
^XMB(3.9,145832,2,417,0)="""RTN"",""VAFCTFU1"",89,0)"
^XMB(3.9,145832,2,418,0)=" .S TFIEN=0 F  S TFIEN=$O(^DGCN(391.91,""AEVN"",PDFN,LP,TFIEN)) Q:'TFIEN  D SET(TFIEN,ARY,.CTR)"
^XMB(3.9,145832,2,419,0)="""RTN"",""VAFCTFU1"",90,0)"
^XMB(3.9,145832,2,420,0)=" .Q"
^XMB(3.9,145832,2,421,0)="""RTN"",""VAFCTFU1"",91,0)"
^XMB(3.9,145832,2,422,0)=" I $D(@ARY)'>9 S VAFCER=""1^Could not find Treating Facilities"""
^XMB(3.9,145832,2,423,0)="""RTN"",""VAFCTFU1"",92,0)"
^XMB(3.9,145832,2,424,0)="QUERYTFQ Q VAFCER"
^XMB(3.9,145832,2,425,0)="""RTN"",""VAFCTFU1"",93,0)"
^XMB(3.9,145832,2,426,0)=" ;"
^XMB(3.9,145832,2,427,0)="""RTN"",""VAFCTFU1"",94,0)"
^XMB(3.9,145832,2,428,0)="ISVAMC(SITEIEN,SITEID) ;Return 1 if this is a VAMC"
^XMB(3.9,145832,2,429,0)="""RTN"",""VAFCTFU1"",95,0)"
^XMB(3.9,145832,2,430,0)=" ;**1042,VAMPI-8212 (mko): New function"
^XMB(3.9,145832,2,431,0)="""RTN"",""VAFCTFU1"",96,0)"
^XMB(3.9,145832,2,432,0)=" N DIERR,MSG"
^XMB(3.9,145832,2,433,0)="""RTN"",""VAFCTFU1"",97,0)"
^XMB(3.9,145832,2,434,0)=" I $G(SITEIEN)="""" Q:$G(SITEID)="""" """" S SITEIEN=$$IEN^XUAF4(SITEID)"
^XMB(3.9,145832,2,435,0)="""RTN"",""VAFCTFU1"",98,0)"
^XMB(3.9,145832,2,436,0)=" I $G(SITEID)="""" S SITEID=$$STA^XUAF4(SITEIEN)"
^XMB(3.9,145832,2,437,0)="""RTN"",""VAFCTFU1"",99,0)"
^XMB(3.9,145832,2,438,0)=" ;**1055,VAMPI-10191 (mko): Allow return of 200, 200CH, and 200MH"
^XMB(3.9,145832,2,439,0)="""RTN"",""VAFCTFU1"",100,0)"
^XMB(3.9,145832,2,440,0)=" I ""^200CH^200MH^""[(U_SITEID_U) Q 1"
^XMB(3.9,145832,2,441,0)="""RTN"",""VAFCTFU1"",101,0)"
^XMB(3.9,145832,2,442,0)=" I $$GET1^DIQ(4,SITEIEN_"","",13,"""","""",""MSG"")'=""OTHER"",SITEID'=""200M"" Q 1"
^XMB(3.9,145832,2,443,0)="""RTN"",""VAFCTFU1"",102,0)"
^XMB(3.9,145832,2,444,0)=" Q 0"
^XMB(3.9,145832,2,445,0)="""RTN"",""VAFCTFU1"",103,0)"
^XMB(3.9,145832,2,446,0)=" ;"
^XMB(3.9,145832,2,447,0)="""RTN"",""VAFCTFU1"",104,0)"
^XMB(3.9,145832,2,448,0)="ISPATIEN(TFLIEN) ;Return 1 if Source ID Type is ""PI"" or null"
^XMB(3.9,145832,2,449,0)="""RTN"",""VAFCTFU1"",105,0)"
^XMB(3.9,145832,2,450,0)=" ;**1042,VAMPI-8212 (mko): New function"
^XMB(3.9,145832,2,451,0)="""RTN"",""VAFCTFU1"",106,0)"
^XMB(3.9,145832,2,452,0)=" Q:$D(^DGCN(391.91,+$G(TFLIEN),0))[0 0"
^XMB(3.9,145832,2,453,0)="""RTN"",""VAFCTFU1"",107,0)"
^XMB(3.9,145832,2,454,0)=" Q ""PI""[$P(^DGCN(391.91,+$G(TFLIEN),0),""^"",9)"
^XMB(3.9,145832,2,455,0)="""VER"")"
^XMB(3.9,145832,2,456,0)="8.0^22.2"
