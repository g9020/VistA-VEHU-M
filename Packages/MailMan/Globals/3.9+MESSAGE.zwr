^XMB(3.9,145834,2,3402,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,3403,0)="""RTN"",""MAGDSTA2"",9,0)"
^XMB(3.9,145834,2,3404,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,3405,0)="""RTN"",""MAGDSTA2"",10,0)"
^XMB(3.9,145834,2,3406,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,3407,0)="""RTN"",""MAGDSTA2"",11,0)"
^XMB(3.9,145834,2,3408,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,3409,0)="""RTN"",""MAGDSTA2"",12,0)"
^XMB(3.9,145834,2,3410,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,3411,0)="""RTN"",""MAGDSTA2"",13,0)"
^XMB(3.9,145834,2,3412,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,3413,0)="""RTN"",""MAGDSTA2"",14,0)"
^XMB(3.9,145834,2,3414,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
