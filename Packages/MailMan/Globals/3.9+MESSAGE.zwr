^XMB(3.9,144657,2,7851,0)="""RTN"",""IBCNICB"",155,0)"
^XMB(3.9,144657,2,7852,0)=" ;  IBFTF    - Data to be filed in the PLAN STANDARD FTF (#.16) field of"
^XMB(3.9,144657,2,7853,0)="""RTN"",""IBCNICB"",156,0)"
^XMB(3.9,144657,2,7854,0)=" ;             355.3 file (Optional)"
^XMB(3.9,144657,2,7855,0)="""RTN"",""IBCNICB"",157,0)"
^XMB(3.9,144657,2,7856,0)=" ;             Corresponds to the Internal Entry Number of the entry in "
^XMB(3.9,144657,2,7857,0)="""RTN"",""IBCNICB"",158,0)"
^XMB(3.9,144657,2,7858,0)=" ;             the INSURANCE FILING TIME FRAME (#355.13) File."
^XMB(3.9,144657,2,7859,0)="""RTN"",""IBCNICB"",159,0)"
^XMB(3.9,144657,2,7860,0)=" ;  IBFTFVAL - Data to be filed in the PLAN STANDARD FTF VALUE (#.17)"
^XMB(3.9,144657,2,7861,0)="""RTN"",""IBCNICB"",160,0)"
^XMB(3.9,144657,2,7862,0)=" ;             field of 355.3 file (Optional - Calling application "
^XMB(3.9,144657,2,7863,0)="""RTN"",""IBCNICB"",161,0)"
^XMB(3.9,144657,2,7864,0)=" ;             responsible to pass value if required for Plan Standard FTF) "
^XMB(3.9,144657,2,7865,0)="""RTN"",""IBCNICB"",162,0)"
^XMB(3.9,144657,2,7866,0)=" ;"
^XMB(3.9,144657,2,7867,0)="""RTN"",""IBCNICB"",163,0)"
^XMB(3.9,144657,2,7868,0)=" ;Output:"
^XMB(3.9,144657,2,7869,0)="""RTN"",""IBCNICB"",164,0)"
^XMB(3.9,144657,2,7870,0)=" ;  RESULT - Returned Parameter Array with results of call"
^XMB(3.9,144657,2,7871,0)="""RTN"",""IBCNICB"",165,0)"
^XMB(3.9,144657,2,7872,0)=" ;   RESULT = 0 ^ No data to update"
^XMB(3.9,144657,2,7873,0)="""RTN"",""IBCNICB"",166,0)"
^XMB(3.9,144657,2,7874,0)=" ;   RESULT(1) = -1^ error with Insurance Type (#2.312) file update"
^XMB(3.9,144657,2,7875,0)="""RTN"",""IBCNICB"",167,0)"
^XMB(3.9,144657,2,7876,0)=" ;   RESULT(1) = 0                   - Insurance Type update worked"
^XMB(3.9,144657,2,7877,0)="""RTN"",""IBCNICB"",168,0)"
^XMB(3.9,144657,2,7878,0)=" ;   RESULT(2) = -1^ error with GROUP INSURANCE PLAN (#355.3) file update"
^XMB(3.9,144657,2,7879,0)="""RTN"",""IBCNICB"",169,0)"
^XMB(3.9,144657,2,7880,0)=" ;   RESULT(2) = 0                   - Group Insurance Plan update worked"
^XMB(3.9,144657,2,7881,0)="""RTN"",""IBCNICB"",170,0)"
^XMB(3.9,144657,2,7882,0)=" ;"
^XMB(3.9,144657,2,7883,0)="""RTN"",""IBCNICB"",171,0)"
^XMB(3.9,144657,2,7884,0)=" ; Update Patient Policy Comment (#1.08) and/or "
^XMB(3.9,144657,2,7885,0)="""RTN"",""IBCNICB"",172,0)"
^XMB(3.9,144657,2,7886,0)=" ; Stop Policy From Billing (#3.04) fields in 2.312 subfile"
^XMB(3.9,144657,2,7887,0)="""RTN"",""IBCNICB"",173,0)"
^XMB(3.9,144657,2,7888,0)=" I $G(IBPOLCOM)]""""!($G(IBPOLBIL)]"""") D"
^XMB(3.9,144657,2,7889,0)="""RTN"",""IBCNICB"",174,0)"
^XMB(3.9,144657,2,7890,0)=" . N IBIENS,IBFDA"
^XMB(3.9,144657,2,7891,0)="""RTN"",""IBCNICB"",175,0)"
^XMB(3.9,144657,2,7892,0)=" . I $G(DFN)']"""" S RESULT(1)=""-1^PATIENT (#2) DFN not passed"" Q"
^XMB(3.9,144657,2,7893,0)="""RTN"",""IBCNICB"",176,0)"
^XMB(3.9,144657,2,7894,0)=" . I $G(IBPOLDA)'>0 S RESULT(1)=""-1^INSURANCE TYPE (#2.312) sub-file IEN not defined"" Q"
^XMB(3.9,144657,2,7895,0)="""RTN"",""IBCNICB"",177,0)"
^XMB(3.9,144657,2,7896,0)=" . I +IBPOLDA,$G(^DPT(DFN,.312,IBPOLDA,0))="""" S RESULT(0)=""-1^Passed Patient INSURANCE TYPE (#2.312) entry doesn't exist"" Q"
^XMB(3.9,144657,2,7897,0)="""RTN"",""IBCNICB"",178,0)"
^XMB(3.9,144657,2,7898,0)=" . L +^DPT(DFN,.312,IBPOLDA):5 I '$T S RESULT(1)=""-1^INSURANCE TYPE (#2.312) sub-file entry locked, data not updated"" Q"
^XMB(3.9,144657,2,7899,0)="""RTN"",""IBCNICB"",179,0)"
^XMB(3.9,144657,2,7900,0)=" . S IBIENS=+IBPOLDA_"",""_+DFN_"","""
^XMB(3.9,144657,2,7901,0)="""RTN"",""IBCNICB"",180,0)"
^XMB(3.9,144657,2,7902,0)=" . ; IB*2.0*549 Change IS THIS POLICY BILLABLE to STOP POLICY FROM BILLING"
^XMB(3.9,144657,2,7903,0)="""RTN"",""IBCNICB"",181,0)"
^XMB(3.9,144657,2,7904,0)=" . I $G(IBPOLBIL)]"""",$$EXTERNAL^DILFD(2.312,3.04,"""",IBPOLBIL)']"""" S RESULT(1)=""-1^STOP POLICY FROM BILLING (""_IBPOLBIL_"") not a valid value"",IBPOLBIL="""""
^XMB(3.9,144657,2,7905,0)="""RTN"",""IBCNICB"",182,0)"
^XMB(3.9,144657,2,7906,0)=" . S:$G(IBPOLBIL)]"""" IBFDA(2.312,IBIENS,3.04)=IBPOLBIL"
^XMB(3.9,144657,2,7907,0)="""RTN"",""IBCNICB"",183,0)"
^XMB(3.9,144657,2,7908,0)=" . I $D(IBFDA)>0 D FILE^DIE(,""IBFDA"") S:$D(RESULT(1))'>0 RESULT(1)=0"
^XMB(3.9,144657,2,7909,0)="""RTN"",""IBCNICB"",184,0)"
^XMB(3.9,144657,2,7910,0)=" . D PPCOMM(DFN,IBPOLDA,IBPOLCOM,.RESULT)"
^XMB(3.9,144657,2,7911,0)="""RTN"",""IBCNICB"",185,0)"
^XMB(3.9,144657,2,7912,0)=" . L -^DPT(DFN,.312,IBPOLDA)"
^XMB(3.9,144657,2,7913,0)="""RTN"",""IBCNICB"",186,0)"
^XMB(3.9,144657,2,7914,0)=" ;"
^XMB(3.9,144657,2,7915,0)="""RTN"",""IBCNICB"",187,0)"
^XMB(3.9,144657,2,7916,0)=" ; Update Plan Filing Time Frame (#.13), Electronic Plan Type (#.15)"
^XMB(3.9,144657,2,7917,0)="""RTN"",""IBCNICB"",188,0)"
^XMB(3.9,144657,2,7918,0)=" ; Plan Standard FTF (#.16), Plan Standard FTF Value (#.17), and/or"
^XMB(3.9,144657,2,7919,0)="""RTN"",""IBCNICB"",189,0)"
^XMB(3.9,144657,2,7920,0)=" ; Group Plan Comments (#11) fields in 355.3 file"
^XMB(3.9,144657,2,7921,0)="""RTN"",""IBCNICB"",190,0)"
^XMB(3.9,144657,2,7922,0)=" I $G(IBPLAN)]""""!($G(IBELEC)]"""")!($D(IBGPCOM)>0)!($G(IBFTF)]"""")!($G(IBFTFVAL)]"""") D"
^XMB(3.9,144657,2,7923,0)="""RTN"",""IBCNICB"",191,0)"
^XMB(3.9,144657,2,7924,0)=" . N IBIENS,IBFDA"
^XMB(3.9,144657,2,7925,0)="""RTN"",""IBCNICB"",192,0)"
^XMB(3.9,144657,2,7926,0)=" . I $G(IBGRPDA)'>0 S RESULT(2)=""-1^GROUP INSURANCE PLAN (#355.3) file IEN not defined"" Q"
^XMB(3.9,144657,2,7927,0)="""RTN"",""IBCNICB"",193,0)"
^XMB(3.9,144657,2,7928,0)=" . I +IBGRPDA,$G(^IBA(355.3,IBGRPDA,0))="""" S RESULT(2)=""-1^Passed GROUP INSURANCE PLAN (#355.3) entry doesn't exist"" Q"
^XMB(3.9,144657,2,7929,0)="""RTN"",""IBCNICB"",194,0)"
^XMB(3.9,144657,2,7930,0)=" . L +^IBA(355.3,IBGRPDA):5 I '$T S RESULT(2)=""-1^GROUP INSURANCE PLAN (#355.3) file entry locked, data not updated"" Q"
^XMB(3.9,144657,2,7931,0)="""RTN"",""IBCNICB"",195,0)"
^XMB(3.9,144657,2,7932,0)=" . S IBIENS=+IBGRPDA_"","""
^XMB(3.9,144657,2,7933,0)="""RTN"",""IBCNICB"",196,0)"
^XMB(3.9,144657,2,7934,0)=" . ; Consistency Checks for Plan Standard FTF and FTF VALUE fields"
^XMB(3.9,144657,2,7935,0)="""RTN"",""IBCNICB"",197,0)"
^XMB(3.9,144657,2,7936,0)=" . I $G(IBELEC)]"""",$$EXTERNAL^DILFD(355.3,.15,"""",IBELEC)']"""" S RESULT(2)=""-1^ELECTRONIC PLAN TYPE (""_IBELEC_"") not a valid value"",IBELEC="""""
^XMB(3.9,144657,2,7937,0)="""RTN"",""IBCNICB"",198,0)"
^XMB(3.9,144657,2,7938,0)=" . I $G(IBFTFVAL)]"""",$G(IBFTF)']"""" S RESULT(2)=""-1^PLAN STANDARD FTF should be passed with PLAN STANDARD FTF VALUE"",IBFTFVAL="""""
^XMB(3.9,144657,2,7939,0)="""RTN"",""IBCNICB"",199,0)"
^XMB(3.9,144657,2,7940,0)=" . I $G(IBFTF)]"""",$$EXTERNAL^DILFD(355.3,.16,"""",IBFTF)']"""" S RESULT(2)=""-1^PLAN STANDARD FTF (""_IBFTF_"") not a valid value"",IBFTF="""""
^XMB(3.9,144657,2,7941,0)="""RTN"",""IBCNICB"",200,0)"
^XMB(3.9,144657,2,7942,0)=" . I $G(IBFTF)]"""",$$GET1^DIQ(355.13,+IBFTF_"","",.02,""I"")=1,$G(IBFTFVAL)'>0 S RESULT(2)=""-1^Valid PLAN STANDARD FTF VALUE not passed for ""_$$GET1^DIQ(355.13,+IBFTF,.01,""E""),IBFTF="""",IBFTFVAL="""""
^XMB(3.9,144657,2,7943,0)="""RTN"",""IBCNICB"",201,0)"
^XMB(3.9,144657,2,7944,0)=" . ;"
^XMB(3.9,144657,2,7945,0)="""RTN"",""IBCNICB"",202,0)"
^XMB(3.9,144657,2,7946,0)=" . S:$G(IBPLAN)]"""" IBFDA(355.3,IBIENS,.13)=IBPLAN"
^XMB(3.9,144657,2,7947,0)="""RTN"",""IBCNICB"",203,0)"
^XMB(3.9,144657,2,7948,0)=" . S:$G(IBELEC)]"""" IBFDA(355.3,IBIENS,.15)=IBELEC"
^XMB(3.9,144657,2,7949,0)="""RTN"",""IBCNICB"",204,0)"
^XMB(3.9,144657,2,7950,0)=" . S:$G(IBFTF)]"""" IBFDA(355.3,IBIENS,.16)=IBFTF"
^XMB(3.9,144657,2,7951,0)="""RTN"",""IBCNICB"",205,0)"
^XMB(3.9,144657,2,7952,0)=" . S:$G(IBFTFVAL)]"""" IBFDA(355.3,IBIENS,.17)=IBFTFVAL"
^XMB(3.9,144657,2,7953,0)="""RTN"",""IBCNICB"",206,0)"
^XMB(3.9,144657,2,7954,0)=" . I $D(IBFDA)>0 D FILE^DIE(,""IBFDA"") S:$D(RESULT(2))'>0 RESULT(2)=0"
^XMB(3.9,144657,2,7955,0)="""RTN"",""IBCNICB"",207,0)"
^XMB(3.9,144657,2,7956,0)=" . ;"
^XMB(3.9,144657,2,7957,0)="""RTN"",""IBCNICB"",208,0)"
^XMB(3.9,144657,2,7958,0)=" . ; Update Group Plan Comments (#11) word processing field in 355.3 file"
^XMB(3.9,144657,2,7959,0)="""RTN"",""IBCNICB"",209,0)"
^XMB(3.9,144657,2,7960,0)=" . I $O(IBGPCOM(""""))>0 D WP^DIE(355.3,+IBGRPDA_"","",11,,""IBGPCOM"") S:$D(RESULT(2))'>0 RESULT(2)=0"
^XMB(3.9,144657,2,7961,0)="""RTN"",""IBCNICB"",210,0)"
^XMB(3.9,144657,2,7962,0)=" . L -^IBA(355.3,IBGRPDA)"
^XMB(3.9,144657,2,7963,0)="""RTN"",""IBCNICB"",211,0)"
^XMB(3.9,144657,2,7964,0)=" I $D(RESULT(1))'>0&($D(RESULT(2))'>0) S RESULT=""0^No data to update"""
^XMB(3.9,144657,2,7965,0)="""RTN"",""IBCNICB"",212,0)"
^XMB(3.9,144657,2,7966,0)=" Q"
^XMB(3.9,144657,2,7967,0)="""RTN"",""IBCNICB"",213,0)"
^XMB(3.9,144657,2,7968,0)=" ;"
^XMB(3.9,144657,2,7969,0)="""RTN"",""IBCNICB"",214,0)"
^XMB(3.9,144657,2,7970,0)="PPCOMM(DFN,IBPOLDA,IBPOLCOM,RESULT) ; ib*2*528   record patient policy comments"
^XMB(3.9,144657,2,7971,0)="""RTN"",""IBCNICB"",215,0)"
