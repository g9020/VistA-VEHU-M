^XMB(3.9,144657,2,7077,0)="""RTN"",""IBCNEUT2"",47,0)"
^XMB(3.9,144657,2,7078,0)=" D ^DIE"
^XMB(3.9,144657,2,7079,0)="""RTN"",""IBCNEUT2"",48,0)"
^XMB(3.9,144657,2,7080,0)=" Q"
^XMB(3.9,144657,2,7081,0)="""RTN"",""IBCNEUT2"",49,0)"
^XMB(3.9,144657,2,7082,0)=" ;"
^XMB(3.9,144657,2,7083,0)="""RTN"",""IBCNEUT2"",50,0)"
^XMB(3.9,144657,2,7084,0)="BADMSG(EXT,QUERY) ; Checks to see if the msg is allowed"
^XMB(3.9,144657,2,7085,0)="""RTN"",""IBCNEUT2"",51,0)"
^XMB(3.9,144657,2,7086,0)=" ; IB*713 Introduced this tag, checks for foreign characters as defined"
^XMB(3.9,144657,2,7087,0)="""RTN"",""IBCNEUT2"",52,0)"
^XMB(3.9,144657,2,7088,0)=" ;        in FOREIGN^IBCNINSU. If foreign characters are encountered, some "
^XMB(3.9,144657,2,7089,0)="""RTN"",""IBCNEUT2"",53,0)"
^XMB(3.9,144657,2,7090,0)=" ;        times the msg can't be created/sent via HL7. Other times, if you"
^XMB(3.9,144657,2,7091,0)="""RTN"",""IBCNEUT2"",54,0)"
^XMB(3.9,144657,2,7092,0)=" ;        clear out the field with the foreign character you can still send"
^XMB(3.9,144657,2,7093,0)="""RTN"",""IBCNEUT2"",55,0)"
^XMB(3.9,144657,2,7094,0)=" ;        the message.  (Watch for the STOP variable.)"
^XMB(3.9,144657,2,7095,0)="""RTN"",""IBCNEUT2"",56,0)"
^XMB(3.9,144657,2,7096,0)=" ;        This could be expanded in the future to check other scenarios that"
^XMB(3.9,144657,2,7097,0)="""RTN"",""IBCNEUT2"",57,0)"
^XMB(3.9,144657,2,7098,0)=" ;        should stop the transmissions."
^XMB(3.9,144657,2,7099,0)="""RTN"",""IBCNEUT2"",58,0)"
^XMB(3.9,144657,2,7100,0)=" ;"
^XMB(3.9,144657,2,7101,0)="""RTN"",""IBCNEUT2"",59,0)"
^XMB(3.9,144657,2,7102,0)=" ;INPUT:"
^XMB(3.9,144657,2,7103,0)="""RTN"",""IBCNEUT2"",60,0)"
^XMB(3.9,144657,2,7104,0)=" ;  EXT = WHICH EXTRACT (#365.1,.1)"
^XMB(3.9,144657,2,7105,0)="""RTN"",""IBCNEUT2"",61,0)"
^XMB(3.9,144657,2,7106,0)=" ;  QUERY = QUERY FLAG(#365.1,.11)"
^XMB(3.9,144657,2,7107,0)="""RTN"",""IBCNEUT2"",62,0)"
^XMB(3.9,144657,2,7108,0)=" ;  PID, IN1, HLFS, HLECH - existing global variables"
^XMB(3.9,144657,2,7109,0)="""RTN"",""IBCNEUT2"",63,0)"
^XMB(3.9,144657,2,7110,0)=" ;  GT1 global variable that may or may not exist"
^XMB(3.9,144657,2,7111,0)="""RTN"",""IBCNEUT2"",64,0)"
^XMB(3.9,144657,2,7112,0)=" ;"
^XMB(3.9,144657,2,7113,0)="""RTN"",""IBCNEUT2"",65,0)"
^XMB(3.9,144657,2,7114,0)=" ;OUTPUT: 0 - Continue with creating and sending HL7 msg"
^XMB(3.9,144657,2,7115,0)="""RTN"",""IBCNEUT2"",66,0)"
^XMB(3.9,144657,2,7116,0)=" ;        1 - Do not send this TQ entry out as a HL7 msg"
^XMB(3.9,144657,2,7117,0)="""RTN"",""IBCNEUT2"",67,0)"
^XMB(3.9,144657,2,7118,0)=" ;            * NOTE: If Abort, this function sets the"
^XMB(3.9,144657,2,7119,0)="""RTN"",""IBCNEUT2"",68,0)"
^XMB(3.9,144657,2,7120,0)=" ;              TRANSMISSION QUEUE (#365.1,.04) to ""Cancelled"""
^XMB(3.9,144657,2,7121,0)="""RTN"",""IBCNEUT2"",69,0)"
^XMB(3.9,144657,2,7122,0)=" ;"
^XMB(3.9,144657,2,7123,0)="""RTN"",""IBCNEUT2"",70,0)"
^XMB(3.9,144657,2,7124,0)=" N FLD,HCT,SEG,STOP,TMP"
^XMB(3.9,144657,2,7125,0)="""RTN"",""IBCNEUT2"",71,0)"
^XMB(3.9,144657,2,7126,0)=" S HCT="""",STOP=0"
^XMB(3.9,144657,2,7127,0)="""RTN"",""IBCNEUT2"",72,0)"
^XMB(3.9,144657,2,7128,0)=" F  S HCT=$O(^TMP(""HLS"",$J,HCT)) Q:'HCT  S SEG=$P(^(HCT),HLFS,1),TMP(SEG)=HCT"
^XMB(3.9,144657,2,7129,0)="""RTN"",""IBCNEUT2"",73,0)"
^XMB(3.9,144657,2,7130,0)=" ;"
^XMB(3.9,144657,2,7131,0)="""RTN"",""IBCNEUT2"",74,0)"
^XMB(3.9,144657,2,7132,0)=" ; Regular 270 Messages"
^XMB(3.9,144657,2,7133,0)="""RTN"",""IBCNEUT2"",75,0)"
^XMB(3.9,144657,2,7134,0)=" I (EXT=1)!(EXT=2)!(EXT=5)!(EXT=6) D  G BADMSGX"
^XMB(3.9,144657,2,7135,0)="""RTN"",""IBCNEUT2"",76,0)"
^XMB(3.9,144657,2,7136,0)=" . I $$FOREIGN^IBCNINSU($P(PID,HLFS,6),""1;2;3;4;5;6"") S STOP=1 Q   ;PID-5 PATIENT NAME"
^XMB(3.9,144657,2,7137,0)="""RTN"",""IBCNEUT2"",77,0)"
^XMB(3.9,144657,2,7138,0)=" . I $$FOREIGN^IBCNINSU($P(IN1,HLFS,3)) S STOP=1 Q                 ;IN1-2 PATIENT/SUBSCRIBER ID"
^XMB(3.9,144657,2,7139,0)="""RTN"",""IBCNEUT2"",78,0)"
^XMB(3.9,144657,2,7140,0)=" . I $D(GT1) D  I STOP Q"
^XMB(3.9,144657,2,7141,0)="""RTN"",""IBCNEUT2"",79,0)"
^XMB(3.9,144657,2,7142,0)=" .. I $$FOREIGN^IBCNINSU($P(GT1,HLFS,3)) S STOP=1 Q                ;GT1-2 SUBSCRIBER ID"
^XMB(3.9,144657,2,7143,0)="""RTN"",""IBCNEUT2"",80,0)"
^XMB(3.9,144657,2,7144,0)=" .. I $$FOREIGN^IBCNINSU($P(GT1,HLFS,4),""1;2;3;4;5;6"") S STOP=1 Q  ;GT1-3 SUBSCRIBER NAME"
