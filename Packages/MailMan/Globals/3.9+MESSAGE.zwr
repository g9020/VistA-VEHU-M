^XMB(3.9,145834,2,668,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,669,0)="""RTN"",""MAGBRTE4"",9,0)"
^XMB(3.9,145834,2,670,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,671,0)="""RTN"",""MAGBRTE4"",10,0)"
^XMB(3.9,145834,2,672,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,673,0)="""RTN"",""MAGBRTE4"",11,0)"
^XMB(3.9,145834,2,674,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,675,0)="""RTN"",""MAGBRTE4"",12,0)"
^XMB(3.9,145834,2,676,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,677,0)="""RTN"",""MAGBRTE4"",13,0)"
^XMB(3.9,145834,2,678,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,679,0)="""RTN"",""MAGBRTE4"",14,0)"
