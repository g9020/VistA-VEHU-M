^XMB(3.9,144657,2,1069,0)="""RTN"",""IBCNBAA"",238,0)"
^XMB(3.9,144657,2,1070,0)="REPL() ; ask user if they want to replace eligibility/benefits data in pt. insuarance"
^XMB(3.9,144657,2,1071,0)="""RTN"",""IBCNBAA"",239,0)"
^XMB(3.9,144657,2,1072,0)=" N DIR,X,Y,IBX"
