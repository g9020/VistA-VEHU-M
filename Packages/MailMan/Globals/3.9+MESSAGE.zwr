^XMB(3.9,145838,2,1051,0)="""RTN"",""FBP192R"",45,0)"
^XMB(3.9,145838,2,1052,0)=" ;Added for v2"
^XMB(3.9,145838,2,1053,0)="""RTN"",""FBP192R"",46,0)"
^XMB(3.9,145838,2,1054,0)=" S LIST(""FBCNH DISPLAY 7078"")=""S DIC(""""S"""")=""""I $P(^(0),U,11)=7"""" D OUTP^FBCH78""   ;FBCNH DISPLAY 7078"
^XMB(3.9,145838,2,1055,0)="""RTN"",""FBP192R"",47,0)"
