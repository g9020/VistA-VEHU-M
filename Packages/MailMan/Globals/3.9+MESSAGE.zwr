^XMB(3.9,144657,2,893,0)="""RTN"",""IBCNBAA"",150,0)"
^XMB(3.9,144657,2,894,0)="PROCESS ; process all changes selected by user, add/edit insurance files based on buffer data, cleanup, ..."
