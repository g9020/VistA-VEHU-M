^XMB(3.9,144661,2,532,0)=" S ORAMLEN=$L($G(ORAMINR),""^""),ORAMRI=0"
^XMB(3.9,144661,2,533,0)="""RTN"",""ORAM1"",147,0)"
^XMB(3.9,144661,2,534,0)=" F ORAMPI=1:2:ORAMLEN D"
