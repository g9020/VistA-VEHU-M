^XMB(3.9,145833,2,2046,0)=" Q"
^XMB(3.9,145833,2,2047,0)="""RTN"",""SDES2UTIL"",392,0)"
^XMB(3.9,145833,2,2048,0)=" ;"
^XMB(3.9,145833,2,2049,0)="""RTN"",""SDES2UTIL"",393,0)"
^XMB(3.9,145833,2,2050,0)="GETSUB(TXT)  ;"
^XMB(3.9,145833,2,2051,0)="""RTN"",""SDES2UTIL"",394,0)"
^XMB(3.9,145833,2,2052,0)=" ; Output - Prior Number or Text with ~ delimiter"
^XMB(3.9,145833,2,2053,0)="""RTN"",""SDES2UTIL"",395,0)"
^XMB(3.9,145833,2,2054,0)=" ; Input - Number or Text"
^XMB(3.9,145833,2,2055,0)="""RTN"",""SDES2UTIL"",396,0)"
^XMB(3.9,145833,2,2056,0)=" N LAST"
^XMB(3.9,145833,2,2057,0)="""RTN"",""SDES2UTIL"",397,0)"
^XMB(3.9,145833,2,2058,0)=" S LAST="""""
^XMB(3.9,145833,2,2059,0)="""RTN"",""SDES2UTIL"",398,0)"
^XMB(3.9,145833,2,2060,0)=" I TXT?1.N S LAST=TXT-1 Q LAST ;- handle numeric"
^XMB(3.9,145833,2,2061,0)="""RTN"",""SDES2UTIL"",399,0)"
^XMB(3.9,145833,2,2062,0)=" S LAST=$E(TXT,$L(TXT))"
^XMB(3.9,145833,2,2063,0)="""RTN"",""SDES2UTIL"",400,0)"
^XMB(3.9,145833,2,2064,0)=" S LAST=$C($A(LAST)-1)"
^XMB(3.9,145833,2,2065,0)="""RTN"",""SDES2UTIL"",401,0)"
^XMB(3.9,145833,2,2066,0)=" S LAST=$E(TXT,1,$L(TXT)-1)_LAST_""~"""
^XMB(3.9,145833,2,2067,0)="""RTN"",""SDES2UTIL"",402,0)"
^XMB(3.9,145833,2,2068,0)=" Q LAST"
^XMB(3.9,145833,2,2069,0)="""RTN"",""SDES2UTIL"",403,0)"
^XMB(3.9,145833,2,2070,0)=" ;"
^XMB(3.9,145833,2,2071,0)="""RTN"",""SDES2UTIL"",404,0)"
^XMB(3.9,145833,2,2072,0)="FILEMANTOHL7(FILEMANDATETIME,DATEWITHOFFSET,EXCLUDETZ) ;Convert FM date/time to HL7 format - supported ICR #10103"
^XMB(3.9,145833,2,2073,0)="""RTN"",""SDES2UTIL"",405,0)"
^XMB(3.9,145833,2,2074,0)=" N HOUR,CONVERTHOUR"
^XMB(3.9,145833,2,2075,0)="""RTN"",""SDES2UTIL"",406,0)"
^XMB(3.9,145833,2,2076,0)=" S DATEWITHOFFSET=FILEMANDATETIME"
^XMB(3.9,145833,2,2077,0)="""RTN"",""SDES2UTIL"",407,0)"
^XMB(3.9,145833,2,2078,0)=" Q:'$L($G(FILEMANDATETIME))"
^XMB(3.9,145833,2,2079,0)="""RTN"",""SDES2UTIL"",408,0)"
^XMB(3.9,145833,2,2080,0)=" S DATEWITHOFFSET=+DATEWITHOFFSET ;Make sure a cononic number"
^XMB(3.9,145833,2,2081,0)="""RTN"",""SDES2UTIL"",409,0)"
^XMB(3.9,145833,2,2082,0)=" Q:(DATEWITHOFFSET<1410102)!(DATEWITHOFFSET>4141015.235959) -1"
^XMB(3.9,145833,2,2083,0)="""RTN"",""SDES2UTIL"",410,0)"
^XMB(3.9,145833,2,2084,0)=" S HOUR=$P(DATEWITHOFFSET,""."",2),DATEWITHOFFSET=$P(DATEWITHOFFSET,""."")"
^XMB(3.9,145833,2,2085,0)="""RTN"",""SDES2UTIL"",411,0)"
^XMB(3.9,145833,2,2086,0)=" S CONVERTHOUR=$E(HOUR,1,2)"
^XMB(3.9,145833,2,2087,0)="""RTN"",""SDES2UTIL"",412,0)"
^XMB(3.9,145833,2,2088,0)=" I CONVERTHOUR>=24 D"
^XMB(3.9,145833,2,2089,0)="""RTN"",""SDES2UTIL"",413,0)"
^XMB(3.9,145833,2,2090,0)=" . S DATEWITHOFFSET=$$FMADD^XLFDT($P(DATEWITHOFFSET,"".""),1)"
^XMB(3.9,145833,2,2091,0)="""RTN"",""SDES2UTIL"",414,0)"
^XMB(3.9,145833,2,2092,0)=" . S CONVERTHOUR=CONVERTHOUR-24"
^XMB(3.9,145833,2,2093,0)="""RTN"",""SDES2UTIL"",415,0)"
^XMB(3.9,145833,2,2094,0)=" . S $E(HOUR,1,2)=$S($L(CONVERTHOUR)=2:CONVERTHOUR,1:""0""_CONVERTHOUR)"
^XMB(3.9,145833,2,2095,0)="""RTN"",""SDES2UTIL"",416,0)"
^XMB(3.9,145833,2,2096,0)=" . S FILEMANDATETIME=DATEWITHOFFSET_"".""_$S($L(CONVERTHOUR)=2:CONVERTHOUR,1:""0""_CONVERTHOUR)"
^XMB(3.9,145833,2,2097,0)="""RTN"",""SDES2UTIL"",417,0)"
^XMB(3.9,145833,2,2098,0)=" S:DATEWITHOFFSET>1 DATEWITHOFFSET=DATEWITHOFFSET+17000000"
^XMB(3.9,145833,2,2099,0)="""RTN"",""SDES2UTIL"",418,0)"
^XMB(3.9,145833,2,2100,0)=" I $L(HOUR) S HOUR=$S($L(HOUR)>4:$E(HOUR_""00"",1,6),1:$E(HOUR_""0000"",1,4))"
^XMB(3.9,145833,2,2101,0)="""RTN"",""SDES2UTIL"",419,0)"
^XMB(3.9,145833,2,2102,0)=" I $L(HOUR) S DATEWITHOFFSET=DATEWITHOFFSET_HOUR S:'$G(EXCLUDETZ) DATEWITHOFFSET=DATEWITHOFFSET_$$TZ^XLFDT()"
^XMB(3.9,145833,2,2103,0)="""RTN"",""SDES2UTIL"",420,0)"
^XMB(3.9,145833,2,2104,0)=" Q"
^XMB(3.9,145833,2,2105,0)="""RTN"",""SDES2UTIL"",421,0)"
^XMB(3.9,145833,2,2106,0)=" ;"
^XMB(3.9,145833,2,2107,0)="""RTN"",""SDESUTIL"")"
