^XMB(3.9,145833,2,746,0)=" S SDGMT=$E(SDDTM,1,4)_""-""_$E(SDDTM,5,6)_""-""_$E(SDDTM,7,8)"
^XMB(3.9,145833,2,747,0)="""RTN"",""SDES2UTDT"",18,0)"
^XMB(3.9,145833,2,748,0)=" ;if time is included, extract and convert to ISO 8601 external format"
^XMB(3.9,145833,2,749,0)="""RTN"",""SDES2UTDT"",19,0)"
^XMB(3.9,145833,2,750,0)=" I $L(SDDTM)>8 D"
^XMB(3.9,145833,2,751,0)="""RTN"",""SDES2UTDT"",20,0)"
^XMB(3.9,145833,2,752,0)=" .S SDTIME=$E(+SDDTM,9,99)"
^XMB(3.9,145833,2,753,0)="""RTN"",""SDES2UTDT"",21,0)"
^XMB(3.9,145833,2,754,0)=" .;S SDTIME=$$REMOVEOFFSET(SDTIME)"
