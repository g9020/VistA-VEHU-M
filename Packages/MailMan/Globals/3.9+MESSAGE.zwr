^XMB(3.9,145834,2,2873,0)="""RTN"",""MAGDSTA1"",113,0)"
^XMB(3.9,145834,2,2874,0)=" . . . K ^TMP(""MAG"",$J,""BATCH Q/R"",""PATIENT DFN"")"
^XMB(3.9,145834,2,2875,0)="""RTN"",""MAGDSTA1"",114,0)"
