^XMB(3.9,145834,2,2931,0)="""RTN"",""MAGDSTA1"",142,0)"
^XMB(3.9,145834,2,2932,0)=" S X=0"
^XMB(3.9,145834,2,2933,0)="""RTN"",""MAGDSTA1"",143,0)"
^XMB(3.9,145834,2,2934,0)=" I IMAGINGSERVICE=""CONSULTS"" D"
