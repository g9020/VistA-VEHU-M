^XMB(3.9,145833,2,829,0)="""RTN"",""SDES2UTDT"",59,0)"
^XMB(3.9,145833,2,830,0)=" .;exclude time if 0's else FMTE returns previous date with .24"
^XMB(3.9,145833,2,831,0)="""RTN"",""SDES2UTDT"",60,0)"
^XMB(3.9,145833,2,832,0)=" .;S SDTIME=$$REMOVEOFFSET(SDTIME)"
^XMB(3.9,145833,2,833,0)="""RTN"",""SDES2UTDT"",61,0)"
^XMB(3.9,145833,2,834,0)=" .S SDTIME=$P(SDTIME,""-"")"
^XMB(3.9,145833,2,835,0)="""RTN"",""SDES2UTDT"",62,0)"
^XMB(3.9,145833,2,836,0)=" .S SDTIME=$P(SDTIME,""+"")"
^XMB(3.9,145833,2,837,0)="""RTN"",""SDES2UTDT"",63,0)"
^XMB(3.9,145833,2,838,0)=" .S SDTIME=$P(SDTIME,""Z"")"
^XMB(3.9,145833,2,839,0)="""RTN"",""SDES2UTDT"",64,0)"
^XMB(3.9,145833,2,840,0)=" .S SDTIME=$P(SDTIME,""."")  ;No ractional seconds"
^XMB(3.9,145833,2,841,0)="""RTN"",""SDES2UTDT"",65,0)"
^XMB(3.9,145833,2,842,0)=" .S SDTIME=$TR(SDTIME,"":"")"
^XMB(3.9,145833,2,843,0)="""RTN"",""SDES2UTDT"",66,0)"
^XMB(3.9,145833,2,844,0)=" .I +SDTIME=0 Q"
^XMB(3.9,145833,2,845,0)="""RTN"",""SDES2UTDT"",67,0)"
^XMB(3.9,145833,2,846,0)=" .;Get the correct offset"
^XMB(3.9,145833,2,847,0)="""RTN"",""SDES2UTDT"",68,0)"
^XMB(3.9,145833,2,848,0)=" .;S TMPFM=$$CVTTOFM(SDGMTDT)  ;Need a FM format of the ISO date that is passed in"
^XMB(3.9,145833,2,849,0)="""RTN"",""SDES2UTDT"",69,0)"
^XMB(3.9,145833,2,850,0)=" .N X,Y,%DT"
^XMB(3.9,145833,2,851,0)="""RTN"",""SDES2UTDT"",70,0)"
^XMB(3.9,145833,2,852,0)=" .S %DT="""""
^XMB(3.9,145833,2,853,0)="""RTN"",""SDES2UTDT"",71,0)"
^XMB(3.9,145833,2,854,0)=" .S X=SDFM"
^XMB(3.9,145833,2,855,0)="""RTN"",""SDES2UTDT"",72,0)"
^XMB(3.9,145833,2,856,0)=" .D ^%DT"
^XMB(3.9,145833,2,857,0)="""RTN"",""SDES2UTDT"",73,0)"
^XMB(3.9,145833,2,858,0)=" .S TMPFM=Y"
^XMB(3.9,145833,2,859,0)="""RTN"",""SDES2UTDT"",74,0)"
^XMB(3.9,145833,2,860,0)=" .I Y=-1 Q  ;vse-2645 date is invalid so leave do dot logic and quit below"
^XMB(3.9,145833,2,861,0)="""RTN"",""SDES2UTDT"",75,0)"
^XMB(3.9,145833,2,862,0)=" .; IF ZULU reset SDGMTDT to match system time"
^XMB(3.9,145833,2,863,0)="""RTN"",""SDES2UTDT"",76,0)"
^XMB(3.9,145833,2,864,0)=" .I SDGMTDT[""Z""!(SDGMTDT[""+0000"") D"
^XMB(3.9,145833,2,865,0)="""RTN"",""SDES2UTDT"",77,0)"
^XMB(3.9,145833,2,866,0)=" ..;S SDOFFSET=$$GETOFFSET(TMPFM,SDCLINIC)"
^XMB(3.9,145833,2,867,0)="""RTN"",""SDES2UTDT"",78,0)"
^XMB(3.9,145833,2,868,0)=" ..D GETTZOFFSET^SDES2UTIL(.SDOFFSET,TMPFM,1,SDCLINIC)"
^XMB(3.9,145833,2,869,0)="""RTN"",""SDES2UTDT"",79,0)"
^XMB(3.9,145833,2,870,0)=" ..I SDOFFSET=-1 S SDOFFSET=-9999"
^XMB(3.9,145833,2,871,0)="""RTN"",""SDES2UTDT"",80,0)"
^XMB(3.9,145833,2,872,0)=" .E  D"
^XMB(3.9,145833,2,873,0)="""RTN"",""SDES2UTDT"",81,0)"
^XMB(3.9,145833,2,874,0)=" ..;S SDISOOFFSET=$$GETISOOFFSET(SDGMTDT)"
^XMB(3.9,145833,2,875,0)="""RTN"",""SDES2UTDT"",82,0)"
^XMB(3.9,145833,2,876,0)=" ..S ISOOFFSET=$P(SDGMTDT,""+"",2),SDISOOFFSET="""""
^XMB(3.9,145833,2,877,0)="""RTN"",""SDES2UTDT"",83,0)"
^XMB(3.9,145833,2,878,0)=" ..I ISOOFFSET'="""" S SDISOOFFSET=""+""_ISOOFFSET"
^XMB(3.9,145833,2,879,0)="""RTN"",""SDES2UTDT"",84,0)"
^XMB(3.9,145833,2,880,0)=" ..I SDISOOFFSET="""" S SDISOOFFSET=""-""_$P(SDISOTIME,""-"",2)"
^XMB(3.9,145833,2,881,0)="""RTN"",""SDES2UTDT"",85,0)"
^XMB(3.9,145833,2,882,0)=" ..S SDISOOFFSET=$TR(SDISOOFFSET,"":"")"
^XMB(3.9,145833,2,883,0)="""RTN"",""SDES2UTDT"",86,0)"
^XMB(3.9,145833,2,884,0)=" ..;"
^XMB(3.9,145833,2,885,0)="""RTN"",""SDES2UTDT"",87,0)"
^XMB(3.9,145833,2,886,0)=" ..D GETOFFSETDIFF(.SDOFFSET,TMPFM,SDCLINIC,SDISOOFFSET,1)"
^XMB(3.9,145833,2,887,0)="""RTN"",""SDES2UTDT"",88,0)"
^XMB(3.9,145833,2,888,0)=" .;Build HLT formatted date with offset (Flip the sign on offset)"
^XMB(3.9,145833,2,889,0)="""RTN"",""SDES2UTDT"",89,0)"
^XMB(3.9,145833,2,890,0)=" .D FLIPOFFSET(.SDOFFSET)"
^XMB(3.9,145833,2,891,0)="""RTN"",""SDES2UTDT"",90,0)"
^XMB(3.9,145833,2,892,0)=" .S SDFM=SDFM_SDTIME_SDOFFSET"
^XMB(3.9,145833,2,893,0)="""RTN"",""SDES2UTDT"",91,0)"
^XMB(3.9,145833,2,894,0)=" I TMPFM=-1 S SDFMDTM=-1 Q"
^XMB(3.9,145833,2,895,0)="""RTN"",""SDES2UTDT"",92,0)"
^XMB(3.9,145833,2,896,0)=" I SDFM[""-9999""!(POP) S SDFMDTM=-1 Q"
^XMB(3.9,145833,2,897,0)="""RTN"",""SDES2UTDT"",93,0)"
^XMB(3.9,145833,2,898,0)=" ;"
^XMB(3.9,145833,2,899,0)="""RTN"",""SDES2UTDT"",94,0)"
^XMB(3.9,145833,2,900,0)=" ;convert date(/time) from HL7 format back to Fileman"
^XMB(3.9,145833,2,901,0)="""RTN"",""SDES2UTDT"",95,0)"
^XMB(3.9,145833,2,902,0)=" I +SDOFFSET S SDFMDTM=$$HL7TFM^XLFDT(SDFM,""U"")"
^XMB(3.9,145833,2,903,0)="""RTN"",""SDES2UTDT"",96,0)"
^XMB(3.9,145833,2,904,0)=" I '(+SDOFFSET) S SDFMDTM=$$HL7TFM^XLFDT(SDFM)"
^XMB(3.9,145833,2,905,0)="""RTN"",""SDES2UTDT"",97,0)"
^XMB(3.9,145833,2,906,0)=" Q:SDFMDTM<0  ;error occurred in conversion"
^XMB(3.9,145833,2,907,0)="""RTN"",""SDES2UTDT"",98,0)"
^XMB(3.9,145833,2,908,0)=" ;check validity of date (including leap year check)"
^XMB(3.9,145833,2,909,0)="""RTN"",""SDES2UTDT"",99,0)"
^XMB(3.9,145833,2,910,0)=" S X=$$FMTE^XLFDT(SDFMDTM)"
^XMB(3.9,145833,2,911,0)="""RTN"",""SDES2UTDT"",100,0)"
^XMB(3.9,145833,2,912,0)=" D ^%DT"
^XMB(3.9,145833,2,913,0)="""RTN"",""SDES2UTDT"",101,0)"
^XMB(3.9,145833,2,914,0)=" S:Y<0 SDFMDTM=-1 ;date(/time) not valid"
^XMB(3.9,145833,2,915,0)="""RTN"",""SDES2UTDT"",102,0)"
^XMB(3.9,145833,2,916,0)=" Q"
^XMB(3.9,145833,2,917,0)="""RTN"",""SDES2UTDT"",103,0)"
^XMB(3.9,145833,2,918,0)=" ;"
^XMB(3.9,145833,2,919,0)="""RTN"",""SDES2UTDT"",104,0)"
^XMB(3.9,145833,2,920,0)="REMOVEOFFSET(TIME,RETURN) ;"
^XMB(3.9,145833,2,921,0)="""RTN"",""SDES2UTDT"",105,0)"
^XMB(3.9,145833,2,922,0)=" S RETURN=$P(TIME,""-"")"
^XMB(3.9,145833,2,923,0)="""RTN"",""SDES2UTDT"",106,0)"
^XMB(3.9,145833,2,924,0)=" S RETURN=$P(RETURN,""+"")"
^XMB(3.9,145833,2,925,0)="""RTN"",""SDES2UTDT"",107,0)"
^XMB(3.9,145833,2,926,0)=" S RETURN=$P(RETURN,""Z"")"
^XMB(3.9,145833,2,927,0)="""RTN"",""SDES2UTDT"",108,0)"
^XMB(3.9,145833,2,928,0)=" Q"
^XMB(3.9,145833,2,929,0)="""RTN"",""SDES2UTDT"",109,0)"
^XMB(3.9,145833,2,930,0)=" ;"
^XMB(3.9,145833,2,931,0)="""RTN"",""SDES2UTDT"",110,0)"
^XMB(3.9,145833,2,932,0)="GETISOOFFSET(DATE,ISOFOOSET) ;"
^XMB(3.9,145833,2,933,0)="""RTN"",""SDES2UTDT"",111,0)"
^XMB(3.9,145833,2,934,0)=" N OFFSET"
^XMB(3.9,145833,2,935,0)="""RTN"",""SDES2UTDT"",112,0)"
^XMB(3.9,145833,2,936,0)=" S ISOOFFSET="""""
^XMB(3.9,145833,2,937,0)="""RTN"",""SDES2UTDT"",113,0)"
^XMB(3.9,145833,2,938,0)=" S OFFSET=$P(DATE,""+"",2)"
^XMB(3.9,145833,2,939,0)="""RTN"",""SDES2UTDT"",114,0)"
^XMB(3.9,145833,2,940,0)=" I OFFSET'="""" S ISOOFFSET=""+""_OFFSET"
^XMB(3.9,145833,2,941,0)="""RTN"",""SDES2UTDT"",115,0)"
^XMB(3.9,145833,2,942,0)=" I ISOOFFSET="""" S ISOOFFSET=""-""_$P($P(DATE,""T"",2),""-"",2)"
^XMB(3.9,145833,2,943,0)="""RTN"",""SDES2UTDT"",116,0)"
^XMB(3.9,145833,2,944,0)=" S ISOOFFSET=$TR(ISOOFFSET,"":"")"
^XMB(3.9,145833,2,945,0)="""RTN"",""SDES2UTDT"",117,0)"
^XMB(3.9,145833,2,946,0)=" Q"
^XMB(3.9,145833,2,947,0)="""RTN"",""SDES2UTDT"",118,0)"
^XMB(3.9,145833,2,948,0)="GETOFFSET(DATE,SDCLINIC) ;"
^XMB(3.9,145833,2,949,0)="""RTN"",""SDES2UTDT"",119,0)"
^XMB(3.9,145833,2,950,0)=" N OFFSET"
^XMB(3.9,145833,2,951,0)="""RTN"",""SDES2UTDT"",120,0)"
^XMB(3.9,145833,2,952,0)=" S OFFSET="""""
^XMB(3.9,145833,2,953,0)="""RTN"",""SDES2UTDT"",121,0)"
^XMB(3.9,145833,2,954,0)=" ;Clinc can be in a different time zone"
^XMB(3.9,145833,2,955,0)="""RTN"",""SDES2UTDT"",122,0)"
^XMB(3.9,145833,2,956,0)=" I $G(SDCLINIC) S OFFSET=$$GETTZOFFSET^SDESUTIL(DATE,SDCLINIC)"
^XMB(3.9,145833,2,957,0)="""RTN"",""SDES2UTDT"",123,0)"
^XMB(3.9,145833,2,958,0)=" ;get offset for VistA Instance"
^XMB(3.9,145833,2,959,0)="""RTN"",""SDES2UTDT"",124,0)"
^XMB(3.9,145833,2,960,0)=" I OFFSET="""" S OFFSET=$$GETTZOFFSET^SDESUTIL(DATE)"
^XMB(3.9,145833,2,961,0)="""RTN"",""SDES2UTDT"",125,0)"
^XMB(3.9,145833,2,962,0)=" I OFFSET=-1 S OFFSET=""BAD OFFSET"""
^XMB(3.9,145833,2,963,0)="""RTN"",""SDES2UTDT"",126,0)"
^XMB(3.9,145833,2,964,0)=" Q OFFSET"
^XMB(3.9,145833,2,965,0)="""RTN"",""SDES2UTDT"",127,0)"
^XMB(3.9,145833,2,966,0)=" ;"
^XMB(3.9,145833,2,967,0)="""RTN"",""SDES2UTDT"",128,0)"
^XMB(3.9,145833,2,968,0)="GETOFFSETDIFF(OFFSET,DATE,SDCLINIC,SDISOOFFSET,VALIDDATE) ;Compare offsets and return the difference"
^XMB(3.9,145833,2,969,0)="""RTN"",""SDES2UTDT"",129,0)"
^XMB(3.9,145833,2,970,0)=" N SDCLNOFFSET,SDSYSOFFSET,TMPOFFSET"
^XMB(3.9,145833,2,971,0)="""RTN"",""SDES2UTDT"",130,0)"
^XMB(3.9,145833,2,972,0)=" S (OFFSET,SDCLNOFFSET)="""""
^XMB(3.9,145833,2,973,0)="""RTN"",""SDES2UTDT"",131,0)"
^XMB(3.9,145833,2,974,0)=" ;S (TMPOFFSET,SDSYSOFFSET)=$$GETOFFSET(DATE)"
^XMB(3.9,145833,2,975,0)="""RTN"",""SDES2UTDT"",132,0)"
^XMB(3.9,145833,2,976,0)=" D GETTZOFFSET^SDES2UTIL(.SDSYSOFFSET,DATE,$G(VALIDDATE))"
^XMB(3.9,145833,2,977,0)="""RTN"",""SDES2UTDT"",133,0)"
^XMB(3.9,145833,2,978,0)=" S TMPOFFSET=SDSYSOFFSET"
^XMB(3.9,145833,2,979,0)="""RTN"",""SDES2UTDT"",134,0)"
^XMB(3.9,145833,2,980,0)=" ;I $G(SDCLINIC) S (TMPOFFSET,SDCLNOFFSET)=$$GETOFFSET(DATE,SDCLINIC)"
^XMB(3.9,145833,2,981,0)="""RTN"",""SDES2UTDT"",135,0)"
^XMB(3.9,145833,2,982,0)=" I $G(SDCLINIC) D GETTZOFFSET^SDES2UTIL(.SDCLNOFFSET,DATE,1,SDCLINIC) S TMPOFFSET=SDCLNOFFSET"
^XMB(3.9,145833,2,983,0)="""RTN"",""SDES2UTDT"",136,0)"
^XMB(3.9,145833,2,984,0)=" I TMPOFFSET=-1 Q ""-9999"""
^XMB(3.9,145833,2,985,0)="""RTN"",""SDES2UTDT"",137,0)"
^XMB(3.9,145833,2,986,0)=" I $E(SDISOOFFSET)?1N S SDISOOFFSET=""+""_SDISOOFFSET"
^XMB(3.9,145833,2,987,0)="""RTN"",""SDES2UTDT"",138,0)"
^XMB(3.9,145833,2,988,0)=" ;If called from ISOTFM and ISO offset is different from the Clinic/System offset"
^XMB(3.9,145833,2,989,0)="""RTN"",""SDES2UTDT"",139,0)"
^XMB(3.9,145833,2,990,0)=" I $G(SDISOOFFSET)'="""",SDISOOFFSET'=TMPOFFSET D"
^XMB(3.9,145833,2,991,0)="""RTN"",""SDES2UTDT"",140,0)"
^XMB(3.9,145833,2,992,0)=" .S OFFSET=TMPOFFSET-SDISOOFFSET"
^XMB(3.9,145833,2,993,0)="""RTN"",""SDES2UTDT"",141,0)"
^XMB(3.9,145833,2,994,0)=" ;"
^XMB(3.9,145833,2,995,0)="""RTN"",""SDES2UTDT"",142,0)"
^XMB(3.9,145833,2,996,0)=" I $G(SDISOOFFSET)="""",SDSYSOFFSET'=SDCLNOFFSET D"
^XMB(3.9,145833,2,997,0)="""RTN"",""SDES2UTDT"",143,0)"
^XMB(3.9,145833,2,998,0)=" .S OFFSET=SDCLNOFFSET-SDSYSOFFSET"
^XMB(3.9,145833,2,999,0)="""RTN"",""SDES2UTDT"",144,0)"
^XMB(3.9,145833,2,1000,0)=" S:OFFSET=0 OFFSET="""""
^XMB(3.9,145833,2,1001,0)="""RTN"",""SDES2UTDT"",145,0)"
^XMB(3.9,145833,2,1002,0)=" Q"
^XMB(3.9,145833,2,1003,0)="""RTN"",""SDES2UTDT"",146,0)"
^XMB(3.9,145833,2,1004,0)=" ;"
^XMB(3.9,145833,2,1005,0)="""RTN"",""SDES2UTDT"",147,0)"
^XMB(3.9,145833,2,1006,0)="FLIPOFFSET(OFFSET) ;Need to flip the sign because HL7TFM will flip it back."
^XMB(3.9,145833,2,1007,0)="""RTN"",""SDES2UTDT"",148,0)"
^XMB(3.9,145833,2,1008,0)=" Q:+OFFSET=0 """""
^XMB(3.9,145833,2,1009,0)="""RTN"",""SDES2UTDT"",149,0)"
