^XMB(3.9,145839,2,289,0)="""RTN"",""TIUCCHL7UT"",21,0)"
^XMB(3.9,145839,2,290,0)=" I $G(X)[$C(11) S X=$TR(X,$C(11),"" "") ; TAB with space"
^XMB(3.9,145839,2,291,0)="""RTN"",""TIUCCHL7UT"",22,0)"
^XMB(3.9,145839,2,292,0)=" I $G(X)[$C(160) S X=$TR(X,$C(160),"" "")  ; Inverted question mark formatting from HSRM"
