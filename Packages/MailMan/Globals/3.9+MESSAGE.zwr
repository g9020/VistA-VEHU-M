^XMB(3.9,145831,2,985,0)="""RTN"",""EDPVIT"",60,0)"
^XMB(3.9,145831,2,986,0)="LAST(DFN) ; -- Return time that vitals were last taken"
^XMB(3.9,145831,2,987,0)="""RTN"",""EDPVIT"",61,0)"
^XMB(3.9,145831,2,988,0)=" N Y,IDX"
