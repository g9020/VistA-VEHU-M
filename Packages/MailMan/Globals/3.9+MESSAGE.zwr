^XMB(3.9,145831,2,350,0)=" . D CLEARSET(SET)"
^XMB(3.9,145831,2,351,0)="""RTN"",""EDPBSL"",52,0)"
^XMB(3.9,145831,2,352,0)=" . S X=CTYP F  S X=$O(REQ(X)) Q:$E(X,1,$L(CTYP))'=CTYP  D"
^XMB(3.9,145831,2,353,0)="""RTN"",""EDPBSL"",53,0)"
^XMB(3.9,145831,2,354,0)=" . . K CODE S CODE="""" D NVPARSE^EDPX(.CODE,REQ(X,1))"
^XMB(3.9,145831,2,355,0)="""RTN"",""EDPBSL"",54,0)"
^XMB(3.9,145831,2,356,0)=" . . ; I CODE(""id"")>0 D UPDCODE(CTYP,.CODE) -- want to keep codes matched to nat'l --KCM"
^XMB(3.9,145831,2,357,0)="""RTN"",""EDPBSL"",55,0)"
^XMB(3.9,145831,2,358,0)=" . . I CODE(""id"")<1 D ADDCODE(CTYP,.CODE)"
^XMB(3.9,145831,2,359,0)="""RTN"",""EDPBSL"",56,0)"
^XMB(3.9,145831,2,360,0)=" . . D ADD2SET(SET,.CODE)"
^XMB(3.9,145831,2,361,0)="""RTN"",""EDPBSL"",57,0)"
^XMB(3.9,145831,2,362,0)=" D SAVEU^EDPBLK(EDPAREA,""selection"",.TOKEN)          ; save selection config -- UNLOCK"
