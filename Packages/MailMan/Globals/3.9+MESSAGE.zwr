^XMB(3.9,145834,2,2825,0)="""RTN"",""MAGDSTA1"",89,0)"
^XMB(3.9,145834,2,2826,0)=" . . E  D"
^XMB(3.9,145834,2,2827,0)="""RTN"",""MAGDSTA1"",90,0)"
^XMB(3.9,145834,2,2828,0)=" . . . K ^TMP(""MAG"",$J,""BATCH Q/R"",""PATIENT DFN"")"
^XMB(3.9,145834,2,2829,0)="""RTN"",""MAGDSTA1"",91,0)"
^XMB(3.9,145834,2,2830,0)=" . . . K PICK ; consult service list"
^XMB(3.9,145834,2,2831,0)="""RTN"",""MAGDSTA1"",92,0)"
^XMB(3.9,145834,2,2832,0)=" . . . Q"
^XMB(3.9,145834,2,2833,0)="""RTN"",""MAGDSTA1"",93,0)"
^XMB(3.9,145834,2,2834,0)=" . . Q"
^XMB(3.9,145834,2,2835,0)="""RTN"",""MAGDSTA1"",94,0)"
^XMB(3.9,145834,2,2836,0)=" . E  I STATUS=""RUNNING"" D"
^XMB(3.9,145834,2,2837,0)="""RTN"",""MAGDSTA1"",95,0)"
^XMB(3.9,145834,2,2838,0)=" . . W !!,""THE LAST "",SCANMODE,"" SCAN RUN HAS NOT YET COMPLETED. The last action was on "",$$FMTE^XLFDT(RUNTIME)"
^XMB(3.9,145834,2,2839,0)="""RTN"",""MAGDSTA1"",96,0)"
^XMB(3.9,145834,2,2840,0)=" . . S ERROR=$$YESNO^MAGDSTQ(""Start this ""_SCANMODE_"" scan where the last run is expected to end?"",,.X) ; no default"
