^XMB(3.9,145834,2,6528,0)="GETDATA(RUNNUMBER,STATS) ; accumulate the data for one run"
^XMB(3.9,145834,2,6529,0)="""RTN"",""MAGDSTAS"",154,0)"
^XMB(3.9,145834,2,6530,0)=" D NODE0(RUNNUMBER)"
^XMB(3.9,145834,2,6531,0)="""RTN"",""MAGDSTAS"",155,0)"
^XMB(3.9,145834,2,6532,0)=" I SCANMODE=""DATE"" D  ; remove dates that have been processed"
^XMB(3.9,145834,2,6533,0)="""RTN"",""MAGDSTAS"",156,0)"
