^XMB(3.9,145839,2,1065,0)="""RTN"",""TIUCCRHL7P4"",37,0)"
^XMB(3.9,145839,2,1066,0)=" ..S LINES(""TEXT"",XX,0)=$TR($E(WORDS,I1,I-1),$C(160),"" ""),LINES(""TEXT"",XX,0)=$$TRIM^XLFSTR(LINES(""TEXT"",XX,0),""LR""),XX=XX+1,LCNT=0  ;,I1=I"
^XMB(3.9,145839,2,1067,0)="""RTN"",""TIUCCRHL7P4"",38,0)"
^XMB(3.9,145839,2,1068,0)=" ..;W !,$G(LINES(""TEXT"",XX-1,0)),""  "",XX-1_""^""_I1_""^""_I_""^""_LCNT"
^XMB(3.9,145839,2,1069,0)="""RTN"",""TIUCCRHL7P4"",39,0)"
^XMB(3.9,145839,2,1070,0)=" ..S I1=I"
^XMB(3.9,145839,2,1071,0)="""RTN"",""TIUCCRHL7P4"",40,0)"
^XMB(3.9,145839,2,1072,0)=" I I1'=LEN N LASTLINES S LASTLINES=$E(WORDS,I1,I) K T2 S T2($C(160)_"" "")="""" S LINES(""TEXT"",XX,0)=$$REPLACE^XLFSTR(LASTLINES,.T2)"
^XMB(3.9,145839,2,1073,0)="""RTN"",""TIUCCRHL7P4"",41,0)"
^XMB(3.9,145839,2,1074,0)=" M TIUZ(""TEXT"")=LINES(""TEXT"")"
^XMB(3.9,145839,2,1075,0)="""RTN"",""TIUCCRHL7P4"",42,0)"
^XMB(3.9,145839,2,1076,0)=" K LINES(""TEXT"")"
^XMB(3.9,145839,2,1077,0)="""RTN"",""TIUCCRHL7P4"",43,0)"
^XMB(3.9,145839,2,1078,0)=" Q"
^XMB(3.9,145839,2,1079,0)="""RTN"",""TIUCCRHL7P4"",44,0)"
^XMB(3.9,145839,2,1080,0)="GETDATE() ; parse date/time of original note. Patch 344 mods to parse out the date of the original note"
^XMB(3.9,145839,2,1081,0)="""RTN"",""TIUCCRHL7P4"",45,0)"
^XMB(3.9,145839,2,1082,0)=" N D1,D2"
^XMB(3.9,145839,2,1083,0)="""RTN"",""TIUCCRHL7P4"",46,0)"
