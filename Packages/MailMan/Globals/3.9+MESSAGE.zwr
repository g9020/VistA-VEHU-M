^XMB(3.9,144657,2,7803,0)="""RTN"",""IBCNICB"",131,0)"
^XMB(3.9,144657,2,7804,0)="UPDTICB(RESULT,DFN,IBPOLDA,IBGRPDA,IBPOLCOM,IBPOLBIL,IBPLAN,IBELEC,IBGPCOM,IBFTF,IBFTFVAL) ;"
^XMB(3.9,144657,2,7805,0)="""RTN"",""IBCNICB"",132,0)"
^XMB(3.9,144657,2,7806,0)=" ;Updates additional fields for ICB Interface"
^XMB(3.9,144657,2,7807,0)="""RTN"",""IBCNICB"",133,0)"
^XMB(3.9,144657,2,7808,0)=" ;"
^XMB(3.9,144657,2,7809,0)="""RTN"",""IBCNICB"",134,0)"
^XMB(3.9,144657,2,7810,0)=" ;Input:"
^XMB(3.9,144657,2,7811,0)="""RTN"",""IBCNICB"",135,0)"
^XMB(3.9,144657,2,7812,0)=" ;  DFN      - PATIENT (#2) file IEN (Required)"
^XMB(3.9,144657,2,7813,0)="""RTN"",""IBCNICB"",136,0)"
^XMB(3.9,144657,2,7814,0)=" ;  IBGRPDA  - GROUP INSURANCE PLAN (#355.3) File IEN (Optional)"
^XMB(3.9,144657,2,7815,0)="""RTN"",""IBCNICB"",137,0)"
^XMB(3.9,144657,2,7816,0)=" ;  IBPOLDA  - INSURANCE TYPE (#2.312) sub-file of PATIENT (#2) IEN "
^XMB(3.9,144657,2,7817,0)="""RTN"",""IBCNICB"",138,0)"
^XMB(3.9,144657,2,7818,0)=" ;             (Optional)"
^XMB(3.9,144657,2,7819,0)="""RTN"",""IBCNICB"",139,0)"
^XMB(3.9,144657,2,7820,0)=" ;  IBPOLCOM - Data to be filed into the COMMENT - SUBSCRIBER POLICY "
^XMB(3.9,144657,2,7821,0)="""RTN"",""IBCNICB"",140,0)"
^XMB(3.9,144657,2,7822,0)=" ;              MULTIPLE (2.312, 1.18) optional"
^XMB(3.9,144657,2,7823,0)="""RTN"",""IBCNICB"",141,0)"
^XMB(3.9,144657,2,7824,0)=" ;  IBPOLBIL - Data to be filed into the STOP POLICY FROM BILLING  (#3.04)"
^XMB(3.9,144657,2,7825,0)="""RTN"",""IBCNICB"",142,0)"
^XMB(3.9,144657,2,7826,0)=" ;             field of the 2.312 sub-file. (Optional)"
^XMB(3.9,144657,2,7827,0)="""RTN"",""IBCNICB"",143,0)"
^XMB(3.9,144657,2,7828,0)=" ;             Corresponds to the Internal codes in 3.04 field of "
^XMB(3.9,144657,2,7829,0)="""RTN"",""IBCNICB"",144,0)"
^XMB(3.9,144657,2,7830,0)=" ;             2.312 sub-file: '0' FOR NO; '1' FOR YES;"
^XMB(3.9,144657,2,7831,0)="""RTN"",""IBCNICB"",145,0)"
^XMB(3.9,144657,2,7832,0)=" ;  IBPLAN   - Data to be filed in PLAN FILING TIME FRAME (#.13) field "
^XMB(3.9,144657,2,7833,0)="""RTN"",""IBCNICB"",146,0)"
^XMB(3.9,144657,2,7834,0)=" ;             of 355.3 file (Optional)"
^XMB(3.9,144657,2,7835,0)="""RTN"",""IBCNICB"",147,0)"
^XMB(3.9,144657,2,7836,0)=" ;  IBELEC   - Data to be file in ELECTRONIC PLAN TYPE  (#.15) field "
^XMB(3.9,144657,2,7837,0)="""RTN"",""IBCNICB"",148,0)"
^XMB(3.9,144657,2,7838,0)=" ;             of 355.3 file (Optional)"
^XMB(3.9,144657,2,7839,0)="""RTN"",""IBCNICB"",149,0)"
^XMB(3.9,144657,2,7840,0)=" ;             Corresponds to the Internal Codes in .15 field of 355.3 file"
^XMB(3.9,144657,2,7841,0)="""RTN"",""IBCNICB"",150,0)"
^XMB(3.9,144657,2,7842,0)=" ;  IBGPCOM  - Group Plan Comment array that contains the word"
^XMB(3.9,144657,2,7843,0)="""RTN"",""IBCNICB"",151,0)"
^XMB(3.9,144657,2,7844,0)=" ;             processing data to be filed the COMMENTS (#11) word-"
^XMB(3.9,144657,2,7845,0)="""RTN"",""IBCNICB"",152,0)"
^XMB(3.9,144657,2,7846,0)=" ;             processing field of  355.3 file. (Optional)"
^XMB(3.9,144657,2,7847,0)="""RTN"",""IBCNICB"",153,0)"
^XMB(3.9,144657,2,7848,0)=" ;              Example:  IBGPCOM(1)=""This is line 1"""
