^XMB(3.9,144661,2,313,0)="""RTN"",""ORAM1"",37,0)"
^XMB(3.9,144661,2,314,0)=" ;S ORAMICD=ICODE_"" """
^XMB(3.9,144661,2,315,0)="""RTN"",""ORAM1"",38,0)"
^XMB(3.9,144661,2,316,0)=" ;S RESULT=$O(^ICD9(""AB"",ORAMICD,0))"
^XMB(3.9,144661,2,317,0)="""RTN"",""ORAM1"",39,0)"
^XMB(3.9,144661,2,318,0)=" ;Q"
^XMB(3.9,144661,2,319,0)="""RTN"",""ORAM1"",40,0)"
^XMB(3.9,144661,2,320,0)=" ;"
^XMB(3.9,144661,2,321,0)="""RTN"",""ORAM1"",41,0)"
^XMB(3.9,144661,2,322,0)="PTCHECK(RESULT,ORAMDFN) ; CHECKS TO SEE IF PT IS IN FILE"
^XMB(3.9,144661,2,323,0)="""RTN"",""ORAM1"",42,0)"
^XMB(3.9,144661,2,324,0)=" N ORPTLOC"
^XMB(3.9,144661,2,325,0)="""RTN"",""ORAM1"",43,0)"
^XMB(3.9,144661,2,326,0)=" Q:'+$G(ORAMDFN)"
^XMB(3.9,144661,2,327,0)="""RTN"",""ORAM1"",44,0)"
^XMB(3.9,144661,2,328,0)=" S RESULT=0"
^XMB(3.9,144661,2,329,0)="""RTN"",""ORAM1"",45,0)"
^XMB(3.9,144661,2,330,0)=" I $S('$D(^ORAM(103,ORAMDFN)):1,+$O(^ORAM(103,ORAMDFN,3,0))'>0:1,1:0) S RESULT=1 Q"
^XMB(3.9,144661,2,331,0)="""RTN"",""ORAM1"",46,0)"
^XMB(3.9,144661,2,332,0)=" S ORPTLOC=$P($G(^ORAM(103,ORAMDFN,6)),U,2)"
^XMB(3.9,144661,2,333,0)="""RTN"",""ORAM1"",47,0)"
^XMB(3.9,144661,2,334,0)=" I ORPTLOC']"""" S RESULT=2 Q"
^XMB(3.9,144661,2,335,0)="""RTN"",""ORAM1"",48,0)"
^XMB(3.9,144661,2,336,0)=" I +ORPTLOC,'$L($$GET^XPAR(ORPTLOC_"";SC(^DIV.`""_DUZ(2),""ORAM CLINIC NAME"",1,""I"")) S RESULT=99"
^XMB(3.9,144661,2,337,0)="""RTN"",""ORAM1"",49,0)"
^XMB(3.9,144661,2,338,0)=" Q"
^XMB(3.9,144661,2,339,0)="""RTN"",""ORAM1"",50,0)"
^XMB(3.9,144661,2,340,0)=" ;"
^XMB(3.9,144661,2,341,0)="""RTN"",""ORAM1"",51,0)"
^XMB(3.9,144661,2,342,0)="PTENTER(RESULT,DFN) ; ENTERS PATIENT INTO FILE WITH ALL DATES = TODAY"
^XMB(3.9,144661,2,343,0)="""RTN"",""ORAM1"",52,0)"
^XMB(3.9,144661,2,344,0)=" N DO,DD,DIC,DINUM,X"
^XMB(3.9,144661,2,345,0)="""RTN"",""ORAM1"",53,0)"
^XMB(3.9,144661,2,346,0)=" S DIC=""^ORAM(103,"""
^XMB(3.9,144661,2,347,0)="""RTN"",""ORAM1"",54,0)"
^XMB(3.9,144661,2,348,0)=" S DIC(0)=""Z"""
^XMB(3.9,144661,2,349,0)="""RTN"",""ORAM1"",55,0)"
^XMB(3.9,144661,2,350,0)=" S (DINUM,X)=DFN"
^XMB(3.9,144661,2,351,0)="""RTN"",""ORAM1"",56,0)"
^XMB(3.9,144661,2,352,0)=" D FILE^DICN"
^XMB(3.9,144661,2,353,0)="""RTN"",""ORAM1"",57,0)"
^XMB(3.9,144661,2,354,0)=" K DO,DD"
^XMB(3.9,144661,2,355,0)="""RTN"",""ORAM1"",58,0)"
