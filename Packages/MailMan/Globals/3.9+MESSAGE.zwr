^XMB(3.9,145834,2,7291,0)="""RTN"",""MAGDSTQ8"",148,0)"
^XMB(3.9,145834,2,7292,0)=" I CODE=""A702"" D  Q ""Failure"""
^XMB(3.9,145834,2,7293,0)="""RTN"",""MAGDSTQ8"",149,0)"
^XMB(3.9,145834,2,7294,0)="  . S MEANING=""Refused: Out of Resources - Unable to perform sub-operations"""
^XMB(3.9,145834,2,7295,0)="""RTN"",""MAGDSTQ8"",150,0)"
