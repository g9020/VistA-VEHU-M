^XMB(3.9,145833,2,2548,0)=" I +PRIAMIS=0 S ERRORNUM=270 Q"
^XMB(3.9,145833,2,2549,0)="""RTN"",""SDESUTIL"",221,0)"
^XMB(3.9,145833,2,2550,0)=" I $L(PRIAMIS) D"
