^XMB(3.9,145834,2,6501,0)="""RTN"",""MAGDSTAS"",140,0)"
^XMB(3.9,145834,2,6502,0)=" . . . . S ZEROIEN1=0"
^XMB(3.9,145834,2,6503,0)="""RTN"",""MAGDSTAS"",141,0)"
^XMB(3.9,145834,2,6504,0)=" . . . . Q"
^XMB(3.9,145834,2,6505,0)="""RTN"",""MAGDSTAS"",142,0)"
^XMB(3.9,145834,2,6506,0)=" . . . Q"
^XMB(3.9,145834,2,6507,0)="""RTN"",""MAGDSTAS"",143,0)"
^XMB(3.9,145834,2,6508,0)=" . . Q"
^XMB(3.9,145834,2,6509,0)="""RTN"",""MAGDSTAS"",144,0)"
^XMB(3.9,145834,2,6510,0)=" . I ZEROIEN1 D ZEROES(ZEROIEN1,ZEROIEN2)"
^XMB(3.9,145834,2,6511,0)="""RTN"",""MAGDSTAS"",145,0)"
