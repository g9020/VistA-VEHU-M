^XMB(3.9,145834,2,8324,0)=" "
^XMB(3.9,145834,2,8325,0)="""^DIC"",2006.541,2006.541,""%D"",21,0)"
^XMB(3.9,145834,2,8326,0)="The DICOM Gateway uses the MAG DICOM Q/R CLIENT to read this file and"
