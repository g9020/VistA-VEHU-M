^XMB(3.9,144654,2,531,0)="""RTN"",""PSOHLDS2"",146,0)"
^XMB(3.9,144654,2,532,0)="NTE3(PSI) ;Drug Warning Narrative"
^XMB(3.9,144654,2,533,0)="""RTN"",""PSOHLDS2"",147,0)"
^XMB(3.9,144654,2,534,0)=" N NTE3,J,TEXT,W,CNT,PSSWSITE"
^XMB(3.9,144654,2,535,0)="""RTN"",""PSOHLDS2"",148,0)"
^XMB(3.9,144654,2,536,0)=" S WARN=$P($G(^PSDRUG(IDGN,0)),""^"",8)"
^XMB(3.9,144654,2,537,0)="""RTN"",""PSOHLDS2"",149,0)"
^XMB(3.9,144654,2,538,0)=" S PSSWSITE=+$O(^PS(59.7,0))"
^XMB(3.9,144654,2,539,0)="""RTN"",""PSOHLDS2"",150,0)"
^XMB(3.9,144654,2,540,0)=" I $P($G(^PS(59.7,PSSWSITE,10)),""^"",11)=""N"" D"
^XMB(3.9,144654,2,541,0)="""RTN"",""PSOHLDS2"",151,0)"
^XMB(3.9,144654,2,542,0)=" .S WARN=$$DRUG^PSSWRNA(IDGN,DFN)"
^XMB(3.9,144654,2,543,0)="""RTN"",""PSOHLDS2"",152,0)"
^XMB(3.9,144654,2,544,0)=" I WARN="""" Q"
^XMB(3.9,144654,2,545,0)="""RTN"",""PSOHLDS2"",153,0)"
^XMB(3.9,144654,2,546,0)=" S NTE3=""NTE""_FS_3_FS_FS,^TMP(""PSO"",$J,PSI)=NTE3,CNT=1"
^XMB(3.9,144654,2,547,0)="""RTN"",""PSOHLDS2"",154,0)"
^XMB(3.9,144654,2,548,0)=" F J=1:1 S W=$P(WARN,"","",J) Q:W=""""  D"
^XMB(3.9,144654,2,549,0)="""RTN"",""PSOHLDS2"",155,0)"
^XMB(3.9,144654,2,550,0)=" . S:CNT>1 ^TMP(""PSO"",$J,PSI,CNT-1)=^TMP(""PSO"",$J,PSI,CNT-1)_""\.sp\"""
^XMB(3.9,144654,2,551,0)="""RTN"",""PSOHLDS2"",156,0)"
^XMB(3.9,144654,2,552,0)=" . S TEXT=$$WTEXT^PSSWRNA(W,$G(OLAN)) I TEXT'="""" S FLDX=1 D"
^XMB(3.9,144654,2,553,0)="""RTN"",""PSOHLDS2"",157,0)"
^XMB(3.9,144654,2,554,0)=" . . I $L(TEXT)<245 S ^TMP(""PSO"",$J,PSI,CNT)=TEXT,CNT=CNT+1 Q"
^XMB(3.9,144654,2,555,0)="""RTN"",""PSOHLDS2"",158,0)"
^XMB(3.9,144654,2,556,0)=" . . N LTH,ST,EN,TXT,WW"
^XMB(3.9,144654,2,557,0)="""RTN"",""PSOHLDS2"",159,0)"
^XMB(3.9,144654,2,558,0)=" . . S LTH=$E($L(TEXT)/245,1) S:$L(TEXT)#245>0 LTH=LTH+1"
^XMB(3.9,144654,2,559,0)="""RTN"",""PSOHLDS2"",160,0)"
^XMB(3.9,144654,2,560,0)=" . . F WW=1:1:LTH D"
^XMB(3.9,144654,2,561,0)="""RTN"",""PSOHLDS2"",161,0)"
^XMB(3.9,144654,2,562,0)=" . . . S:WW=1 ST=1,EN=245 S:WW>1 ST=(ST+245),EN=(EN+245) S TXT=$E(TEXT,ST,EN)"
^XMB(3.9,144654,2,563,0)="""RTN"",""PSOHLDS2"",162,0)"
^XMB(3.9,144654,2,564,0)=" . . . S ^TMP(""PSO"",$J,PSI,CNT)=TXT,CNT=CNT+1"
^XMB(3.9,144654,2,565,0)="""RTN"",""PSOHLDS2"",163,0)"
^XMB(3.9,144654,2,566,0)=" I $G(FLDX) D  S PSI=PSI+1"
^XMB(3.9,144654,2,567,0)="""RTN"",""PSOHLDS2"",164,0)"
^XMB(3.9,144654,2,568,0)=" . I $L(^TMP(""PSO"",$J,PSI,CNT-1)_FS_""Drug Warning Narrative"")<245 S ^TMP(""PSO"",$J,PSI,CNT-1)=$G(^TMP(""PSO"",$J,PSI,CNT-1))_FS_""Drug Warning Narrative"""
^XMB(3.9,144654,2,569,0)="""RTN"",""PSOHLDS2"",165,0)"
^XMB(3.9,144654,2,570,0)=" . E  S ^TMP(""PSO"",$J,PSI,CNT)=FS_""Drug Warning Narrative"""
^XMB(3.9,144654,2,571,0)="""RTN"",""PSOHLDS2"",166,0)"
^XMB(3.9,144654,2,572,0)=" Q"
^XMB(3.9,144654,2,573,0)="""RTN"",""PSOHLDS2"",167,0)"
^XMB(3.9,144654,2,574,0)="NTE4(PSI) ;Profile information"
