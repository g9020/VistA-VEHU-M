^XMB(3.9,144652,2,532,0)=" N ERXNODE0,ERXNODE1,ERXNODE2,ERXNODE3,EPTNODE0,EPTNODE1,EPTNODE2,SKIP,DRSNCODE,CHGMESRQ"
^XMB(3.9,144652,2,533,0)="""RTN"",""PSOERRX1"",147,0)"
^XMB(3.9,144652,2,534,0)=" ; Related Institution Filter (Non-MbM sites only)"
^XMB(3.9,144652,2,535,0)="""RTN"",""PSOERRX1"",148,0)"
^XMB(3.9,144652,2,536,0)=" I '$G(MBMSITE),$G(PSNPINST)'=+$G(^PS(52.49,ERXIEN,24)) Q"
^XMB(3.9,144652,2,537,0)="""RTN"",""PSOERRX1"",149,0)"
^XMB(3.9,144652,2,538,0)=" S ERXNODE0=$G(^PS(52.49,ERXIEN,0)),ERXNODE1=$G(^PS(52.49,ERXIEN,1))"
^XMB(3.9,144652,2,539,0)="""RTN"",""PSOERRX1"",150,0)"
^XMB(3.9,144652,2,540,0)=" S ERXNODE2=$G(^PS(52.49,ERXIEN,2)),ERXNODE3=$G(^PS(52.49,ERXIEN,3))"
^XMB(3.9,144652,2,541,0)="""RTN"",""PSOERRX1"",151,0)"
^XMB(3.9,144652,2,542,0)=" S MSGDT=$P(ERXNODE0,""^"",3)"
^XMB(3.9,144652,2,543,0)="""RTN"",""PSOERRX1"",152,0)"
^XMB(3.9,144652,2,544,0)=" S EPATIEN=$P(ERXNODE0,""^"",4) I 'EPATIEN S EPATIEN=$$GETPAT^PSOERXU5(ERXIEN)"
^XMB(3.9,144652,2,545,0)="""RTN"",""PSOERRX1"",153,0)"
^XMB(3.9,144652,2,546,0)=" ; eRx Patient Filter"
^XMB(3.9,144652,2,547,0)="""RTN"",""PSOERRX1"",154,0)"
^XMB(3.9,144652,2,548,0)=" I $D(PATFLTR),'$D(PATFLTR(+EPATIEN)) Q"
^XMB(3.9,144652,2,549,0)="""RTN"",""PSOERRX1"",155,0)"
^XMB(3.9,144652,2,550,0)=" S EPROVIEN=+ERXNODE2 I 'EPROVIEN S EPROVIEN=$$GETPROV^PSOERXU5(ERXIEN)"
^XMB(3.9,144652,2,551,0)="""RTN"",""PSOERRX1"",156,0)"
^XMB(3.9,144652,2,552,0)=" ; eRx Provider Filter"
^XMB(3.9,144652,2,553,0)="""RTN"",""PSOERRX1"",157,0)"
^XMB(3.9,144652,2,554,0)=" I $D(PRVFLTR),'$D(PRVFLTR(EPROVIEN)) Q"
^XMB(3.9,144652,2,555,0)="""RTN"",""PSOERRX1"",158,0)"
^XMB(3.9,144652,2,556,0)=" S VPATIEN=$P(ERXNODE0,""^"",5),MTYPE=$P(ERXNODE0,""^"",8)"
^XMB(3.9,144652,2,557,0)="""RTN"",""PSOERRX1"",159,0)"
^XMB(3.9,144652,2,558,0)=" S STATIEN=+$G(^PS(52.49,ERXIEN,1)),ERXSTAT=$P(^PS(52.45,STATIEN,0),""^"")"
^XMB(3.9,144652,2,559,0)="""RTN"",""PSOERRX1"",160,0)"
^XMB(3.9,144652,2,560,0)=" ; Actionable/Non-Actionable Status"
^XMB(3.9,144652,2,561,0)="""RTN"",""PSOERRX1"",161,0)"
^XMB(3.9,144652,2,562,0)=" I '$G(PSOALLST),'$G(STSFLTR),$F("",RJ,RM,REM,PR,E,RXA,CXA,CAA,CAN,CXP,RXP,RXA,ICA,CNP,CRP,CRC,RRC,CXC,CNE,CRN,CRR,CRX,CXQ,RXA,RXC,RRN,RRX,RRR,RRP,IRA,"","",""_$E(ERXSTAT,1,3)_"","") Q"
^XMB(3.9,144652,2,563,0)="""RTN"",""PSOERRX1"",162,0)"
^XMB(3.9,144652,2,564,0)=" S RESTYPE=$P($G(^PS(52.49,ERXIEN,52)),""^"",1)"
^XMB(3.9,144652,2,565,0)="""RTN"",""PSOERRX1"",163,0)"
^XMB(3.9,144652,2,566,0)=" S CSERX=+$G(^PS(52.49,ERXIEN,95))"
^XMB(3.9,144652,2,567,0)="""RTN"",""PSOERRX1"",164,0)"
^XMB(3.9,144652,2,568,0)=" S VPRVIEN=$P($G(^PS(52.49,ERXIEN,2)),""^"",3)"
^XMB(3.9,144652,2,569,0)="""RTN"",""PSOERRX1"",165,0)"
^XMB(3.9,144652,2,570,0)=" S VDRGIEN=$P($G(^PS(52.49,ERXIEN,3)),""^"",2)"
^XMB(3.9,144652,2,571,0)="""RTN"",""PSOERRX1"",166,0)"
^XMB(3.9,144652,2,572,0)=" S CHGMESRQ=$$GET1^DIQ(52.49,ERXIEN,315.1,""I"")"
^XMB(3.9,144652,2,573,0)="""RTN"",""PSOERRX1"",167,0)"
^XMB(3.9,144652,2,574,0)=" S CHGMESRI=$$GET1^DIQ(52.45,CHGMESRQ,.01,""I"")"
^XMB(3.9,144652,2,575,0)="""RTN"",""PSOERRX1"",168,0)"
^XMB(3.9,144652,2,576,0)=" S SKIP=0"
^XMB(3.9,144652,2,577,0)="""RTN"",""PSOERRX1"",169,0)"
^XMB(3.9,144652,2,578,0)=" ; Setting Drug Name (if Blank)"
^XMB(3.9,144652,2,579,0)="""RTN"",""PSOERRX1"",170,0)"
^XMB(3.9,144652,2,580,0)=" S EDRUG=$P(ERXNODE3,""^"",1)"
^XMB(3.9,144652,2,581,0)="""RTN"",""PSOERRX1"",171,0)"
^XMB(3.9,144652,2,582,0)=" I EDRUG="""" S EDRUG=$$GETDRUG^PSOERXU5(ERXIEN) I EDRUG="""" S EDRUG=$S(MTYPE=""IE"":""<<INBOUND ERROR>>"",1:""N/A"")"
^XMB(3.9,144652,2,583,0)="""RTN"",""PSOERRX1"",172,0)"
^XMB(3.9,144652,2,584,0)=" ; Applying Filters"
^XMB(3.9,144652,2,585,0)="""RTN"",""PSOERRX1"",173,0)"
^XMB(3.9,144652,2,586,0)=" ; Message Type Filter"
^XMB(3.9,144652,2,587,0)="""RTN"",""PSOERRX1"",174,0)"
^XMB(3.9,144652,2,588,0)=" I $G(MSTPFLTR)'="""",MTYPE'=MSTPFLTR Q"
^XMB(3.9,144652,2,589,0)="""RTN"",""PSOERRX1"",175,0)"
^XMB(3.9,144652,2,590,0)=" I $D(RESARY),$G(MSTPFLTR)'="""",("" RE CX ""[("" ""_MSTPFLTR_"" "")) D  Q:SKIP"
^XMB(3.9,144652,2,591,0)="""RTN"",""PSOERRX1"",176,0)"
^XMB(3.9,144652,2,592,0)=" . I RESTYPE="""" S SKIP=1 Q"
^XMB(3.9,144652,2,593,0)="""RTN"",""PSOERRX1"",177,0)"
^XMB(3.9,144652,2,594,0)=" . I '$D(RESARY(RESTYPE)) S SKIP=1"
^XMB(3.9,144652,2,595,0)="""RTN"",""PSOERRX1"",178,0)"
^XMB(3.9,144652,2,596,0)=" ; Match Status Filter"
^XMB(3.9,144652,2,597,0)="""RTN"",""PSOERRX1"",179,0)"
^XMB(3.9,144652,2,598,0)=" I $G(MATFLTR)=1,VPATIEN Q"
^XMB(3.9,144652,2,599,0)="""RTN"",""PSOERRX1"",180,0)"
^XMB(3.9,144652,2,600,0)=" I $G(MATFLTR)=2,VPRVIEN!'VPATIEN Q"
^XMB(3.9,144652,2,601,0)="""RTN"",""PSOERRX1"",181,0)"
^XMB(3.9,144652,2,602,0)=" I $G(MATFLTR)=3,VDRGIEN!'VPATIEN!'VPRVIEN Q"
^XMB(3.9,144652,2,603,0)="""RTN"",""PSOERRX1"",182,0)"
^XMB(3.9,144652,2,604,0)=" I $G(MATFLTR)=4,'VPATIEN!'VPRVIEN!'VDRGIEN Q"
^XMB(3.9,144652,2,605,0)="""RTN"",""PSOERRX1"",183,0)"
^XMB(3.9,144652,2,606,0)=" ; Main Filter Eligibility by Status"
^XMB(3.9,144652,2,607,0)="""RTN"",""PSOERRX1"",184,0)"
^XMB(3.9,144652,2,608,0)=" I '$G(PSOALLST)!(PSOSTFLT'=""A""),'$$ELIGSTS^PSOERPC1(""RX"",ERXSTAT,MTYPE) Q"
^XMB(3.9,144652,2,609,0)="""RTN"",""PSOERRX1"",185,0)"
^XMB(3.9,144652,2,610,0)=" I '$G(STSFLTR),$G(MSTPFLTR)="""",MTYPE=""CR"",ERXSTAT=""CRE"" Q"
^XMB(3.9,144652,2,611,0)="""RTN"",""PSOERRX1"",186,0)"
^XMB(3.9,144652,2,612,0)=" ; eRx Patient DOB Filter"
^XMB(3.9,144652,2,613,0)="""RTN"",""PSOERRX1"",187,0)"
^XMB(3.9,144652,2,614,0)=" I $G(DOBFLTR),$$GET1^DIQ(52.46,+EPATIEN,.08,""I"")'=DOBFLTR Q"
^XMB(3.9,144652,2,615,0)="""RTN"",""PSOERRX1"",188,0)"
^XMB(3.9,144652,2,616,0)=" ; eRx Status Filter"
^XMB(3.9,144652,2,617,0)="""RTN"",""PSOERRX1"",189,0)"
^XMB(3.9,144652,2,618,0)=" I $G(STSFLTR),STSFLTR'=+ERXNODE1 Q"
^XMB(3.9,144652,2,619,0)="""RTN"",""PSOERRX1"",190,0)"
^XMB(3.9,144652,2,620,0)=" I ($G(STSFLTR1)[""RM"")!($G(STSFLTR1)[""ALL""),'$$CHKSTSLST(ERXIEN,$G(STSFLTR)) Q"
^XMB(3.9,144652,2,621,0)="""RTN"",""PSOERRX1"",191,0)"
^XMB(3.9,144652,2,622,0)=" I ($G(STSFLTR1)[""RJ"")!($G(STSFLTR1)[""ALL""),'$$CHKSTSLST(ERXIEN,$G(STSFLTR)) Q"
^XMB(3.9,144652,2,623,0)="""RTN"",""PSOERRX1"",192,0)"
^XMB(3.9,144652,2,624,0)=" ; eRx Drug Name Filter"
^XMB(3.9,144652,2,625,0)="""RTN"",""PSOERRX1"",193,0)"
^XMB(3.9,144652,2,626,0)=" I $G(DRGFLTR)'="""",$$UP^XLFSTR(EDRUG)'[$$UP^XLFSTR(DRGFLTR) Q"
^XMB(3.9,144652,2,627,0)="""RTN"",""PSOERRX1"",194,0)"
^XMB(3.9,144652,2,628,0)=" ; Controlled Substance Filter"
^XMB(3.9,144652,2,629,0)="""RTN"",""PSOERRX1"",195,0)"
^XMB(3.9,144652,2,630,0)=" I $G(PSOCSERX)=""CS"",'CSERX Q"
^XMB(3.9,144652,2,631,0)="""RTN"",""PSOERRX1"",196,0)"
^XMB(3.9,144652,2,632,0)=" I $G(PSOCSERX)=""Non-CS"",CSERX Q"
^XMB(3.9,144652,2,633,0)="""RTN"",""PSOERRX1"",197,0)"
^XMB(3.9,144652,2,634,0)=" I '$$CSFILTER^PSOERXUT(ERXIEN) Q"
^XMB(3.9,144652,2,635,0)="""RTN"",""PSOERRX1"",198,0)"
^XMB(3.9,144652,2,636,0)=" I $G(VDRGFLTR),VDRGIEN'=VDRGFLTR Q"
^XMB(3.9,144652,2,637,0)="""RTN"",""PSOERRX1"",199,0)"
^XMB(3.9,144652,2,638,0)=" ; If the eRx is a new refill request and the status is refill request new, check for a response."
^XMB(3.9,144652,2,639,0)="""RTN"",""PSOERRX1"",200,0)"
^XMB(3.9,144652,2,640,0)=" ; If no response was received within 14 days, change to RRE (refill request expired)."
^XMB(3.9,144652,2,641,0)="""RTN"",""PSOERRX1"",201,0)"
^XMB(3.9,144652,2,642,0)=" I MTYPE=""RR"",ERXSTAT=""RRN"" D CHKEXP^PSOERX(ERXIEN,MTYPE)"
^XMB(3.9,144652,2,643,0)="""RTN"",""PSOERRX1"",202,0)"
^XMB(3.9,144652,2,644,0)=" ; ChangeRequest messages will be checked for expiration status, "
^XMB(3.9,144652,2,645,0)="""RTN"",""PSOERRX1"",203,0)"
^XMB(3.9,144652,2,646,0)=" ; but will not be displayed in the holding queue list view."
^XMB(3.9,144652,2,647,0)="""RTN"",""PSOERRX1"",204,0)"
^XMB(3.9,144652,2,648,0)=" I MTYPE=""CR"",ERXSTAT=""CRN"" D CHKEXP^PSOERX(ERXIEN,MTYPE)"
^XMB(3.9,144652,2,649,0)="""RTN"",""PSOERRX1"",205,0)"
^XMB(3.9,144652,2,650,0)=" I 'EPATIEN S EPATIEN=$$GETPAT^PSOERXU5(ERXIEN)"
^XMB(3.9,144652,2,651,0)="""RTN"",""PSOERRX1"",206,0)"
^XMB(3.9,144652,2,652,0)=" ; If this is not a search, is a refill response, and is a response type of 'approved',"
^XMB(3.9,144652,2,653,0)="""RTN"",""PSOERRX1"",207,0)"
^XMB(3.9,144652,2,654,0)=" ; do not show in the holding queue."
^XMB(3.9,144652,2,655,0)="""RTN"",""PSOERRX1"",208,0)"
^XMB(3.9,144652,2,656,0)=" I '$$FILTERED^PSOERPC1(""RX""),MTYPE=""RE"",RESTYPE=""A"" Q"
^XMB(3.9,144652,2,657,0)="""RTN"",""PSOERRX1"",209,0)"
^XMB(3.9,144652,2,658,0)=" ; Do not display refill response with 'approved with changes' status in the holding queue."
^XMB(3.9,144652,2,659,0)="""RTN"",""PSOERRX1"",210,0)"
^XMB(3.9,144652,2,660,0)=" I '$$FILTERED^PSOERPC1(""RX""),MTYPE=""RE"",""RXP,RXC,RXA,RRP,""[ERXSTAT Q"
^XMB(3.9,144652,2,661,0)="""RTN"",""PSOERRX1"",211,0)"
^XMB(3.9,144652,2,662,0)=" S SKIP=0"
^XMB(3.9,144652,2,663,0)="""RTN"",""PSOERRX1"",212,0)"
^XMB(3.9,144652,2,664,0)=" I $D(DNDARY),MTYPE=""RE"",$G(MSTPFLTR)=MTYPE,RESTYPE=""D"" D  Q:SKIP"
^XMB(3.9,144652,2,665,0)="""RTN"",""PSOERRX1"",213,0)"
^XMB(3.9,144652,2,666,0)=" . I $D(DNDARY) D  ;if user selected additional filter for DENIED"
^XMB(3.9,144652,2,667,0)="""RTN"",""PSOERRX1"",214,0)"
^XMB(3.9,144652,2,668,0)=" . . I $P(MSTPFLTR1,""/"",3)=""ALL"" Q"
^XMB(3.9,144652,2,669,0)="""RTN"",""PSOERRX1"",215,0)"
^XMB(3.9,144652,2,670,0)=" . . S DRSNCODE=$$DNDRCODE^PSOERRX2(ERXIEN) I $G(DRSNCODE)="""" S SKIP=1 Q  ;get the denied reason code"
^XMB(3.9,144652,2,671,0)="""RTN"",""PSOERRX1"",216,0)"
^XMB(3.9,144652,2,672,0)=" . . I $G(DRSNCODE)'="""",'$D(DNDARY(DRSNCODE)) S SKIP=1"
^XMB(3.9,144652,2,673,0)="""RTN"",""PSOERRX1"",217,0)"
^XMB(3.9,144652,2,674,0)=" S EPTNODE0=$G(^PS(52.46,EPATIEN,0)),EPTNODE1=$G(^PS(52.46,EPATIEN,1)),EPTNODE2=$G(^PS(52.46,EPATIEN,2))"
^XMB(3.9,144652,2,675,0)="""RTN"",""PSOERRX1"",218,0)"
^XMB(3.9,144652,2,676,0)=" S PATNAME=$P(EPTNODE0,""^"") I PATNAME="""" S PATNAME=$$PATNAME^PSOERUT(ERXIEN)"
^XMB(3.9,144652,2,677,0)="""RTN"",""PSOERRX1"",219,0)"
^XMB(3.9,144652,2,678,0)=" S DOB=$P(EPTNODE1,""^"",4)"
^XMB(3.9,144652,2,679,0)="""RTN"",""PSOERRX1"",220,0)"
^XMB(3.9,144652,2,680,0)=" S PROVIDER=+$G(^PS(52.49,ERXIEN,2)),PROVIDER=$P($G(^PS(52.48,PROVIDER,0)),""^"")"
^XMB(3.9,144652,2,681,0)="""RTN"",""PSOERRX1"",221,0)"
^XMB(3.9,144652,2,682,0)=" I PROVIDER="""" S PROVIDER=$$GET1^DIQ(52.48,+$$GETPROV^PSOERXU5(ERXIEN),.01) S:PROVIDER="""" PROVIDER=""N/A"""
^XMB(3.9,144652,2,683,0)="""RTN"",""PSOERRX1"",222,0)"
^XMB(3.9,144652,2,684,0)=" S CSGROUP=$S('PSOCSGRP:""ALL"",CSERX:""CS"",1:""NON-CS"")"
^XMB(3.9,144652,2,685,0)="""RTN"",""PSOERRX1"",223,0)"
^XMB(3.9,144652,2,686,0)=" I MTYPE=""CR"",(ERXSTAT=""CRE"") Q"
^XMB(3.9,144652,2,687,0)="""RTN"",""PSOERRX1"",224,0)"
^XMB(3.9,144652,2,688,0)=" S SKIP=0"
^XMB(3.9,144652,2,689,0)="""RTN"",""PSOERRX1"",225,0)"
^XMB(3.9,144652,2,690,0)=" I $D(RXREQARY),MTYPE=""CR"",$G(MSTPFLTR)=MTYPE D  Q:SKIP"
^XMB(3.9,144652,2,691,0)="""RTN"",""PSOERRX1"",226,0)"
^XMB(3.9,144652,2,692,0)=" . I $G(CHGMESRI)="""" S SKIP=1 Q"
^XMB(3.9,144652,2,693,0)="""RTN"",""PSOERRX1"",227,0)"
^XMB(3.9,144652,2,694,0)=" . I '$D(RXREQARY(CHGMESRI)) S SKIP=1"
^XMB(3.9,144652,2,695,0)="""RTN"",""PSOERRX1"",228,0)"
^XMB(3.9,144652,2,696,0)=" S Z="""",$P(Z,""^"")=PATNAME,$P(Z,""^"",2)=$$FMTE^XLFDT(DOB,""2Z""),$P(Z,""^"",3)=EDRUG,$P(Z,""^"",4)=PROVIDER"
^XMB(3.9,144652,2,697,0)="""RTN"",""PSOERRX1"",229,0)"
^XMB(3.9,144652,2,698,0)=" S $P(Z,""^"",5)=ERXSTAT,$P(Z,""^"",6)=$$FMTE^XLFDT(MSGDT\1,""2Z"")"
^XMB(3.9,144652,2,699,0)="""RTN"",""PSOERRX1"",230,0)"
^XMB(3.9,144652,2,700,0)=" S SORT=MSGDT_ERXIEN_"" """
^XMB(3.9,144652,2,701,0)="""RTN"",""PSOERRX1"",231,0)"
^XMB(3.9,144652,2,702,0)=" I FIELD=""PA"" S SORT=PATNAME_"" ""_ERXIEN"
^XMB(3.9,144652,2,703,0)="""RTN"",""PSOERRX1"",232,0)"
^XMB(3.9,144652,2,704,0)=" I FIELD=""DOB"" S SORT=DOB_"" ""_ERXIEN"
^XMB(3.9,144652,2,705,0)="""RTN"",""PSOERRX1"",233,0)"
^XMB(3.9,144652,2,706,0)=" I FIELD=""DR"" S SORT=$$UP^XLFSTR(EDRUG)_"" ""_ERXIEN"
^XMB(3.9,144652,2,707,0)="""RTN"",""PSOERRX1"",234,0)"
^XMB(3.9,144652,2,708,0)=" I FIELD=""PR"" S SORT=PROVIDER_"" ""_ERXIEN"
^XMB(3.9,144652,2,709,0)="""RTN"",""PSOERRX1"",235,0)"
^XMB(3.9,144652,2,710,0)=" I FIELD=""RE"" S SORT=MSGDT_"" ""_ERXIEN"
^XMB(3.9,144652,2,711,0)="""RTN"",""PSOERRX1"",236,0)"
^XMB(3.9,144652,2,712,0)=" I FIELD=""STA"" S SORT=ERXSTAT_"" ""_ERXIEN"
^XMB(3.9,144652,2,713,0)="""RTN"",""PSOERRX1"",237,0)"
^XMB(3.9,144652,2,714,0)=" S ^TMP(""PSOERRXS"",$J,CSGROUP,SORT)=Z"
^XMB(3.9,144652,2,715,0)="""RTN"",""PSOERRX1"",238,0)"
^XMB(3.9,144652,2,716,0)=" S ^TMP(""PSOERRXS"",$J,CSGROUP,SORT,""ERXIEN"")=ERXIEN_""^""_$S($G(LOCKPATS(+EPATIEN)):1,1:0)"
^XMB(3.9,144652,2,717,0)="""RTN"",""PSOERRX1"",239,0)"
^XMB(3.9,144652,2,718,0)=" S ^TMP(""PSOERINC"",$J,ERXIEN)="""""
^XMB(3.9,144652,2,719,0)="""RTN"",""PSOERRX1"",240,0)"
^XMB(3.9,144652,2,720,0)=" S COUNTER=$G(COUNTER)+1"
^XMB(3.9,144652,2,721,0)="""RTN"",""PSOERRX1"",241,0)"
^XMB(3.9,144652,2,722,0)=" Q"
^XMB(3.9,144652,2,723,0)="""RTN"",""PSOERRX1"",242,0)"
^XMB(3.9,144652,2,724,0)=" ;"
^XMB(3.9,144652,2,725,0)="""RTN"",""PSOERRX1"",243,0)"
^XMB(3.9,144652,2,726,0)="VPRVFLTR ; - VistA Provider Filter"
^XMB(3.9,144652,2,727,0)="""RTN"",""PSOERRX1"",244,0)"
^XMB(3.9,144652,2,728,0)=" N DIR,PRV,XX,RANGE,COMSEG,I,J,VPRV,EPRV,DIRUT,DIROUT,QUIT"
^XMB(3.9,144652,2,729,0)="""RTN"",""PSOERRX1"",245,0)"
^XMB(3.9,144652,2,730,0)="REP1 ; - Repeat VistA Provider Prompt"
^XMB(3.9,144652,2,731,0)="""RTN"",""PSOERRX1"",246,0)"
^XMB(3.9,144652,2,732,0)=" S DIR(0)=""F^3:30"",DIR(""A"")=""VISTA PROVIDER NAME"""
^XMB(3.9,144652,2,733,0)="""RTN"",""PSOERRX1"",247,0)"
^XMB(3.9,144652,2,734,0)=" W ! D ^DIR I $D(DIRUT)!$D(DIROUT) Q"
^XMB(3.9,144652,2,735,0)="""RTN"",""PSOERRX1"",248,0)"
^XMB(3.9,144652,2,736,0)=" I $$CHKPRV2^PSOERX1A(Y)"
^XMB(3.9,144652,2,737,0)="""RTN"",""PSOERRX1"",249,0)"
^XMB(3.9,144652,2,738,0)=" D FIND^DIC(200,"""",""@;.01;.114;.115;53.2;IX"","""",X,,""B"",""I $$CHKPRV2^PSOERX1A(Y)"","""",""PRVLST"")"
^XMB(3.9,144652,2,739,0)="""RTN"",""PSOERRX1"",250,0)"
^XMB(3.9,144652,2,740,0)=" I '$D(PRVLST(""DILIST"",2)) W !,""No VistA Provider found"",$C(7) K PRVLST G REP1"
^XMB(3.9,144652,2,741,0)="""RTN"",""PSOERRX1"",251,0)"
^XMB(3.9,144652,2,742,0)=" ;"
^XMB(3.9,144652,2,743,0)="""RTN"",""PSOERRX1"",252,0)"
^XMB(3.9,144652,2,744,0)=" D PRVLHDR"
^XMB(3.9,144652,2,745,0)="""RTN"",""PSOERRX1"",253,0)"
^XMB(3.9,144652,2,746,0)=" S (QUIT,CNT)=0 K DIRUT,DTOUT"
^XMB(3.9,144652,2,747,0)="""RTN"",""PSOERRX1"",254,0)"
^XMB(3.9,144652,2,748,0)=" S PRV="""" F  S PRV=$O(PRVLST(""DILIST"",""ID"",PRV)) Q:'PRV  D  I QUIT Q"
^XMB(3.9,144652,2,749,0)="""RTN"",""PSOERRX1"",255,0)"
^XMB(3.9,144652,2,750,0)=" . W !,PRV,""."",?4,$E(PRVLST(""DILIST"",""ID"",PRV,.01),1,30),?35,PRVLST(""DILIST"",""ID"",PRV,53.2)"
^XMB(3.9,144652,2,751,0)="""RTN"",""PSOERRX1"",256,0)"
^XMB(3.9,144652,2,752,0)=" . I PRVLST(""DILIST"",""ID"",PRV,.114)'="""" D"
^XMB(3.9,144652,2,753,0)="""RTN"",""PSOERRX1"",257,0)"
^XMB(3.9,144652,2,754,0)=" . . W ?47,$E(PRVLST(""DILIST"",""ID"",PRV,.114),1,20),""-"",$$STATEABB^PSOERUT(200,PRVLST(""DILIST"",2,PRV))"
^XMB(3.9,144652,2,755,0)="""RTN"",""PSOERRX1"",258,0)"
^XMB(3.9,144652,2,756,0)=" . W ?71,$$FMTE^XLFDT($$LASTREDT^PSOERUT(""AVPRV"",PRVLST(""DILIST"",2,PRV)),""2Z"")"
^XMB(3.9,144652,2,757,0)="""RTN"",""PSOERRX1"",259,0)"
^XMB(3.9,144652,2,758,0)=" . S CNT=CNT+1"
^XMB(3.9,144652,2,759,0)="""RTN"",""PSOERRX1"",260,0)"
^XMB(3.9,144652,2,760,0)=" . I CNT>18,$O(PRVLST(""DILIST"",""ID"",PRV)),$Y>(IOSL-4) D"
^XMB(3.9,144652,2,761,0)="""RTN"",""PSOERRX1"",261,0)"
^XMB(3.9,144652,2,762,0)=" . . K DIR S DIR(0)=""E"" D ^DIR I $D(DIRUT)!$D(DIROUT) S QUIT=1 Q"
^XMB(3.9,144652,2,763,0)="""RTN"",""PSOERRX1"",262,0)"
^XMB(3.9,144652,2,764,0)=" . . W @IOF D PRVLHDR"
^XMB(3.9,144652,2,765,0)="""RTN"",""PSOERRX1"",263,0)"
^XMB(3.9,144652,2,766,0)=" ;"
^XMB(3.9,144652,2,767,0)="""RTN"",""PSOERRX1"",264,0)"
^XMB(3.9,144652,2,768,0)=" K DIR S DIR(""A"")=""SELECT (1-""_+$G(PRVLST(""DILIST"",0))_""): """
^XMB(3.9,144652,2,769,0)="""RTN"",""PSOERRX1"",265,0)"
^XMB(3.9,144652,2,770,0)=" S DIR(0)=""LA^1:""_+$G(PRVLST(""DILIST"",0)) W ! D ^DIR I $D(DIRUT)!$D(DIROUT) G REP1"
^XMB(3.9,144652,2,771,0)="""RTN"",""PSOERRX1"",266,0)"
^XMB(3.9,144652,2,772,0)=" S RANGE=X"
^XMB(3.9,144652,2,773,0)="""RTN"",""PSOERRX1"",267,0)"
^XMB(3.9,144652,2,774,0)=" ;"
^XMB(3.9,144652,2,775,0)="""RTN"",""PSOERRX1"",268,0)"
^XMB(3.9,144652,2,776,0)=" K VPRVFLTR,PRVFLTR"
^XMB(3.9,144652,2,777,0)="""RTN"",""PSOERRX1"",269,0)"
^XMB(3.9,144652,2,778,0)=" F I=1:1:$L(RANGE,"","") D"
^XMB(3.9,144652,2,779,0)="""RTN"",""PSOERRX1"",270,0)"
^XMB(3.9,144652,2,780,0)=" . S COMSEG=$P(RANGE,"","",I)"
^XMB(3.9,144652,2,781,0)="""RTN"",""PSOERRX1"",271,0)"
^XMB(3.9,144652,2,782,0)=" . F J=+COMSEG:1:$S(COMSEG[""-"":$P(COMSEG,""-"",2),1:+COMSEG) D"
^XMB(3.9,144652,2,783,0)="""RTN"",""PSOERRX1"",272,0)"
^XMB(3.9,144652,2,784,0)=" . . S VPRV=+$G(PRVLST(""DILIST"",2,J)) I 'VPRV Q"
^XMB(3.9,144652,2,785,0)="""RTN"",""PSOERRX1"",273,0)"
^XMB(3.9,144652,2,786,0)=" . . S VPRVFLTR(VPRV)="""""
^XMB(3.9,144652,2,787,0)="""RTN"",""PSOERRX1"",274,0)"
^XMB(3.9,144652,2,788,0)=" . . S EPRV=0 F  S EPRV=$O(^PS(52.49,""AVPRV"",VPRV,EPRV)) Q:'EPRV  D"
^XMB(3.9,144652,2,789,0)="""RTN"",""PSOERRX1"",275,0)"
^XMB(3.9,144652,2,790,0)=" . . . S PRVFLTR(EPRV)="""""
^XMB(3.9,144652,2,791,0)="""RTN"",""PSOERRX1"",276,0)"
^XMB(3.9,144652,2,792,0)=" ;"
^XMB(3.9,144652,2,793,0)="""RTN"",""PSOERRX1"",277,0)"
^XMB(3.9,144652,2,794,0)=" I '$D(PRVFLTR) W !!,""There are no eRx Providers associated with the VistA Provider(s) selected."",$C(7) K VPRVFLTR G REP1"
^XMB(3.9,144652,2,795,0)="""RTN"",""PSOERRX1"",278,0)"
^XMB(3.9,144652,2,796,0)=" Q"
^XMB(3.9,144652,2,797,0)="""RTN"",""PSOERRX1"",279,0)"
^XMB(3.9,144652,2,798,0)=" ;"
^XMB(3.9,144652,2,799,0)="""RTN"",""PSOERRX1"",280,0)"
^XMB(3.9,144652,2,800,0)="PRVLHDR ; - Prints the Provider List Header"
^XMB(3.9,144652,2,801,0)="""RTN"",""PSOERRX1"",281,0)"
^XMB(3.9,144652,2,802,0)=" N XX W !?73,""LAST"",!,""#"",?4,""VISTA PROVIDER NAME"",?35,""DEA"",?47,""CITY"",?71,""REC.DATE"""
^XMB(3.9,144652,2,803,0)="""RTN"",""PSOERRX1"",282,0)"
^XMB(3.9,144652,2,804,0)=" S $P(XX,""-"",80)="""" W !,XX"
^XMB(3.9,144652,2,805,0)="""RTN"",""PSOERRX1"",283,0)"
^XMB(3.9,144652,2,806,0)=" Q"
^XMB(3.9,144652,2,807,0)="""RTN"",""PSOERRX1"",284,0)"
^XMB(3.9,144652,2,808,0)=" ;"
^XMB(3.9,144652,2,809,0)="""RTN"",""PSOERRX1"",285,0)"
^XMB(3.9,144652,2,810,0)="VDRGFLTR ;VistA Drug Filter"
^XMB(3.9,144652,2,811,0)="""RTN"",""PSOERRX1"",286,0)"
^XMB(3.9,144652,2,812,0)=" ;- input vars for ^DIC call"
^XMB(3.9,144652,2,813,0)="""RTN"",""PSOERRX1"",287,0)"
^XMB(3.9,144652,2,814,0)=" N DIC,DTOUT,DUOUT,X,Y,DRGFLTR"
^XMB(3.9,144652,2,815,0)="""RTN"",""PSOERRX1"",288,0)"
^XMB(3.9,144652,2,816,0)="REPDRG ;Repeat VistA Drug Prompt"
^XMB(3.9,144652,2,817,0)="""RTN"",""PSOERRX1"",289,0)"
^XMB(3.9,144652,2,818,0)=" I $G(VDRGFLTR) S DIC(""B"")=$$GET1^DIQ(50,VDRGFLTR,.01)"
^XMB(3.9,144652,2,819,0)="""RTN"",""PSOERRX1"",290,0)"
^XMB(3.9,144652,2,820,0)=" W !"
^XMB(3.9,144652,2,821,0)="""RTN"",""PSOERRX1"",291,0)"
^XMB(3.9,144652,2,822,0)=" S DIC=50,DIC(0)=""AEMQZV"",DIC(""A"")=""VISTA DRUG: """
^XMB(3.9,144652,2,823,0)="""RTN"",""PSOERRX1"",292,0)"
^XMB(3.9,144652,2,824,0)=" S DIC(""?PARAM"",50,""INDEX"")=""B"""
^XMB(3.9,144652,2,825,0)="""RTN"",""PSOERRX1"",293,0)"
^XMB(3.9,144652,2,826,0)=" ;- lookup VISTA DRUG"
^XMB(3.9,144652,2,827,0)="""RTN"",""PSOERRX1"",294,0)"
^XMB(3.9,144652,2,828,0)=" D ^DIC K DIC"
^XMB(3.9,144652,2,829,0)="""RTN"",""PSOERRX1"",295,0)"
^XMB(3.9,144652,2,830,0)=" ;- result of lookup"
^XMB(3.9,144652,2,831,0)="""RTN"",""PSOERRX1"",296,0)"
^XMB(3.9,144652,2,832,0)=" I +$G(Y)<1 Q  ;user either press enter or ^"
^XMB(3.9,144652,2,833,0)="""RTN"",""PSOERRX1"",297,0)"
^XMB(3.9,144652,2,834,0)=" ;- if success, check if the selected drug exist in the ^PS(52.49,""AVDRG"" cross reference"
^XMB(3.9,144652,2,835,0)="""RTN"",""PSOERRX1"",298,0)"
^XMB(3.9,144652,2,836,0)=" I (+$G(Y)>0),$D(^PS(52.49,""AVDRG"",+$G(Y))) D"
^XMB(3.9,144652,2,837,0)="""RTN"",""PSOERRX1"",299,0)"
^XMB(3.9,144652,2,838,0)=" . S VDRGFLTR=+$G(Y)"
^XMB(3.9,144652,2,839,0)="""RTN"",""PSOERRX1"",300,0)"
^XMB(3.9,144652,2,840,0)=" E  W !!,IOINHI,""There are no eRx Drug(s) matched to this VistA Drug."",IOINORM,$C(7) K VDRGFLTR G REPDRG"
^XMB(3.9,144652,2,841,0)="""RTN"",""PSOERRX1"",301,0)"
^XMB(3.9,144652,2,842,0)=" Q"
^XMB(3.9,144652,2,843,0)="""RTN"",""PSOERRX1"",302,0)"
^XMB(3.9,144652,2,844,0)=" ;"
^XMB(3.9,144652,2,845,0)="""RTN"",""PSOERRX1"",303,0)"
^XMB(3.9,144652,2,846,0)="CHKSTSLST(ERXIEN,STSFLTR) ;Check erx order status"
^XMB(3.9,144652,2,847,0)="""RTN"",""PSOERRX1"",304,0)"
^XMB(3.9,144652,2,848,0)=" ;Input : ERXIEN  - Pointer to ERX HOLDING QUEUE file (#52.49)"
^XMB(3.9,144652,2,849,0)="""RTN"",""PSOERRX1"",305,0)"
^XMB(3.9,144652,2,850,0)=" ;        STSFLTR - Filter By eRx Status is set (Pointer to ERX HOLDING QUEUE file (#52.45))"
^XMB(3.9,144652,2,851,0)="""RTN"",""PSOERRX1"",306,0)"
^XMB(3.9,144652,2,852,0)=" ;Output: Return 1 if found. otherwise, 0"
^XMB(3.9,144652,2,853,0)="""RTN"",""PSOERRX1"",307,0)"
^XMB(3.9,144652,2,854,0)=" Q:+$G(ERXIEN)<1"
^XMB(3.9,144652,2,855,0)="""RTN"",""PSOERRX1"",308,0)"
^XMB(3.9,144652,2,856,0)=" N STSDTME,STSIEN,RSNIEN,FOUND,CNTR,ERXNODE1"
^XMB(3.9,144652,2,857,0)="""RTN"",""PSOERRX1"",309,0)"
^XMB(3.9,144652,2,858,0)=" S (FOUND,CNTR)=0"
^XMB(3.9,144652,2,859,0)="""RTN"",""PSOERRX1"",310,0)"
^XMB(3.9,144652,2,860,0)=" S ERXNODE1=$G(^PS(52.49,ERXIEN,1))"
^XMB(3.9,144652,2,861,0)="""RTN"",""PSOERRX1"",311,0)"
^XMB(3.9,144652,2,862,0)=" S STSDTME="""" F  S STSDTME=$O(^PS(52.49,ERXIEN,19,""B"",STSDTME),-1) Q:STSDTME=""""!(CNTR=2)  D  Q:FOUND"
^XMB(3.9,144652,2,863,0)="""RTN"",""PSOERRX1"",312,0)"
^XMB(3.9,144652,2,864,0)=" . S STSIEN="""" F  S STSIEN=$O(^PS(52.49,ERXIEN,19,""B"",STSDTME,STSIEN),-1) Q:STSIEN=""""!(CNTR=2)  D  Q:FOUND"
^XMB(3.9,144652,2,865,0)="""RTN"",""PSOERRX1"",313,0)"
^XMB(3.9,144652,2,866,0)=" . . S CNTR=CNTR+1"
^XMB(3.9,144652,2,867,0)="""RTN"",""PSOERRX1"",314,0)"
^XMB(3.9,144652,2,868,0)=" . . S RSNIEN=$P($G(^PS(52.49,ERXIEN,19,STSIEN,0)),""^"",2)"
^XMB(3.9,144652,2,869,0)="""RTN"",""PSOERRX1"",315,0)"
^XMB(3.9,144652,2,870,0)=" . . I $G(STSFLTR)=+ERXNODE1,$D(STSRMARY(RSNIEN)) S FOUND=1"
^XMB(3.9,144652,2,871,0)="""RTN"",""PSOERRX1"",316,0)"
^XMB(3.9,144652,2,872,0)=" Q FOUND"
^XMB(3.9,144652,2,873,0)="""VER"")"
^XMB(3.9,144652,2,874,0)="8.0^22.2"
^XMB(3.9,144652,2,875,0)="$END KID PSO*7.0*805b"
