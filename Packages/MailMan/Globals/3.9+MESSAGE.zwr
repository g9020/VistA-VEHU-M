^XMB(3.9,145837,2,475,0)="""RTN"",""XQALSET"",118,0)"
^XMB(3.9,145837,2,476,0)="SNDNACTV(XQAID) ; Determine if we go ahead and send alerts addressed only to inactive users to backup reviewers"
^XMB(3.9,145837,2,477,0)="""RTN"",""XQALSET"",119,0)"
^XMB(3.9,145837,2,478,0)=" N XVAL"
^XMB(3.9,145837,2,479,0)="""RTN"",""XQALSET"",120,0)"
^XMB(3.9,145837,2,480,0)=" I $E(XQAID,1,3)=""TIU"" S XVAL=$E($P(XQAID,"";""),4,99),XVAL=$$GET1^DIQ(8925,XVAL_"","",1201,""I"") I XVAL>0,$$FMDIFF^XLFDT(DT,XVAL)>60 Q 0"
^XMB(3.9,145837,2,481,0)="""RTN"",""XQALSET"",121,0)"
^XMB(3.9,145837,2,482,0)=" Q 1"
