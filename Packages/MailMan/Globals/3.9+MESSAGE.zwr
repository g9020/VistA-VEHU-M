^XMB(3.9,145834,2,6457,0)="""RTN"",""MAGDSTAS"",118,0)"
^XMB(3.9,145834,2,6458,0)=" . . . Q"
^XMB(3.9,145834,2,6459,0)="""RTN"",""MAGDSTAS"",119,0)"
^XMB(3.9,145834,2,6460,0)=" . . Q "
^XMB(3.9,145834,2,6461,0)="""RTN"",""MAGDSTAS"",120,0)"
^XMB(3.9,145834,2,6462,0)=" . Q"
^XMB(3.9,145834,2,6463,0)="""RTN"",""MAGDSTAS"",121,0)"
^XMB(3.9,145834,2,6464,0)=" E  I SCANMODE=""NUMBER"" D"
^XMB(3.9,145834,2,6465,0)="""RTN"",""MAGDSTAS"",122,0)"
^XMB(3.9,145834,2,6466,0)=" . W !,""The NUMBER scan has not been run for the following IEN intervals:"""
^XMB(3.9,145834,2,6467,0)="""RTN"",""MAGDSTAS"",123,0)"
^XMB(3.9,145834,2,6468,0)=" . S (ZEROIEN1,ZEROIEN2)=0"
^XMB(3.9,145834,2,6469,0)="""RTN"",""MAGDSTAS"",124,0)"
^XMB(3.9,145834,2,6470,0)=" . S MOD100="""" ; first node may be 0"
^XMB(3.9,145834,2,6471,0)="""RTN"",""MAGDSTAS"",125,0)"
^XMB(3.9,145834,2,6472,0)=" . F MOD100=0:1:10 D"
^XMB(3.9,145834,2,6473,0)="""RTN"",""MAGDSTAS"",126,0)"
