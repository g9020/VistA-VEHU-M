^XMB(3.9,144657,2,7540,0)=" ;"
^XMB(3.9,144657,2,7541,0)="""RTN"",""IBCNICB"")"
^XMB(3.9,144657,2,7542,0)="0^19^B150108434"
^XMB(3.9,144657,2,7543,0)="""RTN"",""IBCNICB"",1,0)"
^XMB(3.9,144657,2,7544,0)="IBCNICB ;ALB/SBW - Update utilities for the ICB interface ;1 SEP 2009"
^XMB(3.9,144657,2,7545,0)="""RTN"",""IBCNICB"",2,0)"
^XMB(3.9,144657,2,7546,0)=" ;;2.0;INTEGRATED BILLING;**413,416,528,549,687,737**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,7547,0)="""RTN"",""IBCNICB"",3,0)"
^XMB(3.9,144657,2,7548,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,7549,0)="""RTN"",""IBCNICB"",4,0)"
^XMB(3.9,144657,2,7550,0)=" ;"
^XMB(3.9,144657,2,7551,0)="""RTN"",""IBCNICB"",5,0)"
^XMB(3.9,144657,2,7552,0)="ACCEPAPI(RESULT,IBBUFDA,DFN,IBINSDA,IBGRPDA,IBPOLDA,IBMVINS,IBMVGRP,IBMVPOL,IBNEWINS,IBNEWGRP,IBNEWPOL,IVMREPTR,IBELIG) ;"
^XMB(3.9,144657,2,7553,0)="""RTN"",""IBCNICB"",6,0)"
^XMB(3.9,144657,2,7554,0)=" ;Provides API to be called by the Insurance Capture Buffer (ICB) "
^XMB(3.9,144657,2,7555,0)="""RTN"",""IBCNICB"",7,0)"
^XMB(3.9,144657,2,7556,0)=" ;application to move buffer data in Insurance Files then cleanup"
^XMB(3.9,144657,2,7557,0)="""RTN"",""IBCNICB"",8,0)"
^XMB(3.9,144657,2,7558,0)=" ;"
^XMB(3.9,144657,2,7559,0)="""RTN"",""IBCNICB"",9,0)"
^XMB(3.9,144657,2,7560,0)=" ;The call to PROCESS^IBCNBAR and embedded Sub calls are updated to "
^XMB(3.9,144657,2,7561,0)="""RTN"",""IBCNICB"",10,0)"
^XMB(3.9,144657,2,7562,0)=" ;provide data in the RESULT parameter and suppress user I/O when "
^XMB(3.9,144657,2,7563,0)="""RTN"",""IBCNICB"",11,0)"
^XMB(3.9,144657,2,7564,0)=" ;function is called by ICB."
^XMB(3.9,144657,2,7565,0)="""RTN"",""IBCNICB"",12,0)"
^XMB(3.9,144657,2,7566,0)=" ;Input"
^XMB(3.9,144657,2,7567,0)="""RTN"",""IBCNICB"",13,0)"
^XMB(3.9,144657,2,7568,0)=" ;  IBBUFDA  - INSURANCE BUFFER (#355.33) file internal entry number (IEN) (Required)"
^XMB(3.9,144657,2,7569,0)="""RTN"",""IBCNICB"",14,0)"
^XMB(3.9,144657,2,7570,0)=" ;  DFN      - PATIENT (#2) file IEN (Required)"
^XMB(3.9,144657,2,7571,0)="""RTN"",""IBCNICB"",15,0)"
^XMB(3.9,144657,2,7572,0)=" ;  IBINSDA  - INSURANCE COMPANY (#36) File IEN if not adding new entry (Optional)"
^XMB(3.9,144657,2,7573,0)="""RTN"",""IBCNICB"",16,0)"
^XMB(3.9,144657,2,7574,0)=" ;  IBGRPDA  - GROUP INSURANCE PLAN (#355.3) File IEN if not adding new entry (Optional)"
^XMB(3.9,144657,2,7575,0)="""RTN"",""IBCNICB"",17,0)"
^XMB(3.9,144657,2,7576,0)=" ;  IBPOLDA  - INSURANCE TYPE (#2.312) sub-file of PATIENT (#2) IEN if"
^XMB(3.9,144657,2,7577,0)="""RTN"",""IBCNICB"",18,0)"
^XMB(3.9,144657,2,7578,0)=" ;             not adding new entry (Optional)"
^XMB(3.9,144657,2,7579,0)="""RTN"",""IBCNICB"",19,0)"
^XMB(3.9,144657,2,7580,0)=" ;  IBMVINS  - Type for INSURANCE (Required)"
^XMB(3.9,144657,2,7581,0)="""RTN"",""IBCNICB"",20,0)"
^XMB(3.9,144657,2,7582,0)=" ;     1=Merge, 2=Overwrite, 3=Replace, 4=Unsupported"
^XMB(3.9,144657,2,7583,0)="""RTN"",""IBCNICB"",21,0)"
^XMB(3.9,144657,2,7584,0)=" ;  IBMVGRP  - Type for GROUP (Optional)"
^XMB(3.9,144657,2,7585,0)="""RTN"",""IBCNICB"",22,0)"
^XMB(3.9,144657,2,7586,0)=" ;     1=Merge, 2=Overwrite, 3=Replace, 4=Unsupported"
^XMB(3.9,144657,2,7587,0)="""RTN"",""IBCNICB"",23,0)"
^XMB(3.9,144657,2,7588,0)=" ;  IBMVPOL  - Type for POLICY (Optional)"
^XMB(3.9,144657,2,7589,0)="""RTN"",""IBCNICB"",24,0)"
^XMB(3.9,144657,2,7590,0)=" ;     1=Merge, 2=Overwrite, 3=Replace, 4=Unsupported"
^XMB(3.9,144657,2,7591,0)="""RTN"",""IBCNICB"",25,0)"
^XMB(3.9,144657,2,7592,0)=" ;  IBNEWINS - Add new INSURANCE COMPANY flag (non-zero means add)"
^XMB(3.9,144657,2,7593,0)="""RTN"",""IBCNICB"",26,0)"
^XMB(3.9,144657,2,7594,0)=" ;  IBNEWGRP - Add new GROUP INSURANCE PLAN flag (non-zero means add)"
^XMB(3.9,144657,2,7595,0)="""RTN"",""IBCNICB"",27,0)"
^XMB(3.9,144657,2,7596,0)=" ;  IBNEWPOL - Add new patient insurance policy (non-zero means add)"
^XMB(3.9,144657,2,7597,0)="""RTN"",""IBCNICB"",28,0)"
^XMB(3.9,144657,2,7598,0)=" ;  IVMREPTR - IVM REASONS FOR NOT UPLOADING (#301.91) IEN (Optional)"
^XMB(3.9,144657,2,7599,0)="""RTN"",""IBCNICB"",29,0)"
^XMB(3.9,144657,2,7600,0)=" ;"
^XMB(3.9,144657,2,7601,0)="""RTN"",""IBCNICB"",30,0)"
^XMB(3.9,144657,2,7602,0)=" ;OUTPUT"
^XMB(3.9,144657,2,7603,0)="""RTN"",""IBCNICB"",31,0)"
^XMB(3.9,144657,2,7604,0)=" ;  RESULT   - Returned Parameter Array with IENS of new entries and/or errors/warning."
^XMB(3.9,144657,2,7605,0)="""RTN"",""IBCNICB"",32,0)"
^XMB(3.9,144657,2,7606,0)=" ;     RESULT(0) = -1^error message"
^XMB(3.9,144657,2,7607,0)="""RTN"",""IBCNICB"",33,0)"
^XMB(3.9,144657,2,7608,0)=" ;     RESULT(0) =   0 -Move worked"
^XMB(3.9,144657,2,7609,0)="""RTN"",""IBCNICB"",34,0)"
^XMB(3.9,144657,2,7610,0)=" ;     RESULT(0) =   0 ^ warning message ^ warning message ^ "
^XMB(3.9,144657,2,7611,0)="""RTN"",""IBCNICB"",35,0)"
^XMB(3.9,144657,2,7612,0)=" ;                   warning message ^ warning message"
^XMB(3.9,144657,2,7613,0)="""RTN"",""IBCNICB"",36,0)"
^XMB(3.9,144657,2,7614,0)=" ;             - Move worked but there may be zero to 4 warning messages"
^XMB(3.9,144657,2,7615,0)="""RTN"",""IBCNICB"",37,0)"
^XMB(3.9,144657,2,7616,0)=" ;     RESULT(1) = ""IBINSDA^"" IEN of new Insurance Company (#36) File"
^XMB(3.9,144657,2,7617,0)="""RTN"",""IBCNICB"",38,0)"
^XMB(3.9,144657,2,7618,0)=" ;     RESULT(1,""ERR"",#) - Array with any FM errors when data updated"
^XMB(3.9,144657,2,7619,0)="""RTN"",""IBCNICB"",39,0)"
^XMB(3.9,144657,2,7620,0)=" ;                         from file 355.33 to 36."
^XMB(3.9,144657,2,7621,0)="""RTN"",""IBCNICB"",40,0)"
^XMB(3.9,144657,2,7622,0)=" ;     RESULT(2) = ""IBGRPDA^"" IEN of new GROUP INSURANCE PLAN (#355.3) File"
^XMB(3.9,144657,2,7623,0)="""RTN"",""IBCNICB"",41,0)"
^XMB(3.9,144657,2,7624,0)=" ;     RESULT(2,""ERR"",#) - Array with any FM errors when data updated"
^XMB(3.9,144657,2,7625,0)="""RTN"",""IBCNICB"",42,0)"
^XMB(3.9,144657,2,7626,0)=" ;                         from file 355.33 to 355.3."
^XMB(3.9,144657,2,7627,0)="""RTN"",""IBCNICB"",43,0)"
^XMB(3.9,144657,2,7628,0)=" ;     RESULT(3) = ""IBPOLDA^"" IEN of new INSURANCE TYPE (#2.312) sub-file of PATIENT (#2) IEN"
^XMB(3.9,144657,2,7629,0)="""RTN"",""IBCNICB"",44,0)"
^XMB(3.9,144657,2,7630,0)=" ;     RESULT(3,""ERR"",#) - Array with any FM errors when data updated"
^XMB(3.9,144657,2,7631,0)="""RTN"",""IBCNICB"",45,0)"
^XMB(3.9,144657,2,7632,0)=" ;                         from file 355.33 to 2.312."
^XMB(3.9,144657,2,7633,0)="""RTN"",""IBCNICB"",46,0)"
^XMB(3.9,144657,2,7634,0)=" ;     RESULT(4) Contains the results of the call to UPDPOL^IBCNICB which"
^XMB(3.9,144657,2,7635,0)="""RTN"",""IBCNICB"",47,0)"
^XMB(3.9,144657,2,7636,0)=" ;               is used to update a new group into an existing patient"
^XMB(3.9,144657,2,7637,0)="""RTN"",""IBCNICB"",48,0)"
^XMB(3.9,144657,2,7638,0)=" ;               policy entry when applicable."
^XMB(3.9,144657,2,7639,0)="""RTN"",""IBCNICB"",49,0)"
^XMB(3.9,144657,2,7640,0)=" ;     RESULT(4) =-1^error message      "
^XMB(3.9,144657,2,7641,0)="""RTN"",""IBCNICB"",50,0)"
^XMB(3.9,144657,2,7642,0)=" ;     RESULT(4) =0 ^ message that process was successful or not required"
^XMB(3.9,144657,2,7643,0)="""RTN"",""IBCNICB"",51,0)"
^XMB(3.9,144657,2,7644,0)=" ;"
^XMB(3.9,144657,2,7645,0)="""RTN"",""IBCNICB"",52,0)"
^XMB(3.9,144657,2,7646,0)=" ;IB*687/ckb - added IBCNICB"
^XMB(3.9,144657,2,7647,0)="""RTN"",""IBCNICB"",53,0)"
^XMB(3.9,144657,2,7648,0)=" N IBCNICB,IBSUPRES,IBUFSTAT,IBX"
^XMB(3.9,144657,2,7649,0)="""RTN"",""IBCNICB"",54,0)"
^XMB(3.9,144657,2,7650,0)=" I '$D(IBELIG) S IBELIG=0"
^XMB(3.9,144657,2,7651,0)="""RTN"",""IBCNICB"",55,0)"
^XMB(3.9,144657,2,7652,0)=" ;Set IBSUPRES to suppress screen I/O within ACCEPT"
^XMB(3.9,144657,2,7653,0)="""RTN"",""IBCNICB"",56,0)"
^XMB(3.9,144657,2,7654,0)=" S IBSUPRES=1,IBUFSTAT=$P($G(^IBA(355.33,$G(IBBUFDA),0)),U,4)"
^XMB(3.9,144657,2,7655,0)="""RTN"",""IBCNICB"",57,0)"
^XMB(3.9,144657,2,7656,0)=" ;IB*687/ckb - add set of IBCNICB. It will be used to set the ICB PROCESSED BUFFER field #1.08, in the"
^XMB(3.9,144657,2,7657,0)="""RTN"",""IBCNICB"",58,0)"
^XMB(3.9,144657,2,7658,0)=" ; INTERFACILITY UPDATE file #365.19. IBCNBAR will use IBCNICB when it calls LOC^IBCNIUF."
^XMB(3.9,144657,2,7659,0)="""RTN"",""IBCNICB"",59,0)"
^XMB(3.9,144657,2,7660,0)=" S IBCNICB=1"
^XMB(3.9,144657,2,7661,0)="""RTN"",""IBCNICB"",60,0)"
^XMB(3.9,144657,2,7662,0)=" ;"
^XMB(3.9,144657,2,7663,0)="""RTN"",""IBCNICB"",61,0)"
^XMB(3.9,144657,2,7664,0)=" S RESULT(0)=""-1^INSURANCE BUFFER (#355.33) IEN required"" Q:'$G(IBBUFDA)"
^XMB(3.9,144657,2,7665,0)="""RTN"",""IBCNICB"",62,0)"
^XMB(3.9,144657,2,7666,0)=" S RESULT(0)=""-1^INSURANCE BUFFER ENTRY PREVIOUSLY PROCESSED"""
^XMB(3.9,144657,2,7667,0)="""RTN"",""IBCNICB"",63,0)"
^XMB(3.9,144657,2,7668,0)=" Q:""~A~R~""[(""~""_IBUFSTAT_""~"")"
^XMB(3.9,144657,2,7669,0)="""RTN"",""IBCNICB"",64,0)"
^XMB(3.9,144657,2,7670,0)=" S RESULT(0)=""-1^INSURANCE BUFFER ENTRY STATUS SHOULD BE ENTERED"""
^XMB(3.9,144657,2,7671,0)="""RTN"",""IBCNICB"",65,0)"
^XMB(3.9,144657,2,7672,0)=" Q:IBUFSTAT'=""E"""
^XMB(3.9,144657,2,7673,0)="""RTN"",""IBCNICB"",66,0)"
^XMB(3.9,144657,2,7674,0)=" S RESULT(0)=""-1^PATIENT (#2) IEN required"" Q:'$G(DFN)"
^XMB(3.9,144657,2,7675,0)="""RTN"",""IBCNICB"",67,0)"
^XMB(3.9,144657,2,7676,0)=" S IBINSDA=$G(IBINSDA),IBGRPDA=$G(IBGRPDA),IBPOLDA=$G(IBPOLDA)"
^XMB(3.9,144657,2,7677,0)="""RTN"",""IBCNICB"",68,0)"
^XMB(3.9,144657,2,7678,0)=" S IBMVINS=$G(IBMVINS,2),IBMVGRP=$G(IBMVGRP,2),IBMVPOL=$G(IBMVPOL,2)"
^XMB(3.9,144657,2,7679,0)="""RTN"",""IBCNICB"",69,0)"
^XMB(3.9,144657,2,7680,0)=" S IBNEWINS=$G(IBNEWINS),IBNEWGRP=$G(IBNEWGRP),IBNEWPOL=$G(IBNEWPOL)"
^XMB(3.9,144657,2,7681,0)="""RTN"",""IBCNICB"",70,0)"
^XMB(3.9,144657,2,7682,0)=" ;"
^XMB(3.9,144657,2,7683,0)="""RTN"",""IBCNICB"",71,0)"
^XMB(3.9,144657,2,7684,0)=" S RESULT(0)=""-1^Passed INSURANCE COMPANY (#36) entry doesn't exist"""
^XMB(3.9,144657,2,7685,0)="""RTN"",""IBCNICB"",72,0)"
^XMB(3.9,144657,2,7686,0)=" I +IBINSDA,$G(^DIC(36,IBINSDA,0))="""" Q"
^XMB(3.9,144657,2,7687,0)="""RTN"",""IBCNICB"",73,0)"
^XMB(3.9,144657,2,7688,0)=" S RESULT(0)=""-1^Passed GROUP INSURANCE PLAN (#355.3) entry doesn't exist"""
^XMB(3.9,144657,2,7689,0)="""RTN"",""IBCNICB"",74,0)"
^XMB(3.9,144657,2,7690,0)=" I +IBGRPDA,$G(^IBA(355.3,IBGRPDA,0))="""" Q"
^XMB(3.9,144657,2,7691,0)="""RTN"",""IBCNICB"",75,0)"
^XMB(3.9,144657,2,7692,0)=" ; \Beginning IB*2*549 - added the following lines."
^XMB(3.9,144657,2,7693,0)="""RTN"",""IBCNICB"",76,0)"
^XMB(3.9,144657,2,7694,0)=" S RESULT(0)=""-1^Unable to add new INSURANCE COMPANY (#36) - See your supervisor"""
^XMB(3.9,144657,2,7695,0)="""RTN"",""IBCNICB"",77,0)"
^XMB(3.9,144657,2,7696,0)=" I +IBNEWINS,'$D(^XUSEC(""IB INSURANCE COMPANY EDIT"",DUZ)) Q"
^XMB(3.9,144657,2,7697,0)="""RTN"",""IBCNICB"",78,0)"
^XMB(3.9,144657,2,7698,0)=" S RESULT(0)=""-1^Unable to add new GROUP INSURANCE PLAN (#355.3) - See your supervisor"""
^XMB(3.9,144657,2,7699,0)="""RTN"",""IBCNICB"",79,0)"
^XMB(3.9,144657,2,7700,0)=" I +IBNEWGRP,'$D(^XUSEC(""IB GROUP PLAN EDIT"",DUZ)) Q"
^XMB(3.9,144657,2,7701,0)="""RTN"",""IBCNICB"",80,0)"
^XMB(3.9,144657,2,7702,0)=" S RESULT(0)=""-1^Unable to add new GROUP INSURANCE PLAN (#355.3) - Duplicate Group Plan"""
^XMB(3.9,144657,2,7703,0)="""RTN"",""IBCNICB"",81,0)"
^XMB(3.9,144657,2,7704,0)=" ;"
^XMB(3.9,144657,2,7705,0)="""RTN"",""IBCNICB"",82,0)"
^XMB(3.9,144657,2,7706,0)=" ; If new insurance company cont. processing"
^XMB(3.9,144657,2,7707,0)="""RTN"",""IBCNICB"",83,0)"
^XMB(3.9,144657,2,7708,0)=" I '(+IBNEWINS),+IBNEWGRP,$$EXACTM^IBCNICB2(IBINSDA,IBBUFDA) Q"
^XMB(3.9,144657,2,7709,0)="""RTN"",""IBCNICB"",84,0)"
^XMB(3.9,144657,2,7710,0)=" ; \End of IB*2*549"
^XMB(3.9,144657,2,7711,0)="""RTN"",""IBCNICB"",85,0)"
^XMB(3.9,144657,2,7712,0)=" S RESULT(0)=""-1^Passed Patient INSURANCE TYPE (#2.312) entry doesn't exist"""
^XMB(3.9,144657,2,7713,0)="""RTN"",""IBCNICB"",86,0)"
^XMB(3.9,144657,2,7714,0)=" I +IBPOLDA,$G(^DPT(DFN,.312,IBPOLDA,0))="""" Q"
^XMB(3.9,144657,2,7715,0)="""RTN"",""IBCNICB"",87,0)"
^XMB(3.9,144657,2,7716,0)=" S RESULT(0)=""-1^Passed GROUP INSURANCE PLAN (#355.3) entry points to different INSURANCE COMPANY (#36) entry"""
^XMB(3.9,144657,2,7717,0)="""RTN"",""IBCNICB"",88,0)"
^XMB(3.9,144657,2,7718,0)=" I +IBGRPDA,+IBINSDA,+$G(^IBA(355.3,IBGRPDA,0))'=IBINSDA Q"
^XMB(3.9,144657,2,7719,0)="""RTN"",""IBCNICB"",89,0)"
^XMB(3.9,144657,2,7720,0)=" S RESULT(0)=""-1^Individual Policy Patient required to be Patient DFN when Group Insurance Plan is not Group Policy"""
^XMB(3.9,144657,2,7721,0)="""RTN"",""IBCNICB"",90,0)"
^XMB(3.9,144657,2,7722,0)=" I +IBGRPDA S IBX=$G(^IBA(355.3,IBGRPDA,0)) I $P(IBX,U,2)=0,+$P(IBX,U,10),$P(IBX,U,10)'=DFN Q"
^XMB(3.9,144657,2,7723,0)="""RTN"",""IBCNICB"",91,0)"
^XMB(3.9,144657,2,7724,0)=" ;"
^XMB(3.9,144657,2,7725,0)="""RTN"",""IBCNICB"",92,0)"
^XMB(3.9,144657,2,7726,0)=" ;If existing GROUP INSURANCE PLAN (#355.3) entry is being changed from "
^XMB(3.9,144657,2,7727,0)="""RTN"",""IBCNICB"",93,0)"
^XMB(3.9,144657,2,7728,0)=" ;a group plan to individual plan with other subscribers, send error "
^XMB(3.9,144657,2,7729,0)="""RTN"",""IBCNICB"",94,0)"
^XMB(3.9,144657,2,7730,0)=" ;message and abort update"
^XMB(3.9,144657,2,7731,0)="""RTN"",""IBCNICB"",95,0)"
^XMB(3.9,144657,2,7732,0)=" S RESULT(0)=""-1^Can't change GROUP INSURANCE PLAN from Group Plan to Individual Plan when there are subscribers"""
^XMB(3.9,144657,2,7733,0)="""RTN"",""IBCNICB"",96,0)"
^XMB(3.9,144657,2,7734,0)=" I +IBGRPDA,$P(IBX,U,2)=1,$P($G(^IBA(355.33,+$G(IBBUFDA),40)),U,1)'=1,$$SUBS^IBCNSJ(IBINSDA,IBGRPDA)>1 Q"
^XMB(3.9,144657,2,7735,0)="""RTN"",""IBCNICB"",97,0)"
^XMB(3.9,144657,2,7736,0)=" ;"
^XMB(3.9,144657,2,7737,0)="""RTN"",""IBCNICB"",98,0)"
^XMB(3.9,144657,2,7738,0)=" N IBBUFABORT S IBBUFABORT=0 ;IB*737/CKB"
^XMB(3.9,144657,2,7739,0)="""RTN"",""IBCNICB"",99,0)"
^XMB(3.9,144657,2,7740,0)=" D PROCESS^IBCNBAR"
^XMB(3.9,144657,2,7741,0)="""RTN"",""IBCNICB"",100,0)"
^XMB(3.9,144657,2,7742,0)=" I IBBUFABORT=1 S RESULT(0)=""-1^Unable to process entry, if accepted it would corrupt the Effective Date of the policy"" ;IB*737/CKB"
^XMB(3.9,144657,2,7743,0)="""RTN"",""IBCNICB"",101,0)"
^XMB(3.9,144657,2,7744,0)=" Q"
^XMB(3.9,144657,2,7745,0)="""RTN"",""IBCNICB"",102,0)"
^XMB(3.9,144657,2,7746,0)=" ;"
^XMB(3.9,144657,2,7747,0)="""RTN"",""IBCNICB"",103,0)"
^XMB(3.9,144657,2,7748,0)="REJECAPI(RESULT,IBBUFDA,IVMREPTR) ;"
^XMB(3.9,144657,2,7749,0)="""RTN"",""IBCNICB"",104,0)"
^XMB(3.9,144657,2,7750,0)=" ;Provides API to be called by the Insurance Capture Buffer (ICB) "
^XMB(3.9,144657,2,7751,0)="""RTN"",""IBCNICB"",105,0)"
^XMB(3.9,144657,2,7752,0)=" ;application to reject buffer entry."
^XMB(3.9,144657,2,7753,0)="""RTN"",""IBCNICB"",106,0)"
^XMB(3.9,144657,2,7754,0)=" ;The REJPROC^IBCNBAR call and embedded Sub calls are updated to "
^XMB(3.9,144657,2,7755,0)="""RTN"",""IBCNICB"",107,0)"
^XMB(3.9,144657,2,7756,0)=" ;provide data in the RESULT parameter and suppress I/O when function "
^XMB(3.9,144657,2,7757,0)="""RTN"",""IBCNICB"",108,0)"
^XMB(3.9,144657,2,7758,0)=" ;is called by ICB."
^XMB(3.9,144657,2,7759,0)="""RTN"",""IBCNICB"",109,0)"
^XMB(3.9,144657,2,7760,0)=" ;Input:"
^XMB(3.9,144657,2,7761,0)="""RTN"",""IBCNICB"",110,0)"
^XMB(3.9,144657,2,7762,0)=" ;   IBBUFDA  - INSURANCE BUFFER (#355.33) file internal entry number"
^XMB(3.9,144657,2,7763,0)="""RTN"",""IBCNICB"",111,0)"
^XMB(3.9,144657,2,7764,0)=" ;              (required)"
^XMB(3.9,144657,2,7765,0)="""RTN"",""IBCNICB"",112,0)"
^XMB(3.9,144657,2,7766,0)=" ;   IVMREPTR - IVM REASONS FOR NOT UPLOADING (#301.91) File internal"
^XMB(3.9,144657,2,7767,0)="""RTN"",""IBCNICB"",113,0)"
^XMB(3.9,144657,2,7768,0)=" ;              internal entry number (Optional)"
^XMB(3.9,144657,2,7769,0)="""RTN"",""IBCNICB"",114,0)"
^XMB(3.9,144657,2,7770,0)=" ;Output:"
^XMB(3.9,144657,2,7771,0)="""RTN"",""IBCNICB"",115,0)"
^XMB(3.9,144657,2,7772,0)=" ;   RESULT   - Returned parameter variable with errors messages if"
^XMB(3.9,144657,2,7773,0)="""RTN"",""IBCNICB"",116,0)"
^XMB(3.9,144657,2,7774,0)=" ;              problems with the reject processing. Format:"
^XMB(3.9,144657,2,7775,0)="""RTN"",""IBCNICB"",117,0)"
^XMB(3.9,144657,2,7776,0)=" ;     REJECT = -1 ^ error message"
^XMB(3.9,144657,2,7777,0)="""RTN"",""IBCNICB"",118,0)"
^XMB(3.9,144657,2,7778,0)=" ;     REJECT =  0                     - Reject worked"
^XMB(3.9,144657,2,7779,0)="""RTN"",""IBCNICB"",119,0)"
^XMB(3.9,144657,2,7780,0)=" ;     REJECT =  0 ^ warning message   - Reject process worked but there"
