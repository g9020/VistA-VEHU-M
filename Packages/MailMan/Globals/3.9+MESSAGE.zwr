^XMB(3.9,145831,2,1036,0)=" .. S EDPX(""id"")=IEN,EDPX(""time"")=LAST,EDPX(""ussValue"")=$P(REC,U,8)"
^XMB(3.9,145831,2,1037,0)="""RTN"",""EDPVIT"",86,0)"
^XMB(3.9,145831,2,1038,0)=" .. S EDPX(""name"")=TYPE I TYPE=""WT"",$P(REC,U,14) S EDPBMI=IEN_U_$P(REC,U,14)"
