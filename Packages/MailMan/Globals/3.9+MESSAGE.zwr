^XMB(3.9,144657,2,886,0)=" I +IBINSDA,$P(IBMVINS,U,1)=0,+IBGRPDA,$P(IBMVGRP,U,1)=0,+IBPOLDA,$P(IBMVPOL,U,1)=0,$P(IBMVSUB,U,1)=0,+IBELIG=0 W !!!,""This would result in No Change to the existing Insurance data.  Process aborted."" D WAIT G ACCPTQ"
