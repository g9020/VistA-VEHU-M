^XMB(3.9,145834,2,7719,0)="""RTN"",""MAGDSTV1"",126,0)"
^XMB(3.9,145834,2,7720,0)=" . H 1"
^XMB(3.9,145834,2,7721,0)="""RTN"",""MAGDSTV1"",127,0)"
^XMB(3.9,145834,2,7722,0)=" . I $G(BATCHQR) Q  ; suppress text output"
^XMB(3.9,145834,2,7723,0)="""RTN"",""MAGDSTV1"",128,0)"
^XMB(3.9,145834,2,7724,0)=" . W ""."""
