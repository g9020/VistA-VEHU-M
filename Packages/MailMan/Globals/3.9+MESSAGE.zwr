^XMB(3.9,145834,2,2936,0)=" . S X=$$SERVICES^MAGDSTA8(.CONSULTSERVICES,""YES"")"
^XMB(3.9,145834,2,2937,0)="""RTN"",""MAGDSTA1"",145,0)"
^XMB(3.9,145834,2,2938,0)=" . K ^TMP(""MAG"",$J,""BATCH Q/R"",""CONSULT SERVICES"") ; remove old ones"
^XMB(3.9,145834,2,2939,0)="""RTN"",""MAGDSTA1"",146,0)"
