^XMB(3.9,144657,2,7004,0)=" N DIE,DA,DR,D,D0,DI,DIC,DQ,X"
^XMB(3.9,144657,2,7005,0)="""RTN"",""IBCNEUT2"",11,0)"
^XMB(3.9,144657,2,7006,0)=" S DIE=""^IBCN(365.1,"",DA=IEN,DR="".12////""_TDT"
