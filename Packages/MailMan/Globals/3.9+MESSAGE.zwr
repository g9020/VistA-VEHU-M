^XMB(3.9,145834,2,7328,0)=" S MEANING=""Unknown Status Code: """"""_CODE_"""""""""
^XMB(3.9,145834,2,7329,0)="""RTN"",""MAGDSTQ8"",167,0)"
^XMB(3.9,145834,2,7330,0)=" Q ""???"""
