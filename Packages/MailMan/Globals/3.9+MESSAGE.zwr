^XMB(3.9,144654,2,459,0)="""RTN"",""PSOHLDS2"",110,0)"
^XMB(3.9,144654,2,460,0)=" I $O(OSGY(0)) D  G KNTE"
^XMB(3.9,144654,2,461,0)="""RTN"",""PSOHLDS2"",111,0)"
^XMB(3.9,144654,2,462,0)=" .K DRR F DR=0:0 S DR=$O(SGY(DR)) Q:'DR  S DRR=$G(DRR)+1"
