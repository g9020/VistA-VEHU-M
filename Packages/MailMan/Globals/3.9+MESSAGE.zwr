^XMB(3.9,145833,2,761,0)="""RTN"",""SDES2UTDT"",25,0)"
^XMB(3.9,145833,2,762,0)=" .;append hour and min"
^XMB(3.9,145833,2,763,0)="""RTN"",""SDES2UTDT"",26,0)"
^XMB(3.9,145833,2,764,0)=" .S SDGMT=SDGMT_""T""_$E(SDTIME,1,2)_"":""_$E(SDTIME,3,4)"
