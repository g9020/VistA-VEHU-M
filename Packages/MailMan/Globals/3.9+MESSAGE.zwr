^XMB(3.9,145834,2,7499,0)="""RTN"",""MAGDSTV1"",16,0)"
^XMB(3.9,145834,2,7500,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,7501,0)="""RTN"",""MAGDSTV1"",17,0)"
^XMB(3.9,145834,2,7502,0)=" ;;"
^XMB(3.9,145834,2,7503,0)="""RTN"",""MAGDSTV1"",18,0)"
^XMB(3.9,145834,2,7504,0)=" ;"
^XMB(3.9,145834,2,7505,0)="""RTN"",""MAGDSTV1"",19,0)"
^XMB(3.9,145834,2,7506,0)=" ; Supported IA #10103 reference $$NOW^XLFDT function call"
^XMB(3.9,145834,2,7507,0)="""RTN"",""MAGDSTV1"",20,0)"
^XMB(3.9,145834,2,7508,0)=" ; Supported IA #10103 reference $$FMTE^XLFDT function call"
^XMB(3.9,145834,2,7509,0)="""RTN"",""MAGDSTV1"",21,0)"
^XMB(3.9,145834,2,7510,0)=" ;"
^XMB(3.9,145834,2,7511,0)="""RTN"",""MAGDSTV1"",22,0)"
^XMB(3.9,145834,2,7512,0)="SOPUIDQ ; Called from batch compare/retrieve for a SOP Instance Query"
^XMB(3.9,145834,2,7513,0)="""RTN"",""MAGDSTV1"",23,0)"
^XMB(3.9,145834,2,7514,0)=" ; suppress text output when doing a batch query"
^XMB(3.9,145834,2,7515,0)="""RTN"",""MAGDSTV1"",24,0)"
^XMB(3.9,145834,2,7516,0)=" N BATCHQR"
^XMB(3.9,145834,2,7517,0)="""RTN"",""MAGDSTV1"",25,0)"
^XMB(3.9,145834,2,7518,0)=" S BATCHQR=1"
^XMB(3.9,145834,2,7519,0)="""RTN"",""MAGDSTV1"",26,0)"
^XMB(3.9,145834,2,7520,0)=" K ^XTMP(MAGXTMP,HOSTNAME,$J,""AUTOMATIC"")"
^XMB(3.9,145834,2,7521,0)="""RTN"",""MAGDSTV1"",27,0)"
^XMB(3.9,145834,2,7522,0)=" D ENTRY(""Q"")"
^XMB(3.9,145834,2,7523,0)="""RTN"",""MAGDSTV1"",28,0)"
^XMB(3.9,145834,2,7524,0)=" Q"
^XMB(3.9,145834,2,7525,0)="""RTN"",""MAGDSTV1"",29,0)"
^XMB(3.9,145834,2,7526,0)=" ;"
^XMB(3.9,145834,2,7527,0)="""RTN"",""MAGDSTV1"",30,0)"
^XMB(3.9,145834,2,7528,0)="SOPUIDR ; Called from batch retrieve for a SOP Instance Retrieval"
^XMB(3.9,145834,2,7529,0)="""RTN"",""MAGDSTV1"",31,0)"
^XMB(3.9,145834,2,7530,0)=" ; suppress text output when doing a batch retrieve"
^XMB(3.9,145834,2,7531,0)="""RTN"",""MAGDSTV1"",32,0)"
^XMB(3.9,145834,2,7532,0)=" N BATCHQR"
^XMB(3.9,145834,2,7533,0)="""RTN"",""MAGDSTV1"",33,0)"
^XMB(3.9,145834,2,7534,0)=" S BATCHQR=1"
^XMB(3.9,145834,2,7535,0)="""RTN"",""MAGDSTV1"",34,0)"
^XMB(3.9,145834,2,7536,0)=" K ^XTMP(MAGXTMP,HOSTNAME,$J,""AUTOMATIC"")"
^XMB(3.9,145834,2,7537,0)="""RTN"",""MAGDSTV1"",35,0)"
^XMB(3.9,145834,2,7538,0)=" ;"
^XMB(3.9,145834,2,7539,0)="""RTN"",""MAGDSTV1"",36,0)"
^XMB(3.9,145834,2,7540,0)=" S ^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,""ACCESSION NUMBER"")=ACNUMB"
^XMB(3.9,145834,2,7541,0)="""RTN"",""MAGDSTV1"",37,0)"
^XMB(3.9,145834,2,7542,0)=" ;"
^XMB(3.9,145834,2,7543,0)="""RTN"",""MAGDSTV1"",38,0)"
^XMB(3.9,145834,2,7544,0)=" ; indicate if the retrieve monitor is running - P305 PMK 03/15/2022"
^XMB(3.9,145834,2,7545,0)="""RTN"",""MAGDSTV1"",39,0)"
^XMB(3.9,145834,2,7546,0)=" I $$ENABLED^MAGDSTV1 S ^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,""RETRIEVE MONITOR"")=""YES"""
^XMB(3.9,145834,2,7547,0)="""RTN"",""MAGDSTV1"",40,0)"
^XMB(3.9,145834,2,7548,0)=" E  S ^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,""RETRIEVE MONITOR"")=""NO"""
^XMB(3.9,145834,2,7549,0)="""RTN"",""MAGDSTV1"",41,0)"
^XMB(3.9,145834,2,7550,0)=" ;"
^XMB(3.9,145834,2,7551,0)="""RTN"",""MAGDSTV1"",42,0)"
^XMB(3.9,145834,2,7552,0)=" D ENTRY(""R"") ; don't show retrieve results"
^XMB(3.9,145834,2,7553,0)="""RTN"",""MAGDSTV1"",43,0)"
^XMB(3.9,145834,2,7554,0)=" Q"
^XMB(3.9,145834,2,7555,0)="""RTN"",""MAGDSTV1"",44,0)"
^XMB(3.9,145834,2,7556,0)=" ;"
^XMB(3.9,145834,2,7557,0)="""RTN"",""MAGDSTV1"",45,0)"
^XMB(3.9,145834,2,7558,0)=" ;"
^XMB(3.9,145834,2,7559,0)="""RTN"",""MAGDSTV1"",46,0)"
^XMB(3.9,145834,2,7560,0)="ENTRY(MODE,SHOWRRSL) ; called from ^MAGDSTQ for a VistA Q/R client"
^XMB(3.9,145834,2,7561,0)="""RTN"",""MAGDSTV1"",47,0)"
^XMB(3.9,145834,2,7562,0)=" N CMOVEAET,GATEWAYHOSTNAME,I,IEN2006541,KEY,REQUESTDATETIME,VALUE,X,ZERONODE"
^XMB(3.9,145834,2,7563,0)="""RTN"",""MAGDSTV1"",48,0)"
^XMB(3.9,145834,2,7564,0)=" S MODE=$G(MODE)"
^XMB(3.9,145834,2,7565,0)="""RTN"",""MAGDSTV1"",49,0)"
^XMB(3.9,145834,2,7566,0)=" I MODE'=""Q"",MODE'=""R"" D  Q"
^XMB(3.9,145834,2,7567,0)="""RTN"",""MAGDSTV1"",50,0)"
^XMB(3.9,145834,2,7568,0)=" . W !,""Illegal mode in ENTRY^""_$T(+0),"": "",MODE"
^XMB(3.9,145834,2,7569,0)="""RTN"",""MAGDSTV1"",51,0)"
^XMB(3.9,145834,2,7570,0)=" . D CONTINUE^MAGDSTQ"
^XMB(3.9,145834,2,7571,0)="""RTN"",""MAGDSTV1"",52,0)"
^XMB(3.9,145834,2,7572,0)=" . Q"
^XMB(3.9,145834,2,7573,0)="""RTN"",""MAGDSTV1"",53,0)"
^XMB(3.9,145834,2,7574,0)=" K ^XTMP(MAGXTMP,HOSTNAME,$J,QRSTACK,""MESSAGE"") ; remove any previous query error message"
^XMB(3.9,145834,2,7575,0)="""RTN"",""MAGDSTV1"",54,0)"
^XMB(3.9,145834,2,7576,0)=" S SHOWRRSL=$G(SHOWRRSL) ; 1 = show retrieval results"
^XMB(3.9,145834,2,7577,0)="""RTN"",""MAGDSTV1"",55,0)"
^XMB(3.9,145834,2,7578,0)=" ;"
^XMB(3.9,145834,2,7579,0)="""RTN"",""MAGDSTV1"",56,0)"
^XMB(3.9,145834,2,7580,0)=" ; store the request on the queue"
^XMB(3.9,145834,2,7581,0)="""RTN"",""MAGDSTV1"",57,0)"
^XMB(3.9,145834,2,7582,0)=" L +^MAGDSTT(2006.541):10 ; foreground process"
^XMB(3.9,145834,2,7583,0)="""RTN"",""MAGDSTV1"",58,0)"
^XMB(3.9,145834,2,7584,0)=" S ZERONODE=$G(^MAGDSTT(2006.541,0))"
^XMB(3.9,145834,2,7585,0)="""RTN"",""MAGDSTV1"",59,0)"
^XMB(3.9,145834,2,7586,0)=" S $P(ZERONODE,""^"",1,2)=""DICOM VISTA Q/R REQUEST QUEUE^2006.541"""
^XMB(3.9,145834,2,7587,0)="""RTN"",""MAGDSTV1"",60,0)"
^XMB(3.9,145834,2,7588,0)=" S IEN2006541=$O(^MAGDSTT(2006.541,"" ""),-1)+1 ; Next number"
^XMB(3.9,145834,2,7589,0)="""RTN"",""MAGDSTV1"",61,0)"
^XMB(3.9,145834,2,7590,0)=" S $P(ZERONODE,""^"",3)=IEN2006541"
^XMB(3.9,145834,2,7591,0)="""RTN"",""MAGDSTV1"",62,0)"
^XMB(3.9,145834,2,7592,0)=" S $P(ZERONODE,""^"",4)=$P(ZERONODE,""^"",4)+1 ; Total count"
^XMB(3.9,145834,2,7593,0)="""RTN"",""MAGDSTV1"",63,0)"
^XMB(3.9,145834,2,7594,0)=" S ^MAGDSTT(2006.541,0)=ZERONODE"
^XMB(3.9,145834,2,7595,0)="""RTN"",""MAGDSTV1"",64,0)"
^XMB(3.9,145834,2,7596,0)=" S REQUESTDATETIME=$$NOW^XLFDT"
^XMB(3.9,145834,2,7597,0)="""RTN"",""MAGDSTV1"",65,0)"
^XMB(3.9,145834,2,7598,0)=" S ^MAGDSTT(2006.541,IEN2006541,0)=REQUESTDATETIME_""^""_MODE_""^""_MAGXTMP_""^""_HOSTNAME_""^""_$J_""^""_QRSTACK_""^""_DUZ"
^XMB(3.9,145834,2,7599,0)="""RTN"",""MAGDSTV1"",66,0)"
^XMB(3.9,145834,2,7600,0)=" S KEY="""" F I=1:1 S KEY=$O(^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,KEY)) Q:KEY=""""  D"
^XMB(3.9,145834,2,7601,0)="""RTN"",""MAGDSTV1"",67,0)"
^XMB(3.9,145834,2,7602,0)=" . S VALUE=^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,KEY)"
^XMB(3.9,145834,2,7603,0)="""RTN"",""MAGDSTV1"",68,0)"
^XMB(3.9,145834,2,7604,0)=" . S VALUE=$TR(VALUE,""^"",""~"") ; change ^'s in names to ~'s"
^XMB(3.9,145834,2,7605,0)="""RTN"",""MAGDSTV1"",69,0)"
^XMB(3.9,145834,2,7606,0)=" . S ^MAGDSTT(2006.541,IEN2006541,1,I,0)=KEY_""^""_VALUE"
^XMB(3.9,145834,2,7607,0)="""RTN"",""MAGDSTV1"",70,0)"
^XMB(3.9,145834,2,7608,0)=" . S ^MAGDSTT(2006.541,IEN2006541,1,""B"",KEY,I)="""""
^XMB(3.9,145834,2,7609,0)="""RTN"",""MAGDSTV1"",71,0)"
^XMB(3.9,145834,2,7610,0)=" . Q"
^XMB(3.9,145834,2,7611,0)="""RTN"",""MAGDSTV1"",72,0)"
^XMB(3.9,145834,2,7612,0)=" S ^MAGDSTT(2006.541,""B"",REQUESTDATETIME,IEN2006541)="""" ; create B-xref"
^XMB(3.9,145834,2,7613,0)="""RTN"",""MAGDSTV1"",73,0)"
^XMB(3.9,145834,2,7614,0)=" S I=I-1"
^XMB(3.9,145834,2,7615,0)="""RTN"",""MAGDSTV1"",74,0)"
^XMB(3.9,145834,2,7616,0)=" S ^MAGDSTT(2006.541,IEN2006541,1,0)=""^2006.5411A^""_I_""^""_I"
^XMB(3.9,145834,2,7617,0)="""RTN"",""MAGDSTV1"",75,0)"
^XMB(3.9,145834,2,7618,0)=" S ^MAGDSTT(2006.541,0)=ZERONODE"
^XMB(3.9,145834,2,7619,0)="""RTN"",""MAGDSTV1"",76,0)"
^XMB(3.9,145834,2,7620,0)=" L -^MAGDSTT(2006.541)"
^XMB(3.9,145834,2,7621,0)="""RTN"",""MAGDSTV1"",77,0)"
^XMB(3.9,145834,2,7622,0)=" ;"
^XMB(3.9,145834,2,7623,0)="""RTN"",""MAGDSTV1"",78,0)"
^XMB(3.9,145834,2,7624,0)=" I MODE=""Q"" D"
^XMB(3.9,145834,2,7625,0)="""RTN"",""MAGDSTV1"",79,0)"
^XMB(3.9,145834,2,7626,0)=" . I '$G(BATCHQR) W !,""Performing query on DICOM Gateway"""
^XMB(3.9,145834,2,7627,0)="""RTN"",""MAGDSTV1"",80,0)"
^XMB(3.9,145834,2,7628,0)=" . ; ""DONE"" uses the request IEN for proper synchronization"
^XMB(3.9,145834,2,7629,0)="""RTN"",""MAGDSTV1"",81,0)"
^XMB(3.9,145834,2,7630,0)=" . I '$$WAIT(.CMOVEAET) Q"
^XMB(3.9,145834,2,7631,0)="""RTN"",""MAGDSTV1"",82,0)"
^XMB(3.9,145834,2,7632,0)=" . I '$G(BATCHQR) D DISPLAY^MAGDSTQ5"
^XMB(3.9,145834,2,7633,0)="""RTN"",""MAGDSTV1"",83,0)"
^XMB(3.9,145834,2,7634,0)=" . Q"
^XMB(3.9,145834,2,7635,0)="""RTN"",""MAGDSTV1"",84,0)"
^XMB(3.9,145834,2,7636,0)=" E  I MODE=""R"" D"
^XMB(3.9,145834,2,7637,0)="""RTN"",""MAGDSTV1"",85,0)"
^XMB(3.9,145834,2,7638,0)=" . I '$$WAIT(.CMOVEAET) Q"
^XMB(3.9,145834,2,7639,0)="""RTN"",""MAGDSTV1"",86,0)"
^XMB(3.9,145834,2,7640,0)=" . ; save Move Application Entity Title"
^XMB(3.9,145834,2,7641,0)="""RTN"",""MAGDSTV1"",87,0)"
^XMB(3.9,145834,2,7642,0)=" . I $D(RUNNUMBER) S $P(^MAGDSTT(2006.543,RUNNUMBER,0),""^"",8)=CMOVEAET"
^XMB(3.9,145834,2,7643,0)="""RTN"",""MAGDSTV1"",88,0)"
^XMB(3.9,145834,2,7644,0)=" . I $G(BATCHQR) Q  ; suppress text output"
^XMB(3.9,145834,2,7645,0)="""RTN"",""MAGDSTV1"",89,0)"
^XMB(3.9,145834,2,7646,0)=" . I 'SHOWRRSL D"
^XMB(3.9,145834,2,7647,0)="""RTN"",""MAGDSTV1"",90,0)"
^XMB(3.9,145834,2,7648,0)=" . . F  Q:$X=0  W @IOBS,"" "",@IOBS ; erase the line"
^XMB(3.9,145834,2,7649,0)="""RTN"",""MAGDSTV1"",91,0)"
^XMB(3.9,145834,2,7650,0)=" . . W ""Performing retrieve from """""",QRSCP,"""""" from DICOM Gateway"""
^XMB(3.9,145834,2,7651,0)="""RTN"",""MAGDSTV1"",92,0)"
^XMB(3.9,145834,2,7652,0)=" . . W "" ("",GATEWAYHOSTNAME,"")"""
^XMB(3.9,145834,2,7653,0)="""RTN"",""MAGDSTV1"",93,0)"
^XMB(3.9,145834,2,7654,0)=" . . R X:3"
^XMB(3.9,145834,2,7655,0)="""RTN"",""MAGDSTV1"",94,0)"
^XMB(3.9,145834,2,7656,0)=" . Q"
^XMB(3.9,145834,2,7657,0)="""RTN"",""MAGDSTV1"",95,0)"
^XMB(3.9,145834,2,7658,0)=" Q"
^XMB(3.9,145834,2,7659,0)="""RTN"",""MAGDSTV1"",96,0)"
^XMB(3.9,145834,2,7660,0)=" ;"
^XMB(3.9,145834,2,7661,0)="""RTN"",""MAGDSTV1"",97,0)"
^XMB(3.9,145834,2,7662,0)="WAIT(CMOVEAET) ; wait up to ten minutes for response from DICOM Gateway"
^XMB(3.9,145834,2,7663,0)="""RTN"",""MAGDSTV1"",98,0)"
^XMB(3.9,145834,2,7664,0)=" N I,J,SUCCESS,TIMESTAMP,X"
^XMB(3.9,145834,2,7665,0)="""RTN"",""MAGDSTV1"",99,0)"
^XMB(3.9,145834,2,7666,0)=" S CMOVEAET="""",SUCCESS=0"
^XMB(3.9,145834,2,7667,0)="""RTN"",""MAGDSTV1"",100,0)"
^XMB(3.9,145834,2,7668,0)=" S TIMESTAMP=$$NOW^XLFDT ; time at the beginning of the wait"
^XMB(3.9,145834,2,7669,0)="""RTN"",""MAGDSTV1"",101,0)"
^XMB(3.9,145834,2,7670,0)=" ;"
^XMB(3.9,145834,2,7671,0)="""RTN"",""MAGDSTV1"",102,0)"
^XMB(3.9,145834,2,7672,0)=" ; check that the gateway surrogated picked up the Q/R request"
^XMB(3.9,145834,2,7673,0)="""RTN"",""MAGDSTV1"",103,0)"
^XMB(3.9,145834,2,7674,0)=" F I=1:1:10 D  Q:SUCCESS "
^XMB(3.9,145834,2,7675,0)="""RTN"",""MAGDSTV1"",104,0)"
^XMB(3.9,145834,2,7676,0)=" . S X=$G(^XTMP(MAGXTMP,HOSTNAME,$J,QRSTACK,""WORKING..."",IEN2006541))"
^XMB(3.9,145834,2,7677,0)="""RTN"",""MAGDSTV1"",105,0)"
^XMB(3.9,145834,2,7678,0)=" . I $L(X) D  Q"
^XMB(3.9,145834,2,7679,0)="""RTN"",""MAGDSTV1"",106,0)"
^XMB(3.9,145834,2,7680,0)=" . . S GATEWAYHOSTNAME=$P(X,""^"",3)"
^XMB(3.9,145834,2,7681,0)="""RTN"",""MAGDSTV1"",107,0)"
^XMB(3.9,145834,2,7682,0)=" . . S SUCCESS=1"
^XMB(3.9,145834,2,7683,0)="""RTN"",""MAGDSTV1"",108,0)"
^XMB(3.9,145834,2,7684,0)=" . . Q"
^XMB(3.9,145834,2,7685,0)="""RTN"",""MAGDSTV1"",109,0)"
^XMB(3.9,145834,2,7686,0)=" . H 1"
^XMB(3.9,145834,2,7687,0)="""RTN"",""MAGDSTV1"",110,0)"
^XMB(3.9,145834,2,7688,0)=" . Q"
^XMB(3.9,145834,2,7689,0)="""RTN"",""MAGDSTV1"",111,0)"
^XMB(3.9,145834,2,7690,0)=" I 'SUCCESS D  Q SUCCESS"
^XMB(3.9,145834,2,7691,0)="""RTN"",""MAGDSTV1"",112,0)"
^XMB(3.9,145834,2,7692,0)=" . W !"
^XMB(3.9,145834,2,7693,0)="""RTN"",""MAGDSTV1"",113,0)"
^XMB(3.9,145834,2,7694,0)=" . W ! F J=1:1:80 W ""*"""
^XMB(3.9,145834,2,7695,0)="""RTN"",""MAGDSTV1"",114,0)"
^XMB(3.9,145834,2,7696,0)=" . W !,""***  No DICOM Gateway Surrogate process is available for VistA Q/R Client"""
^XMB(3.9,145834,2,7697,0)="""RTN"",""MAGDSTV1"",115,0)"
^XMB(3.9,145834,2,7698,0)=" . W ?77,""***"""
^XMB(3.9,145834,2,7699,0)="""RTN"",""MAGDSTV1"",116,0)"
^XMB(3.9,145834,2,7700,0)=" . W ! F J=1:1:80 W ""*"""
^XMB(3.9,145834,2,7701,0)="""RTN"",""MAGDSTV1"",117,0)"
