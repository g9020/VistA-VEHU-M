^XMB(3.9,144657,2,5090,0)=" . S IBIEN=+$P(IBDATA,U,4)     ; Ins Co IEN (#36)"
^XMB(3.9,144657,2,5091,0)="""RTN"",""IBCNEQU"",192,0)"
^XMB(3.9,144657,2,5092,0)=" . S IBSYM=$P($$INSERROR^IBCNEUT3(""I"",IBIEN),""^"",1)"
