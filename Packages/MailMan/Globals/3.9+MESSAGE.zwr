^XMB(3.9,145834,2,2967,0)="""RTN"",""MAGDSTA1"",160,0)"
^XMB(3.9,145834,2,2968,0)=" . S QUESTION(""DESCENDING"")=QUESTION"
^XMB(3.9,145834,2,2969,0)="""RTN"",""MAGDSTA1"",161,0)"
^XMB(3.9,145834,2,2970,0)=" . Q"
^XMB(3.9,145834,2,2971,0)="""RTN"",""MAGDSTA1"",162,0)"
^XMB(3.9,145834,2,2972,0)=" E  I SCANMODE=""DATE"" D"
^XMB(3.9,145834,2,2973,0)="""RTN"",""MAGDSTA1"",163,0)"
^XMB(3.9,145834,2,2974,0)=" . S QUESTION=""SORTORDR^MAGDSTA2"""
^XMB(3.9,145834,2,2975,0)="""RTN"",""MAGDSTA1"",164,0)"
^XMB(3.9,145834,2,2976,0)=" . S QUESTION(""ASCENDING"")=QUESTION_"" BEGDATE^MAGDSTA2 ENDDATE^MAGDSTA2 HOURS^MAGDSTA2 VERIFY^MAGDSTA9"""
^XMB(3.9,145834,2,2977,0)="""RTN"",""MAGDSTA1"",165,0)"
^XMB(3.9,145834,2,2978,0)=" . S QUESTION(""DESCENDING"")=QUESTION_"" ENDDATE^MAGDSTA2 BEGDATE^MAGDSTA2 HOURS^MAGDSTA2 VERIFY^MAGDSTA9"""
^XMB(3.9,145834,2,2979,0)="""RTN"",""MAGDSTA1"",166,0)"
^XMB(3.9,145834,2,2980,0)=" . Q"
^XMB(3.9,145834,2,2981,0)="""RTN"",""MAGDSTA1"",167,0)"
^XMB(3.9,145834,2,2982,0)=" E  I SCANMODE=""PATIENT"" D"
^XMB(3.9,145834,2,2983,0)="""RTN"",""MAGDSTA1"",168,0)"
^XMB(3.9,145834,2,2984,0)=" . S QUESTION=""PATIENTA^MAGDSTQA SORTORDR^MAGDSTA2"""
^XMB(3.9,145834,2,2985,0)="""RTN"",""MAGDSTA1"",169,0)"
^XMB(3.9,145834,2,2986,0)=" . S QUESTION(""ASCENDING"")=QUESTION_"" BEGDATE^MAGDSTA2 ENDDATE^MAGDSTA2 HOURS^MAGDSTA2 VERIFY^MAGDSTA9"""
^XMB(3.9,145834,2,2987,0)="""RTN"",""MAGDSTA1"",170,0)"
^XMB(3.9,145834,2,2988,0)=" . S QUESTION(""DESCENDING"")=QUESTION_"" ENDDATE^MAGDSTA2 BEGDATE^MAGDSTA2 HOURS^MAGDSTA2 VERIFY^MAGDSTA9"""
^XMB(3.9,145834,2,2989,0)="""RTN"",""MAGDSTA1"",171,0)"
^XMB(3.9,145834,2,2990,0)=" . Q"
^XMB(3.9,145834,2,2991,0)="""RTN"",""MAGDSTA1"",172,0)"
^XMB(3.9,145834,2,2992,0)=" ; "
^XMB(3.9,145834,2,2993,0)="""RTN"",""MAGDSTA1"",173,0)"
^XMB(3.9,145834,2,2994,0)=" S QUESTION(""NONE"")=QUESTION(""ASCENDING"") ; initial default is ASCENDING"
^XMB(3.9,145834,2,2995,0)="""RTN"",""MAGDSTA1"",174,0)"
^XMB(3.9,145834,2,2996,0)=" ;"
^XMB(3.9,145834,2,2997,0)="""RTN"",""MAGDSTA1"",175,0)"
^XMB(3.9,145834,2,2998,0)=" S SORTORDER=""NONE"" ; value will change when SORTORDER^MAGDSTA2 is invoked"
^XMB(3.9,145834,2,2999,0)="""RTN"",""MAGDSTA1"",176,0)"
^XMB(3.9,145834,2,3000,0)=" F I=1:1:$L(QUESTION(SORTORDER),"" "") D  I I<0 S QUIT=-1 Q"
^XMB(3.9,145834,2,3001,0)="""RTN"",""MAGDSTA1"",177,0)"
^XMB(3.9,145834,2,3002,0)=" . S QUIT=0"
^XMB(3.9,145834,2,3003,0)="""RTN"",""MAGDSTA1"",178,0)"
^XMB(3.9,145834,2,3004,0)=" . D @$P(QUESTION(SORTORDER),"" "",I)"
^XMB(3.9,145834,2,3005,0)="""RTN"",""MAGDSTA1"",179,0)"
^XMB(3.9,145834,2,3006,0)=" . I QUIT>0 S I=I-2"
^XMB(3.9,145834,2,3007,0)="""RTN"",""MAGDSTA1"",180,0)"
^XMB(3.9,145834,2,3008,0)=" . E  I QUIT<0 S I=-1"
^XMB(3.9,145834,2,3009,0)="""RTN"",""MAGDSTA1"",181,0)"
^XMB(3.9,145834,2,3010,0)=" . Q"
^XMB(3.9,145834,2,3011,0)="""RTN"",""MAGDSTA1"",182,0)"
^XMB(3.9,145834,2,3012,0)=" I QUIT<0 Q"
^XMB(3.9,145834,2,3013,0)="""RTN"",""MAGDSTA1"",183,0)"
^XMB(3.9,145834,2,3014,0)=" ;"
^XMB(3.9,145834,2,3015,0)="""RTN"",""MAGDSTA1"",184,0)"
^XMB(3.9,145834,2,3016,0)=" D TASKINIT"
^XMB(3.9,145834,2,3017,0)="""RTN"",""MAGDSTA1"",185,0)"
^XMB(3.9,145834,2,3018,0)=" ;"
^XMB(3.9,145834,2,3019,0)="""RTN"",""MAGDSTA1"",186,0)"
^XMB(3.9,145834,2,3020,0)=" ; Setup for tasking the compare image counts/retrieve job"
^XMB(3.9,145834,2,3021,0)="""RTN"",""MAGDSTA1"",187,0)"
^XMB(3.9,145834,2,3022,0)=" ;"
^XMB(3.9,145834,2,3023,0)="""RTN"",""MAGDSTA1"",188,0)"
^XMB(3.9,145834,2,3024,0)=" ; ZTDESC is set above"
^XMB(3.9,145834,2,3025,0)="""RTN"",""MAGDSTA1"",189,0)"
^XMB(3.9,145834,2,3026,0)=" ;"
^XMB(3.9,145834,2,3027,0)="""RTN"",""MAGDSTA1"",190,0)"
^XMB(3.9,145834,2,3028,0)=" N %ZIS,ZTSAVE"
^XMB(3.9,145834,2,3029,0)="""RTN"",""MAGDSTA1"",191,0)"
^XMB(3.9,145834,2,3030,0)=" S ZTSAVE(""HOSTNAME"")="""""
^XMB(3.9,145834,2,3031,0)="""RTN"",""MAGDSTA1"",192,0)"
^XMB(3.9,145834,2,3032,0)=" S ZTSAVE(""MAGIOM"")="""""
^XMB(3.9,145834,2,3033,0)="""RTN"",""MAGDSTA1"",193,0)"
^XMB(3.9,145834,2,3034,0)=" S ZTSAVE(""MAGXTMP"")="""""
^XMB(3.9,145834,2,3035,0)="""RTN"",""MAGDSTA1"",194,0)"
^XMB(3.9,145834,2,3036,0)=" S ZTSAVE(""MENUOPTION"")="""""
^XMB(3.9,145834,2,3037,0)="""RTN"",""MAGDSTA1"",195,0)"
^XMB(3.9,145834,2,3038,0)=" S ZTSAVE(""^TMP(""""MAG"""",$J,""""BATCH Q/R"""","")="""""
^XMB(3.9,145834,2,3039,0)="""RTN"",""MAGDSTA1"",196,0)"
^XMB(3.9,145834,2,3040,0)=" S ZTSAVE(""^TMP(""""MAG"""",$J,""""Q/R PARAM"""","")="""""
^XMB(3.9,145834,2,3041,0)="""RTN"",""MAGDSTA1"",197,0)"
^XMB(3.9,145834,2,3042,0)=" S ZTSAVE(""QRSTACK"")="""""
^XMB(3.9,145834,2,3043,0)="""RTN"",""MAGDSTA1"",198,0)"
^XMB(3.9,145834,2,3044,0)=" S ZTSAVE(""CONSULTSERVICES("")="""""
^XMB(3.9,145834,2,3045,0)="""RTN"",""MAGDSTA1"",199,0)"
^XMB(3.9,145834,2,3046,0)=" D EN^XUTMDEVQ(""TASK^""_$T(+0),ZTDESC,.ZTSAVE,.%ZIS)"
^XMB(3.9,145834,2,3047,0)="""RTN"",""MAGDSTA1"",200,0)"
^XMB(3.9,145834,2,3048,0)=" Q"
^XMB(3.9,145834,2,3049,0)="""RTN"",""MAGDSTA1"",201,0)"
^XMB(3.9,145834,2,3050,0)=" ;"
^XMB(3.9,145834,2,3051,0)="""RTN"",""MAGDSTA1"",202,0)"
^XMB(3.9,145834,2,3052,0)="TASKINIT ; initialize MAGIOM and ZTDESC"
^XMB(3.9,145834,2,3053,0)="""RTN"",""MAGDSTA1"",203,0)"
^XMB(3.9,145834,2,3054,0)=" I ^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION"")=""RETRIEVE MISSING IMAGES"" D"
^XMB(3.9,145834,2,3055,0)="""RTN"",""MAGDSTA1"",204,0)"
^XMB(3.9,145834,2,3056,0)=" . W !!,""Recommend report output of 132 columns"",!!"
^XMB(3.9,145834,2,3057,0)="""RTN"",""MAGDSTA1"",205,0)"
^XMB(3.9,145834,2,3058,0)=" . S MAGIOM=132 ; retrieve requires 132 columns"
^XMB(3.9,145834,2,3059,0)="""RTN"",""MAGDSTA1"",206,0)"
^XMB(3.9,145834,2,3060,0)=" . S ZTDESC=""Retrieve Missing Images"" ; for tasking"
^XMB(3.9,145834,2,3061,0)="""RTN"",""MAGDSTA1"",207,0)"
^XMB(3.9,145834,2,3062,0)=" . Q"
^XMB(3.9,145834,2,3063,0)="""RTN"",""MAGDSTA1"",208,0)"
^XMB(3.9,145834,2,3064,0)=" E  D  ; compare image counts"
^XMB(3.9,145834,2,3065,0)="""RTN"",""MAGDSTA1"",209,0)"
^XMB(3.9,145834,2,3066,0)=" . S MAGIOM=80 ; comparing image counts requires only 80 columns"
^XMB(3.9,145834,2,3067,0)="""RTN"",""MAGDSTA1"",210,0)"
^XMB(3.9,145834,2,3068,0)=" . S ZTDESC=""Compare Image Counts"" ; for tasking"
^XMB(3.9,145834,2,3069,0)="""RTN"",""MAGDSTA1"",211,0)"
^XMB(3.9,145834,2,3070,0)=" . Q"
^XMB(3.9,145834,2,3071,0)="""RTN"",""MAGDSTA1"",212,0)"
^XMB(3.9,145834,2,3072,0)=" S ZTDESC=ZTDESC_"" for ""_IMAGINGSERVICE"
^XMB(3.9,145834,2,3073,0)="""RTN"",""MAGDSTA1"",213,0)"
^XMB(3.9,145834,2,3074,0)=" Q"
^XMB(3.9,145834,2,3075,0)="""RTN"",""MAGDSTA1"",214,0)"
^XMB(3.9,145834,2,3076,0)=" ;"
^XMB(3.9,145834,2,3077,0)="""RTN"",""MAGDSTA1"",215,0)"
^XMB(3.9,145834,2,3078,0)="TASK ; entry point for a tasked job"
^XMB(3.9,145834,2,3079,0)="""RTN"",""MAGDSTA1"",216,0)"
^XMB(3.9,145834,2,3080,0)=" N $ETRAP,$ESTACK S $ETRAP=""D ERROR^MAGDSTA"""
^XMB(3.9,145834,2,3081,0)="""RTN"",""MAGDSTA1"",217,0)"
^XMB(3.9,145834,2,3082,0)=" N I"
^XMB(3.9,145834,2,3083,0)="""RTN"",""MAGDSTA1"",218,0)"
^XMB(3.9,145834,2,3084,0)=" F I=1:1:$L(ZTDESC) W $E(ZTDESC,I),"" """
^XMB(3.9,145834,2,3085,0)="""RTN"",""MAGDSTA1"",219,0)"
^XMB(3.9,145834,2,3086,0)=" W !,""-"" F I=2:1:$L(ZTDESC) W ""--"""
^XMB(3.9,145834,2,3087,0)="""RTN"",""MAGDSTA1"",220,0)"
^XMB(3.9,145834,2,3088,0)=" W !,""Started on "",$$FMTE^XLFDT($$NOW^XLFDT,1)"
^XMB(3.9,145834,2,3089,0)="""RTN"",""MAGDSTA1"",221,0)"
^XMB(3.9,145834,2,3090,0)=" W "" by "",$$GET1^DIQ(200,DUZ,.01,""E""),"" (DUZ: "",DUZ,"")"""
^XMB(3.9,145834,2,3091,0)="""RTN"",""MAGDSTA1"",222,0)"
^XMB(3.9,145834,2,3092,0)=" W ""  Job Number: "",$J"
^XMB(3.9,145834,2,3093,0)="""RTN"",""MAGDSTA1"",223,0)"
^XMB(3.9,145834,2,3094,0)=" D DISPLAY^MAGDSTA9"
^XMB(3.9,145834,2,3095,0)="""RTN"",""MAGDSTA1"",224,0)"
^XMB(3.9,145834,2,3096,0)=" W !!"
^XMB(3.9,145834,2,3097,0)="""RTN"",""MAGDSTA1"",225,0)"
^XMB(3.9,145834,2,3098,0)=" ;"
^XMB(3.9,145834,2,3099,0)="""RTN"",""MAGDSTA1"",226,0)"
^XMB(3.9,145834,2,3100,0)="BEGIN ; entry point for running the image compare or retrieve process"
^XMB(3.9,145834,2,3101,0)="""RTN"",""MAGDSTA1"",227,0)"
^XMB(3.9,145834,2,3102,0)=" N ACNUMB,BATCHSIZE,BEGDATE,DFN,ENDDATE,HOURS,IMAGINGSERVICE,OPTION,QRSCP,RUNTIME"
^XMB(3.9,145834,2,3103,0)="""RTN"",""MAGDSTA1"",228,0)"
^XMB(3.9,145834,2,3104,0)=" N SCANMODE,SORTORDER,STARTIEN,STARTTIME,STATUS,STUDYDATE,STUDYIEN"
^XMB(3.9,145834,2,3105,0)="""RTN"",""MAGDSTA1"",229,0)"
^XMB(3.9,145834,2,3106,0)=" N DIRECTION,I,J,K,L,RUNNUMBER,STOP"
^XMB(3.9,145834,2,3107,0)="""RTN"",""MAGDSTA1"",230,0)"
^XMB(3.9,145834,2,3108,0)=" ;"
^XMB(3.9,145834,2,3109,0)="""RTN"",""MAGDSTA1"",231,0)"
^XMB(3.9,145834,2,3110,0)=" S X=MAGIOM X ^%ZOSF(""RM"") ; set right margin to 80 or 132"
^XMB(3.9,145834,2,3111,0)="""RTN"",""MAGDSTA1"",232,0)"
^XMB(3.9,145834,2,3112,0)=" ;"
^XMB(3.9,145834,2,3113,0)="""RTN"",""MAGDSTA1"",233,0)"
^XMB(3.9,145834,2,3114,0)=" S OPTION=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION""))"
^XMB(3.9,145834,2,3115,0)="""RTN"",""MAGDSTA1"",234,0)"
^XMB(3.9,145834,2,3116,0)=" S IMAGINGSERVICE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""IMAGING SERVICE""))"
^XMB(3.9,145834,2,3117,0)="""RTN"",""MAGDSTA1"",235,0)"
^XMB(3.9,145834,2,3118,0)=" S SCANMODE=$G(^TMP(""MAG"",$J,""Q/R PARAM"",""SCAN MODE""))"
^XMB(3.9,145834,2,3119,0)="""RTN"",""MAGDSTA1"",236,0)"
^XMB(3.9,145834,2,3120,0)=" S SORTORDER=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""SORT ORDER""))"
^XMB(3.9,145834,2,3121,0)="""RTN"",""MAGDSTA1"",237,0)"
^XMB(3.9,145834,2,3122,0)=" S BATCHSIZE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""BATCH SIZE""))"
^XMB(3.9,145834,2,3123,0)="""RTN"",""MAGDSTA1"",238,0)"
^XMB(3.9,145834,2,3124,0)=" S STARTIEN=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""REPORT/STUDY IEN""))"
^XMB(3.9,145834,2,3125,0)="""RTN"",""MAGDSTA1"",239,0)"
^XMB(3.9,145834,2,3126,0)=" S BEGDATE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""BEGIN DATE""))"
^XMB(3.9,145834,2,3127,0)="""RTN"",""MAGDSTA1"",240,0)"
