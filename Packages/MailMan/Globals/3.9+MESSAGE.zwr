^XMB(3.9,144657,2,7785,0)="""RTN"",""IBCNICB"",122,0)"
^XMB(3.9,144657,2,7786,0)=" N IBSUPRES"
^XMB(3.9,144657,2,7787,0)="""RTN"",""IBCNICB"",123,0)"
^XMB(3.9,144657,2,7788,0)=" ;Set IBSUPRES to suppress screen I/O within REJECT"
