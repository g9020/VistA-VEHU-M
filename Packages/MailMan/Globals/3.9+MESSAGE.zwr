^XMB(3.9,145831,2,1002,0)="READ(CTXT) ; -- return current vitals in XML"
^XMB(3.9,145831,2,1003,0)="""RTN"",""EDPVIT"",69,0)"
^XMB(3.9,145831,2,1004,0)=" D XML^EDPX(""<vitals>"")"
^XMB(3.9,145831,2,1005,0)="""RTN"",""EDPVIT"",70,0)"
