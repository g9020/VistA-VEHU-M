^XMB(3.9,145837,2,517,0)="""RTN"",""XQALSET"",139,0)"
^XMB(3.9,145837,2,518,0)=" . S @FDA@(8992.1,""+1,"",.01)=XQAID D UPDATE^DIE("""",FDA,""IENS"")"
