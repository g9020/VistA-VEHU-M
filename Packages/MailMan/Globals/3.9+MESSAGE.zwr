^XMB(3.9,145839,2,247,0)="""RTN"",""TIUCCHL7UT"")"
^XMB(3.9,145839,2,248,0)="0^5^B56388743"
^XMB(3.9,145839,2,249,0)="""RTN"",""TIUCCHL7UT"",1,0)"
^XMB(3.9,145839,2,250,0)="TIUCCHL7UT ; CCRA/PB - TIUCCRA HSRM Msg Processing; November 3, 2020"
^XMB(3.9,145839,2,251,0)="""RTN"",""TIUCCHL7UT"",2,0)"
^XMB(3.9,145839,2,252,0)=" ;;1.0;TEXT INTEGRATION UTILITIES;**337,344,356**;Sep 27, 2023;Build 0"
^XMB(3.9,145839,2,253,0)="""RTN"",""TIUCCHL7UT"",3,0)"
^XMB(3.9,145839,2,254,0)=" ;"
^XMB(3.9,145839,2,255,0)="""RTN"",""TIUCCHL7UT"",4,0)"
^XMB(3.9,145839,2,256,0)=" ;PB - Patch 344 to modify how the note and addendum text is formatted"
^XMB(3.9,145839,2,257,0)="""RTN"",""TIUCCHL7UT"",5,0)"
^XMB(3.9,145839,2,258,0)=" ;PB - Patch 356 modifications to file the note as a stand-alone note and not linked to a consult"
^XMB(3.9,145839,2,259,0)="""RTN"",""TIUCCHL7UT"",6,0)"
^XMB(3.9,145839,2,260,0)=" Q"
^XMB(3.9,145839,2,261,0)="""RTN"",""TIUCCHL7UT"",7,0)"
^XMB(3.9,145839,2,262,0)=" ;"
^XMB(3.9,145839,2,263,0)="""RTN"",""TIUCCHL7UT"",8,0)"
^XMB(3.9,145839,2,264,0)="TIUC(X) ; Check each segment of the CCRA TIU notes for HL7 control characters"
^XMB(3.9,145839,2,265,0)="""RTN"",""TIUCCHL7UT"",9,0)"
^XMB(3.9,145839,2,266,0)=" Q:$G(X)="""""
^XMB(3.9,145839,2,267,0)="""RTN"",""TIUCCHL7UT"",10,0)"
^XMB(3.9,145839,2,268,0)=" I $G(X)[$C(13,10,10) S X=$TR(X,$C(13,10,10),"""") ; <cr><lf><lf>"
^XMB(3.9,145839,2,269,0)="""RTN"",""TIUCCHL7UT"",11,0)"
^XMB(3.9,145839,2,270,0)=" I $G(X)[$C(13,10) S X=$TR(X,$C(13,10),"""") ; <cr><lf>"
^XMB(3.9,145839,2,271,0)="""RTN"",""TIUCCHL7UT"",12,0)"
^XMB(3.9,145839,2,272,0)=" I $G(X)[$C(13) S X=$TR(X,$C(13),"""") ; TERM char"
^XMB(3.9,145839,2,273,0)="""RTN"",""TIUCCHL7UT"",13,0)"
^XMB(3.9,145839,2,274,0)=" I $G(X)[$C(1) S X=$TR(X,$C(1),"""") ; SOH"
^XMB(3.9,145839,2,275,0)="""RTN"",""TIUCCHL7UT"",14,0)"
