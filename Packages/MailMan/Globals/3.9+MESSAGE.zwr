^XMB(3.9,145836,2,922,0)="TOOL2 N DAYSEP,DRUGHDR1,DRUGHDR2,DRUGSEP,INSTSEP1,INSTSEP2"
^XMB(3.9,145836,2,923,0)="""RTN"",""GMTSPST2"",11,0)"
^XMB(3.9,145836,2,924,0)=" N EMPTYLN,PRETYPE,SUPTYPE,PSOQPEND"
^XMB(3.9,145836,2,925,0)="""RTN"",""GMTSPST2"",12,0)"
^XMB(3.9,145836,2,926,0)=" N BLNKLN,IDRUG,ISIG,ITYPE,PDRUG"
^XMB(3.9,145836,2,927,0)="""RTN"",""GMTSPST2"",13,0)"
^XMB(3.9,145836,2,928,0)=" N NVA,PAGE,PGWIDTH,PGLENGTH,GMTS59"
^XMB(3.9,145836,2,929,0)="""RTN"",""GMTSPST2"",14,0)"
^XMB(3.9,145836,2,930,0)=" N RXIEN,SIGCNT,SIGPOS,XPOS1,XPOS2,XPOS4"
^XMB(3.9,145836,2,931,0)="""RTN"",""GMTSPST2"",15,0)"
