^XMB(3.9,145836,2,1356,0)=" F PSOQSCT=2:1:$O(GMTSPST2("" ""),-1) K GMTSPST2(PSOQSCT)"
^XMB(3.9,145836,2,1357,0)="""RTN"",""GMTSPST2"",228,0)"
^XMB(3.9,145836,2,1358,0)=" S J=0"
^XMB(3.9,145836,2,1359,0)="""RTN"",""GMTSPST2"",229,0)"
^XMB(3.9,145836,2,1360,0)=" F GMTSPST2=2:1 S J=$O(^TMP(""ORWORD"",$J,PTR,J)) Q:'J  S K=0 F  S K=$O(^TMP(""ORWORD"",$J,PTR,J,K)) Q:'K  I $D(^TMP(""ORWORD"",$J,PTR,J,K,0)) S GMTSPST2(GMTSPST2)=^(0)"
^XMB(3.9,145836,2,1361,0)="""RTN"",""GMTSPST2"",230,0)"
^XMB(3.9,145836,2,1362,0)=" S PTR=$P($G(ORDIALOG(""B"",""COMMENTS"")),""^"",2) Q:PTR="""""
^XMB(3.9,145836,2,1363,0)="""RTN"",""GMTSPST2"",231,0)"
^XMB(3.9,145836,2,1364,0)=" S J=0,GMTSPST2=GMTSPST2-1"
^XMB(3.9,145836,2,1365,0)="""RTN"",""GMTSPST2"",232,0)"
^XMB(3.9,145836,2,1366,0)=" F  S J=$O(^TMP(""ORWORD"",$J,PTR,J)) Q:'J  S K=0 F  S K=$O(^TMP(""ORWORD"",$J,PTR,J,K)) Q:'K  I $D(^TMP(""ORWORD"",$J,PTR,J,K,0)) S X=^(0) D ADD"
^XMB(3.9,145836,2,1367,0)="""RTN"",""GMTSPST2"",233,0)"
^XMB(3.9,145836,2,1368,0)=" Q"
^XMB(3.9,145836,2,1369,0)="""RTN"",""GMTSPST2"",234,0)"
^XMB(3.9,145836,2,1370,0)="ADD ; -- Add text X to GMTSPST2()"
^XMB(3.9,145836,2,1371,0)="""RTN"",""GMTSPST2"",235,0)"
^XMB(3.9,145836,2,1372,0)=" N I,Y,Z S Y=$L(GMTSPST2(GMTSPST2)) S:Y Y=Y+1 ;allow for space"
^XMB(3.9,145836,2,1373,0)="""RTN"",""GMTSPST2"",236,0)"
^XMB(3.9,145836,2,1374,0)=" I $E(X)="" "",Y S GMTSPST2=GMTSPST2+1,GMTSPST2(GMTSPST2)="""",Y=0,X=$E(X,2,999) ;new line"
^XMB(3.9,145836,2,1375,0)="""RTN"",""GMTSPST2"",237,0)"
^XMB(3.9,145836,2,1376,0)=" I Y+$L(X)'>65 S GMTSPST2(GMTSPST2)=GMTSPST2(GMTSPST2)_$S(Y:"" "",1:"""")_X Q"
^XMB(3.9,145836,2,1377,0)="""RTN"",""GMTSPST2"",238,0)"
^XMB(3.9,145836,2,1378,0)=" F I=1:1:$L(X,"" "") S Z=$P(X,"" "",I) D:(Y+$L(Z))>65  S GMTSPST2(GMTSPST2)=$G(GMTSPST2(GMTSPST2))_$S(Y:"" "",1:"""")_Z,Y=$L(GMTSPST2(GMTSPST2)) S:Y Y=Y+1"
^XMB(3.9,145836,2,1379,0)="""RTN"",""GMTSPST2"",239,0)"
^XMB(3.9,145836,2,1380,0)=" . I $L(Z)>65 F  S GMTSPST2(GMTSPST2)=$G(GMTSPST2(GMTSPST2))_$S(Y:"" "",1:"""")_$E(Z,1,65-Y),Z=$E(Z,65-Y+1,999) Q:$L(Z)'>65  S GMTSPST2=GMTSPST2+1,Y=0"
^XMB(3.9,145836,2,1381,0)="""RTN"",""GMTSPST2"",240,0)"
^XMB(3.9,145836,2,1382,0)=" . S GMTSPST2=GMTSPST2+1,Y=0"
^XMB(3.9,145836,2,1383,0)="""RTN"",""GMTSPST2"",241,0)"
^XMB(3.9,145836,2,1384,0)=" Q"
