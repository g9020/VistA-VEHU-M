^XMB(3.9,144657,2,9835,0)="""RTN"",""IBJPI"",186,0)"
^XMB(3.9,144657,2,9836,0)=" ;IB*771/TAZ - Added blank lines to start section on a new page"
^XMB(3.9,144657,2,9837,0)="""RTN"",""IBJPI"",187,0)"
^XMB(3.9,144657,2,9838,0)=" N IBEX,IBEX1,IBEIVB,IBST,IEN,XX"
^XMB(3.9,144657,2,9839,0)="""RTN"",""IBJPI"",188,0)"
^XMB(3.9,144657,2,9840,0)=" ;IB*806/CKB - changed the number of Blank lines from 6 to 3"
