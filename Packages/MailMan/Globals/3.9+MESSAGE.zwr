^XMB(3.9,145839,2,903,0)="""RTN"",""TIUCCRHL7P1"",178,0)"
^XMB(3.9,145839,2,904,0)=" K T2 S T2(""Patient Admitted (Yes/No): If yes, then please complete the Discharge Planning Addendum."")=$C(10)_""Patient Admitted (Yes/No): If yes, then please complete the Discharge Planning Addendum"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,905,0)="""RTN"",""TIUCCRHL7P1"",179,0)"
^XMB(3.9,145839,2,906,0)=" K T2 S T2(""Chief Complaint: ""_$C(160))=$C(10)_""Chief Complaint:"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,907,0)="""RTN"",""TIUCCRHL7P1"",180,0)"
^XMB(3.9,145839,2,908,0)=" K T2 S T2(""Risks"")=$C(10)_""Risks x"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
