^XMB(3.9,144657,2,5631,0)="""RTN"",""IBCNES"",8,0)"
^XMB(3.9,144657,2,5632,0)=" ; see below at tag INIT for a description of the parameters"
^XMB(3.9,144657,2,5633,0)="""RTN"",""IBCNES"",9,0)"
^XMB(3.9,144657,2,5634,0)=" ; IBVSUB is required at this entry point because the ListMan array uses this variable"
^XMB(3.9,144657,2,5635,0)="""RTN"",""IBCNES"",10,0)"
^XMB(3.9,144657,2,5636,0)=" ;"
^XMB(3.9,144657,2,5637,0)="""RTN"",""IBCNES"",11,0)"
^XMB(3.9,144657,2,5638,0)=" D EN^VALM(""IBCNE ELIGIBILITY/BENEFIT INFO"")"
^XMB(3.9,144657,2,5639,0)="""RTN"",""IBCNES"",12,0)"
^XMB(3.9,144657,2,5640,0)="EBX ;"
^XMB(3.9,144657,2,5641,0)="""RTN"",""IBCNES"",13,0)"
^XMB(3.9,144657,2,5642,0)=" Q"
^XMB(3.9,144657,2,5643,0)="""RTN"",""IBCNES"",14,0)"
^XMB(3.9,144657,2,5644,0)=" ;"
^XMB(3.9,144657,2,5645,0)="""RTN"",""IBCNES"",15,0)"
^XMB(3.9,144657,2,5646,0)="HDR ; -- header code - called by ListManager"
^XMB(3.9,144657,2,5647,0)="""RTN"",""IBCNES"",16,0)"
^XMB(3.9,144657,2,5648,0)=" ; build the header area based on the values of IBVF and IBVIENS"
^XMB(3.9,144657,2,5649,0)="""RTN"",""IBCNES"",17,0)"
^XMB(3.9,144657,2,5650,0)=" ;"
^XMB(3.9,144657,2,5651,0)="""RTN"",""IBCNES"",18,0)"
^XMB(3.9,144657,2,5652,0)=" ; pt. insurance"
^XMB(3.9,144657,2,5653,0)="""RTN"",""IBCNES"",19,0)"
^XMB(3.9,144657,2,5654,0)=" I IBVF=2.322 D"
^XMB(3.9,144657,2,5655,0)="""RTN"",""IBCNES"",20,0)"
^XMB(3.9,144657,2,5656,0)=" . N DFN,IBCDFN,PNB,PN,LPID,INS,INSNM,IENS,RSDATE,RSTYPE"
^XMB(3.9,144657,2,5657,0)="""RTN"",""IBCNES"",21,0)"
^XMB(3.9,144657,2,5658,0)=" . S DFN=+$P(IBVIENS,"","",2)"
^XMB(3.9,144657,2,5659,0)="""RTN"",""IBCNES"",22,0)"
^XMB(3.9,144657,2,5660,0)=" . S IBCDFN=+$P(IBVIENS,"","",1)"
^XMB(3.9,144657,2,5661,0)="""RTN"",""IBCNES"",23,0)"
^XMB(3.9,144657,2,5662,0)=" . S PNB=$$PT^IBEFUNC(DFN)"
^XMB(3.9,144657,2,5663,0)="""RTN"",""IBCNES"",24,0)"
^XMB(3.9,144657,2,5664,0)=" . S PN=$P(PNB,U,1)    ; pt name"
^XMB(3.9,144657,2,5665,0)="""RTN"",""IBCNES"",25,0)"
^XMB(3.9,144657,2,5666,0)=" . S LPID=$P(PNB,U,2)  ; pt id"
^XMB(3.9,144657,2,5667,0)="""RTN"",""IBCNES"",26,0)"
^XMB(3.9,144657,2,5668,0)=" . S INS=+$P($G(^DPT(DFN,.312,IBCDFN,0)),U,1),INSNM="""""
^XMB(3.9,144657,2,5669,0)="""RTN"",""IBCNES"",27,0)"
^XMB(3.9,144657,2,5670,0)=" . I INS S INSNM=$P($G(^DIC(36,INS,0)),U,1)"
^XMB(3.9,144657,2,5671,0)="""RTN"",""IBCNES"",28,0)"
^XMB(3.9,144657,2,5672,0)=" . S IENS=IBCDFN_"",""_DFN_"","""
^XMB(3.9,144657,2,5673,0)="""RTN"",""IBCNES"",29,0)"
^XMB(3.9,144657,2,5674,0)=" . S RSDATE=$$GET1^DIQ(2.312,IENS,8.01,""I""),RSTYPE=$$GET1^DIQ(2.312,IENS,8.02,""I"")"
^XMB(3.9,144657,2,5675,0)="""RTN"",""IBCNES"",30,0)"
^XMB(3.9,144657,2,5676,0)=" . S VALMHDR(1)=$$FO^IBCNEUT1(PN,30)_""  ""_$$FO^IBCNEUT1(LPID,15)_""  ""_$$FO^IBCNEUT1(INSNM,30)"
^XMB(3.9,144657,2,5677,0)="""RTN"",""IBCNES"",31,0)"
^XMB(3.9,144657,2,5678,0)=" . S VALMHDR(2)=""** Based on service date ""_$S(RSDATE:$$FMTE^XLFDT(RSDATE,""5Z""),1:""UNKNOWN"")_"" and service type: ""_$S(RSTYPE:$P($G(^IBE(365.013,RSTYPE,0)),U,2),1:""UNKNOWN"")_"" **"""
^XMB(3.9,144657,2,5679,0)="""RTN"",""IBCNES"",32,0)"
^XMB(3.9,144657,2,5680,0)=" . S RSPIEN=$$GET1^DIQ(2.312,IENS,8.03,""I"")"
^XMB(3.9,144657,2,5681,0)="""RTN"",""IBCNES"",33,0)"
^XMB(3.9,144657,2,5682,0)=" ;"
^XMB(3.9,144657,2,5683,0)="""RTN"",""IBCNES"",34,0)"
^XMB(3.9,144657,2,5684,0)=" ; eIV response file"
^XMB(3.9,144657,2,5685,0)="""RTN"",""IBCNES"",35,0)"
^XMB(3.9,144657,2,5686,0)=" I IBVF=365.02 D"
^XMB(3.9,144657,2,5687,0)="""RTN"",""IBCNES"",36,0)"
^XMB(3.9,144657,2,5688,0)=" . N RSPIEN,IBX,DFN,INS,PNB,PN,LPID,INSNM,TQIEN,NODE0,RSTYPE,RSDATE"
^XMB(3.9,144657,2,5689,0)="""RTN"",""IBCNES"",37,0)"
^XMB(3.9,144657,2,5690,0)=" . S RSPIEN=+IBVIENS"
^XMB(3.9,144657,2,5691,0)="""RTN"",""IBCNES"",38,0)"
^XMB(3.9,144657,2,5692,0)=" . S IBX=$G(^IBCN(365,RSPIEN,0))"
^XMB(3.9,144657,2,5693,0)="""RTN"",""IBCNES"",39,0)"
^XMB(3.9,144657,2,5694,0)=" . ; IB*702/TAZ,CKB - Set the RSTYPE=REQUESTED SERVICE TYPE CODE (365,.15), and"
^XMB(3.9,144657,2,5695,0)="""RTN"",""IBCNES"",40,0)"
^XMB(3.9,144657,2,5696,0)=" . ; RSDATE=REQUESTED SERVICE DATE (365,.14)"
^XMB(3.9,144657,2,5697,0)="""RTN"",""IBCNES"",41,0)"
^XMB(3.9,144657,2,5698,0)=" . ;S TQIEN=$P(IBX,U,5),NODE0=$G(^IBCN(365.1,TQIEN,0)),RSTYPE=$P(NODE0,U,20)"
^XMB(3.9,144657,2,5699,0)="""RTN"",""IBCNES"",42,0)"
^XMB(3.9,144657,2,5700,0)=" . S RSTYPE=$$GET1^DIQ(365,RSPIEN_"","",.15,""I"")"
^XMB(3.9,144657,2,5701,0)="""RTN"",""IBCNES"",43,0)"
^XMB(3.9,144657,2,5702,0)=" . ;S RSDATE=$P($G(^IBCN(365,RSPIEN,1)),U,10) I RSDATE="""" S RSDATE=$P(NODE0,U,12)"
^XMB(3.9,144657,2,5703,0)="""RTN"",""IBCNES"",44,0)"
^XMB(3.9,144657,2,5704,0)=" . S RSDATE=$P($G(^IBCN(365,RSPIEN,1)),U,10) I RSDATE="""" S RSDATE=$$GET1^DIQ(365,RSPIEN_"","",.14,""I"")"
^XMB(3.9,144657,2,5705,0)="""RTN"",""IBCNES"",45,0)"
^XMB(3.9,144657,2,5706,0)=" . S DFN=+$P(IBX,U,2)   ; pt ien"
^XMB(3.9,144657,2,5707,0)="""RTN"",""IBCNES"",46,0)"
^XMB(3.9,144657,2,5708,0)=" . S INS=+$P(IBX,U,3)   ; payer ien"
^XMB(3.9,144657,2,5709,0)="""RTN"",""IBCNES"",47,0)"
^XMB(3.9,144657,2,5710,0)=" . S INSNM="""""
^XMB(3.9,144657,2,5711,0)="""RTN"",""IBCNES"",48,0)"
^XMB(3.9,144657,2,5712,0)=" . S PNB=$$PT^IBEFUNC(DFN)"
^XMB(3.9,144657,2,5713,0)="""RTN"",""IBCNES"",49,0)"
^XMB(3.9,144657,2,5714,0)=" . S PN=$P(PNB,U,1)     ; pt name"
^XMB(3.9,144657,2,5715,0)="""RTN"",""IBCNES"",50,0)"
^XMB(3.9,144657,2,5716,0)=" . S LPID=$P(PNB,U,2)   ; pt id"
^XMB(3.9,144657,2,5717,0)="""RTN"",""IBCNES"",51,0)"
^XMB(3.9,144657,2,5718,0)=" . I INS S INSNM=$P($G(^IBE(365.12,INS,0)),U,1)   ; payer name"
^XMB(3.9,144657,2,5719,0)="""RTN"",""IBCNES"",52,0)"
^XMB(3.9,144657,2,5720,0)=" . S VALMHDR(1)=$$FO^IBCNEUT1(PN,30)_""  ""_$$FO^IBCNEUT1(LPID,15)_""  ""_$$FO^IBCNEUT1(INSNM,30)"
^XMB(3.9,144657,2,5721,0)="""RTN"",""IBCNES"",53,0)"
^XMB(3.9,144657,2,5722,0)=" . S VALMHDR(2)=""** Based on service date ""_$S(RSDATE:$$FMTE^XLFDT(RSDATE,""5Z""),1:""UNKNOWN"")_"" and service type: ""_$S(RSTYPE:$P($G(^IBE(365.013,RSTYPE,0)),U,2),1:""UNKNOWN"")_"" **"""
^XMB(3.9,144657,2,5723,0)="""RTN"",""IBCNES"",54,0)"
^XMB(3.9,144657,2,5724,0)=" ;"
^XMB(3.9,144657,2,5725,0)="""RTN"",""IBCNES"",55,0)"
^XMB(3.9,144657,2,5726,0)=" I $G(IBBUFDA) D"
^XMB(3.9,144657,2,5727,0)="""RTN"",""IBCNES"",56,0)"
^XMB(3.9,144657,2,5728,0)=" .N SRVARRAY,Z"
^XMB(3.9,144657,2,5729,0)="""RTN"",""IBCNES"",57,0)"
^XMB(3.9,144657,2,5730,0)=" .D SERVLN^IBCNBLE(IBBUFDA,.SRVARRAY) I SRVARRAY F Z=1:1:SRVARRAY S VALMHDR(Z+1)=SRVARRAY(Z)"
^XMB(3.9,144657,2,5731,0)="""RTN"",""IBCNES"",58,0)"
^XMB(3.9,144657,2,5732,0)=" Q"
^XMB(3.9,144657,2,5733,0)="""RTN"",""IBCNES"",59,0)"
^XMB(3.9,144657,2,5734,0)=" ;"
^XMB(3.9,144657,2,5735,0)="""RTN"",""IBCNES"",60,0)"
^XMB(3.9,144657,2,5736,0)="INIT(IBVF,IBVIENS,IBVEBFLG,IBVV,IBVSUB) ; List Entry"
^XMB(3.9,144657,2,5737,0)="""RTN"",""IBCNES"",61,0)"
^XMB(3.9,144657,2,5738,0)=" ;"
^XMB(3.9,144657,2,5739,0)="""RTN"",""IBCNES"",62,0)"
^XMB(3.9,144657,2,5740,0)=" ;     IBVF = file# 2.322 or 365.02 (required)"
^XMB(3.9,144657,2,5741,0)="""RTN"",""IBCNES"",63,0)"
^XMB(3.9,144657,2,5742,0)=" ;  IBVIENS = std IENS list of internal entry numbers - NOT including any EB iens (required)"
^XMB(3.9,144657,2,5743,0)="""RTN"",""IBCNES"",64,0)"
^XMB(3.9,144657,2,5744,0)=" ; IBVEBFLG = flag indicating which EB records to pull"
^XMB(3.9,144657,2,5745,0)="""RTN"",""IBCNES"",65,0)"
^XMB(3.9,144657,2,5746,0)=" ;            ""A"" - all of them"
^XMB(3.9,144657,2,5747,0)="""RTN"",""IBCNES"",66,0)"
^XMB(3.9,144657,2,5748,0)=" ;            ""L"" - only the last one (default)"
^XMB(3.9,144657,2,5749,0)="""RTN"",""IBCNES"",67,0)"
^XMB(3.9,144657,2,5750,0)=" ;            ""F"" - only the first one"
^XMB(3.9,144657,2,5751,0)="""RTN"",""IBCNES"",68,0)"
^XMB(3.9,144657,2,5752,0)=" ;            ""M"" - multiple, pass IBEBFLG by reference and include the IB iens in"
^XMB(3.9,144657,2,5753,0)="""RTN"",""IBCNES"",69,0)"
^XMB(3.9,144657,2,5754,0)=" ;                  an array as follows:"
^XMB(3.9,144657,2,5755,0)="""RTN"",""IBCNES"",70,0)"
^XMB(3.9,144657,2,5756,0)=" ;                  IBVEBFLG=""M"""
^XMB(3.9,144657,2,5757,0)="""RTN"",""IBCNES"",71,0)"
^XMB(3.9,144657,2,5758,0)=" ;                  IBVEBFLG(3)="""""
^XMB(3.9,144657,2,5759,0)="""RTN"",""IBCNES"",72,0)"
^XMB(3.9,144657,2,5760,0)=" ;                  IBVEBFLG(5)="""""
^XMB(3.9,144657,2,5761,0)="""RTN"",""IBCNES"",73,0)"
^XMB(3.9,144657,2,5762,0)=" ;     IBVV = Video attributes flag"
^XMB(3.9,144657,2,5763,0)="""RTN"",""IBCNES"",74,0)"
^XMB(3.9,144657,2,5764,0)=" ;            1 = reverse video (default)"
^XMB(3.9,144657,2,5765,0)="""RTN"",""IBCNES"",75,0)"
^XMB(3.9,144657,2,5766,0)=" ;            2 = bold"
^XMB(3.9,144657,2,5767,0)="""RTN"",""IBCNES"",76,0)"
^XMB(3.9,144657,2,5768,0)=" ;            3 = underline"
^XMB(3.9,144657,2,5769,0)="""RTN"",""IBCNES"",77,0)"
^XMB(3.9,144657,2,5770,0)=" ;   IBVSUB = literal subscript to use in the display scratch global"
^XMB(3.9,144657,2,5771,0)="""RTN"",""IBCNES"",78,0)"
^XMB(3.9,144657,2,5772,0)=" ;"
^XMB(3.9,144657,2,5773,0)="""RTN"",""IBCNES"",79,0)"
^XMB(3.9,144657,2,5774,0)=" N IBVDA,GLO,IBVLIST,IEN,IBVEBIEN,IBVEBTOT,IBVEBCNT"
^XMB(3.9,144657,2,5775,0)="""RTN"",""IBCNES"",80,0)"
^XMB(3.9,144657,2,5776,0)=" ;N IBECODE,IIVSTAT,PLNDESC,IBINSTYP,OTHINS,MWNRIEN     ;IB*2.0*506 to be used to create EBSummary"
^XMB(3.9,144657,2,5777,0)="""RTN"",""IBCNES"",81,0)"
^XMB(3.9,144657,2,5778,0)=" ;"
^XMB(3.9,144657,2,5779,0)="""RTN"",""IBCNES"",82,0)"
^XMB(3.9,144657,2,5780,0)=" S OTHINS=0 ;IB*2.0*506/TAZ Initialize Other Insurance variable"
^XMB(3.9,144657,2,5781,0)="""RTN"",""IBCNES"",83,0)"
^XMB(3.9,144657,2,5782,0)=" S MWNRIEN=$P($G(^IBE(350.9,1,51)),U,25) ;IB*2.0*506/TAZ Initialize Medicare WNR payer IEN"
^XMB(3.9,144657,2,5783,0)="""RTN"",""IBCNES"",84,0)"
^XMB(3.9,144657,2,5784,0)=" S IBVSUB=$G(IBVSUB)"
^XMB(3.9,144657,2,5785,0)="""RTN"",""IBCNES"",85,0)"
^XMB(3.9,144657,2,5786,0)=" I IBVSUB="""" S IBVSUB=""EB ELIG/BEN"""
^XMB(3.9,144657,2,5787,0)="""RTN"",""IBCNES"",86,0)"
^XMB(3.9,144657,2,5788,0)=" K ^TMP(IBVSUB,$J)"
^XMB(3.9,144657,2,5789,0)="""RTN"",""IBCNES"",87,0)"
^XMB(3.9,144657,2,5790,0)=" I $D(VALMEVL) D CLEAN^VALM10,KILL^VALM10()"
^XMB(3.9,144657,2,5791,0)="""RTN"",""IBCNES"",88,0)"
^XMB(3.9,144657,2,5792,0)=" ;"
^XMB(3.9,144657,2,5793,0)="""RTN"",""IBCNES"",89,0)"
^XMB(3.9,144657,2,5794,0)=" D DA^DILF(IBVIENS,.IBVDA)    ; build the IBVDA array for the iens"
^XMB(3.9,144657,2,5795,0)="""RTN"",""IBCNES"",90,0)"
^XMB(3.9,144657,2,5796,0)=" I '$D(IBVDA) D NODATA G INITX"
^XMB(3.9,144657,2,5797,0)="""RTN"",""IBCNES"",91,0)"
^XMB(3.9,144657,2,5798,0)=" ;"
^XMB(3.9,144657,2,5799,0)="""RTN"",""IBCNES"",92,0)"
^XMB(3.9,144657,2,5800,0)=" I $D(VALMEVL),'$G(IBVV) S IBVV=1    ; default reverse video for ListMan"
^XMB(3.9,144657,2,5801,0)="""RTN"",""IBCNES"",93,0)"
^XMB(3.9,144657,2,5802,0)=" I '$D(VALMEVL) S IBVV=""""            ; no video attributes for non-ListMan"
^XMB(3.9,144657,2,5803,0)="""RTN"",""IBCNES"",94,0)"
^XMB(3.9,144657,2,5804,0)=" ;"
^XMB(3.9,144657,2,5805,0)="""RTN"",""IBCNES"",95,0)"
^XMB(3.9,144657,2,5806,0)=" D RPDM^IBCNES3($S(IBVF=365.02:365,1:2.312),.IBVDA,IBVV,IBVSUB)  ; IB*2*497  display group level eligibility information"
^XMB(3.9,144657,2,5807,0)="""RTN"",""IBCNES"",96,0)"
^XMB(3.9,144657,2,5808,0)=" ;"
^XMB(3.9,144657,2,5809,0)="""RTN"",""IBCNES"",97,0)"
^XMB(3.9,144657,2,5810,0)=" I IBVF=2.322 S GLO=$NA(^DPT(+$G(IBVDA(1)),.312,+$G(IBVDA),6))   ; pt. insurance"
^XMB(3.9,144657,2,5811,0)="""RTN"",""IBCNES"",98,0)"
^XMB(3.9,144657,2,5812,0)=" I IBVF=365.02 S GLO=$NA(^IBCN(365,+$G(IBVDA),2))                ; response file"
^XMB(3.9,144657,2,5813,0)="""RTN"",""IBCNES"",99,0)"
^XMB(3.9,144657,2,5814,0)=" I $G(GLO)="""" D NODATA G INITX"
^XMB(3.9,144657,2,5815,0)="""RTN"",""IBCNES"",100,0)"
^XMB(3.9,144657,2,5816,0)=" ;"
^XMB(3.9,144657,2,5817,0)="""RTN"",""IBCNES"",101,0)"
^XMB(3.9,144657,2,5818,0)=" S IBVEBFLG=$G(IBVEBFLG,""L"")"
^XMB(3.9,144657,2,5819,0)="""RTN"",""IBCNES"",102,0)"
^XMB(3.9,144657,2,5820,0)=" K IBVLIST"
^XMB(3.9,144657,2,5821,0)="""RTN"",""IBCNES"",103,0)"
^XMB(3.9,144657,2,5822,0)=" I IBVEBFLG=""L"" S IEN=+$O(@GLO@("" ""),-1) I IEN S IBVLIST(IEN)=""""            ; last EB ien on file"
^XMB(3.9,144657,2,5823,0)="""RTN"",""IBCNES"",104,0)"
^XMB(3.9,144657,2,5824,0)=" I IBVEBFLG=""F"" S IEN=+$O(@GLO@(0)) I IEN S IBVLIST(IEN)=""""                 ; first EB ien on file"
^XMB(3.9,144657,2,5825,0)="""RTN"",""IBCNES"",105,0)"
^XMB(3.9,144657,2,5826,0)=" I IBVEBFLG=""A"" S IEN=0 F  S IEN=$O(@GLO@(IEN)) Q:'IEN  S IBVLIST(IEN)=""""   ; all EB iens on file"
^XMB(3.9,144657,2,5827,0)="""RTN"",""IBCNES"",106,0)"
^XMB(3.9,144657,2,5828,0)=" I IBVEBFLG=""M"" S IEN=0 F  S IEN=$O(IBVEBFLG(IEN)) Q:'IEN  I $D(@GLO@(IEN)) S IBVLIST(IEN)=""""   ; multiple"
^XMB(3.9,144657,2,5829,0)="""RTN"",""IBCNES"",107,0)"
^XMB(3.9,144657,2,5830,0)=" ;"
^XMB(3.9,144657,2,5831,0)="""RTN"",""IBCNES"",108,0)"
^XMB(3.9,144657,2,5832,0)=" I '$D(IBVLIST) D NODATA G INITX"
^XMB(3.9,144657,2,5833,0)="""RTN"",""IBCNES"",109,0)"
^XMB(3.9,144657,2,5834,0)=" ;"
^XMB(3.9,144657,2,5835,0)="""RTN"",""IBCNES"",110,0)"
^XMB(3.9,144657,2,5836,0)=" ; count them"
^XMB(3.9,144657,2,5837,0)="""RTN"",""IBCNES"",111,0)"
^XMB(3.9,144657,2,5838,0)=" S IEN=0 F IBVEBTOT=0:1 S IEN=$O(IBVLIST(IEN)) Q:'IEN"
^XMB(3.9,144657,2,5839,0)="""RTN"",""IBCNES"",112,0)"
^XMB(3.9,144657,2,5840,0)=" I 'IBVEBTOT D NODATA G INITX"
^XMB(3.9,144657,2,5841,0)="""RTN"",""IBCNES"",113,0)"
^XMB(3.9,144657,2,5842,0)=" ;"
^XMB(3.9,144657,2,5843,0)="""RTN"",""IBCNES"",114,0)"
^XMB(3.9,144657,2,5844,0)=" ;IB*506 -  Count EBs and gather EB Summary Data"
^XMB(3.9,144657,2,5845,0)="""RTN"",""IBCNES"",115,0)"
^XMB(3.9,144657,2,5846,0)=" ;  IB*806 All related code to IB*506 for EB count and EB Summary Data was replaced"
^XMB(3.9,144657,2,5847,0)="""RTN"",""IBCNES"",116,0)"
^XMB(3.9,144657,2,5848,0)=" ;         "
^XMB(3.9,144657,2,5849,0)="""RTN"",""IBCNES"",117,0)"
^XMB(3.9,144657,2,5850,0)=" D SUMMARY   ; Summary of EB loops"
^XMB(3.9,144657,2,5851,0)="""RTN"",""IBCNES"",118,0)"
^XMB(3.9,144657,2,5852,0)=" ;"
^XMB(3.9,144657,2,5853,0)="""RTN"",""IBCNES"",119,0)"
^XMB(3.9,144657,2,5854,0)=" I 'IBVEBTOT D NODATA G INITX"
^XMB(3.9,144657,2,5855,0)="""RTN"",""IBCNES"",120,0)"
^XMB(3.9,144657,2,5856,0)=" ;"
^XMB(3.9,144657,2,5857,0)="""RTN"",""IBCNES"",121,0)"
^XMB(3.9,144657,2,5858,0)=" S IBVEBIEN=1,IBVEBCNT=0  ;IB*806/DJW  initialize IBVEBIEN to 1 to skip 1st EB loop (FSC generated loop)"
^XMB(3.9,144657,2,5859,0)="""RTN"",""IBCNES"",122,0)"
^XMB(3.9,144657,2,5860,0)=" F  S IBVEBIEN=$O(IBVLIST(IBVEBIEN)) Q:'IBVEBIEN  D"
^XMB(3.9,144657,2,5861,0)="""RTN"",""IBCNES"",123,0)"
^XMB(3.9,144657,2,5862,0)=" . S IBVEBCNT=IBVEBCNT+1"
^XMB(3.9,144657,2,5863,0)="""RTN"",""IBCNES"",124,0)"
^XMB(3.9,144657,2,5864,0)=" . N TXVIENS"
^XMB(3.9,144657,2,5865,0)="""RTN"",""IBCNES"",125,0)"
^XMB(3.9,144657,2,5866,0)=" . ;"
^XMB(3.9,144657,2,5867,0)="""RTN"",""IBCNES"",126,0)"
^XMB(3.9,144657,2,5868,0)=" . ; if there is more than 1 EB group, then display a header line for separation"
^XMB(3.9,144657,2,5869,0)="""RTN"",""IBCNES"",127,0)"
^XMB(3.9,144657,2,5870,0)=" . I IBVEBTOT>1 D"
^XMB(3.9,144657,2,5871,0)="""RTN"",""IBCNES"",128,0)"
^XMB(3.9,144657,2,5872,0)=" .. N DSP,LN,IBZ"
^XMB(3.9,144657,2,5873,0)="""RTN"",""IBCNES"",129,0)"
^XMB(3.9,144657,2,5874,0)=" .. S DSP=$NA(^TMP(IBVSUB,$J,""DISP""))"
^XMB(3.9,144657,2,5875,0)="""RTN"",""IBCNES"",130,0)"
^XMB(3.9,144657,2,5876,0)=" .. S LN=+$O(@DSP@(""""),-1)"
^XMB(3.9,144657,2,5877,0)="""RTN"",""IBCNES"",131,0)"
^XMB(3.9,144657,2,5878,0)=" .. S IBZ=""eIV Eligibility/Benefit Data Group# ""_IBVEBCNT_"" of ""_(IBVEBTOT-1)  ;IB*806 added -1"
^XMB(3.9,144657,2,5879,0)="""RTN"",""IBCNES"",132,0)"
^XMB(3.9,144657,2,5880,0)=" .. S IBZ=$$FO^IBCNEUT1($J("""",20)_IBZ,80)"
^XMB(3.9,144657,2,5881,0)="""RTN"",""IBCNES"",133,0)"
^XMB(3.9,144657,2,5882,0)=" .. S LN=LN+1 D SET^IBCNES1(LN,1,IBZ,,IBVV)   ;section hdr ""eIV Elig ... x of x"""
^XMB(3.9,144657,2,5883,0)="""RTN"",""IBCNES"",134,0)"
^XMB(3.9,144657,2,5884,0)=" .. S IBZ=""---------------------------------------------"""
^XMB(3.9,144657,2,5885,0)="""RTN"",""IBCNES"",135,0)"
^XMB(3.9,144657,2,5886,0)=" .. S IBZ=$$FO^IBCNEUT1($J("""",20)_IBZ,80)"
^XMB(3.9,144657,2,5887,0)="""RTN"",""IBCNES"",136,0)"
^XMB(3.9,144657,2,5888,0)=" .. S LN=LN+1 D SET^IBCNES1(LN,1,IBZ,,IBVV)"
^XMB(3.9,144657,2,5889,0)="""RTN"",""IBCNES"",137,0)"
^XMB(3.9,144657,2,5890,0)=" . ;"
^XMB(3.9,144657,2,5891,0)="""RTN"",""IBCNES"",138,0)"
^XMB(3.9,144657,2,5892,0)=" . ; add this EB ien to the list of iens"
^XMB(3.9,144657,2,5893,0)="""RTN"",""IBCNES"",139,0)"
^XMB(3.9,144657,2,5894,0)=" . S TXVIENS=IBVEBIEN_"",""_IBVIENS"
^XMB(3.9,144657,2,5895,0)="""RTN"",""IBCNES"",140,0)"
^XMB(3.9,144657,2,5896,0)=" . ;"
^XMB(3.9,144657,2,5897,0)="""RTN"",""IBCNES"",141,0)"
^XMB(3.9,144657,2,5898,0)=" . ; call the screen sections to build the display"
^XMB(3.9,144657,2,5899,0)="""RTN"",""IBCNES"",142,0)"
^XMB(3.9,144657,2,5900,0)=" . D EB^IBCNES1(IBVF,TXVIENS,IBVV,IBVSUB)"
^XMB(3.9,144657,2,5901,0)="""RTN"",""IBCNES"",143,0)"
^XMB(3.9,144657,2,5902,0)=" . D CMPI^IBCNES1(IBVF,TXVIENS,IBVV,IBVSUB)"
^XMB(3.9,144657,2,5903,0)="""RTN"",""IBCNES"",144,0)"
^XMB(3.9,144657,2,5904,0)=" . D HCSD^IBCNES1(IBVF,TXVIENS,IBVV,IBVSUB)"
^XMB(3.9,144657,2,5905,0)="""RTN"",""IBCNES"",145,0)"
^XMB(3.9,144657,2,5906,0)=" . D NTE^IBCNES1(IBVF,TXVIENS,IBVV,IBVSUB)"
^XMB(3.9,144657,2,5907,0)="""RTN"",""IBCNES"",146,0)"
^XMB(3.9,144657,2,5908,0)=" . D BRE^IBCNES1(IBVF,TXVIENS,IBVV,IBVSUB)"
^XMB(3.9,144657,2,5909,0)="""RTN"",""IBCNES"",147,0)"
^XMB(3.9,144657,2,5910,0)=" ;"
^XMB(3.9,144657,2,5911,0)="""RTN"",""IBCNES"",148,0)"
^XMB(3.9,144657,2,5912,0)=" S VALMCNT=$O(^TMP(IBVSUB,$J,""DISP"","" ""),-1)"
^XMB(3.9,144657,2,5913,0)="""RTN"",""IBCNES"",149,0)"
^XMB(3.9,144657,2,5914,0)=" ;"
^XMB(3.9,144657,2,5915,0)="""RTN"",""IBCNES"",150,0)"
^XMB(3.9,144657,2,5916,0)="INITX ;"
^XMB(3.9,144657,2,5917,0)="""RTN"",""IBCNES"",151,0)"
^XMB(3.9,144657,2,5918,0)=" Q"
^XMB(3.9,144657,2,5919,0)="""RTN"",""IBCNES"",152,0)"
^XMB(3.9,144657,2,5920,0)=" ;"
^XMB(3.9,144657,2,5921,0)="""RTN"",""IBCNES"",153,0)"
^XMB(3.9,144657,2,5922,0)="SUMMARY ;"
^XMB(3.9,144657,2,5923,0)="""RTN"",""IBCNES"",154,0)"
^XMB(3.9,144657,2,5924,0)=" N ARRAY,DSP,LN,IBZ,IBINSTYP,IBPEDT,XX,HLDT,IIVSTAT,DFN,RSPIEN,IBX,DATA"
^XMB(3.9,144657,2,5925,0)="""RTN"",""IBCNES"",155,0)"
^XMB(3.9,144657,2,5926,0)=" ;"
^XMB(3.9,144657,2,5927,0)="""RTN"",""IBCNES"",156,0)"
^XMB(3.9,144657,2,5928,0)=" KILL ARRAY"
^XMB(3.9,144657,2,5929,0)="""RTN"",""IBCNES"",157,0)"
^XMB(3.9,144657,2,5930,0)=" ;"
^XMB(3.9,144657,2,5931,0)="""RTN"",""IBCNES"",158,0)"
^XMB(3.9,144657,2,5932,0)=" I IBVF=2.322 D"
^XMB(3.9,144657,2,5933,0)="""RTN"",""IBCNES"",159,0)"
^XMB(3.9,144657,2,5934,0)=" . S DFN=+$G(IBVDA(1))"
^XMB(3.9,144657,2,5935,0)="""RTN"",""IBCNES"",160,0)"
^XMB(3.9,144657,2,5936,0)=" . S RSPIEN=$$GET1^DIQ(2.312,+$G(IBVDA)_"",""_DFN_"","",8.03,""I"")"
^XMB(3.9,144657,2,5937,0)="""RTN"",""IBCNES"",161,0)"
^XMB(3.9,144657,2,5938,0)=" I IBVF=365.02 D"
^XMB(3.9,144657,2,5939,0)="""RTN"",""IBCNES"",162,0)"
^XMB(3.9,144657,2,5940,0)=" . S RSPIEN=+$G(IBVDA)"
^XMB(3.9,144657,2,5941,0)="""RTN"",""IBCNES"",163,0)"
^XMB(3.9,144657,2,5942,0)=" . S IBX=$G(^IBCN(365,RSPIEN,0)),DFN=+$P(IBX,U,2)"
^XMB(3.9,144657,2,5943,0)="""RTN"",""IBCNES"",164,0)"
^XMB(3.9,144657,2,5944,0)=" ;"
^XMB(3.9,144657,2,5945,0)="""RTN"",""IBCNES"",165,0)"
^XMB(3.9,144657,2,5946,0)=" S DSP=$NA(^TMP(IBVSUB,$J,""DISP""))"
^XMB(3.9,144657,2,5947,0)="""RTN"",""IBCNES"",166,0)"
^XMB(3.9,144657,2,5948,0)=" S LN=+$O(@DSP@(""""),-1)"
^XMB(3.9,144657,2,5949,0)="""RTN"",""IBCNES"",167,0)"
^XMB(3.9,144657,2,5950,0)=" S IBZ=""Summary of eIV Eligibility/Benefit Data"""
^XMB(3.9,144657,2,5951,0)="""RTN"",""IBCNES"",168,0)"
^XMB(3.9,144657,2,5952,0)=" S IBZ=$$FO^IBCNEUT1($J("""",20)_IBZ,80)"
^XMB(3.9,144657,2,5953,0)="""RTN"",""IBCNES"",169,0)"
^XMB(3.9,144657,2,5954,0)=" S LN=LN+1 D SET^IBCNES1(LN,1,IBZ,,IBVV)"
^XMB(3.9,144657,2,5955,0)="""RTN"",""IBCNES"",170,0)"
^XMB(3.9,144657,2,5956,0)=" S IBZ=""---------------------------------------"""
^XMB(3.9,144657,2,5957,0)="""RTN"",""IBCNES"",171,0)"
^XMB(3.9,144657,2,5958,0)=" S IBZ=$$FO^IBCNEUT1($J("""",20)_IBZ,80)"
^XMB(3.9,144657,2,5959,0)="""RTN"",""IBCNES"",172,0)"
^XMB(3.9,144657,2,5960,0)=" S LN=LN+1 D SET^IBCNES1(LN,1,IBZ,,IBVV)"
^XMB(3.9,144657,2,5961,0)="""RTN"",""IBCNES"",173,0)"
^XMB(3.9,144657,2,5962,0)=" ;"
^XMB(3.9,144657,2,5963,0)="""RTN"",""IBCNES"",174,0)"
^XMB(3.9,144657,2,5964,0)=" D EBSUMMARY^IBCNEUT2(DFN,RSPIEN,"""",.ARRAY)"
^XMB(3.9,144657,2,5965,0)="""RTN"",""IBCNES"",175,0)"
^XMB(3.9,144657,2,5966,0)=" ;"
^XMB(3.9,144657,2,5967,0)="""RTN"",""IBCNES"",176,0)"
^XMB(3.9,144657,2,5968,0)=" S IBPEDT=$P($G(RPTDATA(1)),U,11)  ; get Effective dt  from above"
^XMB(3.9,144657,2,5969,0)="""RTN"",""IBCNES"",177,0)"
^XMB(3.9,144657,2,5970,0)=" I '$O(ARRAY(0)) D  G SUMX  ; IB*806/DTG blank summary section use $O instead of $D"
^XMB(3.9,144657,2,5971,0)="""RTN"",""IBCNES"",178,0)"
^XMB(3.9,144657,2,5972,0)=" . S LN=LN+1 D SET^IBCNES1(LN,1,""Insurance Type"",""Unknown"")"
^XMB(3.9,144657,2,5973,0)="""RTN"",""IBCNES"",179,0)"
^XMB(3.9,144657,2,5974,0)=" . S LN=LN+1 D SET^IBCNES1(LN,5,""Coverage Status"",""Unknown"")"
^XMB(3.9,144657,2,5975,0)="""RTN"",""IBCNES"",180,0)"
^XMB(3.9,144657,2,5976,0)=" . S LN=LN+1 D SET^IBCNES1(LN,5,""Plan Date/Effective Date"",$S(IBPEDT'="""":IBPEDT,1:""Unknown""))  ;use eff dt from above / uknown if not there"
^XMB(3.9,144657,2,5977,0)="""RTN"",""IBCNES"",181,0)"
^XMB(3.9,144657,2,5978,0)=" . S LN=LN+1 D SET^IBCNES1(LN)"
^XMB(3.9,144657,2,5979,0)="""RTN"",""IBCNES"",182,0)"
^XMB(3.9,144657,2,5980,0)=" ;"
^XMB(3.9,144657,2,5981,0)="""RTN"",""IBCNES"",183,0)"
^XMB(3.9,144657,2,5982,0)=" S XX="""" F  S XX=$O(ARRAY(XX)) Q:XX=""""  D"
^XMB(3.9,144657,2,5983,0)="""RTN"",""IBCNES"",184,0)"
^XMB(3.9,144657,2,5984,0)=" . S IBINSTYP="""" F  S IBINSTYP=$O(ARRAY(XX,IBINSTYP)) Q:IBINSTYP=""""  D"
^XMB(3.9,144657,2,5985,0)="""RTN"",""IBCNES"",185,0)"
^XMB(3.9,144657,2,5986,0)=" .. S DATA=ARRAY(XX,IBINSTYP),IIVSTAT=$P(DATA,U,5),HLDT=$$FMTE^XLFDT($P(DATA,U,3),""5Z"")"
^XMB(3.9,144657,2,5987,0)="""RTN"",""IBCNES"",186,0)"
^XMB(3.9,144657,2,5988,0)=" .. ;I HLDT="""" S HLDT=""Unknown"""
^XMB(3.9,144657,2,5989,0)="""RTN"",""IBCNES"",187,0)"
^XMB(3.9,144657,2,5990,0)=" .. I HLDT="""" S HLDT=IBPEDT  ; use eff dt from above"
^XMB(3.9,144657,2,5991,0)="""RTN"",""IBCNES"",188,0)"
^XMB(3.9,144657,2,5992,0)=" .. I HLDT="""" S HLDT=""Unknown""  ; if date is still null use Unknown"
^XMB(3.9,144657,2,5993,0)="""RTN"",""IBCNES"",189,0)"
^XMB(3.9,144657,2,5994,0)=" .. S LN=LN+1 D SET^IBCNES1(LN,1,""Insurance Type"",IBINSTYP)"
^XMB(3.9,144657,2,5995,0)="""RTN"",""IBCNES"",190,0)"
^XMB(3.9,144657,2,5996,0)=" .. S LN=LN+1 D SET^IBCNES1(LN,5,""Coverage Status"",IIVSTAT)"
^XMB(3.9,144657,2,5997,0)="""RTN"",""IBCNES"",191,0)"
^XMB(3.9,144657,2,5998,0)=" .. S LN=LN+1 D SET^IBCNES1(LN,5,""Plan Date/Effective Date"",HLDT)"
^XMB(3.9,144657,2,5999,0)="""RTN"",""IBCNES"",192,0)"
^XMB(3.9,144657,2,6000,0)=" .. S LN=LN+1 D SET^IBCNES1(LN)"
^XMB(3.9,144657,2,6001,0)="""RTN"",""IBCNES"",193,0)"
^XMB(3.9,144657,2,6002,0)=" ;"
^XMB(3.9,144657,2,6003,0)="""RTN"",""IBCNES"",194,0)"
^XMB(3.9,144657,2,6004,0)=" I $D(ARRAY(""OHI"")) D"
^XMB(3.9,144657,2,6005,0)="""RTN"",""IBCNES"",195,0)"
^XMB(3.9,144657,2,6006,0)=" . S LN=LN+1 D SET^IBCNES1(LN,1,""Other insurance was potentially found"")"
^XMB(3.9,144657,2,6007,0)="""RTN"",""IBCNES"",196,0)"
^XMB(3.9,144657,2,6008,0)=" . S LN=LN+1 D SET^IBCNES1(LN)"
^XMB(3.9,144657,2,6009,0)="""RTN"",""IBCNES"",197,0)"
^XMB(3.9,144657,2,6010,0)=" ;"
^XMB(3.9,144657,2,6011,0)="""RTN"",""IBCNES"",198,0)"
^XMB(3.9,144657,2,6012,0)="SUMX ; end of summary section  ;IB*806/DTG"
^XMB(3.9,144657,2,6013,0)="""RTN"",""IBCNES"",199,0)"
^XMB(3.9,144657,2,6014,0)=" ;"
^XMB(3.9,144657,2,6015,0)="""RTN"",""IBCNES"",200,0)"
^XMB(3.9,144657,2,6016,0)=" Q"
^XMB(3.9,144657,2,6017,0)="""RTN"",""IBCNES"",201,0)"
^XMB(3.9,144657,2,6018,0)=" ;"
^XMB(3.9,144657,2,6019,0)="""RTN"",""IBCNES"",202,0)"
^XMB(3.9,144657,2,6020,0)="NODATA ; display no data found"
^XMB(3.9,144657,2,6021,0)="""RTN"",""IBCNES"",203,0)"
^XMB(3.9,144657,2,6022,0)=" N DSP,LN"
^XMB(3.9,144657,2,6023,0)="""RTN"",""IBCNES"",204,0)"
^XMB(3.9,144657,2,6024,0)=" S DSP=$NA(^TMP(IBVSUB,$J,""DISP""))       ; scratch global display array"
^XMB(3.9,144657,2,6025,0)="""RTN"",""IBCNES"",205,0)"
^XMB(3.9,144657,2,6026,0)=" S LN=+$O(@DSP@(""""),-1)                  ; last line# used in scratch global"
^XMB(3.9,144657,2,6027,0)="""RTN"",""IBCNES"",206,0)"
^XMB(3.9,144657,2,6028,0)=" S LN=LN+1 D SET^IBCNES1(LN)"
^XMB(3.9,144657,2,6029,0)="""RTN"",""IBCNES"",207,0)"
^XMB(3.9,144657,2,6030,0)=" S LN=LN+1 D SET^IBCNES1(LN,5,""No eIV Eligibility/Benefit Data Found"")"
^XMB(3.9,144657,2,6031,0)="""RTN"",""IBCNES"",208,0)"
^XMB(3.9,144657,2,6032,0)=" S VALMCNT=$O(^TMP(IBVSUB,$J,""DISP"","" ""),-1)"
^XMB(3.9,144657,2,6033,0)="""RTN"",""IBCNES"",209,0)"
^XMB(3.9,144657,2,6034,0)="NODATAX ;"
^XMB(3.9,144657,2,6035,0)="""RTN"",""IBCNES"",210,0)"
^XMB(3.9,144657,2,6036,0)=" Q"
^XMB(3.9,144657,2,6037,0)="""RTN"",""IBCNES"",211,0)"
^XMB(3.9,144657,2,6038,0)=" ;"
^XMB(3.9,144657,2,6039,0)="""RTN"",""IBCNES"",212,0)"
^XMB(3.9,144657,2,6040,0)="HELP ; -- help code"
^XMB(3.9,144657,2,6041,0)="""RTN"",""IBCNES"",213,0)"
^XMB(3.9,144657,2,6042,0)=" S X=""?"",VALMANS=""??"" D DISP^XQORM1 W !!"
^XMB(3.9,144657,2,6043,0)="""RTN"",""IBCNES"",214,0)"
^XMB(3.9,144657,2,6044,0)=" Q"
^XMB(3.9,144657,2,6045,0)="""RTN"",""IBCNES"",215,0)"
^XMB(3.9,144657,2,6046,0)=" ;"
^XMB(3.9,144657,2,6047,0)="""RTN"",""IBCNES"",216,0)"
^XMB(3.9,144657,2,6048,0)="EXIT ; -- exit code"
^XMB(3.9,144657,2,6049,0)="""RTN"",""IBCNES"",217,0)"
^XMB(3.9,144657,2,6050,0)=" K ^TMP(IBVSUB,$J)"
^XMB(3.9,144657,2,6051,0)="""RTN"",""IBCNES"",218,0)"
^XMB(3.9,144657,2,6052,0)=" I $D(VALMEVL) D CLEAN^VALM10,KILL^VALM10()"
^XMB(3.9,144657,2,6053,0)="""RTN"",""IBCNES"",219,0)"
^XMB(3.9,144657,2,6054,0)=" Q"
^XMB(3.9,144657,2,6055,0)="""RTN"",""IBCNETST"")"
^XMB(3.9,144657,2,6056,0)="0^10^B45011499"
^XMB(3.9,144657,2,6057,0)="""RTN"",""IBCNETST"",1,0)"
^XMB(3.9,144657,2,6058,0)="IBCNETST ;DAOU/ALA - eIV Gate-keeper test scenarios ; 11-OCT-2017"
^XMB(3.9,144657,2,6059,0)="""RTN"",""IBCNETST"",2,0)"
^XMB(3.9,144657,2,6060,0)=" ;;2.0;INTEGRATED BILLING;**601,732,778**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,6061,0)="""RTN"",""IBCNETST"",3,0)"
^XMB(3.9,144657,2,6062,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,6063,0)="""RTN"",""IBCNETST"",4,0)"
^XMB(3.9,144657,2,6064,0)=" ;"
^XMB(3.9,144657,2,6065,0)="""RTN"",""IBCNETST"",5,0)"
^XMB(3.9,144657,2,6066,0)=" ;**Program Description**"
^XMB(3.9,144657,2,6067,0)="""RTN"",""IBCNETST"",6,0)"
^XMB(3.9,144657,2,6068,0)=" ;This program serves as a gate-keeper to protect FSC from receiving unexpected"
^XMB(3.9,144657,2,6069,0)="""RTN"",""IBCNETST"",7,0)"
^XMB(3.9,144657,2,6070,0)=" ;transmissions from a test account via the electronic Insurance Verification"
^XMB(3.9,144657,2,6071,0)="""RTN"",""IBCNETST"",8,0)"
^XMB(3.9,144657,2,6072,0)=" ;interface. Unexpected transmission have been known to take down their test"
^XMB(3.9,144657,2,6073,0)="""RTN"",""IBCNETST"",9,0)"
^XMB(3.9,144657,2,6074,0)=" ;systems. DO NOT alter or remove this routine."
^XMB(3.9,144657,2,6075,0)="""RTN"",""IBCNETST"",10,0)"
^XMB(3.9,144657,2,6076,0)=" ;"
^XMB(3.9,144657,2,6077,0)="""RTN"",""IBCNETST"",11,0)"
^XMB(3.9,144657,2,6078,0)=" ; IB*2*601/DM XMITOK() Gate-keeper routine moved from IBCNEUT7"
^XMB(3.9,144657,2,6079,0)="""RTN"",""IBCNETST"",12,0)"
^XMB(3.9,144657,2,6080,0)=" ; IB*2*732/TZ added Test patients for auto-update with no group number"
^XMB(3.9,144657,2,6081,0)="""RTN"",""IBCNETST"",13,0)"
^XMB(3.9,144657,2,6082,0)=" ; IB*2*732/CKB added Test patients for 'Blues'"
^XMB(3.9,144657,2,6083,0)="""RTN"",""IBCNETST"",14,0)"
^XMB(3.9,144657,2,6084,0)=" ; IB*2*778/DJW changed acceptable SUBSCRIBER ID for 2 of the scenarios"
^XMB(3.9,144657,2,6085,0)="""RTN"",""IBCNETST"",15,0)"
^XMB(3.9,144657,2,6086,0)=" ;"
^XMB(3.9,144657,2,6087,0)="""RTN"",""IBCNETST"",16,0)"
^XMB(3.9,144657,2,6088,0)=" Q"
^XMB(3.9,144657,2,6089,0)="""RTN"",""IBCNETST"",17,0)"
^XMB(3.9,144657,2,6090,0)=" ;"
^XMB(3.9,144657,2,6091,0)="""RTN"",""IBCNETST"",18,0)"
^XMB(3.9,144657,2,6092,0)="XMITOK(TQIEN) ;EP"
^XMB(3.9,144657,2,6093,0)="""RTN"",""IBCNETST"",19,0)"
^XMB(3.9,144657,2,6094,0)=" ; Checks if the site is a test site (not a production site) and if so"
^XMB(3.9,144657,2,6095,0)="""RTN"",""IBCNETST"",20,0)"
^XMB(3.9,144657,2,6096,0)=" ; only allows transactions in the eIV queue that meet specific criteria"
^XMB(3.9,144657,2,6097,0)="""RTN"",""IBCNETST"",21,0)"
^XMB(3.9,144657,2,6098,0)=" ; to be transmitted to FSC. Prevents invalid transmissions from a test"
^XMB(3.9,144657,2,6099,0)="""RTN"",""IBCNETST"",22,0)"
^XMB(3.9,144657,2,6100,0)=" ; site to FSC which blocks the interface and need to be manually resolved"
^XMB(3.9,144657,2,6101,0)="""RTN"",""IBCNETST"",23,0)"
^XMB(3.9,144657,2,6102,0)=" ; at FSC."
^XMB(3.9,144657,2,6103,0)="""RTN"",""IBCNETST"",24,0)"
^XMB(3.9,144657,2,6104,0)=" ; Input:   TQIEN   - IEN of the IIV Transmission Queue entry"
^XMB(3.9,144657,2,6105,0)="""RTN"",""IBCNETST"",25,0)"
^XMB(3.9,144657,2,6106,0)=" ; Returns: 1       - Ok to add item to the eIV queue"
^XMB(3.9,144657,2,6107,0)="""RTN"",""IBCNETST"",26,0)"
^XMB(3.9,144657,2,6108,0)=" ;          0       - Not ok to add item to the eIV queue"
^XMB(3.9,144657,2,6109,0)="""RTN"",""IBCNETST"",27,0)"
^XMB(3.9,144657,2,6110,0)=" ;"
^XMB(3.9,144657,2,6111,0)="""RTN"",""IBCNETST"",28,0)"
^XMB(3.9,144657,2,6112,0)=" N DFN,GOOD,GRPNUM,IBIEN,IBCNMPI,IENS,IVPIEN,MCARE,PATDOB,PATID,PATNM,PATSEX,PAYRNM,PIEN"
^XMB(3.9,144657,2,6113,0)="""RTN"",""IBCNETST"",29,0)"
^XMB(3.9,144657,2,6114,0)=" N SUBID,SUBNM,TSITE,XX"
^XMB(3.9,144657,2,6115,0)="""RTN"",""IBCNETST"",30,0)"
^XMB(3.9,144657,2,6116,0)=" ;"
^XMB(3.9,144657,2,6117,0)="""RTN"",""IBCNETST"",31,0)"
^XMB(3.9,144657,2,6118,0)=" ; First check to see if the site is a test or a production site"
^XMB(3.9,144657,2,6119,0)="""RTN"",""IBCNETST"",32,0)"
^XMB(3.9,144657,2,6120,0)=" S TSITE=$S($$PROD^XUPROD(1):0,1:1)"
^XMB(3.9,144657,2,6121,0)="""RTN"",""IBCNETST"",33,0)"
^XMB(3.9,144657,2,6122,0)=" Q:'TSITE 1                                  ; Production site no checks done"
^XMB(3.9,144657,2,6123,0)="""RTN"",""IBCNETST"",34,0)"
^XMB(3.9,144657,2,6124,0)=" ;Q 0 ;Don't send anything"
^XMB(3.9,144657,2,6125,0)="""RTN"",""IBCNETST"",35,0)"
^XMB(3.9,144657,2,6126,0)=" ;"
^XMB(3.9,144657,2,6127,0)="""RTN"",""IBCNETST"",36,0)"
^XMB(3.9,144657,2,6128,0)=" S MCARE=$$GET1^DIQ(350.9,""1,"",51.25,""E"")    ; Medicare Payer Name"
^XMB(3.9,144657,2,6129,0)="""RTN"",""IBCNETST"",37,0)"
^XMB(3.9,144657,2,6130,0)=" ;S XX=$G(^IBCN(365.1,TQIEN,0))              ; IB*732 - invalid code"
^XMB(3.9,144657,2,6131,0)="""RTN"",""IBCNETST"",38,0)"
^XMB(3.9,144657,2,6132,0)=" S (GRPNUM,PATID,SUBID,SUBNM)="""""
^XMB(3.9,144657,2,6133,0)="""RTN"",""IBCNETST"",39,0)"
^XMB(3.9,144657,2,6134,0)=" S DFN=$$GET1^DIQ(365.1,TQIEN_"","",.02,""I"")   ; Patient IEN"
^XMB(3.9,144657,2,6135,0)="""RTN"",""IBCNETST"",40,0)"
^XMB(3.9,144657,2,6136,0)=" S PATNM=$$GET1^DIQ(2,DFN_"","",.01,""I"")       ; Patient Name"
^XMB(3.9,144657,2,6137,0)="""RTN"",""IBCNETST"",41,0)"
^XMB(3.9,144657,2,6138,0)=" S IBCNMPI=$$GET1^DIQ(2,DFN_"","",991.01,""I"")  ; Integration Control Number MPI"
^XMB(3.9,144657,2,6139,0)="""RTN"",""IBCNETST"",42,0)"
^XMB(3.9,144657,2,6140,0)=" ; Quit if the Integration Control Number MPI is null - MUST be present"
^XMB(3.9,144657,2,6141,0)="""RTN"",""IBCNETST"",43,0)"
^XMB(3.9,144657,2,6142,0)=" Q:IBCNMPI="""" 0"
^XMB(3.9,144657,2,6143,0)="""RTN"",""IBCNETST"",44,0)"
^XMB(3.9,144657,2,6144,0)=" ;"
^XMB(3.9,144657,2,6145,0)="""RTN"",""IBCNETST"",45,0)"
^XMB(3.9,144657,2,6146,0)=" ; If the patient name contains ""EICD"" they are test scenario's for the ""EICD"" process."
^XMB(3.9,144657,2,6147,0)="""RTN"",""IBCNETST"",46,0)"
^XMB(3.9,144657,2,6148,0)=" I PATNM[""EICD"" Q 1"
^XMB(3.9,144657,2,6149,0)="""RTN"",""IBCNETST"",47,0)"
^XMB(3.9,144657,2,6150,0)=" ;"
^XMB(3.9,144657,2,6151,0)="""RTN"",""IBCNETST"",48,0)"
^XMB(3.9,144657,2,6152,0)=" S PIEN=$$GET1^DIQ(365.1,TQIEN_"","",.03,""I"")  ; Payer IEN"
^XMB(3.9,144657,2,6153,0)="""RTN"",""IBCNETST"",49,0)"
^XMB(3.9,144657,2,6154,0)=" S IBIEN=$$GET1^DIQ(365.1,TQIEN_"","",.13,""I"") ; Insurance multiple number"
^XMB(3.9,144657,2,6155,0)="""RTN"",""IBCNETST"",50,0)"
^XMB(3.9,144657,2,6156,0)=" ;"
^XMB(3.9,144657,2,6157,0)="""RTN"",""IBCNETST"",51,0)"
^XMB(3.9,144657,2,6158,0)=" ; If the insurance multiple is not in the transmission queue, get the"
^XMB(3.9,144657,2,6159,0)="""RTN"",""IBCNETST"",52,0)"
^XMB(3.9,144657,2,6160,0)=" ; following fields from the Insurance Verification Processor file"
^XMB(3.9,144657,2,6161,0)="""RTN"",""IBCNETST"",53,0)"
^XMB(3.9,144657,2,6162,0)=" I IBIEN="""" D"
^XMB(3.9,144657,2,6163,0)="""RTN"",""IBCNETST"",54,0)"
^XMB(3.9,144657,2,6164,0)=" . S IVPIEN=$$GET1^DIQ(365.1,TQIEN_"","",.05,""I"") ; IVP file IEN"
^XMB(3.9,144657,2,6165,0)="""RTN"",""IBCNETST"",55,0)"
^XMB(3.9,144657,2,6166,0)=" . S GRPNUM=$$GET1^DIQ(355.33,IVPIEN_"","",90.02) ; Group Plan Number"
^XMB(3.9,144657,2,6167,0)="""RTN"",""IBCNETST"",56,0)"
^XMB(3.9,144657,2,6168,0)=" . S PATID=$$GET1^DIQ(355.33,IVPIEN_"","",62.01)  ; Group Plan Number"
^XMB(3.9,144657,2,6169,0)="""RTN"",""IBCNETST"",57,0)"
^XMB(3.9,144657,2,6170,0)=" . S SUBID=$$GET1^DIQ(355.33,IVPIEN_"","",90.03)  ; Subscriber ID"
^XMB(3.9,144657,2,6171,0)="""RTN"",""IBCNETST"",58,0)"
^XMB(3.9,144657,2,6172,0)=" . S SUBNM=$$GET1^DIQ(355.33,IVPIEN_"","",91.01)  ; Subscriber Name"
^XMB(3.9,144657,2,6173,0)="""RTN"",""IBCNETST"",59,0)"
^XMB(3.9,144657,2,6174,0)=" E  D"
^XMB(3.9,144657,2,6175,0)="""RTN"",""IBCNETST"",60,0)"
^XMB(3.9,144657,2,6176,0)=" . S IENS=IBIEN_"",""_DFN_"","""
^XMB(3.9,144657,2,6177,0)="""RTN"",""IBCNETST"",61,0)"
^XMB(3.9,144657,2,6178,0)=" . S XX=$$GET1^DIQ(2.312,IENS,.18,""I"")       ; IEN of the Group Plan"
^XMB(3.9,144657,2,6179,0)="""RTN"",""IBCNETST"",62,0)"
^XMB(3.9,144657,2,6180,0)=" . S GRPNUM=$$GET1^DIQ(355.3,XX_"","",2.02)    ; Group Plan Number"
^XMB(3.9,144657,2,6181,0)="""RTN"",""IBCNETST"",63,0)"
^XMB(3.9,144657,2,6182,0)=" . S PATID=$$GET1^DIQ(2.312,IENS,5.01)       ; Patient ID"
^XMB(3.9,144657,2,6183,0)="""RTN"",""IBCNETST"",64,0)"
^XMB(3.9,144657,2,6184,0)=" . S SUBID=$$GET1^DIQ(2.312,IENS,1)          ; Subscriber ID"
^XMB(3.9,144657,2,6185,0)="""RTN"",""IBCNETST"",65,0)"
^XMB(3.9,144657,2,6186,0)=" . S SUBNM=$$GET1^DIQ(2.312,IENS,7.01)       ; Subscriber NM"
^XMB(3.9,144657,2,6187,0)="""RTN"",""IBCNETST"",66,0)"
^XMB(3.9,144657,2,6188,0)=" ;"
^XMB(3.9,144657,2,6189,0)="""RTN"",""IBCNETST"",67,0)"
^XMB(3.9,144657,2,6190,0)=" I (SUBID="""")!(SUBNM="""") Q 0                 ; Key elements not defined"
^XMB(3.9,144657,2,6191,0)="""RTN"",""IBCNETST"",68,0)"
^XMB(3.9,144657,2,6192,0)=" S XX=$$GET1^DIQ(2,DFN_"","",.03,""I"")          ; Internal Patient DOB"
^XMB(3.9,144657,2,6193,0)="""RTN"",""IBCNETST"",69,0)"
^XMB(3.9,144657,2,6194,0)=" S PATDOB=$TR($$FMTE^XLFDT(XX,""7DZ""),""/"","""") ; YYYYMMDD format"
^XMB(3.9,144657,2,6195,0)="""RTN"",""IBCNETST"",70,0)"
^XMB(3.9,144657,2,6196,0)=" S PATSEX=$$GET1^DIQ(2,DFN_"","",.02,""I"")      ; Patient Sex"
^XMB(3.9,144657,2,6197,0)="""RTN"",""IBCNETST"",71,0)"
^XMB(3.9,144657,2,6198,0)=" S PATNM=$$GET1^DIQ(2,DFN_"","",.01,""I"")       ; Patient Name"
^XMB(3.9,144657,2,6199,0)="""RTN"",""IBCNETST"",72,0)"
^XMB(3.9,144657,2,6200,0)=" S PAYRNM=$$GET1^DIQ(365.12,PIEN_"","",.01)    ; Payer Name"
^XMB(3.9,144657,2,6201,0)="""RTN"",""IBCNETST"",73,0)"
^XMB(3.9,144657,2,6202,0)=" S PAYRNM=$$UP^XLFSTR(PAYRNM)"
^XMB(3.9,144657,2,6203,0)="""RTN"",""IBCNETST"",74,0)"
^XMB(3.9,144657,2,6204,0)=" S GOOD=0"
^XMB(3.9,144657,2,6205,0)="""RTN"",""IBCNETST"",75,0)"
^XMB(3.9,144657,2,6206,0)=" ;"
^XMB(3.9,144657,2,6207,0)="""RTN"",""IBCNETST"",76,0)"
^XMB(3.9,144657,2,6208,0)=" I PAYRNM=""CMS MBI ONLY"" G MBI ; this is an MBI test "
^XMB(3.9,144657,2,6209,0)="""RTN"",""IBCNETST"",77,0)"
^XMB(3.9,144657,2,6210,0)=" ;"
^XMB(3.9,144657,2,6211,0)="""RTN"",""IBCNETST"",78,0)"
^XMB(3.9,144657,2,6212,0)=" I PAYRNM=""AETNA"",GRPNUM=""GRP NUM 13805"",SUBID=""111111AE"" D  Q:GOOD 1"
^XMB(3.9,144657,2,6213,0)="""RTN"",""IBCNETST"",79,0)"
^XMB(3.9,144657,2,6214,0)=" . Q:SUBNM'=""IBSUB,ACTIVE"""
^XMB(3.9,144657,2,6215,0)="""RTN"",""IBCNETST"",80,0)"
^XMB(3.9,144657,2,6216,0)=" . Q:PATDOB'=""19220202"""
^XMB(3.9,144657,2,6217,0)="""RTN"",""IBCNETST"",81,0)"
^XMB(3.9,144657,2,6218,0)=" . Q:PATSEX'=""M"""
^XMB(3.9,144657,2,6219,0)="""RTN"",""IBCNETST"",82,0)"
^XMB(3.9,144657,2,6220,0)=" . S GOOD=1"
^XMB(3.9,144657,2,6221,0)="""RTN"",""IBCNETST"",83,0)"
^XMB(3.9,144657,2,6222,0)=" ;"
^XMB(3.9,144657,2,6223,0)="""RTN"",""IBCNETST"",84,0)"
^XMB(3.9,144657,2,6224,0)=" I PAYRNM=""AETNA"",GRPNUM=""GRP NUM 13188"",SUBID=""111111FG"" D  Q:GOOD 1"
^XMB(3.9,144657,2,6225,0)="""RTN"",""IBCNETST"",85,0)"
^XMB(3.9,144657,2,6226,0)=" . Q:SUBNM'=""IBSUB,INACTIVE"""
^XMB(3.9,144657,2,6227,0)="""RTN"",""IBCNETST"",86,0)"
^XMB(3.9,144657,2,6228,0)=" . Q:PATDOB'=""19480101"""
^XMB(3.9,144657,2,6229,0)="""RTN"",""IBCNETST"",87,0)"
^XMB(3.9,144657,2,6230,0)=" . Q:PATSEX'=""F"""
^XMB(3.9,144657,2,6231,0)="""RTN"",""IBCNETST"",88,0)"
^XMB(3.9,144657,2,6232,0)=" . S GOOD=1"
^XMB(3.9,144657,2,6233,0)="""RTN"",""IBCNETST"",89,0)"
^XMB(3.9,144657,2,6234,0)=" ;"
^XMB(3.9,144657,2,6235,0)="""RTN"",""IBCNETST"",90,0)"
^XMB(3.9,144657,2,6236,0)=" ; IB*778/DJW SUBID below is more generic"
^XMB(3.9,144657,2,6237,0)="""RTN"",""IBCNETST"",91,0)"
^XMB(3.9,144657,2,6238,0)=" I PAYRNM=""CIGNA"",GRPNUM=""GRP NUM 5442"",SUBID=""87654321CI"" D  Q:GOOD 1"
^XMB(3.9,144657,2,6239,0)="""RTN"",""IBCNETST"",92,0)"
^XMB(3.9,144657,2,6240,0)=" . Q:SUBNM'=""IBSUB,AAAERROR"""
^XMB(3.9,144657,2,6241,0)="""RTN"",""IBCNETST"",93,0)"
^XMB(3.9,144657,2,6242,0)=" . Q:PATDOB'=""19470211"""
^XMB(3.9,144657,2,6243,0)="""RTN"",""IBCNETST"",94,0)"
^XMB(3.9,144657,2,6244,0)=" . Q:PATSEX'=""M"""
^XMB(3.9,144657,2,6245,0)="""RTN"",""IBCNETST"",95,0)"
^XMB(3.9,144657,2,6246,0)=" . S GOOD=1"
^XMB(3.9,144657,2,6247,0)="""RTN"",""IBCNETST"",96,0)"
^XMB(3.9,144657,2,6248,0)=" ;"
^XMB(3.9,144657,2,6249,0)="""RTN"",""IBCNETST"",97,0)"
^XMB(3.9,144657,2,6250,0)=" I PAYRNM=""AETNA"",GRPNUM=""AET1234"",SUBID=""W1234561111"" D  Q:GOOD 1"
^XMB(3.9,144657,2,6251,0)="""RTN"",""IBCNETST"",98,0)"
^XMB(3.9,144657,2,6252,0)=" . Q:SUBNM'=""IBINS,ACTIVE""                  ; Note this patient is male"
^XMB(3.9,144657,2,6253,0)="""RTN"",""IBCNETST"",99,0)"
^XMB(3.9,144657,2,6254,0)=" . Q:PATID'=""W123452222"""
^XMB(3.9,144657,2,6255,0)="""RTN"",""IBCNETST"",100,0)"
^XMB(3.9,144657,2,6256,0)=" . Q:PATNM'=""IBDEP,ACTIVE"""
^XMB(3.9,144657,2,6257,0)="""RTN"",""IBCNETST"",101,0)"
^XMB(3.9,144657,2,6258,0)=" . Q:PATDOB'=""19900304"""
^XMB(3.9,144657,2,6259,0)="""RTN"",""IBCNETST"",102,0)"
^XMB(3.9,144657,2,6260,0)=" . Q:PATSEX'=""F""                            ; Note this is subscriber's spouse"
^XMB(3.9,144657,2,6261,0)="""RTN"",""IBCNETST"",103,0)"
^XMB(3.9,144657,2,6262,0)=" . S GOOD=1"
^XMB(3.9,144657,2,6263,0)="""RTN"",""IBCNETST"",104,0)"
^XMB(3.9,144657,2,6264,0)=" ;"
^XMB(3.9,144657,2,6265,0)="""RTN"",""IBCNETST"",105,0)"
