^XMB(3.9,144653,2,296,0)=" N PLOOP,PCNT,QTLOOP,QTCNT,PSOEXMS,DIR,ORDERTYP,PSOEXCNT,SCNT,SIGDAT,SLOOP,POORD,PMVAL,PRMVAL,DMVAL,PATINST,RXSTAT"
^XMB(3.9,144653,2,297,0)="""RTN"",""PSOERX1F"",29,0)"
^XMB(3.9,144653,2,298,0)=" N VADAYS,UNEXPI,PINARY,WRITDT,SLOOP2,MTYPE,REQIEN,ORXIEN,RESTYPE,DELTAS,RXIEN,ERXMSG,I,CSERRMSG,PSOQUIT,DIC,PAINDFU,INDARY,SLOOP3"
^XMB(3.9,144653,2,299,0)="""RTN"",""PSOERX1F"",30,0)"
^XMB(3.9,144653,2,300,0)=" S MBMSITE=$S($$GET1^DIQ(59.7,1,102,""I"")=""MBM"":1,1:0)"
^XMB(3.9,144653,2,301,0)="""RTN"",""PSOERX1F"",31,0)"
^XMB(3.9,144653,2,302,0)=" S F=52.49"
^XMB(3.9,144653,2,303,0)="""RTN"",""PSOERX1F"",32,0)"
^XMB(3.9,144653,2,304,0)=" Q:'$G(PSOIEN)"
^XMB(3.9,144653,2,305,0)="""RTN"",""PSOERX1F"",33,0)"
^XMB(3.9,144653,2,306,0)=" D FULL^VALM1 I MBMSITE S VALMBCK=""R"""
^XMB(3.9,144653,2,307,0)="""RTN"",""PSOERX1F"",34,0)"
^XMB(3.9,144653,2,308,0)=" I $$DONOTFIL^PSOERXUT(PSOIEN) Q"
^XMB(3.9,144653,2,309,0)="""RTN"",""PSOERX1F"",35,0)"
^XMB(3.9,144653,2,310,0)=" S RXSTAT=$$GET1^DIQ(52.49,PSOIEN,1,""E"")"
^XMB(3.9,144653,2,311,0)="""RTN"",""PSOERX1F"",36,0)"
^XMB(3.9,144653,2,312,0)=" I RXSTAT=""RJ""!(RXSTAT=""RM"")!($E(RXSTAT,1,3)=""REM"")!(RXSTAT=""PR"")!(RXSTAT=""CXP"")!(RXSTAT=""RXP"") D  Q"
^XMB(3.9,144653,2,313,0)="""RTN"",""PSOERX1F"",37,0)"
^XMB(3.9,144653,2,314,0)=" . W !!,""Cannot accept a prescription with a status of 'Rejected', 'Removed',"",!,""or 'Processed"",!"
^XMB(3.9,144653,2,315,0)="""RTN"",""PSOERX1F"",38,0)"
^XMB(3.9,144653,2,316,0)=" . S DIR(0)=""E"" D ^DIR"
^XMB(3.9,144653,2,317,0)="""RTN"",""PSOERX1F"",39,0)"
^XMB(3.9,144653,2,318,0)=" S PSOIENS=PSOIEN_"","""
^XMB(3.9,144653,2,319,0)="""RTN"",""PSOERX1F"",40,0)"
^XMB(3.9,144653,2,320,0)=" D GETS^DIQ(F,PSOIENS,"".01;.05;.07;.08;1;1.3;1.5;1.7;2.1;2.3;3.2;5.9;6.2;6.3;8;20.1;20.2;20.4;20.5;20.6;25;25.2;27;29;29.1;29.2;30;52.1"",""IE"",""PSODAT"")"
^XMB(3.9,144653,2,321,0)="""RTN"",""PSOERX1F"",41,0)"
^XMB(3.9,144653,2,322,0)=" S PSOEXCNT=0"
^XMB(3.9,144653,2,323,0)="""RTN"",""PSOERX1F"",42,0)"
^XMB(3.9,144653,2,324,0)=" S MTYPE=$G(PSODAT(F,PSOIENS,.08,""I""))"
^XMB(3.9,144653,2,325,0)="""RTN"",""PSOERX1F"",43,0)"
^XMB(3.9,144653,2,326,0)=" S RESTYPE=$G(PSODAT(F,PSOIENS,52.1,""I""))"
^XMB(3.9,144653,2,327,0)="""RTN"",""PSOERX1F"",44,0)"
^XMB(3.9,144653,2,328,0)=" I MTYPE=""RE"",RESTYPE'=""R"" D  Q"
^XMB(3.9,144653,2,329,0)="""RTN"",""PSOERX1F"",45,0)"
^XMB(3.9,144653,2,330,0)=" .S REQIEN=$$GETREQ^PSOERXU2(PSOIEN)"
^XMB(3.9,144653,2,331,0)="""RTN"",""PSOERX1F"",46,0)"
^XMB(3.9,144653,2,332,0)=" .I REQIEN S RXIEN=$$GET1^DIQ(52.49,REQIEN,.13,""I"")"
^XMB(3.9,144653,2,333,0)="""RTN"",""PSOERX1F"",47,0)"
^XMB(3.9,144653,2,334,0)=" .D PREFRES^PSOERXU3(PSOIEN,.PSOHY,.PSOEXCNT,.PSOEXMS,.PSODAT)"
^XMB(3.9,144653,2,335,0)="""RTN"",""PSOERX1F"",48,0)"
^XMB(3.9,144653,2,336,0)=" .I $G(PSODAT(F,PSOIENS,2.3,""I"")) S PSOHY(""PROV"")=$G(PSODAT(F,PSOIENS,2.3,""I""))"
^XMB(3.9,144653,2,337,0)="""RTN"",""PSOERX1F"",49,0)"
^XMB(3.9,144653,2,338,0)=" .D RRDELTA^PSOERXU2(.DELTAS,REQIEN,PSOIEN)"
^XMB(3.9,144653,2,339,0)="""RTN"",""PSOERX1F"",50,0)"
^XMB(3.9,144653,2,340,0)=" .I $O(PSOEXMS(0)),RESTYPE=""AWC"",$D(DELTAS(52.49,""EXTERNAL PROVIDER"")) D  Q"
^XMB(3.9,144653,2,341,0)="""RTN"",""PSOERX1F"",51,0)"
^XMB(3.9,144653,2,342,0)=" ..D MSGDIR^PSOERXU1(.PSOEXMS)"
^XMB(3.9,144653,2,343,0)="""RTN"",""PSOERX1F"",52,0)"
^XMB(3.9,144653,2,344,0)=" .I $O(PSOEXMS(0)),$E(RESTYPE)=""A"",'$D(DELTAS(52.49,""EXTERNAL PROVIDER"")) D  Q"
^XMB(3.9,144653,2,345,0)="""RTN"",""PSOERX1F"",53,0)"
^XMB(3.9,144653,2,346,0)=" ..D UPDSTAT^PSOERXU1(PSOIEN,""RXF"",""Unable to add order to Pending file."") Q"
^XMB(3.9,144653,2,347,0)="""RTN"",""PSOERX1F"",54,0)"
^XMB(3.9,144653,2,348,0)=" .I $D(DELTAS(52.49,""EXTERNAL PROVIDER"")) D ADD Q"
^XMB(3.9,144653,2,349,0)="""RTN"",""PSOERX1F"",55,0)"
^XMB(3.9,144653,2,350,0)=" .; call using silent mode if this is auto-processing"
^XMB(3.9,144653,2,351,0)="""RTN"",""PSOERX1F"",56,0)"
^XMB(3.9,144653,2,352,0)=" .D ADD($S($G(PSOCLNC):0,1:1))"
^XMB(3.9,144653,2,353,0)="""RTN"",""PSOERX1F"",57,0)"
^XMB(3.9,144653,2,354,0)=" S ERXSTA=$G(PSODAT(F,PSOIENS,1,""E"")) I ERXSTA=""E""!($E(ERXSTA)=""H"") S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""eRx is in a 'Hold' status."" D MSGDIR^PSOERXU1(.PSOEXMS) Q"
^XMB(3.9,144653,2,355,0)="""RTN"",""PSOERX1F"",58,0)"
^XMB(3.9,144653,2,356,0)=" I MTYPE=""N""!(MTYPE=""RE""&(RESTYPE=""R"")!(MTYPE=""CX"")) D"
^XMB(3.9,144653,2,357,0)="""RTN"",""PSOERX1F"",59,0)"
^XMB(3.9,144653,2,358,0)=" .S PMVAL=$G(PSODAT(F,PSOIENS,1.7,""I"")) I 'PMVAL S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Patient has not been manually validated."""
^XMB(3.9,144653,2,359,0)="""RTN"",""PSOERX1F"",60,0)"
^XMB(3.9,144653,2,360,0)=" .S PRMVAL=$G(PSODAT(F,PSOIENS,1.3,""I"")) I 'PRMVAL S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Provider has not been manually validated."""
^XMB(3.9,144653,2,361,0)="""RTN"",""PSOERX1F"",61,0)"
^XMB(3.9,144653,2,362,0)=" .S DMVAL=$G(PSODAT(F,PSOIENS,1.5,""I"")) I 'DMVAL S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Drug has not been manually validated."""
^XMB(3.9,144653,2,363,0)="""RTN"",""PSOERX1F"",62,0)"
^XMB(3.9,144653,2,364,0)=" ; for now, if validations have not occurred, do not check the other fields."
^XMB(3.9,144653,2,365,0)="""RTN"",""PSOERX1F"",63,0)"
^XMB(3.9,144653,2,366,0)=" I $O(PSOEXMS(0)) D MSGDIR^PSOERXU1(.PSOEXMS) Q"
^XMB(3.9,144653,2,367,0)="""RTN"",""PSOERX1F"",64,0)"
^XMB(3.9,144653,2,368,0)=" ; CS eRx Validations"
^XMB(3.9,144653,2,369,0)="""RTN"",""PSOERX1F"",65,0)"
^XMB(3.9,144653,2,370,0)=" D PRDRVAL^PSOERXUT(.CSERRMSG,""AC"",PSOIEN)"
^XMB(3.9,144653,2,371,0)="""RTN"",""PSOERX1F"",66,0)"
^XMB(3.9,144653,2,372,0)=" I '$G(CSERRMSG),$P(CSERRMSG,""^"",2)=""B"" D MSGDIR^PSOERXU1(.CSERRMSG) Q"
^XMB(3.9,144653,2,373,0)="""RTN"",""PSOERX1F"",67,0)"
^XMB(3.9,144653,2,374,0)=" I $$GET1^DIQ(52.49,PSOIEN,95.1,""I""),'$$VALPTADD^PSOERXUT(+$G(PSODAT(F,PSOIENS,.05,""I""))) D  Q"
^XMB(3.9,144653,2,375,0)="""RTN"",""PSOERX1F"",68,0)"
^XMB(3.9,144653,2,376,0)=" . S CSERRMSG(1)=""Patient does not have a current mailing or residential address on file."""
^XMB(3.9,144653,2,377,0)="""RTN"",""PSOERX1F"",69,0)"
^XMB(3.9,144653,2,378,0)=" . D MSGDIR^PSOERXU1(.CSERRMSG)"
^XMB(3.9,144653,2,379,0)="""RTN"",""PSOERX1F"",70,0)"
^XMB(3.9,144653,2,380,0)=" ;"
^XMB(3.9,144653,2,381,0)="""RTN"",""PSOERX1F"",71,0)"
^XMB(3.9,144653,2,382,0)=" S POORD=$G(PSODAT(F,PSOIENS,25.2,""I"")) I POORD S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Pending outpatient order already exists."""
^XMB(3.9,144653,2,383,0)="""RTN"",""PSOERX1F"",72,0)"
^XMB(3.9,144653,2,384,0)=" S PATIEN=$G(PSODAT(F,PSOIENS,.05,""I"")) I 'PATIEN S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""No matched vista patient."""
^XMB(3.9,144653,2,385,0)="""RTN"",""PSOERX1F"",73,0)"
^XMB(3.9,144653,2,386,0)=" S PROVIEN=$G(PSODAT(F,PSOIENS,2.3,""I"")) I 'PROVIEN S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Provider not matched to a vista provider."""
^XMB(3.9,144653,2,387,0)="""RTN"",""PSOERX1F"",74,0)"
^XMB(3.9,144653,2,388,0)=" S VADRUG=$G(PSODAT(F,PSOIENS,3.2,""I"")) I 'VADRUG S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Drug not matched to a vista drug."""
^XMB(3.9,144653,2,389,0)="""RTN"",""PSOERX1F"",75,0)"
^XMB(3.9,144653,2,390,0)=" S ERXNUM=$G(PSODAT(F,PSOIENS,.01,""E"")) I 'ERXNUM S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""eRx number missing."""
^XMB(3.9,144653,2,391,0)="""RTN"",""PSOERX1F"",76,0)"
^XMB(3.9,144653,2,392,0)=" S VQTY=$G(PSODAT(F,PSOIENS,20.1,""E"")) I 'VQTY S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Quantity missing."""
^XMB(3.9,144653,2,393,0)="""RTN"",""PSOERX1F"",77,0)"
^XMB(3.9,144653,2,394,0)=" S EFFDT=$G(PSODAT(F,PSOIENS,6.3,""I"")),WRITDT=$G(PSODAT(F,PSOIENS,5.9,""I""))"
^XMB(3.9,144653,2,395,0)="""RTN"",""PSOERX1F"",78,0)"
^XMB(3.9,144653,2,396,0)=" S LOC=$G(PSODAT(F,PSOIENS,20.6,""I"")) I 'LOC S LOC=$$GET1^DIQ(59,PSOSITE,10,""I"")"
^XMB(3.9,144653,2,397,0)="""RTN"",""PSOERX1F"",79,0)"
^XMB(3.9,144653,2,398,0)=" ; if the effective date is passed in and there is no time, add .000001 to the date"
^XMB(3.9,144653,2,399,0)="""RTN"",""PSOERX1F"",80,0)"
^XMB(3.9,144653,2,400,0)=" I EFFDT]"""" S EFFDT=$P(EFFDT,""."")"
^XMB(3.9,144653,2,401,0)="""RTN"",""PSOERX1F"",81,0)"
^XMB(3.9,144653,2,402,0)=" I '$L(EFFDT) S EFFDT=WRITDT"
^XMB(3.9,144653,2,403,0)="""RTN"",""PSOERX1F"",82,0)"
^XMB(3.9,144653,2,404,0)=" S VADAYS=$G(PSODAT(F,PSOIENS,20.2,""E""))"
^XMB(3.9,144653,2,405,0)="""RTN"",""PSOERX1F"",83,0)"
^XMB(3.9,144653,2,406,0)=" S VAOI=$$GET1^DIQ(50,VADRUG,2.1,""I"") I 'VAOI S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Orderable item not associated with drug."""
^XMB(3.9,144653,2,407,0)="""RTN"",""PSOERX1F"",84,0)"
^XMB(3.9,144653,2,408,0)=" S VAREF=$G(PSODAT(F,PSOIENS,20.5,""E""))"
^XMB(3.9,144653,2,409,0)="""RTN"",""PSOERX1F"",85,0)"
^XMB(3.9,144653,2,410,0)=" S VAROUT=$G(PSODAT(F,PSOIENS,20.4,""I"")) I '$L(VAROUT) S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Pickup routing missing."""
^XMB(3.9,144653,2,411,0)="""RTN"",""PSOERX1F"",86,0)"
^XMB(3.9,144653,2,412,0)=" S PATINST=$G(PSODAT(F,PSOIENS,27,""E""))"
^XMB(3.9,144653,2,413,0)="""RTN"",""PSOERX1F"",87,0)"
^XMB(3.9,144653,2,414,0)=" ; CALL TO AVOID SPACE CONCATENATION"
^XMB(3.9,144653,2,415,0)="""RTN"",""PSOERX1F"",88,0)"
^XMB(3.9,144653,2,416,0)=" D TXT2ARY^PSOERXD1(.PINARY,$$LSIG^PSOERXU6(PATINST))"
^XMB(3.9,144653,2,417,0)="""RTN"",""PSOERX1F"",89,0)"
^XMB(3.9,144653,2,418,0)=" ; get provider comments from VA PROVIDER COMMENTS field"
^XMB(3.9,144653,2,419,0)="""RTN"",""PSOERX1F"",90,0)"
^XMB(3.9,144653,2,420,0)=" S PRVCOMM=$G(PSODAT(F,PSOIENS,30,""E""))"
^XMB(3.9,144653,2,421,0)="""RTN"",""PSOERX1F"",91,0)"
^XMB(3.9,144653,2,422,0)=" D TXT2ARY^PSOERXD1(.PRVARY,$$LSIG^PSOERXU6(PRVCOMM))"
^XMB(3.9,144653,2,423,0)="""RTN"",""PSOERX1F"",92,0)"
^XMB(3.9,144653,2,424,0)=" S (PLOOP,PCNT)=0 F  S PLOOP=$O(PRVARY(PLOOP)) Q:'PLOOP  D"
^XMB(3.9,144653,2,425,0)="""RTN"",""PSOERX1F"",93,0)"
^XMB(3.9,144653,2,426,0)=" .S PCNT=PCNT+1,PSOHY(""PRCOM"",PCNT)=$G(PRVARY(PLOOP))"
^XMB(3.9,144653,2,427,0)="""RTN"",""PSOERX1F"",94,0)"
^XMB(3.9,144653,2,428,0)=" I '$O(^PS(52.49,PSOIEN,21,0)) S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Dosing information missing."""
^XMB(3.9,144653,2,429,0)="""RTN"",""PSOERX1F"",95,0)"
^XMB(3.9,144653,2,430,0)=" S (QTLOOP,QTCNT)=0 F  S QTLOOP=$O(^PS(52.49,PSOIEN,21,QTLOOP)) Q:'QTLOOP  D"
^XMB(3.9,144653,2,431,0)="""RTN"",""PSOERX1F"",96,0)"
^XMB(3.9,144653,2,432,0)=" .S QTCNT=QTCNT+1 M PSOHY(""QTSUB"",QTCNT)=^PS(52.49,PSOIEN,21,QTLOOP)"
^XMB(3.9,144653,2,433,0)="""RTN"",""PSOERX1F"",97,0)"
^XMB(3.9,144653,2,434,0)=" ;"
^XMB(3.9,144653,2,435,0)="""RTN"",""PSOERX1F"",98,0)"
^XMB(3.9,144653,2,436,0)=" ; Assigning Clinic which the User is logged into"
^XMB(3.9,144653,2,437,0)="""RTN"",""PSOERX1F"",99,0)"
^XMB(3.9,144653,2,438,0)=" S (LOC,PSOQUIT)=0"
^XMB(3.9,144653,2,439,0)="""RTN"",""PSOERX1F"",100,0)"
^XMB(3.9,144653,2,440,0)=" I $G(MBMSITE),DUZ'=+$$PROXYDUZ^PSOERXUT(),+$$GET1^DIQ(52.49,PSOIEN,20.6,""I"")'=+$G(PSOCLNC) D  I $G(PSOQUIT) S DIR(0)=""E"" D ^DIR K DIR Q"
^XMB(3.9,144653,2,441,0)="""RTN"",""PSOERX1F"",101,0)"
^XMB(3.9,144653,2,442,0)=" . W !!,""Current Clinic assigned to the eRx: "",$$GET1^DIQ(52.49,PSOIEN,20.6),!"
^XMB(3.9,144653,2,443,0)="""RTN"",""PSOERX1F"",102,0)"
^XMB(3.9,144653,2,444,0)=" . K DIC S DIC(0)=""AEMQ"",DIC=44,DIC(""S"")=""I '$P($G(^(""""I"""")),U,1)!$P($G(^(""""I"""")),U,2)"""
^XMB(3.9,144653,2,445,0)="""RTN"",""PSOERX1F"",103,0)"
^XMB(3.9,144653,2,446,0)=" . S DIC(""A"")=""Send to eRx Clinic: """
^XMB(3.9,144653,2,447,0)="""RTN"",""PSOERX1F"",104,0)"
^XMB(3.9,144653,2,448,0)=" . I $G(PSOCLNC) S DIC(""B"")=$$GET1^DIQ(44,PSOCLNC,.01)"
^XMB(3.9,144653,2,449,0)="""RTN"",""PSOERX1F"",105,0)"
^XMB(3.9,144653,2,450,0)=" . D ^DIC I Y=""^""!$D(DTOUT)!$D(DUOUT) S PSOQUIT=1 Q"
^XMB(3.9,144653,2,451,0)="""RTN"",""PSOERX1F"",106,0)"
^XMB(3.9,144653,2,452,0)=" . I $G(Y)>0 S LOC=+Y"
^XMB(3.9,144653,2,453,0)="""RTN"",""PSOERX1F"",107,0)"
^XMB(3.9,144653,2,454,0)=" ; always 'routine' for now"
^XMB(3.9,144653,2,455,0)="""RTN"",""PSOERX1F"",108,0)"
^XMB(3.9,144653,2,456,0)=" S VAPRIOR=""R"""
^XMB(3.9,144653,2,457,0)="""RTN"",""PSOERX1F"",109,0)"
^XMB(3.9,144653,2,458,0)=" ; always 'new' for this version"
^XMB(3.9,144653,2,459,0)="""RTN"",""PSOERX1F"",110,0)"
^XMB(3.9,144653,2,460,0)=" I '$L($G(ORDERTYP)) S ORDERTYP=""NW"""
^XMB(3.9,144653,2,461,0)="""RTN"",""PSOERX1F"",111,0)"
^XMB(3.9,144653,2,462,0)=" I $G(LOC) S PSOHY(""LOC"")=LOC"
^XMB(3.9,144653,2,463,0)="""RTN"",""PSOERX1F"",112,0)"
^XMB(3.9,144653,2,464,0)=" I '$G(PSOHY(""LOC"")) D"
^XMB(3.9,144653,2,465,0)="""RTN"",""PSOERX1F"",113,0)"
^XMB(3.9,144653,2,466,0)=" . I $G(PSOCLNC) D"
^XMB(3.9,144653,2,467,0)="""RTN"",""PSOERX1F"",114,0)"
^XMB(3.9,144653,2,468,0)=" . . S PSOHY(""LOC"")=PSOCLNC"
^XMB(3.9,144653,2,469,0)="""RTN"",""PSOERX1F"",115,0)"
^XMB(3.9,144653,2,470,0)=" . E  S PSOHY(""LOC"")=+$$GET1^DIQ(59,+$G(PSOSITE),10,""I"")"
^XMB(3.9,144653,2,471,0)="""RTN"",""PSOERX1F"",116,0)"
^XMB(3.9,144653,2,472,0)=" S PSOHY(""CHNUM"")=$G(ERXNUM)"
^XMB(3.9,144653,2,473,0)="""RTN"",""PSOERX1F"",117,0)"
^XMB(3.9,144653,2,474,0)=" S PSOHY(""PICK"")=VAROUT"
^XMB(3.9,144653,2,475,0)="""RTN"",""PSOERX1F"",118,0)"
^XMB(3.9,144653,2,476,0)=" S PSOHY(""ENTER"")=DUZ"
^XMB(3.9,144653,2,477,0)="""RTN"",""PSOERX1F"",119,0)"
^XMB(3.9,144653,2,478,0)=" S PSOHY(""PROV"")=PROVIEN,PSOHY(""SDT"")=EFFDT"
^XMB(3.9,144653,2,479,0)="""RTN"",""PSOERX1F"",120,0)"
^XMB(3.9,144653,2,480,0)=" S PSOHY(""ITEM"")=VAOI,PSOHY(""DRUG"")=VADRUG"
^XMB(3.9,144653,2,481,0)="""RTN"",""PSOERX1F"",121,0)"
^XMB(3.9,144653,2,482,0)=" S PSOHY(""QTY"")=VQTY,PSOHY(""REF"")=VAREF"
^XMB(3.9,144653,2,483,0)="""RTN"",""PSOERX1F"",122,0)"
^XMB(3.9,144653,2,484,0)=" S (PSOHY(""PAT""),DFN)=PATIEN,PSOHY(""OCC"")=ORDERTYP"
^XMB(3.9,144653,2,485,0)="""RTN"",""PSOERX1F"",123,0)"
^XMB(3.9,144653,2,486,0)=" ; Login date will always be the Message Received Date/Time"
^XMB(3.9,144653,2,487,0)="""RTN"",""PSOERX1F"",124,0)"
^XMB(3.9,144653,2,488,0)=" S PSOHY(""EDT"")=$$GET1^DIQ(52.49,PSOIEN,.03,""I""),PSOHY(""PRIOR"")=VAPRIOR"
^XMB(3.9,144653,2,489,0)="""RTN"",""PSOERX1F"",125,0)"
^XMB(3.9,144653,2,490,0)=" ; ALWAYS PSO as the external application"
^XMB(3.9,144653,2,491,0)="""RTN"",""PSOERX1F"",126,0)"
^XMB(3.9,144653,2,492,0)=" S PSOHY(""EXAPP"")=""PHARMACY"""
^XMB(3.9,144653,2,493,0)="""RTN"",""PSOERX1F"",127,0)"
^XMB(3.9,144653,2,494,0)=" S PSOHY(""DAYS"")=VADAYS"
^XMB(3.9,144653,2,495,0)="""RTN"",""PSOERX1F"",128,0)"
^XMB(3.9,144653,2,496,0)=" ; sig from eRx"
^XMB(3.9,144653,2,497,0)="""RTN"",""PSOERX1F"",129,0)"
^XMB(3.9,144653,2,498,0)=" S (SLOOP,SCNT)=0 F  S SLOOP=$O(^PS(52.49,PSOIEN,""SIG"",SLOOP)) Q:'SLOOP  D"
^XMB(3.9,144653,2,499,0)="""RTN"",""PSOERX1F"",130,0)"
^XMB(3.9,144653,2,500,0)=" .S SIGDAT=$G(^PS(52.49,PSOIEN,""SIG"",SLOOP,0))"
^XMB(3.9,144653,2,501,0)="""RTN"",""PSOERX1F"",131,0)"
^XMB(3.9,144653,2,502,0)=" .S SCNT=SCNT+1,PSOHY(""SIG"",SCNT)=SIGDAT"
^XMB(3.9,144653,2,503,0)="""RTN"",""PSOERX1F"",132,0)"
^XMB(3.9,144653,2,504,0)=" ;indications for use from erx, concatenate it to the sig if set to 1"
^XMB(3.9,144653,2,505,0)="""RTN"",""PSOERX1F"",133,0)"
^XMB(3.9,144653,2,506,0)=" S (PAINDFU,PSOHY(""IND""))=$G(PSODAT(F,PSOIENS,29,""E"")) ;patient indications for use"
^XMB(3.9,144653,2,507,0)="""RTN"",""PSOERX1F"",134,0)"
^XMB(3.9,144653,2,508,0)=" S PSOHY(""INDO"")=$G(PSODAT(F,PSOIENS,29.2,""E""))"
^XMB(3.9,144653,2,509,0)="""RTN"",""PSOERX1F"",135,0)"
^XMB(3.9,144653,2,510,0)=" D TXT2ARY^PSOERXD1(.INDARY,$$LSIG^PSOERXU6(PAINDFU)) ;patient indications for use"
^XMB(3.9,144653,2,511,0)="""RTN"",""PSOERX1F"",136,0)"
^XMB(3.9,144653,2,512,0)=" I +$G(PSODAT(F,PSOIENS,29.1,""I"")) D"
^XMB(3.9,144653,2,513,0)="""RTN"",""PSOERX1F"",137,0)"
^XMB(3.9,144653,2,514,0)=" . S SLOOP3=0 F  S SLOOP3=$O(INDARY(SLOOP3)) Q:'SLOOP3  D"
^XMB(3.9,144653,2,515,0)="""RTN"",""PSOERX1F"",138,0)"
^XMB(3.9,144653,2,516,0)=" . . S SCNT=SCNT+1,PSOHY(""SIG"",SCNT)=$G(INDARY(SLOOP3))"
^XMB(3.9,144653,2,517,0)="""RTN"",""PSOERX1F"",139,0)"
^XMB(3.9,144653,2,518,0)=" ;patient instructions"
^XMB(3.9,144653,2,519,0)="""RTN"",""PSOERX1F"",140,0)"
^XMB(3.9,144653,2,520,0)=" S SLOOP2=0 F  S SLOOP2=$O(PINARY(SLOOP2)) Q:'SLOOP2  D"
^XMB(3.9,144653,2,521,0)="""RTN"",""PSOERX1F"",141,0)"
^XMB(3.9,144653,2,522,0)=" .S SCNT=SCNT+1,PSOHY(""SIG"",SCNT)=$G(PINARY(SLOOP2))"
^XMB(3.9,144653,2,523,0)="""RTN"",""PSOERX1F"",142,0)"
^XMB(3.9,144653,2,524,0)=" ; if provider, patient or drug is missing, no need to continue."
^XMB(3.9,144653,2,525,0)="""RTN"",""PSOERX1F"",143,0)"
^XMB(3.9,144653,2,526,0)=" D ADD"
^XMB(3.9,144653,2,527,0)="""RTN"",""PSOERX1F"",144,0)"
^XMB(3.9,144653,2,528,0)=" I $G(PSOEXMS)]"""" W !,PSOEXMS S DIR(0)=""E"" D ^DIR K DIR Q"
^XMB(3.9,144653,2,529,0)="""RTN"",""PSOERX1F"",145,0)"
^XMB(3.9,144653,2,530,0)=" D REF^PSOERSE1"
^XMB(3.9,144653,2,531,0)="""RTN"",""PSOERX1F"",146,0)"
^XMB(3.9,144653,2,532,0)=" K DFN"
^XMB(3.9,144653,2,533,0)="""RTN"",""PSOERX1F"",147,0)"
^XMB(3.9,144653,2,534,0)=" Q"
^XMB(3.9,144653,2,535,0)="""RTN"",""PSOERX1F"",148,0)"
^XMB(3.9,144653,2,536,0)="ADD(QUIET) ;Add CHCS message to Outpatient Pending Orders file"
^XMB(3.9,144653,2,537,0)="""RTN"",""PSOERX1F"",149,0)"
^XMB(3.9,144653,2,538,0)=" N MBMSITE,PSOHQ,PSOHQT,PSOCPEND,PSOHINI,PSOHINLO,ERXSTA,ORDNUM,ILOOP,IARY,PSSRET,DA,PSORDEA,PSORDFDA,PSORDNUM"
^XMB(3.9,144653,2,539,0)="""RTN"",""PSOERX1F"",150,0)"
^XMB(3.9,144653,2,540,0)=" S MBMSITE=$S($$GET1^DIQ(59.7,1,102,""I"")=""MBM"":1,1:0)"
^XMB(3.9,144653,2,541,0)="""RTN"",""PSOERX1F"",151,0)"
^XMB(3.9,144653,2,542,0)=" I '$G(PSOHY(""DRUG"")) D  Q"
^XMB(3.9,144653,2,543,0)="""RTN"",""PSOERX1F"",152,0)"
^XMB(3.9,144653,2,544,0)=" . S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Invalid Dispense Drug"" Q"
^XMB(3.9,144653,2,545,0)="""RTN"",""PSOERX1F"",153,0)"
^XMB(3.9,144653,2,546,0)=" S (PSOHINI,PSOHINLO)=0 D"
^XMB(3.9,144653,2,547,0)="""RTN"",""PSOERX1F"",154,0)"
^XMB(3.9,144653,2,548,0)=" . I $G(PSOHY(""LOC"")) S PSOHINLO=$P($G(^SC(PSOHY(""LOC""),0)),""^"",4)"
^XMB(3.9,144653,2,549,0)="""RTN"",""PSOERX1F"",155,0)"
^XMB(3.9,144653,2,550,0)=" ; get institution from 52.49 if clinic was not passed in"
^XMB(3.9,144653,2,551,0)="""RTN"",""PSOERX1F"",156,0)"
^XMB(3.9,144653,2,552,0)=" S RESTYPE=$$GET1^DIQ(52.49,PSOIEN,52.1,""I"")"
^XMB(3.9,144653,2,553,0)="""RTN"",""PSOERX1F"",157,0)"
^XMB(3.9,144653,2,554,0)=" I $G(PSOHINLO)<1 S PSOHINLO=$$GET1^DIQ(52.49,PSOIEN,24.1,""I"")"
^XMB(3.9,144653,2,555,0)="""RTN"",""PSOERX1F"",158,0)"
^XMB(3.9,144653,2,556,0)=" I +$G(PSOHINLO)<1 S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Unable to derive Institution from Clinic."" Q"
^XMB(3.9,144653,2,557,0)="""RTN"",""PSOERX1F"",159,0)"
^XMB(3.9,144653,2,558,0)=" K DD,DO,DIC S X=PSOHY(""CHNUM""),DIC=""^PS(52.41,"",DIC(0)=""L"""
^XMB(3.9,144653,2,559,0)="""RTN"",""PSOERX1F"",160,0)"
^XMB(3.9,144653,2,560,0)=" S:$G(PSOHY(""PICK""))="""" PSOHY(""PICK"")=""M"""
^XMB(3.9,144653,2,561,0)="""RTN"",""PSOERX1F"",161,0)"
^XMB(3.9,144653,2,562,0)=" S DIC(""DR"")=""4////""_$G(PSOHY(""ENTER""))_"";5////""_PSOHY(""PROV"")_"";6////""_$G(PSOHY(""SDT""))_"";8////""_PSOHY(""ITEM"")_"";11////""_PSOHY(""DRUG"")"
^XMB(3.9,144653,2,563,0)="""RTN"",""PSOERX1F"",162,0)"
^XMB(3.9,144653,2,564,0)=" S DIC(""DR"")=$G(DIC(""DR""))_"";12////""_$G(PSOHY(""QTY""))_"";13////""_$G(PSOHY(""REF""))_"";22.1////""_$G(PSOHY(""PREVORD""))_"";101////""_$G(PSOHY(""DAYS""))"
^XMB(3.9,144653,2,565,0)="""RTN"",""PSOERX1F"",163,0)"
^XMB(3.9,144653,2,566,0)=" D FILE^DICN K DD,DIC,DO I Y<0 D  Q"
^XMB(3.9,144653,2,567,0)="""RTN"",""PSOERX1F"",164,0)"
^XMB(3.9,144653,2,568,0)=" .S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Unable to add order to Pending file."""
^XMB(3.9,144653,2,569,0)="""RTN"",""PSOERX1F"",165,0)"
^XMB(3.9,144653,2,570,0)=" .I MTYPE=""RE"" D UPDSTAT^PSOERXU1(PSOIEN,""RXF"",PSOEXMS(PSOEXCNT))"
^XMB(3.9,144653,2,571,0)="""RTN"",""PSOERX1F"",166,0)"
^XMB(3.9,144653,2,572,0)=" .S REQIEN=$$GETREQ^PSOERXU2(PSOIEN) I REQIEN D UPDSTAT^PSOERXU1(PSOIEN,""RRF"",PSOEXMS)"
^XMB(3.9,144653,2,573,0)="""RTN"",""PSOERX1F"",167,0)"
^XMB(3.9,144653,2,574,0)=" S PSOCPEND=+Y"
^XMB(3.9,144653,2,575,0)="""RTN"",""PSOERX1F"",168,0)"
^XMB(3.9,144653,2,576,0)=" S $P(^PS(52.41,PSOCPEND,0),""^"",2)=PSOHY(""PAT""),$P(^(0),""^"",3)=PSOHY(""OCC""),$P(^(0),""^"",12)=$G(PSOHY(""EDT"")),$P(^(0),""^"",13)=$G(PSOHY(""LOC""))"
^XMB(3.9,144653,2,577,0)="""RTN"",""PSOERX1F"",169,0)"
^XMB(3.9,144653,2,578,0)=" S $P(^PS(52.41,PSOCPEND,0),""^"",14)=$G(PSOHY(""PRIOR"")),$P(^(0),""^"",17)=$G(PSOHY(""PICK""))"
^XMB(3.9,144653,2,579,0)="""RTN"",""PSOERX1F"",170,0)"
^XMB(3.9,144653,2,580,0)=" S $P(^PS(52.41,PSOCPEND,""EXT""),""^"")=PSOHY(""CHNUM""),$P(^(""EXT""),""^"",2)=0,$P(^(""EXT""),""^"",3)=PSOHY(""EXAPP"")"
^XMB(3.9,144653,2,581,0)="""RTN"",""PSOERX1F"",171,0)"
^XMB(3.9,144653,2,582,0)=" S DIE=""^PS(52.41,"",DA=PSOCPEND,DR=""104.1///1"" D ^DIE K DIE,DA,DR"
^XMB(3.9,144653,2,583,0)="""RTN"",""PSOERX1F"",172,0)"
^XMB(3.9,144653,2,584,0)=" ; PSO*7*506"
^XMB(3.9,144653,2,585,0)="""RTN"",""PSOERX1F"",173,0)"
^XMB(3.9,144653,2,586,0)=" S FDA(52.41,PSOCPEND_"","",104)=$G(PATINST) D FILE^DIE(,""FDA"") K FDA"
^XMB(3.9,144653,2,587,0)="""RTN"",""PSOERX1F"",174,0)"
^XMB(3.9,144653,2,588,0)=" N DA,DIK S DA=PSOCPEND,DIK=""^PS(52.41,"",DIK(1)=""114^C"" D EN1^DIK"
^XMB(3.9,144653,2,589,0)="""RTN"",""PSOERX1F"",175,0)"
^XMB(3.9,144653,2,590,0)=" I $O(PSOHY(""PRCOM"",0)) D  I PSOHQT S ^PS(52.41,PSOCPEND,3,0)=""^^""_PSOHQT_""^""_PSOHQT_""^""_DT_""^"""
^XMB(3.9,144653,2,591,0)="""RTN"",""PSOERX1F"",176,0)"
^XMB(3.9,144653,2,592,0)=" .S PSOHQ="""",PSOHQT=0 F  S PSOHQ=$O(PSOHY(""PRCOM"",PSOHQ)) Q:PSOHQ=""""  I $G(PSOHY(""PRCOM"",PSOHQ))'="""" S PSOHQT=PSOHQT+1,^PS(52.41,PSOCPEND,3,PSOHQT,0)=$G(PSOHY(""PRCOM"",PSOHQ))"
^XMB(3.9,144653,2,593,0)="""RTN"",""PSOERX1F"",177,0)"
^XMB(3.9,144653,2,594,0)=" S $P(^PS(52.41,PSOCPEND,4),""^"",2,3)=$G(PSOHY(""IND""))_""^""_$G(PSOHY(""INDO"")) ;indication for use and other language indication for use"
^XMB(3.9,144653,2,595,0)="""RTN"",""PSOERX1F"",178,0)"
^XMB(3.9,144653,2,596,0)=" I $O(PSOHY(""SIG"",0)) D  I PSOHQT S ^PS(52.41,PSOCPEND,""SIG"",0)=""^52.4124A^""_PSOHQT_""^""_PSOHQT"
^XMB(3.9,144653,2,597,0)="""RTN"",""PSOERX1F"",179,0)"
^XMB(3.9,144653,2,598,0)=" .S PSOHQ="""",PSOHQT=0 F  S PSOHQ=$O(PSOHY(""SIG"",PSOHQ)) Q:PSOHQ=""""  I $G(PSOHY(""SIG"",PSOHQ))'="""" S PSOHQT=PSOHQT+1,^PS(52.41,PSOCPEND,""SIG"",PSOHQT,0)=$G(PSOHY(""SIG"",PSOHQ))"
^XMB(3.9,144653,2,599,0)="""RTN"",""PSOERX1F"",180,0)"
^XMB(3.9,144653,2,600,0)=" S $P(^PS(52.41,PSOCPEND,""INI""),""^"")=$G(PSOHINLO)"
^XMB(3.9,144653,2,601,0)="""RTN"",""PSOERX1F"",181,0)"
^XMB(3.9,144653,2,602,0)=" ; add quantity/timing subfile information"
^XMB(3.9,144653,2,603,0)="""RTN"",""PSOERX1F"",182,0)"
^XMB(3.9,144653,2,604,0)=" I $O(PSOHY(""QTSUB"",0)) D  I PSOHQT S ^PS(52.41,PSOCPEND,1,0)=""^52.413^""_PSOHQT_""^""_PSOHQT"
^XMB(3.9,144653,2,605,0)="""RTN"",""PSOERX1F"",183,0)"
^XMB(3.9,144653,2,606,0)=" .S PSOHQ="""",PSOHQT=0 F  S PSOHQ=$O(PSOHY(""QTSUB"",PSOHQ)) Q:PSOHQ=""""  D"
^XMB(3.9,144653,2,607,0)="""RTN"",""PSOERX1F"",184,0)"
^XMB(3.9,144653,2,608,0)=" ..I $O(PSOHY(""QTSUB"",PSOHQ,0)) S PSOHQT=PSOHQT+1"
^XMB(3.9,144653,2,609,0)="""RTN"",""PSOERX1F"",185,0)"
^XMB(3.9,144653,2,610,0)=" ..S ^PS(52.41,PSOCPEND,1,PSOHQT,0)=PSOHY(""QTSUB"",PSOHQ,0)"
^XMB(3.9,144653,2,611,0)="""RTN"",""PSOERX1F"",186,0)"
^XMB(3.9,144653,2,612,0)=" ..S ^PS(52.41,PSOCPEND,1,PSOHQT,1)=PSOHY(""QTSUB"",PSOHQ,1)"
^XMB(3.9,144653,2,613,0)="""RTN"",""PSOERX1F"",187,0)"
^XMB(3.9,144653,2,614,0)=" ..S ^PS(52.41,PSOCPEND,1,PSOHQT,2)=PSOHY(""QTSUB"",PSOHQ,2)"
^XMB(3.9,144653,2,615,0)="""RTN"",""PSOERX1F"",188,0)"
^XMB(3.9,144653,2,616,0)=" I $O(PINARY(0)) D WP^DIE(52.41,PSOCPEND_"","",105,""K"",""PINARY"")"
^XMB(3.9,144653,2,617,0)="""RTN"",""PSOERX1F"",189,0)"
^XMB(3.9,144653,2,618,0)=" ;Cross references not set yet preventing Pharmacy from finishing order"
^XMB(3.9,144653,2,619,0)="""RTN"",""PSOERX1F"",190,0)"
^XMB(3.9,144653,2,620,0)=" D EN^PSOHLSNC(PSOCPEND,""SN"",""IP"")"
^XMB(3.9,144653,2,621,0)="""RTN"",""PSOERX1F"",191,0)"
^XMB(3.9,144653,2,622,0)=" D FULL^VALM1"
^XMB(3.9,144653,2,623,0)="""RTN"",""PSOERX1F"",192,0)"
^XMB(3.9,144653,2,624,0)=" S PSORDNUM=$P($G(^PS(52.41,PSOCPEND,0)),U)"
^XMB(3.9,144653,2,625,0)="""RTN"",""PSOERX1F"",193,0)"
^XMB(3.9,144653,2,626,0)=" S PSORDEA=$$FIND1^DIC(101.52,"""",""B"",PSORDNUM)"
^XMB(3.9,144653,2,627,0)="""RTN"",""PSOERX1F"",194,0)"
^XMB(3.9,144653,2,628,0)=" I $E($$GET1^DIQ(101.52,PSORDEA,1,""I""),*)'=""S"" S PSORDEA="""""
^XMB(3.9,144653,2,629,0)="""RTN"",""PSOERX1F"",195,0)"
^XMB(3.9,144653,2,630,0)=" I PSORDEA S PSORDFDA(101.52,PSORDEA_"","",1)=""@"" D FILE^DIE(""K"",""PSORDFDA"")"
^XMB(3.9,144653,2,631,0)="""RTN"",""PSOERX1F"",196,0)"
^XMB(3.9,144653,2,632,0)=" ;"
^XMB(3.9,144653,2,633,0)="""RTN"",""PSOERX1F"",197,0)"
^XMB(3.9,144653,2,634,0)=" ;Just set to DC, don't delete because 52.41 entry would be re-used"
^XMB(3.9,144653,2,635,0)="""RTN"",""PSOERX1F"",198,0)"
^XMB(3.9,144653,2,636,0)=" I '$P($G(^PS(52.41,PSOCPEND,""EXT"")),""^"",2) D  S $P(^PS(52.41,PSOCPEND,0),""^"",3)=""DC"" S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""Unable to send CHCS order to CPRS."" Q"
^XMB(3.9,144653,2,637,0)="""RTN"",""PSOERX1F"",199,0)"
^XMB(3.9,144653,2,638,0)=" .;x-ref shouldn't be set, but we'll kill them just in case"
^XMB(3.9,144653,2,639,0)="""RTN"",""PSOERX1F"",200,0)"
^XMB(3.9,144653,2,640,0)=" .K ^PS(52.41,""AOR"",$P(^PS(52.41,PSOCPEND,0),""^"",2),+$P($G(^(""INI"")),""^""),PSOCPEND),^PS(52.41,""AD"",$P(^PS(52.41,PSOCPEND,0),""^"",12),+$P($G(^(""INI"")),""^""),PSOCPEND)"
^XMB(3.9,144653,2,641,0)="""RTN"",""PSOERX1F"",201,0)"
^XMB(3.9,144653,2,642,0)=" .K ^PS(52.41,""ACL"",+$P(^PS(52.41,PSOCPEND,0),""^"",13),$P(^(0),""^"",12),PSOCPEND),^PS(52.41,""AQ"",+$P($G(^PS(52.41,PSOCPEND,0)),""^"",21),PSOCPEND)"
^XMB(3.9,144653,2,643,0)="""RTN"",""PSOERX1F"",202,0)"
^XMB(3.9,144653,2,644,0)=" .S $P(^PS(52.41,PSOCPEND,4),""^"")=""External order, unable to successfully transmit to CPRS."""
^XMB(3.9,144653,2,645,0)="""RTN"",""PSOERX1F"",203,0)"
^XMB(3.9,144653,2,646,0)=" .I $D(QUIET) S PSOEXCNT=PSOEXCNT+1,PSOEXMS(PSOEXCNT)=""External order, unable to successfully transmit to CPRS."""
^XMB(3.9,144653,2,647,0)="""RTN"",""PSOERX1F"",204,0)"
^XMB(3.9,144653,2,648,0)=" .I '$D(QUIET) W !!,""External order, unable to successfully transmit to CPRS."""
^XMB(3.9,144653,2,649,0)="""RTN"",""PSOERX1F"",205,0)"
^XMB(3.9,144653,2,650,0)=" .I '$D(QUIET) S DIR(0)=""E"" D ^DIR"
^XMB(3.9,144653,2,651,0)="""RTN"",""PSOERX1F"",206,0)"
^XMB(3.9,144653,2,652,0)=" ;Successful transmission to CPRS"
^XMB(3.9,144653,2,653,0)="""RTN"",""PSOERX1F"",207,0)"
^XMB(3.9,144653,2,654,0)=" S DA=PSOCPEND,DIK=""^PS(52.41,"" D IX^DIK"
^XMB(3.9,144653,2,655,0)="""RTN"",""PSOERX1F"",208,0)"
^XMB(3.9,144653,2,656,0)=" ; add the pending outpatient order number to 52.49 and update status of eRx to PR (Processed)"
^XMB(3.9,144653,2,657,0)="""RTN"",""PSOERX1F"",209,0)"
^XMB(3.9,144653,2,658,0)=" S ERXSTA=$O(^PS(52.45,""C"",""ERX"",""PR"",0))"
^XMB(3.9,144653,2,659,0)="""RTN"",""PSOERX1F"",210,0)"
^XMB(3.9,144653,2,660,0)=" S ORDNUM=$P($G(^PS(52.41,PSOCPEND,0)),U)"
^XMB(3.9,144653,2,661,0)="""RTN"",""PSOERX1F"",211,0)"
^XMB(3.9,144653,2,662,0)=" S DIE=""^PS(52.49,"",DR=""25.2///""_PSOCPEND_"";.12///""_ORDNUM,DA=PSOIEN D ^DIE K DIE,DA,DR"
^XMB(3.9,144653,2,663,0)="""RTN"",""PSOERX1F"",212,0)"
^XMB(3.9,144653,2,664,0)=" ; PSO*7*508 - add checks to update refill requests and responses"
^XMB(3.9,144653,2,665,0)="""RTN"",""PSOERX1F"",213,0)"
^XMB(3.9,144653,2,666,0)=" ; add activity to status history"
^XMB(3.9,144653,2,667,0)="""RTN"",""PSOERX1F"",214,0)"
^XMB(3.9,144653,2,668,0)=" I MTYPE=""N"" D UPDSTAT^PSOERXU1(PSOIEN,""PR"")"
^XMB(3.9,144653,2,669,0)="""RTN"",""PSOERX1F"",215,0)"
^XMB(3.9,144653,2,670,0)=" I MTYPE=""RE"" D UPDSTAT^PSOERXU1(PSOIEN,""RXP"")"
^XMB(3.9,144653,2,671,0)="""RTN"",""PSOERX1F"",216,0)"
^XMB(3.9,144653,2,672,0)=" ;B3S4"
^XMB(3.9,144653,2,673,0)="""RTN"",""PSOERX1F"",217,0)"
^XMB(3.9,144653,2,674,0)=" I MTYPE=""CX"" D "
^XMB(3.9,144653,2,675,0)="""RTN"",""PSOERX1F"",218,0)"
^XMB(3.9,144653,2,676,0)=" .D UPDSTAT^PSOERXU1(PSOIEN,""CXP"")"
^XMB(3.9,144653,2,677,0)="""RTN"",""PSOERX1F"",219,0)"
^XMB(3.9,144653,2,678,0)=" .S RTHID=$$GET1^DIQ(52.49,PSOIEN,.14),RTHIEN=$O(^PS(52.49,""FMID"",RTHID,0))"
^XMB(3.9,144653,2,679,0)="""RTN"",""PSOERX1F"",220,0)"
^XMB(3.9,144653,2,680,0)=" .D UPDSTAT^PSOERXU1(RTHIEN,""CRP"")"
^XMB(3.9,144653,2,681,0)="""RTN"",""PSOERX1F"",221,0)"
^XMB(3.9,144653,2,682,0)=" S REQIEN=$$GETREQ^PSOERXU2(PSOIEN) I REQIEN,$$GET1^DIQ(52.49,REQIEN,.08,""I"")=""RR"" D UPDSTAT^PSOERXU1(REQIEN,""RRP"")"
^XMB(3.9,144653,2,683,0)="""RTN"",""PSOERX1F"",222,0)"
^XMB(3.9,144653,2,684,0)=" ; PSO*7*508 - end"
^XMB(3.9,144653,2,685,0)="""RTN"",""PSOERX1F"",223,0)"
^XMB(3.9,144653,2,686,0)=" ;"
^XMB(3.9,144653,2,687,0)="""RTN"",""PSOERX1F"",224,0)"
^XMB(3.9,144653,2,688,0)=" ; Saves the Actual eRx SIG (from outside provider) into the PROVIDER COMMENTS field (P-651/14)"
^XMB(3.9,144653,2,689,0)="""RTN"",""PSOERX1F"",225,0)"
^XMB(3.9,144653,2,690,0)=" N UNEXINS S UNEXINS(1)=$$ERXSIG^PSOERXUT(PSOIEN)"
^XMB(3.9,144653,2,691,0)="""RTN"",""PSOERX1F"",226,0)"
^XMB(3.9,144653,2,692,0)=" I $L($G(UNEXINS(1))) D WP^DIE(52.41,PSOCPEND_"","",9,""K"",""UNEXINS"")"
^XMB(3.9,144653,2,693,0)="""RTN"",""PSOERX1F"",227,0)"
^XMB(3.9,144653,2,694,0)=" ;"
^XMB(3.9,144653,2,695,0)="""RTN"",""PSOERX1F"",228,0)"
^XMB(3.9,144653,2,696,0)=" I '$D(QUIET) D"
^XMB(3.9,144653,2,697,0)="""RTN"",""PSOERX1F"",229,0)"
^XMB(3.9,144653,2,698,0)=" . W !!,""eRx #""_PSOHY(""CHNUM"")_"" sent to PENDING ORDERS Queue."""
^XMB(3.9,144653,2,699,0)="""RTN"",""PSOERX1F"",230,0)"
^XMB(3.9,144653,2,700,0)=" . W:$G(MBMSITE) "" (Clinic: ""_$$GET1^DIQ(44,+$G(PSOHY(""LOC"")),.01)_"")"" H 1.5"
^XMB(3.9,144653,2,701,0)="""RTN"",""PSOERX1F"",231,0)"
^XMB(3.9,144653,2,702,0)=" ;PSO*7*520 - add sending and warning/information related to RxVerify Message."
^XMB(3.9,144653,2,703,0)="""RTN"",""PSOERX1F"",232,0)"
^XMB(3.9,144653,2,704,0)=" I '$$UNACCBEF^PSOERX1H(PSOIEN),MTYPE=""N""!((MTYPE=""RE"")&(RESTYPE=""R""))!(MTYPE=""CX"") D"
^XMB(3.9,144653,2,705,0)="""RTN"",""PSOERX1F"",233,0)"
^XMB(3.9,144653,2,706,0)=" . W !!,""Sending rxVerify Message to prescriber."""
^XMB(3.9,144653,2,707,0)="""RTN"",""PSOERX1F"",234,0)"
^XMB(3.9,144653,2,708,0)=" . D POST^PSOERXO1(PSOIEN,.PSSRET,,,,1)"
^XMB(3.9,144653,2,709,0)="""RTN"",""PSOERX1F"",235,0)"
^XMB(3.9,144653,2,710,0)=" . ; if the post was unsuccessful, inform the user and quit."
^XMB(3.9,144653,2,711,0)="""RTN"",""PSOERX1F"",236,0)"
^XMB(3.9,144653,2,712,0)=" . I $P(PSSRET(0),U)<1 W !,$P(PSSRET(0),U,2) S DIR(0)=""E"" D ^DIR K DIR Q"
^XMB(3.9,144653,2,713,0)="""RTN"",""PSOERX1F"",237,0)"
^XMB(3.9,144653,2,714,0)=" . I $D(PSSRET(""errorMessage"")) W !,PSSRET(""errorMessage"") S DIR(0)=""E"" D ^DIR K DIR Q"
^XMB(3.9,144653,2,715,0)="""RTN"",""PSOERX1F"",238,0)"
^XMB(3.9,144653,2,716,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144653,2,717,0)="""RTN"",""PSOERX1F"",239,0)"
^XMB(3.9,144653,2,718,0)=" ;PSO*7*520 - end rxVerify changes"
^XMB(3.9,144653,2,719,0)="""RTN"",""PSOERX1F"",240,0)"
^XMB(3.9,144653,2,720,0)=" ;"
^XMB(3.9,144653,2,721,0)="""RTN"",""PSOERX1F"",241,0)"
^XMB(3.9,144653,2,722,0)=" K QUIET"
^XMB(3.9,144653,2,723,0)="""RTN"",""PSOERX1F"",242,0)"
^XMB(3.9,144653,2,724,0)=" Q"
^XMB(3.9,144653,2,725,0)="""RTN"",""PSOERX1F"",243,0)"
^XMB(3.9,144653,2,726,0)=" ;"
^XMB(3.9,144653,2,727,0)="""RTN"",""PSOERX1F"",244,0)"
^XMB(3.9,144653,2,728,0)="ORDNUM() ; Returns the correct IEN for the ORDER file (#100) for the Rx"
^XMB(3.9,144653,2,729,0)="""RTN"",""PSOERX1F"",245,0)"
^XMB(3.9,144653,2,730,0)=" I $P(XQY0,""^"")=""PSO LM BACKDOOR ORDERS""!($P(XQY0,""^"")=""PSO LMOE FINISH""),$P(VALMKEY,""^"",2)=""PSO HIDDEN ACTIONS"",$G(RXN) Q +$$GET1^DIQ(52,RXN,39.3,""I"")"
