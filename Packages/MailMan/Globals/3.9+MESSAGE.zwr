^XMB(3.9,145834,2,7224,0)=" . . Q"
^XMB(3.9,145834,2,7225,0)="""RTN"",""MAGDSTQ8"",115,0)"
^XMB(3.9,145834,2,7226,0)=" . Q:DONE"
^XMB(3.9,145834,2,7227,0)="""RTN"",""MAGDSTQ8"",116,0)"
^XMB(3.9,145834,2,7228,0)=" . W ?68,""More?"""
^XMB(3.9,145834,2,7229,0)="""RTN"",""MAGDSTQ8"",117,0)"
^XMB(3.9,145834,2,7230,0)=" . R ""  y// "",X:TIMEOUT"
^XMB(3.9,145834,2,7231,0)="""RTN"",""MAGDSTQ8"",118,0)"
^XMB(3.9,145834,2,7232,0)=" . I X="""" S X=""y"" W X"
^XMB(3.9,145834,2,7233,0)="""RTN"",""MAGDSTQ8"",119,0)"
^XMB(3.9,145834,2,7234,0)=" . I ""Yy""'[$E(X) S DONE=1"
^XMB(3.9,145834,2,7235,0)="""RTN"",""MAGDSTQ8"",120,0)"
^XMB(3.9,145834,2,7236,0)=" . Q"
^XMB(3.9,145834,2,7237,0)="""RTN"",""MAGDSTQ8"",121,0)"
^XMB(3.9,145834,2,7238,0)=" I DONE<1 W !,""*** Possible problem with DICOM Gateway C-Move Request process ***"""
^XMB(3.9,145834,2,7239,0)="""RTN"",""MAGDSTQ8"",122,0)"
^XMB(3.9,145834,2,7240,0)=" D CONTINUE^MAGDSTQ"
