^XMB(3.9,145836,2,1079,0)="""RTN"",""GMTSPST2"",89,0)"
^XMB(3.9,145836,2,1080,0)=" . W !!,""Any medication items listed as """"pending"""" are those that have just been"" D CKP^GMTSUP Q:$D(GMTSQIT)"
