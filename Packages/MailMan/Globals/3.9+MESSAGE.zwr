^XMB(3.9,144652,2,239,0)="""RTN"",""PSOERRX1"")"
^XMB(3.9,144652,2,240,0)="0^1^B151562025"
^XMB(3.9,144652,2,241,0)="""RTN"",""PSOERRX1"",1,0)"
^XMB(3.9,144652,2,242,0)="PSOERRX1 ;BIRM/MFR - All Rxs eRx Queue - Supporting APIs ;08/28/22"
^XMB(3.9,144652,2,243,0)="""RTN"",""PSOERRX1"",2,0)"
^XMB(3.9,144652,2,244,0)=" ;;7.0;OUTPATIENT PHARMACY;**700,769,770**;DEC 1997;Build 0"
^XMB(3.9,144652,2,245,0)="""RTN"",""PSOERRX1"",3,0)"
^XMB(3.9,144652,2,246,0)=" ;"
^XMB(3.9,144652,2,247,0)="""RTN"",""PSOERRX1"",4,0)"
^XMB(3.9,144652,2,248,0)="HDR ; - Builds the Header section"
^XMB(3.9,144652,2,249,0)="""RTN"",""PSOERRX1"",5,0)"
^XMB(3.9,144652,2,250,0)=" N LINE1,LINE2,LINE3,ARR"
^XMB(3.9,144652,2,251,0)="""RTN"",""PSOERRX1"",6,0)"
^XMB(3.9,144652,2,252,0)=" ;"
^XMB(3.9,144652,2,253,0)="""RTN"",""PSOERRX1"",7,0)"
^XMB(3.9,144652,2,254,0)=" S LINE1=""LOOK BACK DAYS: ""_IOINHI_$S($G(REDTFLTR):""N/A"",1:PSOLKBKD)_IOINORM"
^XMB(3.9,144652,2,255,0)="""RTN"",""PSOERRX1"",8,0)"
^XMB(3.9,144652,2,256,0)=" S $E(LINE1,40)=""CS/NON-CS: ""_IOINHI_$S(PSOCSERX=""CS"":""CS ONLY"",PSOCSERX=""Non-CS"":""NON-CS ONLY"",1:""BOTH"")"
^XMB(3.9,144652,2,257,0)="""RTN"",""PSOERRX1"",9,0)"
^XMB(3.9,144652,2,258,0)=" S:PSOCSERX'=""Non-CS"" LINE1=LINE1_"" (""_$S(PSOCSSCH=1:""II"",PSOCSSCH=2:""III-V"",1:""II-V"")_"")"""
^XMB(3.9,144652,2,259,0)="""RTN"",""PSOERRX1"",10,0)"
^XMB(3.9,144652,2,260,0)=" S LINE1=LINE1_IOINORM"
^XMB(3.9,144652,2,261,0)="""RTN"",""PSOERRX1"",11,0)"
^XMB(3.9,144652,2,262,0)=" D INSTR^VALM1(""MAX. QUEUE SIZE: ""_IOINHI_$J(PSOMAXQS,4)_IOINORM,60,2)"
^XMB(3.9,144652,2,263,0)="""RTN"",""PSOERRX1"",12,0)"
^XMB(3.9,144652,2,264,0)=" ;"
^XMB(3.9,144652,2,265,0)="""RTN"",""PSOERRX1"",13,0)"
^XMB(3.9,144652,2,266,0)=" S LINE2=""ERX STATUS: ""_IOINHI"
^XMB(3.9,144652,2,267,0)="""RTN"",""PSOERRX1"",14,0)"
^XMB(3.9,144652,2,268,0)=" I PSOSTFLT=""A"" S LINE2=LINE2_""ALL"""
^XMB(3.9,144652,2,269,0)="""RTN"",""PSOERRX1"",15,0)"
^XMB(3.9,144652,2,270,0)=" I PSOSTFLT=""N"" S LINE2=LINE2_""NEW"""
^XMB(3.9,144652,2,271,0)="""RTN"",""PSOERRX1"",16,0)"
^XMB(3.9,144652,2,272,0)=" I PSOSTFLT=""I"" S LINE2=LINE2_""IN PROGRESS"""
^XMB(3.9,144652,2,273,0)="""RTN"",""PSOERRX1"",17,0)"
^XMB(3.9,144652,2,274,0)=" I PSOSTFLT=""W"" S LINE2=LINE2_""WAIT"""
^XMB(3.9,144652,2,275,0)="""RTN"",""PSOERRX1"",18,0)"
^XMB(3.9,144652,2,276,0)=" I PSOSTFLT=""H"" S LINE2=LINE2_$S(PSOHDSTS=""ALL"":""HOLD (ALL)"",1:""HOLD (""_PSOHDSTS_"")"")"
^XMB(3.9,144652,2,277,0)="""RTN"",""PSOERRX1"",19,0)"
^XMB(3.9,144652,2,278,0)=" I PSOSTFLT=""C"" S LINE2=LINE2_$S(PSOCCRST=""ALL"":""CCR (ALL)"",1:""CCR (""_PSOCCRST_"")"")"
^XMB(3.9,144652,2,279,0)="""RTN"",""PSOERRX1"",20,0)"
^XMB(3.9,144652,2,280,0)=" S LINE2=LINE2_IOINORM"
^XMB(3.9,144652,2,281,0)="""RTN"",""PSOERRX1"",21,0)"
^XMB(3.9,144652,2,282,0)=" S LINE3="""""
^XMB(3.9,144652,2,283,0)="""RTN"",""PSOERRX1"",22,0)"
^XMB(3.9,144652,2,284,0)=" I $D(PATFLTR)!$G(DOBFLTR)!$G(REDTFLTR)!$D(PRVFLTR)!$G(STSFLTR)!($G(DRGFLTR)'="""")!$G(MATFLTR)!($G(MSTPFLTR)'="""")!$G(VDRGFLTR) D"
^XMB(3.9,144652,2,285,0)="""RTN"",""PSOERRX1"",23,0)"
^XMB(3.9,144652,2,286,0)=" . N FILTER S FILTER="""""
^XMB(3.9,144652,2,287,0)="""RTN"",""PSOERRX1"",24,0)"
^XMB(3.9,144652,2,288,0)=" . I $G(REDTFLTR) S FILTER=FILTER_""|""_$$FMTE^XLFDT(+REDTFLTR,""2Z"")_""-""_$$FMTE^XLFDT($P(REDTFLTR,""^"",2),""2Z"")"
^XMB(3.9,144652,2,289,0)="""RTN"",""PSOERRX1"",25,0)"
^XMB(3.9,144652,2,290,0)=" . I $G(MATFLTR) S FILTER=FILTER_""|MATCH(""_$$MATCHLBL^PSOERPC2(MATFLTR)_"")"""
^XMB(3.9,144652,2,291,0)="""RTN"",""PSOERRX1"",26,0)"
^XMB(3.9,144652,2,292,0)=" . I $G(DRGFLTR)'="""" S FILTER=FILTER_""|ERX DRUG NAME('""_DRGFLTR_""')"""
^XMB(3.9,144652,2,293,0)="""RTN"",""PSOERRX1"",27,0)"
^XMB(3.9,144652,2,294,0)=" . I $G(DOBFLTR) S FILTER=FILTER_""|DOB(""_$$FMTE^XLFDT(DOBFLTR,""2Z"")_"")"""
^XMB(3.9,144652,2,295,0)="""RTN"",""PSOERRX1"",28,0)"
^XMB(3.9,144652,2,296,0)=" . I $G(STSFLTR) S FILTER=FILTER_""|STATUS(""_$S($G(STSFLTR1)'="""":STSFLTR1,1:$$GET1^DIQ(52.45,STSFLTR,.01))_"")"""
^XMB(3.9,144652,2,297,0)="""RTN"",""PSOERRX1"",29,0)"
^XMB(3.9,144652,2,298,0)=" . I $G(MSTPFLTR)'="""" S FILTER=FILTER_""|TYPE(""_$S($G(MSTPFLTR1)'="""":MSTPFLTR1,1:$G(MTARR(MSTPFLTR)))_"")"""
^XMB(3.9,144652,2,299,0)="""RTN"",""PSOERRX1"",30,0)"
^XMB(3.9,144652,2,300,0)=" . I $D(PRVFLTR) S FILTER=FILTER_""|PROVIDER(""_$$EPRVFLST^PSOERUT(60)_"")"""
^XMB(3.9,144652,2,301,0)="""RTN"",""PSOERRX1"",31,0)"
^XMB(3.9,144652,2,302,0)=" . I $D(PATFLTR) S FILTER=FILTER_""|PATIENT(""_$$EPATFLST^PSOERUT(60)_"")"""
^XMB(3.9,144652,2,303,0)="""RTN"",""PSOERRX1"",32,0)"
^XMB(3.9,144652,2,304,0)=" . I $G(VDRGFLTR) S FILTER=FILTER_""|VISTA DRUG(""_$$GET1^DIQ(50,VDRGFLTR,.01)_"")"""
^XMB(3.9,144652,2,305,0)="""RTN"",""PSOERRX1"",33,0)"
^XMB(3.9,144652,2,306,0)=" . S $E(FILTER,1)="""" I $L(FILTER)>63 S FILTER=$E(FILTER,1,60)_""..."""
^XMB(3.9,144652,2,307,0)="""RTN"",""PSOERRX1"",34,0)"
^XMB(3.9,144652,2,308,0)=" . S LINE2=""FILTERED BY: ""_IOINHI_FILTER_IOINORM"
^XMB(3.9,144652,2,309,0)="""RTN"",""PSOERRX1"",35,0)"
^XMB(3.9,144652,2,310,0)=" K VALMHDR S VALMHDR(1)=LINE1,VALMHDR(2)=LINE2 ;S:LINE3'="""" VALMHDR(3)=LINE3 S VALMHDR(4)=IOINORM"
^XMB(3.9,144652,2,311,0)="""RTN"",""PSOERRX1"",36,0)"
^XMB(3.9,144652,2,312,0)=" D SETHDR()"
^XMB(3.9,144652,2,313,0)="""RTN"",""PSOERRX1"",37,0)"
^XMB(3.9,144652,2,314,0)=" Q"
^XMB(3.9,144652,2,315,0)="""RTN"",""PSOERRX1"",38,0)"
^XMB(3.9,144652,2,316,0)=" ;"
^XMB(3.9,144652,2,317,0)="""RTN"",""PSOERRX1"",39,0)"
^XMB(3.9,144652,2,318,0)="SETHDR() ; - Displays the Header Line"
^XMB(3.9,144652,2,319,0)="""RTN"",""PSOERRX1"",40,0)"
^XMB(3.9,144652,2,320,0)=" N HDR,SRTORD,SRTPOS"
^XMB(3.9,144652,2,321,0)="""RTN"",""PSOERRX1"",41,0)"
^XMB(3.9,144652,2,322,0)=" S HDR=""#"",$E(HDR,5)=""PATIENT"",$E(HDR,26)=""DOB"",$E(HDR,35)=$S($G(PSODETDP):"""",1:""DRUG"")"
^XMB(3.9,144652,2,323,0)="""RTN"",""PSOERRX1"",42,0)"
^XMB(3.9,144652,2,324,0)=" S $E(HDR,57)=""PROVIDER"",$E(HDR,69)=""STA"",$E(HDR,73)=""REC.DATE"""
^XMB(3.9,144652,2,325,0)="""RTN"",""PSOERRX1"",43,0)"
^XMB(3.9,144652,2,326,0)=" D INSTR^VALM1(IORVON_HDR_IOINORM,1,4)"
^XMB(3.9,144652,2,327,0)="""RTN"",""PSOERRX1"",44,0)"
^XMB(3.9,144652,2,328,0)=" S SRTORD=$S(PSORDER=""A"":""^"",1:""v"")"
^XMB(3.9,144652,2,329,0)="""RTN"",""PSOERRX1"",45,0)"
^XMB(3.9,144652,2,330,0)=" S SRTPOS=$S(PSOSRTBY=""PA"":12,PSOSRTBY=""DOB"":29,PSOSRTBY=""DR"":39,PSOSRTBY=""PR"":65,PSOSRTBY=""STA"":72,1:80)"
^XMB(3.9,144652,2,331,0)="""RTN"",""PSOERRX1"",46,0)"
^XMB(3.9,144652,2,332,0)=" D INSTR^VALM1(IOINHI_IORVON_SRTORD_IOINORM,SRTPOS,4)"
