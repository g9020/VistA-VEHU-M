^XMB(3.9,145837,2,498,0)=" Q XQAID"
^XMB(3.9,145837,2,499,0)="""RTN"",""XQALSET"",130,0)"
^XMB(3.9,145837,2,500,0)=" ;"
^XMB(3.9,145837,2,501,0)="""RTN"",""XQALSET"",131,0)"
^XMB(3.9,145837,2,502,0)="SETTRACK ; Setup entry in Alert Tracking file"
