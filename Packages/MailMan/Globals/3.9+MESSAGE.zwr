^XMB(3.9,144654,2,348,0)=" S ^TMP(""PSO"",$J,PSI)=RXR,PSI=PSI+1"
^XMB(3.9,144654,2,349,0)="""RTN"",""PSOHLDS2"",55,0)"
^XMB(3.9,144654,2,350,0)=" K PSROUTE,RTNAME,PSRTLP"
^XMB(3.9,144654,2,351,0)="""RTN"",""PSOHLDS2"",56,0)"
^XMB(3.9,144654,2,352,0)=" Q"
^XMB(3.9,144654,2,353,0)="""RTN"",""PSOHLDS2"",57,0)"
^XMB(3.9,144654,2,354,0)="SIG K OT S SGY="""" F P=1:1:$L(SIG,"" "") S X=$P(SIG,"" "",P) D:X]"""""
^XMB(3.9,144654,2,355,0)="""RTN"",""PSOHLDS2"",58,0)"
^XMB(3.9,144654,2,356,0)=" .I $D(^PS(51,""A"",X)) D"
^XMB(3.9,144654,2,357,0)="""RTN"",""PSOHLDS2"",59,0)"
^XMB(3.9,144654,2,358,0)=" ..;PSO*7*282 Intended Use"
^XMB(3.9,144654,2,359,0)="""RTN"",""PSOHLDS2"",60,0)"
^XMB(3.9,144654,2,360,0)=" ..I $P($G(^PS(55,DFN,""LAN"")),""^"") S OT=$O(^PS(51,""B"",X,0)) I OT,($P(^PS(51,OT,0),""^"",4)<2)&($P($G(^PS(51,OT,4)),""^"")]"""") S X=$P(^PS(51,OT,4),""^"") K OT Q"
^XMB(3.9,144654,2,361,0)="""RTN"",""PSOHLDS2"",61,0)"
^XMB(3.9,144654,2,362,0)=" ..;S %=^PS(51,""A"",X),X=$P(%,""^"") I $P(%,""^"",2)]"""" S Y=$P(SIG,"" "",P-1),Y=$E(Y,$L(Y)) S:Y>1 X=$P(%,""^"",2)"
^XMB(3.9,144654,2,363,0)="""RTN"",""PSOHLDS2"",62,0)"
^XMB(3.9,144654,2,364,0)=" .S SGY=SGY_X_"" """
^XMB(3.9,144654,2,365,0)="""RTN"",""PSOHLDS2"",63,0)"
^XMB(3.9,144654,2,366,0)=" S X="""",SGC=1 F J=1:1 S Z=$P(SGY,"" "",J) S:Z="""" SGY(SGC)=X Q:Z=""""  S:$L(X)+$L(Z)'<$S($P(PSOPAR,""^"",28):46,1:34) SGY(SGC)=X,SGC=SGC+1,X="""" S X=X_Z_"" """
^XMB(3.9,144654,2,367,0)="""RTN"",""PSOHLDS2"",64,0)"
^XMB(3.9,144654,2,368,0)="SIGOLD I '$P(PSOPAR,""^"",28) D  K NHC"
^XMB(3.9,144654,2,369,0)="""RTN"",""PSOHLDS2"",65,0)"
^XMB(3.9,144654,2,370,0)=" .K DIC,DR,DIQ,NHC S DIC=2,DA=DFN,DR=148,DIQ=""NHC"",DIQ(0)=""I"""
^XMB(3.9,144654,2,371,0)="""RTN"",""PSOHLDS2"",66,0)"
^XMB(3.9,144654,2,372,0)=" .D EN^DIQ1 K DIC,DR,DIQ"
^XMB(3.9,144654,2,373,0)="""RTN"",""PSOHLDS2"",67,0)"
^XMB(3.9,144654,2,374,0)=" .I NHC(2,DFN,148,""I"")=""Y""!($P($G(^PS(55,DFN,40)),""^"")) S SGC=SGC+1,SGY(SGC)=""Expiration:________ Mfg:_________"""
^XMB(3.9,144654,2,375,0)="""RTN"",""PSOHLDS2"",68,0)"
^XMB(3.9,144654,2,376,0)=" Q"
^XMB(3.9,144654,2,377,0)="""RTN"",""PSOHLDS2"",69,0)"
^XMB(3.9,144654,2,378,0)=" ;"
^XMB(3.9,144654,2,379,0)="""RTN"",""PSOHLDS2"",70,0)"
^XMB(3.9,144654,2,380,0)="PSOLBL3 ;RX must be defined (Internal), Check already done for OERR SIG"
^XMB(3.9,144654,2,381,0)="""RTN"",""PSOHLDS2"",71,0)"
^XMB(3.9,144654,2,382,0)=" ;Format OERR Sig for New and Old label stock"
^XMB(3.9,144654,2,383,0)="""RTN"",""PSOHLDS2"",72,0)"
^XMB(3.9,144654,2,384,0)=" N CTCT,FFFF,LLIM,LLLL,LVAR,LVAR1,PPP,PPPP,SGCT,SIG9,ZZZZ,PSLONG,PPPP"
^XMB(3.9,144654,2,385,0)="""RTN"",""PSOHLDS2"",73,0)"
^XMB(3.9,144654,2,386,0)=" S RX=IRXN"
^XMB(3.9,144654,2,387,0)="""RTN"",""PSOHLDS2"",74,0)"
^XMB(3.9,144654,2,388,0)=" I $P($G(^PS(55,DFN,""LAN"")),""^"") N II D OTHL^PSOLBL3 G:$G(FND) FMSIG"
^XMB(3.9,144654,2,389,0)="""RTN"",""PSOHLDS2"",75,0)"
^XMB(3.9,144654,2,390,0)=" S PSLONG=$S($P(PSOPAR,""^"",28):46,1:34)"
^XMB(3.9,144654,2,391,0)="""RTN"",""PSOHLDS2"",76,0)"
^XMB(3.9,144654,2,392,0)=" ; NEXT LINE IF SIG IS MOVED BACK TO MULTIPLE"
^XMB(3.9,144654,2,393,0)="""RTN"",""PSOHLDS2"",77,0)"
^XMB(3.9,144654,2,394,0)=" S PPPP=1 F PPP=0:0 S PPP=$O(^PSRX(RX,""SIG1"",PPP)) Q:'PPP  I $G(^PSRX(RX,""SIG1"",PPP,0))'="""" S SIG9(PPPP)=^(0) S PPPP=PPPP+1"
^XMB(3.9,144654,2,395,0)="""RTN"",""PSOHLDS2"",78,0)"
^XMB(3.9,144654,2,396,0)=" ;NEXT LINE IF 1ST FRONT DOOR SIG LINE LIVES IN BACK DOOR SPOT"
^XMB(3.9,144654,2,397,0)="""RTN"",""PSOHLDS2"",79,0)"
^XMB(3.9,144654,2,398,0)="FMSIG S (LVAR,LVAR1)="""",LLLL=1"
^XMB(3.9,144654,2,399,0)="""RTN"",""PSOHLDS2"",80,0)"
^XMB(3.9,144654,2,400,0)=" F FFFF=0:0 S FFFF=$O(SIG9(FFFF)) Q:'FFFF  S SGCT=0 F ZZZZ=1:1:$L(SIG9(FFFF)) I $E(SIG9(FFFF),ZZZZ)="" ""!($L(SIG9(FFFF))=ZZZZ) S SGCT=SGCT+1 D  I $L(LVAR)>PSLONG S SGY(LLLL)=LLIM_"" "",LLLL=LLLL+1,LVAR=LVAR1"
^XMB(3.9,144654,2,401,0)="""RTN"",""PSOHLDS2"",81,0)"
^XMB(3.9,144654,2,402,0)=" .S LVAR1=$P(SIG9(FFFF),"" "",(SGCT)),LLIM=LVAR,LVAR=$S(LVAR="""":LVAR1,1:LVAR_"" ""_LVAR1)"
^XMB(3.9,144654,2,403,0)="""RTN"",""PSOHLDS2"",82,0)"
^XMB(3.9,144654,2,404,0)=" I $G(LVAR)'="""" S SGY(LLLL)=LVAR"
