^XMB(3.9,144662,2,243,0)="""RTN"",""PRCHCON1"")"
^XMB(3.9,144662,2,244,0)="0^1^B27177150"
^XMB(3.9,144662,2,245,0)="""RTN"",""PRCHCON1"",1,0)"
^XMB(3.9,144662,2,246,0)="PRCHCON1 ;WISC/KMB/DL/DXH - CONV. TEMP 2237 TO PC ORDER ;7.29.99"
^XMB(3.9,144662,2,247,0)="""RTN"",""PRCHCON1"",2,0)"
^XMB(3.9,144662,2,248,0)="V ;;5.1;IFCAP;**108,156,192,208**;Oct 20, 2000;Build 0"
^XMB(3.9,144662,2,249,0)="""RTN"",""PRCHCON1"",3,0)"
^XMB(3.9,144662,2,250,0)=" ;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144662,2,251,0)="""RTN"",""PRCHCON1"",4,0)"
^XMB(3.9,144662,2,252,0)=" ;"
^XMB(3.9,144662,2,253,0)="""RTN"",""PRCHCON1"",5,0)"
^XMB(3.9,144662,2,254,0)=" ;PRC*5.1*192 Modify $3000 limit to be $3500, per FAR 2.101 as of "
^XMB(3.9,144662,2,255,0)="""RTN"",""PRCHCON1"",6,0)"
^XMB(3.9,144662,2,256,0)=" ;            10/1/2015 for micro purchase threshold for goods.  Also,"
^XMB(3.9,144662,2,257,0)="""RTN"",""PRCHCON1"",7,0)"
^XMB(3.9,144662,2,258,0)=" ;            as of 10/1/2015 the SPL was increased to $3500 for all"
^XMB(3.9,144662,2,259,0)="""RTN"",""PRCHCON1"",8,0)"
^XMB(3.9,144662,2,260,0)=" ;            PCards for simplified orders."
^XMB(3.9,144662,2,261,0)="""RTN"",""PRCHCON1"",9,0)"
^XMB(3.9,144662,2,262,0)=" ;"
^XMB(3.9,144662,2,263,0)="""RTN"",""PRCHCON1"",10,0)"
^XMB(3.9,144662,2,264,0)=" ;PRC*5.1*208 Modify $3500 limit to be $10000 for micro-purchase threshold "
^XMB(3.9,144662,2,265,0)="""RTN"",""PRCHCON1"",11,0)"
^XMB(3.9,144662,2,266,0)=" ;            for goods and services. Also, the SPL was increased to $10000 "
^XMB(3.9,144662,2,267,0)="""RTN"",""PRCHCON1"",12,0)"
^XMB(3.9,144662,2,268,0)=" ;            for all PCards for simplified orders."
^XMB(3.9,144662,2,269,0)="""RTN"",""PRCHCON1"",13,0)"
^XMB(3.9,144662,2,270,0)=" ;"
^XMB(3.9,144662,2,271,0)="""RTN"",""PRCHCON1"",14,0)"
^XMB(3.9,144662,2,272,0)=" I '$D(^PRC(440.5,""C"",DUZ)) W !!,""You are not authorized to use this option."" Q"
^XMB(3.9,144662,2,273,0)="""RTN"",""PRCHCON1"",15,0)"
^XMB(3.9,144662,2,274,0)="START ;   get transaction number, convert to regular 2237"
^XMB(3.9,144662,2,275,0)="""RTN"",""PRCHCON1"",16,0)"
^XMB(3.9,144662,2,276,0)=" N PRC,Y,PRCSIP,PRCSQ,ODA,PNW,TRY,TX1,T1,T2,T3,T4,PRCSY,PRCSDIC,PRCSAPP"
^XMB(3.9,144662,2,277,0)="""RTN"",""PRCHCON1"",17,0)"
^XMB(3.9,144662,2,278,0)=" N PRCHCV,PRCHCPD,PRCHQTDT"
^XMB(3.9,144662,2,279,0)="""RTN"",""PRCHCON1"",18,0)"
^XMB(3.9,144662,2,280,0)=" I $G(QUIT)'="""" K QUIT Q"
^XMB(3.9,144662,2,281,0)="""RTN"",""PRCHCON1"",19,0)"
^XMB(3.9,144662,2,282,0)=" K PRC(""SITE"") W @IOF D EN3F^PRCSUT(1) G W5:'$D(PRC(""SITE"")) S:Y<0 QUIT=1 Q:Y<0"
^XMB(3.9,144662,2,283,0)="""RTN"",""PRCHCON1"",20,0)"
^XMB(3.9,144662,2,284,0)=" D START1 G START"
^XMB(3.9,144662,2,285,0)="""RTN"",""PRCHCON1"",21,0)"
^XMB(3.9,144662,2,286,0)="START1 ;"
^XMB(3.9,144662,2,287,0)="""RTN"",""PRCHCON1"",22,0)"
^XMB(3.9,144662,2,288,0)=" W !!,""Select the existing transaction number to be converted"",!"
^XMB(3.9,144662,2,289,0)="""RTN"",""PRCHCON1"",23,0)"
^XMB(3.9,144662,2,290,0)=" ; don't select an order which is signed, or attached to PC already"
^XMB(3.9,144662,2,291,0)="""RTN"",""PRCHCON1"",24,0)"
^XMB(3.9,144662,2,292,0)=" S DIC=""^PRCS(410,"",DIC(0)=""AEFMQ"""
^XMB(3.9,144662,2,293,0)="""RTN"",""PRCHCON1"",25,0)"
^XMB(3.9,144662,2,294,0)=" S DIC(""S"")=""I $P(^(0),U,2)=""""O"""",$P(^(0),U,5)=PRC(""""SITE""""),$P(^(0),U,12)'=""""A"""",$D(^(3)),+$P(^(3),U)=+PRC(""""CP""""),$P($G(^(4)),U,5)="""""""""""
^XMB(3.9,144662,2,295,0)="""RTN"",""PRCHCON1"",26,0)"
^XMB(3.9,144662,2,296,0)=" D ^DIC S:Y<0 QUIT=1 Q:Y<0  S (ODA,DA)=+Y,PRCSDIC=DIC"
^XMB(3.9,144662,2,297,0)="""RTN"",""PRCHCON1"",27,0)"
^XMB(3.9,144662,2,298,0)=" S PRCHQTDT=$P($G(^PRCS(410,ODA,0)),U,11)"
^XMB(3.9,144662,2,299,0)="""RTN"",""PRCHCON1"",28,0)"
^XMB(3.9,144662,2,300,0)=" I $P($G(^PRCS(410,DA,3)),U,4)="""" W !,""This transaction has no entry in the Vendor File."",!,""Please edit this transaction's vendor before converting this order."" H 4 Q"
^XMB(3.9,144662,2,301,0)="""RTN"",""PRCHCON1"",29,0)"
^XMB(3.9,144662,2,302,0)=" I $P($G(^PRCS(410,DA,4)),U)>10000 W !,""The dollar amount for this transaction exceeds the $10000 purchase card cutoff."" H 4 Q    ;PRC*5.1*208"
^XMB(3.9,144662,2,303,0)="""RTN"",""PRCHCON1"",30,0)"
^XMB(3.9,144662,2,304,0)=" D W1^PRCSEB0 Q:%<0  S DIC=PRCSDIC"
^XMB(3.9,144662,2,305,0)="""RTN"",""PRCHCON1"",31,0)"
^XMB(3.9,144662,2,306,0)=" L +^PRCS(410,DA):15 G:$T=0 START S T1=ODA,T2=^PRCS(410,DA,0),T4=$P(T2,""^"",2),T2=$P(T2,""^""),T3=$P(^(3),""^"")"
^XMB(3.9,144662,2,307,0)="""RTN"",""PRCHCON1"",32,0)"
^XMB(3.9,144662,2,308,0)=" N REM,REM1 S REM=DA,REM1=+$P(PRC(""CP""),"" "")"
^XMB(3.9,144662,2,309,0)="""RTN"",""PRCHCON1"",33,0)"
^XMB(3.9,144662,2,310,0)=" L -^PRCS(410,DA) K DA,DIC,Y"
^XMB(3.9,144662,2,311,0)="""RTN"",""PRCHCON1"",34,0)"
^XMB(3.9,144662,2,312,0)=" W !!,""Enter the information for the new transaction number"",!"
^XMB(3.9,144662,2,313,0)="""RTN"",""PRCHCON1"",35,0)"
^XMB(3.9,144662,2,314,0)=" D EN^PRCSUT3 Q:'$D(PRC(""QTR""))  Q:'$D(PRC(""CP""))"
^XMB(3.9,144662,2,315,0)="""RTN"",""PRCHCON1"",36,0)"
^XMB(3.9,144662,2,316,0)=" S TX1=X,PRCSAPP=$P(^PRC(420,PRC(""SITE""),1,+PRC(""CP""),0),""^"",3) I PRC(""CP"")'=T3,PRCSAPP[""_"" D PRCFY Q:PRCSAPP[""_"""
^XMB(3.9,144662,2,317,0)="""RTN"",""PRCHCON1"",37,0)"
^XMB(3.9,144662,2,318,0)=" S X=TX1 D EN1^PRCSUT3 Q:'X  S TX1=X,(DIC,DIE)=""^PRCS(410,"""
^XMB(3.9,144662,2,319,0)="""RTN"",""PRCHCON1"",38,0)"
^XMB(3.9,144662,2,320,0)="CK G:'+T2 CK1 K DA S DLAYGO=410,DIC=""^PRCS(410,"",DIC(0)=""LXZ"" D ^DIC K DLAYGO Q:Y'>0  S DA=+Y"
^XMB(3.9,144662,2,321,0)="""RTN"",""PRCHCON1"",39,0)"
^XMB(3.9,144662,2,322,0)=" K ^PRCS(410,""B"",TX1,DA),^PRCS(410,""B2"",$P(TX1,""-"",5),DA),^PRCS(410,""B3"",$P(TX1,""-"",2)_""-""_$P(TX1,""-"",5),DA),^PRCS(410,""AE"",$P(TX1,""-"",1,4),DA)"
^XMB(3.9,144662,2,323,0)="""RTN"",""PRCHCON1"",40,0)"
^XMB(3.9,144662,2,324,0)=" K ^PRCS(410,""B"",T2,T1),^PRCS(410,""B2"",$P(T2,""-"",5),T1),^PRCS(410,""B3"",$P(T2,""-"",2)_""-""_$P(T2,""-"",5),T1),^PRCS(410,""AE"",$P(T2,""-"",1,4),T1)"
^XMB(3.9,144662,2,325,0)="""RTN"",""PRCHCON1"",41,0)"
^XMB(3.9,144662,2,326,0)=" ;Patch PRC*5.1*156 insures the running balance ('RB') index is killed for temp 2237"
^XMB(3.9,144662,2,327,0)="""RTN"",""PRCHCON1"",42,0)"
^XMB(3.9,144662,2,328,0)=" I +PRCHQTDT>0 K ^PRCS(410,""RB"",PRCHQTDT_""-""_$P(T2,""-"")_""-""_$P(T2,""-"",4)_""-""_$P(T2,""-"",2)_""-""_$P(T2,""-"",5),ODA)"
^XMB(3.9,144662,2,329,0)="""RTN"",""PRCHCON1"",43,0)"
^XMB(3.9,144662,2,330,0)=" K PRCHQTDT"
^XMB(3.9,144662,2,331,0)="""RTN"",""PRCHCON1"",44,0)"
^XMB(3.9,144662,2,332,0)=" S $P(^PRCS(410,DA,0),U)=T2 S (^PRCS(410,""B"",T2,DA),^PRCS(410,""B2"",$P(T2,""-"",5),DA),^PRCS(410,""B3"",$P(T2,""-"",2)_""-""_$P(T2,""-"",5),DA),^PRCS(410,""AE"",$P(T2,""-"",1,4),DA))="""""
^XMB(3.9,144662,2,333,0)="""RTN"",""PRCHCON1"",45,0)"
^XMB(3.9,144662,2,334,0)="CK1 S $P(^PRCS(410,T1,0),U)=TX1 S (^PRCS(410,""B"",TX1,T1),^PRCS(410,""B2"",$P(TX1,""-"",5),T1),^PRCS(410,""B3"",$P(TX1,""-"",2)_""-""_$P(TX1,""-"",5),T1),^PRCS(410,""AE"",$P(TX1,""-"",1,4),T1))="""""
^XMB(3.9,144662,2,335,0)="""RTN"",""PRCHCON1"",46,0)"
^XMB(3.9,144662,2,336,0)=" S $P(^PRCS(410,T1,6),""^"",4)="""" K ^PRCS(410,""K"",REM1,REM)"
^XMB(3.9,144662,2,337,0)="""RTN"",""PRCHCON1"",47,0)"
^XMB(3.9,144662,2,338,0)=" I '+T2 S DA=ODA,DIE=""^PRCS(410,"",DR="".5///""_PRC(""SITE"")_"";S X=X;15///""_PRC(""CP"") D ^DIE G EN"
^XMB(3.9,144662,2,339,0)="""RTN"",""PRCHCON1"",48,0)"
^XMB(3.9,144662,2,340,0)=" S DIE=""^PRCS(410,"",DR="".5///""_+T2_"";S X=X;15///""_T3_"";60///Transaction ""_T2_"" replaced by trans. ""_TX1"
^XMB(3.9,144662,2,341,0)="""RTN"",""PRCHCON1"",49,0)"
^XMB(3.9,144662,2,342,0)=" D ^DIE S $P(^PRCS(410,DA,0),U,2)=""CA"" D ERS410^PRC0G(DA_""^C""),W5^PRCSEB W !,""Old transaction ""_T2_"" is now cancelled."",!"
^XMB(3.9,144662,2,343,0)="""RTN"",""PRCHCON1"",50,0)"
^XMB(3.9,144662,2,344,0)=" I $D(^PRC(443,ODA,0)) S DA=ODA,DIK=""^PRC(443,"" D ^DIK K DA,DIK"
^XMB(3.9,144662,2,345,0)="""RTN"",""PRCHCON1"",51,0)"
^XMB(3.9,144662,2,346,0)="EN W !!,""Transaction '""_T2_""' has been replaced by ""_TX1,! S PNW=ODA,PNW(1)=TX1"
^XMB(3.9,144662,2,347,0)="""RTN"",""PRCHCON1"",52,0)"
^XMB(3.9,144662,2,348,0)=" S TRY=0"
^XMB(3.9,144662,2,349,0)="""RTN"",""PRCHCON1"",53,0)"
^XMB(3.9,144662,2,350,0)="RETRY ;"
^XMB(3.9,144662,2,351,0)="""RTN"",""PRCHCON1"",54,0)"
^XMB(3.9,144662,2,352,0)=" S TRY=TRY+1 Q:TRY>3"
^XMB(3.9,144662,2,353,0)="""RTN"",""PRCHCON1"",55,0)"
^XMB(3.9,144662,2,354,0)=" N A,B S DA=PNW L +^PRCS(410,DA):15 G:$T=0 RETRY"
^XMB(3.9,144662,2,355,0)="""RTN"",""PRCHCON1"",56,0)"
^XMB(3.9,144662,2,356,0)=" S DA=PNW"
^XMB(3.9,144662,2,357,0)="""RTN"",""PRCHCON1"",57,0)"
^XMB(3.9,144662,2,358,0)=" S A=TX1 D RBQTR"
^XMB(3.9,144662,2,359,0)="""RTN"",""PRCHCON1"",58,0)"
^XMB(3.9,144662,2,360,0)=" S DA=PNW,DR=B_$S(+T2:""1///""_T4,1:"""")_$S(PRC(""SITE"")'=+T2:"";S X=X;.5///""_PRC(""SITE""),1:"""")_$S(PRC(""CP"")'=T3:"";S X=X;15///""_PRC(""CP""),1:"""")_$S($D(PRCSIP):"";4////""_PRCSIP,1:"""")"
^XMB(3.9,144662,2,361,0)="""RTN"",""PRCHCON1"",59,0)"
^XMB(3.9,144662,2,362,0)=" D ^DIE S PRC(""ACC"")=$$ACC^PRC0C(PRC(""SITE""),PRC(""CP"")_""^""_PRC(""FY"")_""^""_PRC(""BBFY""))"
^XMB(3.9,144662,2,363,0)="""RTN"",""PRCHCON1"",60,0)"
^XMB(3.9,144662,2,364,0)=" S PRCSAPP=$P(PRC(""ACC""),""^"",11),$P(^PRCS(410,DA,3),U)=PRC(""CP""),$P(^(3),""^"",2)=PRCSAPP,$P(^(3),""^"",12)=$P(PRC(""ACC""),""^"",3)"
^XMB(3.9,144662,2,365,0)="""RTN"",""PRCHCON1"",61,0)"
^XMB(3.9,144662,2,366,0)=" S $P(^PRCS(410,DA,3),""^"",11)=$P($$DATE^PRC0C(PRC(""BBFY""),""E""),""^"",7)"
^XMB(3.9,144662,2,367,0)="""RTN"",""PRCHCON1"",62,0)"
^XMB(3.9,144662,2,368,0)=" N MYY S MYY="""" D EN2B^PRCSUT3"
^XMB(3.9,144662,2,369,0)="""RTN"",""PRCHCON1"",63,0)"
^XMB(3.9,144662,2,370,0)=" D K^PRCSUT1 K T1(1)"
^XMB(3.9,144662,2,371,0)="""RTN"",""PRCHCON1"",64,0)"
^XMB(3.9,144662,2,372,0)=" L -^PRCS(410,DA)"
^XMB(3.9,144662,2,373,0)="""RTN"",""PRCHCON1"",65,0)"
^XMB(3.9,144662,2,374,0)=" D ^PRCHCON2 QUIT"
^XMB(3.9,144662,2,375,0)="""RTN"",""PRCHCON1"",66,0)"
^XMB(3.9,144662,2,376,0)=" ;;;;;;;;;;;;;;;;"
^XMB(3.9,144662,2,377,0)="""RTN"",""PRCHCON1"",67,0)"
^XMB(3.9,144662,2,378,0)="PRCFY I '$D(PRC(""FY"")) D NOW^%DTC S PRC(""FY"")=$E(X,2,3) S:$E(X,4,5)>9 PRC(""FY"")=$E(100+PRC(""FY"")+1,2,3)"
^XMB(3.9,144662,2,379,0)="""RTN"",""PRCHCON1"",68,0)"
^XMB(3.9,144662,2,380,0)=" S A=PRCSAPP I A[""_/_"" D FY2 G KILL"
^XMB(3.9,144662,2,381,0)="""RTN"",""PRCHCON1"",69,0)"
^XMB(3.9,144662,2,382,0)=" I A[""_"" S PRCSAPP=$P(A,""_"",1)_$E(PRC(""FY""),$L(PRC(""FY"")))_$P(A,""_"",2)"
^XMB(3.9,144662,2,383,0)="""RTN"",""PRCHCON1"",70,0)"
^XMB(3.9,144662,2,384,0)="KILL K %DT,A,B,RES,X Q"
^XMB(3.9,144662,2,385,0)="""RTN"",""PRCHCON1"",71,0)"
^XMB(3.9,144662,2,386,0)="FY2 ; two year appropriation"
^XMB(3.9,144662,2,387,0)="""RTN"",""PRCHCON1"",72,0)"
^XMB(3.9,144662,2,388,0)=" W !!,""Enter first year of this two year appropriation: "",PRC(""FY""),"" // "" R RES:DTIME G:RES[""^"" FY21 I RES[""?""!(RES'?.4N) W !,""Enter fiscal year in format '1' '81' or '1981'"",!! G FY2"
^XMB(3.9,144662,2,389,0)="""RTN"",""PRCHCON1"",73,0)"
^XMB(3.9,144662,2,390,0)="FY21 S:'RES RES=PRC(""FY"") S RES=$E(RES,$L(RES)),PRCSAPP=$P(A,""_"",1)_RES_""/""_(RES+1#10)_$P(A,""_"",3) Q"
^XMB(3.9,144662,2,391,0)="""RTN"",""PRCHCON1"",74,0)"
^XMB(3.9,144662,2,392,0)="W5 W !!,""You are not an authorized control point user."",!,""Contact your control point official."" R X:5"
^XMB(3.9,144662,2,393,0)="""RTN"",""PRCHCON1"",75,0)"
^XMB(3.9,144662,2,394,0)=" Q"
^XMB(3.9,144662,2,395,0)="""RTN"",""PRCHCON1"",76,0)"
^XMB(3.9,144662,2,396,0)="RBQTR N C,D S B="""",B=$S(B="""":$P(A,""-"",2)_""^F"",1:+$$DATE^PRC0C(B,""I"")),C=$$QTRDT^PRC0G($P(A,""-"",1)_""^""_$P(A,""-"",4)_""^""_B)"
^XMB(3.9,144662,2,397,0)="""RTN"",""PRCHCON1"",77,0)"
^XMB(3.9,144662,2,398,0)=" S D=$$QTRDATE^PRC0D($P(A,""-"",2),$P(A,""-"",3)),D=$P(D,""^"",7)"
^XMB(3.9,144662,2,399,0)="""RTN"",""PRCHCON1"",78,0)"
^XMB(3.9,144662,2,400,0)=" S B=$S(D<$P(C,""^"",3):$P(C,""^"",3),$P(C,""^"",2)<D:$P(C,""^"",2),1:D)"
^XMB(3.9,144662,2,401,0)="""RTN"",""PRCHCON1"",79,0)"
^XMB(3.9,144662,2,402,0)=" S B=""449////""_B_"";"""
