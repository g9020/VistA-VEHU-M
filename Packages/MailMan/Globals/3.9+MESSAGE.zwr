^XMB(3.9,144657,2,1083,0)="""RTN"",""IBCNBAA"",245,0)"
^XMB(3.9,144657,2,1084,0)=" ;"
^XMB(3.9,144657,2,1085,0)="""RTN"",""IBCNBAA"",246,0)"
^XMB(3.9,144657,2,1086,0)="OK() ; ask the user if the buffer data should be moved to the insurance files"
^XMB(3.9,144657,2,1087,0)="""RTN"",""IBCNBAA"",247,0)"
^XMB(3.9,144657,2,1088,0)=" ; returns 1 if yes, 0 otherwise"
^XMB(3.9,144657,2,1089,0)="""RTN"",""IBCNBAA"",248,0)"
^XMB(3.9,144657,2,1090,0)=" N DIR,X,Y,IBX S IBX=0 W !!!"
^XMB(3.9,144657,2,1091,0)="""RTN"",""IBCNBAA"",249,0)"
^XMB(3.9,144657,2,1092,0)=" S DIR(""?"")=""Enter Yes to accept/verify the buffer data and move it to the insurance files.  Enter No to stop this process."""
^XMB(3.9,144657,2,1093,0)="""RTN"",""IBCNBAA"",250,0)"
^XMB(3.9,144657,2,1094,0)=" S DIR(""?"",1)=""Entering Yes will cause several things to happen:"""
^XMB(3.9,144657,2,1095,0)="""RTN"",""IBCNBAA"",251,0)"
^XMB(3.9,144657,2,1096,0)=" S DIR(""?"",2)=""  1 - the above changes will be completed and the Insurance files updated with"""
^XMB(3.9,144657,2,1097,0)="""RTN"",""IBCNBAA"",252,0)"
^XMB(3.9,144657,2,1098,0)=" S DIR(""?"",3)=""      the buffer data."""
^XMB(3.9,144657,2,1099,0)="""RTN"",""IBCNBAA"",253,0)"
^XMB(3.9,144657,2,1100,0)=" S DIR(""?"",4)=""  2 - the Insurance entries modified or added will be flagged as verified."""
^XMB(3.9,144657,2,1101,0)="""RTN"",""IBCNBAA"",254,0)"
^XMB(3.9,144657,2,1102,0)=" S DIR(""?"",5)=""  3 - most of the insurance and patient related information in the buffer entry"""
^XMB(3.9,144657,2,1103,0)="""RTN"",""IBCNBAA"",255,0)"
^XMB(3.9,144657,2,1104,0)=" S DIR(""?"",6)=""      will be deleted, leaving only a stub entry for reporting purposes."",DIR(""?"",7)="""""
^XMB(3.9,144657,2,1105,0)="""RTN"",""IBCNBAA"",256,0)"
^XMB(3.9,144657,2,1106,0)=" S DIR(0)=""YO"",DIR(""A"")=""Is this Correct, update the existing Insurance files now"" D ^DIR I Y=1 S IBX=1"
^XMB(3.9,144657,2,1107,0)="""RTN"",""IBCNBAA"",257,0)"
^XMB(3.9,144657,2,1108,0)=" Q IBX"
^XMB(3.9,144657,2,1109,0)="""RTN"",""IBCNBAA"",258,0)"
^XMB(3.9,144657,2,1110,0)=" ;"
^XMB(3.9,144657,2,1111,0)="""RTN"",""IBCNBAA"",259,0)"
^XMB(3.9,144657,2,1112,0)="WAIT N DIR,DIRUT,DUOUT,DTOUT,X,Y W !! S DIR(0)=""E"",DIR(""A"")=""Enter RETURN to continue"" D ^DIR W !!"
^XMB(3.9,144657,2,1113,0)="""RTN"",""IBCNBAA"",260,0)"
