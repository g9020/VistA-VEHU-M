^XMB(3.9,145833,2,2589,0)="""RTN"",""SDESUTIL"",241,0)"
^XMB(3.9,145833,2,2590,0)="AMISTOSTOPCODE(AMIS) ; Map from AMIS to Stop Code"
^XMB(3.9,145833,2,2591,0)="""RTN"",""SDESUTIL"",242,0)"
^XMB(3.9,145833,2,2592,0)=" ; Input: AMIS = (Req) the AMIS REPORTING STOP CODE (#1) field from the CLINIC STOP (#40.7) file."
^XMB(3.9,145833,2,2593,0)="""RTN"",""SDESUTIL"",243,0)"
^XMB(3.9,145833,2,2594,0)=" ; Output: 0:validation failed, IEN for the Stop Code that matches to the passed in AMIS code."
^XMB(3.9,145833,2,2595,0)="""RTN"",""SDESUTIL"",244,0)"
^XMB(3.9,145833,2,2596,0)=" N STOPIEN,STOPINACTDT,STOPCOUNT,STOPFOUND"
^XMB(3.9,145833,2,2597,0)="""RTN"",""SDESUTIL"",245,0)"
^XMB(3.9,145833,2,2598,0)=" I '$G(AMIS) Q 0"
