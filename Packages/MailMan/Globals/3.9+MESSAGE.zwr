^XMB(3.9,145834,2,6364,0)=" . Q"
^XMB(3.9,145834,2,6365,0)="""RTN"",""MAGDSTAS"",72,0)"
^XMB(3.9,145834,2,6366,0)=" D CONTINUE^MAGDSTQ"
^XMB(3.9,145834,2,6367,0)="""RTN"",""MAGDSTAS"",73,0)"
^XMB(3.9,145834,2,6368,0)=" K ^TMP(""MAG"",$J,""BATCH Q/R"",""DATE""),^(""NUMBER"")"
^XMB(3.9,145834,2,6369,0)="""RTN"",""MAGDSTAS"",74,0)"
^XMB(3.9,145834,2,6370,0)=" Q"
^XMB(3.9,145834,2,6371,0)="""RTN"",""MAGDSTAS"",75,0)"
^XMB(3.9,145834,2,6372,0)=" ;"
^XMB(3.9,145834,2,6373,0)="""RTN"",""MAGDSTAS"",76,0)"
^XMB(3.9,145834,2,6374,0)="OPTION(MENUOPTION,S2) ; output statistics for all runs for one option/scan mode"
^XMB(3.9,145834,2,6375,0)="""RTN"",""MAGDSTAS"",77,0)"
^XMB(3.9,145834,2,6376,0)=" N HDATE1,HDATE2,I,MAXLENGTH,OPTIONIEN,OPTIONNAME,RUNNUMBER,STATS"
^XMB(3.9,145834,2,6377,0)="""RTN"",""MAGDSTAS"",78,0)"
^XMB(3.9,145834,2,6378,0)=" ;"
^XMB(3.9,145834,2,6379,0)="""RTN"",""MAGDSTAS"",79,0)"
^XMB(3.9,145834,2,6380,0)=" S SCANMODE=$S(S2=""D"":""DATE"",S2=""N"":""NUMBER"",S2=""P"":""PATIENT"")"
^XMB(3.9,145834,2,6381,0)="""RTN"",""MAGDSTAS"",80,0)"
^XMB(3.9,145834,2,6382,0)=" ;"
^XMB(3.9,145834,2,6383,0)="""RTN"",""MAGDSTAS"",81,0)"
^XMB(3.9,145834,2,6384,0)=" I SCANMODE=""DATE"" D  ; build list of $H dates"
^XMB(3.9,145834,2,6385,0)="""RTN"",""MAGDSTAS"",82,0)"
^XMB(3.9,145834,2,6386,0)=" . S HDATE1=+$$FMTH^XLFDT(2900000) ; $H format of FM date Jan 1, 1990"
^XMB(3.9,145834,2,6387,0)="""RTN"",""MAGDSTAS"",83,0)"
^XMB(3.9,145834,2,6388,0)=" . S HDATE2=+$H ; today"
^XMB(3.9,145834,2,6389,0)="""RTN"",""MAGDSTAS"",84,0)"
^XMB(3.9,145834,2,6390,0)=" . F I=HDATE1:1:HDATE2 S ^TMP(""MAG"",$J,""BATCH Q/R"",""DATE"",I)="""""
^XMB(3.9,145834,2,6391,0)="""RTN"",""MAGDSTAS"",85,0)"
^XMB(3.9,145834,2,6392,0)=" . Q"
^XMB(3.9,145834,2,6393,0)="""RTN"",""MAGDSTAS"",86,0)"
^XMB(3.9,145834,2,6394,0)=" E  I SCANMODE=""NUMBER"" D"
^XMB(3.9,145834,2,6395,0)="""RTN"",""MAGDSTAS"",87,0)"
^XMB(3.9,145834,2,6396,0)=" . ;"
^XMB(3.9,145834,2,6397,0)="""RTN"",""MAGDSTAS"",88,0)"
^XMB(3.9,145834,2,6398,0)=" . Q"
^XMB(3.9,145834,2,6399,0)="""RTN"",""MAGDSTAS"",89,0)"
^XMB(3.9,145834,2,6400,0)=" ;"
^XMB(3.9,145834,2,6401,0)="""RTN"",""MAGDSTAS"",90,0)"
^XMB(3.9,145834,2,6402,0)=" S OPTIONIEN=$$FIND1^DIC(19,"""",""B"",MENUOPTION)"
^XMB(3.9,145834,2,6403,0)="""RTN"",""MAGDSTAS"",91,0)"
^XMB(3.9,145834,2,6404,0)=" S OPTIONNAME=$$GET1^DIQ(19,OPTIONIEN,1,""E"")"
^XMB(3.9,145834,2,6405,0)="""RTN"",""MAGDSTAS"",92,0)"
^XMB(3.9,145834,2,6406,0)=" W @IOF,OPTIONNAME,"" -- "",SCANMODE,"" scan"""
^XMB(3.9,145834,2,6407,0)="""RTN"",""MAGDSTAS"",93,0)"
^XMB(3.9,145834,2,6408,0)=" ;"
^XMB(3.9,145834,2,6409,0)="""RTN"",""MAGDSTAS"",94,0)"
^XMB(3.9,145834,2,6410,0)=" ; collect statistics"
^XMB(3.9,145834,2,6411,0)="""RTN"",""MAGDSTAS"",95,0)"
^XMB(3.9,145834,2,6412,0)=" ;"
^XMB(3.9,145834,2,6413,0)="""RTN"",""MAGDSTAS"",96,0)"
^XMB(3.9,145834,2,6414,0)=" S (MAXLENGTH,RUNNUMBER,STATS)=0"
^XMB(3.9,145834,2,6415,0)="""RTN"",""MAGDSTAS"",97,0)"
^XMB(3.9,145834,2,6416,0)=" F  S RUNNUMBER=$O(^MAGDSTT(2006.543,""C"",MENUOPTION,S2,RUNNUMBER)) Q:RUNNUMBER=""""  D"
^XMB(3.9,145834,2,6417,0)="""RTN"",""MAGDSTAS"",98,0)"
^XMB(3.9,145834,2,6418,0)=" . D GETDATA(RUNNUMBER,.STATS)"
^XMB(3.9,145834,2,6419,0)="""RTN"",""MAGDSTAS"",99,0)"
^XMB(3.9,145834,2,6420,0)=" . Q"
^XMB(3.9,145834,2,6421,0)="""RTN"",""MAGDSTAS"",100,0)"
^XMB(3.9,145834,2,6422,0)=" ;"
^XMB(3.9,145834,2,6423,0)="""RTN"",""MAGDSTAS"",101,0)"
^XMB(3.9,145834,2,6424,0)=" ; display statistics"
^XMB(3.9,145834,2,6425,0)="""RTN"",""MAGDSTAS"",102,0)"
^XMB(3.9,145834,2,6426,0)=" ;"
^XMB(3.9,145834,2,6427,0)="""RTN"",""MAGDSTAS"",103,0)"
