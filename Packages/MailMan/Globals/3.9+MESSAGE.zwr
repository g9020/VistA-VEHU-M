^XMB(3.9,145833,2,771,0)="""RTN"",""SDES2UTDT"",30,0)"
^XMB(3.9,145833,2,772,0)=" .D GETTZOFFSET^SDES2UTIL(.OFFSET,SDFMDT,1,SDCLINIC)"
^XMB(3.9,145833,2,773,0)="""RTN"",""SDES2UTDT"",31,0)"
