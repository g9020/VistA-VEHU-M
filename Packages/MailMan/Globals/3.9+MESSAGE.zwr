^XMB(3.9,144654,2,497,0)="""RTN"",""PSOHLDS2"",129,0)"
^XMB(3.9,144654,2,498,0)=" I $L(NT1)>245 S LTH=$E($L(NT1)/245,1) S:$L(NT1)#245>0 LTH=LTH+1 F WW=1:1:LTH D"
^XMB(3.9,144654,2,499,0)="""RTN"",""PSOHLDS2"",130,0)"
^XMB(3.9,144654,2,500,0)=" . S:WW=1 ST=1,EN=245 S:WW>1 ST=(ST+245),EN=(EN+245) S NT11=$E(NT1,ST,EN)"
^XMB(3.9,144654,2,501,0)="""RTN"",""PSOHLDS2"",131,0)"
