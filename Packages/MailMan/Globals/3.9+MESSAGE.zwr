^XMB(3.9,144657,2,5195,0)="""RTN"",""IBCNEQU"",244,0)"
^XMB(3.9,144657,2,5196,0)=" ; IB*582/HN - Modified Default Service Type Code to pull from the MCCF Billing Parameters File (350.9,60.01)"
^XMB(3.9,144657,2,5197,0)="""RTN"",""IBCNEQU"",245,0)"
^XMB(3.9,144657,2,5198,0)=" N DIR,X,Y"
^XMB(3.9,144657,2,5199,0)="""RTN"",""IBCNEQU"",246,0)"
^XMB(3.9,144657,2,5200,0)=" ; IBEISTC used as STC variable"
^XMB(3.9,144657,2,5201,0)="""RTN"",""IBCNEQU"",247,0)"
^XMB(3.9,144657,2,5202,0)=" S IBEISTC="""""
^XMB(3.9,144657,2,5203,0)="""RTN"",""IBCNEQU"",248,0)"
^XMB(3.9,144657,2,5204,0)=" S DIR(0)=""PAO^365.013:EMZ"",DIR(""A"")=""Enter Service Type Code: """
^XMB(3.9,144657,2,5205,0)="""RTN"",""IBCNEQU"",249,0)"
^XMB(3.9,144657,2,5206,0)=" S DIR(""B"")=$$GET1^DIQ(350.9,1_"","",60.01,""E"")"
^XMB(3.9,144657,2,5207,0)="""RTN"",""IBCNEQU"",250,0)"
^XMB(3.9,144657,2,5208,0)=" S DIR(""??"")=""^D HELPSTC2^IBCNEQU"""
^XMB(3.9,144657,2,5209,0)="""RTN"",""IBCNEQU"",251,0)"
^XMB(3.9,144657,2,5210,0)="STCEN ; Intital and re-enterant tag upon error"
^XMB(3.9,144657,2,5211,0)="""RTN"",""IBCNEQU"",252,0)"
^XMB(3.9,144657,2,5212,0)=" D ^DIR Q:X=""^"""
^XMB(3.9,144657,2,5213,0)="""RTN"",""IBCNEQU"",253,0)"
^XMB(3.9,144657,2,5214,0)=" ; Check to verify code is active, if not, display error and ask again"
^XMB(3.9,144657,2,5215,0)="""RTN"",""IBCNEQU"",254,0)"
^XMB(3.9,144657,2,5216,0)=" I $P($G(Y(0)),U,3)'="""" W !,""Code selected is not an active code - please select another code."",! G STCEN"
^XMB(3.9,144657,2,5217,0)="""RTN"",""IBCNEQU"",255,0)"
^XMB(3.9,144657,2,5218,0)=" ; If valid STC entered, set IBEISTC to be STC IEN. If no code entered, default to service code 30"
^XMB(3.9,144657,2,5219,0)="""RTN"",""IBCNEQU"",256,0)"
^XMB(3.9,144657,2,5220,0)=" ;S IBEISTC=$S(+Y>0:$P(Y,U,1),1:$O(^IBE(365.013,""B"",30,"""")))"
^XMB(3.9,144657,2,5221,0)="""RTN"",""IBCNEQU"",257,0)"
^XMB(3.9,144657,2,5222,0)=" ; If valid STC entered, set IBEISTC to be STCIEN."
^XMB(3.9,144657,2,5223,0)="""RTN"",""IBCNEQU"",258,0)"
^XMB(3.9,144657,2,5224,0)=" S IBEISTC=$P(Y,U,1)"
^XMB(3.9,144657,2,5225,0)="""RTN"",""IBCNEQU"",259,0)"
^XMB(3.9,144657,2,5226,0)=" Q"
^XMB(3.9,144657,2,5227,0)="""RTN"",""IBCNEQU"",260,0)"
^XMB(3.9,144657,2,5228,0)=" ;"
^XMB(3.9,144657,2,5229,0)="""RTN"",""IBCNEQU"",261,0)"
^XMB(3.9,144657,2,5230,0)="FASTEXIT ; Sets flag to indicate a quick exit from the option"
^XMB(3.9,144657,2,5231,0)="""RTN"",""IBCNEQU"",262,0)"
^XMB(3.9,144657,2,5232,0)=" N DIR,DIRUT,X,Y"
^XMB(3.9,144657,2,5233,0)="""RTN"",""IBCNEQU"",263,0)"
^XMB(3.9,144657,2,5234,0)=" S VALMBCK=""Q"""
^XMB(3.9,144657,2,5235,0)="""RTN"",""IBCNEQU"",264,0)"
^XMB(3.9,144657,2,5236,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,5237,0)="""RTN"",""IBCNEQU"",265,0)"
^XMB(3.9,144657,2,5238,0)=" S DIR(0)=""Y"",DIR(""A"")=""Exit option entirely"",DIR(""B"")=""NO"""
^XMB(3.9,144657,2,5239,0)="""RTN"",""IBCNEQU"",266,0)"
^XMB(3.9,144657,2,5240,0)=" D ^DIR"
^XMB(3.9,144657,2,5241,0)="""RTN"",""IBCNEQU"",267,0)"
^XMB(3.9,144657,2,5242,0)=" I +Y S IBFASTXT=1"
^XMB(3.9,144657,2,5243,0)="""RTN"",""IBCNEQU"",268,0)"
^XMB(3.9,144657,2,5244,0)=" Q"
^XMB(3.9,144657,2,5245,0)="""RTN"",""IBCNEQU"",269,0)"
^XMB(3.9,144657,2,5246,0)=" ;"
^XMB(3.9,144657,2,5247,0)="""RTN"",""IBCNEQU"",270,0)"
^XMB(3.9,144657,2,5248,0)="HELPSTC2 ; Text to display in response to '??' entry"
^XMB(3.9,144657,2,5249,0)="""RTN"",""IBCNEQU"",271,0)"
^XMB(3.9,144657,2,5250,0)=" N DIR"
^XMB(3.9,144657,2,5251,0)="""RTN"",""IBCNEQU"",272,0)"
^XMB(3.9,144657,2,5252,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,5253,0)="""RTN"",""IBCNEQU"",273,0)"
^XMB(3.9,144657,2,5254,0)=" W @IOF"
^XMB(3.9,144657,2,5255,0)="""RTN"",""IBCNEQU"",274,0)"
^XMB(3.9,144657,2,5256,0)=" ;IB*732/DTG start - change help text to reflect code is dictionary driven"
^XMB(3.9,144657,2,5257,0)="""RTN"",""IBCNEQU"",275,0)"
^XMB(3.9,144657,2,5258,0)=" W !,""Enter the single SERVICE TYPE CODE to be sent with inquiry or press"""
^XMB(3.9,144657,2,5259,0)="""RTN"",""IBCNEQU"",276,0)"
^XMB(3.9,144657,2,5260,0)=" W !,""'ENTER' to send default service type code. The default service type"""
^XMB(3.9,144657,2,5261,0)="""RTN"",""IBCNEQU"",277,0)"
^XMB(3.9,144657,2,5262,0)=" W !,""code may auto-update. All other service types will not auto-update."""
^XMB(3.9,144657,2,5263,0)="""RTN"",""IBCNEQU"",278,0)"
^XMB(3.9,144657,2,5264,0)=" ;IB*732/DTG end - change help text to reflect code is dictionary driven"
^XMB(3.9,144657,2,5265,0)="""RTN"",""IBCNEQU"",279,0)"
^XMB(3.9,144657,2,5266,0)=" Q"
^XMB(3.9,144657,2,5267,0)="""RTN"",""IBCNEQU"",280,0)"
^XMB(3.9,144657,2,5268,0)=" ;"
^XMB(3.9,144657,2,5269,0)="""RTN"",""IBCNEQU"",281,0)"
^XMB(3.9,144657,2,5270,0)="ELIGDT() ; Prompt user for eligibility date"
^XMB(3.9,144657,2,5271,0)="""RTN"",""IBCNEQU"",282,0)"
^XMB(3.9,144657,2,5272,0)=" N DIR,X,Y,DIRUT,DUOUT,STARTDT,ENDDT,ELIGDT"
^XMB(3.9,144657,2,5273,0)="""RTN"",""IBCNEQU"",283,0)"
^XMB(3.9,144657,2,5274,0)=" S ELIGDT="""""
^XMB(3.9,144657,2,5275,0)="""RTN"",""IBCNEQU"",284,0)"
^XMB(3.9,144657,2,5276,0)=" D DT^DILF(,""T-12M"",.STARTDT) ; start date within the last 12 months"
^XMB(3.9,144657,2,5277,0)="""RTN"",""IBCNEQU"",285,0)"
^XMB(3.9,144657,2,5278,0)=" ; allow end date up to the end of the current month"
^XMB(3.9,144657,2,5279,0)="""RTN"",""IBCNEQU"",286,0)"
^XMB(3.9,144657,2,5280,0)=" S ENDDT=$$SCH^XLFDT(""1M(L@1A)"",DT)\1 ; ICR#10103 this call returns the last day of the current month at 1 AM.  If not time was sent, it would actually return the next to last day at 2400 hours."
^XMB(3.9,144657,2,5281,0)="""RTN"",""IBCNEQU"",287,0)"
^XMB(3.9,144657,2,5282,0)=" S DIR(0)=""DA^""_STARTDT_"":""_ENDDT_"":""_""EX"",DIR(""A"")=""Enter Eligibility Date: "",DIR(""B"")=""TODAY"""
^XMB(3.9,144657,2,5283,0)="""RTN"",""IBCNEQU"",288,0)"
^XMB(3.9,144657,2,5284,0)=" S DIR(""?"",1)=""Select an eligibility date to be sent in the inquiry."""
^XMB(3.9,144657,2,5285,0)="""RTN"",""IBCNEQU"",289,0)"
^XMB(3.9,144657,2,5286,0)=" S DIR(""?"")=""Date must be within the last 12 months or up to the end of the current month."""
^XMB(3.9,144657,2,5287,0)="""RTN"",""IBCNEQU"",290,0)"
^XMB(3.9,144657,2,5288,0)=" D ^DIR"
^XMB(3.9,144657,2,5289,0)="""RTN"",""IBCNEQU"",291,0)"
^XMB(3.9,144657,2,5290,0)=" I $D(DIRUT)!$D(DUOUT)!('Y) G ELIGDTX"
^XMB(3.9,144657,2,5291,0)="""RTN"",""IBCNEQU"",292,0)"
^XMB(3.9,144657,2,5292,0)=" S ELIGDT=Y"
^XMB(3.9,144657,2,5293,0)="""RTN"",""IBCNEQU"",293,0)"
^XMB(3.9,144657,2,5294,0)="ELIGDTX ; "
^XMB(3.9,144657,2,5295,0)="""RTN"",""IBCNEQU"",294,0)"
^XMB(3.9,144657,2,5296,0)=" Q ELIGDT"
^XMB(3.9,144657,2,5297,0)="""RTN"",""IBCNEQU"",295,0)"
^XMB(3.9,144657,2,5298,0)=" ;"
^XMB(3.9,144657,2,5299,0)="""RTN"",""IBCNEQU"",296,0)"
^XMB(3.9,144657,2,5300,0)="MBIREQ ; User requested a MBI lookup request"
^XMB(3.9,144657,2,5301,0)="""RTN"",""IBCNEQU"",297,0)"
^XMB(3.9,144657,2,5302,0)=" ;/vd-IB*2*668 - Added the variable APIEN"
^XMB(3.9,144657,2,5303,0)="""RTN"",""IBCNEQU"",298,0)"
^XMB(3.9,144657,2,5304,0)=" N APIEN,DIR,X,Y,DIRUT,DUOUT"
^XMB(3.9,144657,2,5305,0)="""RTN"",""IBCNEQU"",299,0)"
^XMB(3.9,144657,2,5306,0)=" N IBMBIPYR,IBBUF,IBFDA"
^XMB(3.9,144657,2,5307,0)="""RTN"",""IBCNEQU"",300,0)"
^XMB(3.9,144657,2,5308,0)=" ;"
^XMB(3.9,144657,2,5309,0)="""RTN"",""IBCNEQU"",301,0)"
^XMB(3.9,144657,2,5310,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,5311,0)="""RTN"",""IBCNEQU"",302,0)"
^XMB(3.9,144657,2,5312,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,5313,0)="""RTN"",""IBCNEQU"",303,0)"
^XMB(3.9,144657,2,5314,0)=" K DIR"
^XMB(3.9,144657,2,5315,0)="""RTN"",""IBCNEQU"",304,0)"
^XMB(3.9,144657,2,5316,0)=" ;"
^XMB(3.9,144657,2,5317,0)="""RTN"",""IBCNEQU"",305,0)"
^XMB(3.9,144657,2,5318,0)=" ; see if the MBI PAYER site parameter has been populated "
^XMB(3.9,144657,2,5319,0)="""RTN"",""IBCNEQU"",306,0)"
^XMB(3.9,144657,2,5320,0)=" S IBMBIPYR=+$$GET1^DIQ(350.9,""1,"",""MBI PAYER"",""I"")"
^XMB(3.9,144657,2,5321,0)="""RTN"",""IBCNEQU"",307,0)"
^XMB(3.9,144657,2,5322,0)=" I 'IBMBIPYR D  G MBIREQX"
^XMB(3.9,144657,2,5323,0)="""RTN"",""IBCNEQU"",308,0)"
^XMB(3.9,144657,2,5324,0)=" . W !!,"" The required MBI Payer site parameter is not populated; try again later"",!"
^XMB(3.9,144657,2,5325,0)="""RTN"",""IBCNEQU"",309,0)"
^XMB(3.9,144657,2,5326,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144657,2,5327,0)="""RTN"",""IBCNEQU"",310,0)"
^XMB(3.9,144657,2,5328,0)=" ;"
^XMB(3.9,144657,2,5329,0)="""RTN"",""IBCNEQU"",311,0)"
^XMB(3.9,144657,2,5330,0)=" S APIEN=$$PYRAPP^IBCNEUT5(""EIV"",IBMBIPYR)   ;/vd-IB*2*668"
^XMB(3.9,144657,2,5331,0)="""RTN"",""IBCNEQU"",312,0)"
^XMB(3.9,144657,2,5332,0)=" ;/vd-IB*2*668 - Replaced the following 2 lines of code to remove a hardcoded value."
^XMB(3.9,144657,2,5333,0)="""RTN"",""IBCNEQU"",313,0)"
^XMB(3.9,144657,2,5334,0)=" ;I '($$GET1^DIQ(365.121,""1,""_IBMBIPYR_"","",.02,""I"")) D  G MBIREQX"
^XMB(3.9,144657,2,5335,0)="""RTN"",""IBCNEQU"",314,0)"
^XMB(3.9,144657,2,5336,0)=" ;. W !!,"" The MBI Payer is not nationally active; try again later"",!"
^XMB(3.9,144657,2,5337,0)="""RTN"",""IBCNEQU"",315,0)"
^XMB(3.9,144657,2,5338,0)=" I '($$GET1^DIQ(365.121,APIEN_"",""_IBMBIPYR_"","",.02,""I"")) D  G MBIREQX"
^XMB(3.9,144657,2,5339,0)="""RTN"",""IBCNEQU"",316,0)"
^XMB(3.9,144657,2,5340,0)=" . W !!,"" The MBI Payer is not NATIONALLY Enabled; try again later"",!"
^XMB(3.9,144657,2,5341,0)="""RTN"",""IBCNEQU"",317,0)"
^XMB(3.9,144657,2,5342,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144657,2,5343,0)="""RTN"",""IBCNEQU"",318,0)"
^XMB(3.9,144657,2,5344,0)=" ;"
^XMB(3.9,144657,2,5345,0)="""RTN"",""IBCNEQU"",319,0)"
^XMB(3.9,144657,2,5346,0)=" ;/vd-IB*2*668 - Replaced the following 2 lines of code to remove a hardcoded value."
^XMB(3.9,144657,2,5347,0)="""RTN"",""IBCNEQU"",320,0)"
^XMB(3.9,144657,2,5348,0)=" ;I '($$GET1^DIQ(365.121,""1,""_IBMBIPYR_"","",.03,""I"")) D  G MBIREQX"
^XMB(3.9,144657,2,5349,0)="""RTN"",""IBCNEQU"",321,0)"
^XMB(3.9,144657,2,5350,0)=" ;. W !!,"" The MBI Payer LOCAL ACTIVE field is set to 'NO'; it must be 'YES' to proceed"",!"
^XMB(3.9,144657,2,5351,0)="""RTN"",""IBCNEQU"",322,0)"
^XMB(3.9,144657,2,5352,0)=" I '($$GET1^DIQ(365.121,APIEN_"",""_IBMBIPYR_"","",.03,""I"")) D  G MBIREQX"
^XMB(3.9,144657,2,5353,0)="""RTN"",""IBCNEQU"",323,0)"
^XMB(3.9,144657,2,5354,0)=" . W !!,"" The MBI Payer is not LOCALLY Enabled; try again later"",!"
^XMB(3.9,144657,2,5355,0)="""RTN"",""IBCNEQU"",324,0)"
^XMB(3.9,144657,2,5356,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144657,2,5357,0)="""RTN"",""IBCNEQU"",325,0)"
^XMB(3.9,144657,2,5358,0)=" ;"
^XMB(3.9,144657,2,5359,0)="""RTN"",""IBCNEQU"",326,0)"
^XMB(3.9,144657,2,5360,0)=" D DEM^VADPT ; ; ICR#10061"
^XMB(3.9,144657,2,5361,0)="""RTN"",""IBCNEQU"",327,0)"
^XMB(3.9,144657,2,5362,0)=" I ($P(VADM(2),U)="""")!($P(VADM(3),U)="""") D  G MBIREQX"
^XMB(3.9,144657,2,5363,0)="""RTN"",""IBCNEQU"",328,0)"
^XMB(3.9,144657,2,5364,0)=" . W !!,"" SSN and DOB are required fields, they must be populated in order to proceed"",!"
^XMB(3.9,144657,2,5365,0)="""RTN"",""IBCNEQU"",329,0)"
^XMB(3.9,144657,2,5366,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144657,2,5367,0)="""RTN"",""IBCNEQU"",330,0)"
^XMB(3.9,144657,2,5368,0)=" ; "
^XMB(3.9,144657,2,5369,0)="""RTN"",""IBCNEQU"",331,0)"
^XMB(3.9,144657,2,5370,0)=" S DIR(0)=""Y"""
^XMB(3.9,144657,2,5371,0)="""RTN"",""IBCNEQU"",332,0)"
^XMB(3.9,144657,2,5372,0)=" S DIR(""A"")=""Are you sure you want to request this Patient's Medicare Beneficiary ID"""
^XMB(3.9,144657,2,5373,0)="""RTN"",""IBCNEQU"",333,0)"
^XMB(3.9,144657,2,5374,0)=" S DIR(""B"")=""YES"""
^XMB(3.9,144657,2,5375,0)="""RTN"",""IBCNEQU"",334,0)"
^XMB(3.9,144657,2,5376,0)=" S DIR(""?"",1)=""  If yes, a MBI request will be initiated immediately."""
^XMB(3.9,144657,2,5377,0)="""RTN"",""IBCNEQU"",335,0)"
^XMB(3.9,144657,2,5378,0)=" S DIR(""?"")=""  If no, the MBI request will be cancelled."""
^XMB(3.9,144657,2,5379,0)="""RTN"",""IBCNEQU"",336,0)"
^XMB(3.9,144657,2,5380,0)=" D ^DIR K DIR"
^XMB(3.9,144657,2,5381,0)="""RTN"",""IBCNEQU"",337,0)"
^XMB(3.9,144657,2,5382,0)=" I $D(DIRUT)!$D(DUOUT)!('Y) G MBIREQX"
^XMB(3.9,144657,2,5383,0)="""RTN"",""IBCNEQU"",338,0)"
^XMB(3.9,144657,2,5384,0)=" ;"
^XMB(3.9,144657,2,5385,0)="""RTN"",""IBCNEQU"",339,0)"
^XMB(3.9,144657,2,5386,0)=" ;write a buffer entry "
^XMB(3.9,144657,2,5387,0)="""RTN"",""IBCNEQU"",340,0)"
^XMB(3.9,144657,2,5388,0)=" ;the real time process will set the patient relationship to self automatically"
^XMB(3.9,144657,2,5389,0)="""RTN"",""IBCNEQU"",341,0)"
^XMB(3.9,144657,2,5390,0)=" ;patient fields, name, dob and ssn will be populated automatically"
^XMB(3.9,144657,2,5391,0)="""RTN"",""IBCNEQU"",342,0)"
^XMB(3.9,144657,2,5392,0)=" K IBBUF"
^XMB(3.9,144657,2,5393,0)="""RTN"",""IBCNEQU"",343,0)"
^XMB(3.9,144657,2,5394,0)=" S IBBUF(.02)=DUZ  ; Entered By"
^XMB(3.9,144657,2,5395,0)="""RTN"",""IBCNEQU"",344,0)"
^XMB(3.9,144657,2,5396,0)=" S IBBUF(.12)=$P($$PAYER^IBCNEUT4(IBMBIPYR),U) ; Buffer Symbol "
^XMB(3.9,144657,2,5397,0)="""RTN"",""IBCNEQU"",345,0)"
^XMB(3.9,144657,2,5398,0)=" S IBBUF(20.01)=$$GET1^DIQ(350.9,""1,"",""MBI PAYER"",""E"")"
^XMB(3.9,144657,2,5399,0)="""RTN"",""IBCNEQU"",346,0)"
^XMB(3.9,144657,2,5400,0)=" S IBBUF(60.01)=DFN ; Patient IEN"
^XMB(3.9,144657,2,5401,0)="""RTN"",""IBCNEQU"",347,0)"
^XMB(3.9,144657,2,5402,0)=" S IBBUF(90.03)=""MBIrequest"" ; MBI placeholder for subscriber ID"
^XMB(3.9,144657,2,5403,0)="""RTN"",""IBCNEQU"",348,0)"
^XMB(3.9,144657,2,5404,0)=" S IBBUF(91.01)=VADM(1) ; patient (subscriber) name "
^XMB(3.9,144657,2,5405,0)="""RTN"",""IBCNEQU"",349,0)"
^XMB(3.9,144657,2,5406,0)=" ; the following call in-turn, calls EDITSTF^IBCNBES which will make sure to file subscriber ID last, automatically"
^XMB(3.9,144657,2,5407,0)="""RTN"",""IBCNEQU"",350,0)"
^XMB(3.9,144657,2,5408,0)=" S IBFDA=$$ADDSTF^IBCNBES($$FIND1^DIC(355.12,,,""MEDICARE"",""C""),DFN,.IBBUF)"
^XMB(3.9,144657,2,5409,0)="""RTN"",""IBCNEQU"",351,0)"
^XMB(3.9,144657,2,5410,0)=" ;"
^XMB(3.9,144657,2,5411,0)="""RTN"",""IBCNEQU"",352,0)"
^XMB(3.9,144657,2,5412,0)=" W !!,""The MBI request was successful, check the buffer for results."",!"
^XMB(3.9,144657,2,5413,0)="""RTN"",""IBCNEQU"",353,0)"
^XMB(3.9,144657,2,5414,0)=" S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144657,2,5415,0)="""RTN"",""IBCNEQU"",354,0)"
^XMB(3.9,144657,2,5416,0)=" S VALMBCK=""Q"""
^XMB(3.9,144657,2,5417,0)="""RTN"",""IBCNEQU"",355,0)"
^XMB(3.9,144657,2,5418,0)=" Q"
^XMB(3.9,144657,2,5419,0)="""RTN"",""IBCNEQU"",356,0)"
^XMB(3.9,144657,2,5420,0)="MBIREQX ;"
^XMB(3.9,144657,2,5421,0)="""RTN"",""IBCNEQU"",357,0)"
^XMB(3.9,144657,2,5422,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,5423,0)="""RTN"",""IBCNEQU"",358,0)"
^XMB(3.9,144657,2,5424,0)=" Q"
^XMB(3.9,144657,2,5425,0)="""RTN"",""IBCNEQU"",359,0)"
^XMB(3.9,144657,2,5426,0)=" ;"
^XMB(3.9,144657,2,5427,0)="""RTN"",""IBCNERTC"")"
^XMB(3.9,144657,2,5428,0)="0^4^B9367965"
^XMB(3.9,144657,2,5429,0)="""RTN"",""IBCNERTC"",1,0)"
^XMB(3.9,144657,2,5430,0)="IBCNERTC ;AITC/HN - Covered by Health Insurance ;03-MAR-2017"
^XMB(3.9,144657,2,5431,0)="""RTN"",""IBCNERTC"",2,0)"
^XMB(3.9,144657,2,5432,0)=" ;;2.0;INTEGRATED BILLING;**593**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,5433,0)="""RTN"",""IBCNERTC"",3,0)"
^XMB(3.9,144657,2,5434,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,5435,0)="""RTN"",""IBCNERTC"",4,0)"
^XMB(3.9,144657,2,5436,0)=" ;"
^XMB(3.9,144657,2,5437,0)="""RTN"",""IBCNERTC"",5,0)"
^XMB(3.9,144657,2,5438,0)=" ;**Program Description**"
^XMB(3.9,144657,2,5439,0)="""RTN"",""IBCNERTC"",6,0)"
^XMB(3.9,144657,2,5440,0)=" ;  This program will loop through the ACHI Index of the Patient (2) file to update the "
^XMB(3.9,144657,2,5441,0)="""RTN"",""IBCNERTC"",7,0)"
^XMB(3.9,144657,2,5442,0)=" ;  Covered by Health Insurance (2.3192) field based on current active policies."
^XMB(3.9,144657,2,5443,0)="""RTN"",""IBCNERTC"",8,0)"
^XMB(3.9,144657,2,5444,0)=" ;"
^XMB(3.9,144657,2,5445,0)="""RTN"",""IBCNERTC"",9,0)"
^XMB(3.9,144657,2,5446,0)=" ;  This option is designed to run through TaskMan after midnight.  It shouldn't take long since there"
^XMB(3.9,144657,2,5447,0)="""RTN"",""IBCNERTC"",10,0)"
^XMB(3.9,144657,2,5448,0)=" ;  should not be many entries in the ACHI index per day."
^XMB(3.9,144657,2,5449,0)="""RTN"",""IBCNERTC"",11,0)"
^XMB(3.9,144657,2,5450,0)=" ;"
^XMB(3.9,144657,2,5451,0)="""RTN"",""IBCNERTC"",12,0)"
^XMB(3.9,144657,2,5452,0)=" ;  UPATF should be used with care since it will process the entire Patient File"
^XMB(3.9,144657,2,5453,0)="""RTN"",""IBCNERTC"",13,0)"
^XMB(3.9,144657,2,5454,0)=" ;"
^XMB(3.9,144657,2,5455,0)="""RTN"",""IBCNERTC"",14,0)"
^XMB(3.9,144657,2,5456,0)=" Q"
^XMB(3.9,144657,2,5457,0)="""RTN"",""IBCNERTC"",15,0)"
^XMB(3.9,144657,2,5458,0)=" ;"
^XMB(3.9,144657,2,5459,0)="""RTN"",""IBCNERTC"",16,0)"
^XMB(3.9,144657,2,5460,0)="EN(IBDT) ;From Taskman nightly job.  Call from label TASK."
^XMB(3.9,144657,2,5461,0)="""RTN"",""IBCNERTC"",17,0)"
^XMB(3.9,144657,2,5462,0)=" N DFN"
^XMB(3.9,144657,2,5463,0)="""RTN"",""IBCNERTC"",18,0)"
^XMB(3.9,144657,2,5464,0)=" S DFN="""""
^XMB(3.9,144657,2,5465,0)="""RTN"",""IBCNERTC"",19,0)"
^XMB(3.9,144657,2,5466,0)=" F  S DFN=$O(^DPT(""ACHI"",IBDT,DFN)) Q:'DFN  D INS(DFN,IBDT)"
^XMB(3.9,144657,2,5467,0)="""RTN"",""IBCNERTC"",20,0)"
^XMB(3.9,144657,2,5468,0)=" Q"
^XMB(3.9,144657,2,5469,0)="""RTN"",""IBCNERTC"",21,0)"
^XMB(3.9,144657,2,5470,0)=" ;"
^XMB(3.9,144657,2,5471,0)="""RTN"",""IBCNERTC"",22,0)"
^XMB(3.9,144657,2,5472,0)="INS(DFN,IBDT) ;Check insurance"
^XMB(3.9,144657,2,5473,0)="""RTN"",""IBCNERTC"",23,0)"
^XMB(3.9,144657,2,5474,0)=" N DA,DIE,IBCOV,IBIND,IBINS,IBNCOV,DR,IBINSD,IENS,EFFDT,IBIENS,DEFIND,IBIEN,IBSYM"
^XMB(3.9,144657,2,5475,0)="""RTN"",""IBCNERTC"",24,0)"
^XMB(3.9,144657,2,5476,0)=" S (IBCOV,IBNCOV)=$$GET1^DIQ(2,DFN_"","",""COVERED BY HEALTH INSURANCE?"",""I"")"
^XMB(3.9,144657,2,5477,0)="""RTN"",""IBCNERTC"",25,0)"
^XMB(3.9,144657,2,5478,0)=" D ALL^IBCNS1(DFN,""IBINS"",2,IBDT) S IBINSD=+$G(IBINS(0))"
^XMB(3.9,144657,2,5479,0)="""RTN"",""IBCNERTC"",26,0)"
^XMB(3.9,144657,2,5480,0)=" ;"
^XMB(3.9,144657,2,5481,0)="""RTN"",""IBCNERTC"",27,0)"
^XMB(3.9,144657,2,5482,0)=" ; -- initial value ="""" or Unknown"
^XMB(3.9,144657,2,5483,0)="""RTN"",""IBCNERTC"",28,0)"
^XMB(3.9,144657,2,5484,0)=" I $TR(IBCOV,""U"","""")']"""" S IBNCOV=$S('$O(^DPT(DFN,.312,0)):""U"",IBINSD:""Y"",1:""N"")"
^XMB(3.9,144657,2,5485,0)="""RTN"",""IBCNERTC"",29,0)"
^XMB(3.9,144657,2,5486,0)=" ; -- initial value = YES or NO (treat the same)"
^XMB(3.9,144657,2,5487,0)="""RTN"",""IBCNERTC"",30,0)"
^XMB(3.9,144657,2,5488,0)=" I ""YN""[IBCOV S IBNCOV=$S('$O(^DPT(DFN,.312,0)):""N"",IBINSD:""Y"",1:""N"")"
^XMB(3.9,144657,2,5489,0)="""RTN"",""IBCNERTC"",31,0)"
^XMB(3.9,144657,2,5490,0)=" ;"
^XMB(3.9,144657,2,5491,0)="""RTN"",""IBCNERTC"",32,0)"
^XMB(3.9,144657,2,5492,0)=" I IBCOV'=IBNCOV S DIE=""^DPT("",DR="".3192///""_IBNCOV,DA=DFN D ^DIE"
^XMB(3.9,144657,2,5493,0)="""RTN"",""IBCNERTC"",33,0)"
^XMB(3.9,144657,2,5494,0)=" ;"
^XMB(3.9,144657,2,5495,0)="""RTN"",""IBCNERTC"",34,0)"
^XMB(3.9,144657,2,5496,0)=" ; Create Buffer entry for those whose Effective Date = IBDT"
^XMB(3.9,144657,2,5497,0)="""RTN"",""IBCNERTC"",35,0)"
^XMB(3.9,144657,2,5498,0)=" ;"
^XMB(3.9,144657,2,5499,0)="""RTN"",""IBCNERTC"",36,0)"
^XMB(3.9,144657,2,5500,0)=" S DA=0 F  S DA=$O(IBINS(DA)) Q:'DA  D"
^XMB(3.9,144657,2,5501,0)="""RTN"",""IBCNERTC"",37,0)"
^XMB(3.9,144657,2,5502,0)=" . S IBIEN=+IBINS(DA,0)"
^XMB(3.9,144657,2,5503,0)="""RTN"",""IBCNERTC"",38,0)"
^XMB(3.9,144657,2,5504,0)=" . S IBIENS=DA_"",""_DFN_"","""
^XMB(3.9,144657,2,5505,0)="""RTN"",""IBCNERTC"",39,0)"
^XMB(3.9,144657,2,5506,0)=" . S EFFDT=$$GET1^DIQ(2.312,IBIENS,8,""I"")"
^XMB(3.9,144657,2,5507,0)="""RTN"",""IBCNERTC"",40,0)"
^XMB(3.9,144657,2,5508,0)=" . I EFFDT'=IBDT Q"
^XMB(3.9,144657,2,5509,0)="""RTN"",""IBCNERTC"",41,0)"
^XMB(3.9,144657,2,5510,0)=" . ; Add check to see if already in buffer"
^XMB(3.9,144657,2,5511,0)="""RTN"",""IBCNERTC"",42,0)"
^XMB(3.9,144657,2,5512,0)=" . S DEFIND=$$BFEXIST(DFN,IBIEN) Q:DEFIND=1"
^XMB(3.9,144657,2,5513,0)="""RTN"",""IBCNERTC"",43,0)"
^XMB(3.9,144657,2,5514,0)=" . S IBSYM=$P($$INSERROR^IBCNEUT3(""I"",IBIEN),""^"",1)"
^XMB(3.9,144657,2,5515,0)="""RTN"",""IBCNERTC"",44,0)"
^XMB(3.9,144657,2,5516,0)=" . D PT^IBCNEBF(DFN,DA,IBSYM,,1)"
^XMB(3.9,144657,2,5517,0)="""RTN"",""IBCNERTC"",45,0)"
^XMB(3.9,144657,2,5518,0)=" Q"
^XMB(3.9,144657,2,5519,0)="""RTN"",""IBCNERTC"",46,0)"
^XMB(3.9,144657,2,5520,0)=" ;"
^XMB(3.9,144657,2,5521,0)="""RTN"",""IBCNERTC"",47,0)"
^XMB(3.9,144657,2,5522,0)="UPATF ;Update the entire Patient File"
^XMB(3.9,144657,2,5523,0)="""RTN"",""IBCNERTC"",48,0)"
^XMB(3.9,144657,2,5524,0)=" ; This should be tasked for late evening since it will take awhile to run."
^XMB(3.9,144657,2,5525,0)="""RTN"",""IBCNERTC"",49,0)"
^XMB(3.9,144657,2,5526,0)=" N DFN,IENS"
^XMB(3.9,144657,2,5527,0)="""RTN"",""IBCNERTC"",50,0)"
^XMB(3.9,144657,2,5528,0)=" S DFN=0"
^XMB(3.9,144657,2,5529,0)="""RTN"",""IBCNERTC"",51,0)"
^XMB(3.9,144657,2,5530,0)=" F  S DFN=$O(^DPT(DFN)) Q:'DFN  D"
^XMB(3.9,144657,2,5531,0)="""RTN"",""IBCNERTC"",52,0)"
^XMB(3.9,144657,2,5532,0)=" . D INS(DFN,DT)"
^XMB(3.9,144657,2,5533,0)="""RTN"",""IBCNERTC"",53,0)"
^XMB(3.9,144657,2,5534,0)=" Q"
^XMB(3.9,144657,2,5535,0)="""RTN"",""IBCNERTC"",54,0)"
^XMB(3.9,144657,2,5536,0)=" ;"
^XMB(3.9,144657,2,5537,0)="""RTN"",""IBCNERTC"",55,0)"
^XMB(3.9,144657,2,5538,0)="BFEXIST(DFN,INSNAME) ; Function returns 1 if an Entered Ins Buffer File "
^XMB(3.9,144657,2,5539,0)="""RTN"",""IBCNERTC"",56,0)"
^XMB(3.9,144657,2,5540,0)=" ; entry exists with the same DFN and INSNAME, otherwise it returns a 0"
^XMB(3.9,144657,2,5541,0)="""RTN"",""IBCNERTC"",57,0)"
^XMB(3.9,144657,2,5542,0)=" ;"
^XMB(3.9,144657,2,5543,0)="""RTN"",""IBCNERTC"",58,0)"
^XMB(3.9,144657,2,5544,0)=" ; DFN - Patient DFN"
^XMB(3.9,144657,2,5545,0)="""RTN"",""IBCNERTC"",59,0)"
^XMB(3.9,144657,2,5546,0)=" ; INSNAME - Insurance Company Name File 36 - Field .01"
^XMB(3.9,144657,2,5547,0)="""RTN"",""IBCNERTC"",60,0)"
^XMB(3.9,144657,2,5548,0)=" ;"
^XMB(3.9,144657,2,5549,0)="""RTN"",""IBCNERTC"",61,0)"
^XMB(3.9,144657,2,5550,0)=" NEW EXIST,IEN,EDATE"
^XMB(3.9,144657,2,5551,0)="""RTN"",""IBCNERTC"",62,0)"
^XMB(3.9,144657,2,5552,0)=" S EXIST=0"
^XMB(3.9,144657,2,5553,0)="""RTN"",""IBCNERTC"",63,0)"
^XMB(3.9,144657,2,5554,0)=" S INSNAME=$P($G(^DIC(36,IBIEN,0)),U) ;$$TRIM^XLFSTR(INSNAME)  ; trimmed"
^XMB(3.9,144657,2,5555,0)="""RTN"",""IBCNERTC"",64,0)"
^XMB(3.9,144657,2,5556,0)=" I ('DFN)!(INSNAME="""") G BFEXIT"
^XMB(3.9,144657,2,5557,0)="""RTN"",""IBCNERTC"",65,0)"
^XMB(3.9,144657,2,5558,0)=" ;"
^XMB(3.9,144657,2,5559,0)="""RTN"",""IBCNERTC"",66,0)"
^XMB(3.9,144657,2,5560,0)=" S IEN=0"
^XMB(3.9,144657,2,5561,0)="""RTN"",""IBCNERTC"",67,0)"
^XMB(3.9,144657,2,5562,0)=" F  S IEN=$O(^IBA(355.33,""C"",DFN,IEN)) Q:'IEN!EXIST  D"
^XMB(3.9,144657,2,5563,0)="""RTN"",""IBCNERTC"",68,0)"
^XMB(3.9,144657,2,5564,0)=" .  ; Quit if status is NOT 'Entered'"
^XMB(3.9,144657,2,5565,0)="""RTN"",""IBCNERTC"",69,0)"
^XMB(3.9,144657,2,5566,0)=" .  I $$GET1^DIQ(355.33,IEN_"","",""STATUS"",""I"")'=""E"" Q"
^XMB(3.9,144657,2,5567,0)="""RTN"",""IBCNERTC"",70,0)"
^XMB(3.9,144657,2,5568,0)=" .  ; Quit if Ins Buffer Ins Co Name (trimmed) is NOT EQUAL to "
^XMB(3.9,144657,2,5569,0)="""RTN"",""IBCNERTC"",71,0)"
^XMB(3.9,144657,2,5570,0)=" .  ;  the Ins Co Name parameter (trimmed)"
^XMB(3.9,144657,2,5571,0)="""RTN"",""IBCNERTC"",72,0)"
^XMB(3.9,144657,2,5572,0)=" .  I $$TRIM^XLFSTR($$GET1^DIQ(355.33,IEN_"","",""INSURANCE COMPANY NAME""))'=INSNAME Q"
^XMB(3.9,144657,2,5573,0)="""RTN"",""IBCNERTC"",73,0)"
^XMB(3.9,144657,2,5574,0)=" .  ; Quit if Date Enterd Matches"
^XMB(3.9,144657,2,5575,0)="""RTN"",""IBCNERTC"",74,0)"
^XMB(3.9,144657,2,5576,0)=" .  S EDATE=$P($$GET1^DIQ(355.33,IEN_"","",""DATE ENTERED"",""I""),""."")"
^XMB(3.9,144657,2,5577,0)="""RTN"",""IBCNERTC"",75,0)"
^XMB(3.9,144657,2,5578,0)=" .  I IBDT'=EDATE Q"
^XMB(3.9,144657,2,5579,0)="""RTN"",""IBCNERTC"",76,0)"
^XMB(3.9,144657,2,5580,0)=" .  ; Match found"
^XMB(3.9,144657,2,5581,0)="""RTN"",""IBCNERTC"",77,0)"
^XMB(3.9,144657,2,5582,0)=" .  S EXIST=1"
^XMB(3.9,144657,2,5583,0)="""RTN"",""IBCNERTC"",78,0)"
^XMB(3.9,144657,2,5584,0)=" .  Q"
^XMB(3.9,144657,2,5585,0)="""RTN"",""IBCNERTC"",79,0)"
^XMB(3.9,144657,2,5586,0)="BFEXIT ;"
^XMB(3.9,144657,2,5587,0)="""RTN"",""IBCNERTC"",80,0)"
^XMB(3.9,144657,2,5588,0)=" Q EXIST"
^XMB(3.9,144657,2,5589,0)="""RTN"",""IBCNERTC"",81,0)"
^XMB(3.9,144657,2,5590,0)=" ;"
^XMB(3.9,144657,2,5591,0)="""RTN"",""IBCNERTC"",82,0)"
^XMB(3.9,144657,2,5592,0)="XREF ;Build the ""ACHI"" cross reference"
^XMB(3.9,144657,2,5593,0)="""RTN"",""IBCNERTC"",83,0)"
^XMB(3.9,144657,2,5594,0)=" N CNT,DA,DFN,FILE,DIK,X,Y"
^XMB(3.9,144657,2,5595,0)="""RTN"",""IBCNERTC"",84,0)"
^XMB(3.9,144657,2,5596,0)=" S DFN=0"
^XMB(3.9,144657,2,5597,0)="""RTN"",""IBCNERTC"",85,0)"
^XMB(3.9,144657,2,5598,0)=" F  S DFN=$O(^DPT(DFN)) Q:'DFN  D"
^XMB(3.9,144657,2,5599,0)="""RTN"",""IBCNERTC"",86,0)"
^XMB(3.9,144657,2,5600,0)=" . I $$GET1^DIQ(2,DFN_"",""_""DATE OF DEATH"") Q  ;Patient Deceased"
^XMB(3.9,144657,2,5601,0)="""RTN"",""IBCNERTC"",87,0)"
^XMB(3.9,144657,2,5602,0)=" . S DA(1)=DFN"
^XMB(3.9,144657,2,5603,0)="""RTN"",""IBCNERTC"",88,0)"
^XMB(3.9,144657,2,5604,0)=" . S DIK=""^DPT(""_DA(1)_"",.312,"""
^XMB(3.9,144657,2,5605,0)="""RTN"",""IBCNERTC"",89,0)"
^XMB(3.9,144657,2,5606,0)=" . S DIK(1)=""3^ACHI"""
^XMB(3.9,144657,2,5607,0)="""RTN"",""IBCNERTC"",90,0)"
^XMB(3.9,144657,2,5608,0)=" . D ENALL^DIK"
^XMB(3.9,144657,2,5609,0)="""RTN"",""IBCNERTC"",91,0)"
^XMB(3.9,144657,2,5610,0)=" . S DIK(1)=""8^ACHI"""
^XMB(3.9,144657,2,5611,0)="""RTN"",""IBCNERTC"",92,0)"
^XMB(3.9,144657,2,5612,0)=" . D ENALL^DIK"
^XMB(3.9,144657,2,5613,0)="""RTN"",""IBCNERTC"",93,0)"
^XMB(3.9,144657,2,5614,0)=" Q"
^XMB(3.9,144657,2,5615,0)="""RTN"",""IBCNES"")"
^XMB(3.9,144657,2,5616,0)="0^23^B68725109"
^XMB(3.9,144657,2,5617,0)="""RTN"",""IBCNES"",1,0)"
^XMB(3.9,144657,2,5618,0)="IBCNES ;ALB/ESG - eIV elig/Benefit screen ; 14-Jul-2009"
^XMB(3.9,144657,2,5619,0)="""RTN"",""IBCNES"",2,0)"
