^XMB(3.9,144654,2,503,0)="""RTN"",""PSOHLDS2"",132,0)"
^XMB(3.9,144654,2,504,0)=" S:'$D(LTH) ^TMP(""PSO"",$J,PSI)=NT1 S PSI=PSI+1"
^XMB(3.9,144654,2,505,0)="""RTN"",""PSOHLDS2"",133,0)"
^XMB(3.9,144654,2,506,0)=" Q"
^XMB(3.9,144654,2,507,0)="""RTN"",""PSOHLDS2"",134,0)"
^XMB(3.9,144654,2,508,0)="NTE2(PSI) ; Patient Narrative"
^XMB(3.9,144654,2,509,0)="""RTN"",""PSOHLDS2"",135,0)"
^XMB(3.9,144654,2,510,0)=" K ^UTILITY($J,""W"") S (DIWL,PSNACNT)=1,DIWR=45,DIWF="""",(PSSIXFL,PSSEVFL)=0 F ZZ=0:0 S ZZ=$O(^PS(59,PSOSITE,6,ZZ)) Q:'ZZ  I $D(^(ZZ,0)) S X=^(0) D ^DIWP"
^XMB(3.9,144654,2,511,0)="""RTN"",""PSOHLDS2"",136,0)"
^XMB(3.9,144654,2,512,0)=" F LLL=0:0 S LLL=$O(^UTILITY($J,""W"",DIWL,LLL)) Q:'LLL  S ^TMP(""PSO"",$J,PSI,PSNACNT)=^UTILITY($J,""W"",DIWL,LLL,0) S PSNACNT=PSNACNT+1,PSSIXFL=1"
^XMB(3.9,144654,2,513,0)="""RTN"",""PSOHLDS2"",137,0)"
^XMB(3.9,144654,2,514,0)=" I PSSIXFL S ^TMP(""PSO"",$J,PSI)=""NTE""_FS_2_FS_FS,^TMP(""PSO"",$J,PSI,PSNACNT)="" "" S PSNACNT=PSNACNT+1,FLDX=1"
^XMB(3.9,144654,2,515,0)="""RTN"",""PSOHLDS2"",138,0)"
^XMB(3.9,144654,2,516,0)=" S DIWL=1,DIWR=45,DIWF="""" K ^UTILITY($J,""W"") F ZZ=0:0 S ZZ=$O(^PS(59,PSOSITE,7,ZZ)) Q:'ZZ  I $D(^(ZZ,0)) S X=^(0) D ^DIWP"
^XMB(3.9,144654,2,517,0)="""RTN"",""PSOHLDS2"",139,0)"
^XMB(3.9,144654,2,518,0)=" F LLL=0:0 S LLL=$O(^UTILITY($J,""W"",DIWL,LLL)) Q:'LLL  S ^TMP(""PSO"",$J,PSI,PSNACNT)=^UTILITY($J,""W"",DIWL,LLL,0) S PSNACNT=PSNACNT+1,PSSEVFL=1"
^XMB(3.9,144654,2,519,0)="""RTN"",""PSOHLDS2"",140,0)"
^XMB(3.9,144654,2,520,0)=" I PSSEVFL S ^TMP(""PSO"",$J,PSI,PSNACNT)="" "" S PSNACNT=PSNACNT+1"
^XMB(3.9,144654,2,521,0)="""RTN"",""PSOHLDS2"",141,0)"
^XMB(3.9,144654,2,522,0)=" S DIWL=1,DIWR=45,DIWF="""" K ^UTILITY($J,""W"") F ZZ=0:0 S ZZ=$O(^PS(59,PSOSITE,4,ZZ)) Q:'ZZ  I $D(^(ZZ,0)) S X=^(0) D ^DIWP"
^XMB(3.9,144654,2,523,0)="""RTN"",""PSOHLDS2"",142,0)"
^XMB(3.9,144654,2,524,0)=" F LLL=0:0 S LLL=$O(^UTILITY($J,""W"",DIWL,LLL)) Q:'LLL  S ^TMP(""PSO"",$J,PSI,PSNACNT)=^UTILITY($J,""W"",DIWL,LLL,0) S PSNACNT=PSNACNT+1"
^XMB(3.9,144654,2,525,0)="""RTN"",""PSOHLDS2"",143,0)"
^XMB(3.9,144654,2,526,0)=" S:$D(FLDX) ^TMP(""PSO"",$J,PSI,PSNACNT-1)=^TMP(""PSO"",$J,PSI,PSNACNT-1)_FS_""Patient Narrative"",PSI=PSI+1"
^XMB(3.9,144654,2,527,0)="""RTN"",""PSOHLDS2"",144,0)"
^XMB(3.9,144654,2,528,0)=" K DIWF,DIWL,DIWR,LLL,PSNACNT,PSSEVFL,PSSIXFL,ZZ"
^XMB(3.9,144654,2,529,0)="""RTN"",""PSOHLDS2"",145,0)"
