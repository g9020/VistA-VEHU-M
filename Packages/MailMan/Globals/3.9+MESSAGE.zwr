^XMB(3.9,145834,2,8330,0)=" "
^XMB(3.9,145834,2,8331,0)="""^DIC"",2006.541,2006.541,""%D"",24,0)"
^XMB(3.9,145834,2,8332,0)="This file should be truncated periodically, as there is no need for"
