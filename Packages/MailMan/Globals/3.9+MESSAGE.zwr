^XMB(3.9,144661,2,471,0)="""RTN"",""ORAM1"",116,0)"
^XMB(3.9,144661,2,472,0)=" S OLDRTN=$P($G(^ORAM(103,DFN,0)),""^"",4)"
^XMB(3.9,144661,2,473,0)="""RTN"",""ORAM1"",117,0)"
^XMB(3.9,144661,2,474,0)=" I SI'="""" K ^ORAM(103,DFN,1) S ORAMSIL=$L(SI,""^""),^ORAM(103,DFN,1,0)=""^^""_ORAMSIL_""^""_ORAMSIL_""^""_ORAMDAY_""^"" F R=1:1:ORAMSIL D"
