^XMB(3.9,144657,2,3548,0)=" .W !,""      $ - Escalated Active policy."""
^XMB(3.9,144657,2,3549,0)="""RTN"",""IBCNBLL"",111,0)"
^XMB(3.9,144657,2,3550,0)=" .; W !,""      * - Previously either an active or not active policy.""  ; IB*2.0*737 removed"
^XMB(3.9,144657,2,3551,0)="""RTN"",""IBCNBLL"",112,0)"
^XMB(3.9,144657,2,3552,0)=" .W !,""      # - Can not determine from eIV response if coverage is Active."""
^XMB(3.9,144657,2,3553,0)="""RTN"",""IBCNBLL"",113,0)"
^XMB(3.9,144657,2,3554,0)=" .W !,""          Review Response Report. Manual verification required."""
^XMB(3.9,144657,2,3555,0)="""RTN"",""IBCNBLL"",114,0)"
^XMB(3.9,144657,2,3556,0)=" .W !,""      ! - eIV was unable to send an inquiry for this entry."""
^XMB(3.9,144657,2,3557,0)="""RTN"",""IBCNBLL"",115,0)"
^XMB(3.9,144657,2,3558,0)=" .W !,""          Corrections required or payer not Active."""
^XMB(3.9,144657,2,3559,0)="""RTN"",""IBCNBLL"",116,0)"
^XMB(3.9,144657,2,3560,0)=" .W !,""      - - eIV payer response indicates this is NOT an active policy."""
^XMB(3.9,144657,2,3561,0)="""RTN"",""IBCNBLL"",117,0)"
^XMB(3.9,144657,2,3562,0)=" .W !,""      % - CMS responded with the patient's new MBI value."""
^XMB(3.9,144657,2,3563,0)="""RTN"",""IBCNBLL"",118,0)"
^XMB(3.9,144657,2,3564,0)=" .W !,""<Blank> - Entry added through manual process."""
^XMB(3.9,144657,2,3565,0)="""RTN"",""IBCNBLL"",119,0)"
^XMB(3.9,144657,2,3566,0)=" .Q"
^XMB(3.9,144657,2,3567,0)="""RTN"",""IBCNBLL"",120,0)"
^XMB(3.9,144657,2,3568,0)=" I VIEW=4 D"
^XMB(3.9,144657,2,3569,0)="""RTN"",""IBCNBLL"",121,0)"
^XMB(3.9,144657,2,3570,0)=" .W !,""      ! - eIV was unable to send an inquiry for this entry."""
^XMB(3.9,144657,2,3571,0)="""RTN"",""IBCNBLL"",122,0)"
^XMB(3.9,144657,2,3572,0)=" .W !,""          Corrections required or payer not Active."""
^XMB(3.9,144657,2,3573,0)="""RTN"",""IBCNBLL"",123,0)"
^XMB(3.9,144657,2,3574,0)=" .Q"
^XMB(3.9,144657,2,3575,0)="""RTN"",""IBCNBLL"",124,0)"
^XMB(3.9,144657,2,3576,0)=" ;"
^XMB(3.9,144657,2,3577,0)="""RTN"",""IBCNBLL"",125,0)"
^XMB(3.9,144657,2,3578,0)=" I VIEW=5 D      ; IB*2*435"
^XMB(3.9,144657,2,3579,0)="""RTN"",""IBCNBLL"",126,0)"
^XMB(3.9,144657,2,3580,0)=" . W !,""      e-Pharmacy buffer entries are not applicable for e-IV processing."""
^XMB(3.9,144657,2,3581,0)="""RTN"",""IBCNBLL"",127,0)"
^XMB(3.9,144657,2,3582,0)=" . Q"
^XMB(3.9,144657,2,3583,0)="""RTN"",""IBCNBLL"",128,0)"
^XMB(3.9,144657,2,3584,0)=" ;"
^XMB(3.9,144657,2,3585,0)="""RTN"",""IBCNBLL"",129,0)"
^XMB(3.9,144657,2,3586,0)=" D PAUSE^VALM1 I 'Y Q"
^XMB(3.9,144657,2,3587,0)="""RTN"",""IBCNBLL"",130,0)"
^XMB(3.9,144657,2,3588,0)=" W !,""When an entry is Processed it is either:"""
^XMB(3.9,144657,2,3589,0)="""RTN"",""IBCNBLL"",131,0)"
^XMB(3.9,144657,2,3590,0)=" W !,""   Accepted - the Buffer entry's data is stored in the main Insurance files."""
^XMB(3.9,144657,2,3591,0)="""RTN"",""IBCNBLL"",132,0)"
^XMB(3.9,144657,2,3592,0)=" W !,""            - the modified Insurance entry is flagged as Verified."""
^XMB(3.9,144657,2,3593,0)="""RTN"",""IBCNBLL"",133,0)"
^XMB(3.9,144657,2,3594,0)=" W !"
^XMB(3.9,144657,2,3595,0)="""RTN"",""IBCNBLL"",134,0)"
^XMB(3.9,144657,2,3596,0)=" W !,""   Rejected - the Buffer entry's data is not stored in the main Insurance files."""
^XMB(3.9,144657,2,3597,0)="""RTN"",""IBCNBLL"",135,0)"
^XMB(3.9,144657,2,3598,0)=" W !!"
^XMB(3.9,144657,2,3599,0)="""RTN"",""IBCNBLL"",136,0)"
^XMB(3.9,144657,2,3600,0)=" W !,""Once an entry is processed (either accepted or rejected) most of the data in"""
^XMB(3.9,144657,2,3601,0)="""RTN"",""IBCNBLL"",137,0)"
^XMB(3.9,144657,2,3602,0)=" W !,""the Buffer File entry is deleted leaving only a stub entry for tracking"""
^XMB(3.9,144657,2,3603,0)="""RTN"",""IBCNBLL"",138,0)"
^XMB(3.9,144657,2,3604,0)=" W !,""and reporting purposes."""
^XMB(3.9,144657,2,3605,0)="""RTN"",""IBCNBLL"",139,0)"
^XMB(3.9,144657,2,3606,0)=" W !!"
^XMB(3.9,144657,2,3607,0)="""RTN"",""IBCNBLL"",140,0)"
^XMB(3.9,144657,2,3608,0)=" W !,""The IB INSURANCE SUPERVISOR key is required to either Accept or Reject an entry."""
^XMB(3.9,144657,2,3609,0)="""RTN"",""IBCNBLL"",141,0)"
^XMB(3.9,144657,2,3610,0)=" D PAUSE^VALM1"
^XMB(3.9,144657,2,3611,0)="""RTN"",""IBCNBLL"",142,0)"
^XMB(3.9,144657,2,3612,0)=" Q"
^XMB(3.9,144657,2,3613,0)="""RTN"",""IBCNBLL"",143,0)"
^XMB(3.9,144657,2,3614,0)=" ;"
^XMB(3.9,144657,2,3615,0)="""RTN"",""IBCNBLL"",144,0)"
^XMB(3.9,144657,2,3616,0)="EXIT ;  exit list manager option and clean up"
^XMB(3.9,144657,2,3617,0)="""RTN"",""IBCNBLL"",145,0)"
^XMB(3.9,144657,2,3618,0)=" K ^TMP(""IBCNBLL"",$J),^TMP(""IBCNBLLX"",$J),^TMP(""IBCNBLLY"",$J),^TMP($J,""IBCNBLLS""),^TMP($J,""SDAMA301""),^TMP($J,""IBCNAPPTS"")"
^XMB(3.9,144657,2,3619,0)="""RTN"",""IBCNBLL"",146,0)"
^XMB(3.9,144657,2,3620,0)=" K ^TMP(""IBCNBLLSP"",$J)  ;IB*806/DTG new policy flag track"
^XMB(3.9,144657,2,3621,0)="""RTN"",""IBCNBLL"",147,0)"
^XMB(3.9,144657,2,3622,0)=" K IBCNSORT,IBCNSCRN,DFN,IBINSDA,IBFASTXT,IBBUFDA"
^XMB(3.9,144657,2,3623,0)="""RTN"",""IBCNBLL"",148,0)"
^XMB(3.9,144657,2,3624,0)=" D CLEAR^VALM1"
^XMB(3.9,144657,2,3625,0)="""RTN"",""IBCNBLL"",149,0)"
^XMB(3.9,144657,2,3626,0)=" Q"
^XMB(3.9,144657,2,3627,0)="""RTN"",""IBCNBLL"",150,0)"
^XMB(3.9,144657,2,3628,0)=" ;"
^XMB(3.9,144657,2,3629,0)="""RTN"",""IBCNBLL"",151,0)"
^XMB(3.9,144657,2,3630,0)="BLD ;  build screen display"
^XMB(3.9,144657,2,3631,0)="""RTN"",""IBCNBLL"",152,0)"
^XMB(3.9,144657,2,3632,0)=" N IBCNT,IBCNS1,IBCNS2,IBBUFDA,IBLINE"
^XMB(3.9,144657,2,3633,0)="""RTN"",""IBCNBLL"",153,0)"
^XMB(3.9,144657,2,3634,0)=" ;"
^XMB(3.9,144657,2,3635,0)="""RTN"",""IBCNBLL"",154,0)"
^XMB(3.9,144657,2,3636,0)=" N IBSUBSAV,IBSBSAVA S (IBSUBSAV,IBSBSAVA)=""""  ;IB*806/DTG new var's for new flag"
^XMB(3.9,144657,2,3637,0)="""RTN"",""IBCNBLL"",155,0)"
^XMB(3.9,144657,2,3638,0)=" ;"
^XMB(3.9,144657,2,3639,0)="""RTN"",""IBCNBLL"",156,0)"
^XMB(3.9,144657,2,3640,0)=" D SORT S IBCNT=0,VALMCNT=0,IBBUFDA=0"
^XMB(3.9,144657,2,3641,0)="""RTN"",""IBCNBLL"",157,0)"
^XMB(3.9,144657,2,3642,0)=" ;"
^XMB(3.9,144657,2,3643,0)="""RTN"",""IBCNBLL"",158,0)"
^XMB(3.9,144657,2,3644,0)=" I '$D(ZTQUEUED) W !,""Building display ""  ;IB*794/DJW telling users what we are doing"
^XMB(3.9,144657,2,3645,0)="""RTN"",""IBCNBLL"",159,0)"
^XMB(3.9,144657,2,3646,0)=" S IBCNS1="""" F  S IBCNS1=$O(^TMP($J,""IBCNBLLS"",IBCNS1)) Q:IBCNS1=""""  D"
^XMB(3.9,144657,2,3647,0)="""RTN"",""IBCNBLL"",160,0)"
^XMB(3.9,144657,2,3648,0)=" .S IBCNS2="""" F  S IBCNS2=$O(^TMP($J,""IBCNBLLS"",IBCNS1,IBCNS2)) Q:IBCNS2=""""  D"
^XMB(3.9,144657,2,3649,0)="""RTN"",""IBCNBLL"",161,0)"
^XMB(3.9,144657,2,3650,0)=" ..S IBBUFDA=0 F  S IBBUFDA=$O(^TMP($J,""IBCNBLLS"",IBCNS1,IBCNS2,IBBUFDA)) Q:'IBBUFDA  D"
^XMB(3.9,144657,2,3651,0)="""RTN"",""IBCNBLL"",162,0)"
^XMB(3.9,144657,2,3652,0)=" ...S DFLG=^TMP($J,""IBCNBLLS"",IBCNS1,IBCNS2,IBBUFDA)"
^XMB(3.9,144657,2,3653,0)="""RTN"",""IBCNBLL"",163,0)"
^XMB(3.9,144657,2,3654,0)=" ...S IBSBSAVA=$G(^TMP(""IBCNBLLSP"",$J,IBCNS1,IBCNS2,IBBUFDA))  ;IB*806/DTG pick up the potential new pt flag"
^XMB(3.9,144657,2,3655,0)="""RTN"",""IBCNBLL"",164,0)"
^XMB(3.9,144657,2,3656,0)=" ...S IBCNT=IBCNT+1 I '$D(ZTQUEUED),'(IBCNT#100) W "".""  ;IB*794/DJW changed '(IBCNT#15) to be #100"
^XMB(3.9,144657,2,3657,0)="""RTN"",""IBCNBLL"",165,0)"
^XMB(3.9,144657,2,3658,0)=" ...S IBLINE=$$BLDLN(IBBUFDA,IBCNT,DFLG) I IBLINE="""" S IBCNT=IBCNT-1 Q  ; IB*2*506/taz If line is null stop processing this entry."
^XMB(3.9,144657,2,3659,0)="""RTN"",""IBCNBLL"",166,0)"
^XMB(3.9,144657,2,3660,0)=" ...D SET(IBLINE,IBCNT)"
^XMB(3.9,144657,2,3661,0)="""RTN"",""IBCNBLL"",167,0)"
^XMB(3.9,144657,2,3662,0)=" ;"
^XMB(3.9,144657,2,3663,0)="""RTN"",""IBCNBLL"",168,0)"
^XMB(3.9,144657,2,3664,0)=" I VALMCNT=0 D SET("""",0),SET(""There are no Buffer entries that have not been processed."",0)"
^XMB(3.9,144657,2,3665,0)="""RTN"",""IBCNBLL"",169,0)"
^XMB(3.9,144657,2,3666,0)=" Q"
^XMB(3.9,144657,2,3667,0)="""RTN"",""IBCNBLL"",170,0)"
^XMB(3.9,144657,2,3668,0)=" ;"
^XMB(3.9,144657,2,3669,0)="""RTN"",""IBCNBLL"",171,0)"
^XMB(3.9,144657,2,3670,0)="BLDLN(IBBUFDA,IBCNT,DFLG) ; build line to display on List screen for one Buffer entry"
^XMB(3.9,144657,2,3671,0)="""RTN"",""IBCNBLL"",172,0)"
^XMB(3.9,144657,2,3672,0)=" N DFN,IB0,IB20,IB40,IB60,IBLINE,IBMTS,IBY,MCFLAG,VA,VADM,VAERR,VAIN,X,Y"
^XMB(3.9,144657,2,3673,0)="""RTN"",""IBCNBLL"",173,0)"
^XMB(3.9,144657,2,3674,0)=" S IBLINE="""",IBBUFDA=+$G(IBBUFDA)"
^XMB(3.9,144657,2,3675,0)="""RTN"",""IBCNBLL"",174,0)"
^XMB(3.9,144657,2,3676,0)=" S IB40=$G(^IBA(355.33,IBBUFDA,40)),MCFLAG=$$GTMFLG(IBBUFDA)  ;IB*2.0*549"
^XMB(3.9,144657,2,3677,0)="""RTN"",""IBCNBLL"",175,0)"
^XMB(3.9,144657,2,3678,0)=" S IB0=$G(^IBA(355.33,IBBUFDA,0)),IB20=$G(^IBA(355.33,IBBUFDA,20)),IB60=$G(^IBA(355.33,IBBUFDA,60))"
^XMB(3.9,144657,2,3679,0)="""RTN"",""IBCNBLL"",176,0)"
^XMB(3.9,144657,2,3680,0)=" S DFN=+IB60 I +DFN D DEM^VADPT,INP^VADPT"
^XMB(3.9,144657,2,3681,0)="""RTN"",""IBCNBLL"",177,0)"
^XMB(3.9,144657,2,3682,0)=" ;"
^XMB(3.9,144657,2,3683,0)="""RTN"",""IBCNBLL"",178,0)"
^XMB(3.9,144657,2,3684,0)=" ;IB*2.0*549 - Replaced the following line of code:"
^XMB(3.9,144657,2,3685,0)="""RTN"",""IBCNBLL"",179,0)"
^XMB(3.9,144657,2,3686,0)=" ;I 'IBKEYS,'$$ACTIVE(DFN) G BLDLNQ  ;IB*2*506/taz Only allow active insurance for users not holding IB INSURANCE EDIT or IB GROUP/PLAN EDIT keys"
^XMB(3.9,144657,2,3687,0)="""RTN"",""IBCNBLL"",180,0)"
^XMB(3.9,144657,2,3688,0)=" ; With the following code that will determine if the list item is Medicare (+MCFLAG,) then include it on"
^XMB(3.9,144657,2,3689,0)="""RTN"",""IBCNBLL"",181,0)"
^XMB(3.9,144657,2,3690,0)=" ; the list even if the user doesn't have the security keys and if the patient has ACTIVE or INACTIVE policies."
^XMB(3.9,144657,2,3691,0)="""RTN"",""IBCNBLL"",182,0)"
^XMB(3.9,144657,2,3692,0)=" I 'IBKEYS,'$$ACTIVE(DFN),'MCFLAG G BLDLNQ  ;IB*2.0*549"
^XMB(3.9,144657,2,3693,0)="""RTN"",""IBCNBLL"",183,0)"
^XMB(3.9,144657,2,3694,0)=" ;"
^XMB(3.9,144657,2,3695,0)="""RTN"",""IBCNBLL"",184,0)"
^XMB(3.9,144657,2,3696,0)=" S IBY=$G(IBCNT),IBLINE=$$SETSTR^VALM1(IBY,"""",1,4)"
^XMB(3.9,144657,2,3697,0)="""RTN"",""IBCNBLL"",185,0)"
^XMB(3.9,144657,2,3698,0)=" ;"
^XMB(3.9,144657,2,3699,0)="""RTN"",""IBCNBLL"",186,0)"
^XMB(3.9,144657,2,3700,0)=" ; ESG - 6/6/02 - SDD 5.1.8"
^XMB(3.9,144657,2,3701,0)="""RTN"",""IBCNBLL"",187,0)"
^XMB(3.9,144657,2,3702,0)=" ; pull the symbol from the symbol function"
^XMB(3.9,144657,2,3703,0)="""RTN"",""IBCNBLL"",188,0)"
^XMB(3.9,144657,2,3704,0)=" ;"
^XMB(3.9,144657,2,3705,0)="""RTN"",""IBCNBLL"",189,0)"
^XMB(3.9,144657,2,3706,0)=" S IBY=$$SYMBOL(IBBUFDA)"
^XMB(3.9,144657,2,3707,0)="""RTN"",""IBCNBLL"",190,0)"
^XMB(3.9,144657,2,3708,0)=" ;I IBY=""*"" S IBY="" ""  ;528/baa ;IB*737/DTG stop '*' verified"
^XMB(3.9,144657,2,3709,0)="""RTN"",""IBCNBLL"",191,0)"
^XMB(3.9,144657,2,3710,0)=" S IBY=IBY_$P($G(^DPT(+DFN,0)),U,1),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,5,20)"
^XMB(3.9,144657,2,3711,0)="""RTN"",""IBCNBLL"",192,0)"
^XMB(3.9,144657,2,3712,0)=" S IBLINE=$$SETSTR^VALM1(DFLG,IBLINE,25,1)"
^XMB(3.9,144657,2,3713,0)="""RTN"",""IBCNBLL"",193,0)"
^XMB(3.9,144657,2,3714,0)=" S IBY=$G(VA(""BID"")),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,27,4)"
^XMB(3.9,144657,2,3715,0)="""RTN"",""IBCNBLL"",194,0)"
^XMB(3.9,144657,2,3716,0)=" ;S IBY=$P(IB20,U,1),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,32,17)"
^XMB(3.9,144657,2,3717,0)="""RTN"",""IBCNBLL"",195,0)"
^XMB(3.9,144657,2,3718,0)=" S IBY=$P(IB20,U,1),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,32,16)  ;IB*806/DTG new position for policy flag"
^XMB(3.9,144657,2,3719,0)="""RTN"",""IBCNBLL"",196,0)"
^XMB(3.9,144657,2,3720,0)=" ;S IBY=$P(IB60,U,4),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,50,13)"
^XMB(3.9,144657,2,3721,0)="""RTN"",""IBCNBLL"",197,0)"
^XMB(3.9,144657,2,3722,0)=" S IBY=$P(IB60,U,4),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,49,13)  ;IB*806/DTG new position for policy flag"
^XMB(3.9,144657,2,3723,0)="""RTN"",""IBCNBLL"",198,0)"
^XMB(3.9,144657,2,3724,0)=" ;S IBY=$$GET1^DIQ(355.12,$P(IB0,U,3),.03),IBLINE=$$SETSTR^VALM1($$SRCCNV(IBY),IBLINE,64,1)"
^XMB(3.9,144657,2,3725,0)="""RTN"",""IBCNBLL"",199,0)"
^XMB(3.9,144657,2,3726,0)=" S IBY=$$GET1^DIQ(355.12,$P(IB0,U,3),.03),IBLINE=$$SETSTR^VALM1($$SRCCNV(IBY),IBLINE,63,1)  ;IB*806/DTG new position for policy flag"
^XMB(3.9,144657,2,3727,0)="""RTN"",""IBCNBLL"",200,0)"
^XMB(3.9,144657,2,3728,0)=" ;S IBY=$$DATE(+IB0),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,66,8)"
^XMB(3.9,144657,2,3729,0)="""RTN"",""IBCNBLL"",201,0)"
^XMB(3.9,144657,2,3730,0)=" S IBY=$$DATE(+IB0),IBLINE=$$SETSTR^VALM1(IBY,IBLINE,65,8)  ;IB*806/DTG new position for policy flag"
^XMB(3.9,144657,2,3731,0)="""RTN"",""IBCNBLL"",202,0)"
^XMB(3.9,144657,2,3732,0)=" ;IB*771/TAZ - Moved Flags logic to FLAGS subroutine."
^XMB(3.9,144657,2,3733,0)="""RTN"",""IBCNBLL"",203,0)"
^XMB(3.9,144657,2,3734,0)=" ;S IBY="""" D FLAGS(DFN,.IBY) S IBLINE=$$SETSTR^VALM1(IBY,IBLINE,76,5)"
^XMB(3.9,144657,2,3735,0)="""RTN"",""IBCNBLL"",204,0)"
^XMB(3.9,144657,2,3736,0)=" S IBY="""" D FLAGS(DFN,.IBY,IBBUFDA) S IBLINE=$$SETSTR^VALM1(IBY,IBLINE,75,6)  ;IB*806/DTG new policy flag"
^XMB(3.9,144657,2,3737,0)="""RTN"",""IBCNBLL"",205,0)"
^XMB(3.9,144657,2,3738,0)=" ;"
^XMB(3.9,144657,2,3739,0)="""RTN"",""IBCNBLL"",206,0)"
^XMB(3.9,144657,2,3740,0)="BLDLNQ ; IB*2*506/taz Tag added"
^XMB(3.9,144657,2,3741,0)="""RTN"",""IBCNBLL"",207,0)"
^XMB(3.9,144657,2,3742,0)=" Q IBLINE"
^XMB(3.9,144657,2,3743,0)="""RTN"",""IBCNBLL"",208,0)"
^XMB(3.9,144657,2,3744,0)=" ;"
^XMB(3.9,144657,2,3745,0)="""RTN"",""IBCNBLL"",209,0)"
^XMB(3.9,144657,2,3746,0)=" ;FLAGS(DFN,IBY) ;Build flag set for line"
^XMB(3.9,144657,2,3747,0)="""RTN"",""IBCNBLL"",210,0)"
^XMB(3.9,144657,2,3748,0)="FLAGS(DFN,IBY,IBBUFSN) ;Build flag set for line  ; IB*806/DTG added additional var for 'P'otential flag"
^XMB(3.9,144657,2,3749,0)="""RTN"",""IBCNBLL"",211,0)"
^XMB(3.9,144657,2,3750,0)=" ;IB*771/TAZ - Segregated so that the code could be called from other routines."
^XMB(3.9,144657,2,3751,0)="""RTN"",""IBCNBLL"",212,0)"
^XMB(3.9,144657,2,3752,0)=" ;INPUT:"
^XMB(3.9,144657,2,3753,0)="""RTN"",""IBCNBLL"",213,0)"
^XMB(3.9,144657,2,3754,0)=" ;  DFN   -  Patient IEN"
^XMB(3.9,144657,2,3755,0)="""RTN"",""IBCNBLL"",214,0)"
^XMB(3.9,144657,2,3756,0)=" ;  IBY   -  String to append the buffer flags to.  Must be initialized in calling routine."
^XMB(3.9,144657,2,3757,0)="""RTN"",""IBCNBLL"",215,0)"
^XMB(3.9,144657,2,3758,0)=" ;"
^XMB(3.9,144657,2,3759,0)="""RTN"",""IBCNBLL"",216,0)"
^XMB(3.9,144657,2,3760,0)=" ;"
^XMB(3.9,144657,2,3761,0)="""RTN"",""IBCNBLL"",217,0)"
^XMB(3.9,144657,2,3762,0)=" ;OUTPUT:"
^XMB(3.9,144657,2,3763,0)="""RTN"",""IBCNBLL"",218,0)"
^XMB(3.9,144657,2,3764,0)=" ;  IBY   -  String with formatted flags appended."
^XMB(3.9,144657,2,3765,0)="""RTN"",""IBCNBLL"",219,0)"
^XMB(3.9,144657,2,3766,0)=" ;"
^XMB(3.9,144657,2,3767,0)="""RTN"",""IBCNBLL"",220,0)"
^XMB(3.9,144657,2,3768,0)=" N IBMTS,VA,VADM,VAIN,VAERR"
^XMB(3.9,144657,2,3769,0)="""RTN"",""IBCNBLL"",221,0)"
^XMB(3.9,144657,2,3770,0)=" D DEM^VADPT,INP^VADPT"
^XMB(3.9,144657,2,3771,0)="""RTN"",""IBCNBLL"",222,0)"
^XMB(3.9,144657,2,3772,0)=" S IBY=IBY_$S(+$$INSURED^IBCNS1(DFN,DT):""i"",1:"" "")"
^XMB(3.9,144657,2,3773,0)="""RTN"",""IBCNBLL"",223,0)"
^XMB(3.9,144657,2,3774,0)=" S IBY=IBY_$S(+$G(VAIN(1)):""I"",1:"" "")"
^XMB(3.9,144657,2,3775,0)="""RTN"",""IBCNBLL"",224,0)"
^XMB(3.9,144657,2,3776,0)=" S IBY=IBY_$S(+$G(VADM(6)):""E"",1:"" "")"
^XMB(3.9,144657,2,3777,0)="""RTN"",""IBCNBLL"",225,0)"
^XMB(3.9,144657,2,3778,0)=" S IBMTS=$P($$LST^DGMTU(DFN),U,4)"
^XMB(3.9,144657,2,3779,0)="""RTN"",""IBCNBLL"",226,0)"
^XMB(3.9,144657,2,3780,0)=" S IBY=IBY_$S(IBMTS=""C"":""Y"",IBMTS=""G"":""Y"",1:"" "")"
^XMB(3.9,144657,2,3781,0)="""RTN"",""IBCNBLL"",227,0)"
^XMB(3.9,144657,2,3782,0)=" S IBY=IBY_$S(+$$HOLD(DFN):""H"",1:"" "")"
^XMB(3.9,144657,2,3783,0)="""RTN"",""IBCNBLL"",228,0)"
^XMB(3.9,144657,2,3784,0)=" S IBBUFSN=$G(IBBUFSN)  ; IB*806/DTG added for 'P'otential flag"
^XMB(3.9,144657,2,3785,0)="""RTN"",""IBCNBLL"",229,0)"
^XMB(3.9,144657,2,3786,0)=" I $D(IBSBSAVA) S IBY=IBY_$G(IBSBSAVA)"
^XMB(3.9,144657,2,3787,0)="""RTN"",""IBCNBLL"",230,0)"
^XMB(3.9,144657,2,3788,0)=" I '$D(IBSBSAVA) S IBY=IBY_$$SUBCLNCK^IBCNBLA(DFN,IBBUFSN)"
^XMB(3.9,144657,2,3789,0)="""RTN"",""IBCNBLL"",231,0)"
^XMB(3.9,144657,2,3790,0)=" Q"
^XMB(3.9,144657,2,3791,0)="""RTN"",""IBCNBLL"",232,0)"
^XMB(3.9,144657,2,3792,0)=" ;"
^XMB(3.9,144657,2,3793,0)="""RTN"",""IBCNBLL"",233,0)"
^XMB(3.9,144657,2,3794,0)="SET(LINE,CNT) ;  set up list manager screen display array"
^XMB(3.9,144657,2,3795,0)="""RTN"",""IBCNBLL"",234,0)"
^XMB(3.9,144657,2,3796,0)=" S VALMCNT=VALMCNT+1"
^XMB(3.9,144657,2,3797,0)="""RTN"",""IBCNBLL"",235,0)"
^XMB(3.9,144657,2,3798,0)=" S ^TMP(""IBCNBLL"",$J,VALMCNT,0)=LINE Q:'CNT"
^XMB(3.9,144657,2,3799,0)="""RTN"",""IBCNBLL"",236,0)"
^XMB(3.9,144657,2,3800,0)=" S ^TMP(""IBCNBLL"",$J,""IDX"",VALMCNT,+CNT)="""""
^XMB(3.9,144657,2,3801,0)="""RTN"",""IBCNBLL"",237,0)"
^XMB(3.9,144657,2,3802,0)=" S ^TMP(""IBCNBLLX"",$J,CNT)=VALMCNT_U_IBBUFDA"
^XMB(3.9,144657,2,3803,0)="""RTN"",""IBCNBLL"",238,0)"
^XMB(3.9,144657,2,3804,0)=" S ^TMP(""IBCNBLLY"",$J,IBBUFDA)=VALMCNT_U_+CNT"
^XMB(3.9,144657,2,3805,0)="""RTN"",""IBCNBLL"",239,0)"
^XMB(3.9,144657,2,3806,0)=" Q"
^XMB(3.9,144657,2,3807,0)="""RTN"",""IBCNBLL"",240,0)"
^XMB(3.9,144657,2,3808,0)=" ;"
^XMB(3.9,144657,2,3809,0)="""RTN"",""IBCNBLL"",241,0)"
^XMB(3.9,144657,2,3810,0)="SORT ;  set up sort for list screen"
^XMB(3.9,144657,2,3811,0)="""RTN"",""IBCNBLL"",242,0)"
^XMB(3.9,144657,2,3812,0)=" ; IB*2.0*737/DTG remove ""8^Verified"" reference"
^XMB(3.9,144657,2,3813,0)="""RTN"",""IBCNBLL"",243,0)"
^XMB(3.9,144657,2,3814,0)=" ; Line below is the relationship between the sort order and the external description."
^XMB(3.9,144657,2,3815,0)="""RTN"",""IBCNBLL"",244,0)"
^XMB(3.9,144657,2,3816,0)=" ;  1^Patient Name, 2^Ins Name, 3^Source Of Info, 4^Date Entered, 5^Inpatient (Y/N), 6^Means Test (Y/N), 7^On Hold, 8^Verified, 9^eIV Status, 10^Positive Response"
^XMB(3.9,144657,2,3817,0)="""RTN"",""IBCNBLL"",245,0)"
^XMB(3.9,144657,2,3818,0)=" ;  1^Patient Name, 2^Ins Name, 3^Source Of Info, 4^Date Entered, 5^Inpatient (Y/N), 6^Means Test (Y/N), 7^On Hold, 8^eIV Status, 10^Positive Response"
^XMB(3.9,144657,2,3819,0)="""RTN"",""IBCNBLL"",246,0)"
^XMB(3.9,144657,2,3820,0)=" N APPTNUM,IB0,IB20,IB60,IBCNDT,IBBUFDA,IBCNDFN,IBCNPAT,IBCSORT1,IBCSORT2,IBSDA,DFN,VAIN,VA,VAERR,IBX,IBCNT,INAME,SYM,X,Y"
^XMB(3.9,144657,2,3821,0)="""RTN"",""IBCNBLL"",247,0)"
^XMB(3.9,144657,2,3822,0)=" S IBCNT=0"
^XMB(3.9,144657,2,3823,0)="""RTN"",""IBCNBLL"",248,0)"
^XMB(3.9,144657,2,3824,0)=" ;"
^XMB(3.9,144657,2,3825,0)="""RTN"",""IBCNBLL"",249,0)"
^XMB(3.9,144657,2,3826,0)=" K ^TMP($J,""IBCNBLLS"") I '$G(IBCNSORT) S IBCNSORT=""1^Patient Name"""
^XMB(3.9,144657,2,3827,0)="""RTN"",""IBCNBLL"",250,0)"
^XMB(3.9,144657,2,3828,0)=" K ^TMP(""IBCNBLLSP"",$J)  ;IB*806/DTG clear new pt policy flag track"
^XMB(3.9,144657,2,3829,0)="""RTN"",""IBCNBLL"",251,0)"
^XMB(3.9,144657,2,3830,0)=" ; get payer ien for Medicare WNR"
^XMB(3.9,144657,2,3831,0)="""RTN"",""IBCNBLL"",252,0)"
^XMB(3.9,144657,2,3832,0)=" ;"
^XMB(3.9,144657,2,3833,0)="""RTN"",""IBCNBLL"",253,0)"
^XMB(3.9,144657,2,3834,0)=" I '$D(ZTQUEUED) W !,""Gathering and sorting the records ""  ;IB*794/DJW telling users what we are doing"
^XMB(3.9,144657,2,3835,0)="""RTN"",""IBCNBLL"",254,0)"
^XMB(3.9,144657,2,3836,0)=" S IBCNDT=0 F  S IBCNDT=$O(^IBA(355.33,""AEST"",""E"",IBCNDT)) Q:'IBCNDT  D"
^XMB(3.9,144657,2,3837,0)="""RTN"",""IBCNBLL"",255,0)"
^XMB(3.9,144657,2,3838,0)=" .S IBBUFDA=0 F  S IBBUFDA=$O(^IBA(355.33,""AEST"",""E"",IBCNDT,IBBUFDA)) Q:'IBBUFDA  D"
^XMB(3.9,144657,2,3839,0)="""RTN"",""IBCNBLL"",256,0)"
^XMB(3.9,144657,2,3840,0)=" ..S IBCNT=IBCNT+1 I '$D(ZTQUEUED),'(IBCNT#100) W "".""  ;IB*794/DJW changed '(IBCNT#15) to be #100"
^XMB(3.9,144657,2,3841,0)="""RTN"",""IBCNBLL"",257,0)"
^XMB(3.9,144657,2,3842,0)=" ..S IB0=$G(^IBA(355.33,IBBUFDA,0)),IB20=$G(^IBA(355.33,IBBUFDA,20)),IB60=$G(^IBA(355.33,IBBUFDA,60))"
^XMB(3.9,144657,2,3843,0)="""RTN"",""IBCNBLL"",258,0)"
^XMB(3.9,144657,2,3844,0)=" ..S IBCNDFN=+IB60,IBCNPAT="""" I +IBCNDFN S IBCNPAT=$P($G(^DPT(IBCNDFN,0)),U,1)"
^XMB(3.9,144657,2,3845,0)="""RTN"",""IBCNBLL"",259,0)"
^XMB(3.9,144657,2,3846,0)=" ..S IBSUBSAV=$$SUBCLNCK^IBCNBLA(IBCNDFN,+IBBUFDA)  ;IB*806/DTG check for new pt policy"
^XMB(3.9,144657,2,3847,0)="""RTN"",""IBCNBLL"",260,0)"
^XMB(3.9,144657,2,3848,0)=" ..;"
^XMB(3.9,144657,2,3849,0)="""RTN"",""IBCNBLL"",261,0)"
^XMB(3.9,144657,2,3850,0)=" ..S INAME=$P(IB20,U)"
^XMB(3.9,144657,2,3851,0)="""RTN"",""IBCNBLL"",262,0)"
^XMB(3.9,144657,2,3852,0)=" ..;"
^XMB(3.9,144657,2,3853,0)="""RTN"",""IBCNBLL"",263,0)"
^XMB(3.9,144657,2,3854,0)=" ..I +IBCNSORT=1 S IBCSORT1=IBCNPAT"
^XMB(3.9,144657,2,3855,0)="""RTN"",""IBCNBLL"",264,0)"
^XMB(3.9,144657,2,3856,0)=" ..I +IBCNSORT=2 S IBCSORT1=INAME"
^XMB(3.9,144657,2,3857,0)="""RTN"",""IBCNBLL"",265,0)"
^XMB(3.9,144657,2,3858,0)=" ..I +IBCNSORT=3 S IBCSORT1=$P(IB0,U,3)"
^XMB(3.9,144657,2,3859,0)="""RTN"",""IBCNBLL"",266,0)"
^XMB(3.9,144657,2,3860,0)=" ..I +IBCNSORT=4 S IBCSORT1=$P(+IB0,""."",1)"
^XMB(3.9,144657,2,3861,0)="""RTN"",""IBCNBLL"",267,0)"
^XMB(3.9,144657,2,3862,0)=" ..I +IBCNSORT=5 I +IBCNDFN S DFN=+IBCNDFN D INP^VADPT S IBCSORT1=$S($G(VAIN(1)):1,1:2)"
^XMB(3.9,144657,2,3863,0)="""RTN"",""IBCNBLL"",268,0)"
^XMB(3.9,144657,2,3864,0)=" ..I +IBCNSORT=6 I +IBCNDFN S IBX=$P($$LST^DGMTU(IBCNDFN),U,4) S IBCSORT1=$S(IBX=""C"":1,IBX=""G"":1,1:2)"
^XMB(3.9,144657,2,3865,0)="""RTN"",""IBCNBLL"",269,0)"
^XMB(3.9,144657,2,3866,0)=" ..I +IBCNSORT=7 I +IBCNDFN S IBX=$$HOLD(IBCNDFN) S IBCSORT1=$S(+IBX:1,1:2)"
^XMB(3.9,144657,2,3867,0)="""RTN"",""IBCNBLL"",270,0)"
^XMB(3.9,144657,2,3868,0)=" .. ;IB*737 dropped ""* verified"" sort which was +IBCNSORT=8, changed"
^XMB(3.9,144657,2,3869,0)="""RTN"",""IBCNBLL"",271,0)"
^XMB(3.9,144657,2,3870,0)=" .. ;  code below where +IBCNSORT=9 & +IBCNSORT=10 is now 8 and 9"
^XMB(3.9,144657,2,3871,0)="""RTN"",""IBCNBLL"",272,0)"
^XMB(3.9,144657,2,3872,0)=" .. ;  to compensate for dropping ""*"""
^XMB(3.9,144657,2,3873,0)="""RTN"",""IBCNBLL"",273,0)"
^XMB(3.9,144657,2,3874,0)=" ..; I +IBCNSORT=8 S IBCSORT1=$S(+$P(IB0,U,10):1,1:2)  ; IB*737 removed"
^XMB(3.9,144657,2,3875,0)="""RTN"",""IBCNBLL"",274,0)"
^XMB(3.9,144657,2,3876,0)=" ..; Sort by symbol and then within the symbol, sort by date entered"
^XMB(3.9,144657,2,3877,0)="""RTN"",""IBCNBLL"",275,0)"
^XMB(3.9,144657,2,3878,0)=" ..; Build a numerical subscript with format ##.FM date"
^XMB(3.9,144657,2,3879,0)="""RTN"",""IBCNBLL"",276,0)"
^XMB(3.9,144657,2,3880,0)=" ..S SYM=$$SYMBOL(IBBUFDA)"
^XMB(3.9,144657,2,3881,0)="""RTN"",""IBCNBLL"",277,0)"
^XMB(3.9,144657,2,3882,0)=" ..; I +IBCNSORT=9 S IBCSORT1=$G(IBCNSORT(1,SYM))_"".""_$P(+IB0,""."",1),IBCSORT1=+IBCSORT1  ;IB*737"
^XMB(3.9,144657,2,3883,0)="""RTN"",""IBCNBLL"",278,0)"
^XMB(3.9,144657,2,3884,0)=" ..; I +IBCNSORT=10 S IBCSORT1=$S(SYM=""+"":0,1:1),IBCSORT2=IBCNPAT  ;IB*737"
^XMB(3.9,144657,2,3885,0)="""RTN"",""IBCNBLL"",279,0)"
^XMB(3.9,144657,2,3886,0)=" ..;"
^XMB(3.9,144657,2,3887,0)="""RTN"",""IBCNBLL"",280,0)"
^XMB(3.9,144657,2,3888,0)=" ..I +IBCNSORT=8 S IBCSORT1=$G(IBCNSORT(1,SYM))_"".""_$P(+IB0,""."",1),IBCSORT1=+IBCSORT1  ;IB*737"
^XMB(3.9,144657,2,3889,0)="""RTN"",""IBCNBLL"",281,0)"
^XMB(3.9,144657,2,3890,0)=" ..;"
^XMB(3.9,144657,2,3891,0)="""RTN"",""IBCNBLL"",282,0)"
^XMB(3.9,144657,2,3892,0)=" ..I +IBCNSORT=9 S IBCSORT1=$S(SYM=""+"":0,1:1),IBCSORT2=IBCNPAT  ;IB*737"
^XMB(3.9,144657,2,3893,0)="""RTN"",""IBCNBLL"",283,0)"
^XMB(3.9,144657,2,3894,0)=" ..;"
^XMB(3.9,144657,2,3895,0)="""RTN"",""IBCNBLL"",284,0)"
^XMB(3.9,144657,2,3896,0)=" ..I +IBCNSORT=10 S IBCSORT1=$S(IBSUBSAV=""P"":0,1:1),IBCSORT2=IBCNPAT  ;IB*806/DTG new sort for 'P'otential new patient"
^XMB(3.9,144657,2,3897,0)="""RTN"",""IBCNBLL"",285,0)"
^XMB(3.9,144657,2,3898,0)=" ..;"
^XMB(3.9,144657,2,3899,0)="""RTN"",""IBCNBLL"",286,0)"
^XMB(3.9,144657,2,3900,0)=" ..S IBCSORT1=$S($G(IBCSORT1)="""":""~UNKNOWN"",1:IBCSORT1),IBCSORT2=$S(IBCNPAT="""":""~UNKNOWN"",1:IBCNPAT)"
^XMB(3.9,144657,2,3901,0)="""RTN"",""IBCNBLL"",287,0)"
^XMB(3.9,144657,2,3902,0)=" ..; get future appointments"
^XMB(3.9,144657,2,3903,0)="""RTN"",""IBCNBLL"",288,0)"
^XMB(3.9,144657,2,3904,0)=" ..S IBSDA(1)=DT,IBSDA(3)=""R;I;NT"",IBSDA(4)=IBCNDFN,IBSDA(""FLDS"")=""1;2"""
^XMB(3.9,144657,2,3905,0)="""RTN"",""IBCNBLL"",289,0)"
^XMB(3.9,144657,2,3906,0)=" ..S DFLG="""" ;,APPTNUM=$$SDAPI^SDAMA301(.IBSDA) I APPTNUM>0,SYM=""!"" S DFLG=""d"" ; duplicate flag ;IB*2*506 appointment data removed."
^XMB(3.9,144657,2,3907,0)="""RTN"",""IBCNBLL"",290,0)"
^XMB(3.9,144657,2,3908,0)=" ..;I $$INCL(VIEW,SYM,IB0) S ^TMP($J,""IBCNBLLS"",IBCSORT1,IBCSORT2,IBBUFDA)=DFLG"
^XMB(3.9,144657,2,3909,0)="""RTN"",""IBCNBLL"",291,0)"
^XMB(3.9,144657,2,3910,0)=" ..I $$INCL(VIEW,SYM,IB0) D  ;IB806/DTG add set for new flag 'P'"
^XMB(3.9,144657,2,3911,0)="""RTN"",""IBCNBLL"",292,0)"
^XMB(3.9,144657,2,3912,0)=" ...S ^TMP($J,""IBCNBLLS"",IBCSORT1,IBCSORT2,IBBUFDA)=DFLG"
^XMB(3.9,144657,2,3913,0)="""RTN"",""IBCNBLL"",293,0)"
^XMB(3.9,144657,2,3914,0)=" ...I $G(IBSUBSAV)'="""" S ^TMP(""IBCNBLLSP"",$J,IBCSORT1,IBCSORT2,IBBUFDA)=IBSUBSAV"
^XMB(3.9,144657,2,3915,0)="""RTN"",""IBCNBLL"",294,0)"
^XMB(3.9,144657,2,3916,0)=" ..K VAIN,IBCSORT1,IBCSORT2"
^XMB(3.9,144657,2,3917,0)="""RTN"",""IBCNBLL"",295,0)"
^XMB(3.9,144657,2,3918,0)=" ..Q"
^XMB(3.9,144657,2,3919,0)="""RTN"",""IBCNBLL"",296,0)"
^XMB(3.9,144657,2,3920,0)=" .Q"
^XMB(3.9,144657,2,3921,0)="""RTN"",""IBCNBLL"",297,0)"
^XMB(3.9,144657,2,3922,0)=" ;I IBCNT,'$D(ZTQUEUED) W ""|""  ;IB*794 ""|"" No longer needed"
^XMB(3.9,144657,2,3923,0)="""RTN"",""IBCNBLL"",298,0)"
^XMB(3.9,144657,2,3924,0)=" Q"
^XMB(3.9,144657,2,3925,0)="""RTN"",""IBCNBLL"",299,0)"
^XMB(3.9,144657,2,3926,0)=" ;"
^XMB(3.9,144657,2,3927,0)="""RTN"",""IBCNBLL"",300,0)"
^XMB(3.9,144657,2,3928,0)="INCL(VIEW,SYM,IB0) ;"
^XMB(3.9,144657,2,3929,0)="""RTN"",""IBCNBLL"",301,0)"
^XMB(3.9,144657,2,3930,0)=" N INCL,IENS,IBEBI,MCFLAG"
^XMB(3.9,144657,2,3931,0)="""RTN"",""IBCNBLL"",302,0)"
^XMB(3.9,144657,2,3932,0)=" S INCL=0"
^XMB(3.9,144657,2,3933,0)="""RTN"",""IBCNBLL"",303,0)"
^XMB(3.9,144657,2,3934,0)=" ; IB*2*549 - Added 'MCFLAG to allow Medicare in the following line."
^XMB(3.9,144657,2,3935,0)="""RTN"",""IBCNBLL"",304,0)"
^XMB(3.9,144657,2,3936,0)=" S MCFLAG=$$GTMFLG(IBBUFDA)"
^XMB(3.9,144657,2,3937,0)="""RTN"",""IBCNBLL"",305,0)"
^XMB(3.9,144657,2,3938,0)=" I 'IBKEYS,'MCFLAG,(SYM'=""+"") G INCLQ ; If users don't have required keys, they only see current Positive Entries."
^XMB(3.9,144657,2,3939,0)="""RTN"",""IBCNBLL"",306,0)"
^XMB(3.9,144657,2,3940,0)=" I VIEW=6 S INCL=1 G INCLQ  ;Include Everything  (Complete view)"
^XMB(3.9,144657,2,3941,0)="""RTN"",""IBCNBLL"",307,0)"
^XMB(3.9,144657,2,3942,0)=" I VIEW=7,((INAME[""TRICARE"")!(INAME[""CHAMPVA"")) S INCL=1 G INCLQ  ; Tricare/Champva;528/baa "
^XMB(3.9,144657,2,3943,0)="""RTN"",""IBCNBLL"",308,0)"
^XMB(3.9,144657,2,3944,0)=" I VIEW=5,$P(IB0,U,17) S INCL=1 G INCLQ  ;Only e-Pharmacy on e-Pharmacy view (IB*2*435)"
^XMB(3.9,144657,2,3945,0)="""RTN"",""IBCNBLL"",309,0)"
^XMB(3.9,144657,2,3946,0)=" I $P(IB0,U,17) G INCLQ  ;Exclude e-Pharmacy (IB*2*435)"
^XMB(3.9,144657,2,3947,0)="""RTN"",""IBCNBLL"",310,0)"
^XMB(3.9,144657,2,3948,0)=" I VIEW=3,MCFLAG S INCL=1 G INCLQ ;Only Medicare View"
^XMB(3.9,144657,2,3949,0)="""RTN"",""IBCNBLL"",311,0)"
^XMB(3.9,144657,2,3950,0)=" I MCFLAG G INCLQ  ;Exclude Medicare from Positive, Negative and Failure Views"
^XMB(3.9,144657,2,3951,0)="""RTN"",""IBCNBLL"",312,0)"
^XMB(3.9,144657,2,3952,0)=" I VIEW=4,(SYM=""!"") S INCL=1 G INCLQ  ;Only failures on Failure view"
^XMB(3.9,144657,2,3953,0)="""RTN"",""IBCNBLL"",313,0)"
^XMB(3.9,144657,2,3954,0)=" I VIEW=1,((SYM=""+"")!(SYM=""$"")) S INCL=1 G INCLQ  ;Positive View"
^XMB(3.9,144657,2,3955,0)="""RTN"",""IBCNBLL"",314,0)"
^XMB(3.9,144657,2,3956,0)=" I VIEW=2,(SYM=""-"") S INCL=1 G INCLQ  ;Negative View"
^XMB(3.9,144657,2,3957,0)="""RTN"",""IBCNBLL"",315,0)"
^XMB(3.9,144657,2,3958,0)=" ;I SYM=""*"" D  G INCLQ  ;IB*737/DTG stop '*' verified"
^XMB(3.9,144657,2,3959,0)="""RTN"",""IBCNBLL"",316,0)"
^XMB(3.9,144657,2,3960,0)=" ;. ;find history in Response file for verified entries."
^XMB(3.9,144657,2,3961,0)="""RTN"",""IBCNBLL"",317,0)"
^XMB(3.9,144657,2,3962,0)=" ;. I $$GET1^DIQ(355.33,IBBUFDA,.15)="""" S:(VIEW=1) INCL=1 Q  ;IIV PROCESSED DATE field is empty entry is positive"
^XMB(3.9,144657,2,3963,0)="""RTN"",""IBCNBLL"",318,0)"
^XMB(3.9,144657,2,3964,0)=" ;. S IENS=""1,""_$O(^IBCN(365,""AF"",IBBUFDA,""""))_"","""
^XMB(3.9,144657,2,3965,0)="""RTN"",""IBCNBLL"",319,0)"
^XMB(3.9,144657,2,3966,0)=" ;. ;the following line of code is necessary to check for both ""eIV Eligibility Determination"" and ""IIV Eligibility Determination"" (IB*2.0*506)"
^XMB(3.9,144657,2,3967,0)="""RTN"",""IBCNBLL"",320,0)"
^XMB(3.9,144657,2,3968,0)=" ;. I $$GET1^DIQ(365.02,IENS,.06)[""IV Eligibility Determination"" Q"
^XMB(3.9,144657,2,3969,0)="""RTN"",""IBCNBLL"",321,0)"
^XMB(3.9,144657,2,3970,0)=" ;. S IBEBI=$$GET1^DIQ(365.02,IENS,.02)  ;Eligibility/Benefits Info"
^XMB(3.9,144657,2,3971,0)="""RTN"",""IBCNBLL"",322,0)"
^XMB(3.9,144657,2,3972,0)=" ;. I IBEBI=1 S:(VIEW=1) INCL=1 Q"
^XMB(3.9,144657,2,3973,0)="""RTN"",""IBCNBLL"",323,0)"
^XMB(3.9,144657,2,3974,0)=" ;. I VIEW=2 S INCL=1 Q"
^XMB(3.9,144657,2,3975,0)="""RTN"",""IBCNBLL"",324,0)"
^XMB(3.9,144657,2,3976,0)="INCLQ ;"
^XMB(3.9,144657,2,3977,0)="""RTN"",""IBCNBLL"",325,0)"
^XMB(3.9,144657,2,3978,0)=" Q INCL"
^XMB(3.9,144657,2,3979,0)="""RTN"",""IBCNBLL"",326,0)"
^XMB(3.9,144657,2,3980,0)=" ;"
^XMB(3.9,144657,2,3981,0)="""RTN"",""IBCNBLL"",327,0)"
^XMB(3.9,144657,2,3982,0)="DATE(X) ;"
^XMB(3.9,144657,2,3983,0)="""RTN"",""IBCNBLL"",328,0)"
^XMB(3.9,144657,2,3984,0)=" Q $E(X,4,5)_""/""_$E(X,6,7)_""/""_$E(X,2,3)"
^XMB(3.9,144657,2,3985,0)="""RTN"",""IBCNBLL"",329,0)"
^XMB(3.9,144657,2,3986,0)="HOLD(DFN) ; returns true if patient has bills On Hold"
^XMB(3.9,144657,2,3987,0)="""RTN"",""IBCNBLL"",330,0)"
^XMB(3.9,144657,2,3988,0)=" Q $D(^IB(""AH"",+$G(DFN)))"
^XMB(3.9,144657,2,3989,0)="""RTN"",""IBCNBLL"",331,0)"
^XMB(3.9,144657,2,3990,0)=" ;"
^XMB(3.9,144657,2,3991,0)="""RTN"",""IBCNBLL"",332,0)"
^XMB(3.9,144657,2,3992,0)="SYMBOL(IBBUFDA) ; Returns the symbol for this buffer entry"
^XMB(3.9,144657,2,3993,0)="""RTN"",""IBCNBLL"",333,0)"
^XMB(3.9,144657,2,3994,0)=" NEW IB0,SYM"
^XMB(3.9,144657,2,3995,0)="""RTN"",""IBCNBLL"",334,0)"
^XMB(3.9,144657,2,3996,0)=" S IB0=$G(^IBA(355.33,IBBUFDA,0)),SYM="""""
^XMB(3.9,144657,2,3997,0)="""RTN"",""IBCNBLL"",335,0)"
^XMB(3.9,144657,2,3998,0)=" I +$P(IB0,U,12) S SYM=$C($P($G(^IBE(365.15,+$P(IB0,U,12),0)),U,2))"
^XMB(3.9,144657,2,3999,0)="""RTN"",""IBCNBLL"",336,0)"
^XMB(3.9,144657,2,4000,0)=" ; If the entry has been manually verified, override the symbol displayed"
^XMB(3.9,144657,2,4001,0)="""RTN"",""IBCNBLL"",337,0)"
^XMB(3.9,144657,2,4002,0)=" ;I $P(IB0,U,10)'="""",'+$P(IB0,U,12) S SYM=""*""  ;IB*737/DTG stop '*' verified"
^XMB(3.9,144657,2,4003,0)="""RTN"",""IBCNBLL"",338,0)"
^XMB(3.9,144657,2,4004,0)=" I SYM="""" S SYM="" """
^XMB(3.9,144657,2,4005,0)="""RTN"",""IBCNBLL"",339,0)"
^XMB(3.9,144657,2,4006,0)=" Q SYM"
^XMB(3.9,144657,2,4007,0)="""RTN"",""IBCNBLL"",340,0)"
^XMB(3.9,144657,2,4008,0)=" ;"
^XMB(3.9,144657,2,4009,0)="""RTN"",""IBCNBLL"",341,0)"
^XMB(3.9,144657,2,4010,0)=" ;"
^XMB(3.9,144657,2,4011,0)="""RTN"",""IBCNBLL"",342,0)"
^XMB(3.9,144657,2,4012,0)="UPDLN(IBBUFDA,ACTION) ; *** called by any action that modifies a buffer entry, so list screen can be updated if screen not recompiled"
^XMB(3.9,144657,2,4013,0)="""RTN"",""IBCNBLL"",343,0)"
^XMB(3.9,144657,2,4014,0)=" ; modifies a single line in the display array for a buffer entry that has been modified in some way"
^XMB(3.9,144657,2,4015,0)="""RTN"",""IBCNBLL"",344,0)"
^XMB(3.9,144657,2,4016,0)=" ; ACTION = REJECTED, ACCEPTED, EDITED"
^XMB(3.9,144657,2,4017,0)="""RTN"",""IBCNBLL"",345,0)"
^XMB(3.9,144657,2,4018,0)=" N IBARRN,IBOLD,IBNEW,IBO,IBN S IBO=""0123456789"",IBN=""----------"""
^XMB(3.9,144657,2,4019,0)="""RTN"",""IBCNBLL"",346,0)"
^XMB(3.9,144657,2,4020,0)=" ;"
^XMB(3.9,144657,2,4021,0)="""RTN"",""IBCNBLL"",347,0)"
^XMB(3.9,144657,2,4022,0)=" S IBARRN=$G(^TMP(""IBCNBLLY"",$J,+$G(IBBUFDA))) Q:'IBARRN"
^XMB(3.9,144657,2,4023,0)="""RTN"",""IBCNBLL"",348,0)"
^XMB(3.9,144657,2,4024,0)=" S IBOLD=$G(^TMP(""IBCNBLL"",$J,+IBARRN,0)) Q:IBOLD="""""
^XMB(3.9,144657,2,4025,0)="""RTN"",""IBCNBLL"",349,0)"
^XMB(3.9,144657,2,4026,0)=" ;"
^XMB(3.9,144657,2,4027,0)="""RTN"",""IBCNBLL"",350,0)"
^XMB(3.9,144657,2,4028,0)=" ; if action is REJECTED or ACCEPTED then the patient name is replaced by the Action in the display array"
^XMB(3.9,144657,2,4029,0)="""RTN"",""IBCNBLL"",351,0)"
^XMB(3.9,144657,2,4030,0)=" ; and the buffer entry is removed from the list of entries that can be selected"
^XMB(3.9,144657,2,4031,0)="""RTN"",""IBCNBLL"",352,0)"
^XMB(3.9,144657,2,4032,0)=" I (ACTION=""REJECTED"")!(ACTION=""ACCEPTED"") D"
^XMB(3.9,144657,2,4033,0)="""RTN"",""IBCNBLL"",353,0)"
^XMB(3.9,144657,2,4034,0)=" . S IBNEW=$TR($E(IBOLD,1,5),IBO,IBN)_ACTION_$J("""",7)_$E(IBOLD,21,999)"
^XMB(3.9,144657,2,4035,0)="""RTN"",""IBCNBLL"",354,0)"
^XMB(3.9,144657,2,4036,0)=" . S ^TMP(""IBCNBLL"",$J,+IBARRN,0)=IBNEW"
^XMB(3.9,144657,2,4037,0)="""RTN"",""IBCNBLL"",355,0)"
^XMB(3.9,144657,2,4038,0)=" ;"
^XMB(3.9,144657,2,4039,0)="""RTN"",""IBCNBLL"",356,0)"
^XMB(3.9,144657,2,4040,0)=" ; if the action is EDITED then the line for the buffer entry is recompiled and the updated line is set into "
^XMB(3.9,144657,2,4041,0)="""RTN"",""IBCNBLL"",357,0)"
^XMB(3.9,144657,2,4042,0)=" ; the display array"
^XMB(3.9,144657,2,4043,0)="""RTN"",""IBCNBLL"",358,0)"
^XMB(3.9,144657,2,4044,0)=" I ACTION=""EDITED"" D"
^XMB(3.9,144657,2,4045,0)="""RTN"",""IBCNBLL"",359,0)"
^XMB(3.9,144657,2,4046,0)=" . S IBNEW=$$BLDLN(IBBUFDA,+$P(IBARRN,U,2),$E(IBOLD,25))"
^XMB(3.9,144657,2,4047,0)="""RTN"",""IBCNBLL"",360,0)"
^XMB(3.9,144657,2,4048,0)=" . S ^TMP(""IBCNBLL"",$J,+IBARRN,0)=IBNEW"
^XMB(3.9,144657,2,4049,0)="""RTN"",""IBCNBLL"",361,0)"
^XMB(3.9,144657,2,4050,0)=" Q"
^XMB(3.9,144657,2,4051,0)="""RTN"",""IBCNBLL"",362,0)"
^XMB(3.9,144657,2,4052,0)=" ;"
^XMB(3.9,144657,2,4053,0)="""RTN"",""IBCNBLL"",363,0)"
^XMB(3.9,144657,2,4054,0)="SRCCNV(SRC) ; convert Source of Info acronym from field 355.12/.03 into 1 char code"
^XMB(3.9,144657,2,4055,0)="""RTN"",""IBCNBLL"",364,0)"
^XMB(3.9,144657,2,4056,0)=" ; IB*2*595/DM T,U,B,O,N,S,A,K,J translations added"
^XMB(3.9,144657,2,4057,0)="""RTN"",""IBCNBLL"",365,0)"
^XMB(3.9,144657,2,4058,0)=" ; IB*2*664/DW updated ""U"" for Community Care Network - should be CCN and not PCC"
^XMB(3.9,144657,2,4059,0)="""RTN"",""IBCNBLL"",366,0)"
^XMB(3.9,144657,2,4060,0)=" ; IB*2*664/VD added ""W"" for Electronic Health Record"
^XMB(3.9,144657,2,4061,0)="""RTN"",""IBCNBLL"",367,0)"
^XMB(3.9,144657,2,4062,0)=" ; IB*2*668/DW added ""G"" for Adv Med Cost Mgmt Solution"
^XMB(3.9,144657,2,4063,0)="""RTN"",""IBCNBLL"",368,0)"
^XMB(3.9,144657,2,4064,0)=" N SRCSTR,CODE"
^XMB(3.9,144657,2,4065,0)="""RTN"",""IBCNBLL"",369,0)"
^XMB(3.9,144657,2,4066,0)=" Q:SRC="""" """""
^XMB(3.9,144657,2,4067,0)="""RTN"",""IBCNBLL"",370,0)"
^XMB(3.9,144657,2,4068,0)=" S SRCSTR=""INTVW;I^DMTCH;D^IVM;V^PreRg;P^eIV;E^HMS;H^MCR;M^ICB;R^CS;C^eRxEL;X^IIU;F^INSPT;T^CCN;U^PCFB;B^PCOTR;O^INSIN;N^INSVR;S^VAR;A^KSK;K^MVAH;J^EHR;W^AMCMS;G"""
^XMB(3.9,144657,2,4069,0)="""RTN"",""IBCNBLL"",371,0)"
^XMB(3.9,144657,2,4070,0)=" S CODE=$P($P(SRCSTR,SRC_"";"",2),U,1)"
^XMB(3.9,144657,2,4071,0)="""RTN"",""IBCNBLL"",372,0)"
^XMB(3.9,144657,2,4072,0)=" Q CODE"
^XMB(3.9,144657,2,4073,0)="""RTN"",""IBCNBLL"",373,0)"
^XMB(3.9,144657,2,4074,0)=" ;"
^XMB(3.9,144657,2,4075,0)="""RTN"",""IBCNBLL"",374,0)"
^XMB(3.9,144657,2,4076,0)="GETKEYS(DUZ) ; "
^XMB(3.9,144657,2,4077,0)="""RTN"",""IBCNBLL"",375,0)"
^XMB(3.9,144657,2,4078,0)=" ;Make sure that user has the INSURANCE EDIT key and/or the GROUP/PLAN EDIT key.  User"
^XMB(3.9,144657,2,4079,0)="""RTN"",""IBCNBLL"",376,0)"
^XMB(3.9,144657,2,4080,0)=" ;must have either key in order to see non_Positive Entries."
^XMB(3.9,144657,2,4081,0)="""RTN"",""IBCNBLL"",377,0)"
^XMB(3.9,144657,2,4082,0)=" N KEY1,KEY2"
^XMB(3.9,144657,2,4083,0)="""RTN"",""IBCNBLL"",378,0)"
^XMB(3.9,144657,2,4084,0)=" S KEY1=$O(^DIC(19.1,""B"",""IB INSURANCE COMPANY EDIT"","""")) I KEY1 S KEY1=$D(^VA(200,DUZ,51,KEY1))"
^XMB(3.9,144657,2,4085,0)="""RTN"",""IBCNBLL"",379,0)"
^XMB(3.9,144657,2,4086,0)=" S KEY2=$O(^DIC(19.1,""B"",""IB GROUP PLAN EDIT"","""")) I KEY2 S KEY2=$D(^VA(200,DUZ,51,KEY2))"
^XMB(3.9,144657,2,4087,0)="""RTN"",""IBCNBLL"",380,0)"
^XMB(3.9,144657,2,4088,0)=" Q KEY1!KEY2"
^XMB(3.9,144657,2,4089,0)="""RTN"",""IBCNBLL"",381,0)"
^XMB(3.9,144657,2,4090,0)=" ;"
^XMB(3.9,144657,2,4091,0)="""RTN"",""IBCNBLL"",382,0)"
^XMB(3.9,144657,2,4092,0)="ACTIVE(DFN) ;Check for active insurance"
^XMB(3.9,144657,2,4093,0)="""RTN"",""IBCNBLL"",383,0)"
^XMB(3.9,144657,2,4094,0)=" N IBINSCO"
^XMB(3.9,144657,2,4095,0)="""RTN"",""IBCNBLL"",384,0)"
^XMB(3.9,144657,2,4096,0)=" D ALL^IBCNS1(DFN,""IBINSCO"",3,DT,0)  ;IB*2.0*519 allow WNRs and Indemnity plans"
^XMB(3.9,144657,2,4097,0)="""RTN"",""IBCNBLL"",385,0)"
^XMB(3.9,144657,2,4098,0)=" Q +$G(IBINSCO(0))"
^XMB(3.9,144657,2,4099,0)="""RTN"",""IBCNBLL"",386,0)"
^XMB(3.9,144657,2,4100,0)=" ;"
^XMB(3.9,144657,2,4101,0)="""RTN"",""IBCNBLL"",387,0)"
^XMB(3.9,144657,2,4102,0)="GTMFLG(IBBUFDA) ;Check if Medicare"
^XMB(3.9,144657,2,4103,0)="""RTN"",""IBCNBLL"",388,0)"
^XMB(3.9,144657,2,4104,0)=" ; IB*2.0*549 Added method"
^XMB(3.9,144657,2,4105,0)="""RTN"",""IBCNBLL"",389,0)"
^XMB(3.9,144657,2,4106,0)=" N MWNRIEN,MWNRFLG"
^XMB(3.9,144657,2,4107,0)="""RTN"",""IBCNBLL"",390,0)"
^XMB(3.9,144657,2,4108,0)=" S MWNRFLG=0"
^XMB(3.9,144657,2,4109,0)="""RTN"",""IBCNBLL"",391,0)"
^XMB(3.9,144657,2,4110,0)=" S MWNRIEN=$P($G(^IBE(350.9,1,51)),U,25)"
^XMB(3.9,144657,2,4111,0)="""RTN"",""IBCNBLL"",392,0)"
^XMB(3.9,144657,2,4112,0)=" S MWNRFLG=0"
^XMB(3.9,144657,2,4113,0)="""RTN"",""IBCNBLL"",393,0)"
^XMB(3.9,144657,2,4114,0)=" I MWNRIEN'="""",$P($$INSERROR^IBCNEUT3(""B"",IBBUFDA),U,2)=MWNRIEN S MWNRFLG=1"
^XMB(3.9,144657,2,4115,0)="""RTN"",""IBCNBLL"",394,0)"
^XMB(3.9,144657,2,4116,0)=" Q MWNRFLG"
^XMB(3.9,144657,2,4117,0)="""RTN"",""IBCNBLL"",395,0)"
^XMB(3.9,144657,2,4118,0)="REFRESH ; IB*794/DJW Refresh the buffer data but keep the selected view and sort"
^XMB(3.9,144657,2,4119,0)="""RTN"",""IBCNBLL"",396,0)"
^XMB(3.9,144657,2,4120,0)=" D INIT,HDR"
^XMB(3.9,144657,2,4121,0)="""RTN"",""IBCNBLL"",397,0)"
^XMB(3.9,144657,2,4122,0)=" S VALMBCK=""R"",VALMBG=1"
^XMB(3.9,144657,2,4123,0)="""RTN"",""IBCNBLL"",398,0)"
^XMB(3.9,144657,2,4124,0)=" Q "
^XMB(3.9,144657,2,4125,0)="""RTN"",""IBCNBLL"",399,0)"
^XMB(3.9,144657,2,4126,0)=" ;"
^XMB(3.9,144657,2,4127,0)="""RTN"",""IBCNBLL1"")"
^XMB(3.9,144657,2,4128,0)="1^16"
^XMB(3.9,144657,2,4129,0)="""RTN"",""IBCNEHL5A"")"
^XMB(3.9,144657,2,4130,0)="0^22^B102704194"
^XMB(3.9,144657,2,4131,0)="""RTN"",""IBCNEHL5A"",1,0)"
^XMB(3.9,144657,2,4132,0)="IBCNEHL5A ;AITC/CKB - HL7 Process Incoming RPI Msgs (Cont.) ; 10-JAN-2025"
^XMB(3.9,144657,2,4133,0)="""RTN"",""IBCNEHL5A"",2,0)"
^XMB(3.9,144657,2,4134,0)=" ;;2.0;INTEGRATED BILLING;**806**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,4135,0)="""RTN"",""IBCNEHL5A"",3,0)"
^XMB(3.9,144657,2,4136,0)=" ;;Per VA Directive 6402, this routine should not be modified."
