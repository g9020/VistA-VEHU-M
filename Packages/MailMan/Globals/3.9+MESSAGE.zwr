^XMB(3.9,145839,2,387,0)="""RTN"",""TIUCCHL7UT"",70,0)"
^XMB(3.9,145839,2,388,0)=" S MSGN=$G(HL(""MID""))"
^XMB(3.9,145839,2,389,0)="""RTN"",""TIUCCHL7UT"",71,0)"
^XMB(3.9,145839,2,390,0)=" ;S HLA(""HLA"",1)=""MSA|AE|""_$G(MSGN)_""|""_$G(USERMAIL)_"" ""_$G(NAKMSG)_""|||""_$G(ICN)_""^""_$G(PATNAME)_""^""_SITE_""^""_CONID_""^""_APTTM"
^XMB(3.9,145839,2,391,0)="""RTN"",""TIUCCHL7UT"",72,0)"
^XMB(3.9,145839,2,392,0)=" S HLA(""HLA"",1)=""MSA""_HL(""FS"")_""CA""_HL(""FS"")_$G(MSGID)  ;_HL(""FS"")_$G(TIUEMAIL)_"" ""_$G(MSGTEXT)_HL(""FS"")_HL(""FS"")_HL(""FS"")_$G(ICN)_""^""_$G(TIU(""PTNAME""))_""^""_SITE_""^""_CONID_""^""_$$FMTHL7^XLFDT($$NOW^XLFDT())"
^XMB(3.9,145839,2,393,0)="""RTN"",""TIUCCHL7UT"",73,0)"
^XMB(3.9,145839,2,394,0)=" D GENACK^HLMA1(EID,$G(HLMTIENS),EIDS,""LM"",1,.RES)"
^XMB(3.9,145839,2,395,0)="""RTN"",""TIUCCHL7UT"",74,0)"
^XMB(3.9,145839,2,396,0)=" Q"
^XMB(3.9,145839,2,397,0)="""RTN"",""TIUCCHL7UT"",75,0)"
^XMB(3.9,145839,2,398,0)=" ;PB - Sep 23 - Patch 356 changed how to lookup the note in order to file an addendum for the note"
^XMB(3.9,145839,2,399,0)="""RTN"",""TIUCCHL7UT"",76,0)"
^XMB(3.9,145839,2,400,0)="TIULKUP(CONSULTID,TITLE,NOTEDATE,NOTENUM) ;"
^XMB(3.9,145839,2,401,0)="""RTN"",""TIUCCHL7UT"",77,0)"
^XMB(3.9,145839,2,402,0)=" ;CONSULTID = Consult's IEN from file #123"
^XMB(3.9,145839,2,403,0)="""RTN"",""TIUCCHL7UT"",78,0)"
^XMB(3.9,145839,2,404,0)=" ;TITLE = Note Title IEN from file #8925.1"
^XMB(3.9,145839,2,405,0)="""RTN"",""TIUCCHL7UT"",79,0)"
^XMB(3.9,145839,2,406,0)=" ;NOTEDATE = date of the original note, use to look up the note in 8925, if the original note date"
^XMB(3.9,145839,2,407,0)="""RTN"",""TIUCCHL7UT"",80,0)"
^XMB(3.9,145839,2,408,0)=" ; is not available, use the date of the consult to begin the lookup for the note"
^XMB(3.9,145839,2,409,0)="""RTN"",""TIUCCHL7UT"",81,0)"
^XMB(3.9,145839,2,410,0)=" ;NOTNUM = CCP Note number from the HL7 message for this addendum"
^XMB(3.9,145839,2,411,0)="""RTN"",""TIUCCHL7UT"",82,0)"
^XMB(3.9,145839,2,412,0)=" S:$G(NOTEDATE)="""" NOTEDATE=$$GET1^DIQ(123,CONSULTID_"","",.01,""I""),NOTEDATE=$$FMADD^XLFDT(NOTEDATE,,-1)"
^XMB(3.9,145839,2,413,0)="""RTN"",""TIUCCHL7UT"",83,0)"
^XMB(3.9,145839,2,414,0)=" N TIUIEN,IEN,CCPNUMBER,TIUIEN1"
^XMB(3.9,145839,2,415,0)="""RTN"",""TIUCCHL7UT"",84,0)"
^XMB(3.9,145839,2,416,0)=" S XX=NOTEDATE,TIUIEN1=0 F  S NOTEDATE=$O(^TIU(8925,""F"",NOTEDATE)) Q:NOTEDATE'>0  S IEN=0 F  S IEN=$O(^TIU(8925,""F"",NOTEDATE,IEN)) Q:IEN'>0  D"
^XMB(3.9,145839,2,417,0)="""RTN"",""TIUCCHL7UT"",85,0)"
^XMB(3.9,145839,2,418,0)=" .Q:$P(^TIU(8925,IEN,0),""^"")'=TITLE"
^XMB(3.9,145839,2,419,0)="""RTN"",""TIUCCHL7UT"",86,0)"
^XMB(3.9,145839,2,420,0)=" .N CONSULT"
^XMB(3.9,145839,2,421,0)="""RTN"",""TIUCCHL7UT"",87,0)"
^XMB(3.9,145839,2,422,0)=" .S TIUIEN1=0"
^XMB(3.9,145839,2,423,0)="""RTN"",""TIUCCHL7UT"",88,0)"
^XMB(3.9,145839,2,424,0)=" .K YY"
^XMB(3.9,145839,2,425,0)="""RTN"",""TIUCCHL7UT"",89,0)"
^XMB(3.9,145839,2,426,0)=" .S YY=0 F  S YY=$O(^TIU(8925,IEN,""TEXT"",YY)) Q:YY'>0  D"
^XMB(3.9,145839,2,427,0)="""RTN"",""TIUCCHL7UT"",90,0)"
^XMB(3.9,145839,2,428,0)=" ..Q:TIUIEN1>0"
^XMB(3.9,145839,2,429,0)="""RTN"",""TIUCCHL7UT"",91,0)"
^XMB(3.9,145839,2,430,0)=" ..I $G(^TIU(8925,IEN,""TEXT"",YY,0))[""Unique Consult ID: "" S CONSULT=$P(^TIU(8925,IEN,""TEXT"",YY,0),""_"",2)"
^XMB(3.9,145839,2,431,0)="""RTN"",""TIUCCHL7UT"",92,0)"
^XMB(3.9,145839,2,432,0)=" ..I $G(^TIU(8925,IEN,""TEXT"",YY,0))[""CCPN Number: "" S CCPNUMBER=$P(^TIU(8925,IEN,""TEXT"",YY,0),"" "",3)"
^XMB(3.9,145839,2,433,0)="""RTN"",""TIUCCHL7UT"",93,0)"
^XMB(3.9,145839,2,434,0)=" ..I $G(CONSULT)>0,(CONSULT=CONSULTID),($G(CCPNUMBER)=NOTENUM) S TIUIEN1=IEN ;W !,""TIUIEN= "",TIUIEN Q"
^XMB(3.9,145839,2,435,0)="""RTN"",""TIUCCHL7UT"",94,0)"
^XMB(3.9,145839,2,436,0)=" ..Q:$G(TIUIEN1)>0"
^XMB(3.9,145839,2,437,0)="""RTN"",""TIUCCHL7UT"",95,0)"
^XMB(3.9,145839,2,438,0)=" ;W !,""TIUIEN1= "",TIUIEN1"
^XMB(3.9,145839,2,439,0)="""RTN"",""TIUCCHL7UT"",96,0)"
^XMB(3.9,145839,2,440,0)=" Q TIUIEN1"
^XMB(3.9,145839,2,441,0)="""RTN"",""TIUCCHL7UT"",97,0)"
^XMB(3.9,145839,2,442,0)=" ;added CHECKLST and LIST to lookup the clinic associated with the consult service"
^XMB(3.9,145839,2,443,0)="""RTN"",""TIUCCHL7UT"",98,0)"
^XMB(3.9,145839,2,444,0)="CHECKLST(SERVICENAME) ;"
^XMB(3.9,145839,2,445,0)="""RTN"",""TIUCCHL7UT"",99,0)"
^XMB(3.9,145839,2,446,0)=" ; lookup matching clinic for imaging comm care consults"
^XMB(3.9,145839,2,447,0)="""RTN"",""TIUCCHL7UT"",100,0)"
^XMB(3.9,145839,2,448,0)=" I $G(SERVICENAME)="""" Q 0"
^XMB(3.9,145839,2,449,0)="""RTN"",""TIUCCHL7UT"",101,0)"
^XMB(3.9,145839,2,450,0)=" N CLINID,CLINIC,CONTITLE,DIVID,LEN,I,XC,RSNAME,SERVICENAMEX"
^XMB(3.9,145839,2,451,0)="""RTN"",""TIUCCHL7UT"",102,0)"
^XMB(3.9,145839,2,452,0)=" S CLINID=0,DIVID=$$GET1^DIQ(123,CONSULTID_"","",81,""E"")"
^XMB(3.9,145839,2,453,0)="""RTN"",""TIUCCHL7UT"",103,0)"
^XMB(3.9,145839,2,454,0)=" S:$G(SERVICENAME)["" - "" SERVICENAME=$P(SERVICENAME,"" - "",1)_""-""_$P(SERVICENAME,"" - "",2)"
^XMB(3.9,145839,2,455,0)="""RTN"",""TIUCCHL7UT"",104,0)"
^XMB(3.9,145839,2,456,0)=" S:$G(SERVICENAME)["" -"" SERVICENAME=$P(SERVICENAME,"" -"",1)_""-""_$P(SERVICENAME,"" -"",2)"
^XMB(3.9,145839,2,457,0)="""RTN"",""TIUCCHL7UT"",105,0)"
^XMB(3.9,145839,2,458,0)=" S:$G(SERVICENAME)[""- "" SERVICENAME=$P(SERVICENAME,""- "",1)_""-""_$P(SERVICENAME,""- "",2)"
^XMB(3.9,145839,2,459,0)="""RTN"",""TIUCCHL7UT"",106,0)"
^XMB(3.9,145839,2,460,0)=" S LEN=$L(SERVICENAME),XC=1"
^XMB(3.9,145839,2,461,0)="""RTN"",""TIUCCHL7UT"",107,0)"
^XMB(3.9,145839,2,462,0)=" F I=0:1:LEN I $E(SERVICENAME,I)=""-"" S XC=XC+1"
^XMB(3.9,145839,2,463,0)="""RTN"",""TIUCCHL7UT"",108,0)"
^XMB(3.9,145839,2,464,0)=" S CONTITLE=SERVICENAME"
^XMB(3.9,145839,2,465,0)="""RTN"",""TIUCCHL7UT"",109,0)"
^XMB(3.9,145839,2,466,0)=" S (RSNAME,SERVICENAME)=""COM CARE-""_$P(SERVICENAME,""-"",2,XC),SERVICENAME=$E(SERVICENAME,1,30) S:$E(SERVICENAME,30)="" "" SERVICENAME=$E(SERVICENAME,1,29)"
^XMB(3.9,145839,2,467,0)="""RTN"",""TIUCCHL7UT"",110,0)"
^XMB(3.9,145839,2,468,0)=" S:$E($P(RSNAME,""-"",2),1,3)=""DOD"" (RSNAME,SERVICENAME)=""CC-""_$P(RSNAME,""-"",2,XC)"
^XMB(3.9,145839,2,469,0)="""RTN"",""TIUCCHL7UT"",111,0)"
^XMB(3.9,145839,2,470,0)=" S CLINID=$O(^SC(""B"",$E($G(SERVICENAME),1,30),""""))"
^XMB(3.9,145839,2,471,0)="""RTN"",""TIUCCHL7UT"",112,0)"
^XMB(3.9,145839,2,472,0)=" I $G(CLINID)'>0 D"
^XMB(3.9,145839,2,473,0)="""RTN"",""TIUCCHL7UT"",113,0)"
^XMB(3.9,145839,2,474,0)=" .F I=1:1:20 D"
^XMB(3.9,145839,2,475,0)="""RTN"",""TIUCCHL7UT"",114,0)"
^XMB(3.9,145839,2,476,0)=" ..Q:$G(CLINID)>0"
^XMB(3.9,145839,2,477,0)="""RTN"",""TIUCCHL7UT"",115,0)"
^XMB(3.9,145839,2,478,0)=" ..I $P($P($T(LIST+I),"";;"",2),""^"",1)=CONTITLE S CLINIC=$P($P($T(LIST+I),"";;"",2),""^"",2),CLINID=$O(^SC(""B"",$G(CLINIC),"""")),SERVICENAME=CLINIC"
^XMB(3.9,145839,2,479,0)="""RTN"",""TIUCCHL7UT"",116,0)"
^XMB(3.9,145839,2,480,0)=" I CLINID'>0 D"
^XMB(3.9,145839,2,481,0)="""RTN"",""TIUCCHL7UT"",117,0)"
^XMB(3.9,145839,2,482,0)=" . N LENG,SERVICENAME1"
^XMB(3.9,145839,2,483,0)="""RTN"",""TIUCCHL7UT"",118,0)"
^XMB(3.9,145839,2,484,0)=" . S LENG=0"
^XMB(3.9,145839,2,485,0)="""RTN"",""TIUCCHL7UT"",119,0)"
^XMB(3.9,145839,2,486,0)=" . S LENG=$L(SERVICENAME)"
^XMB(3.9,145839,2,487,0)="""RTN"",""TIUCCHL7UT"",120,0)"
^XMB(3.9,145839,2,488,0)=" . S (SERVICENAME,SERVICENAME1)=$S(LENG>28:$E(SERVICENAME,1,28)_""-X"",1:$G(SERVICENAME)_""-X""),CLINID=$O(^SC(""B"",$G(SERVICENAME1),""""))"
^XMB(3.9,145839,2,489,0)="""RTN"",""TIUCCHL7UT"",121,0)"
^XMB(3.9,145839,2,490,0)=" S SERVICENAMEX=SERVICENAME"
^XMB(3.9,145839,2,491,0)="""RTN"",""TIUCCHL7UT"",122,0)"
^XMB(3.9,145839,2,492,0)=" ;Need to check to see if the clinic is inactive - is there an SDEC API for this?"
^XMB(3.9,145839,2,493,0)="""RTN"",""TIUCCHL7UT"",123,0)"
^XMB(3.9,145839,2,494,0)=" N INACT S:$G(CLINID)>0 INACT=$$INACTIVE^SDEC32(CLINID)"
^XMB(3.9,145839,2,495,0)="""RTN"",""TIUCCHL7UT"",124,0)"
^XMB(3.9,145839,2,496,0)=" I $G(INACT)=1 S (NAKMSG,ERR1)=""Clinic ""_$P(^SC(CLINID,0),""^"")_"" is inactive"",ABORT=""1^""_ERR1 Q 0"
^XMB(3.9,145839,2,497,0)="""RTN"",""TIUCCHL7UT"",125,0)"
^XMB(3.9,145839,2,498,0)=" ;If no matching clinic found look for com care-other-DIVID (DIVID from the PV! segment)"
^XMB(3.9,145839,2,499,0)="""RTN"",""TIUCCHL7UT"",126,0)"
^XMB(3.9,145839,2,500,0)=" I CLINID'>0!$G(INACT)=1 S CLINID=$O(^SC(""B"",""COM CARE-OTHER-""_DIVID,"""")) S:$G(CLINID)>0 (SERVICENAMEX,SERVICENAME)=$P(^SC(CLINID,0),""^"") S:$G(CLINID)'>0 (SERVICENAMEX,SERVICENAME)=""COM CARE-OTHER-""_$G(DIVID)"
^XMB(3.9,145839,2,501,0)="""RTN"",""TIUCCHL7UT"",127,0)"
^XMB(3.9,145839,2,502,0)=" I CLINID'>0!$G(INACT)=1 S CLINID=$O(^SC(""B"",""COM CARE-OTHER"","""")) S:$G(CLINID)>0 (SERVICENAMEX,SERVICENAME)=$P(^SC(CLINID,0),""^"") S:$G(CLINID)'>0 (SERVICENAMEX,SERVICENAME)=""COM CARE-OTHER"""
^XMB(3.9,145839,2,503,0)="""RTN"",""TIUCCHL7UT"",128,0)"
^XMB(3.9,145839,2,504,0)=" Q CLINID"
^XMB(3.9,145839,2,505,0)="""RTN"",""TIUCCHL7UT"",129,0)"
^XMB(3.9,145839,2,506,0)="LIST ; List of Imaging Community Care consult titles and clinics"
^XMB(3.9,145839,2,507,0)="""RTN"",""TIUCCHL7UT"",130,0)"
^XMB(3.9,145839,2,508,0)=" ;;COMMUNITY CARE-IMAGING CT-AUTO^COM CARE-IMAG CT-AUTO"
^XMB(3.9,145839,2,509,0)="""RTN"",""TIUCCHL7UT"",131,0)"
^XMB(3.9,145839,2,510,0)=" ;;COMMUNITY CARE-IMAGING GENERAL RADIOLOGY-AUTO^COM CARE-IMAG GEN RAD-AUTO"
^XMB(3.9,145839,2,511,0)="""RTN"",""TIUCCHL7UT"",132,0)"
^XMB(3.9,145839,2,512,0)=" ;;COMMUNITY CARE-IMAGING MAGNETIC RESONANCE IMAGING-AUTO^COM CARE-IMAG MRI-AUTO"
^XMB(3.9,145839,2,513,0)="""RTN"",""TIUCCHL7UT"",133,0)"
^XMB(3.9,145839,2,514,0)=" ;;COMMUNITY CARE-IMAGING MAMMOGRAPHY DIAGNOSTIC-AUTO^COM CARE-IMAG MAM DIAG-AUTO"
^XMB(3.9,145839,2,515,0)="""RTN"",""TIUCCHL7UT"",134,0)"
^XMB(3.9,145839,2,516,0)=" ;;COMMUNITY CARE-IMAGING MAMMOGRAPHY SCREEN-AUTO^COM CARE-IMAG MAM SCR-AUTO"
^XMB(3.9,145839,2,517,0)="""RTN"",""TIUCCHL7UT"",135,0)"
^XMB(3.9,145839,2,518,0)=" ;;COMMUNITY CARE-IMAGING NUCLEAR MEDICINE-AUTO^COM CARE-IMAG NUC MEC-AUTO"
^XMB(3.9,145839,2,519,0)="""RTN"",""TIUCCHL7UT"",136,0)"
^XMB(3.9,145839,2,520,0)=" ;;COMMUNITY CARE-IMAGING ULTRASOUND-AUTO^COM CARE-IMAG U/S-AUTO"
^XMB(3.9,145839,2,521,0)="""RTN"",""TIUCCHL7UT"",137,0)"
^XMB(3.9,145839,2,522,0)=" ;;COMMUNITY CARE-CIH BIOFEEDBACK/NEUROFEEDBACK^COM CARE-CIH BIO/NEURO FB"
^XMB(3.9,145839,2,523,0)="""RTN"",""TIUCCHL7UT"",138,0)"
^XMB(3.9,145839,2,524,0)=" ;;COMMUNITY CARE-CIH CLINICAL/BEHAVIORAL HYPNOTHERAPY^COM CARE-CIH CLIN/BEH HYPNO"
^XMB(3.9,145839,2,525,0)="""RTN"",""TIUCCHL7UT"",139,0)"
^XMB(3.9,145839,2,526,0)=" ;;COMMUNITY CARE-EMERGENCY TREATMENT APPROVED^COM CARE-EMER TREAT APPR"
^XMB(3.9,145839,2,527,0)="""RTN"",""TIUCCHL7UT"",140,0)"
^XMB(3.9,145839,2,528,0)=" ;;COMMUNITY CARE-INFERTILITY EVAL ONLY^COM CARE-INFERTILITY EVAL"
^XMB(3.9,145839,2,529,0)="""RTN"",""TIUCCHL7UT"",141,0)"
^XMB(3.9,145839,2,530,0)=" ;;COMMUNITY CARE-GEC ADULT DAY HEALTH CARE^COM CARE-GEC ADHC"
^XMB(3.9,145839,2,531,0)="""RTN"",""TIUCCHL7UT"",142,0)"
^XMB(3.9,145839,2,532,0)=" ;;COMMUNITY CARE-GEC NON-SKILLED HOME HEALTH AIDE^COM CARE-GEC NON-SK HHA"
^XMB(3.9,145839,2,533,0)="""RTN"",""TIUCCHL7UT"",143,0)"
^XMB(3.9,145839,2,534,0)=" ;;COMMUNITY CARE-IMAGING CT COLONOGRAPHY^COM CARE-IMAG CT COLON"
^XMB(3.9,145839,2,535,0)="""RTN"",""TIUCCHL7UT"",144,0)"
^XMB(3.9,145839,2,536,0)=" ;;COMMUNITY CARE-IMAGING BARIUM ENEMA^COM CARE-IMAG BARIUM ENEMA"
^XMB(3.9,145839,2,537,0)="""RTN"",""TIUCCHL7UT"",145,0)"
^XMB(3.9,145839,2,538,0)=" ;;COMMUNITY CARE-HOME SLEEP APNEA TEST^COM CARE-HOME SLEEP APNEA"
^XMB(3.9,145839,2,539,0)="""RTN"",""TIUCCHL7UT"",146,0)"
^XMB(3.9,145839,2,540,0)=" ;;COMMUNITY CARE-PTSD CLINICAL DEMONSTRATION (HBOT)^COM CARE-PTSD CL DEMO (HBOT)"
^XMB(3.9,145839,2,541,0)="""RTN"",""TIUCCHL7UT"",147,0)"
^XMB(3.9,145839,2,542,0)=" ;;COMMUNITY CARE-TREATMENT RESISTANT DEPRESSION^COM CARE-TRT RESIST DEP"
^XMB(3.9,145839,2,543,0)="""RTN"",""TIUCCHL7UT"",148,0)"
^XMB(3.9,145839,2,544,0)=" ;;COMMUNITY CARE-HEMATOLOGY/ONCOLOGY^COM CARE-HEMATOLOGY/ONCOLOGY"
^XMB(3.9,145839,2,545,0)="""RTN"",""TIUCCHL7UT"",149,0)"
^XMB(3.9,145839,2,546,0)=" ;;COMMUNITY CARE-HARDSHIP DETERMINATION^COM CARE-HARDSHIP DETER"
^XMB(3.9,145839,2,547,0)="""RTN"",""TIUCCRHL7P1"")"
^XMB(3.9,145839,2,548,0)="0^1^B174119283"
^XMB(3.9,145839,2,549,0)="""RTN"",""TIUCCRHL7P1"",1,0)"
^XMB(3.9,145839,2,550,0)="TIUCCRHL7P1 ; CCRA/PB - TIU CCRA HL7 Msg Processing; January 6, 2006"
^XMB(3.9,145839,2,551,0)="""RTN"",""TIUCCRHL7P1"",2,0)"
^XMB(3.9,145839,2,552,0)=" ;;1.0;TEXT INTEGRATION UTILITIES;**337,344,348,349,352,356,366,371**;Sep 27, 2023;Build 0"
^XMB(3.9,145839,2,553,0)="""RTN"",""TIUCCRHL7P1"",3,0)"
^XMB(3.9,145839,2,554,0)=" ;"
^XMB(3.9,145839,2,555,0)="""RTN"",""TIUCCRHL7P1"",4,0)"
^XMB(3.9,145839,2,556,0)=" ;PB - Patch 344 to modify how the note and addendum text is formatted"
^XMB(3.9,145839,2,557,0)="""RTN"",""TIUCCRHL7P1"",5,0)"
^XMB(3.9,145839,2,558,0)=" ;PB - Patch 348 modification to parse the note text from NTE segments rather than the OBX segment"
^XMB(3.9,145839,2,559,0)="""RTN"",""TIUCCRHL7P1"",6,0)"
^XMB(3.9,145839,2,560,0)=" ;PB - Patch 349 modification to parse and file the consult factor from the note and file as a comment with the consult"
^XMB(3.9,145839,2,561,0)="""RTN"",""TIUCCRHL7P1"",7,0)"
^XMB(3.9,145839,2,562,0)=" ;NOTES FROM NOV 10: Need to loop thru the XTMP(""TIUHL7"" temp global and if the last character is "
^XMB(3.9,145839,2,563,0)="""RTN"",""TIUCCRHL7P1"",8,0)"
^XMB(3.9,145839,2,564,0)=" ;$C(160), remove it."
^XMB(3.9,145839,2,565,0)="""RTN"",""TIUCCRHL7P1"",9,0)"
^XMB(3.9,145839,2,566,0)=" ;PB - Patch 352 removes the text CF#: from the CFNOTE"
^XMB(3.9,145839,2,567,0)="""RTN"",""TIUCCRHL7P1"",10,0)"
^XMB(3.9,145839,2,568,0)=" ;PB - Patch 356 modifications to file the note as a stand-alone note and not linked to a consult"
^XMB(3.9,145839,2,569,0)="""RTN"",""TIUCCRHL7P1"",11,0)"
^XMB(3.9,145839,2,570,0)=" ;PB - Patch 371 removes unused code"
^XMB(3.9,145839,2,571,0)="""RTN"",""TIUCCRHL7P1"",12,0)"
^XMB(3.9,145839,2,572,0)=" Q"
^XMB(3.9,145839,2,573,0)="""RTN"",""TIUCCRHL7P1"",13,0)"
^XMB(3.9,145839,2,574,0)="PROCMSG ;"
^XMB(3.9,145839,2,575,0)="""RTN"",""TIUCCRHL7P1"",14,0)"
^XMB(3.9,145839,2,576,0)=" N DFN,DUZ,CONSULTID,MSGID,TIU,TIUDA,TIUDPRM,TIUDT,TIUERR,TIUI,TIUJ,TIUMSG,TIUELS,STOP,TIUIEN,NOTEDATE,NOTENUM"
^XMB(3.9,145839,2,577,0)="""RTN"",""TIUCCRHL7P1"",15,0)"
^XMB(3.9,145839,2,578,0)=" N TIUEMAIL,TIUNAME,TIUTMP,TIUFS,TIUCS,TIURS,TIUES,TIUSS,TIUZ,VNUM,MSGTEXT,ADDENDUM,CFNOTE,ORIGSTAT,CONSULTID"
^XMB(3.9,145839,2,579,0)="""RTN"",""TIUCCRHL7P1"",16,0)"
^XMB(3.9,145839,2,580,0)=" S ADDENDUM="""""
^XMB(3.9,145839,2,581,0)="""RTN"",""TIUCCRHL7P1"",17,0)"
^XMB(3.9,145839,2,582,0)=" ; remove HL7 message entries7 days or older"
^XMB(3.9,145839,2,583,0)="""RTN"",""TIUCCRHL7P1"",18,0)"
^XMB(3.9,145839,2,584,0)=" D CLEAN^TIUHL7U1"
^XMB(3.9,145839,2,585,0)="""RTN"",""TIUCCRHL7P1"",19,0)"
^XMB(3.9,145839,2,586,0)=" S U=""^"""
^XMB(3.9,145839,2,587,0)="""RTN"",""TIUCCRHL7P1"",20,0)"
^XMB(3.9,145839,2,588,0)=" S TIUDT=$$NOW^XLFDT"
^XMB(3.9,145839,2,589,0)="""RTN"",""TIUCCRHL7P1"",21,0)"
^XMB(3.9,145839,2,590,0)=" ; sets field, component and repetition separators from HL7 Message"
^XMB(3.9,145839,2,591,0)="""RTN"",""TIUCCRHL7P1"",22,0)"
^XMB(3.9,145839,2,592,0)=" S TIUFS=$G(HL(""FS"")),TIUJ=0 F TIUI=""TIUCS"",""TIURS"",""TIUES"",""TIUSS"" S TIUJ=TIUJ+1 S @TIUI=$E(HL(""ECH""),TIUJ,TIUJ)"
^XMB(3.9,145839,2,593,0)="""RTN"",""TIUCCRHL7P1"",23,0)"
^XMB(3.9,145839,2,594,0)=" ; initializes variables and ^XTMP expiration"
^XMB(3.9,145839,2,595,0)="""RTN"",""TIUCCRHL7P1"",24,0)"
^XMB(3.9,145839,2,596,0)=" S TIU=""TIU"",(TIU(""EC""),TIUDA)=0,TIUNAME=$NA(^XTMP(""TIUHL7"",TIUDT,HLMTIENS)),^XTMP(""TIUHL7"",0)=$$FMADD^XLFDT(TIUDT,7)_U_TIUDT"
^XMB(3.9,145839,2,597,0)="""RTN"",""TIUCCRHL7P1"",25,0)"
^XMB(3.9,145839,2,598,0)=" S MSGID=HL(""MID"")"
^XMB(3.9,145839,2,599,0)="""RTN"",""TIUCCRHL7P1"",26,0)"
^XMB(3.9,145839,2,600,0)=" ; retrieves HL7 message and stores to temporary global"
^XMB(3.9,145839,2,601,0)="""RTN"",""TIUCCRHL7P1"",27,0)"
^XMB(3.9,145839,2,602,0)=" F TIUI=1:1 X HLNEXT Q:HLQUIT'>0  D"
^XMB(3.9,145839,2,603,0)="""RTN"",""TIUCCRHL7P1"",28,0)"
^XMB(3.9,145839,2,604,0)=" . S @TIUNAME@(""MSG"",TIUI)=HLNODE,TIUJ=0"
^XMB(3.9,145839,2,605,0)="""RTN"",""TIUCCRHL7P1"",29,0)"
^XMB(3.9,145839,2,606,0)=" . F  S TIUJ=$O(HLNODE(TIUJ)) Q:'TIUJ  D"
^XMB(3.9,145839,2,607,0)="""RTN"",""TIUCCRHL7P1"",30,0)"
^XMB(3.9,145839,2,608,0)=" . . S @TIUNAME@(""MSG"",TIUI)=@TIUNAME@(""MSG"",TIUI)_HLNODE(TIUJ)  ;$$TIUC^TIUCCHL7UT(HLNODE(TIUJ))"
^XMB(3.9,145839,2,609,0)="""RTN"",""TIUCCRHL7P1"",31,0)"
^XMB(3.9,145839,2,610,0)=" ; places temporary global in local meory & adds EOM flag"
^XMB(3.9,145839,2,611,0)="""RTN"",""TIUCCRHL7P1"",32,0)"
^XMB(3.9,145839,2,612,0)=" M TIUMSG=@TIUNAME@(""MSG"")"
^XMB(3.9,145839,2,613,0)="""RTN"",""TIUCCRHL7P1"",33,0)"
^XMB(3.9,145839,2,614,0)=" S TIU(""XTMP"")=TIUNAME,TIUNAME=""TIUMSG"",TIUI="""",TIUI=$O(TIUMSG(TIUI),-1),TIUI=TIUI+1,TIUMSG(TIUI)=""EOM"""
^XMB(3.9,145839,2,615,0)="""RTN"",""TIUCCRHL7P1"",34,0)"
^XMB(3.9,145839,2,616,0)=" ; verify message format"
^XMB(3.9,145839,2,617,0)="""RTN"",""TIUCCRHL7P1"",35,0)"
^XMB(3.9,145839,2,618,0)=" S TIUI="""" F  S TIUI=$O(@TIUNAME@(TIUI)) Q:@TIUNAME@(TIUI)=""EOM""  D"
^XMB(3.9,145839,2,619,0)="""RTN"",""TIUCCRHL7P1"",36,0)"
^XMB(3.9,145839,2,620,0)=" . S TIUJ=$S(TIUI=1:""MSH"",TIUI=2:""EVN"",TIUI=3:""PID"",TIUI=4:""PV1"",TIUI=5:""TXA"",TIUI=6:""OBX"",TIUI>6:""NTE"",1:""OBX"")"
^XMB(3.9,145839,2,621,0)="""RTN"",""TIUCCRHL7P1"",37,0)"
^XMB(3.9,145839,2,622,0)=" . I $P(@TIUNAME@(TIUI),TIUFS)'=TIUJ D ERR^TIUCCHL7UT(""MSG"",1,""000.000"",""Improper/missing message format: ""_TIUJ_"" segment."")"
^XMB(3.9,145839,2,623,0)="""RTN"",""TIUCCRHL7P1"",38,0)"
^XMB(3.9,145839,2,624,0)=" ; get consult id"
^XMB(3.9,145839,2,625,0)="""RTN"",""TIUCCRHL7P1"",39,0)"
^XMB(3.9,145839,2,626,0)=" S CONSULTID=$$REMESC^TIUHL7U1($P($G(@TIUNAME@(4)),TIUFS,20))"
^XMB(3.9,145839,2,627,0)="""RTN"",""TIUCCRHL7P1"",40,0)"
^XMB(3.9,145839,2,628,0)=" ; get patient name [required]"
^XMB(3.9,145839,2,629,0)="""RTN"",""TIUCCRHL7P1"",41,0)"
^XMB(3.9,145839,2,630,0)=" S TIU(""PTNAME"")=$$UPPER^HLFNC($$FMNAME^HLFNC($P($P($G(@TIUNAME@(3)),TIUFS,6),TIUCS,1,4),TIUCS)),TIU(""PTNAME"")=$$REMESC^TIUHL7U1(TIU(""PTNAME""))"
^XMB(3.9,145839,2,631,0)="""RTN"",""TIUCCRHL7P1"",42,0)"
^XMB(3.9,145839,2,632,0)=" ; get patient ICN/SSN/DFN - order may vary [conditionally required]"
^XMB(3.9,145839,2,633,0)="""RTN"",""TIUCCRHL7P1"",43,0)"
^XMB(3.9,145839,2,634,0)=" S (TIU(""DFN""),TIU(""ICN""),TIU(""SSN""))="""" F TIUI=1:1:$L($P($G(@TIUNAME@(3)),U,4),TIURS) S TIUJ=$P($P($G(@TIUNAME@(3)),TIUFS,4),TIURS,TIUI) I +TIUJ>0 D"
^XMB(3.9,145839,2,635,0)="""RTN"",""TIUCCRHL7P1"",44,0)"
^XMB(3.9,145839,2,636,0)=" . S TIU(""ICN"")=+$P(TIUJ,U,1)"
^XMB(3.9,145839,2,637,0)="""RTN"",""TIUCCRHL7P1"",45,0)"
^XMB(3.9,145839,2,638,0)=" I +$G(TIU(""ICN""))'>0 S MSGTEXT=""Patient ICN not in HL7 message."",STOP=1 D MESSAGE^TIUCCRHL7P3(MSGID,$G(CONSULTID),MSGTEXT),ANAK^TIUCCHL7UT(MSGID,$G(MSGTEXT),$G(CONSULTID))"
^XMB(3.9,145839,2,639,0)="""RTN"",""TIUCCRHL7P1"",46,0)"
^XMB(3.9,145839,2,640,0)=" Q:$G(STOP)=1"
^XMB(3.9,145839,2,641,0)="""RTN"",""TIUCCRHL7P1"",47,0)"
^XMB(3.9,145839,2,642,0)=" Q:+$G(TIU(""ICN""))'>0"
^XMB(3.9,145839,2,643,0)="""RTN"",""TIUCCRHL7P1"",48,0)"
^XMB(3.9,145839,2,644,0)=" S (DFN,TIU(""DFN""))=$$GETDFN^MPIF001($P(TIU(""ICN""),""V"")),TIU(""SSN"")=$$GET1^DIQ(2,TIU(""DFN"")_"","",.09,""I"")"
^XMB(3.9,145839,2,645,0)="""RTN"",""TIUCCRHL7P1"",49,0)"
^XMB(3.9,145839,2,646,0)=" S TIUTMP=$S($P(TIUJ,TIUCS,5)=""NI"":""ICN"",$P(TIUJ,TIUCS,5)=""SS"":""SSN"",$P(TIUJ,TIUCS,5)=""PI"":""DFN"",1:""UNK"")"
^XMB(3.9,145839,2,647,0)="""RTN"",""TIUCCRHL7P1"",50,0)"
^XMB(3.9,145839,2,648,0)=" I +TIU(""DFN"")=-1 S MSGTEXT=""Patient not found on VistA "",STOP=1 D MESSAGE^TIUCCRHL7P3(MSGID,$G(CONSULTID),MSGTEXT),ANAK^TIUCCHL7UT(MSGID,$G(MSGTEXT),$G(CONSULTID))"
^XMB(3.9,145839,2,649,0)="""RTN"",""TIUCCRHL7P1"",51,0)"
^XMB(3.9,145839,2,650,0)=" Q:$G(STOP)=1"
^XMB(3.9,145839,2,651,0)="""RTN"",""TIUCCRHL7P1"",52,0)"
^XMB(3.9,145839,2,652,0)=" Q:+TIU(""DFN"")=-1"
^XMB(3.9,145839,2,653,0)="""RTN"",""TIUCCRHL7P1"",53,0)"
^XMB(3.9,145839,2,654,0)=" ; get DOCUMENT TITLE (#8925.1) [required] & set IEN, document title is in TIU(""TITLE"")"
^XMB(3.9,145839,2,655,0)="""RTN"",""TIUCCRHL7P1"",54,0)"
^XMB(3.9,145839,2,656,0)=" S TIU(""TITLE"")=$$UPPER^HLFNC($P($G(@TIUNAME@(5)),TIUFS,17)),TIU(""TITLE"")=$$REMESC^TIUHL7U1(TIU(""TITLE""))"
^XMB(3.9,145839,2,657,0)="""RTN"",""TIUCCRHL7P1"",55,0)"
^XMB(3.9,145839,2,658,0)=" S TIU(""TITLEB"")=$$UPPER^HLFNC($P($G(@TIUNAME@(5)),TIUFS,3)),TIU(""TITLEB"")=$$REMESC^TIUHL7U1(TIU(""TITLEB"")),TIU(""TITLEB"")=$P(TIU(""TITLEB""),""^"",2)"
^XMB(3.9,145839,2,659,0)="""RTN"",""TIUCCRHL7P1"",56,0)"
^XMB(3.9,145839,2,660,0)=" ;patch 344 code below to determine if this is an original note or an addendum"
^XMB(3.9,145839,2,661,0)="""RTN"",""TIUCCRHL7P1"",57,0)"
^XMB(3.9,145839,2,662,0)=" I $G(TIU(""TITLEB""))[""ADDENDUM"" D"
^XMB(3.9,145839,2,663,0)="""RTN"",""TIUCCRHL7P1"",58,0)"
^XMB(3.9,145839,2,664,0)=" .K T2 S T2("" - "")=""-"" S TIU(""TITLEB"")=$$REPLACE^XLFSTR(TIU(""TITLEB""),.T2) K T2"
^XMB(3.9,145839,2,665,0)="""RTN"",""TIUCCRHL7P1"",59,0)"
^XMB(3.9,145839,2,666,0)=" .S:$G(TIU(""TITLEB""))[""ADDENDUM"" ADDENDUM=$P(TIU(""TITLEB""),""-"",2)"
^XMB(3.9,145839,2,667,0)="""RTN"",""TIUCCRHL7P1"",60,0)"
^XMB(3.9,145839,2,668,0)=" S TIU(""TDA"")=$$LU^TIUHL7U1(8925.1,TIU(""TITLE""),""X"",""I $P(^TIU(8925.1,+Y,0),U,4)=""""DOC"""""") I $L(TIU(""TITLE""))'>0 S TIU(""TITLE"")=""[UNKNOWN]"""
^XMB(3.9,145839,2,669,0)="""RTN"",""TIUCCRHL7P1"",61,0)"
^XMB(3.9,145839,2,670,0)=" ; get VISIT # [optional]"
^XMB(3.9,145839,2,671,0)="""RTN"",""TIUCCRHL7P1"",62,0)"
^XMB(3.9,145839,2,672,0)=" S:$G(TIU(""VNUM""))'="""" TIU(""AVAIL"")=""AV"",TIU(""COMP"")=""LA"""
^XMB(3.9,145839,2,673,0)="""RTN"",""TIUCCRHL7P1"",63,0)"
^XMB(3.9,145839,2,674,0)=" ;line of code added below to test filing a note but not linking it to a consult"
^XMB(3.9,145839,2,675,0)="""RTN"",""TIUCCRHL7P1"",64,0)"
^XMB(3.9,145839,2,676,0)=" S TIU(""AVAIL"")=""AV"",TIU(""COMP"")=""LA"""
^XMB(3.9,145839,2,677,0)="""RTN"",""TIUCCRHL7P1"",65,0)"
^XMB(3.9,145839,2,678,0)=" S TIU(""SIGNED"")=$$NOW^TIULC,TIU(""CSIGNED"")="""""
^XMB(3.9,145839,2,679,0)="""RTN"",""TIUCCRHL7P1"",66,0)"
^XMB(3.9,145839,2,680,0)=" S TIUEMAIL=$$LOW^XLFSTR($P($G(@TIUNAME@(5)),TIUFS,10))"
^XMB(3.9,145839,2,681,0)="""RTN"",""TIUCCRHL7P1"",67,0)"
^XMB(3.9,145839,2,682,0)=" I $L(TIUEMAIL)'>0 S MSGTEXT=""Missing or invalid VA Email Address."",STOP=1 D MESSAGE^TIUCCRHL7P3(MSGID,$G(CONSULTID),MSGTEXT),ANAK^TIUCCHL7UT(MSGID,$G(MSGTEXT),$G(CONSULTID))"
^XMB(3.9,145839,2,683,0)="""RTN"",""TIUCCRHL7P1"",68,0)"
^XMB(3.9,145839,2,684,0)=" Q:$G(STOP)=1"
^XMB(3.9,145839,2,685,0)="""RTN"",""TIUCCRHL7P1"",69,0)"
^XMB(3.9,145839,2,686,0)=" Q:$L(TIUEMAIL)'>0"
^XMB(3.9,145839,2,687,0)="""RTN"",""TIUCCRHL7P1"",70,0)"
^XMB(3.9,145839,2,688,0)=" S (TIU(""AUIEN""),TIU(""AUDA""))=$O(^VA(200,""ADUPN"",TIUEMAIL,""""))"
^XMB(3.9,145839,2,689,0)="""RTN"",""TIUCCRHL7P1"",71,0)"
^XMB(3.9,145839,2,690,0)=" I $L(TIU(""AUIEN""))'>0 S MSGTEXT=""No valid User Account for ""_$G(TIUEMAIL),STOP=1 D MESSAGE^TIUCCRHL7P3(MSGID,$G(CONSULTID),MSGTEXT),ANAK^TIUCCHL7UT(MSGID,$G(MSGTEXT),$G(CONSULTID))"
^XMB(3.9,145839,2,691,0)="""RTN"",""TIUCCRHL7P1"",72,0)"
^XMB(3.9,145839,2,692,0)=" Q:$G(STOP)=1"
^XMB(3.9,145839,2,693,0)="""RTN"",""TIUCCRHL7P1"",73,0)"
^XMB(3.9,145839,2,694,0)=" Q:$L(TIU(""AUIEN""))'>0"
^XMB(3.9,145839,2,695,0)="""RTN"",""TIUCCRHL7P1"",74,0)"
^XMB(3.9,145839,2,696,0)=" S TIU(""AUNAME"")=$$UPPER^HLFNC($P(^VA(200,TIU(""AUIEN""),0),U,1))"
^XMB(3.9,145839,2,697,0)="""RTN"",""TIUCCRHL7P1"",75,0)"
^XMB(3.9,145839,2,698,0)=" S TIU(""AUNAME"")=$$REMESC^TIUHL7U1(TIU(""AUNAME""))"
^XMB(3.9,145839,2,699,0)="""RTN"",""TIUCCRHL7P1"",76,0)"
^XMB(3.9,145839,2,700,0)=" S TIU(""ELESIG"")=$$GET1^DIQ(200,TIU(""AUIEN""),20.4)"
^XMB(3.9,145839,2,701,0)="""RTN"",""TIUCCRHL7P1"",77,0)"
^XMB(3.9,145839,2,702,0)=" S TIUTMP="""" F  S TIUTMP=$O(@TIUNAME@(TIUTMP)) Q:TIUTMP=""""  D:$P($G(@TIUNAME@(TIUTMP)),TIUFS)=""OBX"""
^XMB(3.9,145839,2,703,0)="""RTN"",""TIUCCRHL7P1"",78,0)"
^XMB(3.9,145839,2,704,0)=" . I $P(@TIUNAME@(TIUTMP),TIUFS,2)=1,$L($G(TIU(""SUB"")))'>0 S TIU(""SUB"")=$P($P(@TIUNAME@(TIUTMP),TIUFS,4),TIUCS,2),TIU(""SUB"")=$$REMESC^TIUHL7U1(TIU(""SUB""))"
^XMB(3.9,145839,2,705,0)="""RTN"",""TIUCCRHL7P1"",79,0)"
^XMB(3.9,145839,2,706,0)=" . F TIUI=1:1:$L($P(@TIUNAME@(TIUTMP),TIUFS,6),TIURS) D"
^XMB(3.9,145839,2,707,0)="""RTN"",""TIUCCRHL7P1"",80,0)"
^XMB(3.9,145839,2,708,0)=" . . S TIUZ(""TEXT"",TIUI,0)=$P($P(@TIUNAME@(TIUTMP),TIUFS,6),TIURS,TIUI)"
^XMB(3.9,145839,2,709,0)="""RTN"",""TIUCCRHL7P1"",81,0)"
^XMB(3.9,145839,2,710,0)=" . . S TIUZ(""TEXT"",TIUI,0)=$$STRIP^TIUHL7U2($$REMESC^TIUHL7U1(TIUZ(""TEXT"",TIUI,0)))"
^XMB(3.9,145839,2,711,0)="""RTN"",""TIUCCRHL7P1"",82,0)"
^XMB(3.9,145839,2,712,0)=" I $L(@TIUNAME@(7))>0&($E(@TIUNAME@(7),1,3)=""NTE"") D"
^XMB(3.9,145839,2,713,0)="""RTN"",""TIUCCRHL7P1"",83,0)"
^XMB(3.9,145839,2,714,0)=" .N X1X,XCNTX S XCNTX=1,X1X=6 F  S X1X=$O(@TIUNAME@(X1X)) Q:X1X'>""""  D"
^XMB(3.9,145839,2,715,0)="""RTN"",""TIUCCRHL7P1"",84,0)"
^XMB(3.9,145839,2,716,0)=" ..S TIUZ(""TEXT"",XCNTX,0)=$TR($P($G(@TIUNAME@(X1X)),""|"",4),$C(160),"" "")"
^XMB(3.9,145839,2,717,0)="""RTN"",""TIUCCRHL7P1"",85,0)"
^XMB(3.9,145839,2,718,0)=" ..I $G(TIUZ(""TEXT"",XCNTX,0))[""&apos;"" D"
^XMB(3.9,145839,2,719,0)="""RTN"",""TIUCCRHL7P1"",86,0)"
^XMB(3.9,145839,2,720,0)=" ...N SPEC,T5 S SPEC(""&apos;"")=""'"",T5=TIUZ(""TEXT"",XCNTX,0)"
^XMB(3.9,145839,2,721,0)="""RTN"",""TIUCCRHL7P1"",87,0)"
^XMB(3.9,145839,2,722,0)=" ...S TIUZ(""TEXT"",XCNTX,0)=$$REPLACE^XLFSTR(T5,.SPEC)"
^XMB(3.9,145839,2,723,0)="""RTN"",""TIUCCRHL7P1"",88,0)"
^XMB(3.9,145839,2,724,0)=" ..I $G(TIUZ(""TEXT"",XCNTX,0))[""&quot;"" D"
^XMB(3.9,145839,2,725,0)="""RTN"",""TIUCCRHL7P1"",89,0)"
^XMB(3.9,145839,2,726,0)=" ...N SPEC,T5 S SPEC(""&quot;"")="""""""",T5=TIUZ(""TEXT"",XCNTX,0)"
^XMB(3.9,145839,2,727,0)="""RTN"",""TIUCCRHL7P1"",90,0)"
^XMB(3.9,145839,2,728,0)=" ...S TIUZ(""TEXT"",XCNTX,0)=$$REPLACE^XLFSTR(T5,.SPEC)"
^XMB(3.9,145839,2,729,0)="""RTN"",""TIUCCRHL7P1"",91,0)"
^XMB(3.9,145839,2,730,0)=" ..I $G(TIUZ(""TEXT"",XCNTX,0))[""Original CCP Note Date (mm/dd/yyyy):"" S NOTEDATE=$P(TIUZ(""TEXT"",XCNTX,0),"":"",2)"
^XMB(3.9,145839,2,731,0)="""RTN"",""TIUCCRHL7P1"",92,0)"
^XMB(3.9,145839,2,732,0)=" ..I $G(TIUZ(""TEXT"",XCNTX,0))[""CCPN Number:"" S NOTENUM=$P(TIUZ(""TEXT"",XCNTX,0),"":"",2)"
^XMB(3.9,145839,2,733,0)="""RTN"",""TIUCCRHL7P1"",93,0)"
^XMB(3.9,145839,2,734,0)=" ..I $G(TIUZ(""TEXT"",XCNTX,0))'=""""&($L(TIUZ(""TEXT"",XCNTX,0))>80) D SPLIT(TIUZ(""TEXT"",XCNTX,0),XCNTX)"
^XMB(3.9,145839,2,735,0)="""RTN"",""TIUCCRHL7P1"",94,0)"
^XMB(3.9,145839,2,736,0)=" ..;patch 349, PB - Feb 15, 2022 - modifications to capture the Consult Factor text to be filed as a comment with the consult"
^XMB(3.9,145839,2,737,0)="""RTN"",""TIUCCRHL7P1"",95,0)"
^XMB(3.9,145839,2,738,0)=" ..I $G(TIUZ(""TEXT"",XCNTX,0))[""CF#:"" S CFNOTE=$P($G(TIUZ(""TEXT"",XCNTX,0)),""CF#: "",2)"
^XMB(3.9,145839,2,739,0)="""RTN"",""TIUCCRHL7P1"",96,0)"
^XMB(3.9,145839,2,740,0)=" ..S XCNTX=XCNTX+1"
^XMB(3.9,145839,2,741,0)="""RTN"",""TIUCCRHL7P1"",97,0)"
^XMB(3.9,145839,2,742,0)=" I '$D(@TIUNAME@(7)) D"
^XMB(3.9,145839,2,743,0)="""RTN"",""TIUCCRHL7P1"",98,0)"
^XMB(3.9,145839,2,744,0)=" .D:$G(ADDENDUM)="""" WORD"
^XMB(3.9,145839,2,745,0)="""RTN"",""TIUCCRHL7P1"",99,0)"
^XMB(3.9,145839,2,746,0)=" .D:$G(ADDENDUM)'="""" WORD^TIUCCRHL7P4"
^XMB(3.9,145839,2,747,0)="""RTN"",""TIUCCRHL7P1"",100,0)"
^XMB(3.9,145839,2,748,0)=" ; begin data verification"
^XMB(3.9,145839,2,749,0)="""RTN"",""TIUCCRHL7P1"",101,0)"
^XMB(3.9,145839,2,750,0)=" ; PATIENT IDENTIFICATION"
^XMB(3.9,145839,2,751,0)="""RTN"",""TIUCCRHL7P1"",102,0)"
^XMB(3.9,145839,2,752,0)=" D"
^XMB(3.9,145839,2,753,0)="""RTN"",""TIUCCRHL7P1"",103,0)"
^XMB(3.9,145839,2,754,0)=" .Q"
^XMB(3.9,145839,2,755,0)="""RTN"",""TIUCCRHL7P1"",104,0)"
^XMB(3.9,145839,2,756,0)=" . N TIUI,TIUJ,TIUERR,TIUN,TIUOUT,TIUTMP,TIUQUIT"
^XMB(3.9,145839,2,757,0)="""RTN"",""TIUCCRHL7P1"",105,0)"
^XMB(3.9,145839,2,758,0)=" . I $D(TIU(""DFN"")) S TIUJ=1"
^XMB(3.9,145839,2,759,0)="""RTN"",""TIUCCRHL7P1"",106,0)"
^XMB(3.9,145839,2,760,0)=" . I '+$L($G(TIU(""PTNAME""))) D ERR^TIUCCHL7UT(""PID"",5,""0000.00"",""Missing PATIENT NAME."")"
^XMB(3.9,145839,2,761,0)="""RTN"",""TIUCCRHL7P1"",107,0)"
^XMB(3.9,145839,2,762,0)=" . I +TIUJ=1 D"
^XMB(3.9,145839,2,763,0)="""RTN"",""TIUCCRHL7P1"",108,0)"
^XMB(3.9,145839,2,764,0)=" . . I '+$L($P(TIU(""PTNAME""),"","",2)) D ERR^TIUCCHL7UT(""PID"",5,""0000.00"",""FIRST NAME/INITIAL missing with only one numeric identifier sent."")"
^XMB(3.9,145839,2,765,0)="""RTN"",""TIUCCRHL7P1"",109,0)"
^XMB(3.9,145839,2,766,0)=" . . S TIUN(""PT"")=$$PNAME^TIUHL7U1(TIU(""PTNAME"")),TIUTMP=1"
^XMB(3.9,145839,2,767,0)="""RTN"",""TIUCCRHL7P1"",110,0)"
^XMB(3.9,145839,2,768,0)=" . E  S TIUN(""PT"")=$P(TIU(""PTNAME""),"","")"
^XMB(3.9,145839,2,769,0)="""RTN"",""TIUCCRHL7P1"",111,0)"
^XMB(3.9,145839,2,770,0)=" . S TIUJ=0"
^XMB(3.9,145839,2,771,0)="""RTN"",""TIUCCRHL7P1"",112,0)"
^XMB(3.9,145839,2,772,0)=" . ; check DFN if available"
^XMB(3.9,145839,2,773,0)="""RTN"",""TIUCCRHL7P1"",113,0)"
^XMB(3.9,145839,2,774,0)=" . I +$G(TIU(""DFN"")) S TIUJ=TIUJ+1,DFN(TIUJ)=TIU(""DFN"") D"
^XMB(3.9,145839,2,775,0)="""RTN"",""TIUCCRHL7P1"",114,0)"
^XMB(3.9,145839,2,776,0)=" . . I +$G(TIUTMP) S TIUN(""DFN"")=$$PNAME^TIUHL7U1($$GET1^DIQ(2,TIU(""DFN""),.01))"
^XMB(3.9,145839,2,777,0)="""RTN"",""TIUCCRHL7P1"",115,0)"
^XMB(3.9,145839,2,778,0)=" . . E  S TIUN(""DFN"")=$P($$GET1^DIQ(2,TIU(""DFN""),.01),"","")"
^XMB(3.9,145839,2,779,0)="""RTN"",""TIUCCRHL7P1"",116,0)"
^XMB(3.9,145839,2,780,0)=" . . I '$$COMPARE^TIUHL7U1(TIUN(""DFN""),TIUN(""PT"")) D ERR^TIUCCHL7UT(""PID"",5,""0000.00"",""PATIENT NAME discrepancy between HL7 message name [""_TIU(""PTNAME"")_""] & the HL7 message DFN #""_TIU(""DFN"")_"" [""_$$GET1^DIQ(2,DFN(TIUJ),.01)_""]."")"
^XMB(3.9,145839,2,781,0)="""RTN"",""TIUCCRHL7P1"",117,0)"
^XMB(3.9,145839,2,782,0)=" . ; check ICN if available"
^XMB(3.9,145839,2,783,0)="""RTN"",""TIUCCRHL7P1"",118,0)"
^XMB(3.9,145839,2,784,0)=" . I +$G(TIU(""ICN"")) S TIUJ=TIUJ+1,DFN(TIUJ)=+$$FIND1^DIC(2,"""",""X"",TIU(""ICN""),""AICN"") D"
^XMB(3.9,145839,2,785,0)="""RTN"",""TIUCCRHL7P1"",119,0)"
^XMB(3.9,145839,2,786,0)=" . . I +$G(TIUTMP) S TIUN(""ICN"")=$$PNAME^TIUHL7U1($$GET1^DIQ(2,DFN(TIUJ),.01))"
^XMB(3.9,145839,2,787,0)="""RTN"",""TIUCCRHL7P1"",120,0)"
^XMB(3.9,145839,2,788,0)=" . . E  S TIUN(""ICN"")=$P($$GET1^DIQ(2,DFN(TIUJ),.01),"","")"
^XMB(3.9,145839,2,789,0)="""RTN"",""TIUCCRHL7P1"",121,0)"
^XMB(3.9,145839,2,790,0)=" . . I '$$COMPARE^TIUHL7U1(TIUN(""ICN""),TIUN(""PT"")) D ERR^TIUCCHL7UT(""PID"",5,""0000.00"",""PATIENT NAME discrepancy between HL7 message name [""_TIU(""PTNAME"")_""] & the HL7 message ICN #""_TIU(""ICN"")_"" [""_$$GET1^DIQ(2,DFN(TIUJ),.01)_""]."")"
^XMB(3.9,145839,2,791,0)="""RTN"",""TIUCCRHL7P1"",122,0)"
^XMB(3.9,145839,2,792,0)=" . ; check SSN if available"
^XMB(3.9,145839,2,793,0)="""RTN"",""TIUCCRHL7P1"",123,0)"
^XMB(3.9,145839,2,794,0)=" . I +$G(TIU(""SSN"")) S TIUJ=TIUJ+1,DFN(TIUJ)=+$$FIND1^DIC(2,"""",""X"",TIU(""SSN""),""SSN"") D"
^XMB(3.9,145839,2,795,0)="""RTN"",""TIUCCRHL7P1"",124,0)"
^XMB(3.9,145839,2,796,0)=" . . I +$G(TIUTMP) S TIUN(""SSN"")=$$PNAME^TIUHL7U1($$GET1^DIQ(2,DFN(TIUJ),.01))"
^XMB(3.9,145839,2,797,0)="""RTN"",""TIUCCRHL7P1"",125,0)"
^XMB(3.9,145839,2,798,0)=" . . E  S TIUN(""SSN"")=$P($$GET1^DIQ(2,DFN(TIUJ),.01),"","")"
^XMB(3.9,145839,2,799,0)="""RTN"",""TIUCCRHL7P1"",126,0)"
^XMB(3.9,145839,2,800,0)=" . . I '$$COMPARE^TIUHL7U1(TIUN(""SSN""),TIUN(""PT"")) D ERR^TIUCCHL7UT(""PID"",5,""0000.00"",""PATIENT NAME discrepancy between HL7 message name [""_TIU(""PTNAME"")_""] & the HL7 message SSN #""_TIU(""SSN"")_"" [""_$$GET1^DIQ(2,DFN(TIUJ),.01)_""]."")"
^XMB(3.9,145839,2,801,0)="""RTN"",""TIUCCRHL7P1"",127,0)"
^XMB(3.9,145839,2,802,0)=" . ; compare DFN lookup values"
^XMB(3.9,145839,2,803,0)="""RTN"",""TIUCCRHL7P1"",128,0)"
^XMB(3.9,145839,2,804,0)=" . I TIUJ>1 S (TIUI,TIUJ)=0 F  S TIUI=$O(DFN(TIUI)) Q:'TIUI  I TIUI>1 S TIUJ=TIUI-1 I DFN(TIUI)'=DFN(TIUJ) D ERR^TIUCCHL7UT(""PID"",5,""0000.00"",""PATIENT IEN discrepancies between the numeric lookups."") Q"
^XMB(3.9,145839,2,805,0)="""RTN"",""TIUCCRHL7P1"",129,0)"
^XMB(3.9,145839,2,806,0)=" . I TIU(""EC"") Q"
^XMB(3.9,145839,2,807,0)="""RTN"",""TIUCCRHL7P1"",130,0)"
^XMB(3.9,145839,2,808,0)=" . S DFN=DFN(1)"
^XMB(3.9,145839,2,809,0)="""RTN"",""TIUCCRHL7P1"",131,0)"
^XMB(3.9,145839,2,810,0)=" I $G(ADDENDUM)'="""" D"
^XMB(3.9,145839,2,811,0)="""RTN"",""TIUCCRHL7P1"",132,0)"
^XMB(3.9,145839,2,812,0)=" .N N1 S N1=0 F  S N1=$O(TIUZ(""TEXT"",N1)) Q:N1'>0  D"
^XMB(3.9,145839,2,813,0)="""RTN"",""TIUCCRHL7P1"",133,0)"
^XMB(3.9,145839,2,814,0)=" ..I $G(TIUZ(""TEXT"",N1,0))[""Original CCP Note Date (mm/dd/yyyy):"" S NOTEDATE=$P(TIUZ(""TEXT"",N1,0),"": "",2)"
^XMB(3.9,145839,2,815,0)="""RTN"",""TIUCCRHL7P1"",134,0)"
^XMB(3.9,145839,2,816,0)=" ..I $G(TIUZ(""TEXT"",N1,0))[""CCPN Number:"" S NOTENUM=$P(TIUZ(""TEXT"",N1,0),"": "",2)"
^XMB(3.9,145839,2,817,0)="""RTN"",""TIUCCRHL7P1"",135,0)"
^XMB(3.9,145839,2,818,0)=" .S:$G(NOTENUM)'="""" TIUIEN=$$TIULKUP^TIUCCHL7UT(CONSULTID,TIU(""TDA""),$G(NOTEDATE),NOTENUM)"
^XMB(3.9,145839,2,819,0)="""RTN"",""TIUCCRHL7P1"",136,0)"
^XMB(3.9,145839,2,820,0)=" ;"
^XMB(3.9,145839,2,821,0)="""RTN"",""TIUCCRHL7P1"",137,0)"
^XMB(3.9,145839,2,822,0)=" D CONTINUE^TIUCCRHL7P2"
^XMB(3.9,145839,2,823,0)="""RTN"",""TIUCCRHL7P1"",138,0)"
^XMB(3.9,145839,2,824,0)=" Q"
^XMB(3.9,145839,2,825,0)="""RTN"",""TIUCCRHL7P1"",139,0)"
^XMB(3.9,145839,2,826,0)="SPLIT(NODE,CNTR) ;"
^XMB(3.9,145839,2,827,0)="""RTN"",""TIUCCRHL7P1"",140,0)"
^XMB(3.9,145839,2,828,0)=" Q:$G(NODE)="""""
^XMB(3.9,145839,2,829,0)="""RTN"",""TIUCCRHL7P1"",141,0)"
^XMB(3.9,145839,2,830,0)=" Q:$G(CNTR)="""""
^XMB(3.9,145839,2,831,0)="""RTN"",""TIUCCRHL7P1"",142,0)"
^XMB(3.9,145839,2,832,0)=" Q:$L(NODE)<80"
^XMB(3.9,145839,2,833,0)="""RTN"",""TIUCCRHL7P1"",143,0)"
^XMB(3.9,145839,2,834,0)=" K LINE"
^XMB(3.9,145839,2,835,0)="""RTN"",""TIUCCRHL7P1"",144,0)"
^XMB(3.9,145839,2,836,0)=" S NODE=$TR(NODE,$C(160),""""),XCNTX=CNTR"
^XMB(3.9,145839,2,837,0)="""RTN"",""TIUCCRHL7P1"",145,0)"
^XMB(3.9,145839,2,838,0)=" N WORDS,I,XX,SEGS,LEN"
^XMB(3.9,145839,2,839,0)="""RTN"",""TIUCCRHL7P1"",146,0)"
^XMB(3.9,145839,2,840,0)=" S LEN=$L(NODE),SEGS=LEN/80 S:$P(SEGS,""."",2)>0 SEGS=SEGS+1"
^XMB(3.9,145839,2,841,0)="""RTN"",""TIUCCRHL7P1"",147,0)"
^XMB(3.9,145839,2,842,0)=" S WORDS=0 F I=1:1:$L(NODE) I $E(NODE,I)="" "" S WORDS=WORDS+1"
^XMB(3.9,145839,2,843,0)="""RTN"",""TIUCCRHL7P1"",148,0)"
^XMB(3.9,145839,2,844,0)=" S XX="""",CNT=1,LASTWORD=0"
^XMB(3.9,145839,2,845,0)="""RTN"",""TIUCCRHL7P1"",149,0)"
^XMB(3.9,145839,2,846,0)=" F I=1:1:(WORDS+1) D"
^XMB(3.9,145839,2,847,0)="""RTN"",""TIUCCRHL7P1"",150,0)"
^XMB(3.9,145839,2,848,0)=" .S XX=XX_$P(NODE,"" "",I)_"" """
^XMB(3.9,145839,2,849,0)="""RTN"",""TIUCCRHL7P1"",151,0)"
^XMB(3.9,145839,2,850,0)=" .I $L(XX)>80 D"
^XMB(3.9,145839,2,851,0)="""RTN"",""TIUCCRHL7P1"",152,0)"
^XMB(3.9,145839,2,852,0)=" ..S LASTWORD=I"
^XMB(3.9,145839,2,853,0)="""RTN"",""TIUCCRHL7P1"",153,0)"
^XMB(3.9,145839,2,854,0)=" ..S LINE(CNT)=XX,CNT=CNT+1 S XX="""",TIUZ(""TEXT"",XCNTX,0)=$G(LINE(CNT-1)),XCNTX=XCNTX+1"
^XMB(3.9,145839,2,855,0)="""RTN"",""TIUCCRHL7P1"",154,0)"
^XMB(3.9,145839,2,856,0)=" I ((WORDS+1)>LASTWORD) D"
^XMB(3.9,145839,2,857,0)="""RTN"",""TIUCCRHL7P1"",155,0)"
^XMB(3.9,145839,2,858,0)=" .S LINE(CNT)=$P(NODE,"" "",LASTWORD+1,WORDS+1),TIUZ(""TEXT"",XCNTX,0)=$G(LINE(CNT)),XCNTX=XCNTX+1"
^XMB(3.9,145839,2,859,0)="""RTN"",""TIUCCRHL7P1"",156,0)"
^XMB(3.9,145839,2,860,0)=" K I,CNT,LASTWORD"
^XMB(3.9,145839,2,861,0)="""RTN"",""TIUCCRHL7P1"",157,0)"
^XMB(3.9,145839,2,862,0)=" Q"
^XMB(3.9,145839,2,863,0)="""RTN"",""TIUCCRHL7P1"",158,0)"
^XMB(3.9,145839,2,864,0)="WORD ;"
^XMB(3.9,145839,2,865,0)="""RTN"",""TIUCCRHL7P1"",159,0)"
^XMB(3.9,145839,2,866,0)=" K I1,CNT,LCNT,LEN,I,LINES,T2,LASTWORDS,TEST1,WORDS,WORDSLEN,XX,T2,T4,T5"
^XMB(3.9,145839,2,867,0)="""RTN"",""TIUCCRHL7P1"",160,0)"
^XMB(3.9,145839,2,868,0)=" S WORDS=$G(TIUZ(""TEXT"",1,0)),WORDSLEN=$L(TIUZ(""TEXT"",1,0))"
^XMB(3.9,145839,2,869,0)="""RTN"",""TIUCCRHL7P1"",161,0)"
^XMB(3.9,145839,2,870,0)=" I $G(ADDENDUM)'="""" D"
^XMB(3.9,145839,2,871,0)="""RTN"",""TIUCCRHL7P1"",162,0)"
^XMB(3.9,145839,2,872,0)=" .S NOTEDATE=$$GETDATE^TIUCCRHL7P4"
^XMB(3.9,145839,2,873,0)="""RTN"",""TIUCCRHL7P1"",163,0)"
^XMB(3.9,145839,2,874,0)=" .S NOTENUM=$$NOTENUM^TIUCCRHL7P4"
^XMB(3.9,145839,2,875,0)="""RTN"",""TIUCCRHL7P1"",164,0)"
^XMB(3.9,145839,2,876,0)=" .S:$G(NOTENUM)'="""" TIUIEN=$$TIULKUP^TIUCCHL7UT(CONSULTID,TIU(""TDA""),NOTEDATE,NOTENUM) ;Patch 344 lookup the note in the consult to file the addendum with"
^XMB(3.9,145839,2,877,0)="""RTN"",""TIUCCRHL7P1"",165,0)"
^XMB(3.9,145839,2,878,0)=" F TEST1=1:1:WORDSLEN S LASTWORDS=$E(TIUZ(""TEXT"",1,0),WORDSLEN,(WORDSLEN-25))"
^XMB(3.9,145839,2,879,0)="""RTN"",""TIUCCRHL7P1"",166,0)"
^XMB(3.9,145839,2,880,0)=" K T2 S T2(""PROVIDER""_$C(160)_""CONTACT ADDENDUM"")=""PROVIDER CONTACT ADDENDUM"""
^XMB(3.9,145839,2,881,0)="""RTN"",""TIUCCRHL7P1"",167,0)"
^XMB(3.9,145839,2,882,0)=" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,883,0)="""RTN"",""TIUCCRHL7P1"",168,0)"
^XMB(3.9,145839,2,884,0)=" K T2 S T2(""CCP Note Create Date:"")=$C(10)_""CCP Note Create Date:"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,885,0)="""RTN"",""TIUCCRHL7P1"",169,0)"
^XMB(3.9,145839,2,886,0)=" K T2 S T2(""CCPN Number:"")=$C(10)_""CCPN Number:"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,887,0)="""RTN"",""TIUCCRHL7P1"",170,0)"
^XMB(3.9,145839,2,888,0)=" K T2 S T2(""Veteran Last Name:"")=$C(10)_""Veteran Last Name:"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,889,0)="""RTN"",""TIUCCRHL7P1"",171,0)"
