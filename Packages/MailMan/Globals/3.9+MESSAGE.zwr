^XMB(3.9,144657,2,10797,0)="""RTN"",""IBNCPIV"",106,0)"
^XMB(3.9,144657,2,10798,0)=" S IBPER=$S(IBPER:0_IBPER,1:""01"")    ; base the default value on the selected relationship code"
^XMB(3.9,144657,2,10799,0)="""RTN"",""IBNCPIV"",107,0)"
^XMB(3.9,144657,2,10800,0)=" S DIR(0)=""FO^1:3"""
^XMB(3.9,144657,2,10801,0)="""RTN"",""IBNCPIV"",108,0)"
^XMB(3.9,144657,2,10802,0)=" S DIR(""A"")=""Person Code"""
^XMB(3.9,144657,2,10803,0)="""RTN"",""IBNCPIV"",109,0)"
^XMB(3.9,144657,2,10804,0)=" S DIR(""?"",1)=""Enter the Specific Person Code Assigned to the Patient by the Payer."""
^XMB(3.9,144657,2,10805,0)="""RTN"",""IBNCPIV"",110,0)"
