^XMB(3.9,145834,2,5915,0)="""RTN"",""MAGDSTAA"",152,0)"
^XMB(3.9,145834,2,5916,0)="QRSTATUS(TEXT) ; output query/retrieve status text"
^XMB(3.9,145834,2,5917,0)="""RTN"",""MAGDSTAA"",153,0)"
^XMB(3.9,145834,2,5918,0)=" I $Y>(IOSL-4) D HEADER(1)"
^XMB(3.9,145834,2,5919,0)="""RTN"",""MAGDSTAA"",154,0)"
^XMB(3.9,145834,2,5920,0)=" W:$X>82 ! W ?82,TEXT"
^XMB(3.9,145834,2,5921,0)="""RTN"",""MAGDSTAA"",155,0)"
^XMB(3.9,145834,2,5922,0)=" Q"
^XMB(3.9,145834,2,5923,0)="""RTN"",""MAGDSTAA"",156,0)"
^XMB(3.9,145834,2,5924,0)=" ;"
^XMB(3.9,145834,2,5925,0)="""RTN"",""MAGDSTAA"",157,0)"
^XMB(3.9,145834,2,5926,0)="SUSPEND(HOURS) ; check date/time & request to stop"
^XMB(3.9,145834,2,5927,0)="""RTN"",""MAGDSTAA"",158,0)"
^XMB(3.9,145834,2,5928,0)=" ; HOURS is a 24 character string of Y's and N's indicating active times"
^XMB(3.9,145834,2,5929,0)="""RTN"",""MAGDSTAA"",159,0)"
^XMB(3.9,145834,2,5930,0)=" ; Assume that Saturday and Sunday are 24 hours"
^XMB(3.9,145834,2,5931,0)="""RTN"",""MAGDSTAA"",160,0)"
^XMB(3.9,145834,2,5932,0)=" N DONE,FIRSTTIME,TICKER,X"
^XMB(3.9,145834,2,5933,0)="""RTN"",""MAGDSTAA"",161,0)"
^XMB(3.9,145834,2,5934,0)=" ;"
^XMB(3.9,145834,2,5935,0)="""RTN"",""MAGDSTAA"",162,0)"
^XMB(3.9,145834,2,5936,0)=" I SCANMODE=""ACCESSION"" Q 0  ; don't check for accession number scans"
^XMB(3.9,145834,2,5937,0)="""RTN"",""MAGDSTAA"",163,0)"
^XMB(3.9,145834,2,5938,0)=" ;"
^XMB(3.9,145834,2,5939,0)="""RTN"",""MAGDSTAA"",164,0)"
^XMB(3.9,145834,2,5940,0)=" S (DONE,TICKER)=0,FIRSTTIME=1"
^XMB(3.9,145834,2,5941,0)="""RTN"",""MAGDSTAA"",165,0)"
^XMB(3.9,145834,2,5942,0)=" I ""23""[($H#7) S HOURS=$TR($J("""",24),"" "",""Y"") ; Saturday and Sunday"
^XMB(3.9,145834,2,5943,0)="""RTN"",""MAGDSTAA"",166,0)"
^XMB(3.9,145834,2,5944,0)=" F  D  Q:DONE"
^XMB(3.9,145834,2,5945,0)="""RTN"",""MAGDSTAA"",167,0)"
^XMB(3.9,145834,2,5946,0)=" . I $G(^XTMP(MAGXTMP,""AUTO Q/R"",HOSTNAME,$J,""STATUS""))'=""RUN"" D  Q  ; menu stop"
^XMB(3.9,145834,2,5947,0)="""RTN"",""MAGDSTAA"",168,0)"
^XMB(3.9,145834,2,5948,0)=" . . S DONE=-1 ; indicates user stop task"
^XMB(3.9,145834,2,5949,0)="""RTN"",""MAGDSTAA"",169,0)"
^XMB(3.9,145834,2,5950,0)=" . . W !!,""User requested VistA Automatic Q/R Processing to stop at "",$$FMTE^XLFDT($$NOW^XLFDT,1)"
^XMB(3.9,145834,2,5951,0)="""RTN"",""MAGDSTAA"",170,0)"
^XMB(3.9,145834,2,5952,0)=" . . Q"
^XMB(3.9,145834,2,5953,0)="""RTN"",""MAGDSTAA"",171,0)"
^XMB(3.9,145834,2,5954,0)=" . I $$S^%ZTLOAD(""Stopping ""_ZTDESC)  D  Q  ; user has asked task to stop"
^XMB(3.9,145834,2,5955,0)="""RTN"",""MAGDSTAA"",172,0)"
^XMB(3.9,145834,2,5956,0)=" . . S DONE=-1 ; indicates user stop task"
^XMB(3.9,145834,2,5957,0)="""RTN"",""MAGDSTAA"",173,0)"
^XMB(3.9,145834,2,5958,0)=" . . S ZTSTOP=1 ; notify submanager of response to user's STOP request"
^XMB(3.9,145834,2,5959,0)="""RTN"",""MAGDSTAA"",174,0)"
^XMB(3.9,145834,2,5960,0)=" . . W !!,""User requested task to stop at "",$$FMTE^XLFDT($$NOW^XLFDT,1)"
^XMB(3.9,145834,2,5961,0)="""RTN"",""MAGDSTAA"",175,0)"
^XMB(3.9,145834,2,5962,0)=" . . Q"
^XMB(3.9,145834,2,5963,0)="""RTN"",""MAGDSTAA"",176,0)"
^XMB(3.9,145834,2,5964,0)=" . S X=$E(HOURS,$P($H,"","",2)\3600+1)"
^XMB(3.9,145834,2,5965,0)="""RTN"",""MAGDSTAA"",177,0)"
^XMB(3.9,145834,2,5966,0)=" . I X=""Y"" S DONE=1"
^XMB(3.9,145834,2,5967,0)="""RTN"",""MAGDSTAA"",178,0)"
^XMB(3.9,145834,2,5968,0)=" . E  D  ; suspend run  "
^XMB(3.9,145834,2,5969,0)="""RTN"",""MAGDSTAA"",179,0)"
^XMB(3.9,145834,2,5970,0)=" . . I FIRSTTIME W !!,""Waiting for time to start "" S FIRSTTIME=0"
^XMB(3.9,145834,2,5971,0)="""RTN"",""MAGDSTAA"",180,0)"
^XMB(3.9,145834,2,5972,0)=" . . ; Show ""idle"" marker"
