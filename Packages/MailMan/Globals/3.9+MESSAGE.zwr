^XMB(3.9,145831,2,1025,0)="""RTN"",""EDPVIT"",80,0)"
^XMB(3.9,145831,2,1026,0)=" S IDT=""A"" F  S IDT=$O(^UTILITY($J,""GMRVD"",IDT),-1) Q:IDT<1  D"
^XMB(3.9,145831,2,1027,0)="""RTN"",""EDPVIT"",81,0)"
