^XMB(3.9,144654,2,240,0)="0^1^B98633704"
^XMB(3.9,144654,2,241,0)="""RTN"",""PSOHLDS2"",1,0)"
^XMB(3.9,144654,2,242,0)="PSOHLDS2 ;BHAM ISC/PWC,SAB-Build HL7 Segments for automated interface ;11/22/06 3:24pm"
^XMB(3.9,144654,2,243,0)="""RTN"",""PSOHLDS2"",2,0)"
^XMB(3.9,144654,2,244,0)=" ;;7.0;OUTPATIENT PHARMACY;**156,198,255,200,268,305,336,434,282,531,524**;DEC 1997;Build 0"
^XMB(3.9,144654,2,245,0)="""RTN"",""PSOHLDS2"",3,0)"
^XMB(3.9,144654,2,246,0)=" ;DIWP supported by DBIA 10011"
^XMB(3.9,144654,2,247,0)="""RTN"",""PSOHLDS2"",4,0)"
^XMB(3.9,144654,2,248,0)=" ;^PS(50.606 supported by DBIA 2174"
^XMB(3.9,144654,2,249,0)="""RTN"",""PSOHLDS2"",5,0)"
^XMB(3.9,144654,2,250,0)=" ;^PS(50.7 supported by DBIA #2223"
^XMB(3.9,144654,2,251,0)="""RTN"",""PSOHLDS2"",6,0)"
^XMB(3.9,144654,2,252,0)=" ;^PS(51 supported by DBIA 2224"
^XMB(3.9,144654,2,253,0)="""RTN"",""PSOHLDS2"",7,0)"
^XMB(3.9,144654,2,254,0)=" ;^PS(51.2 supported by DBIA 2226"
^XMB(3.9,144654,2,255,0)="""RTN"",""PSOHLDS2"",8,0)"
^XMB(3.9,144654,2,256,0)=" ;^PS(55 supported by DBIA 2228"
^XMB(3.9,144654,2,257,0)="""RTN"",""PSOHLDS2"",9,0)"
^XMB(3.9,144654,2,258,0)=" ;^PSDRUG supported by DBIA 221"
^XMB(3.9,144654,2,259,0)="""RTN"",""PSOHLDS2"",10,0)"
^XMB(3.9,144654,2,260,0)=" ;^PS(54 supported by DBIA 2227"
^XMB(3.9,144654,2,261,0)="""RTN"",""PSOHLDS2"",11,0)"
^XMB(3.9,144654,2,262,0)=" ;Cont'd build HL7 segments"
^XMB(3.9,144654,2,263,0)="""RTN"",""PSOHLDS2"",12,0)"
^XMB(3.9,144654,2,264,0)=" ;"
^XMB(3.9,144654,2,265,0)="""RTN"",""PSOHLDS2"",13,0)"
^XMB(3.9,144654,2,266,0)=" ;*198 add check to insert spaces into PMI segments"
^XMB(3.9,144654,2,267,0)="""RTN"",""PSOHLDS2"",14,0)"
^XMB(3.9,144654,2,268,0)=" ;*255 add 2 new fields to RXE.21 (label name & VA PRINT NAME)"
^XMB(3.9,144654,2,269,0)="""RTN"",""PSOHLDS2"",15,0)"
^XMB(3.9,144654,2,270,0)=" ;     and move NTEPMI tag to PSOHLDS4"
^XMB(3.9,144654,2,271,0)="""RTN"",""PSOHLDS2"",16,0)"
^XMB(3.9,144654,2,272,0)=" ;*305 send  Notice of Privacy Practices in NTE9 - Modified to NTE9 as NTE8 already exist"
^XMB(3.9,144654,2,273,0)="""RTN"",""PSOHLDS2"",17,0)"
^XMB(3.9,144654,2,274,0)=" ;*524 add ZZZ segment for HAZ info to OPAI"
^XMB(3.9,144654,2,275,0)="""RTN"",""PSOHLDS2"",18,0)"
^XMB(3.9,144654,2,276,0)=" ;"
^XMB(3.9,144654,2,277,0)="""RTN"",""PSOHLDS2"",19,0)"
^XMB(3.9,144654,2,278,0)="RXE(PSI) ;pharmacy encoded order segment"
^XMB(3.9,144654,2,279,0)="""RTN"",""PSOHLDS2"",20,0)"
^XMB(3.9,144654,2,280,0)=" Q:'$D(DFN)  N RXE S RXE="""" S $P(RXE,""|"",1)="""""""""""""
^XMB(3.9,144654,2,281,0)="""RTN"",""PSOHLDS2"",21,0)"
^XMB(3.9,144654,2,282,0)=" S $P(RXE,""|"",2)=$S($P($G(^PSDRUG(IDGN,""ND"")),""^"",10)'="""":$P(^(""ND""),""^"",10),($G(PSND1)&$G(PSND3)):$P($G(PSOXN2),""^"",2),1:"""""""""""")_CS_$G(PSND2)_CS_""99PSNDF""_CS_PSND1_"".""_PSND3_"".""_$G(IDGN)_CS_$P($G(^PSDRUG(IDGN,0)),""^"")_CS_""99PSD"""
^XMB(3.9,144654,2,283,0)="""RTN"",""PSOHLDS2"",22,0)"
^XMB(3.9,144654,2,284,0)=" S $P(RXE,""|"",3)="""" I $G(PSOXN)="""" S PSOXN="""""""""""""
^XMB(3.9,144654,2,285,0)="""RTN"",""PSOHLDS2"",23,0)"
^XMB(3.9,144654,2,286,0)=" S $P(RXE,""|"",5)=PSOXN_CS_$S($G(UNIT)'="""":$G(UNIT),1:"""""""""""")_CS_""99PSU"""
^XMB(3.9,144654,2,287,0)="""RTN"",""PSOHLDS2"",24,0)"
^XMB(3.9,144654,2,288,0)=" S POIPTR=$P($G(^PSRX(IRXN,""OR1"")),""^"") I POIPTR S PODOSE=$P($G(^PS(50.7,POIPTR,0)),""^"",2),PODOSENM=$P($G(^PS(50.606,PODOSE,0)),""^"")"
^XMB(3.9,144654,2,289,0)="""RTN"",""PSOHLDS2"",25,0)"
^XMB(3.9,144654,2,290,0)=" I '$G(POIPTR) S PODOSE=$P($G(^PS(50.7,$P($G(^PSDRUG(IDGN,2)),""^""),0)),""^"",2),PODOSENM=$P($G(^PS(50.606,PODOSE,0)),""^"")"
^XMB(3.9,144654,2,291,0)="""RTN"",""PSOHLDS2"",26,0)"
^XMB(3.9,144654,2,292,0)=" S TRADENM=$G(^PSRX(IRXN,""TN"")),$P(RXE,""|"",6)=PODOSE_CS_PODOSENM_CS_""99PSF"""
^XMB(3.9,144654,2,293,0)="""RTN"",""PSOHLDS2"",27,0)"
^XMB(3.9,144654,2,294,0)=" S $P(RXE,""|"",8)=MP,$P(RXE,""|"",9)=TRADENM,$P(RXE,""|"",10)=QTY"
^XMB(3.9,144654,2,295,0)="""RTN"",""PSOHLDS2"",28,0)"
^XMB(3.9,144654,2,296,0)=" S $P(RXE,""|"",11)=CS_$P($G(^PSDRUG(IDGN,660)),""^"",8),$P(RXE,""|"",12)=NRFL"
^XMB(3.9,144654,2,297,0)="""RTN"",""PSOHLDS2"",29,0)"
^XMB(3.9,144654,2,298,0)=" S $P(RXE,""|"",13)=DEAID,$P(RXE,""|"",14)=VPHARMID_CS_$P(VPHARM,"","",1)_CS_$P(VPHARM,"","",2)"
^XMB(3.9,144654,2,299,0)="""RTN"",""PSOHLDS2"",30,0)"
^XMB(3.9,144654,2,300,0)=" S $P(RXE,""|"",15)=$P(^PSRX(IRXN,0),""^""),$P(RXE,""|"",16)=RFRM,$P(RXE,""|"",17)=NFLD"
^XMB(3.9,144654,2,301,0)="""RTN"",""PSOHLDS2"",31,0)"
^XMB(3.9,144654,2,302,0)=" S $P(RXE,""|"",18)=PRIORDT,$P(RXE,""|"",31)=CSUB_RS_SCTALK_RS_OTLAN"
^XMB(3.9,144654,2,303,0)="""RTN"",""PSOHLDS2"",32,0)"
^XMB(3.9,144654,2,304,0)=" S $P(RXE,""|"",21)=CS_DRUG_RS_CS_$G(VANAME)                       ;*255"
^XMB(3.9,144654,2,305,0)="""RTN"",""PSOHLDS2"",33,0)"
^XMB(3.9,144654,2,306,0)=" S ^TMP(""PSO"",$J,PSI)=""RXE|""_RXE,PSI=PSI+1"
^XMB(3.9,144654,2,307,0)="""RTN"",""PSOHLDS2"",34,0)"
^XMB(3.9,144654,2,308,0)=" K PODOSE,PODOSENM,POIPTR,TRADENM,UU"
^XMB(3.9,144654,2,309,0)="""RTN"",""PSOHLDS2"",35,0)"
^XMB(3.9,144654,2,310,0)=" Q"
^XMB(3.9,144654,2,311,0)="""RTN"",""PSOHLDS2"",36,0)"
^XMB(3.9,144654,2,312,0)="RXD(PSI) ;pharmacy dispense segment"
^XMB(3.9,144654,2,313,0)="""RTN"",""PSOHLDS2"",37,0)"
^XMB(3.9,144654,2,314,0)=" Q:'$D(DFN)  N RXD,I"
^XMB(3.9,144654,2,315,0)="""RTN"",""PSOHLDS2"",38,0)"
^XMB(3.9,144654,2,316,0)=" S WNS="""" I $G(WARN) F I=1:1 S WW=$P(WARN,"","",I) Q:WW=""""  S WNS=WNS_WW_CS_$S(WW'[""N"":^PS(54,WW,0),1:"""")_RS"
^XMB(3.9,144654,2,317,0)="""RTN"",""PSOHLDS2"",39,0)"
^XMB(3.9,144654,2,318,0)=" S RXD=""RXD""_FS_$S($G(FPN):FPN,1:0)_FS_$S($P($G(^PSDRUG(IDGN,""ND"")),""^"",10)'="""":$P(^(""ND""),""^"",10),($G(PSND1)&$G(PSND3)):$P($G(PSOXN2),""^"",2),1:"""""""""""")_CS_PSND2_CS_""99PSNDF""  ;*531"
^XMB(3.9,144654,2,319,0)="""RTN"",""PSOHLDS2"",40,0)"
^XMB(3.9,144654,2,320,0)=" S RXD=RXD_CS_PSND1_"".""_PSND3_"".""_$G(IDGN)_CS_$P($G(^PSDRUG(IDGN,0)),""^"")_CS_""99PSD"""
^XMB(3.9,144654,2,321,0)="""RTN"",""PSOHLDS2"",41,0)"
^XMB(3.9,144654,2,322,0)=" S RXD=RXD_FS_DISPDT_FS_FS_FS_FS_$P(^PSRX(IRXN,0),""^"")_FS_NRFL"
^XMB(3.9,144654,2,323,0)="""RTN"",""PSOHLDS2"",42,0)"
^XMB(3.9,144654,2,324,0)=" S RXD=RXD_FS_DEA_RS_PSONDC_FS_$S(FIN'="""":FIN_CS_FIN1,1:"""")_FS"
^XMB(3.9,144654,2,325,0)="""RTN"",""PSOHLDS2"",43,0)"
