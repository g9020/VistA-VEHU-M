^XMB(3.9,145834,2,7861,0)="""RTN"",""MAGDSTV2"",10,0)"
^XMB(3.9,145834,2,7862,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,7863,0)="""RTN"",""MAGDSTV2"",11,0)"
^XMB(3.9,145834,2,7864,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,7865,0)="""RTN"",""MAGDSTV2"",12,0)"
^XMB(3.9,145834,2,7866,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,7867,0)="""RTN"",""MAGDSTV2"",13,0)"
^XMB(3.9,145834,2,7868,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,7869,0)="""RTN"",""MAGDSTV2"",14,0)"
^XMB(3.9,145834,2,7870,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,7871,0)="""RTN"",""MAGDSTV2"",15,0)"
^XMB(3.9,145834,2,7872,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,7873,0)="""RTN"",""MAGDSTV2"",16,0)"
^XMB(3.9,145834,2,7874,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,7875,0)="""RTN"",""MAGDSTV2"",17,0)"
^XMB(3.9,145834,2,7876,0)=" ;;"
^XMB(3.9,145834,2,7877,0)="""RTN"",""MAGDSTV2"",18,0)"
^XMB(3.9,145834,2,7878,0)=" ;"
^XMB(3.9,145834,2,7879,0)="""RTN"",""MAGDSTV2"",19,0)"
^XMB(3.9,145834,2,7880,0)=" ; Supported IA #10103 reference $$NOW^XLFDT function call"
^XMB(3.9,145834,2,7881,0)="""RTN"",""MAGDSTV2"",20,0)"
^XMB(3.9,145834,2,7882,0)=" ;"
^XMB(3.9,145834,2,7883,0)="""RTN"",""MAGDSTV2"",21,0)"
^XMB(3.9,145834,2,7884,0)=" Q"
^XMB(3.9,145834,2,7885,0)="""RTN"",""MAGDSTV2"",22,0)"
^XMB(3.9,145834,2,7886,0)=" ; M2MB server"
^XMB(3.9,145834,2,7887,0)="""RTN"",""MAGDSTV2"",23,0)"
^XMB(3.9,145834,2,7888,0)=" ;"
^XMB(3.9,145834,2,7889,0)="""RTN"",""MAGDSTV2"",24,0)"
^XMB(3.9,145834,2,7890,0)=" ; This routine is invoked by the M2M Broker RPC to handle a Q/R client."
^XMB(3.9,145834,2,7891,0)="""RTN"",""MAGDSTV2"",25,0)"
^XMB(3.9,145834,2,7892,0)=" ;"
^XMB(3.9,145834,2,7893,0)="""RTN"",""MAGDSTV2"",26,0)"
^XMB(3.9,145834,2,7894,0)="ENTRY(RESULT,REQUEST) ; RPC = MAG DICOM Q/R CLIENT"
^XMB(3.9,145834,2,7895,0)="""RTN"",""MAGDSTV2"",27,0)"
^XMB(3.9,145834,2,7896,0)=" N ARGS ; ---- argument string of the REQUEST item"
^XMB(3.9,145834,2,7897,0)="""RTN"",""MAGDSTV2"",28,0)"
^XMB(3.9,145834,2,7898,0)=" N DATETIME ;- fileman date/time of the study"
^XMB(3.9,145834,2,7899,0)="""RTN"",""MAGDSTV2"",29,0)"
^XMB(3.9,145834,2,7900,0)=" N DCMPID ;--- DICOM patient id"
^XMB(3.9,145834,2,7901,0)="""RTN"",""MAGDSTV2"",30,0)"
^XMB(3.9,145834,2,7902,0)=" N DFN ;------ VistA's internal patient identifier"
^XMB(3.9,145834,2,7903,0)="""RTN"",""MAGDSTV2"",31,0)"
^XMB(3.9,145834,2,7904,0)=" N ERRCODE ;-- code for an error, if encountered"
^XMB(3.9,145834,2,7905,0)="""RTN"",""MAGDSTV2"",32,0)"
^XMB(3.9,145834,2,7906,0)=" N IREQUEST ;- pointer to item in REQUEST array"
^XMB(3.9,145834,2,7907,0)="""RTN"",""MAGDSTV2"",33,0)"
^XMB(3.9,145834,2,7908,0)=" N MSG ; ----- error message array"
^XMB(3.9,145834,2,7909,0)="""RTN"",""MAGDSTV2"",34,0)"
^XMB(3.9,145834,2,7910,0)=" N OPCODE ;--- operation code of the REQUEST item"
^XMB(3.9,145834,2,7911,0)="""RTN"",""MAGDSTV2"",35,0)"
^XMB(3.9,145834,2,7912,0)=" N RETURN ;--- intermediate return code"
^XMB(3.9,145834,2,7913,0)="""RTN"",""MAGDSTV2"",36,0)"
^XMB(3.9,145834,2,7914,0)=" N J ;-------- scratch variable"
^XMB(3.9,145834,2,7915,0)="""RTN"",""MAGDSTV2"",37,0)"
^XMB(3.9,145834,2,7916,0)=" ;"
^XMB(3.9,145834,2,7917,0)="""RTN"",""MAGDSTV2"",38,0)"
^XMB(3.9,145834,2,7918,0)=" ; pass the request list and determine what has to be done"
^XMB(3.9,145834,2,7919,0)="""RTN"",""MAGDSTV2"",39,0)"
^XMB(3.9,145834,2,7920,0)=" F IREQUEST=2:1:$G(REQUEST(1)) D"
^XMB(3.9,145834,2,7921,0)="""RTN"",""MAGDSTV2"",40,0)"
^XMB(3.9,145834,2,7922,0)=" . S OPCODE=$P(REQUEST(IREQUEST),""|"")"
^XMB(3.9,145834,2,7923,0)="""RTN"",""MAGDSTV2"",41,0)"
^XMB(3.9,145834,2,7924,0)=" . S ARGS=$P(REQUEST(IREQUEST),""|"",2,999)"
^XMB(3.9,145834,2,7925,0)="""RTN"",""MAGDSTV2"",42,0)"
^XMB(3.9,145834,2,7926,0)=" . ;"
^XMB(3.9,145834,2,7927,0)="""RTN"",""MAGDSTV2"",43,0)"
^XMB(3.9,145834,2,7928,0)=" . I OPCODE=""NEXT"" D  Q"
^XMB(3.9,145834,2,7929,0)="""RTN"",""MAGDSTV2"",44,0)"
^XMB(3.9,145834,2,7930,0)=" . . S NEXTIEN=$G(^MAGDSTT(2006.541,""ACOUNT""))+1"
^XMB(3.9,145834,2,7931,0)="""RTN"",""MAGDSTV2"",45,0)"
^XMB(3.9,145834,2,7932,0)=" . . I '$D(^MAGDSTT(2006.541,NEXTIEN)) D RESULT(""QR-REQUEST"",""NONE"") Q"
^XMB(3.9,145834,2,7933,0)="""RTN"",""MAGDSTV2"",46,0)"
^XMB(3.9,145834,2,7934,0)=" . . ; if another RPC is already processing this request, skip it"
^XMB(3.9,145834,2,7935,0)="""RTN"",""MAGDSTV2"",47,0)"
^XMB(3.9,145834,2,7936,0)=" . . L +^MAGDSTT(2006.541,""ACOUNT""):0 E  D RESULT(""QR-REQUEST"",""NONE"") Q"
^XMB(3.9,145834,2,7937,0)="""RTN"",""MAGDSTV2"",48,0)"
^XMB(3.9,145834,2,7938,0)=" . . S VALUE=^MAGDSTT(2006.541,NEXTIEN,0)_""^""_NEXTIEN"
^XMB(3.9,145834,2,7939,0)="""RTN"",""MAGDSTV2"",49,0)"
^XMB(3.9,145834,2,7940,0)=" . . D RESULT(""QR-REQUEST"",VALUE)"
^XMB(3.9,145834,2,7941,0)="""RTN"",""MAGDSTV2"",50,0)"
^XMB(3.9,145834,2,7942,0)=" . . S J=0"
^XMB(3.9,145834,2,7943,0)="""RTN"",""MAGDSTV2"",51,0)"
^XMB(3.9,145834,2,7944,0)=" . . F  S J=$O(^MAGDSTT(2006.541,NEXTIEN,1,J)) Q:'J  D"
^XMB(3.9,145834,2,7945,0)="""RTN"",""MAGDSTV2"",52,0)"
^XMB(3.9,145834,2,7946,0)=" . . . S VALUE=^MAGDSTT(2006.541,NEXTIEN,1,J,0)"
^XMB(3.9,145834,2,7947,0)="""RTN"",""MAGDSTV2"",53,0)"
^XMB(3.9,145834,2,7948,0)=" . . . D RESULT(""KEY"",VALUE)"
^XMB(3.9,145834,2,7949,0)="""RTN"",""MAGDSTV2"",54,0)"
^XMB(3.9,145834,2,7950,0)=" . . . Q"
^XMB(3.9,145834,2,7951,0)="""RTN"",""MAGDSTV2"",55,0)"
^XMB(3.9,145834,2,7952,0)=" . . S ^MAGDSTT(2006.541,""ACOUNT"")=NEXTIEN"
^XMB(3.9,145834,2,7953,0)="""RTN"",""MAGDSTV2"",56,0)"
^XMB(3.9,145834,2,7954,0)=" . . L -^MAGDSTT(2006.541,""ACOUNT"")"
^XMB(3.9,145834,2,7955,0)="""RTN"",""MAGDSTV2"",57,0)"
^XMB(3.9,145834,2,7956,0)=" . . Q"
^XMB(3.9,145834,2,7957,0)="""RTN"",""MAGDSTV2"",58,0)"
^XMB(3.9,145834,2,7958,0)=" . ;"
^XMB(3.9,145834,2,7959,0)="""RTN"",""MAGDSTV2"",59,0)"
^XMB(3.9,145834,2,7960,0)=" . I OPCODE=""QUERY RESULT"" D  Q  ; save query results in ^XTMP"
^XMB(3.9,145834,2,7961,0)="""RTN"",""MAGDSTV2"",60,0)"
^XMB(3.9,145834,2,7962,0)=" . . N V,VARS,VAR"
^XMB(3.9,145834,2,7963,0)="""RTN"",""MAGDSTV2"",61,0)"
^XMB(3.9,145834,2,7964,0)=" . . S VARS=""MAGXTMP^HOSTNAME^VISTAJOB^QRSTACK^IEN2006541^LEVEL^I^J^K^L^VARIABLE^VALUE"""
^XMB(3.9,145834,2,7965,0)="""RTN"",""MAGDSTV2"",62,0)"
^XMB(3.9,145834,2,7966,0)=" . . F V=1:1:$L(VARS,""^"") S VAR=$P(VARS,""^"",V) N @VAR S @VAR=$P(ARGS,""|"",V)"
^XMB(3.9,145834,2,7967,0)="""RTN"",""MAGDSTV2"",63,0)"
^XMB(3.9,145834,2,7968,0)=" . . I LEVEL=""PATIENT"" D"
^XMB(3.9,145834,2,7969,0)="""RTN"",""MAGDSTV2"",64,0)"
^XMB(3.9,145834,2,7970,0)=" . . . I I="""" S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""PATIENT"")=VALUE"
^XMB(3.9,145834,2,7971,0)="""RTN"",""MAGDSTV2"",65,0)"
^XMB(3.9,145834,2,7972,0)=" . . . E  S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""PATIENT"",I,VARIABLE)=VALUE"
^XMB(3.9,145834,2,7973,0)="""RTN"",""MAGDSTV2"",66,0)"
^XMB(3.9,145834,2,7974,0)=" . . . Q"
^XMB(3.9,145834,2,7975,0)="""RTN"",""MAGDSTV2"",67,0)"
^XMB(3.9,145834,2,7976,0)=" . . E  I LEVEL=""STUDY"" D"
^XMB(3.9,145834,2,7977,0)="""RTN"",""MAGDSTV2"",68,0)"
^XMB(3.9,145834,2,7978,0)=" . . . I J="""" S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""STUDY"",I)=VALUE"
^XMB(3.9,145834,2,7979,0)="""RTN"",""MAGDSTV2"",69,0)"
^XMB(3.9,145834,2,7980,0)=" . . . E  S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""STUDY"",I,J,VARIABLE)=VALUE"
^XMB(3.9,145834,2,7981,0)="""RTN"",""MAGDSTV2"",70,0)"
^XMB(3.9,145834,2,7982,0)=" . . . Q"
^XMB(3.9,145834,2,7983,0)="""RTN"",""MAGDSTV2"",71,0)"
^XMB(3.9,145834,2,7984,0)=" . . E  I LEVEL=""SERIES"" D"
^XMB(3.9,145834,2,7985,0)="""RTN"",""MAGDSTV2"",72,0)"
^XMB(3.9,145834,2,7986,0)=" . . . I K="""" S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""SERIES"",I,J)=VALUE"
^XMB(3.9,145834,2,7987,0)="""RTN"",""MAGDSTV2"",73,0)"
^XMB(3.9,145834,2,7988,0)=" . . . E  S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""SERIES"",I,J,K,VARIABLE)=VALUE"
^XMB(3.9,145834,2,7989,0)="""RTN"",""MAGDSTV2"",74,0)"
^XMB(3.9,145834,2,7990,0)=" . . . Q"
^XMB(3.9,145834,2,7991,0)="""RTN"",""MAGDSTV2"",75,0)"
^XMB(3.9,145834,2,7992,0)=" . . E  I LEVEL=""IMAGE"" D"
^XMB(3.9,145834,2,7993,0)="""RTN"",""MAGDSTV2"",76,0)"
^XMB(3.9,145834,2,7994,0)=" . . . I L="""" S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""IMAGE"",I,J,K)=VALUE"
^XMB(3.9,145834,2,7995,0)="""RTN"",""MAGDSTV2"",77,0)"
^XMB(3.9,145834,2,7996,0)=" . . . E  S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""IMAGE"",I,J,K,L,VARIABLE)=VALUE"
^XMB(3.9,145834,2,7997,0)="""RTN"",""MAGDSTV2"",78,0)"
^XMB(3.9,145834,2,7998,0)=" . . . Q"
^XMB(3.9,145834,2,7999,0)="""RTN"",""MAGDSTV2"",79,0)"
^XMB(3.9,145834,2,8000,0)=" . . E  I LEVEL=""DONE"" D"
^XMB(3.9,145834,2,8001,0)="""RTN"",""MAGDSTV2"",80,0)"
^XMB(3.9,145834,2,8002,0)=" . . . ; ""DONE"" uses the request IEN for proper synchronization"
^XMB(3.9,145834,2,8003,0)="""RTN"",""MAGDSTV2"",81,0)"
^XMB(3.9,145834,2,8004,0)=" . . . S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""DONE"",IEN2006541)=$$NOW^XLFDT_""^""_VARIABLE_""^""_VALUE"
^XMB(3.9,145834,2,8005,0)="""RTN"",""MAGDSTV2"",82,0)"
^XMB(3.9,145834,2,8006,0)=" . . . Q"
^XMB(3.9,145834,2,8007,0)="""RTN"",""MAGDSTV2"",83,0)"
^XMB(3.9,145834,2,8008,0)=" . . E  I LEVEL=""WORKING..."" D"
^XMB(3.9,145834,2,8009,0)="""RTN"",""MAGDSTV2"",84,0)"
^XMB(3.9,145834,2,8010,0)=" . . . S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""WORKING..."",IEN2006541)=$$NOW^XLFDT_""^""_VARIABLE_""^""_VALUE"
^XMB(3.9,145834,2,8011,0)="""RTN"",""MAGDSTV2"",85,0)"
^XMB(3.9,145834,2,8012,0)=" . . . Q"
^XMB(3.9,145834,2,8013,0)="""RTN"",""MAGDSTV2"",86,0)"
^XMB(3.9,145834,2,8014,0)=" . . E  I LEVEL=""MESSAGE"" D"
^XMB(3.9,145834,2,8015,0)="""RTN"",""MAGDSTV2"",87,0)"
^XMB(3.9,145834,2,8016,0)=" . . . S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""MESSAGE"",VARIABLE,I)=VALUE"
^XMB(3.9,145834,2,8017,0)="""RTN"",""MAGDSTV2"",88,0)"
^XMB(3.9,145834,2,8018,0)=" . . . Q"
^XMB(3.9,145834,2,8019,0)="""RTN"",""MAGDSTV2"",89,0)"
^XMB(3.9,145834,2,8020,0)=" . . E  S PI=CIRCUMFERENCE/DIAMETER ; throw an error (line of code written on 3/14)"
^XMB(3.9,145834,2,8021,0)="""RTN"",""MAGDSTV2"",90,0)"
^XMB(3.9,145834,2,8022,0)=" . . Q"
^XMB(3.9,145834,2,8023,0)="""RTN"",""MAGDSTV2"",91,0)"
^XMB(3.9,145834,2,8024,0)=" . I OPCODE=""RETRIEVE RESULT"" D  Q  ; save retrieve results in ^XTMP"
^XMB(3.9,145834,2,8025,0)="""RTN"",""MAGDSTV2"",92,0)"
^XMB(3.9,145834,2,8026,0)=" . . S MAGXTMP=$P(ARGS,""|"",1),HOSTNAME=$P(ARGS,""|"",2),VISTAJOB=$P(ARGS,""|"",3)"
^XMB(3.9,145834,2,8027,0)="""RTN"",""MAGDSTV2"",93,0)"
^XMB(3.9,145834,2,8028,0)=" . . S QRSTACK=$P(ARGS,""|"",4)"
^XMB(3.9,145834,2,8029,0)="""RTN"",""MAGDSTV2"",94,0)"
^XMB(3.9,145834,2,8030,0)=" . . S IEN2006541=$P(ARGS,""|"",5) ; IEN2006541 is not used here"
^XMB(3.9,145834,2,8031,0)="""RTN"",""MAGDSTV2"",95,0)"
^XMB(3.9,145834,2,8032,0)=" . . S ACNUMB=$P(ARGS,""|"",6),X=$P(ARGS,""|"",7,999)"
^XMB(3.9,145834,2,8033,0)="""RTN"",""MAGDSTV2"",96,0)"
^XMB(3.9,145834,2,8034,0)=" . . S ^XTMP(MAGXTMP,HOSTNAME,VISTAJOB,QRSTACK,""Q/R RETRIEVE STATUS"",ACNUMB)=X"
^XMB(3.9,145834,2,8035,0)="""RTN"",""MAGDSTV2"",97,0)"
^XMB(3.9,145834,2,8036,0)=" . . Q"
^XMB(3.9,145834,2,8037,0)="""RTN"",""MAGDSTV2"",98,0)"
^XMB(3.9,145834,2,8038,0)=" . I OPCODE=""CRASH"" D  Q"
^XMB(3.9,145834,2,8039,0)="""RTN"",""MAGDSTV2"",99,0)"
^XMB(3.9,145834,2,8040,0)=" . . S I=1/0 ; generate an error on the server to test error trapping"
^XMB(3.9,145834,2,8041,0)="""RTN"",""MAGDSTV2"",100,0)"
^XMB(3.9,145834,2,8042,0)=" . . Q"
^XMB(3.9,145834,2,8043,0)="""RTN"",""MAGDSTV2"",101,0)"
^XMB(3.9,145834,2,8044,0)=" . Q"
^XMB(3.9,145834,2,8045,0)="""RTN"",""MAGDSTV2"",102,0)"
^XMB(3.9,145834,2,8046,0)=" Q"
^XMB(3.9,145834,2,8047,0)="""RTN"",""MAGDSTV2"",103,0)"
^XMB(3.9,145834,2,8048,0)=" ;"
^XMB(3.9,145834,2,8049,0)="""RTN"",""MAGDSTV2"",104,0)"
^XMB(3.9,145834,2,8050,0)="RESULT(OPCODE,ARGS) ; add an item to the RESULT list"
^XMB(3.9,145834,2,8051,0)="""RTN"",""MAGDSTV2"",105,0)"
^XMB(3.9,145834,2,8052,0)=" S RESULT(1)=$G(RESULT(1),1)+1 ; first element in array is counter"
^XMB(3.9,145834,2,8053,0)="""RTN"",""MAGDSTV2"",106,0)"
^XMB(3.9,145834,2,8054,0)=" S RESULT(RESULT(1))=OPCODE_""|""_ARGS"
^XMB(3.9,145834,2,8055,0)="""RTN"",""MAGDSTV2"",107,0)"
^XMB(3.9,145834,2,8056,0)=" Q"
^XMB(3.9,145834,2,8057,0)="""RTN"",""MAGIP333"")"
^XMB(3.9,145834,2,8058,0)="1^8"
^XMB(3.9,145834,2,8059,0)="""SEC"",""^DIC"",2006.541,2006.541,0,""AUDIT"")"
^XMB(3.9,145834,2,8060,0)="@"
^XMB(3.9,145834,2,8061,0)="""SEC"",""^DIC"",2006.541,2006.541,0,""DD"")"
^XMB(3.9,145834,2,8062,0)="@"
^XMB(3.9,145834,2,8063,0)="""SEC"",""^DIC"",2006.541,2006.541,0,""DEL"")"
^XMB(3.9,145834,2,8064,0)="@"
^XMB(3.9,145834,2,8065,0)="""SEC"",""^DIC"",2006.541,2006.541,0,""LAYGO"")"
^XMB(3.9,145834,2,8066,0)="@"
^XMB(3.9,145834,2,8067,0)="""SEC"",""^DIC"",2006.541,2006.541,0,""RD"")"
^XMB(3.9,145834,2,8068,0)="@"
^XMB(3.9,145834,2,8069,0)="""SEC"",""^DIC"",2006.541,2006.541,0,""WR"")"
^XMB(3.9,145834,2,8070,0)="@"
^XMB(3.9,145834,2,8071,0)="""VER"")"
^XMB(3.9,145834,2,8072,0)="8.0^22.2"
^XMB(3.9,145834,2,8073,0)="""^DD"",2006.1,2006.1,211,0)"
^XMB(3.9,145834,2,8074,0)="Q/R CHECK DIVISION^S^N:DON'T CHECK DIVISION IN AUTO COMPARE/RETRIEVE;Y:CHECK DIVISION IN AUTO COMPARE/RETRIEVE;^8;E1,1^Q"
^XMB(3.9,145834,2,8075,0)="""^DD"",2006.1,2006.1,211,3)"
^XMB(3.9,145834,2,8076,0)="Check the study's division in auto compare/retrieve?"
^XMB(3.9,145834,2,8077,0)="""^DD"",2006.1,2006.1,211,21,0)"
^XMB(3.9,145834,2,8078,0)="^.001^15^15^3220307^^^^"
^XMB(3.9,145834,2,8079,0)="""^DD"",2006.1,2006.1,211,21,1,0)"
^XMB(3.9,145834,2,8080,0)="Some VISNs have a single VistA instantiation serving multiple"
^XMB(3.9,145834,2,8081,0)="""^DD"",2006.1,2006.1,211,21,2,0)"
^XMB(3.9,145834,2,8082,0)="facilities, each of which has its own image share.  Others have"
^XMB(3.9,145834,2,8083,0)="""^DD"",2006.1,2006.1,211,21,3,0)"
^XMB(3.9,145834,2,8084,0)="a single VistA instantiation serving multiple facilities, but there is"
^XMB(3.9,145834,2,8085,0)="""^DD"",2006.1,2006.1,211,21,4,0)"
^XMB(3.9,145834,2,8086,0)="only a single image share."
^XMB(3.9,145834,2,8087,0)="""^DD"",2006.1,2006.1,211,21,5,0)"
^XMB(3.9,145834,2,8088,0)=" "
^XMB(3.9,145834,2,8089,0)="""^DD"",2006.1,2006.1,211,21,6,0)"
^XMB(3.9,145834,2,8090,0)="In the first case, when automatic compare/retrieve is run, only the"
^XMB(3.9,145834,2,8091,0)="""^DD"",2006.1,2006.1,211,21,7,0)"
^XMB(3.9,145834,2,8092,0)="missing images for that facility should be retrieved to that"
^XMB(3.9,145834,2,8093,0)="""^DD"",2006.1,2006.1,211,21,8,0)"
^XMB(3.9,145834,2,8094,0)="facility's image share.  This requires checking the division"
^XMB(3.9,145834,2,8095,0)="""^DD"",2006.1,2006.1,211,21,9,0)"
^XMB(3.9,145834,2,8096,0)="of the study to exclude studies for the other facilities.  The"
^XMB(3.9,145834,2,8097,0)="""^DD"",2006.1,2006.1,211,21,10,0)"
^XMB(3.9,145834,2,8098,0)="switch should be set to ""Y"" to enable division checking."
^XMB(3.9,145834,2,8099,0)="""^DD"",2006.1,2006.1,211,21,11,0)"
^XMB(3.9,145834,2,8100,0)=" "
^XMB(3.9,145834,2,8101,0)="""^DD"",2006.1,2006.1,211,21,12,0)"
^XMB(3.9,145834,2,8102,0)="In the second case, when automatic compare/retrieve is run, all"
^XMB(3.9,145834,2,8103,0)="""^DD"",2006.1,2006.1,211,21,13,0)"
^XMB(3.9,145834,2,8104,0)="the missing images for all the facilities should be retrieved"
^XMB(3.9,145834,2,8105,0)="""^DD"",2006.1,2006.1,211,21,14,0)"
^XMB(3.9,145834,2,8106,0)="to the image share, regardless of the study's division.  The"
^XMB(3.9,145834,2,8107,0)="""^DD"",2006.1,2006.1,211,21,15,0)"
^XMB(3.9,145834,2,8108,0)="switch should be set to ""N"" to skip division checking."
^XMB(3.9,145834,2,8109,0)="""^DD"",2006.1,2006.1,211,""DT"")"
^XMB(3.9,145834,2,8110,0)=3220307
