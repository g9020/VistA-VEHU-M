^XMB(3.9,144657,2,1408,0)=" ;"
^XMB(3.9,144657,2,1409,0)="""RTN"",""IBCNBAR"",111,0)"
^XMB(3.9,144657,2,1410,0)=" ;IB*687/TAZ - File Accepted policy in INTERFACILITY INSURANCE UPDATE File (#365.19)"
^XMB(3.9,144657,2,1411,0)="""RTN"",""IBCNBAR"",112,0)"
^XMB(3.9,144657,2,1412,0)=" ;IBCNICB was set in routine IBCNICB. It will let us know if the buffer entry in file #355.33 was processed by"
^XMB(3.9,144657,2,1413,0)="""RTN"",""IBCNBAR"",113,0)"
^XMB(3.9,144657,2,1414,0)=" ; the COTS ICB product. This field will be used set ICB PROCESSED BUFFER (#365.19,1.08)."
^XMB(3.9,144657,2,1415,0)="""RTN"",""IBCNBAR"",114,0)"
^XMB(3.9,144657,2,1416,0)=" D LOC^IBCNIUF(DFN,IBINSDA,IBPOLDA,,IBBUFDA,$$GET1^DIQ(355.33,IBBUFDA_"","",.03,""E""),$G(IBCNICB))"
^XMB(3.9,144657,2,1417,0)="""RTN"",""IBCNBAR"",115,0)"
^XMB(3.9,144657,2,1418,0)=" ;"
^XMB(3.9,144657,2,1419,0)="""RTN"",""IBCNBAR"",116,0)"
^XMB(3.9,144657,2,1420,0)=" ; IB*2*595/DM if SOI is eIV, update insurance record IEN field in response file (#365/.12)"
^XMB(3.9,144657,2,1421,0)="""RTN"",""IBCNBAR"",117,0)"
^XMB(3.9,144657,2,1422,0)=" I $P(^IBA(355.33,IBBUFDA,0),U,3)=$$FIND1^DIC(355.12,,,""eIV"",""C"") D UPDIREC^IBCNEHL3($O(^IBCN(365,""AF"",IBBUFDA,"""")),IBPOLDA)"
^XMB(3.9,144657,2,1423,0)="""RTN"",""IBCNBAR"",118,0)"
^XMB(3.9,144657,2,1424,0)=" ; update buffer file entry so only stub remains and status is changed"
^XMB(3.9,144657,2,1425,0)="""RTN"",""IBCNBAR"",119,0)"
^XMB(3.9,144657,2,1426,0)=" D STATUS^IBCNBEE(IBBUFDA,""A"",IBNEWINS,IBNEWGRP,IBNEWPOL) ; update buffer entry's status to accepted"
^XMB(3.9,144657,2,1427,0)="""RTN"",""IBCNBAR"",120,0)"
^XMB(3.9,144657,2,1428,0)=" D DELDATA^IBCNBED(IBBUFDA) ; delete buffer's insurance/patient data"
^XMB(3.9,144657,2,1429,0)="""RTN"",""IBCNBAR"",121,0)"
^XMB(3.9,144657,2,1430,0)=" ;"
^XMB(3.9,144657,2,1431,0)="""RTN"",""IBCNBAR"",122,0)"
^XMB(3.9,144657,2,1432,0)=" ; IB*2.0*554"
^XMB(3.9,144657,2,1433,0)="""RTN"",""IBCNBAR"",123,0)"
^XMB(3.9,144657,2,1434,0)=" I $$HOLD^IBCNBLL(DFN),'$$BUFFER^IBCNBU1(DFN) D RELHLD(DFN)"
^XMB(3.9,144657,2,1435,0)="""RTN"",""IBCNBAR"",124,0)"
^XMB(3.9,144657,2,1436,0)=" ;I +DFN,RELHLD D"
^XMB(3.9,144657,2,1437,0)="""RTN"",""IBCNBAR"",125,0)"
^XMB(3.9,144657,2,1438,0)=" ;. ;Suppress Write in $$PTHLD^IBOHCR if called from ICB Interface"
^XMB(3.9,144657,2,1439,0)="""RTN"",""IBCNBAR"",126,0)"
^XMB(3.9,144657,2,1440,0)=" ;. I +$$PTHLD^IBOHCR(DFN,2,$S($G(IBSUPRES)>0:0,1:1)) D"
^XMB(3.9,144657,2,1441,0)="""RTN"",""IBCNBAR"",127,0)"
^XMB(3.9,144657,2,1442,0)=" ;. . I $G(IBSUPRES)'>0 W !!,""Patient has no other active Insurance."",!,""All patient bills On Hold waiting for Insurance to be released."" D WAIT^IBCNBUH"
^XMB(3.9,144657,2,1443,0)="""RTN"",""IBCNBAR"",128,0)"
^XMB(3.9,144657,2,1444,0)=" ;. . S RESULT=$G(RESULT)_""^Patient has no other active Insurance.  All patient bills On Hold waiting for Insurance to be released."""
^XMB(3.9,144657,2,1445,0)="""RTN"",""IBCNBAR"",129,0)"
^XMB(3.9,144657,2,1446,0)=" ;"
^XMB(3.9,144657,2,1447,0)="""RTN"",""IBCNBAR"",130,0)"
^XMB(3.9,144657,2,1448,0)=" S IBCDFN=IBPOLDA S:+IBSOURCE=3 IVMINSUP=1 D AFTER^IBCNSEVT,^IBCNSEVT ; insurance event driver"
^XMB(3.9,144657,2,1449,0)="""RTN"",""IBCNBAR"",131,0)"
^XMB(3.9,144657,2,1450,0)=" ;"
^XMB(3.9,144657,2,1451,0)="""RTN"",""IBCNBAR"",132,0)"
^XMB(3.9,144657,2,1452,0)="ACCPTQ Q"
^XMB(3.9,144657,2,1453,0)="""RTN"",""IBCNBAR"",133,0)"
^XMB(3.9,144657,2,1454,0)=" ;"
^XMB(3.9,144657,2,1455,0)="""RTN"",""IBCNBAR"",134,0)"
^XMB(3.9,144657,2,1456,0)="REJECT(IBBUFDA,IBRTN) ; process a buffer entry reject  ;IB*806/CKB - added IBRTN"
^XMB(3.9,144657,2,1457,0)="""RTN"",""IBCNBAR"",135,0)"
^XMB(3.9,144657,2,1458,0)=" ;Input:"
^XMB(3.9,144657,2,1459,0)="""RTN"",""IBCNBAR"",136,0)"
^XMB(3.9,144657,2,1460,0)=" ; IBBUFDA - IEN of file #355.33 (Required)"
^XMB(3.9,144657,2,1461,0)="""RTN"",""IBCNBAR"",137,0)"
^XMB(3.9,144657,2,1462,0)=" ;   IBRTN - routine calling into REJECT, currently only IBJPI3 (Optional)"
^XMB(3.9,144657,2,1463,0)="""RTN"",""IBCNBAR"",138,0)"
^XMB(3.9,144657,2,1464,0)=" ;"
^XMB(3.9,144657,2,1465,0)="""RTN"",""IBCNBAR"",139,0)"
^XMB(3.9,144657,2,1466,0)=" ;    1) update/notify IVM"
^XMB(3.9,144657,2,1467,0)="""RTN"",""IBCNBAR"",140,0)"
^XMB(3.9,144657,2,1468,0)=" ;    2) buffer ins/group/policy data deleted"
^XMB(3.9,144657,2,1469,0)="""RTN"",""IBCNBAR"",141,0)"
^XMB(3.9,144657,2,1470,0)=" ;    3) buffer entry status updated"
^XMB(3.9,144657,2,1471,0)="""RTN"",""IBCNBAR"",142,0)"
^XMB(3.9,144657,2,1472,0)=" ;    4) if patient has no other active insurance then release any patient bills On Hold"
^XMB(3.9,144657,2,1473,0)="""RTN"",""IBCNBAR"",143,0)"
^XMB(3.9,144657,2,1474,0)=" ;"
^XMB(3.9,144657,2,1475,0)="""RTN"",""IBCNBAR"",144,0)"
^XMB(3.9,144657,2,1476,0)=" N IBSUPRES,RESULT,RELHLD"
^XMB(3.9,144657,2,1477,0)="""RTN"",""IBCNBAR"",145,0)"
^XMB(3.9,144657,2,1478,0)=" ;Set IBSUPRES to 0 to not suppress I/O within REJECT"
^XMB(3.9,144657,2,1479,0)="""RTN"",""IBCNBAR"",146,0)"
^XMB(3.9,144657,2,1480,0)=" S IBSUPRES=0,RELHLD=0"
^XMB(3.9,144657,2,1481,0)="""RTN"",""IBCNBAR"",147,0)"
^XMB(3.9,144657,2,1482,0)=" ;IB*806/CKB - if called from IBJPI3 set IBSUPRES to 1 to suppress I/O"
^XMB(3.9,144657,2,1483,0)="""RTN"",""IBCNBAR"",148,0)"
^XMB(3.9,144657,2,1484,0)=" I $G(IBRTN)=""IBJPI3"" S IBSUPRES=1"
^XMB(3.9,144657,2,1485,0)="""RTN"",""IBCNBAR"",149,0)"
^XMB(3.9,144657,2,1486,0)=" ;"
^XMB(3.9,144657,2,1487,0)="""RTN"",""IBCNBAR"",150,0)"
^XMB(3.9,144657,2,1488,0)="REJPROC ;Entry point for REJECAPI^IBCNICB (Patch 413)"
^XMB(3.9,144657,2,1489,0)="""RTN"",""IBCNBAR"",151,0)"
^XMB(3.9,144657,2,1490,0)=" ;"
^XMB(3.9,144657,2,1491,0)="""RTN"",""IBCNBAR"",152,0)"
^XMB(3.9,144657,2,1492,0)=" N DFN S DFN=+$G(^IBA(355.33,+IBBUFDA,60))"
^XMB(3.9,144657,2,1493,0)="""RTN"",""IBCNBAR"",153,0)"
^XMB(3.9,144657,2,1494,0)=" N RELHLD S RELHLD=0"
^XMB(3.9,144657,2,1495,0)="""RTN"",""IBCNBAR"",154,0)"
^XMB(3.9,144657,2,1496,0)=" S RESULT=""-1^PATIENT IEN MISSING FROM BUFFER ENTRY"" Q:'$G(DFN)"
^XMB(3.9,144657,2,1497,0)="""RTN"",""IBCNBAR"",155,0)"
^XMB(3.9,144657,2,1498,0)=" I +$P($G(^IBA(355.33,+IBBUFDA,0)),U,3)=3 D IVM(0,IBBUFDA,$G(IVMREPTR),$G(IBSUPRES))"
^XMB(3.9,144657,2,1499,0)="""RTN"",""IBCNBAR"",156,0)"
^XMB(3.9,144657,2,1500,0)=" ;"
^XMB(3.9,144657,2,1501,0)="""RTN"",""IBCNBAR"",157,0)"
^XMB(3.9,144657,2,1502,0)=" ; IB*2.0*631/TAZ Add CREATION TO PROCESSING Tracking"
^XMB(3.9,144657,2,1503,0)="""RTN"",""IBCNBAR"",158,0)"
^XMB(3.9,144657,2,1504,0)=" D TRACK"
^XMB(3.9,144657,2,1505,0)="""RTN"",""IBCNBAR"",159,0)"
^XMB(3.9,144657,2,1506,0)=" ;"
^XMB(3.9,144657,2,1507,0)="""RTN"",""IBCNBAR"",160,0)"
^XMB(3.9,144657,2,1508,0)=" S RESULT=0"
^XMB(3.9,144657,2,1509,0)="""RTN"",""IBCNBAR"",161,0)"
^XMB(3.9,144657,2,1510,0)=" D STATUS^IBCNBEE(+IBBUFDA,""R"",0,0,0),DELDATA^IBCNBED(+IBBUFDA) W:$G(IBSUPRES)'>0 "" ... done."""
^XMB(3.9,144657,2,1511,0)="""RTN"",""IBCNBAR"",162,0)"
^XMB(3.9,144657,2,1512,0)=" ;"
^XMB(3.9,144657,2,1513,0)="""RTN"",""IBCNBAR"",163,0)"
^XMB(3.9,144657,2,1514,0)=" ; IB*2.0*554"
^XMB(3.9,144657,2,1515,0)="""RTN"",""IBCNBAR"",164,0)"
^XMB(3.9,144657,2,1516,0)=" I $$HOLD^IBCNBLL(DFN),'$$BUFFER^IBCNBU1(DFN) D RELHLD(DFN)"
^XMB(3.9,144657,2,1517,0)="""RTN"",""IBCNBAR"",165,0)"
^XMB(3.9,144657,2,1518,0)=" ;I +DFN,RELHLD D"
^XMB(3.9,144657,2,1519,0)="""RTN"",""IBCNBAR"",166,0)"
^XMB(3.9,144657,2,1520,0)=" ;. ;Suppress Write in $$PTHLD^IBOHCR if called from ICB Interface"
^XMB(3.9,144657,2,1521,0)="""RTN"",""IBCNBAR"",167,0)"
^XMB(3.9,144657,2,1522,0)=" ;. I +$$PTHLD^IBOHCR(DFN,2,$S($G(IBSUPRES)>0:0,1:1)) D"
^XMB(3.9,144657,2,1523,0)="""RTN"",""IBCNBAR"",168,0)"
^XMB(3.9,144657,2,1524,0)=" ;. . I $G(IBSUPRES)'>0 W !!,""Patient has no other active Insurance."",!,""All patient bills On Hold waiting for Insurance to be released."" D WAIT^IBCNBUH"
^XMB(3.9,144657,2,1525,0)="""RTN"",""IBCNBAR"",169,0)"
^XMB(3.9,144657,2,1526,0)=" ;. . S RESULT=$G(RESULT)_""^Patient has no other active Insurance.  All patient bills On Hold waiting for Insurance to be released."""
^XMB(3.9,144657,2,1527,0)="""RTN"",""IBCNBAR"",170,0)"
^XMB(3.9,144657,2,1528,0)=" ;"
^XMB(3.9,144657,2,1529,0)="""RTN"",""IBCNBAR"",171,0)"
^XMB(3.9,144657,2,1530,0)=" Q"
^XMB(3.9,144657,2,1531,0)="""RTN"",""IBCNBAR"",172,0)"
^XMB(3.9,144657,2,1532,0)=" ;"
^XMB(3.9,144657,2,1533,0)="""RTN"",""IBCNBAR"",173,0)"
^XMB(3.9,144657,2,1534,0)=" ;"
^XMB(3.9,144657,2,1535,0)="""RTN"",""IBCNBAR"",174,0)"
^XMB(3.9,144657,2,1536,0)="IVM(AR,IBBUFDA,IVMREPTR,IBSUPRES) ; IVM must be notified whenever a buffer entry"
^XMB(3.9,144657,2,1537,0)="""RTN"",""IBCNBAR"",175,0)"
^XMB(3.9,144657,2,1538,0)=" ; that originated in IVM is accepted or rejected. This lets IVM clean up"
^XMB(3.9,144657,2,1539,0)="""RTN"",""IBCNBAR"",176,0)"
^XMB(3.9,144657,2,1540,0)=" ; its files since IVM also has a buffer type file of insurance uploaded"
^XMB(3.9,144657,2,1541,0)="""RTN"",""IBCNBAR"",177,0)"
^XMB(3.9,144657,2,1542,0)=" ; from the IVM center."
^XMB(3.9,144657,2,1543,0)="""RTN"",""IBCNBAR"",178,0)"
^XMB(3.9,144657,2,1544,0)=" ; If rejected and Interactive Reads not suppressed, IVM then ask the "
^XMB(3.9,144657,2,1545,0)="""RTN"",""IBCNBAR"",179,0)"
^XMB(3.9,144657,2,1546,0)=" ; user for a reason it was rejected"
^XMB(3.9,144657,2,1547,0)="""RTN"",""IBCNBAR"",180,0)"
^XMB(3.9,144657,2,1548,0)=" ; input:  AR = 1 if accepted, 0 if rejected"
^XMB(3.9,144657,2,1549,0)="""RTN"",""IBCNBAR"",181,0)"
^XMB(3.9,144657,2,1550,0)=" ;    IBBUFDA = Internal Entry Number to 355.33 file"
^XMB(3.9,144657,2,1551,0)="""RTN"",""IBCNBAR"",182,0)"
^XMB(3.9,144657,2,1552,0)=" ;   IVMREPTR = Internal Entry Number to 301.91 file (Optional)"
^XMB(3.9,144657,2,1553,0)="""RTN"",""IBCNBAR"",183,0)"
^XMB(3.9,144657,2,1554,0)=" ;   IBSUPRES = If equals 1, suppress writes and interactive reads"
^XMB(3.9,144657,2,1555,0)="""RTN"",""IBCNBAR"",184,0)"
^XMB(3.9,144657,2,1556,0)=" ;"
^XMB(3.9,144657,2,1557,0)="""RTN"",""IBCNBAR"",185,0)"
^XMB(3.9,144657,2,1558,0)=" N DFN,IBX,IBY I $P($G(^IBA(355.33,+IBBUFDA,0)),U,3)'=3 Q"
^XMB(3.9,144657,2,1559,0)="""RTN"",""IBCNBAR"",186,0)"
^XMB(3.9,144657,2,1560,0)=" ;"
^XMB(3.9,144657,2,1561,0)="""RTN"",""IBCNBAR"",187,0)"
^XMB(3.9,144657,2,1562,0)=" S DFN=+$G(^IBA(355.33,+IBBUFDA,60))"
^XMB(3.9,144657,2,1563,0)="""RTN"",""IBCNBAR"",188,0)"
^XMB(3.9,144657,2,1564,0)=" S IBX=$P($G(^IBA(355.33,+IBBUFDA,20)),U,1)_U_$P($G(^IBA(355.33,+IBBUFDA,21)),U,1)_U_$P($G(^IBA(355.33,+IBBUFDA,90)),U,2)  ; IB*2.0*497 (vd)"
^XMB(3.9,144657,2,1565,0)="""RTN"",""IBCNBAR"",189,0)"
^XMB(3.9,144657,2,1566,0)=" ;"
^XMB(3.9,144657,2,1567,0)="""RTN"",""IBCNBAR"",190,0)"
^XMB(3.9,144657,2,1568,0)=" S IBY=$$UPDATE^IVMLINS4(DFN,AR,IBX,$G(IVMREPTR),$G(IBSUPRES))"
^XMB(3.9,144657,2,1569,0)="""RTN"",""IBCNBAR"",191,0)"
^XMB(3.9,144657,2,1570,0)=" Q"
^XMB(3.9,144657,2,1571,0)="""RTN"",""IBCNBAR"",192,0)"
^XMB(3.9,144657,2,1572,0)=" ; ;IB*2.0*554"
^XMB(3.9,144657,2,1573,0)="""RTN"",""IBCNBAR"",193,0)"
^XMB(3.9,144657,2,1574,0)="RELHLD(DFN) ;Check if need to release copay on hold"
^XMB(3.9,144657,2,1575,0)="""RTN"",""IBCNBAR"",194,0)"
^XMB(3.9,144657,2,1576,0)=" N IBN,X3,X5,IBX,IBFR,IBAT,IBCAT,IBTALK,IBVDT"
^XMB(3.9,144657,2,1577,0)="""RTN"",""IBCNBAR"",195,0)"
^XMB(3.9,144657,2,1578,0)=" S IBTALK=$S($G(IBSUPRES)>0:0,1:1)"
^XMB(3.9,144657,2,1579,0)="""RTN"",""IBCNBAR"",196,0)"
^XMB(3.9,144657,2,1580,0)=" S IBN=0"
^XMB(3.9,144657,2,1581,0)="""RTN"",""IBCNBAR"",197,0)"
^XMB(3.9,144657,2,1582,0)=" F  S IBN=$O(^IB(""AH"",DFN,IBN)) Q:IBN=""""  D"
^XMB(3.9,144657,2,1583,0)="""RTN"",""IBCNBAR"",198,0)"
^XMB(3.9,144657,2,1584,0)=" . S IBX=$G(^IB(IBN,0))"
^XMB(3.9,144657,2,1585,0)="""RTN"",""IBCNBAR"",199,0)"
^XMB(3.9,144657,2,1586,0)=" . S X5=+$P(IBX,U,5) Q:X5'=8"
^XMB(3.9,144657,2,1587,0)="""RTN"",""IBCNBAR"",200,0)"
^XMB(3.9,144657,2,1588,0)=" . S IBFR=$P(IBX,U,14)"
^XMB(3.9,144657,2,1589,0)="""RTN"",""IBCNBAR"",201,0)"
^XMB(3.9,144657,2,1590,0)=" . S X3=$P(IBX,U,3)"
^XMB(3.9,144657,2,1591,0)="""RTN"",""IBCNBAR"",202,0)"
^XMB(3.9,144657,2,1592,0)=" . S IBVDT=$S(IBFR'="""":IBFR,1:DT),IBAT=$P(^IBE(350.1,X3,0),U,11)"
^XMB(3.9,144657,2,1593,0)="""RTN"",""IBCNBAR"",203,0)"
^XMB(3.9,144657,2,1594,0)=" . S IBCAT=$S(IBAT<4:""INPATIENT"",IBAT=4:""OUTPATIENT"",IBAT=5:""PHARMACY"",IBAT=8:""OUTPATIENT"",IBAT=9:""INPATIENT"",1:"""")"
^XMB(3.9,144657,2,1595,0)="""RTN"",""IBCNBAR"",204,0)"
^XMB(3.9,144657,2,1596,0)=" . S IBCAT=$O(^IBE(355.31,""B"",IBCAT,""""))"
^XMB(3.9,144657,2,1597,0)="""RTN"",""IBCNBAR"",205,0)"
^XMB(3.9,144657,2,1598,0)=" . D CHKREL(DFN,IBVDT,IBN,IBCAT)"
^XMB(3.9,144657,2,1599,0)="""RTN"",""IBCNBAR"",206,0)"
^XMB(3.9,144657,2,1600,0)=" Q"
^XMB(3.9,144657,2,1601,0)="""RTN"",""IBCNBAR"",207,0)"
^XMB(3.9,144657,2,1602,0)=" ;"
^XMB(3.9,144657,2,1603,0)="""RTN"",""IBCNBAR"",208,0)"
^XMB(3.9,144657,2,1604,0)="CHKREL(DFN,IBINDT,IBN,IBCAT) ; -- release copay"
^XMB(3.9,144657,2,1605,0)="""RTN"",""IBCNBAR"",209,0)"
^XMB(3.9,144657,2,1606,0)=" ; --Input  DFN     = patient"
^XMB(3.9,144657,2,1607,0)="""RTN"",""IBCNBAR"",210,0)"
^XMB(3.9,144657,2,1608,0)=" ;          IBINDT  = date to check"
^XMB(3.9,144657,2,1609,0)="""RTN"",""IBCNBAR"",211,0)"
^XMB(3.9,144657,2,1610,0)=" ;          IBN     = ien of copay on hold"
^XMB(3.9,144657,2,1611,0)="""RTN"",""IBCNBAR"",212,0)"
^XMB(3.9,144657,2,1612,0)=" ;          IBCAT   = category of hold"
^XMB(3.9,144657,2,1613,0)="""RTN"",""IBCNBAR"",213,0)"
^XMB(3.9,144657,2,1614,0)=" ; will determine if hold should be released"
^XMB(3.9,144657,2,1615,0)="""RTN"",""IBCNBAR"",214,0)"
^XMB(3.9,144657,2,1616,0)=" ;"
^XMB(3.9,144657,2,1617,0)="""RTN"",""IBCNBAR"",215,0)"
^XMB(3.9,144657,2,1618,0)=" N IBCOV,IBDD,PLAN,POLCY,TRICHP,COV,CNT,TYPNAM,X,PLAN,ANYINS,INS,CHKCOV,PLNTYP"
^XMB(3.9,144657,2,1619,0)="""RTN"",""IBCNBAR"",216,0)"
^XMB(3.9,144657,2,1620,0)=" S (IBCOV,CNT,COV,TRICHP,POLCY)=0"
^XMB(3.9,144657,2,1621,0)="""RTN"",""IBCNBAR"",217,0)"
^XMB(3.9,144657,2,1622,0)=" I IBINDT="""" S IBINDT=DT"
^XMB(3.9,144657,2,1623,0)="""RTN"",""IBCNBAR"",218,0)"
^XMB(3.9,144657,2,1624,0)=" S IBINDT=IBINDT\1"
^XMB(3.9,144657,2,1625,0)="""RTN"",""IBCNBAR"",219,0)"
^XMB(3.9,144657,2,1626,0)=" D ALL^IBCNS1(DFN,""IBDD"",2,IBINDT) ;All active ins policies returned in IBDD array"
^XMB(3.9,144657,2,1627,0)="""RTN"",""IBCNBAR"",220,0)"
^XMB(3.9,144657,2,1628,0)=" S ANYINS=($O(IBDD(0))'="""")"
^XMB(3.9,144657,2,1629,0)="""RTN"",""IBCNBAR"",221,0)"
^XMB(3.9,144657,2,1630,0)=" I 'ANYINS D RELEASE^IBOHCR(IBN) Q"
^XMB(3.9,144657,2,1631,0)="""RTN"",""IBCNBAR"",222,0)"
^XMB(3.9,144657,2,1632,0)=" F  S POLCY=$O(IBDD(POLCY)) Q:'POLCY  D"
^XMB(3.9,144657,2,1633,0)="""RTN"",""IBCNBAR"",223,0)"
^XMB(3.9,144657,2,1634,0)=" . S X=IBDD(POLCY,0)"
^XMB(3.9,144657,2,1635,0)="""RTN"",""IBCNBAR"",224,0)"
^XMB(3.9,144657,2,1636,0)=" . S PLAN=$P(X,U,18) I PLAN="""" Q"
^XMB(3.9,144657,2,1637,0)="""RTN"",""IBCNBAR"",225,0)"
^XMB(3.9,144657,2,1638,0)=" . S INS=$P(X,U,1)_"","""
^XMB(3.9,144657,2,1639,0)="""RTN"",""IBCNBAR"",226,0)"
^XMB(3.9,144657,2,1640,0)=" . S COV=$$GET1^DIQ(36,INS,1,""I"") S COV=$S(COV=""N"":0,1:1)"
^XMB(3.9,144657,2,1641,0)="""RTN"",""IBCNBAR"",227,0)"
^XMB(3.9,144657,2,1642,0)=" . S TYPNAM=$$GET1^DIQ(36,INS,.13,""E""),CNT=CNT+1"
^XMB(3.9,144657,2,1643,0)="""RTN"",""IBCNBAR"",228,0)"
^XMB(3.9,144657,2,1644,0)=" . S:TYPNAM[""TRICARE"" TRICHP=1 S:TYPNAM[""CHAMPVA"" TRICHP=1"
^XMB(3.9,144657,2,1645,0)="""RTN"",""IBCNBAR"",229,0)"
^XMB(3.9,144657,2,1646,0)=" . I TYPNAM'[""TRICARE"",TYPNAM'[""CHAMPVA"",COV D"
^XMB(3.9,144657,2,1647,0)="""RTN"",""IBCNBAR"",230,0)"
^XMB(3.9,144657,2,1648,0)=" . . I 'IBCOV S IBCOV=$$PLCOV^IBCNSU3(PLAN,IBINDT,IBCAT)"
^XMB(3.9,144657,2,1649,0)="""RTN"",""IBCNBAR"",231,0)"
^XMB(3.9,144657,2,1650,0)=" ; remove hold if only has TRICARE OR CHAMPVA"
^XMB(3.9,144657,2,1651,0)="""RTN"",""IBCNBAR"",232,0)"
^XMB(3.9,144657,2,1652,0)=" I $G(CNT)=1,TRICHP D RELEASE^IBOHCR(IBN) Q"
^XMB(3.9,144657,2,1653,0)="""RTN"",""IBCNBAR"",233,0)"
^XMB(3.9,144657,2,1654,0)=" ; remove hold if multiple coverage and TRICARE or CHAMPVA and no ibcov"
^XMB(3.9,144657,2,1655,0)="""RTN"",""IBCNBAR"",234,0)"
^XMB(3.9,144657,2,1656,0)=" I $G(CNT)>1,TRICHP I 'IBCOV D RELEASE^IBOHCR(IBN) Q"
^XMB(3.9,144657,2,1657,0)="""RTN"",""IBCNBAR"",235,0)"
^XMB(3.9,144657,2,1658,0)=" ; remove hold if no TRICARE or CHAMPVA and no ibcov"
^XMB(3.9,144657,2,1659,0)="""RTN"",""IBCNBAR"",236,0)"
^XMB(3.9,144657,2,1660,0)=" I 'TRICHP,'IBCOV D RELEASE^IBOHCR(IBN)"
^XMB(3.9,144657,2,1661,0)="""RTN"",""IBCNBAR"",237,0)"
^XMB(3.9,144657,2,1662,0)=" Q"
^XMB(3.9,144657,2,1663,0)="""RTN"",""IBCNBAR"",238,0)"
^XMB(3.9,144657,2,1664,0)=" ;"
^XMB(3.9,144657,2,1665,0)="""RTN"",""IBCNBAR"",239,0)"
^XMB(3.9,144657,2,1666,0)=" ;IB*2.0*631/TAZ Added Tracking for CREATION TO PROCESSING TRACKING File"
^XMB(3.9,144657,2,1667,0)="""RTN"",""IBCNBAR"",240,0)"
^XMB(3.9,144657,2,1668,0)="TRACK ;Build CREATION TO PROCESSING TRACKING File (#355.36)"
^XMB(3.9,144657,2,1669,0)="""RTN"",""IBCNBAR"",241,0)"
^XMB(3.9,144657,2,1670,0)=" N ERROR,FDA,IBMSG,RESP,SOI,TQN,WE"
^XMB(3.9,144657,2,1671,0)="""RTN"",""IBCNBAR"",242,0)"
^XMB(3.9,144657,2,1672,0)=" S WE="""""
^XMB(3.9,144657,2,1673,0)="""RTN"",""IBCNBAR"",243,0)"
^XMB(3.9,144657,2,1674,0)=" S RESP=$O(^IBCN(365,""AF"",IBBUFDA,""""),-1) I RESP D"
^XMB(3.9,144657,2,1675,0)="""RTN"",""IBCNBAR"",244,0)"
^XMB(3.9,144657,2,1676,0)=" . S TQN=$$GET1^DIQ(365,RESP_"","",.05,""I"")"
^XMB(3.9,144657,2,1677,0)="""RTN"",""IBCNBAR"",245,0)"
^XMB(3.9,144657,2,1678,0)=" . S WE=$$GET1^DIQ(365.1,TQN_"","",.1,""I"")"
^XMB(3.9,144657,2,1679,0)="""RTN"",""IBCNBAR"",246,0)"
^XMB(3.9,144657,2,1680,0)=" . S SOI=$$GET1^DIQ(365.1,TQN_"","",3.02,""I"")"
^XMB(3.9,144657,2,1681,0)="""RTN"",""IBCNBAR"",247,0)"
^XMB(3.9,144657,2,1682,0)=" I 'RESP D"
^XMB(3.9,144657,2,1683,0)="""RTN"",""IBCNBAR"",248,0)"
^XMB(3.9,144657,2,1684,0)=" . ; Get data when a user processes a buffer entry before EIV can create an HL7 for a transmission"
^XMB(3.9,144657,2,1685,0)="""RTN"",""IBCNBAR"",249,0)"
^XMB(3.9,144657,2,1686,0)=" . S TQN=$O(^IBCN(365.1,""D"",IBBUFDA,""""),-1)"
^XMB(3.9,144657,2,1687,0)="""RTN"",""IBCNBAR"",250,0)"
^XMB(3.9,144657,2,1688,0)=" . I TQN D  Q"
^XMB(3.9,144657,2,1689,0)="""RTN"",""IBCNBAR"",251,0)"
^XMB(3.9,144657,2,1690,0)=" .. S WE=$$GET1^DIQ(365.1,TQN_"","",.1,""I"")"
^XMB(3.9,144657,2,1691,0)="""RTN"",""IBCNBAR"",252,0)"
^XMB(3.9,144657,2,1692,0)=" .. S SOI=$$GET1^DIQ(365.1,TQN_"","",3.02,""I"")"
^XMB(3.9,144657,2,1693,0)="""RTN"",""IBCNBAR"",253,0)"
^XMB(3.9,144657,2,1694,0)=" . S WE=6"
^XMB(3.9,144657,2,1695,0)="""RTN"",""IBCNBAR"",254,0)"
^XMB(3.9,144657,2,1696,0)=" . S SOI=$$GET1^DIQ(355.33,IBBUFDA_"","",.03,""I"")"
^XMB(3.9,144657,2,1697,0)="""RTN"",""IBCNBAR"",255,0)"
^XMB(3.9,144657,2,1698,0)=" I WE=7 Q   ; Do not want to track."
^XMB(3.9,144657,2,1699,0)="""RTN"",""IBCNBAR"",256,0)"
^XMB(3.9,144657,2,1700,0)=" S FDA(355.36,""+1,"",.01)=$$NOW^XLFDT ; DATE PROCESSED"
^XMB(3.9,144657,2,1701,0)="""RTN"",""IBCNBAR"",257,0)"
^XMB(3.9,144657,2,1702,0)=" ;IB*806/CKB - if IBTRN'=""IBJPI3"",maintain current functionality "
^XMB(3.9,144657,2,1703,0)="""RTN"",""IBCNBAR"",258,0)"
^XMB(3.9,144657,2,1704,0)=" I $G(IBRTN)'=""IBJPI3"" S FDA(355.36,""+1,"",.02)=$S(""^1^2^3^4^""[(U_WE_U):2,""^5^6^""[(U_WE_U):4,1:"""") ;TYPE OF PROCESSING"
^XMB(3.9,144657,2,1705,0)="""RTN"",""IBCNBAR"",259,0)"
^XMB(3.9,144657,2,1706,0)=" ;IB*806/CKB - if IBRTN=""IBJPI3"" this is the Auto Reject (No Touch) of Duplicate Buffer entries"
^XMB(3.9,144657,2,1707,0)="""RTN"",""IBCNBAR"",260,0)"
^XMB(3.9,144657,2,1708,0)=" I $G(IBRTN)=""IBJPI3"" S FDA(355.36,""+1,"",.02)=$S(""^5^6^""[(U_WE_U):3,""^1^2^""[(U_WE_U):1,1:"""")      ;TYPE OF PROCESSING"
^XMB(3.9,144657,2,1709,0)="""RTN"",""IBCNBAR"",261,0)"
^XMB(3.9,144657,2,1710,0)=" S FDA(355.36,""+1,"",.03)=SOI ; SOURCE OF INFORMATION"
^XMB(3.9,144657,2,1711,0)="""RTN"",""IBCNBAR"",262,0)"
^XMB(3.9,144657,2,1712,0)=" S FDA(355.36,""+1,"",.04)=0 ; EIV AUTO-UPDATE (always 0 for No if it hits this code.)"
^XMB(3.9,144657,2,1713,0)="""RTN"",""IBCNBAR"",263,0)"
^XMB(3.9,144657,2,1714,0)=" S FDA(355.36,""+1,"",.05)=$G(TQN) ; EIV INQUIRY"
^XMB(3.9,144657,2,1715,0)="""RTN"",""IBCNBAR"",264,0)"
^XMB(3.9,144657,2,1716,0)=" S FDA(355.36,""+1,"",.06)=RESP ; EIV RESPONSE"
^XMB(3.9,144657,2,1717,0)="""RTN"",""IBCNBAR"",265,0)"
^XMB(3.9,144657,2,1718,0)=" S FDA(355.36,""+1,"",.07)=$G(IBBUFDA) ; BUFFER"
^XMB(3.9,144657,2,1719,0)="""RTN"",""IBCNBAR"",266,0)"
^XMB(3.9,144657,2,1720,0)=" S FDA(355.36,""+1,"",.08)=WE ; WHICH EXTRACT (SOURCE OF REQUEST)"
^XMB(3.9,144657,2,1721,0)="""RTN"",""IBCNBAR"",267,0)"
^XMB(3.9,144657,2,1722,0)=" D UPDATE^DIE("""",""FDA"",,""ERROR"")"
^XMB(3.9,144657,2,1723,0)="""RTN"",""IBCNBAR"",268,0)"
^XMB(3.9,144657,2,1724,0)=" ;"
^XMB(3.9,144657,2,1725,0)="""RTN"",""IBCNBAR"",269,0)"
^XMB(3.9,144657,2,1726,0)=" I $D(ERROR) D"
^XMB(3.9,144657,2,1727,0)="""RTN"",""IBCNBAR"",270,0)"
^XMB(3.9,144657,2,1728,0)=" . D MSG003^IBCNEMS1(.IBMSG,.ERROR,TQN,RESP,$G(IBBUFDA))"
^XMB(3.9,144657,2,1729,0)="""RTN"",""IBCNBAR"",271,0)"
^XMB(3.9,144657,2,1730,0)=" . D MSG^IBCNEUT5($$MGRP^IBCNEUT5(),""eIV Problem: Error writing to the CREATION TO PROCESSING TRACKING File (#355.36)"",""IBMSG("")"
^XMB(3.9,144657,2,1731,0)="""RTN"",""IBCNBAR"",272,0)"
^XMB(3.9,144657,2,1732,0)=" Q"
^XMB(3.9,144657,2,1733,0)="""RTN"",""IBCNBAR"",273,0)"
^XMB(3.9,144657,2,1734,0)=" ;"
^XMB(3.9,144657,2,1735,0)="""RTN"",""IBCNBAR"",274,0)"
^XMB(3.9,144657,2,1736,0)="EFFDTCHK(IBBUFDA,IBSIEN,IBMVPOL) ;"
^XMB(3.9,144657,2,1737,0)="""RTN"",""IBCNBAR"",275,0)"
^XMB(3.9,144657,2,1738,0)=" ;IB*737/CKB - if processing this entry would result in Effective Date (#2.312,8) being null,"
^XMB(3.9,144657,2,1739,0)="""RTN"",""IBCNBAR"",276,0)"
^XMB(3.9,144657,2,1740,0)=" ;             abort processing by returning 1"
^XMB(3.9,144657,2,1741,0)="""RTN"",""IBCNBAR"",277,0)"
^XMB(3.9,144657,2,1742,0)=" ; "
^XMB(3.9,144657,2,1743,0)="""RTN"",""IBCNBAR"",278,0)"
^XMB(3.9,144657,2,1744,0)=" ;"
^XMB(3.9,144657,2,1745,0)="""RTN"",""IBCNBAR"",279,0)"
^XMB(3.9,144657,2,1746,0)=" ;Can't ACCEPT the entry if the Eff Date (#355.33,60.02) is null (includes Replace scenario)"
^XMB(3.9,144657,2,1747,0)="""RTN"",""IBCNBAR"",280,0)"
^XMB(3.9,144657,2,1748,0)=" ;"
^XMB(3.9,144657,2,1749,0)="""RTN"",""IBCNBAR"",281,0)"
^XMB(3.9,144657,2,1750,0)=" ;Overwrite - can't ACCEPT the entry if:"
^XMB(3.9,144657,2,1751,0)="""RTN"",""IBCNBAR"",282,0)"
^XMB(3.9,144657,2,1752,0)=" ;      Exp Date (#355.33,60.03) is null;"
^XMB(3.9,144657,2,1753,0)="""RTN"",""IBCNBAR"",283,0)"
^XMB(3.9,144657,2,1754,0)=" ;      AND Exp Date (#2.312,3) is NOT null;"
^XMB(3.9,144657,2,1755,0)="""RTN"",""IBCNBAR"",284,0)"
^XMB(3.9,144657,2,1756,0)=" ;      AND Eff Date (#355.33,60.02) > Exp Date (#2.312,3)"
^XMB(3.9,144657,2,1757,0)="""RTN"",""IBCNBAR"",285,0)"
^XMB(3.9,144657,2,1758,0)=" ;"
^XMB(3.9,144657,2,1759,0)="""RTN"",""IBCNBAR"",286,0)"
^XMB(3.9,144657,2,1760,0)=" ;Merge - can't ACCEPT the entry if:"
^XMB(3.9,144657,2,1761,0)="""RTN"",""IBCNBAR"",287,0)"
^XMB(3.9,144657,2,1762,0)=" ;      Exp Date (#2.312,3) is NOT null;"
^XMB(3.9,144657,2,1763,0)="""RTN"",""IBCNBAR"",288,0)"
^XMB(3.9,144657,2,1764,0)=" ;      AND Eff Date (#2.312,8) is null;"
^XMB(3.9,144657,2,1765,0)="""RTN"",""IBCNBAR"",289,0)"
^XMB(3.9,144657,2,1766,0)=" ;      AND Eff Date (#355.33,60.02) > Exp Date (#2.312,3);"
^XMB(3.9,144657,2,1767,0)="""RTN"",""IBCNBAR"",290,0)"
^XMB(3.9,144657,2,1768,0)=" ;      AND Exp Date (#355.33,60.03) is null"
^XMB(3.9,144657,2,1769,0)="""RTN"",""IBCNBAR"",291,0)"
^XMB(3.9,144657,2,1770,0)=" ;"
^XMB(3.9,144657,2,1771,0)="""RTN"",""IBCNBAR"",292,0)"
^XMB(3.9,144657,2,1772,0)=" ;Individual - can't ACCEPT the entry if:"
^XMB(3.9,144657,2,1773,0)="""RTN"",""IBCNBAR"",293,0)"
^XMB(3.9,144657,2,1774,0)=" ;      Exp Date (#2.312,3) is NOT null;"
^XMB(3.9,144657,2,1775,0)="""RTN"",""IBCNBAR"",294,0)"
^XMB(3.9,144657,2,1776,0)=" ;      AND Eff Date (#355.33,60.02) > Exp Date (#2.312,3);"
^XMB(3.9,144657,2,1777,0)="""RTN"",""IBCNBAR"",295,0)"
^XMB(3.9,144657,2,1778,0)=" ;      AND User answered YES to Accept Eff Date (#355.33,60.02) - adds to ^TMP($J,""IB BUFFER SELECTED"",60.02);"
^XMB(3.9,144657,2,1779,0)="""RTN"",""IBCNBAR"",296,0)"
^XMB(3.9,144657,2,1780,0)=" ;      AND (User answered NO to Accept Exp Date (#355.33,60.03) OR (#355.33,60.03) is null)"
^XMB(3.9,144657,2,1781,0)="""RTN"",""IBCNBAR"",297,0)"
^XMB(3.9,144657,2,1782,0)=" ;"
^XMB(3.9,144657,2,1783,0)="""RTN"",""IBCNBAR"",298,0)"
^XMB(3.9,144657,2,1784,0)=" N ABORT,BUFEFFDT,BUFEXPDT,CHGEFFDT,CHGEXPDT,INSEFFDT,INSEXPDT"
^XMB(3.9,144657,2,1785,0)="""RTN"",""IBCNBAR"",299,0)"
^XMB(3.9,144657,2,1786,0)=" S ABORT=0"
^XMB(3.9,144657,2,1787,0)="""RTN"",""IBCNBAR"",300,0)"
^XMB(3.9,144657,2,1788,0)=" S BUFEFFDT=$$GET1^DIQ(355.33,IBBUFDA_"","",60.02,""I"")"
^XMB(3.9,144657,2,1789,0)="""RTN"",""IBCNBAR"",301,0)"
^XMB(3.9,144657,2,1790,0)=" S BUFEXPDT=$$GET1^DIQ(355.33,IBBUFDA_"","",60.03,""I"")"
^XMB(3.9,144657,2,1791,0)="""RTN"",""IBCNBAR"",302,0)"
^XMB(3.9,144657,2,1792,0)=" S INSEFFDT=$$GET1^DIQ(2.312,IBSIEN,8,""I"")"
^XMB(3.9,144657,2,1793,0)="""RTN"",""IBCNBAR"",303,0)"
^XMB(3.9,144657,2,1794,0)=" S INSEXPDT=$$GET1^DIQ(2.312,IBSIEN,3,""I"")"
^XMB(3.9,144657,2,1795,0)="""RTN"",""IBCNBAR"",304,0)"
^XMB(3.9,144657,2,1796,0)=" ;"
^XMB(3.9,144657,2,1797,0)="""RTN"",""IBCNBAR"",305,0)"
^XMB(3.9,144657,2,1798,0)=" ;Check Buffer Eff and Exp Date to ensure they are valid dates, if not abort processing"
^XMB(3.9,144657,2,1799,0)="""RTN"",""IBCNBAR"",306,0)"
^XMB(3.9,144657,2,1800,0)=" ; Abort processing if Buffer Eff Date is a """" (null) date"
^XMB(3.9,144657,2,1801,0)="""RTN"",""IBCNBAR"",307,0)"
^XMB(3.9,144657,2,1802,0)=" I $$VALIDDT^IBCNINSU(BUFEFFDT)<1 S ABORT=1 G EFFDTCHKQ"
^XMB(3.9,144657,2,1803,0)="""RTN"",""IBCNBAR"",308,0)"
^XMB(3.9,144657,2,1804,0)=" ; Allow the Buffer Exp Date to have a """" (null) date, this date is evaluated below"
^XMB(3.9,144657,2,1805,0)="""RTN"",""IBCNBAR"",309,0)"
^XMB(3.9,144657,2,1806,0)=" I $$VALIDDT^IBCNINSU(BUFEXPDT)<0 S ABORT=1 G EFFDTCHKQ"
^XMB(3.9,144657,2,1807,0)="""RTN"",""IBCNBAR"",310,0)"
^XMB(3.9,144657,2,1808,0)=" ;"
^XMB(3.9,144657,2,1809,0)="""RTN"",""IBCNBAR"",311,0)"
^XMB(3.9,144657,2,1810,0)=" I $G(IBSIEN)="""" G EFFDTCHKQ  ; buffer okay, can't corrupt existing policy as it's a new policy"
^XMB(3.9,144657,2,1811,0)="""RTN"",""IBCNBAR"",312,0)"
^XMB(3.9,144657,2,1812,0)=" I INSEXPDT="""" G EFFDTCHKQ    ; buffer entry okay to process"
^XMB(3.9,144657,2,1813,0)="""RTN"",""IBCNBAR"",313,0)"
^XMB(3.9,144657,2,1814,0)=" ;"
^XMB(3.9,144657,2,1815,0)="""RTN"",""IBCNBAR"",314,0)"
^XMB(3.9,144657,2,1816,0)=" ;   IBMVPOL = 1:Merge, 2:Overwrite, 3:Replace, 4:Individual "
^XMB(3.9,144657,2,1817,0)="""RTN"",""IBCNBAR"",315,0)"
^XMB(3.9,144657,2,1818,0)=" I IBMVPOL=2 I (BUFEXPDT="""")&(INSEXPDT'="""")&(BUFEFFDT>INSEXPDT) S ABORT=1 G EFFDTCHKQ"
^XMB(3.9,144657,2,1819,0)="""RTN"",""IBCNBAR"",316,0)"
^XMB(3.9,144657,2,1820,0)=" ;"
^XMB(3.9,144657,2,1821,0)="""RTN"",""IBCNBAR"",317,0)"
^XMB(3.9,144657,2,1822,0)=" I IBMVPOL=1 I INSEFFDT=""""&(BUFEFFDT>INSEXPDT)&(BUFEXPDT="""") S ABORT=1 G EFFDTCHKQ"
^XMB(3.9,144657,2,1823,0)="""RTN"",""IBCNBAR"",318,0)"
^XMB(3.9,144657,2,1824,0)=" ;"
^XMB(3.9,144657,2,1825,0)="""RTN"",""IBCNBAR"",319,0)"
^XMB(3.9,144657,2,1826,0)=" I IBMVPOL=4 D"
^XMB(3.9,144657,2,1827,0)="""RTN"",""IBCNBAR"",320,0)"
^XMB(3.9,144657,2,1828,0)=" . S CHGEFFDT=$D(^TMP($J,""IB BUFFER SELECTED"",60.02))  ; user wants to change the Effective Date"
^XMB(3.9,144657,2,1829,0)="""RTN"",""IBCNBAR"",321,0)"
^XMB(3.9,144657,2,1830,0)=" . S CHGEXPDT=$D(^TMP($J,""IB BUFFER SELECTED"",60.03))  ; user wants to change the Expiration Date"
^XMB(3.9,144657,2,1831,0)="""RTN"",""IBCNBAR"",322,0)"
^XMB(3.9,144657,2,1832,0)=" . I (BUFEFFDT>INSEXPDT)&(CHGEFFDT)&((CHGEXPDT="""")!(BUFEXPDT="""")) S ABORT=1"
^XMB(3.9,144657,2,1833,0)="""RTN"",""IBCNBAR"",323,0)"
^XMB(3.9,144657,2,1834,0)=" ;"
^XMB(3.9,144657,2,1835,0)="""RTN"",""IBCNBAR"",324,0)"
^XMB(3.9,144657,2,1836,0)="EFFDTCHKQ ;"
^XMB(3.9,144657,2,1837,0)="""RTN"",""IBCNBAR"",325,0)"
^XMB(3.9,144657,2,1838,0)=" Q ABORT"
^XMB(3.9,144657,2,1839,0)="""RTN"",""IBCNBLA"")"
^XMB(3.9,144657,2,1840,0)="0^21^B85179304"
^XMB(3.9,144657,2,1841,0)="""RTN"",""IBCNBLA"",1,0)"
^XMB(3.9,144657,2,1842,0)="IBCNBLA ;ALB/ARH - Ins Buffer: LM action calls ;1 Jun 97"
^XMB(3.9,144657,2,1843,0)="""RTN"",""IBCNBLA"",2,0)"
^XMB(3.9,144657,2,1844,0)=" ;;2.0;INTEGRATED BILLING;**82,149,153,184,271,416,506,601,737,806**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,1845,0)="""RTN"",""IBCNBLA"",3,0)"
^XMB(3.9,144657,2,1846,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,1847,0)="""RTN"",""IBCNBLA"",4,0)"
^XMB(3.9,144657,2,1848,0)=" ;"
^XMB(3.9,144657,2,1849,0)="""RTN"",""IBCNBLA"",5,0)"
^XMB(3.9,144657,2,1850,0)="NEWSCRN(TEMPLAT,TMPARR,IBBUFDA) ; open a new screen for a specific buffer entry, pass in LM template and the array to select from"
^XMB(3.9,144657,2,1851,0)="""RTN"",""IBCNBLA"",6,0)"
^XMB(3.9,144657,2,1852,0)=" ; if temp array is defined then user selects the buffer entry, otherwise use entry passed in"
^XMB(3.9,144657,2,1853,0)="""RTN"",""IBCNBLA"",7,0)"
^XMB(3.9,144657,2,1854,0)=" ;"
^XMB(3.9,144657,2,1855,0)="""RTN"",""IBCNBLA"",8,0)"
^XMB(3.9,144657,2,1856,0)=" I $G(TMPARR)'="""" N IBBUFDA S IBBUFDA=$$SEL(TMPARR)"
^XMB(3.9,144657,2,1857,0)="""RTN"",""IBCNBLA"",9,0)"
^XMB(3.9,144657,2,1858,0)=" I +$G(IBBUFDA),$G(TEMPLAT)'="""",+$$LOCK^IBCNBU1(IBBUFDA,1) D EN^VALM(TEMPLAT) D UNLOCK^IBCNBU1(IBBUFDA)"
^XMB(3.9,144657,2,1859,0)="""RTN"",""IBCNBLA"",10,0)"
^XMB(3.9,144657,2,1860,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,1861,0)="""RTN"",""IBCNBLA"",11,0)"
^XMB(3.9,144657,2,1862,0)=" Q"
^XMB(3.9,144657,2,1863,0)="""RTN"",""IBCNBLA"",12,0)"
^XMB(3.9,144657,2,1864,0)=" ;"
^XMB(3.9,144657,2,1865,0)="""RTN"",""IBCNBLA"",13,0)"
^XMB(3.9,144657,2,1866,0)="SEL(TMPARR) ; user selects one of the items from the list on the screen"
^XMB(3.9,144657,2,1867,0)="""RTN"",""IBCNBLA"",14,0)"
^XMB(3.9,144657,2,1868,0)=" ;"
^XMB(3.9,144657,2,1869,0)="""RTN"",""IBCNBLA"",15,0)"
^XMB(3.9,144657,2,1870,0)=" N VALMY,IBX,IBY,IBSELN S IBX="""""
^XMB(3.9,144657,2,1871,0)="""RTN"",""IBCNBLA"",16,0)"
^XMB(3.9,144657,2,1872,0)=" I $G(TMPARR)'="""",'$O(^TMP(TMPARR,$J,0)) D  G SELQ"
^XMB(3.9,144657,2,1873,0)="""RTN"",""IBCNBLA"",17,0)"
^XMB(3.9,144657,2,1874,0)=" . W !!,""There are no '"",$S($G(VALM(""ENTITY""))'="""":VALM(""ENTITY""),1:""record""),""s' to select."",! S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144657,2,1875,0)="""RTN"",""IBCNBLA"",18,0)"
^XMB(3.9,144657,2,1876,0)=" ;"
^XMB(3.9,144657,2,1877,0)="""RTN"",""IBCNBLA"",19,0)"
^XMB(3.9,144657,2,1878,0)=" D EN^VALM2($G(XQORNOD(0)),""OS"")"
^XMB(3.9,144657,2,1879,0)="""RTN"",""IBCNBLA"",20,0)"
^XMB(3.9,144657,2,1880,0)=" I $D(VALMY),$G(TMPARR)'="""" S IBSELN=0 F  S IBSELN=$O(VALMY(IBSELN)) Q:'IBSELN  D"
^XMB(3.9,144657,2,1881,0)="""RTN"",""IBCNBLA"",21,0)"
^XMB(3.9,144657,2,1882,0)=" . S IBX=$P($G(^TMP(TMPARR,$J,IBSELN)),U,2,99)"
^XMB(3.9,144657,2,1883,0)="""RTN"",""IBCNBLA"",22,0)"
^XMB(3.9,144657,2,1884,0)=" . ;"
^XMB(3.9,144657,2,1885,0)="""RTN"",""IBCNBLA"",23,0)"
^XMB(3.9,144657,2,1886,0)=" . I TMPARR=""IBCNBLLX"" S IBY=$P($G(^IBA(355.33,+IBX,0)),U,4) I IBY'=""E"" D  S IBX="""""
^XMB(3.9,144657,2,1887,0)="""RTN"",""IBCNBLA"",24,0)"
^XMB(3.9,144657,2,1888,0)=" .. W !!,"" >>> Selected entry has been "",$S(IBY=""A"":""ACCEPTED"",IBY=""R"":""REJECTED"",1:""UNKNOWN STATUS"")"
^XMB(3.9,144657,2,1889,0)="""RTN"",""IBCNBLA"",25,0)"
^XMB(3.9,144657,2,1890,0)=" .. W "" and may no longer be edited or modified."",! S DIR(0)=""E"" D ^DIR K DIR"
^XMB(3.9,144657,2,1891,0)="""RTN"",""IBCNBLA"",26,0)"
^XMB(3.9,144657,2,1892,0)=" ;"
^XMB(3.9,144657,2,1893,0)="""RTN"",""IBCNBLA"",27,0)"
^XMB(3.9,144657,2,1894,0)="SELQ Q IBX"
^XMB(3.9,144657,2,1895,0)="""RTN"",""IBCNBLA"",28,0)"
^XMB(3.9,144657,2,1896,0)=" ;"
^XMB(3.9,144657,2,1897,0)="""RTN"",""IBCNBLA"",29,0)"
^XMB(3.9,144657,2,1898,0)="PNXTSCRN(TEMPLAT,IBBUFDA) ; open a new screen for a buffer entry, rebuild the process screen on return since it may have changed"
^XMB(3.9,144657,2,1899,0)="""RTN"",""IBCNBLA"",30,0)"
^XMB(3.9,144657,2,1900,0)=" D NEWSCRN^IBCNBLA(TEMPLAT,"""",IBBUFDA)"
^XMB(3.9,144657,2,1901,0)="""RTN"",""IBCNBLA"",31,0)"
^XMB(3.9,144657,2,1902,0)=" D CLEAN^VALM10,INIT^IBCNBLP,HDR^IBCNBLP S VALMBCK=""R"""
^XMB(3.9,144657,2,1903,0)="""RTN"",""IBCNBLA"",32,0)"
^XMB(3.9,144657,2,1904,0)=" Q"
^XMB(3.9,144657,2,1905,0)="""RTN"",""IBCNBLA"",33,0)"
^XMB(3.9,144657,2,1906,0)=" ;"
^XMB(3.9,144657,2,1907,0)="""RTN"",""IBCNBLA"",34,0)"
^XMB(3.9,144657,2,1908,0)="LNXTSCRN(TEMPLAT,TMPARR,AVIEW) ; select entries from list to process/expand"
^XMB(3.9,144657,2,1909,0)="""RTN"",""IBCNBLA"",35,0)"
^XMB(3.9,144657,2,1910,0)=" ;"
^XMB(3.9,144657,2,1911,0)="""RTN"",""IBCNBLA"",36,0)"
^XMB(3.9,144657,2,1912,0)=" ; This procedure is called from the ListMan action protocols for"
^XMB(3.9,144657,2,1913,0)="""RTN"",""IBCNBLA"",37,0)"
^XMB(3.9,144657,2,1914,0)=" ; processing and expanding buffer entries."
^XMB(3.9,144657,2,1915,0)="""RTN"",""IBCNBLA"",38,0)"
^XMB(3.9,144657,2,1916,0)=" ;    TEMPLAT - list template name for associated action"
^XMB(3.9,144657,2,1917,0)="""RTN"",""IBCNBLA"",39,0)"
^XMB(3.9,144657,2,1918,0)=" ;    TMPARR  - subscript in scratch global"
^XMB(3.9,144657,2,1919,0)="""RTN"",""IBCNBLA"",40,0)"
^XMB(3.9,144657,2,1920,0)=" ;"
^XMB(3.9,144657,2,1921,0)="""RTN"",""IBCNBLA"",41,0)"
^XMB(3.9,144657,2,1922,0)=" NEW IBCNEZAR,IBCNEZEN,IBCNEZCT,IBCNEZGD,IBCNEZBF,IBCNEZQ,IBBUFDA"
^XMB(3.9,144657,2,1923,0)="""RTN"",""IBCNBLA"",42,0)"
^XMB(3.9,144657,2,1924,0)=" NEW ACT,REMAIN,DIR,X,Y,DIRUT,DTOUT,DUOUT,DIROUT"
^XMB(3.9,144657,2,1925,0)="""RTN"",""IBCNBLA"",43,0)"
^XMB(3.9,144657,2,1926,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,1927,0)="""RTN"",""IBCNBLA"",44,0)"
^XMB(3.9,144657,2,1928,0)=" D MULSEL^IBCNBLA2(TMPARR,.IBCNEZAR,.IBCNEZGD)"
^XMB(3.9,144657,2,1929,0)="""RTN"",""IBCNBLA"",45,0)"
^XMB(3.9,144657,2,1930,0)=" I '$D(IBCNEZAR) G LNXTX"
^XMB(3.9,144657,2,1931,0)="""RTN"",""IBCNBLA"",46,0)"
^XMB(3.9,144657,2,1932,0)=" ;"
^XMB(3.9,144657,2,1933,0)="""RTN"",""IBCNBLA"",47,0)"
^XMB(3.9,144657,2,1934,0)=" ; loop through the list of selected buffer entries"
^XMB(3.9,144657,2,1935,0)="""RTN"",""IBCNBLA"",48,0)"
^XMB(3.9,144657,2,1936,0)=" S IBCNEZEN=0,IBCNEZCT=0"
^XMB(3.9,144657,2,1937,0)="""RTN"",""IBCNBLA"",49,0)"
^XMB(3.9,144657,2,1938,0)=" F  S IBCNEZEN=$O(IBCNEZAR(IBCNEZEN)) Q:'IBCNEZEN  D"
^XMB(3.9,144657,2,1939,0)="""RTN"",""IBCNBLA"",50,0)"
^XMB(3.9,144657,2,1940,0)=" . I 'IBCNEZAR(IBCNEZEN) Q      ; user could not get this one"
^XMB(3.9,144657,2,1941,0)="""RTN"",""IBCNBLA"",51,0)"
^XMB(3.9,144657,2,1942,0)=" . S IBCNEZBF=$P(IBCNEZAR(IBCNEZEN),U,3)    ; buffer ien"
^XMB(3.9,144657,2,1943,0)="""RTN"",""IBCNBLA"",52,0)"
^XMB(3.9,144657,2,1944,0)=" . S IBBUFDA=IBCNEZBF           ; just in case IB rtns need this"
^XMB(3.9,144657,2,1945,0)="""RTN"",""IBCNBLA"",53,0)"
^XMB(3.9,144657,2,1946,0)=" . S IBCNEZCT=IBCNEZCT+1"
^XMB(3.9,144657,2,1947,0)="""RTN"",""IBCNBLA"",54,0)"
^XMB(3.9,144657,2,1948,0)=" . I '$D(IBCNEZQ) D"
^XMB(3.9,144657,2,1949,0)="""RTN"",""IBCNBLA"",55,0)"
^XMB(3.9,144657,2,1950,0)=" .. D EN^VALM(TEMPLAT)                      ; invoke list template"
^XMB(3.9,144657,2,1951,0)="""RTN"",""IBCNBLA"",56,0)"
^XMB(3.9,144657,2,1952,0)=" .. I $G(IBFASTXT) S IBCNEZQ=1 Q            ; Fast Exit processing"
^XMB(3.9,144657,2,1953,0)="""RTN"",""IBCNBLA"",57,0)"
^XMB(3.9,144657,2,1954,0)=" .. S ACT=""expand"""
^XMB(3.9,144657,2,1955,0)="""RTN"",""IBCNBLA"",58,0)"
^XMB(3.9,144657,2,1956,0)=" .. I TEMPLAT[""PROCESS"" S ACT=""process"""
^XMB(3.9,144657,2,1957,0)="""RTN"",""IBCNBLA"",59,0)"
^XMB(3.9,144657,2,1958,0)=" .. S REMAIN=IBCNEZGD-IBCNEZCT"
^XMB(3.9,144657,2,1959,0)="""RTN"",""IBCNBLA"",60,0)"
^XMB(3.9,144657,2,1960,0)=" .. I 'REMAIN Q"
^XMB(3.9,144657,2,1961,0)="""RTN"",""IBCNBLA"",61,0)"
^XMB(3.9,144657,2,1962,0)=" .. W @IOF"
^XMB(3.9,144657,2,1963,0)="""RTN"",""IBCNBLA"",62,0)"
^XMB(3.9,144657,2,1964,0)=" .. W !!!,""You are "",ACT,""ing multiple insurance buffer entries."""
^XMB(3.9,144657,2,1965,0)="""RTN"",""IBCNBLA"",63,0)"
^XMB(3.9,144657,2,1966,0)=" .. W !,""You just completed entry number "",IBCNEZEN,""  ("",IBCNEZCT,"" of "",IBCNEZGD,"")."""
^XMB(3.9,144657,2,1967,0)="""RTN"",""IBCNBLA"",64,0)"
^XMB(3.9,144657,2,1968,0)=" .. S DIR(0)=""Y"""
^XMB(3.9,144657,2,1969,0)="""RTN"",""IBCNBLA"",65,0)"
^XMB(3.9,144657,2,1970,0)=" .. S DIR(""A"")=""Do you want to ""_ACT_"" the remaining entry"""
^XMB(3.9,144657,2,1971,0)="""RTN"",""IBCNBLA"",66,0)"
^XMB(3.9,144657,2,1972,0)=" .. I REMAIN>1 S DIR(""A"")=""Do you want to ""_ACT_"" the remaining ""_REMAIN_"" entries"""
^XMB(3.9,144657,2,1973,0)="""RTN"",""IBCNBLA"",67,0)"
^XMB(3.9,144657,2,1974,0)=" .. S DIR(""B"")=""YES"""
^XMB(3.9,144657,2,1975,0)="""RTN"",""IBCNBLA"",68,0)"
^XMB(3.9,144657,2,1976,0)=" .. W ! D ^DIR K DIR"
^XMB(3.9,144657,2,1977,0)="""RTN"",""IBCNBLA"",69,0)"
^XMB(3.9,144657,2,1978,0)=" .. I 'Y S IBCNEZQ=1       ; User said NO so set the Quitting variable"
^XMB(3.9,144657,2,1979,0)="""RTN"",""IBCNBLA"",70,0)"
^XMB(3.9,144657,2,1980,0)=" .. Q"
^XMB(3.9,144657,2,1981,0)="""RTN"",""IBCNBLA"",71,0)"
^XMB(3.9,144657,2,1982,0)=" . ;"
^XMB(3.9,144657,2,1983,0)="""RTN"",""IBCNBLA"",72,0)"
^XMB(3.9,144657,2,1984,0)=" . ; Make sure to unlock the buffer entry in all cases when finished,"
^XMB(3.9,144657,2,1985,0)="""RTN"",""IBCNBLA"",73,0)"
^XMB(3.9,144657,2,1986,0)=" . ; even if the user wants to quit out of this loop"
^XMB(3.9,144657,2,1987,0)="""RTN"",""IBCNBLA"",74,0)"
^XMB(3.9,144657,2,1988,0)=" . D UNLOCK^IBCNBU1(IBCNEZBF)"
^XMB(3.9,144657,2,1989,0)="""RTN"",""IBCNBLA"",75,0)"
^XMB(3.9,144657,2,1990,0)=" . Q"
^XMB(3.9,144657,2,1991,0)="""RTN"",""IBCNBLA"",76,0)"
^XMB(3.9,144657,2,1992,0)="LNXTX ;"
^XMB(3.9,144657,2,1993,0)="""RTN"",""IBCNBLA"",77,0)"
^XMB(3.9,144657,2,1994,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,1995,0)="""RTN"",""IBCNBLA"",78,0)"
^XMB(3.9,144657,2,1996,0)=" Q"
^XMB(3.9,144657,2,1997,0)="""RTN"",""IBCNBLA"",79,0)"
^XMB(3.9,144657,2,1998,0)=" ;"
^XMB(3.9,144657,2,1999,0)="""RTN"",""IBCNBLA"",80,0)"
^XMB(3.9,144657,2,2000,0)="LREJECT(TMPARR) ; user select entries from list then reject/delete them"
^XMB(3.9,144657,2,2001,0)="""RTN"",""IBCNBLA"",81,0)"
^XMB(3.9,144657,2,2002,0)=" ;"
^XMB(3.9,144657,2,2003,0)="""RTN"",""IBCNBLA"",82,0)"
^XMB(3.9,144657,2,2004,0)=" ; This procedure is called from the ListMan action protocol for"
^XMB(3.9,144657,2,2005,0)="""RTN"",""IBCNBLA"",83,0)"
^XMB(3.9,144657,2,2006,0)=" ; rejecting buffer entries."
^XMB(3.9,144657,2,2007,0)="""RTN"",""IBCNBLA"",84,0)"
^XMB(3.9,144657,2,2008,0)=" ;    TMPARR  - subscript in scratch global"
^XMB(3.9,144657,2,2009,0)="""RTN"",""IBCNBLA"",85,0)"
^XMB(3.9,144657,2,2010,0)=" ;"
^XMB(3.9,144657,2,2011,0)="""RTN"",""IBCNBLA"",86,0)"
^XMB(3.9,144657,2,2012,0)=" NEW IBCNEZAR,IBCNEZEN,IBCNEZCT,IBCNEZGD,IBCNEZBF,IBCNEZQ,IBBUFDA"
^XMB(3.9,144657,2,2013,0)="""RTN"",""IBCNBLA"",87,0)"
^XMB(3.9,144657,2,2014,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,2015,0)="""RTN"",""IBCNBLA"",88,0)"
^XMB(3.9,144657,2,2016,0)=" D MULSEL^IBCNBLA2(TMPARR,.IBCNEZAR,.IBCNEZGD)"
^XMB(3.9,144657,2,2017,0)="""RTN"",""IBCNBLA"",89,0)"
^XMB(3.9,144657,2,2018,0)=" I '$D(IBCNEZAR) G LREJX"
^XMB(3.9,144657,2,2019,0)="""RTN"",""IBCNBLA"",90,0)"
^XMB(3.9,144657,2,2020,0)=" ;"
^XMB(3.9,144657,2,2021,0)="""RTN"",""IBCNBLA"",91,0)"
^XMB(3.9,144657,2,2022,0)=" ; loop through the list of selected buffer entries"
^XMB(3.9,144657,2,2023,0)="""RTN"",""IBCNBLA"",92,0)"
^XMB(3.9,144657,2,2024,0)=" S IBCNEZEN=0,IBCNEZCT=0"
^XMB(3.9,144657,2,2025,0)="""RTN"",""IBCNBLA"",93,0)"
^XMB(3.9,144657,2,2026,0)=" F  S IBCNEZEN=$O(IBCNEZAR(IBCNEZEN)) Q:'IBCNEZEN  D"
^XMB(3.9,144657,2,2027,0)="""RTN"",""IBCNBLA"",94,0)"
^XMB(3.9,144657,2,2028,0)=" . I 'IBCNEZAR(IBCNEZEN) Q      ; user could not get this one"
^XMB(3.9,144657,2,2029,0)="""RTN"",""IBCNBLA"",95,0)"
^XMB(3.9,144657,2,2030,0)=" . S IBCNEZBF=$P(IBCNEZAR(IBCNEZEN),U,3)"
^XMB(3.9,144657,2,2031,0)="""RTN"",""IBCNBLA"",96,0)"
^XMB(3.9,144657,2,2032,0)=" . S IBBUFDA=IBCNEZBF           ; just in case IB rtns need this"
^XMB(3.9,144657,2,2033,0)="""RTN"",""IBCNBLA"",97,0)"
^XMB(3.9,144657,2,2034,0)=" . S IBCNEZCT=IBCNEZCT+1"
^XMB(3.9,144657,2,2035,0)="""RTN"",""IBCNBLA"",98,0)"
^XMB(3.9,144657,2,2036,0)=" . I '$D(IBCNEZQ) D"
^XMB(3.9,144657,2,2037,0)="""RTN"",""IBCNBLA"",99,0)"
^XMB(3.9,144657,2,2038,0)=" .. W @IOF,!?2,$G(IORVON)"
^XMB(3.9,144657,2,2039,0)="""RTN"",""IBCNBLA"",100,0)"
^XMB(3.9,144657,2,2040,0)=" .. W "" Entry "",IBCNEZEN,""  ("",IBCNEZCT,"" of "",IBCNEZGD,"") """
^XMB(3.9,144657,2,2041,0)="""RTN"",""IBCNBLA"",101,0)"
^XMB(3.9,144657,2,2042,0)=" .. W $G(IORVOFF)"
^XMB(3.9,144657,2,2043,0)="""RTN"",""IBCNBLA"",102,0)"
^XMB(3.9,144657,2,2044,0)=" .. D REJECT^IBCNBLA1(IBCNEZBF,.IBCNEZQ)"
^XMB(3.9,144657,2,2045,0)="""RTN"",""IBCNBLA"",103,0)"
^XMB(3.9,144657,2,2046,0)=" .. ;"
^XMB(3.9,144657,2,2047,0)="""RTN"",""IBCNBLA"",104,0)"
^XMB(3.9,144657,2,2048,0)=" .. ; If the user wants to stop and we're not processing the last one,"
^XMB(3.9,144657,2,2049,0)="""RTN"",""IBCNBLA"",105,0)"
^XMB(3.9,144657,2,2050,0)=" .. ; then determine if we should process the remaining entries"
^XMB(3.9,144657,2,2051,0)="""RTN"",""IBCNBLA"",106,0)"
^XMB(3.9,144657,2,2052,0)=" .. ;"
^XMB(3.9,144657,2,2053,0)="""RTN"",""IBCNBLA"",107,0)"
^XMB(3.9,144657,2,2054,0)=" .. I $D(IBCNEZQ),IBCNEZCT<IBCNEZGD D"
^XMB(3.9,144657,2,2055,0)="""RTN"",""IBCNBLA"",108,0)"
^XMB(3.9,144657,2,2056,0)=" ... NEW REMAIN,DIR,X,Y,DTOUT,DUOUT,DIRUT,DIROUT"
^XMB(3.9,144657,2,2057,0)="""RTN"",""IBCNBLA"",109,0)"
^XMB(3.9,144657,2,2058,0)=" ... S REMAIN=IBCNEZGD-IBCNEZCT"
^XMB(3.9,144657,2,2059,0)="""RTN"",""IBCNBLA"",110,0)"
^XMB(3.9,144657,2,2060,0)=" ... S DIR(0)=""Y"""
^XMB(3.9,144657,2,2061,0)="""RTN"",""IBCNBLA"",111,0)"
^XMB(3.9,144657,2,2062,0)=" ... S DIR(""A"")=""Do you want to process the remaining entry"""
^XMB(3.9,144657,2,2063,0)="""RTN"",""IBCNBLA"",112,0)"
^XMB(3.9,144657,2,2064,0)=" ... I REMAIN>1 S DIR(""A"")=""Do you want to process the remaining ""_REMAIN_"" entries"""
^XMB(3.9,144657,2,2065,0)="""RTN"",""IBCNBLA"",113,0)"
^XMB(3.9,144657,2,2066,0)=" ... S DIR(""B"")=""NO"""
^XMB(3.9,144657,2,2067,0)="""RTN"",""IBCNBLA"",114,0)"
^XMB(3.9,144657,2,2068,0)=" ... W ! D ^DIR K DIR"
^XMB(3.9,144657,2,2069,0)="""RTN"",""IBCNBLA"",115,0)"
^XMB(3.9,144657,2,2070,0)=" ... ; if user wants to continue, then kill the quitting variable"
^XMB(3.9,144657,2,2071,0)="""RTN"",""IBCNBLA"",116,0)"
^XMB(3.9,144657,2,2072,0)=" ... I Y KILL IBCNEZQ"
^XMB(3.9,144657,2,2073,0)="""RTN"",""IBCNBLA"",117,0)"
^XMB(3.9,144657,2,2074,0)=" ... Q"
^XMB(3.9,144657,2,2075,0)="""RTN"",""IBCNBLA"",118,0)"
^XMB(3.9,144657,2,2076,0)=" .. Q"
^XMB(3.9,144657,2,2077,0)="""RTN"",""IBCNBLA"",119,0)"
^XMB(3.9,144657,2,2078,0)=" . ;"
^XMB(3.9,144657,2,2079,0)="""RTN"",""IBCNBLA"",120,0)"
^XMB(3.9,144657,2,2080,0)=" . ; Make sure to unlock the buffer entry in all cases when finished,"
^XMB(3.9,144657,2,2081,0)="""RTN"",""IBCNBLA"",121,0)"
^XMB(3.9,144657,2,2082,0)=" . ; even if the user wants to quit out of this loop"
^XMB(3.9,144657,2,2083,0)="""RTN"",""IBCNBLA"",122,0)"
^XMB(3.9,144657,2,2084,0)=" . D UNLOCK^IBCNBU1(IBCNEZBF)"
^XMB(3.9,144657,2,2085,0)="""RTN"",""IBCNBLA"",123,0)"
^XMB(3.9,144657,2,2086,0)=" . Q"
^XMB(3.9,144657,2,2087,0)="""RTN"",""IBCNBLA"",124,0)"
^XMB(3.9,144657,2,2088,0)="LREJX ;"
^XMB(3.9,144657,2,2089,0)="""RTN"",""IBCNBLA"",125,0)"
^XMB(3.9,144657,2,2090,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,2091,0)="""RTN"",""IBCNBLA"",126,0)"
^XMB(3.9,144657,2,2092,0)=" Q"
^XMB(3.9,144657,2,2093,0)="""RTN"",""IBCNBLA"",127,0)"
^XMB(3.9,144657,2,2094,0)=" ;"
^XMB(3.9,144657,2,2095,0)="""RTN"",""IBCNBLA"",128,0)"
^XMB(3.9,144657,2,2096,0)=" ;"
^XMB(3.9,144657,2,2097,0)="""RTN"",""IBCNBLA"",129,0)"
^XMB(3.9,144657,2,2098,0)="FASTEXIT ; sets flag signaling system should be exited"
^XMB(3.9,144657,2,2099,0)="""RTN"",""IBCNBLA"",130,0)"
^XMB(3.9,144657,2,2100,0)=" N DIR,DIRUT,X,Y"
^XMB(3.9,144657,2,2101,0)="""RTN"",""IBCNBLA"",131,0)"
^XMB(3.9,144657,2,2102,0)=" S VALMBCK=""Q"""
^XMB(3.9,144657,2,2103,0)="""RTN"",""IBCNBLA"",132,0)"
^XMB(3.9,144657,2,2104,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,2105,0)="""RTN"",""IBCNBLA"",133,0)"
^XMB(3.9,144657,2,2106,0)=" S DIR(0)=""Y"",DIR(""A"")=""Exit option entirely"",DIR(""B"")=""NO"" D ^DIR"
^XMB(3.9,144657,2,2107,0)="""RTN"",""IBCNBLA"",134,0)"
^XMB(3.9,144657,2,2108,0)=" I +Y S IBFASTXT=1"
^XMB(3.9,144657,2,2109,0)="""RTN"",""IBCNBLA"",135,0)"
^XMB(3.9,144657,2,2110,0)=" Q"
^XMB(3.9,144657,2,2111,0)="""RTN"",""IBCNBLA"",136,0)"
^XMB(3.9,144657,2,2112,0)=" ;"
^XMB(3.9,144657,2,2113,0)="""RTN"",""IBCNBLA"",137,0)"
^XMB(3.9,144657,2,2114,0)="SELSORT ;  select the way to sort the list screen"
^XMB(3.9,144657,2,2115,0)="""RTN"",""IBCNBLA"",138,0)"
^XMB(3.9,144657,2,2116,0)=" N DIR,DIRUT,X,Y,DTOUT,DUOUT,DIROUT,ST,STDES"
^XMB(3.9,144657,2,2117,0)="""RTN"",""IBCNBLA"",139,0)"
^XMB(3.9,144657,2,2118,0)=" ;"
^XMB(3.9,144657,2,2119,0)="""RTN"",""IBCNBLA"",140,0)"
^XMB(3.9,144657,2,2120,0)=" D FULL^VALM1 W !"
^XMB(3.9,144657,2,2121,0)="""RTN"",""IBCNBLA"",141,0)"
^XMB(3.9,144657,2,2122,0)=" W !,""Select the item to sort the buffer records on the buffer list screen."""
^XMB(3.9,144657,2,2123,0)="""RTN"",""IBCNBLA"",142,0)"
^XMB(3.9,144657,2,2124,0)=" ; IB*2*737/DTG remove verify action reference"
^XMB(3.9,144657,2,2125,0)="""RTN"",""IBCNBLA"",143,0)"
^XMB(3.9,144657,2,2126,0)=" ; S DIR(0)=""SO^1:Patient Name;2:Insurance Company;3:Source of Information;4:Date Entered;5:Inpatients;6:Means Test;7:On Hold;8:Verified;9:eIV Status;10:Positive Response"""
^XMB(3.9,144657,2,2127,0)="""RTN"",""IBCNBLA"",144,0)"
^XMB(3.9,144657,2,2128,0)=" ;IB*806/DTG add 'P' potential new policy to sort"
^XMB(3.9,144657,2,2129,0)="""RTN"",""IBCNBLA"",145,0)"
^XMB(3.9,144657,2,2130,0)=" ;S DIR(0)=""SO^1:Patient Name;2:Insurance Company;3:Source of Information;4:Date Entered;5:Inpatients;6:Means Test;7:On Hold;8:eIV Status;9:Positive Response"""
^XMB(3.9,144657,2,2131,0)="""RTN"",""IBCNBLA"",146,0)"
^XMB(3.9,144657,2,2132,0)=" S DIR(0)=""SO^1:Patient Name;2:Insurance Company;3:Source of Information;4:Date Entered;"""
^XMB(3.9,144657,2,2133,0)="""RTN"",""IBCNBLA"",147,0)"
^XMB(3.9,144657,2,2134,0)=" S DIR(0)=DIR(0)_""5:Inpatients;6:Means Test;7:On Hold;8:eIV Status;9:Positive Response;10:Potential new policy"""
^XMB(3.9,144657,2,2135,0)="""RTN"",""IBCNBLA"",148,0)"
^XMB(3.9,144657,2,2136,0)=" S DIR(""A"")=""Sort the list by"",DIR(""B"")=$P($G(IBCNSORT),""^"",2)"
^XMB(3.9,144657,2,2137,0)="""RTN"",""IBCNBLA"",149,0)"
^XMB(3.9,144657,2,2138,0)=" D ^DIR K DIR"
^XMB(3.9,144657,2,2139,0)="""RTN"",""IBCNBLA"",150,0)"
^XMB(3.9,144657,2,2140,0)=" I 'Y G SELSORTX"
^XMB(3.9,144657,2,2141,0)="""RTN"",""IBCNBLA"",151,0)"
^XMB(3.9,144657,2,2142,0)=" S IBCNSORT=Y_""^""_Y(0)"
^XMB(3.9,144657,2,2143,0)="""RTN"",""IBCNBLA"",152,0)"
^XMB(3.9,144657,2,2144,0)=" ;"
^XMB(3.9,144657,2,2145,0)="""RTN"",""IBCNBLA"",153,0)"
^XMB(3.9,144657,2,2146,0)=" ; ESG - 6/7/02 - SDD 5.1.1"
^XMB(3.9,144657,2,2147,0)="""RTN"",""IBCNBLA"",154,0)"
^XMB(3.9,144657,2,2148,0)=" ; If the user wants to sort by symbol, then ask them which"
^XMB(3.9,144657,2,2149,0)="""RTN"",""IBCNBLA"",155,0)"
^XMB(3.9,144657,2,2150,0)=" ; symbol should appear first and process accordingly."
^XMB(3.9,144657,2,2151,0)="""RTN"",""IBCNBLA"",156,0)"
^XMB(3.9,144657,2,2152,0)=" ;"
^XMB(3.9,144657,2,2153,0)="""RTN"",""IBCNBLA"",157,0)"
^XMB(3.9,144657,2,2154,0)=" KILL IBCNSORT(1)       ; initialize the symbol sort array"
^XMB(3.9,144657,2,2155,0)="""RTN"",""IBCNBLA"",158,0)"
^XMB(3.9,144657,2,2156,0)=" ; I +IBCNSORT=9 D  I $D(DIRUT)!('Y) G SELSORTX"
^XMB(3.9,144657,2,2157,0)="""RTN"",""IBCNBLA"",159,0)"
^XMB(3.9,144657,2,2158,0)=" I +IBCNSORT=8 D  I $D(DIRUT)!('Y) G SELSORTX  ; IB*2*737"
^XMB(3.9,144657,2,2159,0)="""RTN"",""IBCNBLA"",160,0)"
^XMB(3.9,144657,2,2160,0)=" . ;"
^XMB(3.9,144657,2,2161,0)="""RTN"",""IBCNBLA"",161,0)"
^XMB(3.9,144657,2,2162,0)=" . ; build the array of default sort order"
^XMB(3.9,144657,2,2163,0)="""RTN"",""IBCNBLA"",162,0)"
^XMB(3.9,144657,2,2164,0)=" . S IBCNSORT(1,""+"")=10"
^XMB(3.9,144657,2,2165,0)="""RTN"",""IBCNBLA"",163,0)"
^XMB(3.9,144657,2,2166,0)=" . S IBCNSORT(1,""$"")=15 ; Added dollar sign to sort criteria"
^XMB(3.9,144657,2,2167,0)="""RTN"",""IBCNBLA"",164,0)"
^XMB(3.9,144657,2,2168,0)=" . S IBCNSORT(1,""%"")=18 ; IB*2*601/DM added %"
^XMB(3.9,144657,2,2169,0)="""RTN"",""IBCNBLA"",165,0)"
^XMB(3.9,144657,2,2170,0)=" . S IBCNSORT(1,""-"")=20"
^XMB(3.9,144657,2,2171,0)="""RTN"",""IBCNBLA"",166,0)"
^XMB(3.9,144657,2,2172,0)=" . S IBCNSORT(1,""#"")=25 ; Added pound to sort criteria"
^XMB(3.9,144657,2,2173,0)="""RTN"",""IBCNBLA"",167,0)"
^XMB(3.9,144657,2,2174,0)=" . S IBCNSORT(1,""!"")=30"
^XMB(3.9,144657,2,2175,0)="""RTN"",""IBCNBLA"",168,0)"
^XMB(3.9,144657,2,2176,0)=" . S IBCNSORT(1,"" "")=40"
^XMB(3.9,144657,2,2177,0)="""RTN"",""IBCNBLA"",169,0)"
^XMB(3.9,144657,2,2178,0)=" . S IBCNSORT(1,""?"")=50"
^XMB(3.9,144657,2,2179,0)="""RTN"",""IBCNBLA"",170,0)"
^XMB(3.9,144657,2,2180,0)=" . ; S IBCNSORT(1,""*"")=60  ; IB*2*737 drop *"
^XMB(3.9,144657,2,2181,0)="""RTN"",""IBCNBLA"",171,0)"
^XMB(3.9,144657,2,2182,0)=" . ;"
^XMB(3.9,144657,2,2183,0)="""RTN"",""IBCNBLA"",172,0)"
^XMB(3.9,144657,2,2184,0)=" . ; build the DIR array to ask the question"
^XMB(3.9,144657,2,2185,0)="""RTN"",""IBCNBLA"",173,0)"
^XMB(3.9,144657,2,2186,0)=" . S DIR(0)=""SO^"""
^XMB(3.9,144657,2,2187,0)="""RTN"",""IBCNBLA"",174,0)"
^XMB(3.9,144657,2,2188,0)=" . ; removed blanks ; replaced tilde w/apostrophe and added pound as option 3, IB*506 added $ as option 2 and adjusted all following."
^XMB(3.9,144657,2,2189,0)="""RTN"",""IBCNBLA"",175,0)"
^XMB(3.9,144657,2,2190,0)=" . ; IB*2*601/DM added % as option 3 and adjusted all following."
^XMB(3.9,144657,2,2191,0)="""RTN"",""IBCNBLA"",176,0)"
^XMB(3.9,144657,2,2192,0)=" . F ST=""1:+'A1"",""2:$'E1"",""3:%'M1"",""4:-'D1"",""5:#'U1"",""6:!'B1"",""7: '"",""8:?'Q1"" D"
^XMB(3.9,144657,2,2193,0)="""RTN"",""IBCNBLA"",177,0)"
^XMB(3.9,144657,2,2194,0)=" .. I ST=""7: '"" S STDES=""No Problems Identified, Awaiting Electronic Processing"" ; removed blanks"
^XMB(3.9,144657,2,2195,0)="""RTN"",""IBCNBLA"",178,0)"
^XMB(3.9,144657,2,2196,0)=" .. E  S STDES=$$GET1^DIQ(365.15,$$FIND1^DIC(365.15,"""",""X"",$P(ST,""'"",2)),.01,""E"")"
^XMB(3.9,144657,2,2197,0)="""RTN"",""IBCNBLA"",179,0)"
^XMB(3.9,144657,2,2198,0)=" .. S DIR(0)=DIR(0)_$P(ST,""'"")_""  ""_STDES_$S(ST=""7:?'Q1"":"""",1:"";"")"
^XMB(3.9,144657,2,2199,0)="""RTN"",""IBCNBLA"",180,0)"
^XMB(3.9,144657,2,2200,0)=" . S DIR(""A"")=""Which eIV Status do you want to appear first?"""
^XMB(3.9,144657,2,2201,0)="""RTN"",""IBCNBLA"",181,0)"
^XMB(3.9,144657,2,2202,0)=" . S DIR(""B"")=1"
^XMB(3.9,144657,2,2203,0)="""RTN"",""IBCNBLA"",182,0)"
^XMB(3.9,144657,2,2204,0)=" . S DIR(""?"",1)="" Please identify the eIV status that you want to appear first in the Insurance"""
^XMB(3.9,144657,2,2205,0)="""RTN"",""IBCNBLA"",183,0)"
^XMB(3.9,144657,2,2206,0)=" . S DIR(""?"",2)="" Buffer listing.  The symbol appears immediately to the left of the patient"""
^XMB(3.9,144657,2,2207,0)="""RTN"",""IBCNBLA"",184,0)"
^XMB(3.9,144657,2,2208,0)=" . S DIR(""?"",3)="" name in the list.  The default sort order for statuses is the same as"""
^XMB(3.9,144657,2,2209,0)="""RTN"",""IBCNBLA"",185,0)"
^XMB(3.9,144657,2,2210,0)=" . S DIR(""?"",4)="" they are presented in this list below.  You may choose which status will appear"""
^XMB(3.9,144657,2,2211,0)="""RTN"",""IBCNBLA"",186,0)"
^XMB(3.9,144657,2,2212,0)=" . S DIR(""?"",5)="" first in the list.  The remaining statuses will be sorted according to this"""
^XMB(3.9,144657,2,2213,0)="""RTN"",""IBCNBLA"",187,0)"
^XMB(3.9,144657,2,2214,0)=" . S DIR(""?"",6)="" default sort order.  When sorting by eIV status, the secondary sort"""
^XMB(3.9,144657,2,2215,0)="""RTN"",""IBCNBLA"",188,0)"
^XMB(3.9,144657,2,2216,0)=" . S DIR(""?"",7)="" is the entered date and the final sort is by patient name."""
^XMB(3.9,144657,2,2217,0)="""RTN"",""IBCNBLA"",189,0)"
^XMB(3.9,144657,2,2218,0)=" . S DIR(""?"")="" """
^XMB(3.9,144657,2,2219,0)="""RTN"",""IBCNBLA"",190,0)"
^XMB(3.9,144657,2,2220,0)=" . D ^DIR K DIR"
^XMB(3.9,144657,2,2221,0)="""RTN"",""IBCNBLA"",191,0)"
^XMB(3.9,144657,2,2222,0)=" . I $D(DIRUT) Q"
^XMB(3.9,144657,2,2223,0)="""RTN"",""IBCNBLA"",192,0)"
^XMB(3.9,144657,2,2224,0)=" . I 'Y Q"
^XMB(3.9,144657,2,2225,0)="""RTN"",""IBCNBLA"",193,0)"
^XMB(3.9,144657,2,2226,0)=" . ;"
^XMB(3.9,144657,2,2227,0)="""RTN"",""IBCNBLA"",194,0)"
^XMB(3.9,144657,2,2228,0)=" . ; update the sort order array with the chosen symbol"
^XMB(3.9,144657,2,2229,0)="""RTN"",""IBCNBLA"",195,0)"
^XMB(3.9,144657,2,2230,0)=" . S IBCNSORT(1,$E(Y(0)))=1"
^XMB(3.9,144657,2,2231,0)="""RTN"",""IBCNBLA"",196,0)"
^XMB(3.9,144657,2,2232,0)=" . S $P(IBCNSORT,U,3)=$E(Y(0))"
^XMB(3.9,144657,2,2233,0)="""RTN"",""IBCNBLA"",197,0)"
^XMB(3.9,144657,2,2234,0)=" . Q"
^XMB(3.9,144657,2,2235,0)="""RTN"",""IBCNBLA"",198,0)"
^XMB(3.9,144657,2,2236,0)=" ;"
^XMB(3.9,144657,2,2237,0)="""RTN"",""IBCNBLA"",199,0)"
^XMB(3.9,144657,2,2238,0)=" ; rebuild and resort the list and update the list header"
^XMB(3.9,144657,2,2239,0)="""RTN"",""IBCNBLA"",200,0)"
^XMB(3.9,144657,2,2240,0)=" D INIT^IBCNBLL,HDR^IBCNBLL"
^XMB(3.9,144657,2,2241,0)="""RTN"",""IBCNBLA"",201,0)"
^XMB(3.9,144657,2,2242,0)=" ;"
^XMB(3.9,144657,2,2243,0)="""RTN"",""IBCNBLA"",202,0)"
^XMB(3.9,144657,2,2244,0)="SELSORTX ;"
^XMB(3.9,144657,2,2245,0)="""RTN"",""IBCNBLA"",203,0)"
^XMB(3.9,144657,2,2246,0)=" S VALMBCK=""R"",VALMBG=1"
^XMB(3.9,144657,2,2247,0)="""RTN"",""IBCNBLA"",204,0)"
^XMB(3.9,144657,2,2248,0)=" Q"
^XMB(3.9,144657,2,2249,0)="""RTN"",""IBCNBLA"",205,0)"
^XMB(3.9,144657,2,2250,0)=" ;"
^XMB(3.9,144657,2,2251,0)="""RTN"",""IBCNBLA"",206,0)"
^XMB(3.9,144657,2,2252,0)="TGLSCRN(IBBUFDA) ; toggle process screen from policy to insurance info, glbal variable IBCNSCRN contains ins co chosen"
^XMB(3.9,144657,2,2253,0)="""RTN"",""IBCNBLA"",207,0)"
^XMB(3.9,144657,2,2254,0)=" Q:'$G(IBBUFDA)"
^XMB(3.9,144657,2,2255,0)="""RTN"",""IBCNBLA"",208,0)"
^XMB(3.9,144657,2,2256,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,2257,0)="""RTN"",""IBCNBLA"",209,0)"
^XMB(3.9,144657,2,2258,0)=" W !!,""Enter an Insurance Company to display the Groups/Plans for that company or "",!,""enter Return to display a patient's policies."",!!"
^XMB(3.9,144657,2,2259,0)="""RTN"",""IBCNBLA"",210,0)"
^XMB(3.9,144657,2,2260,0)=" S IBCNSCRN=+$$SELINS^IBCNBU1"
^XMB(3.9,144657,2,2261,0)="""RTN"",""IBCNBLA"",211,0)"
^XMB(3.9,144657,2,2262,0)=" ;"
^XMB(3.9,144657,2,2263,0)="""RTN"",""IBCNBLA"",212,0)"
^XMB(3.9,144657,2,2264,0)=" D CLEAN^VALM10,INIT^IBCNBLP,HDR^IBCNBLP S VALMBCK=""R"",VALMBG=1"
^XMB(3.9,144657,2,2265,0)="""RTN"",""IBCNBLA"",213,0)"
^XMB(3.9,144657,2,2266,0)=" Q"
^XMB(3.9,144657,2,2267,0)="""RTN"",""IBCNBLA"",214,0)"
^XMB(3.9,144657,2,2268,0)=" ;"
^XMB(3.9,144657,2,2269,0)="""RTN"",""IBCNBLA"",215,0)"
^XMB(3.9,144657,2,2270,0)="AMCHK ; This procedure is called from the main buffer screen as an action"
^XMB(3.9,144657,2,2271,0)="""RTN"",""IBCNBLA"",216,0)"
^XMB(3.9,144657,2,2272,0)=" ; to check the insurance company names in the buffer file.  This will"
^XMB(3.9,144657,2,2273,0)="""RTN"",""IBCNBLA"",217,0)"
^XMB(3.9,144657,2,2274,0)=" ; invoke another ListMan screen that shows a list of all insurance "
^XMB(3.9,144657,2,2275,0)="""RTN"",""IBCNBLA"",218,0)"
^XMB(3.9,144657,2,2276,0)=" ; company names that do not exist in File 36 either as names or as"
^XMB(3.9,144657,2,2277,0)="""RTN"",""IBCNBLA"",219,0)"
^XMB(3.9,144657,2,2278,0)=" ; synonyms and also they do not exist in the Auto Match file.  These"
^XMB(3.9,144657,2,2279,0)="""RTN"",""IBCNBLA"",220,0)"
^XMB(3.9,144657,2,2280,0)=" ; are bad insurance company names that need to be corrected before"
^XMB(3.9,144657,2,2281,0)="""RTN"",""IBCNBLA"",221,0)"
^XMB(3.9,144657,2,2282,0)=" ; electronic insurance verification attempts can be made."
^XMB(3.9,144657,2,2283,0)="""RTN"",""IBCNBLA"",222,0)"
^XMB(3.9,144657,2,2284,0)=" ; esg - 6/20/02 - SDD 5.1.11 - Add an action on the main buffer"
^XMB(3.9,144657,2,2285,0)="""RTN"",""IBCNBLA"",223,0)"
^XMB(3.9,144657,2,2286,0)=" ;       screen to call the buffer names check option"
^XMB(3.9,144657,2,2287,0)="""RTN"",""IBCNBLA"",224,0)"
^XMB(3.9,144657,2,2288,0)=" ;"
^XMB(3.9,144657,2,2289,0)="""RTN"",""IBCNBLA"",225,0)"
^XMB(3.9,144657,2,2290,0)=" D EN^IBCNEAMC"
^XMB(3.9,144657,2,2291,0)="""RTN"",""IBCNBLA"",226,0)"
^XMB(3.9,144657,2,2292,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,2293,0)="""RTN"",""IBCNBLA"",227,0)"
^XMB(3.9,144657,2,2294,0)="AMCHKX ;"
^XMB(3.9,144657,2,2295,0)="""RTN"",""IBCNBLA"",228,0)"
^XMB(3.9,144657,2,2296,0)=" Q"
^XMB(3.9,144657,2,2297,0)="""RTN"",""IBCNBLA"",229,0)"
^XMB(3.9,144657,2,2298,0)=" ;"
^XMB(3.9,144657,2,2299,0)="""RTN"",""IBCNBLA"",230,0)"
^XMB(3.9,144657,2,2300,0)=" ;IB*806/DTG start check the subscriber id for new pt policy"
^XMB(3.9,144657,2,2301,0)="""RTN"",""IBCNBLA"",231,0)"
^XMB(3.9,144657,2,2302,0)="SUBCLNCK(IBSDFN,IBBUFSN) ; Look at subscriber ids in 2.312 and compare for 'P' ;IB*806/DTG check subscriber id equals"
^XMB(3.9,144657,2,2303,0)="""RTN"",""IBCNBLA"",232,0)"
^XMB(3.9,144657,2,2304,0)=" ;Input:"
^XMB(3.9,144657,2,2305,0)="""RTN"",""IBCNBLA"",233,0)"
^XMB(3.9,144657,2,2306,0)=" ; IBSDFN   - patient DFN"
^XMB(3.9,144657,2,2307,0)="""RTN"",""IBCNBLA"",234,0)"
^XMB(3.9,144657,2,2308,0)=" ; IBBUFSN  - 355.33 buffer IEN"
^XMB(3.9,144657,2,2309,0)="""RTN"",""IBCNBLA"",235,0)"
^XMB(3.9,144657,2,2310,0)=" ;Output:"
^XMB(3.9,144657,2,2311,0)="""RTN"",""IBCNBLA"",236,0)"
^XMB(3.9,144657,2,2312,0)=" ;  'P' - new potential policy, if no sub id's, from file #2.312, match the one from file 355.33"
^XMB(3.9,144657,2,2313,0)="""RTN"",""IBCNBLA"",237,0)"
^XMB(3.9,144657,2,2314,0)=" ;"
^XMB(3.9,144657,2,2315,0)="""RTN"",""IBCNBLA"",238,0)"
^XMB(3.9,144657,2,2316,0)=" N IB90,IBA,IBB,IBC,IBD,IBE,IBF,IBI,IBIENS,IBO,IBOUT,IBSUBCLN"
^XMB(3.9,144657,2,2317,0)="""RTN"",""IBCNBLA"",239,0)"
^XMB(3.9,144657,2,2318,0)=" S IBSDFN=+$G(IBSDFN) I IBSDFN="""" Q """"  ; must have PT DFN"
^XMB(3.9,144657,2,2319,0)="""RTN"",""IBCNBLA"",240,0)"
^XMB(3.9,144657,2,2320,0)=" S IBBUFSN=+$G(IBBUFSN)"
^XMB(3.9,144657,2,2321,0)="""RTN"",""IBCNBLA"",241,0)"
^XMB(3.9,144657,2,2322,0)=" I 'IBBUFSN Q """"  ; must have 355.33 IEN"
^XMB(3.9,144657,2,2323,0)="""RTN"",""IBCNBLA"",242,0)"
^XMB(3.9,144657,2,2324,0)=" ;"
^XMB(3.9,144657,2,2325,0)="""RTN"",""IBCNBLA"",243,0)"
^XMB(3.9,144657,2,2326,0)=" ; get subscriber id from 355.33"
^XMB(3.9,144657,2,2327,0)="""RTN"",""IBCNBLA"",244,0)"
^XMB(3.9,144657,2,2328,0)=" D  I 'IBO Q """"  ; must have a cleaned subscriber id"
^XMB(3.9,144657,2,2329,0)="""RTN"",""IBCNBLA"",245,0)"
^XMB(3.9,144657,2,2330,0)=" . S IBO="""",IB90=$G(^IBA(355.33,IBBUFSN,90)),IBE=$P(IB90,U,3) I IBE="""" Q  ; no subscriber id in 355.33"
^XMB(3.9,144657,2,2331,0)="""RTN"",""IBCNBLA"",246,0)"
^XMB(3.9,144657,2,2332,0)=" . S IBF=$$STRIP^IBCNEDE3(IBE) I IBF="""" Q  ; no clean subscriber id in 355.33"
^XMB(3.9,144657,2,2333,0)="""RTN"",""IBCNBLA"",247,0)"
^XMB(3.9,144657,2,2334,0)=" . S IBO=1,IBSUBCLN=IBF"
^XMB(3.9,144657,2,2335,0)="""RTN"",""IBCNBLA"",248,0)"
^XMB(3.9,144657,2,2336,0)=" ;"
^XMB(3.9,144657,2,2337,0)="""RTN"",""IBCNBLA"",249,0)"
^XMB(3.9,144657,2,2338,0)=" S IBD=""P"",IBA=0,IBOUT=0 F  S IBA=$O(^DPT(IBSDFN,.312,IBA)) Q:'IBA  D  Q:IBOUT"
^XMB(3.9,144657,2,2339,0)="""RTN"",""IBCNBLA"",250,0)"
^XMB(3.9,144657,2,2340,0)=" . S IBIENS=IBA_"",""_IBSDFN_"","""
^XMB(3.9,144657,2,2341,0)="""RTN"",""IBCNBLA"",251,0)"
^XMB(3.9,144657,2,2342,0)=" . S IBB=$$GET1^DIQ(2.312,IBIENS,7.02) I IBB="""" Q"
^XMB(3.9,144657,2,2343,0)="""RTN"",""IBCNBLA"",252,0)"
^XMB(3.9,144657,2,2344,0)=" . S IBC=$$STRIP^IBCNEDE3(IBB) I IBC="""" Q  ; remove all non alpha numeric from subscriber id"
^XMB(3.9,144657,2,2345,0)="""RTN"",""IBCNBLA"",253,0)"
^XMB(3.9,144657,2,2346,0)=" . I IBC=IBSUBCLN S IBD="""",IBOUT=1"
^XMB(3.9,144657,2,2347,0)="""RTN"",""IBCNBLA"",254,0)"
^XMB(3.9,144657,2,2348,0)=" Q IBD"
^XMB(3.9,144657,2,2349,0)="""RTN"",""IBCNBLA"",255,0)"
^XMB(3.9,144657,2,2350,0)=" ;IB*806/DTG end check the subscriber id for new pt policy"
^XMB(3.9,144657,2,2351,0)="""RTN"",""IBCNBLE1"")"
^XMB(3.9,144657,2,2352,0)="0^7^B42556307"
^XMB(3.9,144657,2,2353,0)="""RTN"",""IBCNBLE1"",1,0)"
^XMB(3.9,144657,2,2354,0)="IBCNBLE1 ;DAOU/ESG - Ins Buffer, Expand Entry, con't ;25-JUN-2002"
^XMB(3.9,144657,2,2355,0)="""RTN"",""IBCNBLE1"",2,0)"
^XMB(3.9,144657,2,2356,0)=" ;;2.0;INTEGRATED BILLING;**184,271,416,435,467,516,601,668,737**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,2357,0)="""RTN"",""IBCNBLE1"",3,0)"
^XMB(3.9,144657,2,2358,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,2359,0)="""RTN"",""IBCNBLE1"",4,0)"
^XMB(3.9,144657,2,2360,0)=" ;"
^XMB(3.9,144657,2,2361,0)="""RTN"",""IBCNBLE1"",5,0)"
^XMB(3.9,144657,2,2362,0)=" ; Can't be called from the top"
^XMB(3.9,144657,2,2363,0)="""RTN"",""IBCNBLE1"",6,0)"
^XMB(3.9,144657,2,2364,0)=" Q"
^XMB(3.9,144657,2,2365,0)="""RTN"",""IBCNBLE1"",7,0)"
^XMB(3.9,144657,2,2366,0)=" ;"
^XMB(3.9,144657,2,2367,0)="""RTN"",""IBCNBLE1"",8,0)"
^XMB(3.9,144657,2,2368,0)="BLD ; Continuation of Expand Entry list build procedure"
^XMB(3.9,144657,2,2369,0)="""RTN"",""IBCNBLE1"",9,0)"
^XMB(3.9,144657,2,2370,0)=" ; --- Called by IBCNBLE"
^XMB(3.9,144657,2,2371,0)="""RTN"",""IBCNBLE1"",10,0)"
^XMB(3.9,144657,2,2372,0)=" ;"
^XMB(3.9,144657,2,2373,0)="""RTN"",""IBCNBLE1"",11,0)"
^XMB(3.9,144657,2,2374,0)=" NEW ERR,MSG,IBL,IBY,IBLINE,IBER,IBLN,EDITED,ORIGSYME,ORIGSYMI,EEUPDATE"
^XMB(3.9,144657,2,2375,0)="""RTN"",""IBCNBLE1"",12,0)"
^XMB(3.9,144657,2,2376,0)=" NEW ORIGSYMS"
^XMB(3.9,144657,2,2377,0)="""RTN"",""IBCNBLE1"",13,0)"
^XMB(3.9,144657,2,2378,0)=" ;"
^XMB(3.9,144657,2,2379,0)="""RTN"",""IBCNBLE1"",14,0)"
^XMB(3.9,144657,2,2380,0)=" ; save the external and internal IIV status values"
^XMB(3.9,144657,2,2381,0)="""RTN"",""IBCNBLE1"",15,0)"
^XMB(3.9,144657,2,2382,0)=" S ORIGSYMS=$$SYMBOL^IBCNBLL(IBBUFDA)"
^XMB(3.9,144657,2,2383,0)="""RTN"",""IBCNBLE1"",16,0)"
^XMB(3.9,144657,2,2384,0)=" S ORIGSYME=$$GET1^DIQ(355.33,IBBUFDA,.12,""E"")"
^XMB(3.9,144657,2,2385,0)="""RTN"",""IBCNBLE1"",17,0)"
^XMB(3.9,144657,2,2386,0)=" S ORIGSYMI=$P(IB0,U,12)"
^XMB(3.9,144657,2,2387,0)="""RTN"",""IBCNBLE1"",18,0)"
^XMB(3.9,144657,2,2388,0)=" ;"
^XMB(3.9,144657,2,2389,0)="""RTN"",""IBCNBLE1"",19,0)"
^XMB(3.9,144657,2,2390,0)=" ; Determine if Expand Entry is allowed to update the IIV Status"
^XMB(3.9,144657,2,2391,0)="""RTN"",""IBCNBLE1"",20,0)"
^XMB(3.9,144657,2,2392,0)=" S EEUPDATE=1    ; default Expand Entry update flag to true"
^XMB(3.9,144657,2,2393,0)="""RTN"",""IBCNBLE1"",21,0)"
^XMB(3.9,144657,2,2394,0)=" I ORIGSYMI,'$P($G(^IBE(365.15,ORIGSYMI,0)),U,3) S EEUPDATE=0"
^XMB(3.9,144657,2,2395,0)="""RTN"",""IBCNBLE1"",22,0)"
^XMB(3.9,144657,2,2396,0)=" ;"
^XMB(3.9,144657,2,2397,0)="""RTN"",""IBCNBLE1"",23,0)"
^XMB(3.9,144657,2,2398,0)=" ; Do not update the IIV status if manually verified"
^XMB(3.9,144657,2,2399,0)="""RTN"",""IBCNBLE1"",24,0)"
^XMB(3.9,144657,2,2400,0)=" ;I ORIGSYMS=""*"" S EEUPDATE=0  ;IB*737/DTG stop '*' verified"
^XMB(3.9,144657,2,2401,0)="""RTN"",""IBCNBLE1"",25,0)"
^XMB(3.9,144657,2,2402,0)=" ;"
^XMB(3.9,144657,2,2403,0)="""RTN"",""IBCNBLE1"",26,0)"
^XMB(3.9,144657,2,2404,0)=" ; Don't let Expand Entry update the eIV status for ePharmacy buffer entries"
^XMB(3.9,144657,2,2405,0)="""RTN"",""IBCNBLE1"",27,0)"
^XMB(3.9,144657,2,2406,0)=" ; esg - 10/12/10 - IB*2*435"
^XMB(3.9,144657,2,2407,0)="""RTN"",""IBCNBLE1"",28,0)"
^XMB(3.9,144657,2,2408,0)=" I +$P($G(^IBA(355.33,IBBUFDA,0)),U,17) S EEUPDATE=0"
^XMB(3.9,144657,2,2409,0)="""RTN"",""IBCNBLE1"",29,0)"
^XMB(3.9,144657,2,2410,0)=" ;"
^XMB(3.9,144657,2,2411,0)="""RTN"",""IBCNBLE1"",30,0)"
^XMB(3.9,144657,2,2412,0)=" ; If the current IIV Status allows updates by Expand Entry, then"
^XMB(3.9,144657,2,2413,0)="""RTN"",""IBCNBLE1"",31,0)"
^XMB(3.9,144657,2,2414,0)=" ; invoke the function that trys to find a valid payer"
^XMB(3.9,144657,2,2415,0)="""RTN"",""IBCNBLE1"",32,0)"
^XMB(3.9,144657,2,2416,0)=" I EEUPDATE D"
^XMB(3.9,144657,2,2417,0)="""RTN"",""IBCNBLE1"",33,0)"
^XMB(3.9,144657,2,2418,0)=" . S ERR=$$INSERROR^IBCNEUT3(""B"",IBBUFDA,1,.MSG)"
^XMB(3.9,144657,2,2419,0)="""RTN"",""IBCNBLE1"",34,0)"
^XMB(3.9,144657,2,2420,0)=" . ; If no errors, then remove the IIV Status"
^XMB(3.9,144657,2,2421,0)="""RTN"",""IBCNBLE1"",35,0)"
^XMB(3.9,144657,2,2422,0)=" . I 'ERR S ERR=$$SIDERR(IBBUFDA,$P(ERR,U,2))"
^XMB(3.9,144657,2,2423,0)="""RTN"",""IBCNBLE1"",36,0)"
^XMB(3.9,144657,2,2424,0)=" . I 'ERR S ERR=$$PIDERR(IBBUFDA)"
^XMB(3.9,144657,2,2425,0)="""RTN"",""IBCNBLE1"",37,0)"
^XMB(3.9,144657,2,2426,0)=" . I 'ERR D CLEAR^IBCNEUT4(IBBUFDA,.EDITED)"
^XMB(3.9,144657,2,2427,0)="""RTN"",""IBCNBLE1"",38,0)"
^XMB(3.9,144657,2,2428,0)=" . ; If errors found, then update with the new IIV Status"
^XMB(3.9,144657,2,2429,0)="""RTN"",""IBCNBLE1"",39,0)"
^XMB(3.9,144657,2,2430,0)=" . I ERR D BUFF^IBCNEUT2(IBBUFDA,$P(ERR,U,1)) S EDITED=1"
^XMB(3.9,144657,2,2431,0)="""RTN"",""IBCNBLE1"",40,0)"
^XMB(3.9,144657,2,2432,0)=" . ; refresh the IB0 variable for the possible symbol change"
^XMB(3.9,144657,2,2433,0)="""RTN"",""IBCNBLE1"",41,0)"
^XMB(3.9,144657,2,2434,0)=" . S $P(IB0,U,12)=$P($G(^IBA(355.33,IBBUFDA,0)),U,12)"
^XMB(3.9,144657,2,2435,0)="""RTN"",""IBCNBLE1"",42,0)"
^XMB(3.9,144657,2,2436,0)=" . Q"
^XMB(3.9,144657,2,2437,0)="""RTN"",""IBCNBLE1"",43,0)"
^XMB(3.9,144657,2,2438,0)=" ;"
^XMB(3.9,144657,2,2439,0)="""RTN"",""IBCNBLE1"",44,0)"
^XMB(3.9,144657,2,2440,0)=" ; Possibly display information if the OVERRIDE FRESHNESS FLAG is on"
^XMB(3.9,144657,2,2441,0)="""RTN"",""IBCNBLE1"",45,0)"
^XMB(3.9,144657,2,2442,0)=" I $P(IB0,U,13) D"
^XMB(3.9,144657,2,2443,0)="""RTN"",""IBCNBLE1"",46,0)"
^XMB(3.9,144657,2,2444,0)=" . S IBL=""User Requested Inquiry?: "",IBY=""YES"""
^XMB(3.9,144657,2,2445,0)="""RTN"",""IBCNBLE1"",47,0)"
^XMB(3.9,144657,2,2446,0)=" . S IBLINE=$$SETL^IBCNBLE("""",IBY,IBL,18,3)"
^XMB(3.9,144657,2,2447,0)="""RTN"",""IBCNBLE1"",48,0)"
^XMB(3.9,144657,2,2448,0)=" . D SET^IBCNBLE(IBLINE) S IBLINE="""""
^XMB(3.9,144657,2,2449,0)="""RTN"",""IBCNBLE1"",49,0)"
^XMB(3.9,144657,2,2450,0)=" . Q"
^XMB(3.9,144657,2,2451,0)="""RTN"",""IBCNBLE1"",50,0)"
^XMB(3.9,144657,2,2452,0)=" ;"
^XMB(3.9,144657,2,2453,0)="""RTN"",""IBCNBLE1"",51,0)"
^XMB(3.9,144657,2,2454,0)=" ; Display the Current Status line"
^XMB(3.9,144657,2,2455,0)="""RTN"",""IBCNBLE1"",52,0)"
^XMB(3.9,144657,2,2456,0)=" S IBL=""Current eIV Status: """
^XMB(3.9,144657,2,2457,0)="""RTN"",""IBCNBLE1"",53,0)"
^XMB(3.9,144657,2,2458,0)=" S IBY=$$GET1^DIQ(355.33,IBBUFDA,.12,""E"")"
^XMB(3.9,144657,2,2459,0)="""RTN"",""IBCNBLE1"",54,0)"
^XMB(3.9,144657,2,2460,0)=" ;I IBY="""",$$SYMBOL^IBCNBLL(IBBUFDA)'=""*"" S IBY=""No problems identified, Awaiting electronic processing"""
^XMB(3.9,144657,2,2461,0)="""RTN"",""IBCNBLE1"",55,0)"
^XMB(3.9,144657,2,2462,0)=" I IBY="""" S IBY=""No problems identified, Awaiting electronic processing""   ;IB*737/DTG stop '*' verified"
^XMB(3.9,144657,2,2463,0)="""RTN"",""IBCNBLE1"",56,0)"
^XMB(3.9,144657,2,2464,0)=" I $$SYMBOL^IBCNBLL(IBBUFDA)=""*"" S IBY=""Manually verified, No eIV activity at this time"""
^XMB(3.9,144657,2,2465,0)="""RTN"",""IBCNBLE1"",57,0)"
^XMB(3.9,144657,2,2466,0)=" ;"
^XMB(3.9,144657,2,2467,0)="""RTN"",""IBCNBLE1"",58,0)"
^XMB(3.9,144657,2,2468,0)=" ; esg - 10/12/10 - check for epharmacy entries"
^XMB(3.9,144657,2,2469,0)="""RTN"",""IBCNBLE1"",59,0)"
^XMB(3.9,144657,2,2470,0)=" I +$P($G(^IBA(355.33,IBBUFDA,0)),U,17) S IBY=""N/A for e-Pharmacy buffer entries"""
^XMB(3.9,144657,2,2471,0)="""RTN"",""IBCNBLE1"",60,0)"
^XMB(3.9,144657,2,2472,0)=" ;"
^XMB(3.9,144657,2,2473,0)="""RTN"",""IBCNBLE1"",61,0)"
^XMB(3.9,144657,2,2474,0)=" S IBLINE=$$SETL^IBCNBLE("""",IBY,IBL,18,80)"
^XMB(3.9,144657,2,2475,0)="""RTN"",""IBCNBLE1"",62,0)"
^XMB(3.9,144657,2,2476,0)=" D SET^IBCNBLE(IBLINE) S IBLINE="""""
^XMB(3.9,144657,2,2477,0)="""RTN"",""IBCNBLE1"",63,0)"
^XMB(3.9,144657,2,2478,0)=" ;"
^XMB(3.9,144657,2,2479,0)="""RTN"",""IBCNBLE1"",64,0)"
^XMB(3.9,144657,2,2480,0)=" ; Display any text returned by the payer function"
^XMB(3.9,144657,2,2481,0)="""RTN"",""IBCNBLE1"",65,0)"
^XMB(3.9,144657,2,2482,0)=" F IBER=1:1:$G(MSG) D SET^IBCNBLE("" "") F IBLN=1:1:$P($G(MSG(IBER)),U,2) D SET^IBCNBLE(""  ""_$G(MSG(IBER,IBLN)))"
^XMB(3.9,144657,2,2483,0)="""RTN"",""IBCNBLE1"",66,0)"
^XMB(3.9,144657,2,2484,0)=" ;"
^XMB(3.9,144657,2,2485,0)="""RTN"",""IBCNBLE1"",67,0)"
^XMB(3.9,144657,2,2486,0)=" ; Display the current IIV Status generic description"
^XMB(3.9,144657,2,2487,0)="""RTN"",""IBCNBLE1"",68,0)"
^XMB(3.9,144657,2,2488,0)=" D SYMTXT($P(IB0,U,12),1)"
^XMB(3.9,144657,2,2489,0)="""RTN"",""IBCNBLE1"",69,0)"
^XMB(3.9,144657,2,2490,0)=" D SYMTXT($P(IB0,U,12),2)"
^XMB(3.9,144657,2,2491,0)="""RTN"",""IBCNBLE1"",70,0)"
^XMB(3.9,144657,2,2492,0)=" ;"
^XMB(3.9,144657,2,2493,0)="""RTN"",""IBCNBLE1"",71,0)"
^XMB(3.9,144657,2,2494,0)=" ; If the IIV Status ien changed from what it once was, then display the"
^XMB(3.9,144657,2,2495,0)="""RTN"",""IBCNBLE1"",72,0)"
^XMB(3.9,144657,2,2496,0)=" ; Prior Status line"
^XMB(3.9,144657,2,2497,0)="""RTN"",""IBCNBLE1"",73,0)"
^XMB(3.9,144657,2,2498,0)=" I ORIGSYMI'=$P(IB0,U,12) D"
^XMB(3.9,144657,2,2499,0)="""RTN"",""IBCNBLE1"",74,0)"
^XMB(3.9,144657,2,2500,0)=" . I $P(IB0,U,12) D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2501,0)="""RTN"",""IBCNBLE1"",75,0)"
^XMB(3.9,144657,2,2502,0)=" . S IBL=""Prior Status: """
^XMB(3.9,144657,2,2503,0)="""RTN"",""IBCNBLE1"",76,0)"
^XMB(3.9,144657,2,2504,0)=" . S IBY=ORIGSYME"
^XMB(3.9,144657,2,2505,0)="""RTN"",""IBCNBLE1"",77,0)"
^XMB(3.9,144657,2,2506,0)=" . ;I IBY="""",ORIGSYMS'=""*"" S IBY=""No problems identified, Awaiting electronic processing"""
^XMB(3.9,144657,2,2507,0)="""RTN"",""IBCNBLE1"",78,0)"
^XMB(3.9,144657,2,2508,0)=" . ;I ORIGSYMS=""*"" S IBY=""Manually verified, No eIV activity at this time"""
^XMB(3.9,144657,2,2509,0)="""RTN"",""IBCNBLE1"",79,0)"
^XMB(3.9,144657,2,2510,0)=" . I IBY="""" S IBY=""No problems identified, Awaiting electronic processing""  ;IB*737/DTG stop '*' verified"
^XMB(3.9,144657,2,2511,0)="""RTN"",""IBCNBLE1"",80,0)"
^XMB(3.9,144657,2,2512,0)=" . S IBLINE=$$SETL^IBCNBLE("""",IBY,IBL,18,80)"
^XMB(3.9,144657,2,2513,0)="""RTN"",""IBCNBLE1"",81,0)"
^XMB(3.9,144657,2,2514,0)=" . D SET^IBCNBLE(IBLINE) S IBLINE="""""
^XMB(3.9,144657,2,2515,0)="""RTN"",""IBCNBLE1"",82,0)"
^XMB(3.9,144657,2,2516,0)=" . D SYMTXT(ORIGSYMI,1)"
^XMB(3.9,144657,2,2517,0)="""RTN"",""IBCNBLE1"",83,0)"
^XMB(3.9,144657,2,2518,0)=" . Q"
^XMB(3.9,144657,2,2519,0)="""RTN"",""IBCNBLE1"",84,0)"
^XMB(3.9,144657,2,2520,0)=" ;"
^XMB(3.9,144657,2,2521,0)="""RTN"",""IBCNBLE1"",85,0)"
^XMB(3.9,144657,2,2522,0)=" ; Display any existing EC errors"
^XMB(3.9,144657,2,2523,0)="""RTN"",""IBCNBLE1"",86,0)"
^XMB(3.9,144657,2,2524,0)=" D ECERR"
^XMB(3.9,144657,2,2525,0)="""RTN"",""IBCNBLE1"",87,0)"
^XMB(3.9,144657,2,2526,0)=" ; IB*2*601/DM display possible notes"
^XMB(3.9,144657,2,2527,0)="""RTN"",""IBCNBLE1"",88,0)"
^XMB(3.9,144657,2,2528,0)=" D ECNOTE(IBBUFDA)"
^XMB(3.9,144657,2,2529,0)="""RTN"",""IBCNBLE1"",89,0)"
^XMB(3.9,144657,2,2530,0)=" ;D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2531,0)="""RTN"",""IBCNBLE1"",90,0)"
^XMB(3.9,144657,2,2532,0)=" ;"
^XMB(3.9,144657,2,2533,0)="""RTN"",""IBCNBLE1"",91,0)"
^XMB(3.9,144657,2,2534,0)=" ; If the IIV Status was modified then refresh the visual display"
^XMB(3.9,144657,2,2535,0)="""RTN"",""IBCNBLE1"",92,0)"
^XMB(3.9,144657,2,2536,0)=" I $G(EDITED) D UPDLN^IBCNBLL(IBBUFDA,""EDITED"")"
