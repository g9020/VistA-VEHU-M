^XMB(3.9,144657,2,2541,0)="""RTN"",""IBCNBLE1"",95,0)"
^XMB(3.9,144657,2,2542,0)=" ;"
^XMB(3.9,144657,2,2543,0)="""RTN"",""IBCNBLE1"",96,0)"
^XMB(3.9,144657,2,2544,0)="SYMTXT(IEN,TYPE) ; Display the text from the IIV symbol file for this entry"
^XMB(3.9,144657,2,2545,0)="""RTN"",""IBCNBLE1"",97,0)"
^XMB(3.9,144657,2,2546,0)=" ; TYPE=1 - Display Description from IIV Status Table file"
^XMB(3.9,144657,2,2547,0)="""RTN"",""IBCNBLE1"",98,0)"
^XMB(3.9,144657,2,2548,0)=" ; TYPE=2 - Display Corrective Action from IIV Status Table file"
^XMB(3.9,144657,2,2549,0)="""RTN"",""IBCNBLE1"",99,0)"
^XMB(3.9,144657,2,2550,0)=" NEW IBJ"
^XMB(3.9,144657,2,2551,0)="""RTN"",""IBCNBLE1"",100,0)"
^XMB(3.9,144657,2,2552,0)=" I '$G(IEN) G SYMX"
^XMB(3.9,144657,2,2553,0)="""RTN"",""IBCNBLE1"",101,0)"
^XMB(3.9,144657,2,2554,0)=" I '$P($G(^IBE(365.15,IEN,TYPE,0)),U,4) G SYMX"
^XMB(3.9,144657,2,2555,0)="""RTN"",""IBCNBLE1"",102,0)"
^XMB(3.9,144657,2,2556,0)=" D SET^IBCNBLE("" "")"
^XMB(3.9,144657,2,2557,0)="""RTN"",""IBCNBLE1"",103,0)"
^XMB(3.9,144657,2,2558,0)=" S IBJ=0"
^XMB(3.9,144657,2,2559,0)="""RTN"",""IBCNBLE1"",104,0)"
^XMB(3.9,144657,2,2560,0)=" F  S IBJ=$O(^IBE(365.15,IEN,TYPE,IBJ)) Q:'IBJ  D SET^IBCNBLE(""  ""_$G(^IBE(365.15,IEN,TYPE,IBJ,0)))"
^XMB(3.9,144657,2,2561,0)="""RTN"",""IBCNBLE1"",105,0)"
^XMB(3.9,144657,2,2562,0)="SYMX ;"
^XMB(3.9,144657,2,2563,0)="""RTN"",""IBCNBLE1"",106,0)"
^XMB(3.9,144657,2,2564,0)=" Q"
^XMB(3.9,144657,2,2565,0)="""RTN"",""IBCNBLE1"",107,0)"
^XMB(3.9,144657,2,2566,0)=" ;"
^XMB(3.9,144657,2,2567,0)="""RTN"",""IBCNBLE1"",108,0)"
^XMB(3.9,144657,2,2568,0)="ECERR ; Display the Eligibility Communicator Error data from the"
^XMB(3.9,144657,2,2569,0)="""RTN"",""IBCNBLE1"",109,0)"
^XMB(3.9,144657,2,2570,0)=" ; response file if it exists"
^XMB(3.9,144657,2,2571,0)="""RTN"",""IBCNBLE1"",110,0)"
^XMB(3.9,144657,2,2572,0)=" ;"
^XMB(3.9,144657,2,2573,0)="""RTN"",""IBCNBLE1"",111,0)"
^XMB(3.9,144657,2,2574,0)=" NEW RESP,RESPDATA,ERRTXT,IBY,IBLINE,ERRDATA,FUTDT,TQIEN,IBERR,IBCT"
^XMB(3.9,144657,2,2575,0)="""RTN"",""IBCNBLE1"",112,0)"
^XMB(3.9,144657,2,2576,0)=" S RESP=$O(^IBCN(365,""AF"",IBBUFDA,""""),-1)"
