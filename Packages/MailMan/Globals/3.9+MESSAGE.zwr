^XMB(3.9,145840,2,244,0)=" ;;3.0;BAR CODE MED ADMIN;**6,3,4,16,13,10,32,28,42,58,68,70,83,97,96,118,101,123,106,140,152**;Mar 2004;Build 0"
^XMB(3.9,145840,2,245,0)="""RTN"",""PSBRPC3"",3,0)"
^XMB(3.9,145840,2,246,0)=" ;Per VHA Directive 2004-038 (or future revisions regarding same), this routine should not be modified."
^XMB(3.9,145840,2,247,0)="""RTN"",""PSBRPC3"",4,0)"
^XMB(3.9,145840,2,248,0)=" ;"
^XMB(3.9,145840,2,249,0)="""RTN"",""PSBRPC3"",5,0)"
^XMB(3.9,145840,2,250,0)="GUICHK(RESULTS,DUMMY) ;"
^XMB(3.9,145840,2,251,0)="""RTN"",""PSBRPC3"",6,0)"
^XMB(3.9,145840,2,252,0)=" ;"
^XMB(3.9,145840,2,253,0)="""RTN"",""PSBRPC3"",7,0)"
^XMB(3.9,145840,2,254,0)=" ; RPC : PSB VERSION CHECK"
^XMB(3.9,145840,2,255,0)="""RTN"",""PSBRPC3"",8,0)"
^XMB(3.9,145840,2,256,0)=" ;"
^XMB(3.9,145840,2,257,0)="""RTN"",""PSBRPC3"",9,0)"
^XMB(3.9,145840,2,258,0)=" K RESULTS"
^XMB(3.9,145840,2,259,0)="""RTN"",""PSBRPC3"",10,0)"
^XMB(3.9,145840,2,260,0)=" N PSBCURR,PSBPREV,PSBCNT"
^XMB(3.9,145840,2,261,0)="""RTN"",""PSBRPC3"",11,0)"
^XMB(3.9,145840,2,262,0)=" S PSBCURR=""3.0.152.*"""
^XMB(3.9,145840,2,263,0)="""RTN"",""PSBRPC3"",12,0)"
^XMB(3.9,145840,2,264,0)=" S PSBPREV="""",PSBCNT=0"
^XMB(3.9,145840,2,265,0)="""RTN"",""PSBRPC3"",13,0)"
^XMB(3.9,145840,2,266,0)=" S PSBCNT=PSBCNT+1"
^XMB(3.9,145840,2,267,0)="""RTN"",""PSBRPC3"",14,0)"
^XMB(3.9,145840,2,268,0)=" S RESULTS(PSBCNT)=PSBCURR_U_PSBPREV"
^XMB(3.9,145840,2,269,0)="""RTN"",""PSBRPC3"",15,0)"
^XMB(3.9,145840,2,270,0)=" S RESULTS(0)=PSBCNT"
^XMB(3.9,145840,2,271,0)="""RTN"",""PSBRPC3"",16,0)"
^XMB(3.9,145840,2,272,0)=" Q"
^XMB(3.9,145840,2,273,0)="""RTN"",""PSBRPC3"",17,0)"
^XMB(3.9,145840,2,274,0)=" ;"
^XMB(3.9,145840,2,275,0)="""VER"")"
^XMB(3.9,145840,2,276,0)="8.0^22.2"
^XMB(3.9,145840,2,277,0)="$END KID PSB*3.0*157b"
