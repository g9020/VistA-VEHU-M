^XMB(3.9,145834,2,7285,0)="""RTN"",""MAGDSTQ8"",145,0)"
^XMB(3.9,145834,2,7286,0)=" I CODE=""A701"" D  Q ""Failure"""
^XMB(3.9,145834,2,7287,0)="""RTN"",""MAGDSTQ8"",146,0)"
^XMB(3.9,145834,2,7288,0)=" . S MEANING=""Refused: Out of Resources - Unable to calculate number of matches"""
