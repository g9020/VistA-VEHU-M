^XMB(3.9,144657,2,943,0)="""RTN"",""IBCNBAA"",175,0)"
^XMB(3.9,144657,2,944,0)=" W ! S DIR(0)=""YO"",DIR(""A"")=""Is this the correct ""_IBDESC_"" to match with this Buffer entry"" D ^DIR I Y=1 S IBX=1"
^XMB(3.9,144657,2,945,0)="""RTN"",""IBCNBAA"",176,0)"
