^XMB(3.9,145834,2,6490,0)=" . . . . S ZEROIEN2=(MOD100*100)+I-1"
^XMB(3.9,145834,2,6491,0)="""RTN"",""MAGDSTAS"",135,0)"
^XMB(3.9,145834,2,6492,0)=" . . . . Q"
^XMB(3.9,145834,2,6493,0)="""RTN"",""MAGDSTAS"",136,0)"
^XMB(3.9,145834,2,6494,0)=" . . . E  D  ; ""1"""
^XMB(3.9,145834,2,6495,0)="""RTN"",""MAGDSTAS"",137,0)"
