^XMB(3.9,144657,2,928,0)=" N DIR,X,Y,IBX S IBX=0"
^XMB(3.9,144657,2,929,0)="""RTN"",""IBCNBAA"",168,0)"
^XMB(3.9,144657,2,930,0)=" S DIR(""?"")=""Enter Yes if this existing ""_IBDESC_"" corresponds to the buffer entry ""_IBDESC_"".  Enter No to add new ""_IBDESC_""."""
^XMB(3.9,144657,2,931,0)="""RTN"",""IBCNBAA"",169,0)"
