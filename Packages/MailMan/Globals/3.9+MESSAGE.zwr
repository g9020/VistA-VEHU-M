^XMB(3.9,145833,2,259,0)="""RTN"",""SDAMUTDT"")"
^XMB(3.9,145833,2,260,0)="0^2^B49681336"
^XMB(3.9,145833,2,261,0)="""RTN"",""SDAMUTDT"",1,0)"
^XMB(3.9,145833,2,262,0)="SDAMUTDT ;BPOIFO/JFW,TAW,KML,LAB -Scheduling Encapsulation Utilities ;MAY 8,2025"
^XMB(3.9,145833,2,263,0)="""RTN"",""SDAMUTDT"",2,0)"
^XMB(3.9,145833,2,264,0)=" ;;5.3;Scheduling;**266,805,809,813,867,907**;13 Aug 1993;Build 0"
^XMB(3.9,145833,2,265,0)="""RTN"",""SDAMUTDT"",3,0)"
^XMB(3.9,145833,2,266,0)=" ;"
^XMB(3.9,145833,2,267,0)="""RTN"",""SDAMUTDT"",4,0)"
^XMB(3.9,145833,2,268,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,269,0)="""RTN"",""SDAMUTDT"",5,0)"
^XMB(3.9,145833,2,270,0)=" ;              CHANGE LOG"
^XMB(3.9,145833,2,271,0)="""RTN"",""SDAMUTDT"",6,0)"
^XMB(3.9,145833,2,272,0)=" ;"
^XMB(3.9,145833,2,273,0)="""RTN"",""SDAMUTDT"",7,0)"
^XMB(3.9,145833,2,274,0)=" ;  DATE      PATCH       DESCRIPTION"
^XMB(3.9,145833,2,275,0)="""RTN"",""SDAMUTDT"",8,0)"
^XMB(3.9,145833,2,276,0)=" ;--------  ----------    -----------------------------------------"
^XMB(3.9,145833,2,277,0)="""RTN"",""SDAMUTDT"",9,0)"
^XMB(3.9,145833,2,278,0)=" ;1/24/06   SD*5.3*413    ROUTINE COMPLETED"
^XMB(3.9,145833,2,279,0)="""RTN"",""SDAMUTDT"",10,0)"
^XMB(3.9,145833,2,280,0)=" ;1/13/22   SD^5.3*805    Add FMTISO and ISOTFM to support clinic time zone different from system"
^XMB(3.9,145833,2,281,0)="""RTN"",""SDAMUTDT"",11,0)"
^XMB(3.9,145833,2,282,0)=" ;"
^XMB(3.9,145833,2,283,0)="""RTN"",""SDAMUTDT"",12,0)"
^XMB(3.9,145833,2,284,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,285,0)="""RTN"",""SDAMUTDT"",13,0)"
^XMB(3.9,145833,2,286,0)="FMTISO(SDFMDT,SDCLINIC) ;convert internal fileman format to extended GMT"
^XMB(3.9,145833,2,287,0)="""RTN"",""SDAMUTDT"",14,0)"
^XMB(3.9,145833,2,288,0)=" ;initialize variables"
^XMB(3.9,145833,2,289,0)="""RTN"",""SDAMUTDT"",15,0)"
^XMB(3.9,145833,2,290,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,291,0)="""RTN"",""SDAMUTDT"",16,0)"
^XMB(3.9,145833,2,292,0)=" ;INPUT  SDFMDT - Fileman date/time"
^XMB(3.9,145833,2,293,0)="""RTN"",""SDAMUTDT"",17,0)"
^XMB(3.9,145833,2,294,0)=" ;       SDCLINIC - OPT IEN from file 44"
^XMB(3.9,145833,2,295,0)="""RTN"",""SDAMUTDT"",18,0)"
^XMB(3.9,145833,2,296,0)=" ;OUTPUT -1 error occurred in translation"
^XMB(3.9,145833,2,297,0)="""RTN"",""SDAMUTDT"",19,0)"
^XMB(3.9,145833,2,298,0)=" ;       GMT date/time in ISO 8601 extended format (No Errors)"
^XMB(3.9,145833,2,299,0)="""RTN"",""SDAMUTDT"",20,0)"
^XMB(3.9,145833,2,300,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,301,0)="""RTN"",""SDAMUTDT"",21,0)"
^XMB(3.9,145833,2,302,0)=" N SDDTM,SDGMT,SDTIME,SDOFFSET,HH,MM"
^XMB(3.9,145833,2,303,0)="""RTN"",""SDAMUTDT"",22,0)"
^XMB(3.9,145833,2,304,0)=" I +$G(SDFMDT)=0 Q """""
^XMB(3.9,145833,2,305,0)="""RTN"",""SDAMUTDT"",23,0)"
^XMB(3.9,145833,2,306,0)=" D FILEMANTOHL7^SDES2UTIL(.SDFMDT,.SDDTM)"
^XMB(3.9,145833,2,307,0)="""RTN"",""SDAMUTDT"",24,0)"
^XMB(3.9,145833,2,308,0)=" Q:SDDTM<0 -1"
^XMB(3.9,145833,2,309,0)="""RTN"",""SDAMUTDT"",25,0)"
^XMB(3.9,145833,2,310,0)=" S SDCLINIC=$G(SDCLINIC)"
^XMB(3.9,145833,2,311,0)="""RTN"",""SDAMUTDT"",26,0)"
^XMB(3.9,145833,2,312,0)=" ;If clinic offset is differnt from system, adjust SDFMDT"
^XMB(3.9,145833,2,313,0)="""RTN"",""SDAMUTDT"",27,0)"
^XMB(3.9,145833,2,314,0)=" ;I SDCLINIC D"
^XMB(3.9,145833,2,315,0)="""RTN"",""SDAMUTDT"",28,0)"
^XMB(3.9,145833,2,316,0)=" ;.S SDOFFSET=$$GETOFFSETDIFF(SDFMDT,SDCLINIC)"
^XMB(3.9,145833,2,317,0)="""RTN"",""SDAMUTDT"",29,0)"
^XMB(3.9,145833,2,318,0)=" ;.Q:SDOFFSET=""""  ;Clinic and system are the same"
^XMB(3.9,145833,2,319,0)="""RTN"",""SDAMUTDT"",30,0)"
^XMB(3.9,145833,2,320,0)=" ;.S HH=$EXTRACT(SDOFFSET,2,3)"
^XMB(3.9,145833,2,321,0)="""RTN"",""SDAMUTDT"",31,0)"
^XMB(3.9,145833,2,322,0)=" ;.S MM=$EXTRACT(SDOFFSET,4,5)"
^XMB(3.9,145833,2,323,0)="""RTN"",""SDAMUTDT"",32,0)"
^XMB(3.9,145833,2,324,0)=" ;.I $EXTRACT(SDOFFSET)=""-"" S HH=-HH,MM=-MM"
^XMB(3.9,145833,2,325,0)="""RTN"",""SDAMUTDT"",33,0)"
^XMB(3.9,145833,2,326,0)=" ;.S SDFMDT=$$FMADD^XLFDT(SDFMDT,,HH,MM)"
^XMB(3.9,145833,2,327,0)="""RTN"",""SDAMUTDT"",34,0)"
^XMB(3.9,145833,2,328,0)=" ;.S SDDTM=$$FMTHL7^XLFDT(SDFMDT)"
^XMB(3.9,145833,2,329,0)="""RTN"",""SDAMUTDT"",35,0)"
^XMB(3.9,145833,2,330,0)=" ;Gextract out date and convert to ISO 8601 extended format"
^XMB(3.9,145833,2,331,0)="""RTN"",""SDAMUTDT"",36,0)"
^XMB(3.9,145833,2,332,0)=" S SDGMT=$E(SDDTM,1,4)_""-""_$E(SDDTM,5,6)_""-""_$E(SDDTM,7,8)"
^XMB(3.9,145833,2,333,0)="""RTN"",""SDAMUTDT"",37,0)"
^XMB(3.9,145833,2,334,0)=" ;if time is included, extract and convert to ISO 8601 external format"
^XMB(3.9,145833,2,335,0)="""RTN"",""SDAMUTDT"",38,0)"
^XMB(3.9,145833,2,336,0)=" I $L(SDDTM)>8 D"
^XMB(3.9,145833,2,337,0)="""RTN"",""SDAMUTDT"",39,0)"
^XMB(3.9,145833,2,338,0)=" .S SDTIME=$E(+SDDTM,9,99)"
^XMB(3.9,145833,2,339,0)="""RTN"",""SDAMUTDT"",40,0)"
^XMB(3.9,145833,2,340,0)=" .S SDTIME=$$REMOVEOFFSET(SDTIME)"
^XMB(3.9,145833,2,341,0)="""RTN"",""SDAMUTDT"",41,0)"
^XMB(3.9,145833,2,342,0)=" .;append hour and min"
^XMB(3.9,145833,2,343,0)="""RTN"",""SDAMUTDT"",42,0)"
^XMB(3.9,145833,2,344,0)=" .S SDGMT=SDGMT_""T""_$E(SDTIME,1,2)_"":""_$E(SDTIME,3,4)"
^XMB(3.9,145833,2,345,0)="""RTN"",""SDAMUTDT"",43,0)"
^XMB(3.9,145833,2,346,0)=" .;include seconds"
^XMB(3.9,145833,2,347,0)="""RTN"",""SDAMUTDT"",44,0)"
^XMB(3.9,145833,2,348,0)=" .I $L(SDTIME)>4 S SDGMT=SDGMT_"":""_$E(SDTIME,5,6)"
^XMB(3.9,145833,2,349,0)="""RTN"",""SDAMUTDT"",45,0)"
^XMB(3.9,145833,2,350,0)=" .S SDGMT=SDGMT_$$GETOFFSET(SDFMDT,SDCLINIC)"
^XMB(3.9,145833,2,351,0)="""RTN"",""SDAMUTDT"",46,0)"
^XMB(3.9,145833,2,352,0)=" I SDGMT[""-9999"" S SDGMT=-1"
^XMB(3.9,145833,2,353,0)="""RTN"",""SDAMUTDT"",47,0)"
^XMB(3.9,145833,2,354,0)=" Q SDGMT"
^XMB(3.9,145833,2,355,0)="""RTN"",""SDAMUTDT"",48,0)"
^XMB(3.9,145833,2,356,0)=" ;"
^XMB(3.9,145833,2,357,0)="""RTN"",""SDAMUTDT"",49,0)"
^XMB(3.9,145833,2,358,0)="ISOTFM(SDGMTDT,SDCLINIC) ;convert ISO 8601 extended GMT date/time to fileman format"
^XMB(3.9,145833,2,359,0)="""RTN"",""SDAMUTDT"",50,0)"
^XMB(3.9,145833,2,360,0)=" ;initialize variables"
^XMB(3.9,145833,2,361,0)="""RTN"",""SDAMUTDT"",51,0)"
^XMB(3.9,145833,2,362,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,363,0)="""RTN"",""SDAMUTDT"",52,0)"
^XMB(3.9,145833,2,364,0)=" ;INPUT  SDGMTDT - ISO 8601 extended GMT date/time"
^XMB(3.9,145833,2,365,0)="""RTN"",""SDAMUTDT"",53,0)"
^XMB(3.9,145833,2,366,0)=" ;       SDCLINIC - OPT IEN from file 44"
^XMB(3.9,145833,2,367,0)="""RTN"",""SDAMUTDT"",54,0)"
^XMB(3.9,145833,2,368,0)=" ;OUTPUT -1 error occurred in translation"
^XMB(3.9,145833,2,369,0)="""RTN"",""SDAMUTDT"",55,0)"
^XMB(3.9,145833,2,370,0)=" ;       FM date/time (No Errors)"
^XMB(3.9,145833,2,371,0)="""RTN"",""SDAMUTDT"",56,0)"
^XMB(3.9,145833,2,372,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,373,0)="""RTN"",""SDAMUTDT"",57,0)"
^XMB(3.9,145833,2,374,0)=" N SDFM,SDTIME,SDFMDTM,X,Y,%DT,SDFMTMP,POP,TMPFM,TMPDT,SDOFFSET,SDISOOFFSET"
^XMB(3.9,145833,2,375,0)="""RTN"",""SDAMUTDT"",58,0)"
^XMB(3.9,145833,2,376,0)=" S (POP,SDOFFSET,TMPFM)="""""
^XMB(3.9,145833,2,377,0)="""RTN"",""SDAMUTDT"",59,0)"
^XMB(3.9,145833,2,378,0)=" I $G(SDGMTDT)="""" Q """""
^XMB(3.9,145833,2,379,0)="""RTN"",""SDAMUTDT"",60,0)"
^XMB(3.9,145833,2,380,0)=" ;pattern match date(/time) for correctness"
^XMB(3.9,145833,2,381,0)="""RTN"",""SDAMUTDT"",61,0)"
^XMB(3.9,145833,2,382,0)=" I '$$VALIDISO^SDECDATE(SDGMTDT) Q -1"
^XMB(3.9,145833,2,383,0)="""RTN"",""SDAMUTDT"",62,0)"
^XMB(3.9,145833,2,384,0)=" ;I $P(SDGMTDT,""T"",2)="""" Q -1"
^XMB(3.9,145833,2,385,0)="""RTN"",""SDAMUTDT"",63,0)"
^XMB(3.9,145833,2,386,0)=" S SDCLINIC=$G(SDCLINIC)"
^XMB(3.9,145833,2,387,0)="""RTN"",""SDAMUTDT"",64,0)"
^XMB(3.9,145833,2,388,0)=" ;extract out date, removing punctuation"
^XMB(3.9,145833,2,389,0)="""RTN"",""SDAMUTDT"",65,0)"
^XMB(3.9,145833,2,390,0)=" S SDFM=$TR($P(SDGMTDT,""T""),""-"")"
^XMB(3.9,145833,2,391,0)="""RTN"",""SDAMUTDT"",66,0)"
^XMB(3.9,145833,2,392,0)=" ;set parameters to validate date/time"
^XMB(3.9,145833,2,393,0)="""RTN"",""SDAMUTDT"",67,0)"
^XMB(3.9,145833,2,394,0)=" S %DT=""TXS"""
^XMB(3.9,145833,2,395,0)="""RTN"",""SDAMUTDT"",68,0)"
^XMB(3.9,145833,2,396,0)=" ;extract out time if entered, removing all punctuation except for TZ offset"
^XMB(3.9,145833,2,397,0)="""RTN"",""SDAMUTDT"",69,0)"
^XMB(3.9,145833,2,398,0)=" I $P(SDGMTDT,""T"",2)'="""" D"
^XMB(3.9,145833,2,399,0)="""RTN"",""SDAMUTDT"",70,0)"
^XMB(3.9,145833,2,400,0)=" .S SDTIME=$P(SDGMTDT,""T"",2)"
^XMB(3.9,145833,2,401,0)="""RTN"",""SDAMUTDT"",71,0)"
^XMB(3.9,145833,2,402,0)=" .;Must have a time zone offset"
^XMB(3.9,145833,2,403,0)="""RTN"",""SDAMUTDT"",72,0)"
^XMB(3.9,145833,2,404,0)=" .I SDTIME'[""Z"",SDTIME'[""+"",SDTIME'[""-"" S POP=1 Q"
^XMB(3.9,145833,2,405,0)="""RTN"",""SDAMUTDT"",73,0)"
^XMB(3.9,145833,2,406,0)=" .;exclude time if 0's else FMTE returns previous date with .24"
^XMB(3.9,145833,2,407,0)="""RTN"",""SDAMUTDT"",74,0)"
^XMB(3.9,145833,2,408,0)=" .S SDTIME=$$REMOVEOFFSET(SDTIME)"
^XMB(3.9,145833,2,409,0)="""RTN"",""SDAMUTDT"",75,0)"
^XMB(3.9,145833,2,410,0)=" .S SDTIME=$P(SDTIME,""."")  ;No ractional seconds"
^XMB(3.9,145833,2,411,0)="""RTN"",""SDAMUTDT"",76,0)"
^XMB(3.9,145833,2,412,0)=" .S SDTIME=$TR(SDTIME,"":"")"
^XMB(3.9,145833,2,413,0)="""RTN"",""SDAMUTDT"",77,0)"
^XMB(3.9,145833,2,414,0)=" .I +SDTIME=0 Q"
^XMB(3.9,145833,2,415,0)="""RTN"",""SDAMUTDT"",78,0)"
^XMB(3.9,145833,2,416,0)=" .;Get the correct offset"
^XMB(3.9,145833,2,417,0)="""RTN"",""SDAMUTDT"",79,0)"
^XMB(3.9,145833,2,418,0)=" .S TMPFM=$$CVTTOFM(SDGMTDT)  ;Need a FM format of the ISO date that is passed in"
^XMB(3.9,145833,2,419,0)="""RTN"",""SDAMUTDT"",80,0)"
^XMB(3.9,145833,2,420,0)=" .Q:TMPFM=-1  ;vse-2645 date is invalid so leave do dot logic and quit below"
^XMB(3.9,145833,2,421,0)="""RTN"",""SDAMUTDT"",81,0)"
^XMB(3.9,145833,2,422,0)=" .; IF ZULU reset SDGMTDT to match system time"
^XMB(3.9,145833,2,423,0)="""RTN"",""SDAMUTDT"",82,0)"
^XMB(3.9,145833,2,424,0)=" .I SDGMTDT[""Z""!(SDGMTDT[""+0000"") D"
^XMB(3.9,145833,2,425,0)="""RTN"",""SDAMUTDT"",83,0)"
^XMB(3.9,145833,2,426,0)=" ..S SDOFFSET=$$GETOFFSET(TMPFM,SDCLINIC)"
^XMB(3.9,145833,2,427,0)="""RTN"",""SDAMUTDT"",84,0)"
^XMB(3.9,145833,2,428,0)=" .E  D"
^XMB(3.9,145833,2,429,0)="""RTN"",""SDAMUTDT"",85,0)"
^XMB(3.9,145833,2,430,0)=" ..S SDISOOFFSET=$$GETISOOFFSET(SDGMTDT)"
^XMB(3.9,145833,2,431,0)="""RTN"",""SDAMUTDT"",86,0)"
^XMB(3.9,145833,2,432,0)=" ..S SDOFFSET=$$GETOFFSETDIFF(TMPFM,SDCLINIC,SDISOOFFSET)"
^XMB(3.9,145833,2,433,0)="""RTN"",""SDAMUTDT"",87,0)"
^XMB(3.9,145833,2,434,0)=" .;Build HLT formatted date with offset (Flip the sign on offset)"
^XMB(3.9,145833,2,435,0)="""RTN"",""SDAMUTDT"",88,0)"
^XMB(3.9,145833,2,436,0)=" .S SDFM=SDFM_SDTIME_$$FLIPOFFSET(SDOFFSET)"
^XMB(3.9,145833,2,437,0)="""RTN"",""SDAMUTDT"",89,0)"
^XMB(3.9,145833,2,438,0)=" I TMPFM=-1 Q -1"
^XMB(3.9,145833,2,439,0)="""RTN"",""SDAMUTDT"",90,0)"
^XMB(3.9,145833,2,440,0)=" I SDFM[""-9999""!(POP) Q -1"
^XMB(3.9,145833,2,441,0)="""RTN"",""SDAMUTDT"",91,0)"
^XMB(3.9,145833,2,442,0)=" ;"
^XMB(3.9,145833,2,443,0)="""RTN"",""SDAMUTDT"",92,0)"
^XMB(3.9,145833,2,444,0)=" ;convert date(/time) from HL7 format back to Fileman"
^XMB(3.9,145833,2,445,0)="""RTN"",""SDAMUTDT"",93,0)"
^XMB(3.9,145833,2,446,0)=" I +SDOFFSET S SDFMDTM=$$HL7TFM^XLFDT(SDFM,""U"")"
^XMB(3.9,145833,2,447,0)="""RTN"",""SDAMUTDT"",94,0)"
^XMB(3.9,145833,2,448,0)=" I '(+SDOFFSET) S SDFMDTM=$$HL7TFM^XLFDT(SDFM)"
^XMB(3.9,145833,2,449,0)="""RTN"",""SDAMUTDT"",95,0)"
^XMB(3.9,145833,2,450,0)=" Q:SDFMDTM<0 SDFMDTM ;error occurred in conversion"
^XMB(3.9,145833,2,451,0)="""RTN"",""SDAMUTDT"",96,0)"
^XMB(3.9,145833,2,452,0)=" ;check validity of date (including leap year check)"
^XMB(3.9,145833,2,453,0)="""RTN"",""SDAMUTDT"",97,0)"
^XMB(3.9,145833,2,454,0)=" S X=$$FMTE^XLFDT(SDFMDTM)"
^XMB(3.9,145833,2,455,0)="""RTN"",""SDAMUTDT"",98,0)"
^XMB(3.9,145833,2,456,0)=" D ^%DT"
^XMB(3.9,145833,2,457,0)="""RTN"",""SDAMUTDT"",99,0)"
^XMB(3.9,145833,2,458,0)=" Q:Y<0 -1 ;date(/time) not valid"
^XMB(3.9,145833,2,459,0)="""RTN"",""SDAMUTDT"",100,0)"
^XMB(3.9,145833,2,460,0)=" Q SDFMDTM"
^XMB(3.9,145833,2,461,0)="""RTN"",""SDAMUTDT"",101,0)"
^XMB(3.9,145833,2,462,0)=" ;"
^XMB(3.9,145833,2,463,0)="""RTN"",""SDAMUTDT"",102,0)"
^XMB(3.9,145833,2,464,0)="REMOVEOFFSET(TIME) ;"
^XMB(3.9,145833,2,465,0)="""RTN"",""SDAMUTDT"",103,0)"
^XMB(3.9,145833,2,466,0)=" S TIME=$P(TIME,""-"")"
^XMB(3.9,145833,2,467,0)="""RTN"",""SDAMUTDT"",104,0)"
^XMB(3.9,145833,2,468,0)=" S TIME=$P(TIME,""+"")"
^XMB(3.9,145833,2,469,0)="""RTN"",""SDAMUTDT"",105,0)"
^XMB(3.9,145833,2,470,0)=" S TIME=$P(TIME,""Z"")"
^XMB(3.9,145833,2,471,0)="""RTN"",""SDAMUTDT"",106,0)"
^XMB(3.9,145833,2,472,0)=" Q TIME"
^XMB(3.9,145833,2,473,0)="""RTN"",""SDAMUTDT"",107,0)"
^XMB(3.9,145833,2,474,0)="GETISOOFFSET(DATE) ;"
^XMB(3.9,145833,2,475,0)="""RTN"",""SDAMUTDT"",108,0)"
^XMB(3.9,145833,2,476,0)=" N ISOOFFSET"
^XMB(3.9,145833,2,477,0)="""RTN"",""SDAMUTDT"",109,0)"
^XMB(3.9,145833,2,478,0)=" S ISOOFFSET="""""
^XMB(3.9,145833,2,479,0)="""RTN"",""SDAMUTDT"",110,0)"
^XMB(3.9,145833,2,480,0)=" I $P(DATE,""+"",2)'="""" S ISOOFFSET=""+""_$P(DATE,""+"",2)"
^XMB(3.9,145833,2,481,0)="""RTN"",""SDAMUTDT"",111,0)"
^XMB(3.9,145833,2,482,0)=" I ISOOFFSET="""" S ISOOFFSET=""-""_$P($P(DATE,""T"",2),""-"",2)"
^XMB(3.9,145833,2,483,0)="""RTN"",""SDAMUTDT"",112,0)"
^XMB(3.9,145833,2,484,0)=" Q $TR(ISOOFFSET,"":"")"
^XMB(3.9,145833,2,485,0)="""RTN"",""SDAMUTDT"",113,0)"
^XMB(3.9,145833,2,486,0)="GETOFFSET(DATE,SDCLINIC) ;"
^XMB(3.9,145833,2,487,0)="""RTN"",""SDAMUTDT"",114,0)"
^XMB(3.9,145833,2,488,0)=" N OFFSET"
^XMB(3.9,145833,2,489,0)="""RTN"",""SDAMUTDT"",115,0)"
^XMB(3.9,145833,2,490,0)=" S OFFSET="""""
^XMB(3.9,145833,2,491,0)="""RTN"",""SDAMUTDT"",116,0)"
^XMB(3.9,145833,2,492,0)=" ;Clinc can be in a different time zone"
^XMB(3.9,145833,2,493,0)="""RTN"",""SDAMUTDT"",117,0)"
^XMB(3.9,145833,2,494,0)=" I $G(SDCLINIC) S OFFSET=$$GETTZOFFSET^SDESUTIL(DATE,SDCLINIC)"
^XMB(3.9,145833,2,495,0)="""RTN"",""SDAMUTDT"",118,0)"
^XMB(3.9,145833,2,496,0)=" ;get offset for VistA Instance"
^XMB(3.9,145833,2,497,0)="""RTN"",""SDAMUTDT"",119,0)"
^XMB(3.9,145833,2,498,0)=" I OFFSET="""" S OFFSET=$$GETTZOFFSET^SDESUTIL(DATE)"
^XMB(3.9,145833,2,499,0)="""RTN"",""SDAMUTDT"",120,0)"
^XMB(3.9,145833,2,500,0)=" I OFFSET=-1 S OFFSET=""BAD OFFSET"""
^XMB(3.9,145833,2,501,0)="""RTN"",""SDAMUTDT"",121,0)"
^XMB(3.9,145833,2,502,0)=" Q OFFSET"
^XMB(3.9,145833,2,503,0)="""RTN"",""SDAMUTDT"",122,0)"
^XMB(3.9,145833,2,504,0)=" ;"
^XMB(3.9,145833,2,505,0)="""RTN"",""SDAMUTDT"",123,0)"
^XMB(3.9,145833,2,506,0)="GETOFFSETDIFF(DATE,SDCLINIC,SDISOOFFSET) ;Compare offsets and return the difference"
^XMB(3.9,145833,2,507,0)="""RTN"",""SDAMUTDT"",124,0)"
^XMB(3.9,145833,2,508,0)=" N SDCLNOFFSET,SDSYSOFFSET,OFFSET,TMPOFFSET"
^XMB(3.9,145833,2,509,0)="""RTN"",""SDAMUTDT"",125,0)"
^XMB(3.9,145833,2,510,0)=" S (OFFSET,SDCLNOFFSET)="""""
^XMB(3.9,145833,2,511,0)="""RTN"",""SDAMUTDT"",126,0)"
^XMB(3.9,145833,2,512,0)=" S (TMPOFFSET,SDSYSOFFSET)=$$GETOFFSET(DATE)"
^XMB(3.9,145833,2,513,0)="""RTN"",""SDAMUTDT"",127,0)"
^XMB(3.9,145833,2,514,0)=" I $G(SDCLINIC) S (TMPOFFSET,SDCLNOFFSET)=$$GETOFFSET(DATE,SDCLINIC)"
^XMB(3.9,145833,2,515,0)="""RTN"",""SDAMUTDT"",128,0)"
^XMB(3.9,145833,2,516,0)=" I TMPOFFSET=-1 Q ""-9999"""
^XMB(3.9,145833,2,517,0)="""RTN"",""SDAMUTDT"",129,0)"
^XMB(3.9,145833,2,518,0)=" I $E(SDISOOFFSET)?1N S SDISOOFFSET=""+""_SDISOOFFSET"
^XMB(3.9,145833,2,519,0)="""RTN"",""SDAMUTDT"",130,0)"
^XMB(3.9,145833,2,520,0)=" ;If called from ISOTFM and ISO offset is different from the Clinic/System offset"
^XMB(3.9,145833,2,521,0)="""RTN"",""SDAMUTDT"",131,0)"
^XMB(3.9,145833,2,522,0)=" I $G(SDISOOFFSET)'="""",SDISOOFFSET'=TMPOFFSET D"
^XMB(3.9,145833,2,523,0)="""RTN"",""SDAMUTDT"",132,0)"
^XMB(3.9,145833,2,524,0)=" .S OFFSET=TMPOFFSET-SDISOOFFSET"
^XMB(3.9,145833,2,525,0)="""RTN"",""SDAMUTDT"",133,0)"
^XMB(3.9,145833,2,526,0)=" ;"
^XMB(3.9,145833,2,527,0)="""RTN"",""SDAMUTDT"",134,0)"
^XMB(3.9,145833,2,528,0)=" I $G(SDISOOFFSET)="""",SDSYSOFFSET'=SDCLNOFFSET D"
^XMB(3.9,145833,2,529,0)="""RTN"",""SDAMUTDT"",135,0)"
^XMB(3.9,145833,2,530,0)=" .S OFFSET=SDCLNOFFSET-SDSYSOFFSET"
^XMB(3.9,145833,2,531,0)="""RTN"",""SDAMUTDT"",136,0)"
^XMB(3.9,145833,2,532,0)=" S:OFFSET=0 OFFSET="""""
^XMB(3.9,145833,2,533,0)="""RTN"",""SDAMUTDT"",137,0)"
^XMB(3.9,145833,2,534,0)=" Q OFFSET"
^XMB(3.9,145833,2,535,0)="""RTN"",""SDAMUTDT"",138,0)"
^XMB(3.9,145833,2,536,0)=" ;"
^XMB(3.9,145833,2,537,0)="""RTN"",""SDAMUTDT"",139,0)"
^XMB(3.9,145833,2,538,0)="FLIPOFFSET(OFFSET) ;Need to flip the sign because HL7TFM will flip it back."
^XMB(3.9,145833,2,539,0)="""RTN"",""SDAMUTDT"",140,0)"
^XMB(3.9,145833,2,540,0)=" Q:+OFFSET=0 """""
^XMB(3.9,145833,2,541,0)="""RTN"",""SDAMUTDT"",141,0)"
^XMB(3.9,145833,2,542,0)=" I $E(OFFSET)=""-"" D"
^XMB(3.9,145833,2,543,0)="""RTN"",""SDAMUTDT"",142,0)"
^XMB(3.9,145833,2,544,0)=" .S OFFSET=OFFSET*-1"
^XMB(3.9,145833,2,545,0)="""RTN"",""SDAMUTDT"",143,0)"
^XMB(3.9,145833,2,546,0)=" .S OFFSET=""+""_$E(10000+OFFSET,2,5)"
^XMB(3.9,145833,2,547,0)="""RTN"",""SDAMUTDT"",144,0)"
^XMB(3.9,145833,2,548,0)=" E  D"
^XMB(3.9,145833,2,549,0)="""RTN"",""SDAMUTDT"",145,0)"
^XMB(3.9,145833,2,550,0)=" .S OFFSET=""-""_$E(10000+OFFSET,2,5)"
^XMB(3.9,145833,2,551,0)="""RTN"",""SDAMUTDT"",146,0)"
^XMB(3.9,145833,2,552,0)=" Q OFFSET"
^XMB(3.9,145833,2,553,0)="""RTN"",""SDAMUTDT"",147,0)"
^XMB(3.9,145833,2,554,0)=" ;"
^XMB(3.9,145833,2,555,0)="""RTN"",""SDAMUTDT"",148,0)"
^XMB(3.9,145833,2,556,0)="CVTTOFM(D) ;"
^XMB(3.9,145833,2,557,0)="""RTN"",""SDAMUTDT"",149,0)"
^XMB(3.9,145833,2,558,0)=" N X,Y,%DT"
^XMB(3.9,145833,2,559,0)="""RTN"",""SDAMUTDT"",150,0)"
^XMB(3.9,145833,2,560,0)=" S %DT="""""
^XMB(3.9,145833,2,561,0)="""RTN"",""SDAMUTDT"",151,0)"
^XMB(3.9,145833,2,562,0)=" S X=$P(D,""T"")"
^XMB(3.9,145833,2,563,0)="""RTN"",""SDAMUTDT"",152,0)"
^XMB(3.9,145833,2,564,0)=" D ^%DT"
^XMB(3.9,145833,2,565,0)="""RTN"",""SDAMUTDT"",153,0)"
^XMB(3.9,145833,2,566,0)=" Q Y"
^XMB(3.9,145833,2,567,0)="""RTN"",""SDAMUTDT"",154,0)"
^XMB(3.9,145833,2,568,0)=" ;"
^XMB(3.9,145833,2,569,0)="""RTN"",""SDAMUTDT"",155,0)"
^XMB(3.9,145833,2,570,0)=" ;"
^XMB(3.9,145833,2,571,0)="""RTN"",""SDAMUTDT"",156,0)"
^XMB(3.9,145833,2,572,0)="FMTGMT(SDFMDT) ;convert internal fileman format to extended GMT"
^XMB(3.9,145833,2,573,0)="""RTN"",""SDAMUTDT"",157,0)"
^XMB(3.9,145833,2,574,0)=" ;initialize variables"
^XMB(3.9,145833,2,575,0)="""RTN"",""SDAMUTDT"",158,0)"
^XMB(3.9,145833,2,576,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,577,0)="""RTN"",""SDAMUTDT"",159,0)"
^XMB(3.9,145833,2,578,0)=" ;INPUT  SDFMDT - Fileman date/time"
^XMB(3.9,145833,2,579,0)="""RTN"",""SDAMUTDT"",160,0)"
^XMB(3.9,145833,2,580,0)=" ;OUTPUT -1 error occurred in translation"
^XMB(3.9,145833,2,581,0)="""RTN"",""SDAMUTDT"",161,0)"
^XMB(3.9,145833,2,582,0)=" ;       GMT date/time in ISO 8601 extended format (No Errors)"
^XMB(3.9,145833,2,583,0)="""RTN"",""SDAMUTDT"",162,0)"
^XMB(3.9,145833,2,584,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,585,0)="""RTN"",""SDAMUTDT"",163,0)"
^XMB(3.9,145833,2,586,0)=" N SDDTM,SDGMT,SDTIME,SDOFFSET"
^XMB(3.9,145833,2,587,0)="""RTN"",""SDAMUTDT"",164,0)"
^XMB(3.9,145833,2,588,0)=" S SDDTM=$$FMTHL7^XLFDT(SDFMDT)"
^XMB(3.9,145833,2,589,0)="""RTN"",""SDAMUTDT"",165,0)"
^XMB(3.9,145833,2,590,0)=" Q:SDDTM<0 -1"
^XMB(3.9,145833,2,591,0)="""RTN"",""SDAMUTDT"",166,0)"
^XMB(3.9,145833,2,592,0)=" ;extract out date and convert to ISO 8601 extended format"
^XMB(3.9,145833,2,593,0)="""RTN"",""SDAMUTDT"",167,0)"
^XMB(3.9,145833,2,594,0)=" S SDGMT=$E(SDDTM,1,4)_""-""_$E(SDDTM,5,6)_""-""_$E(SDDTM,7,8)"
^XMB(3.9,145833,2,595,0)="""RTN"",""SDAMUTDT"",168,0)"
^XMB(3.9,145833,2,596,0)=" ;if time is included, extract and convert to ISO 8601 external format"
^XMB(3.9,145833,2,597,0)="""RTN"",""SDAMUTDT"",169,0)"
^XMB(3.9,145833,2,598,0)=" I $L(SDDTM)>8 D"
^XMB(3.9,145833,2,599,0)="""RTN"",""SDAMUTDT"",170,0)"
^XMB(3.9,145833,2,600,0)=" .S SDTIME=$E(+SDDTM,9,99),SDOFFSET=$$TZ^XLFDT()"
^XMB(3.9,145833,2,601,0)="""RTN"",""SDAMUTDT"",171,0)"
^XMB(3.9,145833,2,602,0)=" .;determine if seconds are included in time"
^XMB(3.9,145833,2,603,0)="""RTN"",""SDAMUTDT"",172,0)"
^XMB(3.9,145833,2,604,0)=" .I $L(SDTIME)<5 D"
^XMB(3.9,145833,2,605,0)="""RTN"",""SDAMUTDT"",173,0)"
^XMB(3.9,145833,2,606,0)=" ..;no seconds included in date/time"
^XMB(3.9,145833,2,607,0)="""RTN"",""SDAMUTDT"",174,0)"
^XMB(3.9,145833,2,608,0)=" ..S SDGMT=SDGMT_""T""_$E(SDDTM,9,10)_"":""_$E(SDDTM,11,99)"
^XMB(3.9,145833,2,609,0)="""RTN"",""SDAMUTDT"",175,0)"
^XMB(3.9,145833,2,610,0)=" .;seconds included in date/time"
^XMB(3.9,145833,2,611,0)="""RTN"",""SDAMUTDT"",176,0)"
^XMB(3.9,145833,2,612,0)=" .E  S SDGMT=SDGMT_""T""_$E(SDTIME,1,2)_"":""_$E(SDTIME,3,4)_"":""_$E(SDTIME,5,6)_SDOFFSET"
^XMB(3.9,145833,2,613,0)="""RTN"",""SDAMUTDT"",177,0)"
^XMB(3.9,145833,2,614,0)=" Q SDGMT"
^XMB(3.9,145833,2,615,0)="""RTN"",""SDAMUTDT"",178,0)"
^XMB(3.9,145833,2,616,0)=" ;"
^XMB(3.9,145833,2,617,0)="""RTN"",""SDAMUTDT"",179,0)"
^XMB(3.9,145833,2,618,0)="GMTTFM(SDGMTDT) ;convert ISO 8601 extended GMT date/time to fileman format"
^XMB(3.9,145833,2,619,0)="""RTN"",""SDAMUTDT"",180,0)"
^XMB(3.9,145833,2,620,0)=" ;initialize variables"
^XMB(3.9,145833,2,621,0)="""RTN"",""SDAMUTDT"",181,0)"
^XMB(3.9,145833,2,622,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,623,0)="""RTN"",""SDAMUTDT"",182,0)"
^XMB(3.9,145833,2,624,0)=" ;INPUT  SDGMTDT - ISO 8601 extended GMT date/time"
^XMB(3.9,145833,2,625,0)="""RTN"",""SDAMUTDT"",183,0)"
^XMB(3.9,145833,2,626,0)=" ;OUTPUT -1 error occurred in translation"
^XMB(3.9,145833,2,627,0)="""RTN"",""SDAMUTDT"",184,0)"
^XMB(3.9,145833,2,628,0)=" ;       FM date/time (No Errors)"
^XMB(3.9,145833,2,629,0)="""RTN"",""SDAMUTDT"",185,0)"
^XMB(3.9,145833,2,630,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,631,0)="""RTN"",""SDAMUTDT"",186,0)"
^XMB(3.9,145833,2,632,0)=" N SDFM,SDTIME,SDOFFSET,SDFMDTM,X,Y,%DT"
^XMB(3.9,145833,2,633,0)="""RTN"",""SDAMUTDT"",187,0)"
^XMB(3.9,145833,2,634,0)=" ;get offset for VistA Instance"
^XMB(3.9,145833,2,635,0)="""RTN"",""SDAMUTDT"",188,0)"
^XMB(3.9,145833,2,636,0)=" S SDOFFSET=$$TZ^XLFDT()"
^XMB(3.9,145833,2,637,0)="""RTN"",""SDAMUTDT"",189,0)"
^XMB(3.9,145833,2,638,0)=" ;pattern match date(/time) for correctness"
^XMB(3.9,145833,2,639,0)="""RTN"",""SDAMUTDT"",190,0)"
^XMB(3.9,145833,2,640,0)=" Q:((SDGMTDT[""T"")&'(SDGMTDT?4N1""-""2N1""-""2N1""T""2N1"":""2N.E)) -1"
^XMB(3.9,145833,2,641,0)="""RTN"",""SDAMUTDT"",191,0)"
^XMB(3.9,145833,2,642,0)=" Q:((SDGMTDT'[""T"")&'(SDGMTDT?4N1""-""2N1""-""2N)) -1"
^XMB(3.9,145833,2,643,0)="""RTN"",""SDAMUTDT"",192,0)"
^XMB(3.9,145833,2,644,0)=" ;extract out date, removing punctuation"
^XMB(3.9,145833,2,645,0)="""RTN"",""SDAMUTDT"",193,0)"
^XMB(3.9,145833,2,646,0)=" S SDFM=$E(SDGMTDT,1,4)_$E(SDGMTDT,6,7)_$E(SDGMTDT,9,10)"
^XMB(3.9,145833,2,647,0)="""RTN"",""SDAMUTDT"",194,0)"
^XMB(3.9,145833,2,648,0)=" ;set parameters to validate date/time"
^XMB(3.9,145833,2,649,0)="""RTN"",""SDAMUTDT"",195,0)"
^XMB(3.9,145833,2,650,0)=" S %DT=""TXS"""
^XMB(3.9,145833,2,651,0)="""RTN"",""SDAMUTDT"",196,0)"
^XMB(3.9,145833,2,652,0)=" ;extract out time if entered, removing all punctuation except for TZ offset"
^XMB(3.9,145833,2,653,0)="""RTN"",""SDAMUTDT"",197,0)"
^XMB(3.9,145833,2,654,0)=" I SDGMTDT>10 D"
^XMB(3.9,145833,2,655,0)="""RTN"",""SDAMUTDT"",198,0)"
^XMB(3.9,145833,2,656,0)=" .S SDTIME=$P($E(SDGMTDT,12,99),$E(SDOFFSET,1,1))"
^XMB(3.9,145833,2,657,0)="""RTN"",""SDAMUTDT"",199,0)"
^XMB(3.9,145833,2,658,0)=" .;exclude time if 0's else FMTE returns previous date with .24"
^XMB(3.9,145833,2,659,0)="""RTN"",""SDAMUTDT"",200,0)"
^XMB(3.9,145833,2,660,0)=" .Q:((SDTIME[""00:00"")!(SDTIME[""00:00:00""))"
^XMB(3.9,145833,2,661,0)="""RTN"",""SDAMUTDT"",201,0)"
^XMB(3.9,145833,2,662,0)=" .;determine if seconds are included in time"
^XMB(3.9,145833,2,663,0)="""RTN"",""SDAMUTDT"",202,0)"
^XMB(3.9,145833,2,664,0)=" .I $L(SDTIME)<6 D"
^XMB(3.9,145833,2,665,0)="""RTN"",""SDAMUTDT"",203,0)"
^XMB(3.9,145833,2,666,0)=" ..;no seconds include in date/time"
^XMB(3.9,145833,2,667,0)="""RTN"",""SDAMUTDT"",204,0)"
^XMB(3.9,145833,2,668,0)=" ..S SDFM=SDFM_$E(SDGMTDT,12,13)_$E(SDGMTDT,15,99)"
^XMB(3.9,145833,2,669,0)="""RTN"",""SDAMUTDT"",205,0)"
^XMB(3.9,145833,2,670,0)=" .;seconds included in date/time"
^XMB(3.9,145833,2,671,0)="""RTN"",""SDAMUTDT"",206,0)"
^XMB(3.9,145833,2,672,0)=" .E  S SDFM=SDFM_$E(SDTIME,1,2)_$E(SDTIME,4,5)_$E(SDTIME,7,8)_""-""_SDOFFSET"
^XMB(3.9,145833,2,673,0)="""RTN"",""SDAMUTDT"",207,0)"
^XMB(3.9,145833,2,674,0)=" ;convert date(/time) from HL7 format back to Fileman"
^XMB(3.9,145833,2,675,0)="""RTN"",""SDAMUTDT"",208,0)"
^XMB(3.9,145833,2,676,0)=" S SDFMDTM=$$HL7TFM^XLFDT(SDFM)"
^XMB(3.9,145833,2,677,0)="""RTN"",""SDAMUTDT"",209,0)"
^XMB(3.9,145833,2,678,0)=" Q:SDFMDTM<0 SDFMDTM ;error occurred in conversion"
^XMB(3.9,145833,2,679,0)="""RTN"",""SDAMUTDT"",210,0)"
^XMB(3.9,145833,2,680,0)=" ;check validity of date (including leap year check)"
^XMB(3.9,145833,2,681,0)="""RTN"",""SDAMUTDT"",211,0)"
^XMB(3.9,145833,2,682,0)=" S X=$$FMTE^XLFDT(SDFMDTM)"
^XMB(3.9,145833,2,683,0)="""RTN"",""SDAMUTDT"",212,0)"
^XMB(3.9,145833,2,684,0)=" D ^%DT"
^XMB(3.9,145833,2,685,0)="""RTN"",""SDAMUTDT"",213,0)"
^XMB(3.9,145833,2,686,0)=" Q:Y<0 -1 ;date(/time) not valid"
^XMB(3.9,145833,2,687,0)="""RTN"",""SDAMUTDT"",214,0)"
^XMB(3.9,145833,2,688,0)=" Q SDFMDTM"
^XMB(3.9,145833,2,689,0)="""RTN"",""SDAMUTDT"",215,0)"
^XMB(3.9,145833,2,690,0)=" ;"
^XMB(3.9,145833,2,691,0)="""RTN"",""SDAMUTDT"",216,0)"
^XMB(3.9,145833,2,692,0)="SDAPIERR() ; SDAPI Error Messages."
^XMB(3.9,145833,2,693,0)="""RTN"",""SDAMUTDT"",217,0)"
^XMB(3.9,145833,2,694,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,695,0)="""RTN"",""SDAMUTDT"",218,0)"
^XMB(3.9,145833,2,696,0)=" ;INPUT  N/A"
^XMB(3.9,145833,2,697,0)="""RTN"",""SDAMUTDT"",219,0)"
^XMB(3.9,145833,2,698,0)=" ;OUTPUT Extrinsic call returns error message"
^XMB(3.9,145833,2,699,0)="""RTN"",""SDAMUTDT"",220,0)"
^XMB(3.9,145833,2,700,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,701,0)="""RTN"",""SDAMUTDT"",221,0)"
^XMB(3.9,145833,2,702,0)=" N SDERR S SDERR=$O(^TMP($J,""SDAMA301"",""""))"
^XMB(3.9,145833,2,703,0)="""RTN"",""SDAMUTDT"",222,0)"
^XMB(3.9,145833,2,704,0)=" I SDERR="""" Q """""
^XMB(3.9,145833,2,705,0)="""RTN"",""SDAMUTDT"",223,0)"
^XMB(3.9,145833,2,706,0)=" I +SDERR=101 Q ""Error 101: The Appointment Database is not currently available.  Please try again later."""
^XMB(3.9,145833,2,707,0)="""RTN"",""SDAMUTDT"",224,0)"
^XMB(3.9,145833,2,708,0)=" I +SDERR=115 Q ""Error 115: Appointment request contains invalid values.  Please contact National Help Desk."""
^XMB(3.9,145833,2,709,0)="""RTN"",""SDAMUTDT"",225,0)"
^XMB(3.9,145833,2,710,0)=" Q ""Error 117: An error has occurred, check the RSA Error Log."""
