^XMB(3.9,144657,2,2588,0)=" I '$P(RESPDATA,U,14),'$P(RESPDATA,U,15),ERRTXT="""",'FUTDT G ECERRX"
^XMB(3.9,144657,2,2589,0)="""RTN"",""IBCNBLE1"",119,0)"
^XMB(3.9,144657,2,2590,0)=" ;"
^XMB(3.9,144657,2,2591,0)="""RTN"",""IBCNBLE1"",120,0)"
^XMB(3.9,144657,2,2592,0)=" ; At this point, we know there's something to get displayed"
^XMB(3.9,144657,2,2593,0)="""RTN"",""IBCNBLE1"",121,0)"
