^XMB(3.9,144659,2,335,0)="""RTN"",""IBCRHBRV"",44,0)"
^XMB(3.9,144659,2,336,0)=" ;"
^XMB(3.9,144659,2,337,0)="""RTN"",""IBCRHBRV"",45,0)"
^XMB(3.9,144659,2,338,0)="VERSEND() ; return all RC versions and corresponding inactive date 'VERS;INACTIVE DT^VERS;INACTIVE DT^...'"
^XMB(3.9,144659,2,339,0)="""RTN"",""IBCRHBRV"",46,0)"
^XMB(3.9,144659,2,340,0)=" N IBI,LINE,IBX,IBC S IBX="""",IBC="""""
^XMB(3.9,144659,2,341,0)="""RTN"",""IBCRHBRV"",47,0)"
^XMB(3.9,144659,2,342,0)=" F IBI=1:1 S LINE=$P($T(VLIST+IBI),"";;"",2,99) Q:'LINE  I $P(LINE,U,4) S IBX=IBX_IBC_+LINE_"";""_$P(LINE,U,4),IBC=U"
