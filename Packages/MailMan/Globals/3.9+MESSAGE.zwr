^XMB(3.9,145833,2,2604,0)=" .S STOPINACTDT=$$GET1^DIQ(40.7,STOPIEN,2,""I"")"
^XMB(3.9,145833,2,2605,0)="""RTN"",""SDESUTIL"",249,0)"
^XMB(3.9,145833,2,2606,0)=" .I STOPINACTDT,STOPINACTDT<DT!(STOPINACTDT=DT) Q"
^XMB(3.9,145833,2,2607,0)="""RTN"",""SDESUTIL"",250,0)"
^XMB(3.9,145833,2,2608,0)=" .S STOPCOUNT=STOPCOUNT+1"
