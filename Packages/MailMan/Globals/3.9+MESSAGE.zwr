^XMB(3.9,145834,2,399,0)="""KRN"",8994,1844,1,16,0)"
^XMB(3.9,145834,2,400,0)="This RPC will check if there are any new images to be transmitted,"
^XMB(3.9,145834,2,401,0)="""KRN"",8994,1844,1,17,0)"
^XMB(3.9,145834,2,402,0)="and will return information about the first or next one (if any)"
^XMB(3.9,145834,2,403,0)="""KRN"",8994,1844,1,18,0)"
^XMB(3.9,145834,2,404,0)="in the DICOM transmission queue."
^XMB(3.9,145834,2,405,0)="""KRN"",8994,1844,2,0)"
^XMB(3.9,145834,2,406,0)="^8994.02A^5^3"
^XMB(3.9,145834,2,407,0)="""KRN"",8994,1844,2,1,0)"
^XMB(3.9,145834,2,408,0)="LOCATION^1^30^1^1"
^XMB(3.9,145834,2,409,0)="""KRN"",8994,1844,2,1,1,0)"
^XMB(3.9,145834,2,410,0)="^8994.021^3^3"
^XMB(3.9,145834,2,411,0)="""KRN"",8994,1844,2,1,1,1,0)"
^XMB(3.9,145834,2,412,0)="The value of this parameter is a pointer to ^DIC(4)."
^XMB(3.9,145834,2,413,0)="""KRN"",8994,1844,2,1,1,2,0)"
^XMB(3.9,145834,2,414,0)="This pointer identifies the location at which images were acquired,"
^XMB(3.9,145834,2,415,0)="""KRN"",8994,1844,2,1,1,3,0)"
^XMB(3.9,145834,2,416,0)="i.e., from where they are being transmitted."
^XMB(3.9,145834,2,417,0)="""KRN"",8994,1844,2,2,0)"
^XMB(3.9,145834,2,418,0)="D0^1^20^0^2"
^XMB(3.9,145834,2,419,0)="""KRN"",8994,1844,2,2,1,0)"
^XMB(3.9,145834,2,420,0)="^8994.021^6^6"
^XMB(3.9,145834,2,421,0)="""KRN"",8994,1844,2,2,1,1,0)"
^XMB(3.9,145834,2,422,0)="The value of this optional parameter is a pointer into the"
^XMB(3.9,145834,2,423,0)="""KRN"",8994,1844,2,2,1,2,0)"
^XMB(3.9,145834,2,424,0)="DICOM IMAGE OUTPUT file (#2006.574). If this paramater is omitted,"
^XMB(3.9,145834,2,425,0)="""KRN"",8994,1844,2,2,1,3,0)"
^XMB(3.9,145834,2,426,0)="this RPC will find the first (if any) study in this file to be"
^XMB(3.9,145834,2,427,0)="""KRN"",8994,1844,2,2,1,4,0)"
^XMB(3.9,145834,2,428,0)="transmitted. If this parameter is specified, its value is intended"
^XMB(3.9,145834,2,429,0)="""KRN"",8994,1844,2,2,1,5,0)"
^XMB(3.9,145834,2,430,0)="to be the ""D0"" value for the most recent image transmitted, and this"
^XMB(3.9,145834,2,431,0)="""KRN"",8994,1844,2,2,1,6,0)"
^XMB(3.9,145834,2,432,0)="RPC will find the next (if any) image to be transmitted."
^XMB(3.9,145834,2,433,0)="""KRN"",8994,1844,2,3,0)"
^XMB(3.9,145834,2,434,0)="D1^1^20^0^3"
^XMB(3.9,145834,2,435,0)="""KRN"",8994,1844,2,3,1,0)"
^XMB(3.9,145834,2,436,0)="^8994.021^8^8"
^XMB(3.9,145834,2,437,0)="""KRN"",8994,1844,2,3,1,1,0)"
^XMB(3.9,145834,2,438,0)="The value of this optional parameter is a pointer into the"
^XMB(3.9,145834,2,439,0)="""KRN"",8994,1844,2,3,1,2,0)"
^XMB(3.9,145834,2,440,0)="IMAGE multiple of the "
^XMB(3.9,145834,2,441,0)="""KRN"",8994,1844,2,3,1,3,0)"
^XMB(3.9,145834,2,442,0)="DICOM IMAGE OUTPUT file (#2006.574). If this paramater is omitted,"
^XMB(3.9,145834,2,443,0)="""KRN"",8994,1844,2,3,1,4,0)"
^XMB(3.9,145834,2,444,0)="this RPC will find the first (if any) image in this file for the"
^XMB(3.9,145834,2,445,0)="""KRN"",8994,1844,2,3,1,5,0)"
^XMB(3.9,145834,2,446,0)="current study to be"
^XMB(3.9,145834,2,447,0)="""KRN"",8994,1844,2,3,1,6,0)"
^XMB(3.9,145834,2,448,0)="transmitted. If this parameter is specified, its value is intended"
^XMB(3.9,145834,2,449,0)="""KRN"",8994,1844,2,3,1,7,0)"
^XMB(3.9,145834,2,450,0)="to be the ""D1"" value for the most recent image transmitted, and this"
^XMB(3.9,145834,2,451,0)="""KRN"",8994,1844,2,3,1,8,0)"
^XMB(3.9,145834,2,452,0)="RPC will find the next (if any) image to be transmitted."
^XMB(3.9,145834,2,453,0)="""KRN"",8994,1844,2,4,0)"
^XMB(3.9,145834,2,454,0)="SENT^2^10000^0^2"
^XMB(3.9,145834,2,455,0)="""KRN"",8994,1844,2,4,1,0)"
^XMB(3.9,145834,2,456,0)="^8994.021^5^5^3050614^"
^XMB(3.9,145834,2,457,0)="""KRN"",8994,1844,2,4,1,1,0)"
^XMB(3.9,145834,2,458,0)="This parameter is an array. Each element of this array"
^XMB(3.9,145834,2,459,0)="""KRN"",8994,1844,2,4,1,2,0)"
^XMB(3.9,145834,2,460,0)="contains internal entry numbers that identify an entry"
^XMB(3.9,145834,2,461,0)="""KRN"",8994,1844,2,4,1,3,0)"
^XMB(3.9,145834,2,462,0)="in the send-queue that has been transmitted successfully."
^XMB(3.9,145834,2,463,0)="""KRN"",8994,1844,2,4,1,4,0)"
^XMB(3.9,145834,2,464,0)="The RPC will use the contents of this array to remove"
^XMB(3.9,145834,2,465,0)="""KRN"",8994,1844,2,4,1,5,0)"
^XMB(3.9,145834,2,466,0)="entries from the queue that have been transmitted."
^XMB(3.9,145834,2,467,0)="""KRN"",8994,1844,2,5,0)"
^XMB(3.9,145834,2,468,0)="CHECK^1^5^0^3"
^XMB(3.9,145834,2,469,0)="""KRN"",8994,1844,2,5,1,0)"
^XMB(3.9,145834,2,470,0)="^8994.021^6^6^3050614^^"
^XMB(3.9,145834,2,471,0)="""KRN"",8994,1844,2,5,1,1,0)"
^XMB(3.9,145834,2,472,0)="The value of this parameter is a boolean value."
^XMB(3.9,145834,2,473,0)="""KRN"",8994,1844,2,5,1,2,0)"
^XMB(3.9,145834,2,474,0)="When the value of this parameter is non-zero (true),"
^XMB(3.9,145834,2,475,0)="""KRN"",8994,1844,2,5,1,3,0)"
^XMB(3.9,145834,2,476,0)="the RPC will not mark the queue entry as being ""in transmission""."
^XMB(3.9,145834,2,477,0)="""KRN"",8994,1844,2,5,1,4,0)"
^XMB(3.9,145834,2,478,0)="This feature is used when the RPC is being called for the"
^XMB(3.9,145834,2,479,0)="""KRN"",8994,1844,2,5,1,5,0)"
^XMB(3.9,145834,2,480,0)="sole purpose of deternining whether or not there are"
^XMB(3.9,145834,2,481,0)="""KRN"",8994,1844,2,5,1,6,0)"
^XMB(3.9,145834,2,482,0)="any entries in the queue."
^XMB(3.9,145834,2,483,0)="""KRN"",8994,1844,2,""B"",""CHECK"",5)"
^XMB(3.9,145834,2,484,0)=""
^XMB(3.9,145834,2,485,0)="""KRN"",8994,1844,2,""B"",""D0"",2)"
