^XMB(3.9,144657,2,10216,0)=" S IBLDT=$$FMADD^XLFDT(DT,1) F  S IBLGL=$O(^XTMP(""IBNCPLDT""_IBLDT),-1),IBLDT=$E(IBLGL,9,15) Q:IBLDT<$$FMADD^XLFDT(DT,-3)!(IBLGL'[""IBNCPLDT"")  I $D(^XTMP(IBLGL,IBD(""BCID""))) S ^(IBD(""BCID""))="""" Q"
