^XMB(3.9,144657,2,9630,0)=" S ELINE=$$SET(""  Misc. Settings"","""",ELINE,1)"
^XMB(3.9,144657,2,9631,0)="""RTN"",""IBJPI"",84,0)"
^XMB(3.9,144657,2,9632,0)=" S ELINE=$$SET(""     Insurance Import Enabled: "",$$GET1^DIQ(350.9,""1,"",54.01),ELINE,1)"
^XMB(3.9,144657,2,9633,0)="""RTN"",""IBJPI"",85,0)"
^XMB(3.9,144657,2,9634,0)=" S ELINE=$$SET(""                HMS Directory: "",$$GET1^DIQ(350.9,""1,"",13.01),ELINE,1)"
^XMB(3.9,144657,2,9635,0)="""RTN"",""IBJPI"",86,0)"
^XMB(3.9,144657,2,9636,0)=" ;IB*763/CKB - Added display for INSURANCE IMPORT SWITCH"
^XMB(3.9,144657,2,9637,0)="""RTN"",""IBJPI"",87,0)"
^XMB(3.9,144657,2,9638,0)=" ;S STRTLN=ELINE"
