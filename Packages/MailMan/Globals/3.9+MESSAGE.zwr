^XMB(3.9,145834,2,7309,0)="""RTN"",""MAGDSTQ8"",157,0)"
^XMB(3.9,145834,2,7310,0)=" I CODE?1""C""3E D  Q ""Failure"""
^XMB(3.9,145834,2,7311,0)="""RTN"",""MAGDSTQ8"",158,0)"
^XMB(3.9,145834,2,7312,0)=" . S MEANING=""Failed: Unable to Process"""
