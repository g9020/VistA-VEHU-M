^XMB(3.9,144657,2,909,0)="""RTN"",""IBCNBAA"",158,0)"
^XMB(3.9,144657,2,910,0)=" ;"
^XMB(3.9,144657,2,911,0)="""RTN"",""IBCNBAA"",159,0)"
^XMB(3.9,144657,2,912,0)="LKPYR(IBGRPDA,ABYR) ; Look up year"
^XMB(3.9,144657,2,913,0)="""RTN"",""IBCNBAA"",160,0)"
^XMB(3.9,144657,2,914,0)=" N X,Y,DA,DR,DIC"
^XMB(3.9,144657,2,915,0)="""RTN"",""IBCNBAA"",161,0)"
^XMB(3.9,144657,2,916,0)=" S DA=IBGRPDA,DIC=""^IBA(355.4,"",DIC(0)=""MZ"",X=$P(ABYR,U,2)"
^XMB(3.9,144657,2,917,0)="""RTN"",""IBCNBAA"",162,0)"
