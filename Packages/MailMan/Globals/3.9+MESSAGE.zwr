^XMB(3.9,145834,2,3992,0)=" Q"
^XMB(3.9,145834,2,3993,0)="""RTN"",""MAGDSTA5"",23,0)"
^XMB(3.9,145834,2,3994,0)=" ;"
^XMB(3.9,145834,2,3995,0)="""RTN"",""MAGDSTA5"",24,0)"
^XMB(3.9,145834,2,3996,0)=" ; Look for images for completed studies.  The status must be either"
^XMB(3.9,145834,2,3997,0)="""RTN"",""MAGDSTA5"",25,0)"
^XMB(3.9,145834,2,3998,0)=" ; V-VERIFIED or EF-ELECTRONICALY FILED."
^XMB(3.9,145834,2,3999,0)="""RTN"",""MAGDSTA5"",26,0)"
^XMB(3.9,145834,2,4000,0)=" ;"
^XMB(3.9,145834,2,4001,0)="""RTN"",""MAGDSTA5"",27,0)"
^XMB(3.9,145834,2,4002,0)="MAIN() ; The main loop for the program for Radiology"
^XMB(3.9,145834,2,4003,0)="""RTN"",""MAGDSTA5"",28,0)"
^XMB(3.9,145834,2,4004,0)=" ; Input Variables "
^XMB(3.9,145834,2,4005,0)="""RTN"",""MAGDSTA5"",29,0)"
^XMB(3.9,145834,2,4006,0)=" ; SCANMODE ;-- ""PATIENT"", ""DATE"", or ""NUMBER"""
^XMB(3.9,145834,2,4007,0)="""RTN"",""MAGDSTA5"",30,0)"
^XMB(3.9,145834,2,4008,0)=" ; DIRECTION ;- 1=""ASCENDING"" or 0=""DESCENDING"""
^XMB(3.9,145834,2,4009,0)="""RTN"",""MAGDSTA5"",31,0)"
^XMB(3.9,145834,2,4010,0)=" ; BATCHSIZE ;- number of consult & procedure requests to process on this run"
^XMB(3.9,145834,2,4011,0)="""RTN"",""MAGDSTA5"",32,0)"
^XMB(3.9,145834,2,4012,0)=" ; BEGDATE ;--- begin date for search"
^XMB(3.9,145834,2,4013,0)="""RTN"",""MAGDSTA5"",33,0)"
^XMB(3.9,145834,2,4014,0)=" ; ENDDATE ;-- end date for search"
^XMB(3.9,145834,2,4015,0)="""RTN"",""MAGDSTA5"",34,0)"
^XMB(3.9,145834,2,4016,0)=" ; QRSCP ;----- default query/retrieve provider"
^XMB(3.9,145834,2,4017,0)="""RTN"",""MAGDSTA5"",35,0)"
^XMB(3.9,145834,2,4018,0)=" ; HOURS ;----- 24 character string of Y's and N's indicating active times"
^XMB(3.9,145834,2,4019,0)="""RTN"",""MAGDSTA5"",36,0)"
^XMB(3.9,145834,2,4020,0)=" ;"
^XMB(3.9,145834,2,4021,0)="""RTN"",""MAGDSTA5"",37,0)"
^XMB(3.9,145834,2,4022,0)=" N RARPT1,RUNTIME,STOP,X"
^XMB(3.9,145834,2,4023,0)="""RTN"",""MAGDSTA5"",38,0)"
^XMB(3.9,145834,2,4024,0)=" ;"
^XMB(3.9,145834,2,4025,0)="""RTN"",""MAGDSTA5"",39,0)"
^XMB(3.9,145834,2,4026,0)=" D HEADER^MAGDSTAA(0)"
^XMB(3.9,145834,2,4027,0)="""RTN"",""MAGDSTA5"",40,0)"
^XMB(3.9,145834,2,4028,0)=" ;"
^XMB(3.9,145834,2,4029,0)="""RTN"",""MAGDSTA5"",41,0)"
^XMB(3.9,145834,2,4030,0)=" ; STOP: -1=error, 0=run completed, 1=run stopped"
^XMB(3.9,145834,2,4031,0)="""RTN"",""MAGDSTA5"",42,0)"
^XMB(3.9,145834,2,4032,0)=" S STOP=$$RADLKUP()"
^XMB(3.9,145834,2,4033,0)="""RTN"",""MAGDSTA5"",43,0)"
^XMB(3.9,145834,2,4034,0)=" Q STOP"
^XMB(3.9,145834,2,4035,0)="""RTN"",""MAGDSTA5"",44,0)"
^XMB(3.9,145834,2,4036,0)=" ;"
^XMB(3.9,145834,2,4037,0)="""RTN"",""MAGDSTA5"",45,0)"
^XMB(3.9,145834,2,4038,0)="RADLKUP() ; Find the next study to retrieve"
^XMB(3.9,145834,2,4039,0)="""RTN"",""MAGDSTA5"",46,0)"
^XMB(3.9,145834,2,4040,0)=" N STOP"
^XMB(3.9,145834,2,4041,0)="""RTN"",""MAGDSTA5"",47,0)"
^XMB(3.9,145834,2,4042,0)=" I SCANMODE=""PATIENT"" D"
^XMB(3.9,145834,2,4043,0)="""RTN"",""MAGDSTA5"",48,0)"
^XMB(3.9,145834,2,4044,0)=" . S STOP=$$PATIENT()"
^XMB(3.9,145834,2,4045,0)="""RTN"",""MAGDSTA5"",49,0)"
^XMB(3.9,145834,2,4046,0)=" . Q"
^XMB(3.9,145834,2,4047,0)="""RTN"",""MAGDSTA5"",50,0)"
^XMB(3.9,145834,2,4048,0)=" E  I SCANMODE=""DATE"" D"
^XMB(3.9,145834,2,4049,0)="""RTN"",""MAGDSTA5"",51,0)"
^XMB(3.9,145834,2,4050,0)=" . S STOP=$$DATE()"
^XMB(3.9,145834,2,4051,0)="""RTN"",""MAGDSTA5"",52,0)"
^XMB(3.9,145834,2,4052,0)=" . Q"
^XMB(3.9,145834,2,4053,0)="""RTN"",""MAGDSTA5"",53,0)"
^XMB(3.9,145834,2,4054,0)=" E  I SCANMODE=""NUMBER"" D"
^XMB(3.9,145834,2,4055,0)="""RTN"",""MAGDSTA5"",54,0)"
^XMB(3.9,145834,2,4056,0)=" . S STOP=$$NUMBER()"
^XMB(3.9,145834,2,4057,0)="""RTN"",""MAGDSTA5"",55,0)"
^XMB(3.9,145834,2,4058,0)=" . Q"
^XMB(3.9,145834,2,4059,0)="""RTN"",""MAGDSTA5"",56,0)"
^XMB(3.9,145834,2,4060,0)=" E  D"
^XMB(3.9,145834,2,4061,0)="""RTN"",""MAGDSTA5"",57,0)"
^XMB(3.9,145834,2,4062,0)=" . W !!,""*** Illegal SCAN MODE: """""",SCANMODE,"""""""""
^XMB(3.9,145834,2,4063,0)="""RTN"",""MAGDSTA5"",58,0)"
^XMB(3.9,145834,2,4064,0)=" . S STOP=-1"
^XMB(3.9,145834,2,4065,0)="""RTN"",""MAGDSTA5"",59,0)"
^XMB(3.9,145834,2,4066,0)=" . Q"
^XMB(3.9,145834,2,4067,0)="""RTN"",""MAGDSTA5"",60,0)"
^XMB(3.9,145834,2,4068,0)=" Q STOP"
^XMB(3.9,145834,2,4069,0)="""RTN"",""MAGDSTA5"",61,0)"
^XMB(3.9,145834,2,4070,0)=" ;"
^XMB(3.9,145834,2,4071,0)="""RTN"",""MAGDSTA5"",62,0)"
^XMB(3.9,145834,2,4072,0)="PATIENT() ; use ^RARPT ""C"" xref to find studies for a single patient"
^XMB(3.9,145834,2,4073,0)="""RTN"",""MAGDSTA5"",63,0)"
^XMB(3.9,145834,2,4074,0)=" ; ^RARPT(""C"",DFN,RARPT1)="""""
^XMB(3.9,145834,2,4075,0)="""RTN"",""MAGDSTA5"",64,0)"
^XMB(3.9,145834,2,4076,0)=" N EXAMDATE,RARPT0,RARPT1,RETURN,STATUS,STOP"
^XMB(3.9,145834,2,4077,0)="""RTN"",""MAGDSTA5"",65,0)"
^XMB(3.9,145834,2,4078,0)=" S STOP=0 ; set to stop the q/r process"
^XMB(3.9,145834,2,4079,0)="""RTN"",""MAGDSTA5"",66,0)"
^XMB(3.9,145834,2,4080,0)=" S RARPT1="""""
^XMB(3.9,145834,2,4081,0)="""RTN"",""MAGDSTA5"",67,0)"
^XMB(3.9,145834,2,4082,0)=" F  S RARPT1=$O(^RARPT(""C"",DFN,RARPT1),DIRECTION) Q:'RARPT1  Q:STOP  D"
^XMB(3.9,145834,2,4083,0)="""RTN"",""MAGDSTA5"",68,0)"
^XMB(3.9,145834,2,4084,0)=" . S RARPT0=$G(^RARPT(RARPT1,0))"
^XMB(3.9,145834,2,4085,0)="""RTN"",""MAGDSTA5"",69,0)"
^XMB(3.9,145834,2,4086,0)=" . S EXAMDATE=$P(RARPT0,""^"",3),STATUS=$P(RARPT0,""^"",5)"
^XMB(3.9,145834,2,4087,0)="""RTN"",""MAGDSTA5"",70,0)"
^XMB(3.9,145834,2,4088,0)=" . Q:EXAMDATE<BEGDATE  Q:EXAMDATE>ENDDATE"
^XMB(3.9,145834,2,4089,0)="""RTN"",""MAGDSTA5"",71,0)"
^XMB(3.9,145834,2,4090,0)=" . I STATUS'=""V"",STATUS'=""EF"" Q"
^XMB(3.9,145834,2,4091,0)="""RTN"",""MAGDSTA5"",72,0)"
^XMB(3.9,145834,2,4092,0)=" . S STOP=$$RADLKUP1(RARPT1)"
^XMB(3.9,145834,2,4093,0)="""RTN"",""MAGDSTA5"",73,0)"
^XMB(3.9,145834,2,4094,0)=" . Q"
^XMB(3.9,145834,2,4095,0)="""RTN"",""MAGDSTA5"",74,0)"
^XMB(3.9,145834,2,4096,0)=" Q STOP"
^XMB(3.9,145834,2,4097,0)="""RTN"",""MAGDSTA5"",75,0)"
^XMB(3.9,145834,2,4098,0)=" ;"
^XMB(3.9,145834,2,4099,0)="""RTN"",""MAGDSTA5"",76,0)"
^XMB(3.9,145834,2,4100,0)="DATE() ; use ^RARTPT ""AA"" xref to find studies by verified date"
^XMB(3.9,145834,2,4101,0)="""RTN"",""MAGDSTA5"",77,0)"
^XMB(3.9,145834,2,4102,0)=" ; ^RARPT(""AA"",RADTI,RARPT1)="""""
^XMB(3.9,145834,2,4103,0)="""RTN"",""MAGDSTA5"",78,0)"
^XMB(3.9,145834,2,4104,0)=" N DATEBEG,DATESTOP,DONE,RADTI,RARPT0,RARPT1,RETURN,STATUS,STOP"
^XMB(3.9,145834,2,4105,0)="""RTN"",""MAGDSTA5"",79,0)"
^XMB(3.9,145834,2,4106,0)=" S STOP=0 ; set to stop the q/r process"
^XMB(3.9,145834,2,4107,0)="""RTN"",""MAGDSTA5"",80,0)"
^XMB(3.9,145834,2,4108,0)=" D SETDATES(.DATEBEG,.DATESTOP,BEGDATE,ENDDATE,DIRECTION)"
^XMB(3.9,145834,2,4109,0)="""RTN"",""MAGDSTA5"",81,0)"
^XMB(3.9,145834,2,4110,0)=" S RADTI=DATEBEG,(DONE,RETURN)=0"
^XMB(3.9,145834,2,4111,0)="""RTN"",""MAGDSTA5"",82,0)"
^XMB(3.9,145834,2,4112,0)=" ; reverse date, opposite sort order"
^XMB(3.9,145834,2,4113,0)="""RTN"",""MAGDSTA5"",83,0)"
^XMB(3.9,145834,2,4114,0)=" F  S RADTI=$O(^RARPT(""AA"",RADTI),-DIRECTION) Q:'RADTI  Q:DONE  Q:STOP  D"
^XMB(3.9,145834,2,4115,0)="""RTN"",""MAGDSTA5"",84,0)"
^XMB(3.9,145834,2,4116,0)=" . I DIRECTION=1 S DONE=RADTI<DATESTOP Q:DONE"
^XMB(3.9,145834,2,4117,0)="""RTN"",""MAGDSTA5"",85,0)"
^XMB(3.9,145834,2,4118,0)=" . E  S DONE=RADTI>DATESTOP Q:DONE"
^XMB(3.9,145834,2,4119,0)="""RTN"",""MAGDSTA5"",86,0)"
^XMB(3.9,145834,2,4120,0)=" . S RARPT1="""""
^XMB(3.9,145834,2,4121,0)="""RTN"",""MAGDSTA5"",87,0)"
^XMB(3.9,145834,2,4122,0)=" . F  S RARPT1=$O(^RARPT(""AA"",RADTI,RARPT1),DIRECTION) Q:'RARPT1  Q:STOP  D"
^XMB(3.9,145834,2,4123,0)="""RTN"",""MAGDSTA5"",88,0)"
^XMB(3.9,145834,2,4124,0)=" . . S RARPT0=$G(^RARPT(RARPT1,0))"
^XMB(3.9,145834,2,4125,0)="""RTN"",""MAGDSTA5"",89,0)"
^XMB(3.9,145834,2,4126,0)=" . . S STATUS=$P(RARPT0,""^"",5)"
^XMB(3.9,145834,2,4127,0)="""RTN"",""MAGDSTA5"",90,0)"
^XMB(3.9,145834,2,4128,0)=" . . I STATUS'=""V"",STATUS'=""EF"" Q"
^XMB(3.9,145834,2,4129,0)="""RTN"",""MAGDSTA5"",91,0)"
^XMB(3.9,145834,2,4130,0)=" . . S STOP=$$RADLKUP1(RARPT1)"
^XMB(3.9,145834,2,4131,0)="""RTN"",""MAGDSTA5"",92,0)"
^XMB(3.9,145834,2,4132,0)=" . . Q"
^XMB(3.9,145834,2,4133,0)="""RTN"",""MAGDSTA5"",93,0)"
^XMB(3.9,145834,2,4134,0)=" . Q"
^XMB(3.9,145834,2,4135,0)="""RTN"",""MAGDSTA5"",94,0)"
^XMB(3.9,145834,2,4136,0)=" Q STOP"
^XMB(3.9,145834,2,4137,0)="""RTN"",""MAGDSTA5"",95,0)"
^XMB(3.9,145834,2,4138,0)=" ;"
^XMB(3.9,145834,2,4139,0)="""RTN"",""MAGDSTA5"",96,0)"
^XMB(3.9,145834,2,4140,0)="NUMBER() ; use ^RARPT ien"
^XMB(3.9,145834,2,4141,0)="""RTN"",""MAGDSTA5"",97,0)"
^XMB(3.9,145834,2,4142,0)=" ; ^RARPT(RARPT1,..."
^XMB(3.9,145834,2,4143,0)="""RTN"",""MAGDSTA5"",98,0)"
^XMB(3.9,145834,2,4144,0)=" N BATCHSIZE,RARPT0,RARPT1,RETURN,STOP,STATUS,STUDYCNT"
^XMB(3.9,145834,2,4145,0)="""RTN"",""MAGDSTA5"",99,0)"
^XMB(3.9,145834,2,4146,0)=" S STOP=0 ; set to stop the q/r process"
^XMB(3.9,145834,2,4147,0)="""RTN"",""MAGDSTA5"",100,0)"
^XMB(3.9,145834,2,4148,0)=" S STUDYCNT=0 ; only count completed (V or EF) studies"
^XMB(3.9,145834,2,4149,0)="""RTN"",""MAGDSTA5"",101,0)"
^XMB(3.9,145834,2,4150,0)=" S BATCHSIZE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""BATCH SIZE""))"
^XMB(3.9,145834,2,4151,0)="""RTN"",""MAGDSTA5"",102,0)"
^XMB(3.9,145834,2,4152,0)=" S RARPT1=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""REPORT/STUDY IEN""))"
^XMB(3.9,145834,2,4153,0)="""RTN"",""MAGDSTA5"",103,0)"
^XMB(3.9,145834,2,4154,0)=" S RARPT1=RARPT1-DIRECTION ; Massage value for $O"
^XMB(3.9,145834,2,4155,0)="""RTN"",""MAGDSTA5"",104,0)"
^XMB(3.9,145834,2,4156,0)=" F  S RARPT1=$O(^RARPT(RARPT1),DIRECTION) Q:'RARPT1  Q:STUDYCNT>=BATCHSIZE  Q:STOP  D"
^XMB(3.9,145834,2,4157,0)="""RTN"",""MAGDSTA5"",105,0)"
^XMB(3.9,145834,2,4158,0)=" . S RARPT0=$G(^RARPT(RARPT1,0))"
^XMB(3.9,145834,2,4159,0)="""RTN"",""MAGDSTA5"",106,0)"
^XMB(3.9,145834,2,4160,0)=" . S STATUS=$P(RARPT0,""^"",5)"
^XMB(3.9,145834,2,4161,0)="""RTN"",""MAGDSTA5"",107,0)"
^XMB(3.9,145834,2,4162,0)=" . ; should this study have image?"
^XMB(3.9,145834,2,4163,0)="""RTN"",""MAGDSTA5"",108,0)"
^XMB(3.9,145834,2,4164,0)=" . I STATUS'=""V"",STATUS'=""EF"" Q  ; nope"
^XMB(3.9,145834,2,4165,0)="""RTN"",""MAGDSTA5"",109,0)"
^XMB(3.9,145834,2,4166,0)=" . S STUDYCNT=STUDYCNT+1"
^XMB(3.9,145834,2,4167,0)="""RTN"",""MAGDSTA5"",110,0)"
^XMB(3.9,145834,2,4168,0)=" . S STOP=$$RADLKUP1(RARPT1)"
^XMB(3.9,145834,2,4169,0)="""RTN"",""MAGDSTA5"",111,0)"
^XMB(3.9,145834,2,4170,0)=" . Q"
^XMB(3.9,145834,2,4171,0)="""RTN"",""MAGDSTA5"",112,0)"
^XMB(3.9,145834,2,4172,0)=" Q STOP"
^XMB(3.9,145834,2,4173,0)="""RTN"",""MAGDSTA5"",113,0)"
^XMB(3.9,145834,2,4174,0)=" ;"
^XMB(3.9,145834,2,4175,0)="""RTN"",""MAGDSTA5"",114,0)"
^XMB(3.9,145834,2,4176,0)="RADLKUP1(RARPT1) ; lookup one radiology exam"
^XMB(3.9,145834,2,4177,0)="""RTN"",""MAGDSTA5"",115,0)"
^XMB(3.9,145834,2,4178,0)=" N ACNUMB,DFN,EXAMDATE,HOSPDIV,MAGIEN,MAGIENLIST,RADPT0,RADTI,RARPT0,RARPT3"
^XMB(3.9,145834,2,4179,0)="""RTN"",""MAGDSTA5"",116,0)"
^XMB(3.9,145834,2,4180,0)=" ;"
^XMB(3.9,145834,2,4181,0)="""RTN"",""MAGDSTA5"",117,0)"
^XMB(3.9,145834,2,4182,0)=" S RARPT0=$G(^RARPT(RARPT1,0))"
^XMB(3.9,145834,2,4183,0)="""RTN"",""MAGDSTA5"",118,0)"
^XMB(3.9,145834,2,4184,0)=" S ACNUMB=$P(RARPT0,""^"",1),DFN=$P(RARPT0,""^"",2)"
^XMB(3.9,145834,2,4185,0)="""RTN"",""MAGDSTA5"",119,0)"
^XMB(3.9,145834,2,4186,0)=" S EXAMDATE=$P(RARPT0,""^"",3)"
^XMB(3.9,145834,2,4187,0)="""RTN"",""MAGDSTA5"",120,0)"
^XMB(3.9,145834,2,4188,0)=" ;"
^XMB(3.9,145834,2,4189,0)="""RTN"",""MAGDSTA5"",121,0)"
^XMB(3.9,145834,2,4190,0)=" ; check DIVISION"
^XMB(3.9,145834,2,4191,0)="""RTN"",""MAGDSTA5"",122,0)"
^XMB(3.9,145834,2,4192,0)=" S RADTI=$$RADTI(EXAMDATE)"
^XMB(3.9,145834,2,4193,0)="""RTN"",""MAGDSTA5"",123,0)"
^XMB(3.9,145834,2,4194,0)=" S RADPT0=$G(^RADPT(DFN,""DT"",RADTI,0))"
^XMB(3.9,145834,2,4195,0)="""RTN"",""MAGDSTA5"",124,0)"
^XMB(3.9,145834,2,4196,0)=" S HOSPDIV=$P(RADPT0,""^"",3) ; HOSPITAL DIVISION"
^XMB(3.9,145834,2,4197,0)="""RTN"",""MAGDSTA5"",125,0)"
^XMB(3.9,145834,2,4198,0)=" I $$CHECKDIV^MAGDSTAB()=""Y"",HOSPDIV'=DIVISION Q 0 ; not the user's division"
^XMB(3.9,145834,2,4199,0)="""RTN"",""MAGDSTA5"",126,0)"
^XMB(3.9,145834,2,4200,0)=" ;"
^XMB(3.9,145834,2,4201,0)="""RTN"",""MAGDSTA5"",127,0)"
^XMB(3.9,145834,2,4202,0)=" ; lookup legacy 2005 image group pointers"
^XMB(3.9,145834,2,4203,0)="""RTN"",""MAGDSTA5"",128,0)"
^XMB(3.9,145834,2,4204,0)=" S RARPT3=0"
^XMB(3.9,145834,2,4205,0)="""RTN"",""MAGDSTA5"",129,0)"
