^XMB(3.9,144657,2,5071,0)="""RTN"",""IBCNEQU"",182,0)"
^XMB(3.9,144657,2,5072,0)=" . W !!,""No Insurance policies to select."""
^XMB(3.9,144657,2,5073,0)="""RTN"",""IBCNEQU"",183,0)"
^XMB(3.9,144657,2,5074,0)=" . S DIR(0)=""E"" D ^DIR K DIR"
