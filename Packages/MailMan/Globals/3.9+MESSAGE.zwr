^XMB(3.9,144657,2,6495,0)="""RTN"",""IBCNETST"",220,0)"
^XMB(3.9,144657,2,6496,0)=" . S GOOD=1"
^XMB(3.9,144657,2,6497,0)="""RTN"",""IBCNETST"",221,0)"
^XMB(3.9,144657,2,6498,0)=" ;"
^XMB(3.9,144657,2,6499,0)="""RTN"",""IBCNETST"",222,0)"
^XMB(3.9,144657,2,6500,0)=" Q 0"
^XMB(3.9,144657,2,6501,0)="""RTN"",""IBCNEUT1"")"
^XMB(3.9,144657,2,6502,0)="0^11^B44735114"
^XMB(3.9,144657,2,6503,0)="""RTN"",""IBCNEUT1"",1,0)"
^XMB(3.9,144657,2,6504,0)="IBCNEUT1 ;DAOU/ESG - IIV MISC. UTILITIES ;03-JUN-2002"
^XMB(3.9,144657,2,6505,0)="""RTN"",""IBCNEUT1"",2,0)"
^XMB(3.9,144657,2,6506,0)=" ;;2.0;INTEGRATED BILLING;**184,497,506,601**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,6507,0)="""RTN"",""IBCNEUT1"",3,0)"
^XMB(3.9,144657,2,6508,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,6509,0)="""RTN"",""IBCNEUT1"",4,0)"
^XMB(3.9,144657,2,6510,0)=" ;"
^XMB(3.9,144657,2,6511,0)="""RTN"",""IBCNEUT1"",5,0)"
^XMB(3.9,144657,2,6512,0)=" ; Can't be called from the top"
^XMB(3.9,144657,2,6513,0)="""RTN"",""IBCNEUT1"",6,0)"
^XMB(3.9,144657,2,6514,0)=" Q"
^XMB(3.9,144657,2,6515,0)="""RTN"",""IBCNEUT1"",7,0)"
^XMB(3.9,144657,2,6516,0)=" ;"
^XMB(3.9,144657,2,6517,0)="""RTN"",""IBCNEUT1"",8,0)"
^XMB(3.9,144657,2,6518,0)="FO(VALUE,LENGTH,JUSTIFY,FILL,TRUNC) ; Formatted output function"
^XMB(3.9,144657,2,6519,0)="""RTN"",""IBCNEUT1"",9,0)"
^XMB(3.9,144657,2,6520,0)=" ;"
^XMB(3.9,144657,2,6521,0)="""RTN"",""IBCNEUT1"",10,0)"
^XMB(3.9,144657,2,6522,0)=" ; Input parameters:"
^XMB(3.9,144657,2,6523,0)="""RTN"",""IBCNEUT1"",11,0)"
^XMB(3.9,144657,2,6524,0)=" ;   VALUE    the data to get formatted (required)"
^XMB(3.9,144657,2,6525,0)="""RTN"",""IBCNEUT1"",12,0)"
^XMB(3.9,144657,2,6526,0)=" ;   LENGTH   the resulting length of the formatted string (required)"
^XMB(3.9,144657,2,6527,0)="""RTN"",""IBCNEUT1"",13,0)"
^XMB(3.9,144657,2,6528,0)=" ;   JUSTIFY  ""L"" or ""R"" to indicate left or right justification"
^XMB(3.9,144657,2,6529,0)="""RTN"",""IBCNEUT1"",14,0)"
^XMB(3.9,144657,2,6530,0)=" ;               Default is ""L"" if not passed"
^XMB(3.9,144657,2,6531,0)="""RTN"",""IBCNEUT1"",15,0)"
^XMB(3.9,144657,2,6532,0)=" ;   FILL     the character to fill in the spaces"
^XMB(3.9,144657,2,6533,0)="""RTN"",""IBCNEUT1"",16,0)"
^XMB(3.9,144657,2,6534,0)=" ;               Default is a space if not passed"
^XMB(3.9,144657,2,6535,0)="""RTN"",""IBCNEUT1"",17,0)"
^XMB(3.9,144657,2,6536,0)=" ;   TRUNC    Whether or not to truncate Value if its longer than length"
^XMB(3.9,144657,2,6537,0)="""RTN"",""IBCNEUT1"",18,0)"
^XMB(3.9,144657,2,6538,0)=" ;               Default is Yes, to truncate if not passed"
^XMB(3.9,144657,2,6539,0)="""RTN"",""IBCNEUT1"",19,0)"
^XMB(3.9,144657,2,6540,0)=" ;"
^XMB(3.9,144657,2,6541,0)="""RTN"",""IBCNEUT1"",20,0)"
^XMB(3.9,144657,2,6542,0)=" NEW PAD,Z"
^XMB(3.9,144657,2,6543,0)="""RTN"",""IBCNEUT1"",21,0)"
^XMB(3.9,144657,2,6544,0)=" I LENGTH>245 S LENGTH=245"
^XMB(3.9,144657,2,6545,0)="""RTN"",""IBCNEUT1"",22,0)"
^XMB(3.9,144657,2,6546,0)=" S JUSTIFY=$G(JUSTIFY,""L"")               ; default Left"
^XMB(3.9,144657,2,6547,0)="""RTN"",""IBCNEUT1"",23,0)"
^XMB(3.9,144657,2,6548,0)=" S FILL=$E($G(FILL)_"" "")                 ; default space"
^XMB(3.9,144657,2,6549,0)="""RTN"",""IBCNEUT1"",24,0)"
^XMB(3.9,144657,2,6550,0)=" S TRUNC=$G(TRUNC,1)                     ; default true"
^XMB(3.9,144657,2,6551,0)="""RTN"",""IBCNEUT1"",25,0)"
^XMB(3.9,144657,2,6552,0)=" S $P(PAD,FILL,LENGTH-$L(VALUE)+1)="""""
^XMB(3.9,144657,2,6553,0)="""RTN"",""IBCNEUT1"",26,0)"
^XMB(3.9,144657,2,6554,0)=" S Z="""""
^XMB(3.9,144657,2,6555,0)="""RTN"",""IBCNEUT1"",27,0)"
^XMB(3.9,144657,2,6556,0)=" ;"
^XMB(3.9,144657,2,6557,0)="""RTN"",""IBCNEUT1"",28,0)"
^XMB(3.9,144657,2,6558,0)=" ; Check for JUSTIFY being ""R"" first"
^XMB(3.9,144657,2,6559,0)="""RTN"",""IBCNEUT1"",29,0)"
^XMB(3.9,144657,2,6560,0)=" I JUSTIFY[""R"" D  G FOXIT"
^XMB(3.9,144657,2,6561,0)="""RTN"",""IBCNEUT1"",30,0)"
^XMB(3.9,144657,2,6562,0)=" . I $L(VALUE)'>LENGTH S Z=PAD_VALUE Q"
^XMB(3.9,144657,2,6563,0)="""RTN"",""IBCNEUT1"",31,0)"
^XMB(3.9,144657,2,6564,0)=" . I 'TRUNC S Z=VALUE Q"
^XMB(3.9,144657,2,6565,0)="""RTN"",""IBCNEUT1"",32,0)"
^XMB(3.9,144657,2,6566,0)=" . S Z=$E(VALUE,$L(VALUE)-LENGTH+1,$L(VALUE)) Q"
^XMB(3.9,144657,2,6567,0)="""RTN"",""IBCNEUT1"",33,0)"
^XMB(3.9,144657,2,6568,0)=" . Q"
^XMB(3.9,144657,2,6569,0)="""RTN"",""IBCNEUT1"",34,0)"
^XMB(3.9,144657,2,6570,0)=" ;"
^XMB(3.9,144657,2,6571,0)="""RTN"",""IBCNEUT1"",35,0)"
^XMB(3.9,144657,2,6572,0)=" ; JUSTIFY is ""L"" below"
^XMB(3.9,144657,2,6573,0)="""RTN"",""IBCNEUT1"",36,0)"
^XMB(3.9,144657,2,6574,0)=" I $L(VALUE)'>LENGTH S Z=$E(VALUE_PAD,1,LENGTH) G FOXIT"
^XMB(3.9,144657,2,6575,0)="""RTN"",""IBCNEUT1"",37,0)"
^XMB(3.9,144657,2,6576,0)=" I 'TRUNC S Z=VALUE G FOXIT"
^XMB(3.9,144657,2,6577,0)="""RTN"",""IBCNEUT1"",38,0)"
^XMB(3.9,144657,2,6578,0)=" S Z=$E(VALUE,1,LENGTH)"
^XMB(3.9,144657,2,6579,0)="""RTN"",""IBCNEUT1"",39,0)"
^XMB(3.9,144657,2,6580,0)=" ;"
^XMB(3.9,144657,2,6581,0)="""RTN"",""IBCNEUT1"",40,0)"
^XMB(3.9,144657,2,6582,0)="FOXIT ;"
^XMB(3.9,144657,2,6583,0)="""RTN"",""IBCNEUT1"",41,0)"
^XMB(3.9,144657,2,6584,0)=" Q Z"
^XMB(3.9,144657,2,6585,0)="""RTN"",""IBCNEUT1"",42,0)"
^XMB(3.9,144657,2,6586,0)=" ;"
^XMB(3.9,144657,2,6587,0)="""RTN"",""IBCNEUT1"",43,0)"
^XMB(3.9,144657,2,6588,0)=" ;"
^XMB(3.9,144657,2,6589,0)="""RTN"",""IBCNEUT1"",44,0)"
^XMB(3.9,144657,2,6590,0)="AMLOOK(NAME,ERRFLG,LIST) ; Look-up an ins. co. name in Auto Match"
^XMB(3.9,144657,2,6591,0)="""RTN"",""IBCNEUT1"",45,0)"
^XMB(3.9,144657,2,6592,0)=" ;"
^XMB(3.9,144657,2,6593,0)="""RTN"",""IBCNEUT1"",46,0)"
^XMB(3.9,144657,2,6594,0)=" ; Input parameters"
^XMB(3.9,144657,2,6595,0)="""RTN"",""IBCNEUT1"",47,0)"
^XMB(3.9,144657,2,6596,0)=" ;   NAME       Insurance company name to look for (required)"
^XMB(3.9,144657,2,6597,0)="""RTN"",""IBCNEUT1"",48,0)"
^XMB(3.9,144657,2,6598,0)=" ;   ERRFLG     Error flag to determine whether or not to return"
^XMB(3.9,144657,2,6599,0)="""RTN"",""IBCNEUT1"",49,0)"
^XMB(3.9,144657,2,6600,0)=" ;                an array of all hits (optional)"
^XMB(3.9,144657,2,6601,0)="""RTN"",""IBCNEUT1"",50,0)"
^XMB(3.9,144657,2,6602,0)=" ;   LIST       The array to be built - passed by reference"
^XMB(3.9,144657,2,6603,0)="""RTN"",""IBCNEUT1"",51,0)"
^XMB(3.9,144657,2,6604,0)=" ;                (optional)"
^XMB(3.9,144657,2,6605,0)="""RTN"",""IBCNEUT1"",52,0)"
^XMB(3.9,144657,2,6606,0)=" ;                LIST(ins co name)=auto match value"
^XMB(3.9,144657,2,6607,0)="""RTN"",""IBCNEUT1"",53,0)"
^XMB(3.9,144657,2,6608,0)=" ;"
^XMB(3.9,144657,2,6609,0)="""RTN"",""IBCNEUT1"",54,0)"
^XMB(3.9,144657,2,6610,0)=" ; Output"
^XMB(3.9,144657,2,6611,0)="""RTN"",""IBCNEUT1"",55,0)"
^XMB(3.9,144657,2,6612,0)=" ;   The value of this function is either 0 or 1."
^XMB(3.9,144657,2,6613,0)="""RTN"",""IBCNEUT1"",56,0)"
^XMB(3.9,144657,2,6614,0)=" ;     0 - no matches in the Auto Match file for this name"
^XMB(3.9,144657,2,6615,0)="""RTN"",""IBCNEUT1"",57,0)"
^XMB(3.9,144657,2,6616,0)=" ;     1 - at least one match was found in the Auto Match file"
^XMB(3.9,144657,2,6617,0)="""RTN"",""IBCNEUT1"",58,0)"
^XMB(3.9,144657,2,6618,0)=" ;"
^XMB(3.9,144657,2,6619,0)="""RTN"",""IBCNEUT1"",59,0)"
^XMB(3.9,144657,2,6620,0)=" NEW FOUND,AMIEN,INSNAME,AMV,AMVSTART,NOMATCH"
^XMB(3.9,144657,2,6621,0)="""RTN"",""IBCNEUT1"",60,0)"
^XMB(3.9,144657,2,6622,0)=" S FOUND=0                         ; default to not found"
^XMB(3.9,144657,2,6623,0)="""RTN"",""IBCNEUT1"",61,0)"
^XMB(3.9,144657,2,6624,0)=" KILL LIST                         ; initialize results array"
^XMB(3.9,144657,2,6625,0)="""RTN"",""IBCNEUT1"",62,0)"
^XMB(3.9,144657,2,6626,0)=" S ERRFLG=+$G(ERRFLG)              ; ERRFLG default is 0 if not present"
^XMB(3.9,144657,2,6627,0)="""RTN"",""IBCNEUT1"",63,0)"
^XMB(3.9,144657,2,6628,0)=" S NAME=$$TRIM^XLFSTR($G(NAME))    ; strip leading/trailing spaces"
^XMB(3.9,144657,2,6629,0)="""RTN"",""IBCNEUT1"",64,0)"
^XMB(3.9,144657,2,6630,0)=" I NAME="""" G AMLOOKX               ; get out if NAME not present"
^XMB(3.9,144657,2,6631,0)="""RTN"",""IBCNEUT1"",65,0)"
^XMB(3.9,144657,2,6632,0)=" ;"
^XMB(3.9,144657,2,6633,0)="""RTN"",""IBCNEUT1"",66,0)"
^XMB(3.9,144657,2,6634,0)=" ; First look for direct hits in the Auto Match file"
^XMB(3.9,144657,2,6635,0)="""RTN"",""IBCNEUT1"",67,0)"
^XMB(3.9,144657,2,6636,0)=" S AMIEN=$O(^IBCN(365.11,""B"",NAME,""""))"
^XMB(3.9,144657,2,6637,0)="""RTN"",""IBCNEUT1"",68,0)"
^XMB(3.9,144657,2,6638,0)=" I AMIEN D"
^XMB(3.9,144657,2,6639,0)="""RTN"",""IBCNEUT1"",69,0)"
^XMB(3.9,144657,2,6640,0)=" . S FOUND=1"
^XMB(3.9,144657,2,6641,0)="""RTN"",""IBCNEUT1"",70,0)"
^XMB(3.9,144657,2,6642,0)=" . I 'ERRFLG Q"
^XMB(3.9,144657,2,6643,0)="""RTN"",""IBCNEUT1"",71,0)"
^XMB(3.9,144657,2,6644,0)=" . S INSNAME=$P($G(^IBCN(365.11,AMIEN,0)),U,2)"
^XMB(3.9,144657,2,6645,0)="""RTN"",""IBCNEUT1"",72,0)"
^XMB(3.9,144657,2,6646,0)=" . I INSNAME'="""" S LIST(INSNAME)=NAME"
^XMB(3.9,144657,2,6647,0)="""RTN"",""IBCNEUT1"",73,0)"
^XMB(3.9,144657,2,6648,0)=" . Q"
^XMB(3.9,144657,2,6649,0)="""RTN"",""IBCNEUT1"",74,0)"
^XMB(3.9,144657,2,6650,0)=" ;"
^XMB(3.9,144657,2,6651,0)="""RTN"",""IBCNEUT1"",75,0)"
^XMB(3.9,144657,2,6652,0)=" ; If we found one and we're not building the array, then exit"
^XMB(3.9,144657,2,6653,0)="""RTN"",""IBCNEUT1"",76,0)"
^XMB(3.9,144657,2,6654,0)=" I FOUND,'ERRFLG G AMLOOKX"
^XMB(3.9,144657,2,6655,0)="""RTN"",""IBCNEUT1"",77,0)"
^XMB(3.9,144657,2,6656,0)=" ;"
^XMB(3.9,144657,2,6657,0)="""RTN"",""IBCNEUT1"",78,0)"
^XMB(3.9,144657,2,6658,0)=" ; Use the first character of the NAME as a seed value to start"
^XMB(3.9,144657,2,6659,0)="""RTN"",""IBCNEUT1"",79,0)"
^XMB(3.9,144657,2,6660,0)=" ; looping through the Auto Match entries.  Only need to look at"
^XMB(3.9,144657,2,6661,0)="""RTN"",""IBCNEUT1"",80,0)"
^XMB(3.9,144657,2,6662,0)=" ; entries with the ""*"" wildcard character."
^XMB(3.9,144657,2,6663,0)="""RTN"",""IBCNEUT1"",81,0)"
^XMB(3.9,144657,2,6664,0)=" S AMV=$E(NAME)"
^XMB(3.9,144657,2,6665,0)="""RTN"",""IBCNEUT1"",82,0)"
^XMB(3.9,144657,2,6666,0)=" F  S AMV=$O(^IBCN(365.11,""B"",AMV)) Q:$E(AMV)'=$E(NAME)  D  I FOUND,'ERRFLG Q"
^XMB(3.9,144657,2,6667,0)="""RTN"",""IBCNEUT1"",83,0)"
^XMB(3.9,144657,2,6668,0)=" . I AMV'[""*"" Q    ; only looking for wildcarded entries"
^XMB(3.9,144657,2,6669,0)="""RTN"",""IBCNEUT1"",84,0)"
^XMB(3.9,144657,2,6670,0)=" . ;"
^XMB(3.9,144657,2,6671,0)="""RTN"",""IBCNEUT1"",85,0)"
^XMB(3.9,144657,2,6672,0)=" . ; Ensure that the first part of NAME is the same as the first"
^XMB(3.9,144657,2,6673,0)="""RTN"",""IBCNEUT1"",86,0)"
^XMB(3.9,144657,2,6674,0)=" . ; part of the Auto Match value."
^XMB(3.9,144657,2,6675,0)="""RTN"",""IBCNEUT1"",87,0)"
^XMB(3.9,144657,2,6676,0)=" . S AMVSTART=$P(AMV,""*"",1)"
^XMB(3.9,144657,2,6677,0)="""RTN"",""IBCNEUT1"",88,0)"
^XMB(3.9,144657,2,6678,0)=" . I AMVSTART'="""",$E(NAME,1,$L(AMVSTART))'=AMVSTART Q"
^XMB(3.9,144657,2,6679,0)="""RTN"",""IBCNEUT1"",89,0)"
^XMB(3.9,144657,2,6680,0)=" . ;"
^XMB(3.9,144657,2,6681,0)="""RTN"",""IBCNEUT1"",90,0)"
^XMB(3.9,144657,2,6682,0)=" . ; Build the NOMATCH variable and check it"
^XMB(3.9,144657,2,6683,0)="""RTN"",""IBCNEUT1"",91,0)"
^XMB(3.9,144657,2,6684,0)=" . D AMC(""NAME"",AMV,.NOMATCH,0)"
^XMB(3.9,144657,2,6685,0)="""RTN"",""IBCNEUT1"",92,0)"
^XMB(3.9,144657,2,6686,0)=" . I @NOMATCH Q"
^XMB(3.9,144657,2,6687,0)="""RTN"",""IBCNEUT1"",93,0)"
^XMB(3.9,144657,2,6688,0)=" . ;"
^XMB(3.9,144657,2,6689,0)="""RTN"",""IBCNEUT1"",94,0)"
^XMB(3.9,144657,2,6690,0)=" . ; We've got a match so process this accordingly"
^XMB(3.9,144657,2,6691,0)="""RTN"",""IBCNEUT1"",95,0)"
^XMB(3.9,144657,2,6692,0)=" . S FOUND=1"
^XMB(3.9,144657,2,6693,0)="""RTN"",""IBCNEUT1"",96,0)"
^XMB(3.9,144657,2,6694,0)=" . I 'ERRFLG Q"
^XMB(3.9,144657,2,6695,0)="""RTN"",""IBCNEUT1"",97,0)"
^XMB(3.9,144657,2,6696,0)=" . S AMIEN=$O(^IBCN(365.11,""B"",AMV,""""))"
^XMB(3.9,144657,2,6697,0)="""RTN"",""IBCNEUT1"",98,0)"
^XMB(3.9,144657,2,6698,0)=" . S INSNAME=$P($G(^IBCN(365.11,+AMIEN,0)),U,2)"
^XMB(3.9,144657,2,6699,0)="""RTN"",""IBCNEUT1"",99,0)"
^XMB(3.9,144657,2,6700,0)=" . I INSNAME'="""" S LIST(INSNAME)=AMV"
^XMB(3.9,144657,2,6701,0)="""RTN"",""IBCNEUT1"",100,0)"
^XMB(3.9,144657,2,6702,0)=" . Q"
^XMB(3.9,144657,2,6703,0)="""RTN"",""IBCNEUT1"",101,0)"
^XMB(3.9,144657,2,6704,0)=" ;"
^XMB(3.9,144657,2,6705,0)="""RTN"",""IBCNEUT1"",102,0)"
^XMB(3.9,144657,2,6706,0)=" ; If we found one and we're not building the array, then exit"
^XMB(3.9,144657,2,6707,0)="""RTN"",""IBCNEUT1"",103,0)"
^XMB(3.9,144657,2,6708,0)=" I FOUND,'ERRFLG G AMLOOKX"
^XMB(3.9,144657,2,6709,0)="""RTN"",""IBCNEUT1"",104,0)"
^XMB(3.9,144657,2,6710,0)=" ;"
^XMB(3.9,144657,2,6711,0)="""RTN"",""IBCNEUT1"",105,0)"
^XMB(3.9,144657,2,6712,0)=" ; Now we need to look at the Auto Match entries which start with"
^XMB(3.9,144657,2,6713,0)="""RTN"",""IBCNEUT1"",106,0)"
^XMB(3.9,144657,2,6714,0)=" ; the ""*"" wildcard character."
^XMB(3.9,144657,2,6715,0)="""RTN"",""IBCNEUT1"",107,0)"
^XMB(3.9,144657,2,6716,0)=" S AMV=""*"""
^XMB(3.9,144657,2,6717,0)="""RTN"",""IBCNEUT1"",108,0)"
^XMB(3.9,144657,2,6718,0)=" F  S AMV=$O(^IBCN(365.11,""B"",AMV)) Q:$E(AMV)'=""*""  D  I FOUND,'ERRFLG Q"
^XMB(3.9,144657,2,6719,0)="""RTN"",""IBCNEUT1"",109,0)"
^XMB(3.9,144657,2,6720,0)=" . D AMC(""NAME"",AMV,.NOMATCH,0)    ; build the NOMATCH variable"
^XMB(3.9,144657,2,6721,0)="""RTN"",""IBCNEUT1"",110,0)"
^XMB(3.9,144657,2,6722,0)=" . I @NOMATCH Q                    ; check it"
^XMB(3.9,144657,2,6723,0)="""RTN"",""IBCNEUT1"",111,0)"
^XMB(3.9,144657,2,6724,0)=" . S FOUND=1                       ; We've got a match"
^XMB(3.9,144657,2,6725,0)="""RTN"",""IBCNEUT1"",112,0)"
^XMB(3.9,144657,2,6726,0)=" . I 'ERRFLG Q"
^XMB(3.9,144657,2,6727,0)="""RTN"",""IBCNEUT1"",113,0)"
^XMB(3.9,144657,2,6728,0)=" . S AMIEN=$O(^IBCN(365.11,""B"",AMV,""""))"
^XMB(3.9,144657,2,6729,0)="""RTN"",""IBCNEUT1"",114,0)"
^XMB(3.9,144657,2,6730,0)=" . S INSNAME=$P($G(^IBCN(365.11,+AMIEN,0)),U,2)"
^XMB(3.9,144657,2,6731,0)="""RTN"",""IBCNEUT1"",115,0)"
^XMB(3.9,144657,2,6732,0)=" . I INSNAME'="""" S LIST(INSNAME)=AMV"
^XMB(3.9,144657,2,6733,0)="""RTN"",""IBCNEUT1"",116,0)"
^XMB(3.9,144657,2,6734,0)=" . Q"
^XMB(3.9,144657,2,6735,0)="""RTN"",""IBCNEUT1"",117,0)"
^XMB(3.9,144657,2,6736,0)=" ;"
^XMB(3.9,144657,2,6737,0)="""RTN"",""IBCNEUT1"",118,0)"
^XMB(3.9,144657,2,6738,0)="AMLOOKX ;"
^XMB(3.9,144657,2,6739,0)="""RTN"",""IBCNEUT1"",119,0)"
^XMB(3.9,144657,2,6740,0)=" Q FOUND"
^XMB(3.9,144657,2,6741,0)="""RTN"",""IBCNEUT1"",120,0)"
^XMB(3.9,144657,2,6742,0)=" ;"
^XMB(3.9,144657,2,6743,0)="""RTN"",""IBCNEUT1"",121,0)"
^XMB(3.9,144657,2,6744,0)=" ;"
^XMB(3.9,144657,2,6745,0)="""RTN"",""IBCNEUT1"",122,0)"
^XMB(3.9,144657,2,6746,0)="AMC(NAME,AMV,MATCH,FLAG) ; Auto Match check function"
^XMB(3.9,144657,2,6747,0)="""RTN"",""IBCNEUT1"",123,0)"
^XMB(3.9,144657,2,6748,0)=" ;"
^XMB(3.9,144657,2,6749,0)="""RTN"",""IBCNEUT1"",124,0)"
^XMB(3.9,144657,2,6750,0)=" ; NAME   - literal variable name to be matched; enclosed in quotes"
^XMB(3.9,144657,2,6751,0)="""RTN"",""IBCNEUT1"",125,0)"
^XMB(3.9,144657,2,6752,0)=" ; AMV    - Auto Match Value to be pattern matched"
^XMB(3.9,144657,2,6753,0)="""RTN"",""IBCNEUT1"",126,0)"
^XMB(3.9,144657,2,6754,0)=" ; MATCH  - Variable passed by reference; returns condition check command"
^XMB(3.9,144657,2,6755,0)="""RTN"",""IBCNEUT1"",127,0)"
^XMB(3.9,144657,2,6756,0)=" ; FLAG   - if 1, then pattern match check is positive (default)"
^XMB(3.9,144657,2,6757,0)="""RTN"",""IBCNEUT1"",128,0)"
^XMB(3.9,144657,2,6758,0)=" ;        - if 0, then pattern match check is negative"
^XMB(3.9,144657,2,6759,0)="""RTN"",""IBCNEUT1"",129,0)"
^XMB(3.9,144657,2,6760,0)=" ;"
^XMB(3.9,144657,2,6761,0)="""RTN"",""IBCNEUT1"",130,0)"
^XMB(3.9,144657,2,6762,0)=" NEW NUMPCE,J,PCE,PCE1"
^XMB(3.9,144657,2,6763,0)="""RTN"",""IBCNEUT1"",131,0)"
^XMB(3.9,144657,2,6764,0)=" S FLAG=$G(FLAG,1)"
^XMB(3.9,144657,2,6765,0)="""RTN"",""IBCNEUT1"",132,0)"
^XMB(3.9,144657,2,6766,0)=" S MATCH=NAME_$S('FLAG:""'?"",1:""?"")"
^XMB(3.9,144657,2,6767,0)="""RTN"",""IBCNEUT1"",133,0)"
^XMB(3.9,144657,2,6768,0)=" S NUMPCE=$L(AMV,""*"")"
^XMB(3.9,144657,2,6769,0)="""RTN"",""IBCNEUT1"",134,0)"
^XMB(3.9,144657,2,6770,0)=" F J=1:1:NUMPCE D"
^XMB(3.9,144657,2,6771,0)="""RTN"",""IBCNEUT1"",135,0)"
^XMB(3.9,144657,2,6772,0)=" . S PCE=$P(AMV,""*"",J),PCE1="""""
^XMB(3.9,144657,2,6773,0)="""RTN"",""IBCNEUT1"",136,0)"
^XMB(3.9,144657,2,6774,0)=" . I PCE'="""" S PCE1=""1""""""_PCE_"""""""""
^XMB(3.9,144657,2,6775,0)="""RTN"",""IBCNEUT1"",137,0)"
^XMB(3.9,144657,2,6776,0)=" . S MATCH=MATCH_PCE1"
^XMB(3.9,144657,2,6777,0)="""RTN"",""IBCNEUT1"",138,0)"
^XMB(3.9,144657,2,6778,0)=" . I J'=NUMPCE S MATCH=MATCH_"".E"""
^XMB(3.9,144657,2,6779,0)="""RTN"",""IBCNEUT1"",139,0)"
^XMB(3.9,144657,2,6780,0)=" . Q"
^XMB(3.9,144657,2,6781,0)="""RTN"",""IBCNEUT1"",140,0)"
^XMB(3.9,144657,2,6782,0)="AMCX ;"
^XMB(3.9,144657,2,6783,0)="""RTN"",""IBCNEUT1"",141,0)"
^XMB(3.9,144657,2,6784,0)=" Q"
^XMB(3.9,144657,2,6785,0)="""RTN"",""IBCNEUT1"",142,0)"
^XMB(3.9,144657,2,6786,0)=" ;"
^XMB(3.9,144657,2,6787,0)="""RTN"",""IBCNEUT1"",143,0)"
^XMB(3.9,144657,2,6788,0)=" ;"
^XMB(3.9,144657,2,6789,0)="""RTN"",""IBCNEUT1"",144,0)"
^XMB(3.9,144657,2,6790,0)="AMSEL(AMARRAY) ; Select an insurance company name from an Auto Match hit list"
^XMB(3.9,144657,2,6791,0)="""RTN"",""IBCNEUT1"",145,0)"
^XMB(3.9,144657,2,6792,0)=" ;"
^XMB(3.9,144657,2,6793,0)="""RTN"",""IBCNEUT1"",146,0)"
^XMB(3.9,144657,2,6794,0)=" ; Input"
^XMB(3.9,144657,2,6795,0)="""RTN"",""IBCNEUT1"",147,0)"
^XMB(3.9,144657,2,6796,0)=" ;   Array of Auto Match hits.  The structure of this array is the"
^XMB(3.9,144657,2,6797,0)="""RTN"",""IBCNEUT1"",148,0)"
^XMB(3.9,144657,2,6798,0)=" ;   same as that returned by the call to $$AMLOOK above."
^XMB(3.9,144657,2,6799,0)="""RTN"",""IBCNEUT1"",149,0)"
^XMB(3.9,144657,2,6800,0)=" ;   AMARRAY(ins co name) = Auto Match value"
^XMB(3.9,144657,2,6801,0)="""RTN"",""IBCNEUT1"",150,0)"
^XMB(3.9,144657,2,6802,0)=" ;"
^XMB(3.9,144657,2,6803,0)="""RTN"",""IBCNEUT1"",151,0)"
^XMB(3.9,144657,2,6804,0)=" ; Output"
^XMB(3.9,144657,2,6805,0)="""RTN"",""IBCNEUT1"",152,0)"
^XMB(3.9,144657,2,6806,0)=" ;   Insurance Company name (subscript of input array), or"
^XMB(3.9,144657,2,6807,0)="""RTN"",""IBCNEUT1"",153,0)"
^XMB(3.9,144657,2,6808,0)=" ;   -1 if user entered ""^"" or timed out, or"
^XMB(3.9,144657,2,6809,0)="""RTN"",""IBCNEUT1"",154,0)"
^XMB(3.9,144657,2,6810,0)=" ;   0 if user didn't select any of these names"
^XMB(3.9,144657,2,6811,0)="""RTN"",""IBCNEUT1"",155,0)"
^XMB(3.9,144657,2,6812,0)=" ;   No changes are made to the array."
^XMB(3.9,144657,2,6813,0)="""RTN"",""IBCNEUT1"",156,0)"
^XMB(3.9,144657,2,6814,0)=" ;"
^XMB(3.9,144657,2,6815,0)="""RTN"",""IBCNEUT1"",157,0)"
^XMB(3.9,144657,2,6816,0)=" NEW SEL,NM,CNT,MSG,MSGNUM,CH,TXT"
^XMB(3.9,144657,2,6817,0)="""RTN"",""IBCNEUT1"",158,0)"
^XMB(3.9,144657,2,6818,0)=" NEW DIR,X,Y,DIRUT,DTOUT,DUOUT,DIROUT"
^XMB(3.9,144657,2,6819,0)="""RTN"",""IBCNEUT1"",159,0)"
^XMB(3.9,144657,2,6820,0)=" S SEL=0"
^XMB(3.9,144657,2,6821,0)="""RTN"",""IBCNEUT1"",160,0)"
^XMB(3.9,144657,2,6822,0)=" I '$D(AMARRAY) G AMSELX    ; Get out if array not passed in"
^XMB(3.9,144657,2,6823,0)="""RTN"",""IBCNEUT1"",161,0)"
^XMB(3.9,144657,2,6824,0)=" ;"
^XMB(3.9,144657,2,6825,0)="""RTN"",""IBCNEUT1"",162,0)"
^XMB(3.9,144657,2,6826,0)=" ; Display the contents of the array"
^XMB(3.9,144657,2,6827,0)="""RTN"",""IBCNEUT1"",163,0)"
^XMB(3.9,144657,2,6828,0)=" S MSG(1)=""Results of Auto Match search"""
^XMB(3.9,144657,2,6829,0)="""RTN"",""IBCNEUT1"",164,0)"
^XMB(3.9,144657,2,6830,0)=" S MSG(2)="""""
^XMB(3.9,144657,2,6831,0)="""RTN"",""IBCNEUT1"",165,0)"
^XMB(3.9,144657,2,6832,0)=" S MSG(3)=""  ""_$$FO(""Insurance Company Name"",30)_""   Auto Match Value"""
^XMB(3.9,144657,2,6833,0)="""RTN"",""IBCNEUT1"",166,0)"
^XMB(3.9,144657,2,6834,0)=" S MSG(4)=""  ""_$$FO(""----------------------"",30)_""   ----------------"""
^XMB(3.9,144657,2,6835,0)="""RTN"",""IBCNEUT1"",167,0)"
^XMB(3.9,144657,2,6836,0)=" S MSG(1,""F"")=""!!"""
^XMB(3.9,144657,2,6837,0)="""RTN"",""IBCNEUT1"",168,0)"
^XMB(3.9,144657,2,6838,0)=" S NM="""",MSGNUM=$O(MSG(""""),-1),CNT=0,CH="""""
^XMB(3.9,144657,2,6839,0)="""RTN"",""IBCNEUT1"",169,0)"
^XMB(3.9,144657,2,6840,0)=" F  S NM=$O(AMARRAY(NM)) Q:NM=""""  D"
^XMB(3.9,144657,2,6841,0)="""RTN"",""IBCNEUT1"",170,0)"
^XMB(3.9,144657,2,6842,0)=" . S CNT=CNT+1"
^XMB(3.9,144657,2,6843,0)="""RTN"",""IBCNEUT1"",171,0)"
^XMB(3.9,144657,2,6844,0)=" . S TXT=$$FO(NM,30)_""   ""_AMARRAY(NM)"
^XMB(3.9,144657,2,6845,0)="""RTN"",""IBCNEUT1"",172,0)"
^XMB(3.9,144657,2,6846,0)=" . S MSGNUM=MSGNUM+1"
^XMB(3.9,144657,2,6847,0)="""RTN"",""IBCNEUT1"",173,0)"
^XMB(3.9,144657,2,6848,0)=" . S MSG(MSGNUM)=""  ""_TXT"
^XMB(3.9,144657,2,6849,0)="""RTN"",""IBCNEUT1"",174,0)"
^XMB(3.9,144657,2,6850,0)=" . I $L(CH)>440 Q"
^XMB(3.9,144657,2,6851,0)="""RTN"",""IBCNEUT1"",175,0)"
^XMB(3.9,144657,2,6852,0)=" . I CH="""" S CH=CNT_"":""_TXT       ; building the set of codes string"
^XMB(3.9,144657,2,6853,0)="""RTN"",""IBCNEUT1"",176,0)"
^XMB(3.9,144657,2,6854,0)=" . E  S CH=CH_"";""_CNT_"":""_TXT     ; for the DIR reader later on"
^XMB(3.9,144657,2,6855,0)="""RTN"",""IBCNEUT1"",177,0)"
^XMB(3.9,144657,2,6856,0)=" . Q"
^XMB(3.9,144657,2,6857,0)="""RTN"",""IBCNEUT1"",178,0)"
^XMB(3.9,144657,2,6858,0)=" ;"
^XMB(3.9,144657,2,6859,0)="""RTN"",""IBCNEUT1"",179,0)"
^XMB(3.9,144657,2,6860,0)=" ; Get out if there are no entries in the list"
^XMB(3.9,144657,2,6861,0)="""RTN"",""IBCNEUT1"",180,0)"
^XMB(3.9,144657,2,6862,0)=" I 'CNT G AMSELX"
^XMB(3.9,144657,2,6863,0)="""RTN"",""IBCNEUT1"",181,0)"
^XMB(3.9,144657,2,6864,0)=" ;"
^XMB(3.9,144657,2,6865,0)="""RTN"",""IBCNEUT1"",182,0)"
^XMB(3.9,144657,2,6866,0)=" ; One more blank line in the display"
^XMB(3.9,144657,2,6867,0)="""RTN"",""IBCNEUT1"",183,0)"
^XMB(3.9,144657,2,6868,0)=" S MSGNUM=MSGNUM+1"
^XMB(3.9,144657,2,6869,0)="""RTN"",""IBCNEUT1"",184,0)"
^XMB(3.9,144657,2,6870,0)=" S MSG(MSGNUM)="""""
^XMB(3.9,144657,2,6871,0)="""RTN"",""IBCNEUT1"",185,0)"
^XMB(3.9,144657,2,6872,0)=" ;"
^XMB(3.9,144657,2,6873,0)="""RTN"",""IBCNEUT1"",186,0)"
^XMB(3.9,144657,2,6874,0)=" ; Display the entries in the list"
^XMB(3.9,144657,2,6875,0)="""RTN"",""IBCNEUT1"",187,0)"
^XMB(3.9,144657,2,6876,0)=" DO EN^DDIOL(.MSG)"
^XMB(3.9,144657,2,6877,0)="""RTN"",""IBCNEUT1"",188,0)"
^XMB(3.9,144657,2,6878,0)=" ;"
^XMB(3.9,144657,2,6879,0)="""RTN"",""IBCNEUT1"",189,0)"
^XMB(3.9,144657,2,6880,0)=" ; Ask the first question"
^XMB(3.9,144657,2,6881,0)="""RTN"",""IBCNEUT1"",190,0)"
^XMB(3.9,144657,2,6882,0)=" S DIR(0)=""YO"""
^XMB(3.9,144657,2,6883,0)="""RTN"",""IBCNEUT1"",191,0)"
^XMB(3.9,144657,2,6884,0)=" S DIR(""A"")=""Would you like to select this insurance company"""
^XMB(3.9,144657,2,6885,0)="""RTN"",""IBCNEUT1"",192,0)"
^XMB(3.9,144657,2,6886,0)=" I CNT>1 S DIR(""A"")=""Would you like to select one of these insurance companies"""
^XMB(3.9,144657,2,6887,0)="""RTN"",""IBCNEUT1"",193,0)"
^XMB(3.9,144657,2,6888,0)=" S DIR(""B"")=""Yes"""
^XMB(3.9,144657,2,6889,0)="""RTN"",""IBCNEUT1"",194,0)"
^XMB(3.9,144657,2,6890,0)=" D ^DIR K DIR"
^XMB(3.9,144657,2,6891,0)="""RTN"",""IBCNEUT1"",195,0)"
^XMB(3.9,144657,2,6892,0)=" I $D(DIRUT) S SEL=-1 G AMSELX"
^XMB(3.9,144657,2,6893,0)="""RTN"",""IBCNEUT1"",196,0)"
^XMB(3.9,144657,2,6894,0)=" I 'Y S SEL=0 G AMSELX"
^XMB(3.9,144657,2,6895,0)="""RTN"",""IBCNEUT1"",197,0)"
^XMB(3.9,144657,2,6896,0)=" ;"
^XMB(3.9,144657,2,6897,0)="""RTN"",""IBCNEUT1"",198,0)"
^XMB(3.9,144657,2,6898,0)=" ; User said Yes to the above question"
^XMB(3.9,144657,2,6899,0)="""RTN"",""IBCNEUT1"",199,0)"
^XMB(3.9,144657,2,6900,0)=" ; Get out if there is only one entry in the array"
^XMB(3.9,144657,2,6901,0)="""RTN"",""IBCNEUT1"",200,0)"
^XMB(3.9,144657,2,6902,0)=" I CNT=1 S SEL=$O(AMARRAY("""")) G AMSELX"
^XMB(3.9,144657,2,6903,0)="""RTN"",""IBCNEUT1"",201,0)"
^XMB(3.9,144657,2,6904,0)=" ;"
^XMB(3.9,144657,2,6905,0)="""RTN"",""IBCNEUT1"",202,0)"
^XMB(3.9,144657,2,6906,0)=" ; At this point we know there are multiple entries in the list"
^XMB(3.9,144657,2,6907,0)="""RTN"",""IBCNEUT1"",203,0)"
^XMB(3.9,144657,2,6908,0)=" S DIR(0)=""SO^""_CH"
^XMB(3.9,144657,2,6909,0)="""RTN"",""IBCNEUT1"",204,0)"
^XMB(3.9,144657,2,6910,0)=" S DIR(""A"")=""Please choose an insurance company"""
^XMB(3.9,144657,2,6911,0)="""RTN"",""IBCNEUT1"",205,0)"
^XMB(3.9,144657,2,6912,0)=" D ^DIR K DIR"
^XMB(3.9,144657,2,6913,0)="""RTN"",""IBCNEUT1"",206,0)"
^XMB(3.9,144657,2,6914,0)=" I $D(DIRUT) S SEL=-1 G AMSELX"
^XMB(3.9,144657,2,6915,0)="""RTN"",""IBCNEUT1"",207,0)"
^XMB(3.9,144657,2,6916,0)=" I 'Y S SEL=0 G AMSELX"
^XMB(3.9,144657,2,6917,0)="""RTN"",""IBCNEUT1"",208,0)"
^XMB(3.9,144657,2,6918,0)=" S SEL=$$TRIM^XLFSTR($E(Y(0),1,30),""R"")    ; strip trailing spaces"
^XMB(3.9,144657,2,6919,0)="""RTN"",""IBCNEUT1"",209,0)"
^XMB(3.9,144657,2,6920,0)="AMSELX ;"
^XMB(3.9,144657,2,6921,0)="""RTN"",""IBCNEUT1"",210,0)"
^XMB(3.9,144657,2,6922,0)=" Q SEL"
^XMB(3.9,144657,2,6923,0)="""RTN"",""IBCNEUT1"",211,0)"
^XMB(3.9,144657,2,6924,0)=" ;"
^XMB(3.9,144657,2,6925,0)="""RTN"",""IBCNEUT1"",212,0)"
^XMB(3.9,144657,2,6926,0)="LENCHK(VAL,MAX,NUMFLG) ; check value length, called from input transforms on eIV fields"
^XMB(3.9,144657,2,6927,0)="""RTN"",""IBCNEUT1"",213,0)"
^XMB(3.9,144657,2,6928,0)=" ; VAL - value to check"
^XMB(3.9,144657,2,6929,0)="""RTN"",""IBCNEUT1"",214,0)"
^XMB(3.9,144657,2,6930,0)=" ; MAX - max. allowed length for free text field, or max. value for numeric field"
^XMB(3.9,144657,2,6931,0)="""RTN"",""IBCNEUT1"",215,0)"
^XMB(3.9,144657,2,6932,0)=" ; NUMFLG - 1 if field is numeric, 0 if free text"
^XMB(3.9,144657,2,6933,0)="""RTN"",""IBCNEUT1"",216,0)"
^XMB(3.9,144657,2,6934,0)=" ;"
^XMB(3.9,144657,2,6935,0)="""RTN"",""IBCNEUT1"",217,0)"
^XMB(3.9,144657,2,6936,0)=" ; returns 1 if length is acceptable, 0 otherwise"
^XMB(3.9,144657,2,6937,0)="""RTN"",""IBCNEUT1"",218,0)"
^XMB(3.9,144657,2,6938,0)=" N RES"
^XMB(3.9,144657,2,6939,0)="""RTN"",""IBCNEUT1"",219,0)"
^XMB(3.9,144657,2,6940,0)=" S RES=1"
^XMB(3.9,144657,2,6941,0)="""RTN"",""IBCNEUT1"",220,0)"
^XMB(3.9,144657,2,6942,0)=" ; check IB site parameter"
^XMB(3.9,144657,2,6943,0)="""RTN"",""IBCNEUT1"",221,0)"
^XMB(3.9,144657,2,6944,0)=" I '+$P($G(^IBE(350.9,1,62)),U) G LENCHKX"
^XMB(3.9,144657,2,6945,0)="""RTN"",""IBCNEUT1"",222,0)"
^XMB(3.9,144657,2,6946,0)=" I $S(NUMFLG:VAL,1:$L(VAL))>MAX S RES=0"
^XMB(3.9,144657,2,6947,0)="""RTN"",""IBCNEUT1"",223,0)"
^XMB(3.9,144657,2,6948,0)="LENCHKX ;"
^XMB(3.9,144657,2,6949,0)="""RTN"",""IBCNEUT1"",224,0)"
^XMB(3.9,144657,2,6950,0)=" Q RES"
^XMB(3.9,144657,2,6951,0)="""RTN"",""IBCNEUT1"",225,0)"
^XMB(3.9,144657,2,6952,0)=" ;"
