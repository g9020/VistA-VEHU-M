^XMB(3.9,144657,2,1186,0)=" Q $S((Y'=-1&(Y]"""")&($E(Y)'=U))&($L($G(Y),U)'=2):Y_U_$G(Y(0),Y),$G(X)=""@"":""@"",1:Y)"
