^XMB(3.9,144661,2,365,0)="""RTN"",""ORAM1"",63,0)"
^XMB(3.9,144661,2,366,0)=" N ORAMD0,ORAMD4,ORAMD5,ORAMD6,ORAMD9,ORAMD15,ORAMD17,ORAMD18"
^XMB(3.9,144661,2,367,0)="""RTN"",""ORAM1"",64,0)"
^XMB(3.9,144661,2,368,0)=" N ORAMT4,ORAMT5,ORAMT6,ORAMT9,ORAMT15,ORAMT17,ORAMT18,ORAMDXT,ORAMDXC,ORDXI,ORAMPOP"
