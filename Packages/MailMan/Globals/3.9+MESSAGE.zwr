^XMB(3.9,145837,2,504,0)=" ; Note: if there are error messages or we can't create an entry for some reason, it simply returns and continues"
^XMB(3.9,145837,2,505,0)="""RTN"",""XQALSET"",133,0)"
^XMB(3.9,145837,2,506,0)=" N FDA,IENS,XQA2,DIERR"
