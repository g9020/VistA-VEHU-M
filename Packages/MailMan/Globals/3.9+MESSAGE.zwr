^XMB(3.9,144657,2,5135,0)="""RTN"",""IBCNEQU"",214,0)"
^XMB(3.9,144657,2,5136,0)=" S DIR(""?"",3)=""  Buffer entry will be created for nightly batch extract."""
^XMB(3.9,144657,2,5137,0)="""RTN"",""IBCNEQU"",215,0)"
