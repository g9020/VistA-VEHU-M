^XMB(3.9,145834,2,2708,0)=" N ACNUMB,BATCHSIZE,BEGDATE,DFN,ENDDATE,HOSTNAME,HOURS,IMAGINGSERVICE,OPTION,QRSCP,QRSTACK"
^XMB(3.9,145834,2,2709,0)="""RTN"",""MAGDSTA1"",31,0)"
^XMB(3.9,145834,2,2710,0)=" N MAGIOM,MAGXTMP,RUNTIME,SCANMODE,SORTORDER,STARTIEN,STARTTIME,STATUS,STUDYDATE,STUDYIEN"
^XMB(3.9,145834,2,2711,0)="""RTN"",""MAGDSTA1"",32,0)"
^XMB(3.9,145834,2,2712,0)=" N CONSULTSERVICES,DEFAULT,DIVISION,DONE,ERROR,I,LASTRUN,OK,QUESTION,QUIT,SERVICES,X,ZTDESC"
^XMB(3.9,145834,2,2713,0)="""RTN"",""MAGDSTA1"",33,0)"
^XMB(3.9,145834,2,2714,0)=" ;"
^XMB(3.9,145834,2,2715,0)="""RTN"",""MAGDSTA1"",34,0)"
^XMB(3.9,145834,2,2716,0)=" N $ETRAP,$ESTACK S $ETRAP=""D ERROR^MAGDSTA"""
^XMB(3.9,145834,2,2717,0)="""RTN"",""MAGDSTA1"",35,0)"
^XMB(3.9,145834,2,2718,0)=" ;"
^XMB(3.9,145834,2,2719,0)="""RTN"",""MAGDSTA1"",36,0)"
^XMB(3.9,145834,2,2720,0)=" ; application-wide variables"
^XMB(3.9,145834,2,2721,0)="""RTN"",""MAGDSTA1"",37,0)"
^XMB(3.9,145834,2,2722,0)=" S OPTION=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION""))"
^XMB(3.9,145834,2,2723,0)="""RTN"",""MAGDSTA1"",38,0)"
^XMB(3.9,145834,2,2724,0)=" S IMAGINGSERVICE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""IMAGING SERVICE""))"
^XMB(3.9,145834,2,2725,0)="""RTN"",""MAGDSTA1"",39,0)"
^XMB(3.9,145834,2,2726,0)=" S QRSTACK=""AUTOMATIC"""
^XMB(3.9,145834,2,2727,0)="""RTN"",""MAGDSTA1"",40,0)"
^XMB(3.9,145834,2,2728,0)=" S HOSTNAME=$$HOSTNAME^MAGDFCNV"
^XMB(3.9,145834,2,2729,0)="""RTN"",""MAGDSTA1"",41,0)"
^XMB(3.9,145834,2,2730,0)="  I $$CHECKDIV^MAGDSTAB()="""" D  Q"
^XMB(3.9,145834,2,2731,0)="""RTN"",""MAGDSTA1"",42,0)"
^XMB(3.9,145834,2,2732,0)=" . W !!,""*** Use the PARM option to set Check Study Division switch ***"""
^XMB(3.9,145834,2,2733,0)="""RTN"",""MAGDSTA1"",43,0)"
^XMB(3.9,145834,2,2734,0)=" . D CONTINUE^MAGDSTQ"
^XMB(3.9,145834,2,2735,0)="""RTN"",""MAGDSTA1"",44,0)"
^XMB(3.9,145834,2,2736,0)=" . Q"
^XMB(3.9,145834,2,2737,0)="""RTN"",""MAGDSTA1"",45,0)"
^XMB(3.9,145834,2,2738,0)=" S DIVISION=$G(DUZ(2),0) ; user's logon division"
^XMB(3.9,145834,2,2739,0)="""RTN"",""MAGDSTA1"",46,0)"
^XMB(3.9,145834,2,2740,0)=" I $$CHECKDIV^MAGDSTAB()=""Y"",'DIVISION D  Q"
^XMB(3.9,145834,2,2741,0)="""RTN"",""MAGDSTA1"",47,0)"
^XMB(3.9,145834,2,2742,0)=" . W !!,""*** User's Division is not defined ***"""
^XMB(3.9,145834,2,2743,0)="""RTN"",""MAGDSTA1"",48,0)"
^XMB(3.9,145834,2,2744,0)=" . D CONTINUE^MAGDSTQ"
^XMB(3.9,145834,2,2745,0)="""RTN"",""MAGDSTA1"",49,0)"
^XMB(3.9,145834,2,2746,0)=" . Q"
^XMB(3.9,145834,2,2747,0)="""RTN"",""MAGDSTA1"",50,0)"
^XMB(3.9,145834,2,2748,0)=" ;"
^XMB(3.9,145834,2,2749,0)="""RTN"",""MAGDSTA1"",51,0)"
^XMB(3.9,145834,2,2750,0)=" S MAGXTMP=$$INITXTMP^MAGDSTQ0"
^XMB(3.9,145834,2,2751,0)="""RTN"",""MAGDSTA1"",52,0)"
^XMB(3.9,145834,2,2752,0)=" ;"
^XMB(3.9,145834,2,2753,0)="""RTN"",""MAGDSTA1"",53,0)"
^XMB(3.9,145834,2,2754,0)=" S DEFAULT=$G(^TMP(""MAG"",$J,""Q/R PARAM"",""SCAN MODE""),""DATE"")"
^XMB(3.9,145834,2,2755,0)="""RTN"",""MAGDSTA1"",54,0)"
^XMB(3.9,145834,2,2756,0)=" W ! S OK=0 F  D  Q:OK"
^XMB(3.9,145834,2,2757,0)="""RTN"",""MAGDSTA1"",55,0)"
^XMB(3.9,145834,2,2758,0)=" . I IMAGINGSERVICE=""RADIOLOGY"" D"
^XMB(3.9,145834,2,2759,0)="""RTN"",""MAGDSTA1"",56,0)"
^XMB(3.9,145834,2,2760,0)=" . . W !!,""Scan by Date, Report Number, Patient, or Accession (D, N, P, or A): """
^XMB(3.9,145834,2,2761,0)="""RTN"",""MAGDSTA1"",57,0)"
^XMB(3.9,145834,2,2762,0)=" . . Q"
^XMB(3.9,145834,2,2763,0)="""RTN"",""MAGDSTA1"",58,0)"
^XMB(3.9,145834,2,2764,0)=" . E  D"
^XMB(3.9,145834,2,2765,0)="""RTN"",""MAGDSTA1"",59,0)"
^XMB(3.9,145834,2,2766,0)=" . . W !!,""Scan by Date, Consult Number, Patient, or Accession (D, N, P, or A): """
^XMB(3.9,145834,2,2767,0)="""RTN"",""MAGDSTA1"",60,0)"
^XMB(3.9,145834,2,2768,0)=" . . Q"
^XMB(3.9,145834,2,2769,0)="""RTN"",""MAGDSTA1"",61,0)"
^XMB(3.9,145834,2,2770,0)=" . I $L(DEFAULT) W DEFAULT,""// """
^XMB(3.9,145834,2,2771,0)="""RTN"",""MAGDSTA1"",62,0)"
^XMB(3.9,145834,2,2772,0)=" . R X:DTIME E  S OK=-1 Q"
^XMB(3.9,145834,2,2773,0)="""RTN"",""MAGDSTA1"",63,0)"
^XMB(3.9,145834,2,2774,0)=" . I X="""",$L(DEFAULT) S X=DEFAULT W X"
^XMB(3.9,145834,2,2775,0)="""RTN"",""MAGDSTA1"",64,0)"
^XMB(3.9,145834,2,2776,0)=" . I X="""" S OK=-1 Q"
^XMB(3.9,145834,2,2777,0)="""RTN"",""MAGDSTA1"",65,0)"
^XMB(3.9,145834,2,2778,0)=" . I X[""^"" S OK=-1 Q"
^XMB(3.9,145834,2,2779,0)="""RTN"",""MAGDSTA1"",66,0)"
^XMB(3.9,145834,2,2780,0)=" . I ""Dd""[$E(X) S SCANMODE=""DATE"",OK=1 Q"
^XMB(3.9,145834,2,2781,0)="""RTN"",""MAGDSTA1"",67,0)"
^XMB(3.9,145834,2,2782,0)=" . I ""Nn""[$E(X) S SCANMODE=""NUMBER"",OK=1 Q"
^XMB(3.9,145834,2,2783,0)="""RTN"",""MAGDSTA1"",68,0)"
^XMB(3.9,145834,2,2784,0)=" . I ""Pp""[$E(X) S SCANMODE=""PATIENT"",OK=1 Q"
^XMB(3.9,145834,2,2785,0)="""RTN"",""MAGDSTA1"",69,0)"
^XMB(3.9,145834,2,2786,0)=" . I ""Aa""[$E(X) S SCANMODE=""ACCESSION"",OK=1 Q"
^XMB(3.9,145834,2,2787,0)="""RTN"",""MAGDSTA1"",70,0)"
^XMB(3.9,145834,2,2788,0)=" . W ""   ???"",!,""Please enter """"D"""", """"N"""", """"P"""", or """"A""""."""
^XMB(3.9,145834,2,2789,0)="""RTN"",""MAGDSTA1"",71,0)"
^XMB(3.9,145834,2,2790,0)=" . Q"
^XMB(3.9,145834,2,2791,0)="""RTN"",""MAGDSTA1"",72,0)"
^XMB(3.9,145834,2,2792,0)=" Q:OK'=1  ; didn't enter a choice"
^XMB(3.9,145834,2,2793,0)="""RTN"",""MAGDSTA1"",73,0)"
^XMB(3.9,145834,2,2794,0)=" S ^TMP(""MAG"",$J,""Q/R PARAM"",""SCAN MODE"")=SCANMODE"
^XMB(3.9,145834,2,2795,0)="""RTN"",""MAGDSTA1"",74,0)"
^XMB(3.9,145834,2,2796,0)=" ;"
^XMB(3.9,145834,2,2797,0)="""RTN"",""MAGDSTA1"",75,0)"
^XMB(3.9,145834,2,2798,0)=" ; get parameters of last run"
^XMB(3.9,145834,2,2799,0)="""RTN"",""MAGDSTA1"",76,0)"
^XMB(3.9,145834,2,2800,0)=" S LASTRUN=$O(^MAGDSTT(2006.543,""C"",MENUOPTION,$E(SCANMODE,1),""""),-1)"
^XMB(3.9,145834,2,2801,0)="""RTN"",""MAGDSTA1"",77,0)"
^XMB(3.9,145834,2,2802,0)=" I LASTRUN D"
^XMB(3.9,145834,2,2803,0)="""RTN"",""MAGDSTA1"",78,0)"
^XMB(3.9,145834,2,2804,0)=" . S X=""Parameters of the Previous ""_SCANMODE_"" Run"""
^XMB(3.9,145834,2,2805,0)="""RTN"",""MAGDSTA1"",79,0)"
^XMB(3.9,145834,2,2806,0)=" . W !!?10,X,!?10 F I=1:1:$L(X) W ""-"""
^XMB(3.9,145834,2,2807,0)="""RTN"",""MAGDSTA1"",80,0)"
^XMB(3.9,145834,2,2808,0)=" . D LASTRUN^MAGDSTAS(LASTRUN)"
^XMB(3.9,145834,2,2809,0)="""RTN"",""MAGDSTA1"",81,0)"
^XMB(3.9,145834,2,2810,0)=" . D DISPLAY1^MAGDSTA9"
^XMB(3.9,145834,2,2811,0)="""RTN"",""MAGDSTA1"",82,0)"
^XMB(3.9,145834,2,2812,0)=" . I STATUS=""COMPLETED"" D"
^XMB(3.9,145834,2,2813,0)="""RTN"",""MAGDSTA1"",83,0)"
^XMB(3.9,145834,2,2814,0)=" . . W !!,""The last "",SCANMODE,"" scan run completed on "",$$FMTE^XLFDT(RUNTIME)"
^XMB(3.9,145834,2,2815,0)="""RTN"",""MAGDSTA1"",84,0)"
^XMB(3.9,145834,2,2816,0)=" . . S ERROR=$$YESNO^MAGDSTQ(""Start this ""_SCANMODE_"" scan where the last run ended?"",""y"",.X)"
^XMB(3.9,145834,2,2817,0)="""RTN"",""MAGDSTA1"",85,0)"
^XMB(3.9,145834,2,2818,0)=" . . I ERROR<0 W "" YESNO ERROR"" Q"
^XMB(3.9,145834,2,2819,0)="""RTN"",""MAGDSTA1"",86,0)"
^XMB(3.9,145834,2,2820,0)=" . . I X=""YES"" D"
^XMB(3.9,145834,2,2821,0)="""RTN"",""MAGDSTA1"",87,0)"
^XMB(3.9,145834,2,2822,0)=" . . . D COPYPARM(1)"
^XMB(3.9,145834,2,2823,0)="""RTN"",""MAGDSTA1"",88,0)"
