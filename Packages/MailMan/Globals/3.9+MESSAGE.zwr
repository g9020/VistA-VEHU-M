^XMB(3.9,145834,2,5371,0)="""RTN"",""MAGDSTA9"",16,0)"
^XMB(3.9,145834,2,5372,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,5373,0)="""RTN"",""MAGDSTA9"",17,0)"
^XMB(3.9,145834,2,5374,0)=" ;;"
^XMB(3.9,145834,2,5375,0)="""RTN"",""MAGDSTA9"",18,0)"
^XMB(3.9,145834,2,5376,0)=" ;"
^XMB(3.9,145834,2,5377,0)="""RTN"",""MAGDSTA9"",19,0)"
^XMB(3.9,145834,2,5378,0)=" ; Supported IA #10061 reference DEM^VADPT subroutine call"
^XMB(3.9,145834,2,5379,0)="""RTN"",""MAGDSTA9"",20,0)"
^XMB(3.9,145834,2,5380,0)=" ; Supported IA #10103 reference $$FMTE^XLFDT function call"
^XMB(3.9,145834,2,5381,0)="""RTN"",""MAGDSTA9"",21,0)"
^XMB(3.9,145834,2,5382,0)=" ;"
^XMB(3.9,145834,2,5383,0)="""RTN"",""MAGDSTA9"",22,0)"
^XMB(3.9,145834,2,5384,0)=" Q"
^XMB(3.9,145834,2,5385,0)="""RTN"",""MAGDSTA9"",23,0)"
^XMB(3.9,145834,2,5386,0)=" ;"
^XMB(3.9,145834,2,5387,0)="""RTN"",""MAGDSTA9"",24,0)"
^XMB(3.9,145834,2,5388,0)="VERIFY ; get the parameters for this run"
^XMB(3.9,145834,2,5389,0)="""RTN"",""MAGDSTA9"",25,0)"
^XMB(3.9,145834,2,5390,0)=" N PROMPT,X"
^XMB(3.9,145834,2,5391,0)="""RTN"",""MAGDSTA9"",26,0)"
^XMB(3.9,145834,2,5392,0)=" W !!!?10,""F i n a l  P a r a m e t e r   C h e c k l i s t"""
^XMB(3.9,145834,2,5393,0)="""RTN"",""MAGDSTA9"",27,0)"
^XMB(3.9,145834,2,5394,0)=" W !?10,""------------------------------------------------"""
^XMB(3.9,145834,2,5395,0)="""RTN"",""MAGDSTA9"",28,0)"
^XMB(3.9,145834,2,5396,0)=" D DISPLAY"
^XMB(3.9,145834,2,5397,0)="""RTN"",""MAGDSTA9"",29,0)"
^XMB(3.9,145834,2,5398,0)=" I ^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION"")=""RETRIEVE MISSING IMAGES"" D"
^XMB(3.9,145834,2,5399,0)="""RTN"",""MAGDSTA9"",30,0)"
^XMB(3.9,145834,2,5400,0)=" . S PROMPT=""Ready to retrieve missing DICOM images?"""
^XMB(3.9,145834,2,5401,0)="""RTN"",""MAGDSTA9"",31,0)"
^XMB(3.9,145834,2,5402,0)=" . Q"
^XMB(3.9,145834,2,5403,0)="""RTN"",""MAGDSTA9"",32,0)"
^XMB(3.9,145834,2,5404,0)=" E  S PROMPT=""Ready to compare image counts?"""
^XMB(3.9,145834,2,5405,0)="""RTN"",""MAGDSTA9"",33,0)"
^XMB(3.9,145834,2,5406,0)=" I $$YESNO^MAGDSTQ(PROMPT,""y"",.X)<0 S QUIT=1 Q"
^XMB(3.9,145834,2,5407,0)="""RTN"",""MAGDSTA9"",34,0)"
^XMB(3.9,145834,2,5408,0)=" I X=""YES"" S QUIT=0"
^XMB(3.9,145834,2,5409,0)="""RTN"",""MAGDSTA9"",35,0)"
^XMB(3.9,145834,2,5410,0)=" E  W "" -- "",^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION""),"" not started"" S QUIT=-1"
^XMB(3.9,145834,2,5411,0)="""RTN"",""MAGDSTA9"",36,0)"
^XMB(3.9,145834,2,5412,0)=" Q"
^XMB(3.9,145834,2,5413,0)="""RTN"",""MAGDSTA9"",37,0)"
^XMB(3.9,145834,2,5414,0)=" ;"
^XMB(3.9,145834,2,5415,0)="""RTN"",""MAGDSTA9"",38,0)"
^XMB(3.9,145834,2,5416,0)="DISPLAY ; get and display the parameters"
^XMB(3.9,145834,2,5417,0)="""RTN"",""MAGDSTA9"",39,0)"
^XMB(3.9,145834,2,5418,0)=" N BATCHSIZE,BEGDATE,DFN,DILOCKTM,DISYS,DOB,ENDDATE,HOURS,IMAGINGSERVICE"
^XMB(3.9,145834,2,5419,0)="""RTN"",""MAGDSTA9"",40,0)"
^XMB(3.9,145834,2,5420,0)=" N NAME,OPTION,QRSCP,SCANMODE,SERVICE,SORTORDER,SSN"
^XMB(3.9,145834,2,5421,0)="""RTN"",""MAGDSTA9"",41,0)"
^XMB(3.9,145834,2,5422,0)=" ;"
^XMB(3.9,145834,2,5423,0)="""RTN"",""MAGDSTA9"",42,0)"
^XMB(3.9,145834,2,5424,0)=" N ACNUMB,STATUS,STUDYDATE,STUDYIEN ; not set"
^XMB(3.9,145834,2,5425,0)="""RTN"",""MAGDSTA9"",43,0)"
^XMB(3.9,145834,2,5426,0)=" ;"
^XMB(3.9,145834,2,5427,0)="""RTN"",""MAGDSTA9"",44,0)"
^XMB(3.9,145834,2,5428,0)=" S IMAGINGSERVICE=^TMP(""MAG"",$J,""BATCH Q/R"",""IMAGING SERVICE"")"
^XMB(3.9,145834,2,5429,0)="""RTN"",""MAGDSTA9"",45,0)"
^XMB(3.9,145834,2,5430,0)=" S QRSCP=^TMP(""MAG"",$J,""BATCH Q/R"",""PACS Q/R RETRIEVE SCP"")"
^XMB(3.9,145834,2,5431,0)="""RTN"",""MAGDSTA9"",46,0)"
^XMB(3.9,145834,2,5432,0)=" S OPTION=^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION"")"
^XMB(3.9,145834,2,5433,0)="""RTN"",""MAGDSTA9"",47,0)"
^XMB(3.9,145834,2,5434,0)=" S SORTORDER=^TMP(""MAG"",$J,""BATCH Q/R"",""SORT ORDER"")"
^XMB(3.9,145834,2,5435,0)="""RTN"",""MAGDSTA9"",48,0)"
^XMB(3.9,145834,2,5436,0)=" S BEGDATE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""BEGIN DATE""))"
^XMB(3.9,145834,2,5437,0)="""RTN"",""MAGDSTA9"",49,0)"
^XMB(3.9,145834,2,5438,0)=" S ENDDATE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""END DATE""))"
^XMB(3.9,145834,2,5439,0)="""RTN"",""MAGDSTA9"",50,0)"
^XMB(3.9,145834,2,5440,0)=" S BATCHSIZE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""BATCH SIZE""))"
^XMB(3.9,145834,2,5441,0)="""RTN"",""MAGDSTA9"",51,0)"
^XMB(3.9,145834,2,5442,0)=" S HOURS=^TMP(""MAG"",$J,""BATCH Q/R"",""HOURS OF OPERATION"")"
^XMB(3.9,145834,2,5443,0)="""RTN"",""MAGDSTA9"",52,0)"
^XMB(3.9,145834,2,5444,0)=" S SCANMODE=^TMP(""MAG"",$J,""Q/R PARAM"",""SCAN MODE"")"
^XMB(3.9,145834,2,5445,0)="""RTN"",""MAGDSTA9"",53,0)"
^XMB(3.9,145834,2,5446,0)=" D DISPLAY1"
^XMB(3.9,145834,2,5447,0)="""RTN"",""MAGDSTA9"",54,0)"
^XMB(3.9,145834,2,5448,0)=" Q"
^XMB(3.9,145834,2,5449,0)="""RTN"",""MAGDSTA9"",55,0)"
^XMB(3.9,145834,2,5450,0)=" ;"
^XMB(3.9,145834,2,5451,0)="""RTN"",""MAGDSTA9"",56,0)"
^XMB(3.9,145834,2,5452,0)="DISPLAY1 ; just display the parameters - called by ^MAGDSTA1"
^XMB(3.9,145834,2,5453,0)="""RTN"",""MAGDSTA9"",57,0)"
^XMB(3.9,145834,2,5454,0)=" N I,J,LIST"
^XMB(3.9,145834,2,5455,0)="""RTN"",""MAGDSTA9"",58,0)"
^XMB(3.9,145834,2,5456,0)=" N VA,VADM,VAERR,VAICN,VAIN,VAINFO,VAPA,X"
^XMB(3.9,145834,2,5457,0)="""RTN"",""MAGDSTA9"",59,0)"
^XMB(3.9,145834,2,5458,0)=" W !,$$J(""Imaging Service"")"
^XMB(3.9,145834,2,5459,0)="""RTN"",""MAGDSTA9"",60,0)"
^XMB(3.9,145834,2,5460,0)=" I IMAGINGSERVICE=""CONSULTS"" D  ; display consult/procedure services"
^XMB(3.9,145834,2,5461,0)="""RTN"",""MAGDSTA9"",61,0)"
^XMB(3.9,145834,2,5462,0)=" . S (I,J)=0"
^XMB(3.9,145834,2,5463,0)="""RTN"",""MAGDSTA9"",62,0)"
^XMB(3.9,145834,2,5464,0)=" . F  S I=$O(CONSULTSERVICES(I)) Q:I=""""  D"
^XMB(3.9,145834,2,5465,0)="""RTN"",""MAGDSTA9"",63,0)"
^XMB(3.9,145834,2,5466,0)=" . . S J=J+1,LIST(J)=CONSULTSERVICES(I)"
^XMB(3.9,145834,2,5467,0)="""RTN"",""MAGDSTA9"",64,0)"
^XMB(3.9,145834,2,5468,0)=" . . Q"
^XMB(3.9,145834,2,5469,0)="""RTN"",""MAGDSTA9"",65,0)"
^XMB(3.9,145834,2,5470,0)=" . I J D"
^XMB(3.9,145834,2,5471,0)="""RTN"",""MAGDSTA9"",66,0)"
^XMB(3.9,145834,2,5472,0)=" . . F I=1:1:J D"
^XMB(3.9,145834,2,5473,0)="""RTN"",""MAGDSTA9"",67,0)"
^XMB(3.9,145834,2,5474,0)=" . . . S X=LIST(I)"
^XMB(3.9,145834,2,5475,0)="""RTN"",""MAGDSTA9"",68,0)"
^XMB(3.9,145834,2,5476,0)=" . . . I ($L(X)+2)+$X>IOM W "","",!,?27 ; need new line"
^XMB(3.9,145834,2,5477,0)="""RTN"",""MAGDSTA9"",69,0)"
^XMB(3.9,145834,2,5478,0)=" . . . E  W:I>1 "", """
