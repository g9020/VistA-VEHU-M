^XMB(3.9,144657,2,10508,0)=" S BUFF(355.33,BUDA,40.1)=$$GET1^DIQ(355.3,PLDA,6.02,""I"")"
^XMB(3.9,144657,2,10509,0)="""RTN"",""IBNCPDP3"",197,0)"
^XMB(3.9,144657,2,10510,0)=" S BUFF(355.33,BUDA,40.11)=$$GET1^DIQ(355.3,PLDA,6.03,""I"")"
^XMB(3.9,144657,2,10511,0)="""RTN"",""IBNCPDP3"",198,0)"
