^XMB(3.9,145834,2,7333,0)="""RTN"",""MAGDSTQ9"",1,0)"
^XMB(3.9,145834,2,7334,0)="MAGDSTQ9 ;WOIFO/PMK - Study Tracker - Query/Retrieve user ; Feb 15, 2022@10:23:02"
^XMB(3.9,145834,2,7335,0)="""RTN"",""MAGDSTQ9"",2,0)"
^XMB(3.9,145834,2,7336,0)=" ;;3.0;IMAGING;**231,305**;Mar 19, 2002;Build 0"
^XMB(3.9,145834,2,7337,0)="""RTN"",""MAGDSTQ9"",3,0)"
^XMB(3.9,145834,2,7338,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,7339,0)="""RTN"",""MAGDSTQ9"",4,0)"
^XMB(3.9,145834,2,7340,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,7341,0)="""RTN"",""MAGDSTQ9"",5,0)"
^XMB(3.9,145834,2,7342,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145834,2,7343,0)="""RTN"",""MAGDSTQ9"",6,0)"
^XMB(3.9,145834,2,7344,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145834,2,7345,0)="""RTN"",""MAGDSTQ9"",7,0)"
^XMB(3.9,145834,2,7346,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145834,2,7347,0)="""RTN"",""MAGDSTQ9"",8,0)"
^XMB(3.9,145834,2,7348,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,7349,0)="""RTN"",""MAGDSTQ9"",9,0)"
^XMB(3.9,145834,2,7350,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,7351,0)="""RTN"",""MAGDSTQ9"",10,0)"
^XMB(3.9,145834,2,7352,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,7353,0)="""RTN"",""MAGDSTQ9"",11,0)"
^XMB(3.9,145834,2,7354,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,7355,0)="""RTN"",""MAGDSTQ9"",12,0)"
^XMB(3.9,145834,2,7356,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,7357,0)="""RTN"",""MAGDSTQ9"",13,0)"
^XMB(3.9,145834,2,7358,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,7359,0)="""RTN"",""MAGDSTQ9"",14,0)"
^XMB(3.9,145834,2,7360,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,7361,0)="""RTN"",""MAGDSTQ9"",15,0)"
^XMB(3.9,145834,2,7362,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,7363,0)="""RTN"",""MAGDSTQ9"",16,0)"
^XMB(3.9,145834,2,7364,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,7365,0)="""RTN"",""MAGDSTQ9"",17,0)"
^XMB(3.9,145834,2,7366,0)=" ;;"
^XMB(3.9,145834,2,7367,0)="""RTN"",""MAGDSTQ9"",18,0)"
^XMB(3.9,145834,2,7368,0)=" ;"
^XMB(3.9,145834,2,7369,0)="""RTN"",""MAGDSTQ9"",19,0)"
^XMB(3.9,145834,2,7370,0)=" ; Supported IA #2056 reference $$GET1^DIQ function call"
^XMB(3.9,145834,2,7371,0)="""RTN"",""MAGDSTQ9"",20,0)"
^XMB(3.9,145834,2,7372,0)=" ; Supported IA #10090 to read LOCATION file (#4)"
^XMB(3.9,145834,2,7373,0)="""RTN"",""MAGDSTQ9"",21,0)"
^XMB(3.9,145834,2,7374,0)=" ;"
^XMB(3.9,145834,2,7375,0)="""RTN"",""MAGDSTQ9"",22,0)"
^XMB(3.9,145834,2,7376,0)=" ;"
^XMB(3.9,145834,2,7377,0)="""RTN"",""MAGDSTQ9"",23,0)"
^XMB(3.9,145834,2,7378,0)=" ; Select the DICOM Service Class Provider"
^XMB(3.9,145834,2,7379,0)="""RTN"",""MAGDSTQ9"",24,0)"
^XMB(3.9,145834,2,7380,0)=" ; "
^XMB(3.9,145834,2,7381,0)="""RTN"",""MAGDSTQ9"",25,0)"
^XMB(3.9,145834,2,7382,0)=" ; Modeled after PICKSCP^MAGDACU on the DICOM Gateway"
^XMB(3.9,145834,2,7383,0)="""RTN"",""MAGDSTQ9"",26,0)"
^XMB(3.9,145834,2,7384,0)=" ;"
^XMB(3.9,145834,2,7385,0)="""RTN"",""MAGDSTQ9"",27,0)"
^XMB(3.9,145834,2,7386,0)="PICKSCP(DEFAULT,SCPTYPE) ; Pick the SCP for the site"
^XMB(3.9,145834,2,7387,0)="""RTN"",""MAGDSTQ9"",28,0)"
^XMB(3.9,145834,2,7388,0)=" N FOUND,HIT,I,LOCATION,MAGIEN,MAGSCPTYPE,N,NEXT,NEXTDATETIME"
^XMB(3.9,145834,2,7389,0)="""RTN"",""MAGDSTQ9"",29,0)"
^XMB(3.9,145834,2,7390,0)=" N USERAPP,STATNUMB,TARGET,TIMESTAMP,X"
^XMB(3.9,145834,2,7391,0)="""RTN"",""MAGDSTQ9"",30,0)"
^XMB(3.9,145834,2,7392,0)=" S STATNUMB=$$STATNUMB^MAGDFCNV"
^XMB(3.9,145834,2,7393,0)="""RTN"",""MAGDSTQ9"",31,0)"
^XMB(3.9,145834,2,7394,0)=" S DEFAULT=$G(DEFAULT),SCPTYPE=$G(SCPTYPE)"
^XMB(3.9,145834,2,7395,0)="""RTN"",""MAGDSTQ9"",32,0)"
^XMB(3.9,145834,2,7396,0)=" S USERAPP="""",(HIT,I)=0"
^XMB(3.9,145834,2,7397,0)="""RTN"",""MAGDSTQ9"",33,0)"
^XMB(3.9,145834,2,7398,0)=" F  S USERAPP=$O(^MAG(2006.587,""B"",USERAPP)) Q:USERAPP=""""  D"
^XMB(3.9,145834,2,7399,0)="""RTN"",""MAGDSTQ9"",34,0)"
^XMB(3.9,145834,2,7400,0)=" . S (FOUND,MAGIEN,TIMESTAMP)="""""
^XMB(3.9,145834,2,7401,0)="""RTN"",""MAGDSTQ9"",35,0)"
^XMB(3.9,145834,2,7402,0)=" . F  S MAGIEN=$O(^MAG(2006.587,""B"",USERAPP,MAGIEN)) Q:MAGIEN=""""  D"
^XMB(3.9,145834,2,7403,0)="""RTN"",""MAGDSTQ9"",36,0)"
^XMB(3.9,145834,2,7404,0)=" . . S NEXT=^MAG(2006.587,MAGIEN,0)"
^XMB(3.9,145834,2,7405,0)="""RTN"",""MAGDSTQ9"",37,0)"
^XMB(3.9,145834,2,7406,0)=" . . S LOCATION=$P(NEXT,""^"",7)"
^XMB(3.9,145834,2,7407,0)="""RTN"",""MAGDSTQ9"",38,0)"
^XMB(3.9,145834,2,7408,0)=" . . S LOCATION=$$GET1^DIQ(4,LOCATION,99,""E"") ; compare station numbers"
^XMB(3.9,145834,2,7409,0)="""RTN"",""MAGDSTQ9"",39,0)"
^XMB(3.9,145834,2,7410,0)=" . . I LOCATION'=STATNUMB Q  ; ignore entries for other locations"
^XMB(3.9,145834,2,7411,0)="""RTN"",""MAGDSTQ9"",40,0)"
^XMB(3.9,145834,2,7412,0)=" . . S MAGSCPTYPE=$P(NEXT,""^"",9)"
^XMB(3.9,145834,2,7413,0)="""RTN"",""MAGDSTQ9"",41,0)"
^XMB(3.9,145834,2,7414,0)=" . . I SCPTYPE'="""",SCPTYPE'=MAGSCPTYPE Q  ; skip entries for other types"
^XMB(3.9,145834,2,7415,0)="""RTN"",""MAGDSTQ9"",42,0)"
^XMB(3.9,145834,2,7416,0)=" . . S NEXTDATETIME=$P(NEXT,""^"",8)"
^XMB(3.9,145834,2,7417,0)="""RTN"",""MAGDSTQ9"",43,0)"
^XMB(3.9,145834,2,7418,0)=" . . I NEXTDATETIME>TIMESTAMP D  ; get latest version"
^XMB(3.9,145834,2,7419,0)="""RTN"",""MAGDSTQ9"",44,0)"
^XMB(3.9,145834,2,7420,0)=" . . . S FOUND=NEXT,TIMESTAMP=NEXTDATETIME"
^XMB(3.9,145834,2,7421,0)="""RTN"",""MAGDSTQ9"",45,0)"
^XMB(3.9,145834,2,7422,0)=" . . . Q"
^XMB(3.9,145834,2,7423,0)="""RTN"",""MAGDSTQ9"",46,0)"
^XMB(3.9,145834,2,7424,0)=" . . Q"
^XMB(3.9,145834,2,7425,0)="""RTN"",""MAGDSTQ9"",47,0)"
^XMB(3.9,145834,2,7426,0)=" . I FOUND'="""" D"
^XMB(3.9,145834,2,7427,0)="""RTN"",""MAGDSTQ9"",48,0)"
^XMB(3.9,145834,2,7428,0)=" . . S I=I+1,TARGET(I)=FOUND"
^XMB(3.9,145834,2,7429,0)="""RTN"",""MAGDSTQ9"",49,0)"
^XMB(3.9,145834,2,7430,0)=" . . I USERAPP=DEFAULT S HIT=I"
^XMB(3.9,145834,2,7431,0)="""RTN"",""MAGDSTQ9"",50,0)"
^XMB(3.9,145834,2,7432,0)=" . . Q"
^XMB(3.9,145834,2,7433,0)="""RTN"",""MAGDSTQ9"",51,0)"
^XMB(3.9,145834,2,7434,0)=" . Q"
^XMB(3.9,145834,2,7435,0)="""RTN"",""MAGDSTQ9"",52,0)"
^XMB(3.9,145834,2,7436,0)=" S N=I"
^XMB(3.9,145834,2,7437,0)="""RTN"",""MAGDSTQ9"",53,0)"
^XMB(3.9,145834,2,7438,0)=" I N<1 W !!,""No Service Class Providers defined in SCU_LIST.DIC."" Q """""
^XMB(3.9,145834,2,7439,0)="""RTN"",""MAGDSTQ9"",54,0)"
^XMB(3.9,145834,2,7440,0)=" F  D  Q:X'="""""
^XMB(3.9,145834,2,7441,0)="""RTN"",""MAGDSTQ9"",55,0)"
^XMB(3.9,145834,2,7442,0)=" . W !,""DICOM "",$S(SCPTYPE'="""":SCPTYPE_"" "",1:""""),""Service Class Providers"""
^XMB(3.9,145834,2,7443,0)="""RTN"",""MAGDSTQ9"",56,0)"
^XMB(3.9,145834,2,7444,0)=" . S X=$X W ! F I=1:1:X W ""-"""
^XMB(3.9,145834,2,7445,0)="""RTN"",""MAGDSTQ9"",57,0)"
^XMB(3.9,145834,2,7446,0)=" . F I=1:1:N W !,$J(I,3),"" -- "",$P(TARGET(I),""^"")"
^XMB(3.9,145834,2,7447,0)="""RTN"",""MAGDSTQ9"",58,0)"
^XMB(3.9,145834,2,7448,0)=" . I N=1 W "" (selected)"" S X=1 Q"
^XMB(3.9,145834,2,7449,0)="""RTN"",""MAGDSTQ9"",59,0)"
^XMB(3.9,145834,2,7450,0)=" . W !!,""Select the provider application (1-"",N,""): """
^XMB(3.9,145834,2,7451,0)="""RTN"",""MAGDSTQ9"",60,0)"
^XMB(3.9,145834,2,7452,0)=" . W:HIT HIT,""// "" R X:DTIME E  S X=""^"""
^XMB(3.9,145834,2,7453,0)="""RTN"",""MAGDSTQ9"",61,0)"
^XMB(3.9,145834,2,7454,0)=" . I X[""^"" Q  ; a caret will terminate the program"
^XMB(3.9,145834,2,7455,0)="""RTN"",""MAGDSTQ9"",62,0)"
^XMB(3.9,145834,2,7456,0)=" . I X="""" S X=HIT W X I X="""" S X=""^"" Q"
^XMB(3.9,145834,2,7457,0)="""RTN"",""MAGDSTQ9"",63,0)"
^XMB(3.9,145834,2,7458,0)=" . I (X<1)!(X>N)!'$D(TARGET(X)) W "" ??? -- try again"",!! S X="""" Q"
^XMB(3.9,145834,2,7459,0)="""RTN"",""MAGDSTQ9"",64,0)"
^XMB(3.9,145834,2,7460,0)=" . Q"
^XMB(3.9,145834,2,7461,0)="""RTN"",""MAGDSTQ9"",65,0)"
^XMB(3.9,145834,2,7462,0)=" I X[""^"" S X="""""
^XMB(3.9,145834,2,7463,0)="""RTN"",""MAGDSTQ9"",66,0)"
^XMB(3.9,145834,2,7464,0)=" I X S X=$P(TARGET(X),""^"",1)"
^XMB(3.9,145834,2,7465,0)="""RTN"",""MAGDSTQ9"",67,0)"
^XMB(3.9,145834,2,7466,0)=" Q X"
^XMB(3.9,145834,2,7467,0)="""RTN"",""MAGDSTV1"")"
^XMB(3.9,145834,2,7468,0)="0^13^B43298920"
^XMB(3.9,145834,2,7469,0)="""RTN"",""MAGDSTV1"",1,0)"
^XMB(3.9,145834,2,7470,0)="MAGDSTV1 ;WOIFO/PMK - Study Tracker - VistA Query/Retrieve user ; Apr 25, 2022@09:21:50"
