^XMB(3.9,144657,2,1115,0)="""RTN"",""IBCNBAA"",261,0)"
^XMB(3.9,144657,2,1116,0)=" ;"
^XMB(3.9,144657,2,1117,0)="""RTN"",""IBCNBAA"",262,0)"
^XMB(3.9,144657,2,1118,0)="SUASK(IBVAL) ; ask user to select Pt. Relationship to Insured"
^XMB(3.9,144657,2,1119,0)="""RTN"",""IBCNBAA"",263,0)"
^XMB(3.9,144657,2,1120,0)=" N X,Y,DIR,IBF"
^XMB(3.9,144657,2,1121,0)="""RTN"",""IBCNBAA"",264,0)"
^XMB(3.9,144657,2,1122,0)=" W !"
^XMB(3.9,144657,2,1123,0)="""RTN"",""IBCNBAA"",265,0)"
^XMB(3.9,144657,2,1124,0)=" S IBF=$P($G(^DD(2.312,4.03,0)),U,3)"
^XMB(3.9,144657,2,1125,0)="""RTN"",""IBCNBAA"",266,0)"
^XMB(3.9,144657,2,1126,0)=" ;"
^XMB(3.9,144657,2,1127,0)="""RTN"",""IBCNBAA"",267,0)"
^XMB(3.9,144657,2,1128,0)=" S DIR(0)=""SAO^""_IBF"
^XMB(3.9,144657,2,1129,0)="""RTN"",""IBCNBAA"",268,0)"
^XMB(3.9,144657,2,1130,0)=" S DIR(""A"")=""Select the Patient Relationship to Subscriber: """
^XMB(3.9,144657,2,1131,0)="""RTN"",""IBCNBAA"",269,0)"
