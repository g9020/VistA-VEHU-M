^XMB(3.9,145834,2,7029,0)="""RTN"",""MAGDSTQ8"",17,0)"
^XMB(3.9,145834,2,7030,0)=" ;;"
^XMB(3.9,145834,2,7031,0)="""RTN"",""MAGDSTQ8"",18,0)"
^XMB(3.9,145834,2,7032,0)=" ; "
^XMB(3.9,145834,2,7033,0)="""RTN"",""MAGDSTQ8"",19,0)"
^XMB(3.9,145834,2,7034,0)=" ; Notice: This routine is on both VistA and the DICOM Gateway"
^XMB(3.9,145834,2,7035,0)="""RTN"",""MAGDSTQ8"",20,0)"
^XMB(3.9,145834,2,7036,0)=" ;"
^XMB(3.9,145834,2,7037,0)="""RTN"",""MAGDSTQ8"",21,0)"
^XMB(3.9,145834,2,7038,0)=" ; Supported IA #10103 reference $$HTE^XLFDT function call"
^XMB(3.9,145834,2,7039,0)="""RTN"",""MAGDSTQ8"",22,0)"
^XMB(3.9,145834,2,7040,0)=" ;"
^XMB(3.9,145834,2,7041,0)="""RTN"",""MAGDSTQ8"",23,0)"
^XMB(3.9,145834,2,7042,0)=" ; Display Retrieve Status"
^XMB(3.9,145834,2,7043,0)="""RTN"",""MAGDSTQ8"",24,0)"
^XMB(3.9,145834,2,7044,0)=" ;"
^XMB(3.9,145834,2,7045,0)="""RTN"",""MAGDSTQ8"",25,0)"
^XMB(3.9,145834,2,7046,0)=" Q"
^XMB(3.9,145834,2,7047,0)="""RTN"",""MAGDSTQ8"",26,0)"
^XMB(3.9,145834,2,7048,0)=" ;"
^XMB(3.9,145834,2,7049,0)="""RTN"",""MAGDSTQ8"",27,0)"
^XMB(3.9,145834,2,7050,0)="RETRIEVE ;"
^XMB(3.9,145834,2,7051,0)="""RTN"",""MAGDSTQ8"",28,0)"
^XMB(3.9,145834,2,7052,0)=" N ACNUMB,BADTAGS,BADUIDS,COMMENT,COMPLETED,DONE,ERRORID,FAILED,I,MEANING,NORESULTS"
^XMB(3.9,145834,2,7053,0)="""RTN"",""MAGDSTQ8"",29,0)"
^XMB(3.9,145834,2,7054,0)=" N REDISPLAY,REMAINING,STATUS,STATUSCODE,TIME,TIMEOUT,TIMESTAMP,X,WARNING"
^XMB(3.9,145834,2,7055,0)="""RTN"",""MAGDSTQ8"",30,0)"
^XMB(3.9,145834,2,7056,0)=" ;"
^XMB(3.9,145834,2,7057,0)="""RTN"",""MAGDSTQ8"",31,0)"
^XMB(3.9,145834,2,7058,0)=" S TIMEOUT=1"
^XMB(3.9,145834,2,7059,0)="""RTN"",""MAGDSTQ8"",32,0)"
^XMB(3.9,145834,2,7060,0)=" ;"
^XMB(3.9,145834,2,7061,0)="""RTN"",""MAGDSTQ8"",33,0)"
^XMB(3.9,145834,2,7062,0)=" S ACNUMB=$G(^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,""ACCESSION NUMBER""))"
^XMB(3.9,145834,2,7063,0)="""RTN"",""MAGDSTQ8"",34,0)"
^XMB(3.9,145834,2,7064,0)=" I ACNUMB="""",^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,""RETRIEVE LEVEL"")=""PATIENT"" D"
^XMB(3.9,145834,2,7065,0)="""RTN"",""MAGDSTQ8"",35,0)"
^XMB(3.9,145834,2,7066,0)=" . S ACNUMB=^TMP(""MAG"",$J,""Q/R QUERY"",QRSTACK,""PATIENT ID"")"
^XMB(3.9,145834,2,7067,0)="""RTN"",""MAGDSTQ8"",36,0)"
^XMB(3.9,145834,2,7068,0)=" . Q"
^XMB(3.9,145834,2,7069,0)="""RTN"",""MAGDSTQ8"",37,0)"
^XMB(3.9,145834,2,7070,0)=" ;"
^XMB(3.9,145834,2,7071,0)="""RTN"",""MAGDSTQ8"",38,0)"
^XMB(3.9,145834,2,7072,0)=" K ^XTMP(MAGXTMP,HOSTNAME,$J,QRSTACK,""Q/R RETRIEVE STATUS"",ACNUMB)"
^XMB(3.9,145834,2,7073,0)="""RTN"",""MAGDSTQ8"",39,0)"
^XMB(3.9,145834,2,7074,0)=" ;"
^XMB(3.9,145834,2,7075,0)="""RTN"",""MAGDSTQ8"",40,0)"
^XMB(3.9,145834,2,7076,0)=" D DISPLAY(.REDISPLAY)"
^XMB(3.9,145834,2,7077,0)="""RTN"",""MAGDSTQ8"",41,0)"
^XMB(3.9,145834,2,7078,0)=" ;"
^XMB(3.9,145834,2,7079,0)="""RTN"",""MAGDSTQ8"",42,0)"
^XMB(3.9,145834,2,7080,0)=" S (DONE,NORESULTS)=0"
^XMB(3.9,145834,2,7081,0)="""RTN"",""MAGDSTQ8"",43,0)"
^XMB(3.9,145834,2,7082,0)=" F  D  Q:DONE"
^XMB(3.9,145834,2,7083,0)="""RTN"",""MAGDSTQ8"",44,0)"
^XMB(3.9,145834,2,7084,0)=" . I REDISPLAY D DISPLAY(.REDIPLAY)"
^XMB(3.9,145834,2,7085,0)="""RTN"",""MAGDSTQ8"",45,0)"
^XMB(3.9,145834,2,7086,0)=" . F  Q:$X=0  W @IOBS,"" "",@IOBS ; erase the line"
^XMB(3.9,145834,2,7087,0)="""RTN"",""MAGDSTQ8"",46,0)"
^XMB(3.9,145834,2,7088,0)=" . S X=$G(^XTMP(MAGXTMP,HOSTNAME,$J,QRSTACK,""Q/R RETRIEVE STATUS"",ACNUMB))"
^XMB(3.9,145834,2,7089,0)="""RTN"",""MAGDSTQ8"",47,0)"
^XMB(3.9,145834,2,7090,0)=" . I X="""" D"
^XMB(3.9,145834,2,7091,0)="""RTN"",""MAGDSTQ8"",48,0)"
^XMB(3.9,145834,2,7092,0)=" . . W ""No retrieve results yet"""
^XMB(3.9,145834,2,7093,0)="""RTN"",""MAGDSTQ8"",49,0)"
^XMB(3.9,145834,2,7094,0)=" . . S NORESULTS=NORESULTS+1"
^XMB(3.9,145834,2,7095,0)="""RTN"",""MAGDSTQ8"",50,0)"
^XMB(3.9,145834,2,7096,0)=" . . F I=1:1:NORESULTS W ""."""
^XMB(3.9,145834,2,7097,0)="""RTN"",""MAGDSTQ8"",51,0)"
^XMB(3.9,145834,2,7098,0)=" . . I NORESULTS>45 S DONE=-1"
^XMB(3.9,145834,2,7099,0)="""RTN"",""MAGDSTQ8"",52,0)"
^XMB(3.9,145834,2,7100,0)=" . . Q"
^XMB(3.9,145834,2,7101,0)="""RTN"",""MAGDSTQ8"",53,0)"
^XMB(3.9,145834,2,7102,0)=" . E  D"
^XMB(3.9,145834,2,7103,0)="""RTN"",""MAGDSTQ8"",54,0)"
^XMB(3.9,145834,2,7104,0)=" . . S STATE=$P(X,""|"",1)"
^XMB(3.9,145834,2,7105,0)="""RTN"",""MAGDSTQ8"",55,0)"
^XMB(3.9,145834,2,7106,0)=" . . S TIMESTAMP=$P(X,""|"",2)"
^XMB(3.9,145834,2,7107,0)="""RTN"",""MAGDSTQ8"",56,0)"
^XMB(3.9,145834,2,7108,0)=" . . S STATUSCODE=$P(X,""|"",3)"
^XMB(3.9,145834,2,7109,0)="""RTN"",""MAGDSTQ8"",57,0)"
^XMB(3.9,145834,2,7110,0)=" . . I STATUSCODE="""" W STATE Q  ; informational message"
^XMB(3.9,145834,2,7111,0)="""RTN"",""MAGDSTQ8"",58,0)"
^XMB(3.9,145834,2,7112,0)=" . . S REMAINING=+$P(X,""|"",4) ; coerce null to 0"
^XMB(3.9,145834,2,7113,0)="""RTN"",""MAGDSTQ8"",59,0)"
^XMB(3.9,145834,2,7114,0)=" . . S COMPLETED=+$P(X,""|"",5) ; coerce null to 0"
^XMB(3.9,145834,2,7115,0)="""RTN"",""MAGDSTQ8"",60,0)"
^XMB(3.9,145834,2,7116,0)=" . . S FAILED=$P(X,""|"",6)"
^XMB(3.9,145834,2,7117,0)="""RTN"",""MAGDSTQ8"",61,0)"
^XMB(3.9,145834,2,7118,0)=" . . S WARNING=$P(X,""|"",7)"
^XMB(3.9,145834,2,7119,0)="""RTN"",""MAGDSTQ8"",62,0)"
^XMB(3.9,145834,2,7120,0)=" . . S BADTAGS=$P(X,""|"",8)"
^XMB(3.9,145834,2,7121,0)="""RTN"",""MAGDSTQ8"",63,0)"
^XMB(3.9,145834,2,7122,0)=" . . S BADUIDS=$P(X,""|"",9)"
^XMB(3.9,145834,2,7123,0)="""RTN"",""MAGDSTQ8"",64,0)"
^XMB(3.9,145834,2,7124,0)=" . . S ERRORID=$P(X,""|"",10)"
^XMB(3.9,145834,2,7125,0)="""RTN"",""MAGDSTQ8"",65,0)"
^XMB(3.9,145834,2,7126,0)=" . . S COMMENT=$P(X,""|"",11,999) ; may contain ""|"""
^XMB(3.9,145834,2,7127,0)="""RTN"",""MAGDSTQ8"",66,0)"
^XMB(3.9,145834,2,7128,0)=" . . S TIME=$P($$HTE^XLFDT(TIMESTAMP),""@"",2)"
^XMB(3.9,145834,2,7129,0)="""RTN"",""MAGDSTQ8"",67,0)"
^XMB(3.9,145834,2,7130,0)=" . . S STATUS=$$STATUS(STATUSCODE,.MEANING)"
^XMB(3.9,145834,2,7131,0)="""RTN"",""MAGDSTQ8"",68,0)"
^XMB(3.9,145834,2,7132,0)=" . . I STATUS=""Pending"" D"
^XMB(3.9,145834,2,7133,0)="""RTN"",""MAGDSTQ8"",69,0)"
^XMB(3.9,145834,2,7134,0)=" . . . I COMPLETED=0 W ""No DICOM object retrieved yet"""
^XMB(3.9,145834,2,7135,0)="""RTN"",""MAGDSTQ8"",70,0)"
