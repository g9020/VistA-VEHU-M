^XMB(3.9,145833,2,1996,0)=" ;                  Accessing own record"
^XMB(3.9,145833,2,1997,0)="""RTN"",""SDES2UTIL"",367,0)"
^XMB(3.9,145833,2,1998,0)=" ;                4-Access to Patient (#2) file records denied"
^XMB(3.9,145833,2,1999,0)="""RTN"",""SDES2UTIL"",368,0)"
^XMB(3.9,145833,2,2000,0)=" ;                  SSN not defined"
^XMB(3.9,145833,2,2001,0)="""RTN"",""SDES2UTIL"",369,0)"
^XMB(3.9,145833,2,2002,0)=" ;   RESULT(2-10) = error or display messages"
^XMB(3.9,145833,2,2003,0)="""RTN"",""SDES2UTIL"",370,0)"
^XMB(3.9,145833,2,2004,0)=" ;"
^XMB(3.9,145833,2,2005,0)="""RTN"",""SDES2UTIL"",371,0)"
^XMB(3.9,145833,2,2006,0)=" ;Input parameters: DFN = Patient file entry (Required)"
^XMB(3.9,145833,2,2007,0)="""RTN"",""SDES2UTIL"",372,0)"
^XMB(3.9,145833,2,2008,0)=" ;                  SDDUZ = User (Required)"
^XMB(3.9,145833,2,2009,0)="""RTN"",""SDES2UTIL"",373,0)"
^XMB(3.9,145833,2,2010,0)=" ;                  DGMSG = If 1, generate message (optional)"
^XMB(3.9,145833,2,2011,0)="""RTN"",""SDES2UTIL"",374,0)"
^XMB(3.9,145833,2,2012,0)=" ;                  DGOPT  = Option name^Menu text (Optional)"
^XMB(3.9,145833,2,2013,0)="""RTN"",""SDES2UTIL"",375,0)"
^XMB(3.9,145833,2,2014,0)=" ;"
^XMB(3.9,145833,2,2015,0)="""RTN"",""SDES2UTIL"",376,0)"
^XMB(3.9,145833,2,2016,0)=" K RESULT"
^XMB(3.9,145833,2,2017,0)="""RTN"",""SDES2UTIL"",377,0)"
^XMB(3.9,145833,2,2018,0)=" I $G(DFN)="""" D  Q"
^XMB(3.9,145833,2,2019,0)="""RTN"",""SDES2UTIL"",378,0)"
^XMB(3.9,145833,2,2020,0)=" .S RESULT(1)=-1"
^XMB(3.9,145833,2,2021,0)="""RTN"",""SDES2UTIL"",379,0)"
^XMB(3.9,145833,2,2022,0)=" .S RESULT(2)=""Required variable missing."""
^XMB(3.9,145833,2,2023,0)="""RTN"",""SDES2UTIL"",380,0)"
^XMB(3.9,145833,2,2024,0)=" S DGMSG=$G(DGMSG,0)"
^XMB(3.9,145833,2,2025,0)="""RTN"",""SDES2UTIL"",381,0)"
^XMB(3.9,145833,2,2026,0)=" D OWNREC^DGSEC4(.RESULT,DFN,$G(SDDUZ),DGMSG)"
^XMB(3.9,145833,2,2027,0)="""RTN"",""SDES2UTIL"",382,0)"
^XMB(3.9,145833,2,2028,0)=" I RESULT(1)=1 S RESULT(1)=3 Q"
^XMB(3.9,145833,2,2029,0)="""RTN"",""SDES2UTIL"",383,0)"
^XMB(3.9,145833,2,2030,0)=" I RESULT(1)=2 S RESULT(1)=4 Q"
^XMB(3.9,145833,2,2031,0)="""RTN"",""SDES2UTIL"",384,0)"
^XMB(3.9,145833,2,2032,0)=" K RESULT"
^XMB(3.9,145833,2,2033,0)="""RTN"",""SDES2UTIL"",385,0)"
^XMB(3.9,145833,2,2034,0)=" D SENS^DGSEC4(.RESULT,DFN,$G(SDDUZ))"
^XMB(3.9,145833,2,2035,0)="""RTN"",""SDES2UTIL"",386,0)"
^XMB(3.9,145833,2,2036,0)=" I RESULT(1)=1 D"
^XMB(3.9,145833,2,2037,0)="""RTN"",""SDES2UTIL"",387,0)"
^XMB(3.9,145833,2,2038,0)=" .I $G(SDDUZ)="""" D  Q"
^XMB(3.9,145833,2,2039,0)="""RTN"",""SDES2UTIL"",388,0)"
^XMB(3.9,145833,2,2040,0)=" ..;SDDUZ must be defined to access sensitive record & update DG Security log"
^XMB(3.9,145833,2,2041,0)="""RTN"",""SDES2UTIL"",389,0)"
^XMB(3.9,145833,2,2042,0)=" ..S RESULT(1)=-1"
^XMB(3.9,145833,2,2043,0)="""RTN"",""SDES2UTIL"",390,0)"
^XMB(3.9,145833,2,2044,0)=" ..S RESULT(2)=""Your user code is undefined.  This must be defined to access a restricted patient record."""
