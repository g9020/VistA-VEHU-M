^XMB(3.9,145834,2,5696,0)=" S $P(^MAGDSTT(2006.543,RUNNUMBER,0),""^"",16)=STUDYDATE"
^XMB(3.9,145834,2,5697,0)="""RTN"",""MAGDSTAA"",43,0)"
^XMB(3.9,145834,2,5698,0)=" S $P(^MAGDSTT(2006.543,RUNNUMBER,0),""^"",17)=STUDYIEN"
^XMB(3.9,145834,2,5699,0)="""RTN"",""MAGDSTAA"",44,0)"
^XMB(3.9,145834,2,5700,0)=" S $P(^MAGDSTT(2006.543,RUNNUMBER,0),""^"",18)=ACNUMB"
^XMB(3.9,145834,2,5701,0)="""RTN"",""MAGDSTAA"",45,0)"
^XMB(3.9,145834,2,5702,0)=" ;"
^XMB(3.9,145834,2,5703,0)="""RTN"",""MAGDSTAA"",46,0)"
^XMB(3.9,145834,2,5704,0)=" I $$SUSPEND(HOURS) Q 1  ; stop"
^XMB(3.9,145834,2,5705,0)="""RTN"",""MAGDSTAA"",47,0)"
^XMB(3.9,145834,2,5706,0)=" I $Y>(IOSL-6) W !! D HEADER(1)"
^XMB(3.9,145834,2,5707,0)="""RTN"",""MAGDSTAA"",48,0)"
^XMB(3.9,145834,2,5708,0)=" ;"
^XMB(3.9,145834,2,5709,0)="""RTN"",""MAGDSTAA"",49,0)"
^XMB(3.9,145834,2,5710,0)=" S NONDICOM=0,IMAGES=""NONE"""
^XMB(3.9,145834,2,5711,0)="""RTN"",""MAGDSTAA"",50,0)"
^XMB(3.9,145834,2,5712,0)=" W !,$J(STUDYIEN,8),?11,ACNUMB,?30,$P($$FMTE^XLFDT(STUDYDATE,""2Z""),""@"",1)"
^XMB(3.9,145834,2,5713,0)="""RTN"",""MAGDSTAA"",51,0)"
^XMB(3.9,145834,2,5714,0)=" ; lookup legacy 2005 image group pointers"
^XMB(3.9,145834,2,5715,0)="""RTN"",""MAGDSTAA"",52,0)"
^XMB(3.9,145834,2,5716,0)=" K ^TMP(""MAG"",$J,""UIDS"") ; remove the list of UIDs for the VistA study"
^XMB(3.9,145834,2,5717,0)="""RTN"",""MAGDSTAA"",53,0)"
^XMB(3.9,145834,2,5718,0)=" S MAGIEN="""""
^XMB(3.9,145834,2,5719,0)="""RTN"",""MAGDSTAA"",54,0)"
^XMB(3.9,145834,2,5720,0)=" F I=1:1 S MAGIEN=$O(MAGIENLIST(MAGIEN)) Q:MAGIEN=""""  D"
^XMB(3.9,145834,2,5721,0)="""RTN"",""MAGDSTAA"",55,0)"
^XMB(3.9,145834,2,5722,0)=" . W:I>1 ! W ?40,$J(MAGIEN,8)"
^XMB(3.9,145834,2,5723,0)="""RTN"",""MAGDSTAA"",56,0)"
^XMB(3.9,145834,2,5724,0)=" . D LEGACY^MAGDSTA8(MAGIEN,.SERIESCOUNT,.IMAGECOUNT) ; count images in all groups"
^XMB(3.9,145834,2,5725,0)="""RTN"",""MAGDSTAA"",57,0)"
^XMB(3.9,145834,2,5726,0)=" . I SERIESCOUNT W ?52,$J(SERIESCOUNT,5)"
^XMB(3.9,145834,2,5727,0)="""RTN"",""MAGDSTAA"",58,0)"
^XMB(3.9,145834,2,5728,0)=" . E  D"
^XMB(3.9,145834,2,5729,0)="""RTN"",""MAGDSTAA"",59,0)"
^XMB(3.9,145834,2,5730,0)=" . . I IMAGECOUNT W ?52,$J("""",5) ; same as previous series, don't show count"
^XMB(3.9,145834,2,5731,0)="""RTN"",""MAGDSTAA"",60,0)"
^XMB(3.9,145834,2,5732,0)=" . . E  D"
^XMB(3.9,145834,2,5733,0)="""RTN"",""MAGDSTAA"",61,0)"
^XMB(3.9,145834,2,5734,0)=" . . . W ?55,""non-DICOM"" ; not DICOM, maybe TGA, JPEG, PDF, etc."
^XMB(3.9,145834,2,5735,0)="""RTN"",""MAGDSTAA"",62,0)"
^XMB(3.9,145834,2,5736,0)=" . . . S NONDICOM=1"
^XMB(3.9,145834,2,5737,0)="""RTN"",""MAGDSTAA"",63,0)"
^XMB(3.9,145834,2,5738,0)=" . . . Q"
^XMB(3.9,145834,2,5739,0)="""RTN"",""MAGDSTAA"",64,0)"
^XMB(3.9,145834,2,5740,0)=" . . Q"
^XMB(3.9,145834,2,5741,0)="""RTN"",""MAGDSTAA"",65,0)"
^XMB(3.9,145834,2,5742,0)=" . I IMAGECOUNT W ?59,$J(IMAGECOUNT,5)"
^XMB(3.9,145834,2,5743,0)="""RTN"",""MAGDSTAA"",66,0)"
^XMB(3.9,145834,2,5744,0)=" . D STTINC(""LEGACY STUDIES PROCESSED"",1)"
^XMB(3.9,145834,2,5745,0)="""RTN"",""MAGDSTAA"",67,0)"
^XMB(3.9,145834,2,5746,0)=" . D STTINC(""LEGACY SERIES COUNT"",SERIESCOUNT)"
^XMB(3.9,145834,2,5747,0)="""RTN"",""MAGDSTAA"",68,0)"
^XMB(3.9,145834,2,5748,0)=" . D STTINC(""LEGACY IMAGE COUNT"",IMAGECOUNT)"
^XMB(3.9,145834,2,5749,0)="""RTN"",""MAGDSTAA"",69,0)"
^XMB(3.9,145834,2,5750,0)=" . ;"
^XMB(3.9,145834,2,5751,0)="""RTN"",""MAGDSTAA"",70,0)"
^XMB(3.9,145834,2,5752,0)=" . ; save VistA counts for later steps"
^XMB(3.9,145834,2,5753,0)="""RTN"",""MAGDSTAA"",71,0)"
^XMB(3.9,145834,2,5754,0)=" . ; Note: These counts may be for multiple study instance UIDs"
^XMB(3.9,145834,2,5755,0)="""RTN"",""MAGDSTAA"",72,0)"
^XMB(3.9,145834,2,5756,0)=" . S VISTA(""SERIES COUNT"")=$G(VISTA(""SERIES COUNT""),0)+$G(SERIESCOUNT,0)"
^XMB(3.9,145834,2,5757,0)="""RTN"",""MAGDSTAA"",73,0)"
^XMB(3.9,145834,2,5758,0)=" . S VISTA(""IMAGE COUNT"")=$G(VISTA(""IMAGE COUNT""),0)+$G(IMAGECOUNT,0)"
^XMB(3.9,145834,2,5759,0)="""RTN"",""MAGDSTAA"",74,0)"
^XMB(3.9,145834,2,5760,0)=" . Q"
^XMB(3.9,145834,2,5761,0)="""RTN"",""MAGDSTAA"",75,0)"
^XMB(3.9,145834,2,5762,0)=" ;"
^XMB(3.9,145834,2,5763,0)="""RTN"",""MAGDSTAA"",76,0)"
^XMB(3.9,145834,2,5764,0)=" ; look up in new sop class database (P34)"
^XMB(3.9,145834,2,5765,0)="""RTN"",""MAGDSTAA"",77,0)"
^XMB(3.9,145834,2,5766,0)=" D NEWSOPDB^MAGDSTA8(ACNUMB,.SERIESCOUNT,.IMAGECOUNT)"
^XMB(3.9,145834,2,5767,0)="""RTN"",""MAGDSTAA"",78,0)"
^XMB(3.9,145834,2,5768,0)=" I IMAGECOUNT>0 D"
^XMB(3.9,145834,2,5769,0)="""RTN"",""MAGDSTAA"",79,0)"
^XMB(3.9,145834,2,5770,0)=" . W:$D(MAGIENLIST) ! W ?41,""NEW SOP"",?52,$J(SERIESCOUNT,5),?59,$J(IMAGECOUNT,5)"
^XMB(3.9,145834,2,5771,0)="""RTN"",""MAGDSTAA"",80,0)"
^XMB(3.9,145834,2,5772,0)=" . D STTINC(""NEW SOP CLASS STUDIES PROCESSED"",1)"
^XMB(3.9,145834,2,5773,0)="""RTN"",""MAGDSTAA"",81,0)"
^XMB(3.9,145834,2,5774,0)=" . D STTINC(""NEW SOP CLASS SERIES COUNT"",SERIESCOUNT)"
^XMB(3.9,145834,2,5775,0)="""RTN"",""MAGDSTAA"",82,0)"
^XMB(3.9,145834,2,5776,0)=" . D STTINC(""NEW SOP CLASS IMAGE COUNT"",IMAGECOUNT)"
^XMB(3.9,145834,2,5777,0)="""RTN"",""MAGDSTAA"",83,0)"
^XMB(3.9,145834,2,5778,0)=" . Q"
^XMB(3.9,145834,2,5779,0)="""RTN"",""MAGDSTAA"",84,0)"
^XMB(3.9,145834,2,5780,0)=" ;"
^XMB(3.9,145834,2,5781,0)="""RTN"",""MAGDSTAA"",85,0)"
^XMB(3.9,145834,2,5782,0)=" ; update legacy and new database VistA counts for later steps"
^XMB(3.9,145834,2,5783,0)="""RTN"",""MAGDSTAA"",86,0)"
^XMB(3.9,145834,2,5784,0)=" S VISTA(""SERIES COUNT"")=$G(VISTA(""SERIES COUNT""),0)+$G(SERIESCOUNT,0)"
^XMB(3.9,145834,2,5785,0)="""RTN"",""MAGDSTAA"",87,0)"
^XMB(3.9,145834,2,5786,0)=" S VISTA(""IMAGE COUNT"")=$G(VISTA(""IMAGE COUNT""),0)+$G(IMAGECOUNT,0)"
^XMB(3.9,145834,2,5787,0)="""RTN"",""MAGDSTAA"",88,0)"
^XMB(3.9,145834,2,5788,0)=" ;"
^XMB(3.9,145834,2,5789,0)="""RTN"",""MAGDSTAA"",89,0)"
^XMB(3.9,145834,2,5790,0)=" K PACSSTUDYUID"
^XMB(3.9,145834,2,5791,0)="""RTN"",""MAGDSTAA"",90,0)"
^XMB(3.9,145834,2,5792,0)=" S VISTAUIDFLAG=0"
^XMB(3.9,145834,2,5793,0)="""RTN"",""MAGDSTAA"",91,0)"
^XMB(3.9,145834,2,5794,0)=" ; perform Accession Number query to obtain the Study Instance UID & counts from PACS"
^XMB(3.9,145834,2,5795,0)="""RTN"",""MAGDSTAA"",92,0)"
^XMB(3.9,145834,2,5796,0)=" S SSN=$$GET1^DIQ(2,DFN,.09,""E"") ; P306 PMK 06/11/2021 use last 4 of SSN to make query unique"
^XMB(3.9,145834,2,5797,0)="""RTN"",""MAGDSTAA"",93,0)"
^XMB(3.9,145834,2,5798,0)=" S ERROR=$$FINDSUID^MAGDSTAB(ACNUMB,SSN,.PACSSTUDYUID,.SERIESCOUNT,.IMAGECOUNT)"
^XMB(3.9,145834,2,5799,0)="""RTN"",""MAGDSTAA"",94,0)"
^XMB(3.9,145834,2,5800,0)=" ;"
^XMB(3.9,145834,2,5801,0)="""RTN"",""MAGDSTAA"",95,0)"
^XMB(3.9,145834,2,5802,0)=" I VISTA(""IMAGE COUNT"")=0 D  ; no DICOM images on file in VistA"
^XMB(3.9,145834,2,5803,0)="""RTN"",""MAGDSTAA"",96,0)"
^XMB(3.9,145834,2,5804,0)=" . I NONDICOM=0 W ?46,""--"",?55,""--"",?62,""--"""
^XMB(3.9,145834,2,5805,0)="""RTN"",""MAGDSTAA"",97,0)"
^XMB(3.9,145834,2,5806,0)=" . D STTINC(""VISTA STUDIES WITHOUT DICOM IMAGES"",1)"
^XMB(3.9,145834,2,5807,0)="""RTN"",""MAGDSTAA"",98,0)"
^XMB(3.9,145834,2,5808,0)=" . Q"
^XMB(3.9,145834,2,5809,0)="""RTN"",""MAGDSTAA"",99,0)"
^XMB(3.9,145834,2,5810,0)=" E  I '$D(PACSSTUDYUID) D"
^XMB(3.9,145834,2,5811,0)="""RTN"",""MAGDSTAA"",100,0)"
^XMB(3.9,145834,2,5812,0)=" . ; perform queries using the VistA Study Instance UID to get the image and series counts"
^XMB(3.9,145834,2,5813,0)="""RTN"",""MAGDSTAA"",101,0)"
^XMB(3.9,145834,2,5814,0)=" . S (I,VISTASTUDYUID)=0 ; build array of VistA Study Instance UIDs for the query"
^XMB(3.9,145834,2,5815,0)="""RTN"",""MAGDSTAA"",102,0)"
^XMB(3.9,145834,2,5816,0)=" . F  S VISTASTUDYUID=$O(^TMP(""MAG"",$J,""UIDS"",""VISTA"",VISTASTUDYUID)) Q:VISTASTUDYUID=""""  D"
^XMB(3.9,145834,2,5817,0)="""RTN"",""MAGDSTAA"",103,0)"
^XMB(3.9,145834,2,5818,0)=" . . S I=I+1,PACSSTUDYUID(I)=VISTASTUDYUID"
^XMB(3.9,145834,2,5819,0)="""RTN"",""MAGDSTAA"",104,0)"
^XMB(3.9,145834,2,5820,0)=" . . Q"
^XMB(3.9,145834,2,5821,0)="""RTN"",""MAGDSTAA"",105,0)"
^XMB(3.9,145834,2,5822,0)=" . S ERROR=$$QUERY^MAGDSTAC(.PACSSTUDYUID,.SERIESCOUNT,.IMAGECOUNT)"
^XMB(3.9,145834,2,5823,0)="""RTN"",""MAGDSTAA"",106,0)"
^XMB(3.9,145834,2,5824,0)=" . I $D(PACSSTUDYUID(1)) S VISTAUIDFLAG=1"
^XMB(3.9,145834,2,5825,0)="""RTN"",""MAGDSTAA"",107,0)"
^XMB(3.9,145834,2,5826,0)=" . Q"
^XMB(3.9,145834,2,5827,0)="""RTN"",""MAGDSTAA"",108,0)"
^XMB(3.9,145834,2,5828,0)=" ; "
^XMB(3.9,145834,2,5829,0)="""RTN"",""MAGDSTAA"",109,0)"
^XMB(3.9,145834,2,5830,0)=" ; Note: These counts may be for multiple study instance UIDs"
^XMB(3.9,145834,2,5831,0)="""RTN"",""MAGDSTAA"",110,0)"
^XMB(3.9,145834,2,5832,0)=" S PACS(""SERIES COUNT"")=SERIESCOUNT,PACS(""IMAGE COUNT"")=IMAGECOUNT"
^XMB(3.9,145834,2,5833,0)="""RTN"",""MAGDSTAA"",111,0)"
^XMB(3.9,145834,2,5834,0)=" I SERIESCOUNT D"
^XMB(3.9,145834,2,5835,0)="""RTN"",""MAGDSTAA"",112,0)"
^XMB(3.9,145834,2,5836,0)=" . W ?67,$J(SERIESCOUNT,5),?74,$J(IMAGECOUNT,5)"
^XMB(3.9,145834,2,5837,0)="""RTN"",""MAGDSTAA"",113,0)"
^XMB(3.9,145834,2,5838,0)=" . D STTINC(""PACS STUDIES PROCESSED"",1)"
^XMB(3.9,145834,2,5839,0)="""RTN"",""MAGDSTAA"",114,0)"
^XMB(3.9,145834,2,5840,0)=" . D STTINC(""PACS SERIES COUNT"",SERIESCOUNT)"
^XMB(3.9,145834,2,5841,0)="""RTN"",""MAGDSTAA"",115,0)"
^XMB(3.9,145834,2,5842,0)=" . D STTINC(""PACS IMAGE COUNT"",IMAGECOUNT)"
^XMB(3.9,145834,2,5843,0)="""RTN"",""MAGDSTAA"",116,0)"
^XMB(3.9,145834,2,5844,0)=" . I VISTAUIDFLAG D"
^XMB(3.9,145834,2,5845,0)="""RTN"",""MAGDSTAA"",117,0)"
^XMB(3.9,145834,2,5846,0)=" . . W !,"" (Query with Accession Number failed, but worked with VistA Study Instance UID)"""
^XMB(3.9,145834,2,5847,0)="""RTN"",""MAGDSTAA"",118,0)"
^XMB(3.9,145834,2,5848,0)=" . . Q"
^XMB(3.9,145834,2,5849,0)="""RTN"",""MAGDSTAA"",119,0)"
^XMB(3.9,145834,2,5850,0)=" . Q"
^XMB(3.9,145834,2,5851,0)="""RTN"",""MAGDSTAA"",120,0)"
^XMB(3.9,145834,2,5852,0)=" E  D"
^XMB(3.9,145834,2,5853,0)="""RTN"",""MAGDSTAA"",121,0)"
^XMB(3.9,145834,2,5854,0)=" . W ?70,""--"",?77,""--"""
^XMB(3.9,145834,2,5855,0)="""RTN"",""MAGDSTAA"",122,0)"
^XMB(3.9,145834,2,5856,0)=" . D STTINC(""PACS STUDIES WITHOUT IMAGES"",1)"
^XMB(3.9,145834,2,5857,0)="""RTN"",""MAGDSTAA"",123,0)"
^XMB(3.9,145834,2,5858,0)=" . Q"
^XMB(3.9,145834,2,5859,0)="""RTN"",""MAGDSTAA"",124,0)"
^XMB(3.9,145834,2,5860,0)=" ;"
^XMB(3.9,145834,2,5861,0)="""RTN"",""MAGDSTAA"",125,0)"
^XMB(3.9,145834,2,5862,0)=" I ^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION"")=""RETRIEVE MISSING IMAGES"" D"
^XMB(3.9,145834,2,5863,0)="""RTN"",""MAGDSTAA"",126,0)"
^XMB(3.9,145834,2,5864,0)=" . S ERROR=$$RETRIEVE^MAGDSTAC(.PACSSTUDYUID)"
^XMB(3.9,145834,2,5865,0)="""RTN"",""MAGDSTAA"",127,0)"
^XMB(3.9,145834,2,5866,0)=" . Q"
^XMB(3.9,145834,2,5867,0)="""RTN"",""MAGDSTAA"",128,0)"
^XMB(3.9,145834,2,5868,0)=" ;"
^XMB(3.9,145834,2,5869,0)="""RTN"",""MAGDSTAA"",129,0)"
^XMB(3.9,145834,2,5870,0)=" ;"
^XMB(3.9,145834,2,5871,0)="""RTN"",""MAGDSTAA"",130,0)"
^XMB(3.9,145834,2,5872,0)=" ; cleanup"
^XMB(3.9,145834,2,5873,0)="""RTN"",""MAGDSTAA"",131,0)"
^XMB(3.9,145834,2,5874,0)=" K ^TMP(""MAG"",$J,""DICOM""),^(""Q/R QUERY""),^(""UIDS"")"
^XMB(3.9,145834,2,5875,0)="""RTN"",""MAGDSTAA"",132,0)"
^XMB(3.9,145834,2,5876,0)=" Q 0"
^XMB(3.9,145834,2,5877,0)="""RTN"",""MAGDSTAA"",133,0)"
^XMB(3.9,145834,2,5878,0)=" ;"
^XMB(3.9,145834,2,5879,0)="""RTN"",""MAGDSTAA"",134,0)"
^XMB(3.9,145834,2,5880,0)=" ;"
^XMB(3.9,145834,2,5881,0)="""RTN"",""MAGDSTAA"",135,0)"
^XMB(3.9,145834,2,5882,0)="HEADER(CONTINUE,CLEARSCREEN) ;"
^XMB(3.9,145834,2,5883,0)="""RTN"",""MAGDSTAA"",136,0)"
^XMB(3.9,145834,2,5884,0)=" S CONTINUE=$G(CONTINUE,1)"
^XMB(3.9,145834,2,5885,0)="""RTN"",""MAGDSTAA"",137,0)"
^XMB(3.9,145834,2,5886,0)=" S CLEARSCREEN=$G(CLEARSCREEN,1)"
^XMB(3.9,145834,2,5887,0)="""RTN"",""MAGDSTAA"",138,0)"
^XMB(3.9,145834,2,5888,0)=" I CONTINUE D CONTINUE^MAGDSTQ(0)"
^XMB(3.9,145834,2,5889,0)="""RTN"",""MAGDSTAA"",139,0)"
^XMB(3.9,145834,2,5890,0)=" I CLEARSCREEN W @IOF"
^XMB(3.9,145834,2,5891,0)="""RTN"",""MAGDSTAA"",140,0)"
^XMB(3.9,145834,2,5892,0)=" E  W !! S $Y=0"
^XMB(3.9,145834,2,5893,0)="""RTN"",""MAGDSTAA"",141,0)"
^XMB(3.9,145834,2,5894,0)=" W $$FMTE^XLFDT($$NOW^XLFDT,1),?55,""VistA"",?71,""PACS"""
^XMB(3.9,145834,2,5895,0)="""RTN"",""MAGDSTAA"",142,0)"
^XMB(3.9,145834,2,5896,0)=" W !,""Report #"",?11,""Accession Number"",?32,""Date"",?40,""Group #"",?51,""Series Images"",?66,""Series Images"""
^XMB(3.9,145834,2,5897,0)="""RTN"",""MAGDSTAA"",143,0)"
^XMB(3.9,145834,2,5898,0)=" I ^TMP(""MAG"",$J,""BATCH Q/R"",""OPTION"")=""RETRIEVE MISSING IMAGES"" D"
^XMB(3.9,145834,2,5899,0)="""RTN"",""MAGDSTAA"",144,0)"
