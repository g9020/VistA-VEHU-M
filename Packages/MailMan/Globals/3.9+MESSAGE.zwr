^XMB(3.9,145834,2,8273,0)="""^DD"",2006.541,2006.5411,2,21,4,0)"
^XMB(3.9,145834,2,8274,0)="name components.  The carets have been replaced with tildes (~) in"
^XMB(3.9,145834,2,8275,0)="""^DD"",2006.541,2006.5411,2,21,5,0)"
^XMB(3.9,145834,2,8276,0)="this field, so as not to be confused with the FM field separators."
