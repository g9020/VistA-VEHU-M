^XMB(3.9,144657,2,7795,0)="""RTN"",""IBCNICB"",127,0)"
^XMB(3.9,144657,2,7796,0)=" Q:""~A~R~""[(""~""_$$GET1^DIQ(355.33,IBBUFDA,.04,""I"")_""~"")"
^XMB(3.9,144657,2,7797,0)="""RTN"",""IBCNICB"",128,0)"
^XMB(3.9,144657,2,7798,0)=" D REJPROC^IBCNBAR"
