^XMB(3.9,145834,2,5974,0)=" . . S TICKER=TICKER+1 S:TICKER<1 TICKER=1 S:TICKER>4 TICKER=1"
^XMB(3.9,145834,2,5975,0)="""RTN"",""MAGDSTAA"",182,0)"
^XMB(3.9,145834,2,5976,0)=" . . I $E(IOST,1,2)=""C-"" W $E(""-\|/"",TICKER),$C(8)"
^XMB(3.9,145834,2,5977,0)="""RTN"",""MAGDSTAA"",183,0)"
^XMB(3.9,145834,2,5978,0)=" . . H 1"
