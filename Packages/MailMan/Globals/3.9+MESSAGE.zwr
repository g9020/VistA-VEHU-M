^XMB(3.9,145833,2,3019,0)="""RTN"",""SDHL7"",118,0)"
^XMB(3.9,145833,2,3020,0)=" I RTCD="""" S ERROR=""An RTC Date is requried"" Q"
^XMB(3.9,145833,2,3021,0)="""RTN"",""SDHL7"",119,0)"
^XMB(3.9,145833,2,3022,0)=" I (RTCD?7N)=0 S ERROR=""RTC order date format error. Use calendar or format T+2W. Time not allowed."" Q"
^XMB(3.9,145833,2,3023,0)="""RTN"",""SDHL7"",120,0)"
