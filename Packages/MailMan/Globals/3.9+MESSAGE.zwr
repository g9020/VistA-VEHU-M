^XMB(3.9,144657,2,7061,0)="""RTN"",""IBCNEUT2"",39,0)"
^XMB(3.9,144657,2,7062,0)="BUFF(BUFF,BNG) ;  Set error symbol into Buffer File"
^XMB(3.9,144657,2,7063,0)="""RTN"",""IBCNEUT2"",40,0)"
^XMB(3.9,144657,2,7064,0)=" ;  Input Parameter"
