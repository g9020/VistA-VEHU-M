^XMB(3.9,145833,2,1022,0)=" ;"
^XMB(3.9,145833,2,1023,0)="""RTN"",""SDES2UTDT"",156,0)"
^XMB(3.9,145833,2,1024,0)="CVTTOFM(D) ;"
^XMB(3.9,145833,2,1025,0)="""RTN"",""SDES2UTDT"",157,0)"
^XMB(3.9,145833,2,1026,0)=" N X,Y,%DT"
^XMB(3.9,145833,2,1027,0)="""RTN"",""SDES2UTDT"",158,0)"
