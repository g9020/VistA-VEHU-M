^XMB(3.9,144657,2,5142,0)=" I $D(DIRUT)!$D(DUOUT)!(Y<1) G SELX"
^XMB(3.9,144657,2,5143,0)="""RTN"",""IBCNEQU"",218,0)"
^XMB(3.9,144657,2,5144,0)=" S IBSELN=$O(^TMP(""IBCNEQU"",$J,""IDX"",Y,0))"
^XMB(3.9,144657,2,5145,0)="""RTN"",""IBCNEQU"",219,0)"
^XMB(3.9,144657,2,5146,0)=" I IBSELN S IBSELN=$P($G(^TMP(""IBCNEQUX"",$J,IBSELN)),U,2,99)"
^XMB(3.9,144657,2,5147,0)="""RTN"",""IBCNEQU"",220,0)"
^XMB(3.9,144657,2,5148,0)=" I $E($P(IBSELN,U,3))=""*"" W ! D  S IBSELN="""" G SELX"
^XMB(3.9,144657,2,5149,0)="""RTN"",""IBCNEQU"",221,0)"
^XMB(3.9,144657,2,5150,0)=" .S DIR(0)=""EA"""
^XMB(3.9,144657,2,5151,0)="""RTN"",""IBCNEQU"",222,0)"
^XMB(3.9,144657,2,5152,0)=" .S DIR(""A"",1)="""""
^XMB(3.9,144657,2,5153,0)="""RTN"",""IBCNEQU"",223,0)"
^XMB(3.9,144657,2,5154,0)=" .S DIR(""A"",2)=""Selected policy has an existing buffer entry."""
^XMB(3.9,144657,2,5155,0)="""RTN"",""IBCNEQU"",224,0)"
^XMB(3.9,144657,2,5156,0)=" .S DIR(""A"",3)=""You must first process the existing buffer entry."""
^XMB(3.9,144657,2,5157,0)="""RTN"",""IBCNEQU"",225,0)"
^XMB(3.9,144657,2,5158,0)=" .S DIR(""A"")=""Press RETURN to continue "" D ^DIR K DIR W !"
