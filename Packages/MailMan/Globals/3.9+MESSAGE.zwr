^XMB(3.9,144657,2,969,0)="""RTN"",""IBCNBAA"",188,0)"
^XMB(3.9,144657,2,970,0)=" W ! S DIR(0)=""YO"",DIR(""A"")=""Is this the correct ""_IBDESC_"" to match with this Patient Registration entry"" D ^DIR I Y=1 S IBX=1"
^XMB(3.9,144657,2,971,0)="""RTN"",""IBCNBAA"",189,0)"
