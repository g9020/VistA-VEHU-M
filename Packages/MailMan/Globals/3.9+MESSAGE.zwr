^XMB(3.9,145833,2,2600,0)=" S (STOPIEN,STOPCOUNT,STOPFOUND)=0"
^XMB(3.9,145833,2,2601,0)="""RTN"",""SDESUTIL"",247,0)"
^XMB(3.9,145833,2,2602,0)=" F  S STOPIEN=$O(^DIC(40.7,""C"",AMIS,STOPIEN)) Q:'STOPIEN  D"
