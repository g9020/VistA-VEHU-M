^XMB(3.9,144661,2,452,0)=" S $P(ORAMD0,""^"",4)=$G(ORAMT4),$P(ORAMD0,""^"",5)=$G(ORAMT5),$P(ORAMD0,""^"",6)=$G(ORAMT6),$P(ORAMD0,""^"",9)=$G(ORAMT9),$P(ORAMD0,""^"",15)=$G(ORAMT15),$P(ORAMD0,""^"",17)=$G(ORAMT17),$P(ORAMD0,""^"",18)=$G(ORAMT18)"
