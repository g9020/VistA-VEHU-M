^XMB(3.9,144657,2,9259,0)="""RTN"",""IBCNSP01"",83,0)"
^XMB(3.9,144657,2,9260,0)=" ;"
^XMB(3.9,144657,2,9261,0)="""RTN"",""IBCNSP01"",84,0)"
^XMB(3.9,144657,2,9262,0)=" F PCE=3,5,7 D            ; subscriber secondary IDs"
^XMB(3.9,144657,2,9263,0)="""RTN"",""IBCNSP01"",85,0)"
^XMB(3.9,144657,2,9264,0)=" . I $P(G,U,PCE)="""" Q     ; no secondary ID#"
^XMB(3.9,144657,2,9265,0)="""RTN"",""IBCNSP01"",86,0)"
^XMB(3.9,144657,2,9266,0)=" . S QUAL=$P(G,U,PCE-1)   ; internal qualifier code"
^XMB(3.9,144657,2,9267,0)="""RTN"",""IBCNSP01"",87,0)"
^XMB(3.9,144657,2,9268,0)=" . S QUAL1=$S(QUAL=""23"":""Client#"",QUAL=""IG"":""Ins. Policy#"",QUAL=""SY"":""SSN"",1:""Unknown"")"
^XMB(3.9,144657,2,9269,0)="""RTN"",""IBCNSP01"",88,0)"
^XMB(3.9,144657,2,9270,0)=" . S IBL=IBL+1"
^XMB(3.9,144657,2,9271,0)="""RTN"",""IBCNSP01"",89,0)"
^XMB(3.9,144657,2,9272,0)=" . D SET^IBCNSP(IBL,OFFSET,""Subscriber Secondary ID: ""_$P(G,U,PCE))"
^XMB(3.9,144657,2,9273,0)="""RTN"",""IBCNSP01"",90,0)"
^XMB(3.9,144657,2,9274,0)=" . D SET^IBCNSP(IBL,52,""ID Qual: ""_QUAL_"" (""_QUAL1_"")"")"
^XMB(3.9,144657,2,9275,0)="""RTN"",""IBCNSP01"",91,0)"
^XMB(3.9,144657,2,9276,0)=" . Q"
^XMB(3.9,144657,2,9277,0)="""RTN"",""IBCNSP01"",92,0)"
^XMB(3.9,144657,2,9278,0)=" ;"
^XMB(3.9,144657,2,9279,0)="""RTN"",""IBCNSP01"",93,0)"
^XMB(3.9,144657,2,9280,0)=" ; patient=subscriber so skip over patient ID# display"
^XMB(3.9,144657,2,9281,0)="""RTN"",""IBCNSP01"",94,0)"
^XMB(3.9,144657,2,9282,0)=" I +$P(IBCDFND,U,16)=1 G ID1"
^XMB(3.9,144657,2,9283,0)="""RTN"",""IBCNSP01"",95,0)"
^XMB(3.9,144657,2,9284,0)=" ;"
^XMB(3.9,144657,2,9285,0)="""RTN"",""IBCNSP01"",96,0)"
^XMB(3.9,144657,2,9286,0)=" S IBL=IBL+1 D SET^IBCNSP(IBL,2,"" "")   ; blank line"
^XMB(3.9,144657,2,9287,0)="""RTN"",""IBCNSP01"",97,0)"
^XMB(3.9,144657,2,9288,0)=" S IBL=IBL+1"
^XMB(3.9,144657,2,9289,0)="""RTN"",""IBCNSP01"",98,0)"
^XMB(3.9,144657,2,9290,0)=" D SET^IBCNSP(IBL,OFFSET,""     Patient Primary ID: ""_$P(G,U,1))"
^XMB(3.9,144657,2,9291,0)="""RTN"",""IBCNSP01"",99,0)"
^XMB(3.9,144657,2,9292,0)=" ;"
^XMB(3.9,144657,2,9293,0)="""RTN"",""IBCNSP01"",100,0)"
^XMB(3.9,144657,2,9294,0)=" F PCE=9,11,13 D          ; patient secondary IDs"
^XMB(3.9,144657,2,9295,0)="""RTN"",""IBCNSP01"",101,0)"
^XMB(3.9,144657,2,9296,0)=" . I $P(G,U,PCE)="""" Q     ; no secondary ID#"
^XMB(3.9,144657,2,9297,0)="""RTN"",""IBCNSP01"",102,0)"
^XMB(3.9,144657,2,9298,0)=" . S QUAL=$P(G,U,PCE-1)   ; internal qualifier code"
^XMB(3.9,144657,2,9299,0)="""RTN"",""IBCNSP01"",103,0)"
^XMB(3.9,144657,2,9300,0)=" . S QUAL1=$S(QUAL=""23"":""Client#"",QUAL=""IG"":""Ins. Policy#"",QUAL=""SY"":""SSN"",1:""Unknown"")"
^XMB(3.9,144657,2,9301,0)="""RTN"",""IBCNSP01"",104,0)"
^XMB(3.9,144657,2,9302,0)=" . S IBL=IBL+1"
^XMB(3.9,144657,2,9303,0)="""RTN"",""IBCNSP01"",105,0)"
^XMB(3.9,144657,2,9304,0)=" . D SET^IBCNSP(IBL,OFFSET,""   Patient Secondary ID: ""_$P(G,U,PCE))"
^XMB(3.9,144657,2,9305,0)="""RTN"",""IBCNSP01"",106,0)"
^XMB(3.9,144657,2,9306,0)=" . D SET^IBCNSP(IBL,52,""ID Qual: ""_QUAL_"" (""_QUAL1_"")"")"
^XMB(3.9,144657,2,9307,0)="""RTN"",""IBCNSP01"",107,0)"
^XMB(3.9,144657,2,9308,0)=" . Q"
^XMB(3.9,144657,2,9309,0)="""RTN"",""IBCNSP01"",108,0)"
^XMB(3.9,144657,2,9310,0)=" ;"
^XMB(3.9,144657,2,9311,0)="""RTN"",""IBCNSP01"",109,0)"
^XMB(3.9,144657,2,9312,0)="ID1 ; end of section - 2 blank lines"
^XMB(3.9,144657,2,9313,0)="""RTN"",""IBCNSP01"",110,0)"
^XMB(3.9,144657,2,9314,0)=" S IBL=IBL+1 D SET^IBCNSP(IBL,2,"" "")"
^XMB(3.9,144657,2,9315,0)="""RTN"",""IBCNSP01"",111,0)"
^XMB(3.9,144657,2,9316,0)=" S IBL=IBL+1 D SET^IBCNSP(IBL,2,"" "")"
^XMB(3.9,144657,2,9317,0)="""RTN"",""IBCNSP01"",112,0)"
^XMB(3.9,144657,2,9318,0)="IDQ ;"
^XMB(3.9,144657,2,9319,0)="""RTN"",""IBCNSP01"",113,0)"
^XMB(3.9,144657,2,9320,0)=" Q"
^XMB(3.9,144657,2,9321,0)="""RTN"",""IBCNSP01"",114,0)"
^XMB(3.9,144657,2,9322,0)=" ;"
^XMB(3.9,144657,2,9323,0)="""RTN"",""IBCNSP01"",115,0)"
^XMB(3.9,144657,2,9324,0)="RIDER ; -- Personal policy riders"
^XMB(3.9,144657,2,9325,0)="""RTN"",""IBCNSP01"",116,0)"
^XMB(3.9,144657,2,9326,0)=" N OFFSET,START,IBI,IBL,IBPR,IBPRD"
^XMB(3.9,144657,2,9327,0)="""RTN"",""IBCNSP01"",117,0)"
^XMB(3.9,144657,2,9328,0)=" S START=$O(^TMP(""IBCNSVP"",$J,""""),-1)+1,OFFSET=2,IBL=0"
^XMB(3.9,144657,2,9329,0)="""RTN"",""IBCNSP01"",118,0)"
^XMB(3.9,144657,2,9330,0)=" D SET^IBCNSP(START,OFFSET,"" Personal Riders "",IORVON,IORVOFF)"
^XMB(3.9,144657,2,9331,0)="""RTN"",""IBCNSP01"",119,0)"
^XMB(3.9,144657,2,9332,0)=" S IBI="""" F  S IBI=$O(^IBA(355.7,""APP"",DFN,IBCDFN,IBI)) Q:'IBI  S IBPR=$O(^(IBI,0)),IBPRD=+$G(^IBA(355.7,IBPR,0)),IBL=IBL+1 D"
^XMB(3.9,144657,2,9333,0)="""RTN"",""IBCNSP01"",120,0)"
^XMB(3.9,144657,2,9334,0)=" . D SET^IBCNSP(START+IBL,OFFSET,""   Rider #""_IBL_"": ""_$$EXPAND^IBTRE(355.7,.01,IBPRD))"
^XMB(3.9,144657,2,9335,0)="""RTN"",""IBCNSP01"",121,0)"
^XMB(3.9,144657,2,9336,0)=" . Q"
^XMB(3.9,144657,2,9337,0)="""RTN"",""IBCNSP01"",122,0)"
^XMB(3.9,144657,2,9338,0)=" S IBL=IBL+1 D SET^IBCNSP(START+IBL,OFFSET,"" "")"
^XMB(3.9,144657,2,9339,0)="""RTN"",""IBCNSP01"",123,0)"
^XMB(3.9,144657,2,9340,0)=" S IBL=IBL+1 D SET^IBCNSP(START+IBL,OFFSET,"" "")"
^XMB(3.9,144657,2,9341,0)="""RTN"",""IBCNSP01"",124,0)"
^XMB(3.9,144657,2,9342,0)=" Q"
^XMB(3.9,144657,2,9343,0)="""RTN"",""IBCNSP01"",125,0)"
^XMB(3.9,144657,2,9344,0)=" ;"
^XMB(3.9,144657,2,9345,0)="""RTN"",""IBCNSP01"",126,0)"
^XMB(3.9,144657,2,9346,0)="AI ; -- Add ins. verification entry"
^XMB(3.9,144657,2,9347,0)="""RTN"",""IBCNSP01"",127,0)"
^XMB(3.9,144657,2,9348,0)=" ;    called from ai^ibcnsp1"
^XMB(3.9,144657,2,9349,0)="""RTN"",""IBCNSP01"",128,0)"
^XMB(3.9,144657,2,9350,0)=" ;"
^XMB(3.9,144657,2,9351,0)="""RTN"",""IBCNSP01"",129,0)"
^XMB(3.9,144657,2,9352,0)=" ; -- see if current inpatient"
^XMB(3.9,144657,2,9353,0)="""RTN"",""IBCNSP01"",130,0)"
^XMB(3.9,144657,2,9354,0)=" D INP^VADPT I +VAIN(1) D"
^XMB(3.9,144657,2,9355,0)="""RTN"",""IBCNSP01"",131,0)"
^XMB(3.9,144657,2,9356,0)=" .S IBTRN=$O(^IBT(356,""AD"",+VAIN(1),0))"
^XMB(3.9,144657,2,9357,0)="""RTN"",""IBCNSP01"",132,0)"
^XMB(3.9,144657,2,9358,0)=" ;"
^XMB(3.9,144657,2,9359,0)="""RTN"",""IBCNSP01"",133,0)"
^XMB(3.9,144657,2,9360,0)=" S IBXIFN=$O(^IBE(356.11,""ACODE"",85,0))"
^XMB(3.9,144657,2,9361,0)="""RTN"",""IBCNSP01"",134,0)"
^XMB(3.9,144657,2,9362,0)=" ;"
^XMB(3.9,144657,2,9363,0)="""RTN"",""IBCNSP01"",135,0)"
^XMB(3.9,144657,2,9364,0)=" ; -- if not tracking id allow selecting"
^XMB(3.9,144657,2,9365,0)="""RTN"",""IBCNSP01"",136,0)"
^XMB(3.9,144657,2,9366,0)=" I '$G(IBTRN) D  G:IBQUIT AIQ"
^XMB(3.9,144657,2,9367,0)="""RTN"",""IBCNSP01"",137,0)"
^XMB(3.9,144657,2,9368,0)=" .W !,""You can now enter a contact and relate it to a Claims Tracking Admission entry."""
^XMB(3.9,144657,2,9369,0)="""RTN"",""IBCNSP01"",138,0)"
^XMB(3.9,144657,2,9370,0)=" .S DIC(""A"")=""Select RELATED ADMISSION DATE: """
^XMB(3.9,144657,2,9371,0)="""RTN"",""IBCNSP01"",139,0)"
^XMB(3.9,144657,2,9372,0)=" .S DIC=""^IBT(356,"",DIC(0)=""AEQ"",D=""ADFN""_DFN,DIC(""S"")=""I $P(^(0),U,5)"""
^XMB(3.9,144657,2,9373,0)="""RTN"",""IBCNSP01"",140,0)"
^XMB(3.9,144657,2,9374,0)=" .D IX^DIC K DA,DR,DIC,DIE I $D(DUOUT)!($D(DTOUT)) S IBQUIT=1 Q"
^XMB(3.9,144657,2,9375,0)="""RTN"",""IBCNSP01"",141,0)"
^XMB(3.9,144657,2,9376,0)=" .I +Y>1 S IBTRN=+Y"
^XMB(3.9,144657,2,9377,0)="""RTN"",""IBCNSP01"",142,0)"
^XMB(3.9,144657,2,9378,0)=" ;"
^XMB(3.9,144657,2,9379,0)="""RTN"",""IBCNSP01"",143,0)"
^XMB(3.9,144657,2,9380,0)=" I '$G(IBTRN) W !!,""Warning: This contact is not associated with any care in Claims Tracking."",!,""You may only edit or view this contact using this action."",!"
^XMB(3.9,144657,2,9381,0)="""RTN"",""IBCNSP01"",144,0)"
^XMB(3.9,144657,2,9382,0)=" ;"
^XMB(3.9,144657,2,9383,0)="""RTN"",""IBCNSP01"",145,0)"
^XMB(3.9,144657,2,9384,0)=" ; -- select date"
^XMB(3.9,144657,2,9385,0)="""RTN"",""IBCNSP01"",146,0)"
^XMB(3.9,144657,2,9386,0)=" S IBOK=0,IBI=0 F  S IBI=$O(^IBT(356.2,""D"",DFN,IBI)) Q:'IBI  I $P($G(^IBT(356.2,+IBI,0)),U,4)=IBXIFN,$P($G(^(1)),U,5)=IBCDFN S IBOK=1"
^XMB(3.9,144657,2,9387,0)="""RTN"",""IBCNSP01"",147,0)"
^XMB(3.9,144657,2,9388,0)=" I IBOK D  G:IBQUIT AIQ"
^XMB(3.9,144657,2,9389,0)="""RTN"",""IBCNSP01"",148,0)"
^XMB(3.9,144657,2,9390,0)=" .S DIC=""^IBT(356.2,"",DIC(""A"")=""Select Contact Date: """
^XMB(3.9,144657,2,9391,0)="""RTN"",""IBCNSP01"",149,0)"
^XMB(3.9,144657,2,9392,0)=" .S X=""??"",DIC(0)=""EQ"",DIC(""S"")=""I $P($G(^(1)),U,5)=IBCDFN,$P(^(0),U,4)=IBXIFN"" ;,DLAYGO=356.2"
^XMB(3.9,144657,2,9393,0)="""RTN"",""IBCNSP01"",150,0)"
^XMB(3.9,144657,2,9394,0)=" .S D=""ADFN""_DFN"
^XMB(3.9,144657,2,9395,0)="""RTN"",""IBCNSP01"",151,0)"
^XMB(3.9,144657,2,9396,0)=" .D IX^DIC K DIC,DR,DA,DIE,D I $D(DUOUT)!($D(DTOUT)) S IBQUIT=1"
^XMB(3.9,144657,2,9397,0)="""RTN"",""IBCNSP01"",152,0)"
^XMB(3.9,144657,2,9398,0)=" ;"
^XMB(3.9,144657,2,9399,0)="""RTN"",""IBCNSP01"",153,0)"
^XMB(3.9,144657,2,9400,0)=" S DIC=""^IBT(356.2,"",DIC(""A"")=""Select Contact Date: "",DIC(""B"")=""TODAY"""
^XMB(3.9,144657,2,9401,0)="""RTN"",""IBCNSP01"",154,0)"
^XMB(3.9,144657,2,9402,0)=" S DIC(""DR"")="".02////""_$G(IBTRN)_"";.04////""_IBXIFN_"";.05////""_DFN_"";.19////1;1.01///NOW;1.02////""_DUZ_"";1.05////""_IBCDFN"
^XMB(3.9,144657,2,9403,0)="""RTN"",""IBCNSP01"",155,0)"
^XMB(3.9,144657,2,9404,0)=" S DIC(0)=""AEQL"",DIC(""S"")=""I $P(^(0),U,5)=DFN,$P($G(^(1)),U,5)=IBCDFN,$P(^(0),U,4)=IBXIFN"",DLAYGO=356.2"
^XMB(3.9,144657,2,9405,0)="""RTN"",""IBCNSP01"",156,0)"
^XMB(3.9,144657,2,9406,0)=" D ^DIC K DIC"
^XMB(3.9,144657,2,9407,0)="""RTN"",""IBCNSP01"",157,0)"
^XMB(3.9,144657,2,9408,0)=" I $D(DTOUT)!($D(DUOUT))!(+Y<1) G AIQ"
^XMB(3.9,144657,2,9409,0)="""RTN"",""IBCNSP01"",158,0)"
^XMB(3.9,144657,2,9410,0)=" S IBTRC=+Y"
^XMB(3.9,144657,2,9411,0)="""RTN"",""IBCNSP01"",159,0)"
^XMB(3.9,144657,2,9412,0)=" I $G(IBTRC),$G(IBTRN),'$P(^IBT(356.2,+IBTRC,0),U,2) S DA=IBTRC,DIE=""^IBT(356.2,"",DR="".02////""_$G(IBTRN) D ^DIE"
^XMB(3.9,144657,2,9413,0)="""RTN"",""IBCNSP01"",160,0)"
^XMB(3.9,144657,2,9414,0)=" ;"
^XMB(3.9,144657,2,9415,0)="""RTN"",""IBCNSP01"",161,0)"
^XMB(3.9,144657,2,9416,0)=" ; -- edit ins ver type"
^XMB(3.9,144657,2,9417,0)="""RTN"",""IBCNSP01"",162,0)"
^XMB(3.9,144657,2,9418,0)=" D EDIT^IBTRCD1(""[IBT INS VERIFICATION]"",1)"
^XMB(3.9,144657,2,9419,0)="""RTN"",""IBCNSP01"",163,0)"
^XMB(3.9,144657,2,9420,0)="AIQ Q"
^XMB(3.9,144657,2,9421,0)="""RTN"",""IBCNSP01"",164,0)"
^XMB(3.9,144657,2,9422,0)=" ;"
^XMB(3.9,144657,2,9423,0)="""RTN"",""IBCNSP01"",165,0)"
^XMB(3.9,144657,2,9424,0)="SPLIT(OFFSET,LABEL,DATA,DATARRY) ; ib*2*497  reformat data that is too large to fit on one line "
^XMB(3.9,144657,2,9425,0)="""RTN"",""IBCNSP01"",166,0)"
^XMB(3.9,144657,2,9426,0)=" ; "
^XMB(3.9,144657,2,9427,0)="""RTN"",""IBCNSP01"",167,0)"
^XMB(3.9,144657,2,9428,0)=" ;  INPUTS"
^XMB(3.9,144657,2,9429,0)="""RTN"",""IBCNSP01"",168,0)"
^XMB(3.9,144657,2,9430,0)=" ;         OFFSET - left margin starting point (e.g., 2)"
^XMB(3.9,144657,2,9431,0)="""RTN"",""IBCNSP01"",169,0)"
^XMB(3.9,144657,2,9432,0)=" ;         LABEL - the data label that gets displayed alongside the actual data (e.g.""subscriber name:)"
^XMB(3.9,144657,2,9433,0)="""RTN"",""IBCNSP01"",170,0)"
^XMB(3.9,144657,2,9434,0)=" ;         DATA - the value to be set for display on a line (e.g.,   IB, PATIENT"")"
^XMB(3.9,144657,2,9435,0)="""RTN"",""IBCNSP01"",171,0)"
^XMB(3.9,144657,2,9436,0)=" ;  OUTPUT"
^XMB(3.9,144657,2,9437,0)="""RTN"",""IBCNSP01"",172,0)"
^XMB(3.9,144657,2,9438,0)=" ;         DATARRY - an array which contains the data to be displayed on more than 1 line"
^XMB(3.9,144657,2,9439,0)="""RTN"",""IBCNSP01"",173,0)"
^XMB(3.9,144657,2,9440,0)=" ;"
^XMB(3.9,144657,2,9441,0)="""RTN"",""IBCNSP01"",174,0)"
^XMB(3.9,144657,2,9442,0)=" N STRING,I,SAVPOS,QUIT"
^XMB(3.9,144657,2,9443,0)="""RTN"",""IBCNSP01"",175,0)"
^XMB(3.9,144657,2,9444,0)=" S STRING=LABEL_DATA"
^XMB(3.9,144657,2,9445,0)="""RTN"",""IBCNSP01"",176,0)"
^XMB(3.9,144657,2,9446,0)=" I $L(STRING)+OFFSET<81 S DATARRY(1)=STRING Q "
^XMB(3.9,144657,2,9447,0)="""RTN"",""IBCNSP01"",177,0)"
^XMB(3.9,144657,2,9448,0)=" S DATARRY(1)=$E(STRING,1,80-OFFSET)"
^XMB(3.9,144657,2,9449,0)="""RTN"",""IBCNSP01"",178,0)"
^XMB(3.9,144657,2,9450,0)=" S SAVPOS=$L(DATARRY(1))"
^XMB(3.9,144657,2,9451,0)="""RTN"",""IBCNSP01"",179,0)"
^XMB(3.9,144657,2,9452,0)=" S QUIT=0 F I=2:1 D  Q:QUIT"
^XMB(3.9,144657,2,9453,0)="""RTN"",""IBCNSP01"",180,0)"
^XMB(3.9,144657,2,9454,0)=" . S DATARRY(I)=$$REPEAT^XLFSTR("" "",$L(LABEL))_$E(STRING,SAVPOS+1,$L(STRING))"
^XMB(3.9,144657,2,9455,0)="""RTN"",""IBCNSP01"",181,0)"
^XMB(3.9,144657,2,9456,0)=" . I $TR(DATARRY(I),"" "")']"""" K DATARRY(I) S QUIT=1 Q"
^XMB(3.9,144657,2,9457,0)="""RTN"",""IBCNSP01"",182,0)"
^XMB(3.9,144657,2,9458,0)=" . I $L(DATARRY(I))+OFFSET>80 S DATARRY(I)=$E(DATARRY(I),1,80-OFFSET) S SAVPOS=SAVPOS+$L(DATARRY(I)) Q"
^XMB(3.9,144657,2,9459,0)="""RTN"",""IBCNSP01"",183,0)"
^XMB(3.9,144657,2,9460,0)=" . S QUIT=1"
^XMB(3.9,144657,2,9461,0)="""RTN"",""IBCNSP01"",184,0)"
^XMB(3.9,144657,2,9462,0)=" Q"
^XMB(3.9,144657,2,9463,0)="""RTN"",""IBJPI"")"
^XMB(3.9,144657,2,9464,0)="0^18^B106855429"
^XMB(3.9,144657,2,9465,0)="""RTN"",""IBJPI"",1,0)"
^XMB(3.9,144657,2,9466,0)="IBJPI ;DAOU/BHS - IBJP eIV SITE PARAMETERS SCREEN ; 01-APR-2015"
^XMB(3.9,144657,2,9467,0)="""RTN"",""IBJPI"",2,0)"
^XMB(3.9,144657,2,9468,0)=" ;;2.0;INTEGRATED BILLING;**184,271,316,416,438,479,506,528,549,601,621,659,668,687,702,732,763,771,806**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,9469,0)="""RTN"",""IBJPI"",3,0)"
^XMB(3.9,144657,2,9470,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,9471,0)="""RTN"",""IBJPI"",4,0)"
^XMB(3.9,144657,2,9472,0)=" ;"
^XMB(3.9,144657,2,9473,0)="""RTN"",""IBJPI"",5,0)"
^XMB(3.9,144657,2,9474,0)=" ;/vd-IB*2*668 - Removed the SSVI logic introduced with IB*2*528 in its entirety within VistA."
^XMB(3.9,144657,2,9475,0)="""RTN"",""IBJPI"",6,0)"
^XMB(3.9,144657,2,9476,0)=" ;"
^XMB(3.9,144657,2,9477,0)="""RTN"",""IBJPI"",7,0)"
^XMB(3.9,144657,2,9478,0)=" ; eIV - Electronic Insurance Verification Interface parameters"
^XMB(3.9,144657,2,9479,0)="""RTN"",""IBJPI"",8,0)"
^XMB(3.9,144657,2,9480,0)=" ;"
^XMB(3.9,144657,2,9481,0)="""RTN"",""IBJPI"",9,0)"
^XMB(3.9,144657,2,9482,0)="EN ; main entry pt for IBJP IIV SITE PARAMS"
^XMB(3.9,144657,2,9483,0)="""RTN"",""IBJPI"",10,0)"
^XMB(3.9,144657,2,9484,0)=" N CTRLCOL,POP,VALMCNT,VALMHDR,X,%DT"
^XMB(3.9,144657,2,9485,0)="""RTN"",""IBJPI"",11,0)"
^XMB(3.9,144657,2,9486,0)=" D EN^VALM(""IBJP IIV SITE PARAMETERS"")"
^XMB(3.9,144657,2,9487,0)="""RTN"",""IBJPI"",12,0)"
^XMB(3.9,144657,2,9488,0)=" Q"
^XMB(3.9,144657,2,9489,0)="""RTN"",""IBJPI"",13,0)"
^XMB(3.9,144657,2,9490,0)=" ;"
^XMB(3.9,144657,2,9491,0)="""RTN"",""IBJPI"",14,0)"
^XMB(3.9,144657,2,9492,0)="HDR ; header "
^XMB(3.9,144657,2,9493,0)="""RTN"",""IBJPI"",15,0)"
^XMB(3.9,144657,2,9494,0)=" S VALMHDR(1)=""Only authorized persons may edit this data."""
^XMB(3.9,144657,2,9495,0)="""RTN"",""IBJPI"",16,0)"
^XMB(3.9,144657,2,9496,0)=" Q"
^XMB(3.9,144657,2,9497,0)="""RTN"",""IBJPI"",17,0)"
^XMB(3.9,144657,2,9498,0)=" ;"
^XMB(3.9,144657,2,9499,0)="""RTN"",""IBJPI"",18,0)"
^XMB(3.9,144657,2,9500,0)="INIT ; init vars & list array"
^XMB(3.9,144657,2,9501,0)="""RTN"",""IBJPI"",19,0)"
^XMB(3.9,144657,2,9502,0)=" K ^TMP($J,""IBJPI"")"
^XMB(3.9,144657,2,9503,0)="""RTN"",""IBJPI"",20,0)"
^XMB(3.9,144657,2,9504,0)=" ; Kills data and video control arrays with active list"
^XMB(3.9,144657,2,9505,0)="""RTN"",""IBJPI"",21,0)"
^XMB(3.9,144657,2,9506,0)=" D CLEAN^VALM10"
^XMB(3.9,144657,2,9507,0)="""RTN"",""IBJPI"",22,0)"
^XMB(3.9,144657,2,9508,0)=" D BLD"
^XMB(3.9,144657,2,9509,0)="""RTN"",""IBJPI"",23,0)"
^XMB(3.9,144657,2,9510,0)=" Q"
^XMB(3.9,144657,2,9511,0)="""RTN"",""IBJPI"",24,0)"
^XMB(3.9,144657,2,9512,0)=" ;"
^XMB(3.9,144657,2,9513,0)="""RTN"",""IBJPI"",25,0)"
^XMB(3.9,144657,2,9514,0)="HELP ; help"
^XMB(3.9,144657,2,9515,0)="""RTN"",""IBJPI"",26,0)"
^XMB(3.9,144657,2,9516,0)=" ; IB*2.0*601,IB*2.0*621/DM adjust help text"
^XMB(3.9,144657,2,9517,0)="""RTN"",""IBJPI"",27,0)"
^XMB(3.9,144657,2,9518,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,9519,0)="""RTN"",""IBJPI"",28,0)"
^XMB(3.9,144657,2,9520,0)=" W @IOF"
^XMB(3.9,144657,2,9521,0)="""RTN"",""IBJPI"",29,0)"
^XMB(3.9,144657,2,9522,0)=" ;IB*732/CKB - modified the text & added text for the Fix Corrupt Buffers action"
^XMB(3.9,144657,2,9523,0)="""RTN"",""IBJPI"",30,0)"
^XMB(3.9,144657,2,9524,0)=" W !,""This screen displays all the eIV and IIU Site Parameters used to manage"""
^XMB(3.9,144657,2,9525,0)="""RTN"",""IBJPI"",31,0)"
^XMB(3.9,144657,2,9526,0)=" W !,""electronic Insurance Verification."""
^XMB(3.9,144657,2,9527,0)="""RTN"",""IBJPI"",32,0)"
^XMB(3.9,144657,2,9528,0)=" W !!,""The General Parameters section concerns overall parameters for"""
^XMB(3.9,144657,2,9529,0)="""RTN"",""IBJPI"",33,0)"
^XMB(3.9,144657,2,9530,0)=" W !,""monitoring the interface and controlling eIV and IIU communication"""
^XMB(3.9,144657,2,9531,0)="""RTN"",""IBJPI"",34,0)"
^XMB(3.9,144657,2,9532,0)=" W !,""between VistA and the EC located in Austin."""
^XMB(3.9,144657,2,9533,0)="""RTN"",""IBJPI"",35,0)"
^XMB(3.9,144657,2,9534,0)=" W !!,""The Batch Extracts section concerns extract-specific parameters"""
^XMB(3.9,144657,2,9535,0)="""RTN"",""IBJPI"",36,0)"
^XMB(3.9,144657,2,9536,0)=" W !,""including active/inactive status and selection criteria. Parameters"""
^XMB(3.9,144657,2,9537,0)="""RTN"",""IBJPI"",37,0)"
^XMB(3.9,144657,2,9538,0)=" W !,""associated with a specific extract may also be detailed here."""
^XMB(3.9,144657,2,9539,0)="""RTN"",""IBJPI"",38,0)"
^XMB(3.9,144657,2,9540,0)=" W !!,""The Fix Corrupt Buffers action allows a user to list or fix corrupted entries in"""
^XMB(3.9,144657,2,9541,0)="""RTN"",""IBJPI"",39,0)"
^XMB(3.9,144657,2,9542,0)=" W !,""the INSURANCE VERIFICATION PROCESSOR file (#355.33) aka """"the buffer file""""."""
^XMB(3.9,144657,2,9543,0)="""RTN"",""IBJPI"",40,0)"
^XMB(3.9,144657,2,9544,0)=" ;IB*806/CKB - add help text for 'Duplicate Buffer Clean up'"
^XMB(3.9,144657,2,9545,0)="""RTN"",""IBJPI"",41,0)"
^XMB(3.9,144657,2,9546,0)=" W !!,""The Duplicate Buffer Clean up action is a nightly process that rejects"""
^XMB(3.9,144657,2,9547,0)="""RTN"",""IBJPI"",42,0)"
^XMB(3.9,144657,2,9548,0)=" W !,""duplicate entries from the INSURANCE VERIFICATION PROCESSOR file (#355.33)."""
^XMB(3.9,144657,2,9549,0)="""RTN"",""IBJPI"",43,0)"
^XMB(3.9,144657,2,9550,0)=" W !,""Duplicate entries are defined as having identical Insurance Company name,"""
^XMB(3.9,144657,2,9551,0)="""RTN"",""IBJPI"",44,0)"
^XMB(3.9,144657,2,9552,0)=" W !,""Subscriber ID and Group Number for a unique patient. When the action is set"""
^XMB(3.9,144657,2,9553,0)="""RTN"",""IBJPI"",45,0)"
^XMB(3.9,144657,2,9554,0)=" W !,""to YES, the cleanup process will reject the most recent duplicates, leaving"""
^XMB(3.9,144657,2,9555,0)="""RTN"",""IBJPI"",46,0)"
^XMB(3.9,144657,2,9556,0)=" W !,""the oldest entry."""
^XMB(3.9,144657,2,9557,0)="""RTN"",""IBJPI"",47,0)"
^XMB(3.9,144657,2,9558,0)=" D PAUSE^VALM1"
^XMB(3.9,144657,2,9559,0)="""RTN"",""IBJPI"",48,0)"
^XMB(3.9,144657,2,9560,0)=" W @IOF"
^XMB(3.9,144657,2,9561,0)="""RTN"",""IBJPI"",49,0)"
^XMB(3.9,144657,2,9562,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,9563,0)="""RTN"",""IBJPI"",50,0)"
^XMB(3.9,144657,2,9564,0)=" Q"
^XMB(3.9,144657,2,9565,0)="""RTN"",""IBJPI"",51,0)"
^XMB(3.9,144657,2,9566,0)=" ;"
^XMB(3.9,144657,2,9567,0)="""RTN"",""IBJPI"",52,0)"
^XMB(3.9,144657,2,9568,0)="EXIT ; exit"
^XMB(3.9,144657,2,9569,0)="""RTN"",""IBJPI"",53,0)"
^XMB(3.9,144657,2,9570,0)=" K ^TMP($J,""IBJPI"")"
^XMB(3.9,144657,2,9571,0)="""RTN"",""IBJPI"",54,0)"
^XMB(3.9,144657,2,9572,0)=" D CLEAN^VALM10"
^XMB(3.9,144657,2,9573,0)="""RTN"",""IBJPI"",55,0)"
^XMB(3.9,144657,2,9574,0)=" Q"
^XMB(3.9,144657,2,9575,0)="""RTN"",""IBJPI"",56,0)"
^XMB(3.9,144657,2,9576,0)=" ;"
^XMB(3.9,144657,2,9577,0)="""RTN"",""IBJPI"",57,0)"
^XMB(3.9,144657,2,9578,0)="BLD ; Creates the body of the worklist"
^XMB(3.9,144657,2,9579,0)="""RTN"",""IBJPI"",58,0)"
^XMB(3.9,144657,2,9580,0)=" ; IB*2.0*549 - rewrote this entire method and all methods called from it to"
^XMB(3.9,144657,2,9581,0)="""RTN"",""IBJPI"",59,0)"
^XMB(3.9,144657,2,9582,0)=" ;              change to a totally new display of fields"
^XMB(3.9,144657,2,9583,0)="""RTN"",""IBJPI"",60,0)"
^XMB(3.9,144657,2,9584,0)=" N ELINEL,ELINER,SLINE,STARTR"
^XMB(3.9,144657,2,9585,0)="""RTN"",""IBJPI"",61,0)"
^XMB(3.9,144657,2,9586,0)=" S VALMCNT=0,SLINE=1"
^XMB(3.9,144657,2,9587,0)="""RTN"",""IBJPI"",62,0)"
^XMB(3.9,144657,2,9588,0)=" D BLDGENE(SLINE,.ELINEL)                       ; Build Editable General Parameters"
^XMB(3.9,144657,2,9589,0)="""RTN"",""IBJPI"",63,0)"
^XMB(3.9,144657,2,9590,0)=" D BLDGENNL(ELINEL,.STARTR,.ELINEL)             ; Build Non-Editable Gen Param left"
^XMB(3.9,144657,2,9591,0)="""RTN"",""IBJPI"",64,0)"
^XMB(3.9,144657,2,9592,0)=" D BLDGENNR(STARTR,.ELINER)                     ; Build Non-Editable Gen Param Right"
^XMB(3.9,144657,2,9593,0)="""RTN"",""IBJPI"",65,0)"
^XMB(3.9,144657,2,9594,0)=" S SLINE=$S(ELINEL>ELINER:ELINEL,1:ELINER)"
^XMB(3.9,144657,2,9595,0)="""RTN"",""IBJPI"",66,0)"
^XMB(3.9,144657,2,9596,0)=" D BLDGENNB(SLINE,.ELINEL)                      ; Build Non-Editable Bottom Params"
^XMB(3.9,144657,2,9597,0)="""RTN"",""IBJPI"",67,0)"
^XMB(3.9,144657,2,9598,0)=" ;IB*806/CKB - added update SLINE and call to BLDBC"
^XMB(3.9,144657,2,9599,0)="""RTN"",""IBJPI"",68,0)"
^XMB(3.9,144657,2,9600,0)=" S SLINE=$S(ELINEL>ELINER:ELINEL,1:ELINER)"
^XMB(3.9,144657,2,9601,0)="""RTN"",""IBJPI"",69,0)"
^XMB(3.9,144657,2,9602,0)=" D BLDBC(SLINE,.ELINEL)                         ; Build Buffer Cleanup Parameters - IB*806/CKB"
^XMB(3.9,144657,2,9603,0)="""RTN"",""IBJPI"",70,0)"
^XMB(3.9,144657,2,9604,0)=" D BLDBE(ELINEL,.ELINEL)                        ; Build Batch Extract Gen Parameters"
^XMB(3.9,144657,2,9605,0)="""RTN"",""IBJPI"",71,0)"
^XMB(3.9,144657,2,9606,0)=" D BLDGENNS(.ELINEL)                     ; Build Non-Editable IIU Parameters - vd/IB*2*687"
^XMB(3.9,144657,2,9607,0)="""RTN"",""IBJPI"",72,0)"
^XMB(3.9,144657,2,9608,0)=" S VALMCNT=ELINEL-1"
^XMB(3.9,144657,2,9609,0)="""RTN"",""IBJPI"",73,0)"
^XMB(3.9,144657,2,9610,0)=" Q"
^XMB(3.9,144657,2,9611,0)="""RTN"",""IBJPI"",74,0)"
^XMB(3.9,144657,2,9612,0)=" ;"
^XMB(3.9,144657,2,9613,0)="""RTN"",""IBJPI"",75,0)"
^XMB(3.9,144657,2,9614,0)="BLDGENE(SLINE,ELINE) ; Build the General Editable Parameters Section"
^XMB(3.9,144657,2,9615,0)="""RTN"",""IBJPI"",76,0)"
^XMB(3.9,144657,2,9616,0)=" ; Input:   SLINE   - Starting Section Line Number"
^XMB(3.9,144657,2,9617,0)="""RTN"",""IBJPI"",77,0)"
^XMB(3.9,144657,2,9618,0)=" ;          ELINE   - Current Ending Section Line Number"
^XMB(3.9,144657,2,9619,0)="""RTN"",""IBJPI"",78,0)"
^XMB(3.9,144657,2,9620,0)=" ; Output:  ELINE   - Updated Ending Section Line Number"
^XMB(3.9,144657,2,9621,0)="""RTN"",""IBJPI"",79,0)"
^XMB(3.9,144657,2,9622,0)=" ;"
^XMB(3.9,144657,2,9623,0)="""RTN"",""IBJPI"",80,0)"
^XMB(3.9,144657,2,9624,0)=" ;IB*771/TAZ - Completely restructured the section"
^XMB(3.9,144657,2,9625,0)="""RTN"",""IBJPI"",81,0)"
^XMB(3.9,144657,2,9626,0)=" N STRTLN,XX   ;/vd-IB*2*687 - added the STRTLN variable"
^XMB(3.9,144657,2,9627,0)="""RTN"",""IBJPI"",82,0)"
^XMB(3.9,144657,2,9628,0)=" S ELINE=$$SETN(""General Parameters (editable)"",SLINE,1,1)"
