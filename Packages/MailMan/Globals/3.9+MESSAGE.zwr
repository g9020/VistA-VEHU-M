^XMB(3.9,145834,2,843,0)="""RTN"",""MAGBRTE4"",96,0)"
^XMB(3.9,145834,2,844,0)=" N D ;-------- Data type"
^XMB(3.9,145834,2,845,0)="""RTN"",""MAGBRTE4"",97,0)"
^XMB(3.9,145834,2,846,0)=" N DS ;------- Data type enclosed in space-characters"
^XMB(3.9,145834,2,847,0)="""RTN"",""MAGBRTE4"",98,0)"
^XMB(3.9,145834,2,848,0)=" N F ;-------- ..."
^XMB(3.9,145834,2,849,0)="""RTN"",""MAGBRTE4"",99,0)"
^XMB(3.9,145834,2,850,0)=" N METMSG ;--- Message to be issued when rule is evaluated"
^XMB(3.9,145834,2,851,0)="""RTN"",""MAGBRTE4"",100,0)"
^XMB(3.9,145834,2,852,0)=" N O ;-------- Operator"
^XMB(3.9,145834,2,853,0)="""RTN"",""MAGBRTE4"",101,0)"
^XMB(3.9,145834,2,854,0)=" N OK ;------- Flag: indicates whether or not rule is met"
^XMB(3.9,145834,2,855,0)="""RTN"",""MAGBRTE4"",102,0)"
^XMB(3.9,145834,2,856,0)=" N RDT ;------ Current date (don't use DT, process might run over midnight)"
^XMB(3.9,145834,2,857,0)="""RTN"",""MAGBRTE4"",103,0)"
^XMB(3.9,145834,2,858,0)=" N STUDYUID ;- Study UID"
^XMB(3.9,145834,2,859,0)="""RTN"",""MAGBRTE4"",104,0)"
^XMB(3.9,145834,2,860,0)=" N V ;-------- Value for property as specified in rule"
^XMB(3.9,145834,2,861,0)="""RTN"",""MAGBRTE4"",105,0)"
^XMB(3.9,145834,2,862,0)=" N VAL ;------ Actual value of property"
^XMB(3.9,145834,2,863,0)="""RTN"",""MAGBRTE4"",106,0)"
^XMB(3.9,145834,2,864,0)=" N VRS ;------ String of Queue Entry numbers when rule(s) are met"
^XMB(3.9,145834,2,865,0)="""RTN"",""MAGBRTE4"",107,0)"
^XMB(3.9,145834,2,866,0)=" N X ;-------- Scratch variable"
^XMB(3.9,145834,2,867,0)="""RTN"",""MAGBRTE4"",108,0)"
^XMB(3.9,145834,2,868,0)=" ;"
^XMB(3.9,145834,2,869,0)="""RTN"",""MAGBRTE4"",109,0)"
^XMB(3.9,145834,2,870,0)=" S VRS="""""
^XMB(3.9,145834,2,871,0)="""RTN"",""MAGBRTE4"",110,0)"
^XMB(3.9,145834,2,872,0)=" ;"
^XMB(3.9,145834,2,873,0)="""RTN"",""MAGBRTE4"",111,0)"
^XMB(3.9,145834,2,874,0)=" D KEYWORD^MAGBRTK"
^XMB(3.9,145834,2,875,0)="""RTN"",""MAGBRTE4"",112,0)"
^XMB(3.9,145834,2,876,0)=" ;"
^XMB(3.9,145834,2,877,0)="""RTN"",""MAGBRTE4"",113,0)"
^XMB(3.9,145834,2,878,0)=" D FILEFIND^MAGDFB(IMAGE,""FULL"",0,0,.MAGFILE1)"
^XMB(3.9,145834,2,879,0)="""RTN"",""MAGBRTE4"",114,0)"
^XMB(3.9,145834,2,880,0)=" Q:MAGFILE1<0 MAGFILE1"
^XMB(3.9,145834,2,881,0)="""RTN"",""MAGBRTE4"",115,0)"
^XMB(3.9,145834,2,882,0)=" ;"
^XMB(3.9,145834,2,883,0)="""RTN"",""MAGBRTE4"",116,0)"
^XMB(3.9,145834,2,884,0)=" S STUDYUID=$P($G(^MAG(2005,IMAGE,""PACS"")),""^"",1)"
^XMB(3.9,145834,2,885,0)="""RTN"",""MAGBRTE4"",117,0)"
^XMB(3.9,145834,2,886,0)=" S X=$P($G(^MAG(2005,IMAGE,0)),""^"",10)"
^XMB(3.9,145834,2,887,0)="""RTN"",""MAGBRTE4"",118,0)"
^XMB(3.9,145834,2,888,0)=" S:X STUDYUID=$P($G(^MAG(2005,X,""PACS"")),""^"",1)"
^XMB(3.9,145834,2,889,0)="""RTN"",""MAGBRTE4"",119,0)"
^XMB(3.9,145834,2,890,0)=" ;"
^XMB(3.9,145834,2,891,0)="""RTN"",""MAGBRTE4"",120,0)"
^XMB(3.9,145834,2,892,0)=" S RULE=0 F  S RULE=$O(RULE(RULE)) Q:'RULE  D"
^XMB(3.9,145834,2,893,0)="""RTN"",""MAGBRTE4"",121,0)"
^XMB(3.9,145834,2,894,0)=" . S METMSG=$G(RULE(RULE,""ACTION""))"
^XMB(3.9,145834,2,895,0)="""RTN"",""MAGBRTE4"",122,0)"
^XMB(3.9,145834,2,896,0)=" . S X="" ("",C=0 F  S C=$O(RULE(RULE,""ACTION"",C)) Q:'C  D"
^XMB(3.9,145834,2,897,0)="""RTN"",""MAGBRTE4"",123,0)"
^XMB(3.9,145834,2,898,0)=" . . S METMSG=METMSG_X_$G(RULE(RULE,""ACTION"",C)),X="", """
^XMB(3.9,145834,2,899,0)="""RTN"",""MAGBRTE4"",124,0)"
^XMB(3.9,145834,2,900,0)=" . . Q"
^XMB(3.9,145834,2,901,0)="""RTN"",""MAGBRTE4"",125,0)"
^XMB(3.9,145834,2,902,0)=" . S:X'="" ("" METMSG=METMSG_"")"""
^XMB(3.9,145834,2,903,0)="""RTN"",""MAGBRTE4"",126,0)"
^XMB(3.9,145834,2,904,0)=" . S:METMSG="""" METMSG=""Rule #""_RULE"
^XMB(3.9,145834,2,905,0)="""RTN"",""MAGBRTE4"",127,0)"
^XMB(3.9,145834,2,906,0)=" . I (STUDYUID="""")!(ZTSK="""")!(RULE="""") Q  ; P156 DAC - Prevent deleted groups from causing hard crashes"
^XMB(3.9,145834,2,907,0)="""RTN"",""MAGBRTE4"",128,0)"
^XMB(3.9,145834,2,908,0)=" . S OK=$G(^XTMP(""MAGEVALSTUDY"",ZTSK,STUDYUID,RULE))"
^XMB(3.9,145834,2,909,0)="""RTN"",""MAGBRTE4"",129,0)"
^XMB(3.9,145834,2,910,0)=" . I OK="""" S OK=1,C=0 F  S C=$O(RULE(RULE,""CONDITION"",C)) Q:'C  D  Q:'OK"
^XMB(3.9,145834,2,911,0)="""RTN"",""MAGBRTE4"",130,0)"
^XMB(3.9,145834,2,912,0)=" . . S F=$G(RULE(RULE,""CONDITION"",C,""KW"")) Q:F="""""
^XMB(3.9,145834,2,913,0)="""RTN"",""MAGBRTE4"",131,0)"
^XMB(3.9,145834,2,914,0)=" . . S X=$G(KEYWORD(""CONDITION"",F),""^DICOM^MAGBRTE3(F,""""OUT"""",.VAL)"")"
^XMB(3.9,145834,2,915,0)="""RTN"",""MAGBRTE4"",132,0)"
^XMB(3.9,145834,2,916,0)=" . . K VAL D @$P(X,""^"",2,9)"
^XMB(3.9,145834,2,917,0)="""RTN"",""MAGBRTE4"",133,0)"
^XMB(3.9,145834,2,918,0)=" . . ; If the field is not defined, the test passes..."
^XMB(3.9,145834,2,919,0)="""RTN"",""MAGBRTE4"",134,0)"
^XMB(3.9,145834,2,920,0)=" . . Q:$D(VAL)'=1  ; We won't deal with multiple values just yet..."
^XMB(3.9,145834,2,921,0)="""RTN"",""MAGBRTE4"",135,0)"
^XMB(3.9,145834,2,922,0)=" . . ;"
^XMB(3.9,145834,2,923,0)="""RTN"",""MAGBRTE4"",136,0)"
^XMB(3.9,145834,2,924,0)=" . . S V=$G(RULE(RULE,""CONDITION"",C,""VA""))"
^XMB(3.9,145834,2,925,0)="""RTN"",""MAGBRTE4"",137,0)"
^XMB(3.9,145834,2,926,0)=" . . S D=$G(RULE(RULE,""CONDITION"",C,""DT""))"
^XMB(3.9,145834,2,927,0)="""RTN"",""MAGBRTE4"",138,0)"
^XMB(3.9,145834,2,928,0)=" . . S O=$G(RULE(RULE,""CONDITION"",C,""OP""))"
^XMB(3.9,145834,2,929,0)="""RTN"",""MAGBRTE4"",139,0)"
^XMB(3.9,145834,2,930,0)=" . . S:D="""" D=""S"""
^XMB(3.9,145834,2,931,0)="""RTN"",""MAGBRTE4"",140,0)"
^XMB(3.9,145834,2,932,0)=" . . S DS="" ""_D_"" """
^XMB(3.9,145834,2,933,0)="""RTN"",""MAGBRTE4"",141,0)"
^XMB(3.9,145834,2,934,0)=" . . D:"" S CS DS IS LO LT OB OW PN SH ST ""[DS"
^XMB(3.9,145834,2,935,0)="""RTN"",""MAGBRTE4"",142,0)"
^XMB(3.9,145834,2,936,0)=" . . . N WILD ;-- Wildcard to be matched"
^XMB(3.9,145834,2,937,0)="""RTN"",""MAGBRTE4"",143,0)"
^XMB(3.9,145834,2,938,0)=" . . . S WILD=$$WLDMATCH^MAGBRTE5(VAL,V)"
^XMB(3.9,145834,2,939,0)="""RTN"",""MAGBRTE4"",144,0)"
^XMB(3.9,145834,2,940,0)=" . . . I O=""="",'WILD S OK=0 Q"
^XMB(3.9,145834,2,941,0)="""RTN"",""MAGBRTE4"",145,0)"
^XMB(3.9,145834,2,942,0)=" . . . I O=""!="",WILD S OK=0 Q"
^XMB(3.9,145834,2,943,0)="""RTN"",""MAGBRTE4"",146,0)"
^XMB(3.9,145834,2,944,0)=" . . . Q"
^XMB(3.9,145834,2,945,0)="""RTN"",""MAGBRTE4"",147,0)"
^XMB(3.9,145834,2,946,0)=" . . D:"" DT DA TM ""[DS"
^XMB(3.9,145834,2,947,0)="""RTN"",""MAGBRTE4"",148,0)"
^XMB(3.9,145834,2,948,0)=" . . . Q:O'=""=""  ; Only ""within range"" comparisons allowed currently"
^XMB(3.9,145834,2,949,0)="""RTN"",""MAGBRTE4"",149,0)"
^XMB(3.9,145834,2,950,0)=" . . . ;"
^XMB(3.9,145834,2,951,0)="""RTN"",""MAGBRTE4"",150,0)"
^XMB(3.9,145834,2,952,0)=" . . . N A ;--- Flag: indicates whether at least one time-frame matches"
^XMB(3.9,145834,2,953,0)="""RTN"",""MAGBRTE4"",151,0)"
^XMB(3.9,145834,2,954,0)=" . . . N B ;--- Begin date/time"
^XMB(3.9,145834,2,955,0)="""RTN"",""MAGBRTE4"",152,0)"
^XMB(3.9,145834,2,956,0)=" . . . N E ;--- End date/time"
^XMB(3.9,145834,2,957,0)="""RTN"",""MAGBRTE4"",153,0)"
^XMB(3.9,145834,2,958,0)=" . . . N I ;--- Loopcounter"
^XMB(3.9,145834,2,959,0)="""RTN"",""MAGBRTE4"",154,0)"
^XMB(3.9,145834,2,960,0)=" . . . N M ;--- Date/time mask"
^XMB(3.9,145834,2,961,0)="""RTN"",""MAGBRTE4"",155,0)"
^XMB(3.9,145834,2,962,0)=" . . . N N ;--- Loopcounter (time-frames)"
^XMB(3.9,145834,2,963,0)="""RTN"",""MAGBRTE4"",156,0)"
^XMB(3.9,145834,2,964,0)=" . . . N %T ;-- FileMan internal variable"
^XMB(3.9,145834,2,965,0)="""RTN"",""MAGBRTE4"",157,0)"
^XMB(3.9,145834,2,966,0)=" . . . N VV ;-- Actual value"
^XMB(3.9,145834,2,967,0)="""RTN"",""MAGBRTE4"",158,0)"
^XMB(3.9,145834,2,968,0)=" . . . N WD ;-- Weekday"
^XMB(3.9,145834,2,969,0)="""RTN"",""MAGBRTE4"",159,0)"
^XMB(3.9,145834,2,970,0)=" . . . N X1 ;-- FileMan API parameter value -- date"
^XMB(3.9,145834,2,971,0)="""RTN"",""MAGBRTE4"",160,0)"
^XMB(3.9,145834,2,972,0)=" . . . N X2 ;-- FileMan API parameter value -- date"
^XMB(3.9,145834,2,973,0)="""RTN"",""MAGBRTE4"",161,0)"
^XMB(3.9,145834,2,974,0)=" . . . ;"
^XMB(3.9,145834,2,975,0)="""RTN"",""MAGBRTE4"",162,0)"
^XMB(3.9,145834,2,976,0)=" . . . ; convert the literal date/time field into the format for comparison"
^XMB(3.9,145834,2,977,0)="""RTN"",""MAGBRTE4"",163,0)"
^XMB(3.9,145834,2,978,0)=" . . . S VV=VAL"
^XMB(3.9,145834,2,979,0)="""RTN"",""MAGBRTE4"",164,0)"
^XMB(3.9,145834,2,980,0)=" . . . ;"
^XMB(3.9,145834,2,981,0)="""RTN"",""MAGBRTE4"",165,0)"
^XMB(3.9,145834,2,982,0)=" . . . S (A,N)=0 F  S N=$O(RULE(RULE,""CONDITION"",C,""VA"",N)) Q:'N  D"
^XMB(3.9,145834,2,983,0)="""RTN"",""MAGBRTE4"",166,0)"
^XMB(3.9,145834,2,984,0)=" . . . . N T,VB,VC,VE"
^XMB(3.9,145834,2,985,0)="""RTN"",""MAGBRTE4"",167,0)"
^XMB(3.9,145834,2,986,0)=" . . . . S M=$G(RULE(RULE,""CONDITION"",C,""VA"",N,""M""))"
^XMB(3.9,145834,2,987,0)="""RTN"",""MAGBRTE4"",168,0)"
^XMB(3.9,145834,2,988,0)=" . . . . S B=$G(RULE(RULE,""CONDITION"",C,""VA"",N,""B""))"
^XMB(3.9,145834,2,989,0)="""RTN"",""MAGBRTE4"",169,0)"
^XMB(3.9,145834,2,990,0)=" . . . . S E=$G(RULE(RULE,""CONDITION"",C,""VA"",N,""E""))"
^XMB(3.9,145834,2,991,0)="""RTN"",""MAGBRTE4"",170,0)"
^XMB(3.9,145834,2,992,0)=" . . . . S T=1"
^XMB(3.9,145834,2,993,0)="""RTN"",""MAGBRTE4"",171,0)"
^XMB(3.9,145834,2,994,0)=" . . . . I $E(M,1,3)=""HOL"" S:$$GET1^DIQ(40.5,+$E(VV,5,11),.01)="""" T=0 ; IA 10038"
^XMB(3.9,145834,2,995,0)="""RTN"",""MAGBRTE4"",172,0)"
^XMB(3.9,145834,2,996,0)=" . . . . I $E(M,1,3)=""DDD"",$E(B,1,3)'=$E(VAL,1,3) S T=0"
^XMB(3.9,145834,2,997,0)="""RTN"",""MAGBRTE4"",173,0)"
^XMB(3.9,145834,2,998,0)=" . . . . S (VB,VC,VE)="""""
^XMB(3.9,145834,2,999,0)="""RTN"",""MAGBRTE4"",174,0)"
^XMB(3.9,145834,2,1000,0)=" . . . . F I=4:1:$L(M) S:$E(M,I)?1U VC=VC_$E(VV,I),VB=VB_$E(B,I),VE=VE_$E(E,I)"
^XMB(3.9,145834,2,1001,0)="""RTN"",""MAGBRTE4"",175,0)"
^XMB(3.9,145834,2,1002,0)=" . . . . S:VB>VC T=0"
^XMB(3.9,145834,2,1003,0)="""RTN"",""MAGBRTE4"",176,0)"
^XMB(3.9,145834,2,1004,0)=" . . . . S:VE<VC T=0"
^XMB(3.9,145834,2,1005,0)="""RTN"",""MAGBRTE4"",177,0)"
^XMB(3.9,145834,2,1006,0)=" . . . . S:T A=1"
^XMB(3.9,145834,2,1007,0)="""RTN"",""MAGBRTE4"",178,0)"
^XMB(3.9,145834,2,1008,0)=" . . . . Q"
^XMB(3.9,145834,2,1009,0)="""RTN"",""MAGBRTE4"",179,0)"
^XMB(3.9,145834,2,1010,0)=" . . . S:'A OK=0"
^XMB(3.9,145834,2,1011,0)="""RTN"",""MAGBRTE4"",180,0)"
^XMB(3.9,145834,2,1012,0)=" . . . Q"
^XMB(3.9,145834,2,1013,0)="""RTN"",""MAGBRTE4"",181,0)"
^XMB(3.9,145834,2,1014,0)=" . . Q"
^XMB(3.9,145834,2,1015,0)="""RTN"",""MAGBRTE4"",182,0)"
^XMB(3.9,145834,2,1016,0)=" . S ^XTMP(""MAGEVALSTUDY"",ZTSK,STUDYUID,RULE)=OK"
^XMB(3.9,145834,2,1017,0)="""RTN"",""MAGBRTE4"",183,0)"
^XMB(3.9,145834,2,1018,0)=" . S METMSG(OK,METMSG)="""""
^XMB(3.9,145834,2,1019,0)="""RTN"",""MAGBRTE4"",184,0)"
^XMB(3.9,145834,2,1020,0)=" . S RDT=$$NOW^XLFDT()\1"
^XMB(3.9,145834,2,1021,0)="""RTN"",""MAGBRTE4"",185,0)"
^XMB(3.9,145834,2,1022,0)=" . Q:'OK"
^XMB(3.9,145834,2,1023,0)="""RTN"",""MAGBRTE4"",186,0)"
^XMB(3.9,145834,2,1024,0)=" . S ACTION=$G(RULE(RULE,""ACTION""))"
^XMB(3.9,145834,2,1025,0)="""RTN"",""MAGBRTE4"",187,0)"
^XMB(3.9,145834,2,1026,0)=" . Q:ACTION="""""
^XMB(3.9,145834,2,1027,0)="""RTN"",""MAGBRTE4"",188,0)"
^XMB(3.9,145834,2,1028,0)=" . I ACTION=""SEND"" D  Q"
^XMB(3.9,145834,2,1029,0)="""RTN"",""MAGBRTE4"",189,0)"
^XMB(3.9,145834,2,1030,0)=" . . N D,PRI,X"
^XMB(3.9,145834,2,1031,0)="""RTN"",""MAGBRTE4"",190,0)"
^XMB(3.9,145834,2,1032,0)=" . . S X=$G(RULE(RULE,""ACTION"",1))"
^XMB(3.9,145834,2,1033,0)="""RTN"",""MAGBRTE4"",191,0)"
^XMB(3.9,145834,2,1034,0)=" . . I X="""" S METMSG(0,""No location for rule ""_RULE)="""" Q"
^XMB(3.9,145834,2,1035,0)="""RTN"",""MAGBRTE4"",192,0)"
^XMB(3.9,145834,2,1036,0)=" . . D VALDEST^MAGDRPC1(.D,X)"
^XMB(3.9,145834,2,1037,0)="""RTN"",""MAGBRTE4"",193,0)"
^XMB(3.9,145834,2,1038,0)=" . . I D<0 S METMSG(0,""Cannot find location """"""_X_""""""."")="""" Q"
^XMB(3.9,145834,2,1039,0)="""RTN"",""MAGBRTE4"",194,0)"
^XMB(3.9,145834,2,1040,0)=" . . S PRI=$$PRI($G(RULE(RULE,""PRIORITY"")),IMAGE)"
^XMB(3.9,145834,2,1041,0)="""RTN"",""MAGBRTE4"",195,0)"
^XMB(3.9,145834,2,1042,0)=" . . S VRS=$$VRS^MAGBRTE5(VRS,$$SEND^MAGBRTE5(IMAGE,D,PRI,1,LOCATION))"
^XMB(3.9,145834,2,1043,0)="""RTN"",""MAGBRTE4"",196,0)"
^XMB(3.9,145834,2,1044,0)=" . . Q"
^XMB(3.9,145834,2,1045,0)="""RTN"",""MAGBRTE4"",197,0)"
^XMB(3.9,145834,2,1046,0)=" . I ACTION=""DICOM"" D  Q"
^XMB(3.9,145834,2,1047,0)="""RTN"",""MAGBRTE4"",198,0)"
^XMB(3.9,145834,2,1048,0)=" . . N D,PRI,X"
^XMB(3.9,145834,2,1049,0)="""RTN"",""MAGBRTE4"",199,0)"
^XMB(3.9,145834,2,1050,0)=" . . S X=$G(RULE(RULE,""ACTION"",1))"
^XMB(3.9,145834,2,1051,0)="""RTN"",""MAGBRTE4"",200,0)"
^XMB(3.9,145834,2,1052,0)=" . . I X="""" S METMSG(0,""No location for rule ""_RULE)="""" Q"
^XMB(3.9,145834,2,1053,0)="""RTN"",""MAGBRTE4"",201,0)"
^XMB(3.9,145834,2,1054,0)=" . . S D=$O(^MAG(2006.587,""B"",X,""""))"
^XMB(3.9,145834,2,1055,0)="""RTN"",""MAGBRTE4"",202,0)"
^XMB(3.9,145834,2,1056,0)=" . . I D="""" S METMSG(0,""Cannot find location """"""_X_""""""."")="""" Q"
^XMB(3.9,145834,2,1057,0)="""RTN"",""MAGBRTE4"",203,0)"
^XMB(3.9,145834,2,1058,0)=" . . S PRI=$$PRI($G(RULE(RULE,""PRIORITY"")),IMAGE)"
^XMB(3.9,145834,2,1059,0)="""RTN"",""MAGBRTE4"",204,0)"
^XMB(3.9,145834,2,1060,0)=" . . S VRS=$$VRS^MAGBRTE5(VRS,$$SEND^MAGBRTE5(IMAGE,D,PRI,2,LOCATION))"
^XMB(3.9,145834,2,1061,0)="""RTN"",""MAGBRTE4"",205,0)"
^XMB(3.9,145834,2,1062,0)=" . . Q"
^XMB(3.9,145834,2,1063,0)="""RTN"",""MAGBRTE4"",206,0)"
^XMB(3.9,145834,2,1064,0)=" . I ACTION=""BALANCE"" D BALANCE^MAGBRTE5(IMAGE,.RULE) Q"
^XMB(3.9,145834,2,1065,0)="""RTN"",""MAGBRTE4"",207,0)"
^XMB(3.9,145834,2,1066,0)=" . ;"
^XMB(3.9,145834,2,1067,0)="""RTN"",""MAGBRTE4"",208,0)"
^XMB(3.9,145834,2,1068,0)=" . ; Other actions to be inserted here..."
^XMB(3.9,145834,2,1069,0)="""RTN"",""MAGBRTE4"",209,0)"
^XMB(3.9,145834,2,1070,0)=" . ;"
^XMB(3.9,145834,2,1071,0)="""RTN"",""MAGBRTE4"",210,0)"
^XMB(3.9,145834,2,1072,0)=" . Q"
^XMB(3.9,145834,2,1073,0)="""RTN"",""MAGBRTE4"",211,0)"
^XMB(3.9,145834,2,1074,0)=" ;"
^XMB(3.9,145834,2,1075,0)="""RTN"",""MAGBRTE4"",212,0)"
^XMB(3.9,145834,2,1076,0)=" ; Note: we may have:"
^XMB(3.9,145834,2,1077,0)="""RTN"",""MAGBRTE4"",213,0)"
^XMB(3.9,145834,2,1078,0)=" ;    Rule 1: If CR, send to XXX"
^XMB(3.9,145834,2,1079,0)="""RTN"",""MAGBRTE4"",214,0)"
^XMB(3.9,145834,2,1080,0)=" ;    Rule 2: If CT, send to XXX"
^XMB(3.9,145834,2,1081,0)="""RTN"",""MAGBRTE4"",215,0)"
^XMB(3.9,145834,2,1082,0)=" ; For a CR, this would cause an entry of"
^XMB(3.9,145834,2,1083,0)="""RTN"",""MAGBRTE4"",216,0)"
^XMB(3.9,145834,2,1084,0)=" ;    METMSG(0,""SEND(XXX)"") for rule 2"
^XMB(3.9,145834,2,1085,0)="""RTN"",""MAGBRTE4"",217,0)"
^XMB(3.9,145834,2,1086,0)=" ; and an entry of"
^XMB(3.9,145834,2,1087,0)="""RTN"",""MAGBRTE4"",218,0)"
^XMB(3.9,145834,2,1088,0)=" ;    METMSG(1,""SEND(XXX)"") for rule 1"
^XMB(3.9,145834,2,1089,0)="""RTN"",""MAGBRTE4"",219,0)"
^XMB(3.9,145834,2,1090,0)=" ; and for a CT it would be the other way around."
^XMB(3.9,145834,2,1091,0)="""RTN"",""MAGBRTE4"",220,0)"
^XMB(3.9,145834,2,1092,0)=" ; So, first remove all ""failed"" entries that were successful"
^XMB(3.9,145834,2,1093,0)="""RTN"",""MAGBRTE4"",221,0)"
^XMB(3.9,145834,2,1094,0)=" ; for a different rule."
^XMB(3.9,145834,2,1095,0)="""RTN"",""MAGBRTE4"",222,0)"
^XMB(3.9,145834,2,1096,0)=" ;"
^XMB(3.9,145834,2,1097,0)="""RTN"",""MAGBRTE4"",223,0)"
^XMB(3.9,145834,2,1098,0)=" S X="""" F  S X=$O(METMSG(1,X)) Q:X=""""  D"
^XMB(3.9,145834,2,1099,0)="""RTN"",""MAGBRTE4"",224,0)"
^XMB(3.9,145834,2,1100,0)=" . D LOG^MAGBRTE5(""Image ""_IMAGE_"": ""_X)"
^XMB(3.9,145834,2,1101,0)="""RTN"",""MAGBRTE4"",225,0)"
^XMB(3.9,145834,2,1102,0)=" . K METMSG(0,X)"
^XMB(3.9,145834,2,1103,0)="""RTN"",""MAGBRTE4"",226,0)"
^XMB(3.9,145834,2,1104,0)=" . Q"
^XMB(3.9,145834,2,1105,0)="""RTN"",""MAGBRTE4"",227,0)"
^XMB(3.9,145834,2,1106,0)=" S X="""" F  S X=$O(METMSG(0,X)) Q:X=""""  D"
^XMB(3.9,145834,2,1107,0)="""RTN"",""MAGBRTE4"",228,0)"
^XMB(3.9,145834,2,1108,0)=" . D LOG^MAGBRTE5(""Image ""_IMAGE_"": Do not ""_X)"
^XMB(3.9,145834,2,1109,0)="""RTN"",""MAGBRTE4"",229,0)"
^XMB(3.9,145834,2,1110,0)=" . Q"
^XMB(3.9,145834,2,1111,0)="""RTN"",""MAGBRTE4"",230,0)"
^XMB(3.9,145834,2,1112,0)=" Q VRS"
^XMB(3.9,145834,2,1113,0)="""RTN"",""MAGBRTE4"",231,0)"
^XMB(3.9,145834,2,1114,0)=" ;"
^XMB(3.9,145834,2,1115,0)="""RTN"",""MAGBRTE4"",232,0)"
^XMB(3.9,145834,2,1116,0)=" ;"
^XMB(3.9,145834,2,1117,0)="""RTN"",""MAGBRTE4"",233,0)"
^XMB(3.9,145834,2,1118,0)="PRI(PRI,IMAGE) N C,D0,D1,D2,O,P,R,X"
^XMB(3.9,145834,2,1119,0)="""RTN"",""MAGBRTE4"",234,0)"
^XMB(3.9,145834,2,1120,0)=" S PRI=$S(PRI=""HIGH"":750,PRI=""NORMAL"":500,PRI=""LOW"":250,1:500)"
^XMB(3.9,145834,2,1121,0)="""RTN"",""MAGBRTE4"",235,0)"
^XMB(3.9,145834,2,1122,0)=" S X=$G(^MAG(2005,IMAGE,2))"
^XMB(3.9,145834,2,1123,0)="""RTN"",""MAGBRTE4"",236,0)"
^XMB(3.9,145834,2,1124,0)=" S P=$P(X,""^"",6) Q:P'=74 PRI"
^XMB(3.9,145834,2,1125,0)="""RTN"",""MAGBRTE4"",237,0)"
^XMB(3.9,145834,2,1126,0)=" S R=$P(X,""^"",7) Q:'R PRI"
^XMB(3.9,145834,2,1127,0)="""RTN"",""MAGBRTE4"",238,0)"
^XMB(3.9,145834,2,1128,0)=" S C=$P($G(^RARPT(R,0)),""^"",1) Q:C="""" PRI  ; IA 1171"
^XMB(3.9,145834,2,1129,0)="""RTN"",""MAGBRTE4"",239,0)"
^XMB(3.9,145834,2,1130,0)=" S D0=$O(^RADPT(""ADC"",C,"""")) Q:'D0 PRI  ; IA 1172"
^XMB(3.9,145834,2,1131,0)="""RTN"",""MAGBRTE4"",240,0)"
^XMB(3.9,145834,2,1132,0)=" S D1=$O(^RADPT(""ADC"",C,D0,"""")) Q:'D1 PRI  ; IA 1172"
^XMB(3.9,145834,2,1133,0)="""RTN"",""MAGBRTE4"",241,0)"
^XMB(3.9,145834,2,1134,0)=" S D2=$O(^RADPT(""ADC"",C,D0,D1,"""")) Q:'D2 PRI  ; IA 1172"
^XMB(3.9,145834,2,1135,0)="""RTN"",""MAGBRTE4"",242,0)"
^XMB(3.9,145834,2,1136,0)=" S O=$P($G(^RADPT(D0,""DT"",D1,""P"",D2,0)),""^"",11) Q:'O PRI  ; IA 1172"
^XMB(3.9,145834,2,1137,0)="""RTN"",""MAGBRTE4"",243,0)"
^XMB(3.9,145834,2,1138,0)=" S X=$P($G(^RAO(75.1,O,0)),""^"",6) ; IA 3074"
^XMB(3.9,145834,2,1139,0)="""RTN"",""MAGBRTE4"",244,0)"
^XMB(3.9,145834,2,1140,0)=" Q PRI+$S(X=1:20,X=2:10,1:0)"
^XMB(3.9,145834,2,1141,0)="""RTN"",""MAGBRTE4"",245,0)"
^XMB(3.9,145834,2,1142,0)=" ;"
^XMB(3.9,145834,2,1143,0)="""RTN"",""MAGDFCNV"")"
^XMB(3.9,145834,2,1144,0)="0^9^B20613077"
^XMB(3.9,145834,2,1145,0)="""RTN"",""MAGDFCNV"",1,0)"
^XMB(3.9,145834,2,1146,0)="MAGDFCNV ;WOIFO/PMK - Read HL7 and generate DICOM ; Mar 31, 2020@15:52:30"
^XMB(3.9,145834,2,1147,0)="""RTN"",""MAGDFCNV"",2,0)"
^XMB(3.9,145834,2,1148,0)=" ;;3.0;IMAGING;**11,51,141,138,231**;Mar 19, 2002;Build 0;Sep 03, 2013"
^XMB(3.9,145834,2,1149,0)="""RTN"",""MAGDFCNV"",3,0)"
^XMB(3.9,145834,2,1150,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,1151,0)="""RTN"",""MAGDFCNV"",4,0)"
^XMB(3.9,145834,2,1152,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,1153,0)="""RTN"",""MAGDFCNV"",5,0)"
^XMB(3.9,145834,2,1154,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145834,2,1155,0)="""RTN"",""MAGDFCNV"",6,0)"
^XMB(3.9,145834,2,1156,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145834,2,1157,0)="""RTN"",""MAGDFCNV"",7,0)"
^XMB(3.9,145834,2,1158,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145834,2,1159,0)="""RTN"",""MAGDFCNV"",8,0)"
^XMB(3.9,145834,2,1160,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,1161,0)="""RTN"",""MAGDFCNV"",9,0)"
^XMB(3.9,145834,2,1162,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,1163,0)="""RTN"",""MAGDFCNV"",10,0)"
^XMB(3.9,145834,2,1164,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,1165,0)="""RTN"",""MAGDFCNV"",11,0)"
^XMB(3.9,145834,2,1166,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,1167,0)="""RTN"",""MAGDFCNV"",12,0)"
^XMB(3.9,145834,2,1168,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,1169,0)="""RTN"",""MAGDFCNV"",13,0)"
^XMB(3.9,145834,2,1170,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,1171,0)="""RTN"",""MAGDFCNV"",14,0)"
^XMB(3.9,145834,2,1172,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,1173,0)="""RTN"",""MAGDFCNV"",15,0)"
^XMB(3.9,145834,2,1174,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,1175,0)="""RTN"",""MAGDFCNV"",16,0)"
^XMB(3.9,145834,2,1176,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,1177,0)="""RTN"",""MAGDFCNV"",17,0)"
^XMB(3.9,145834,2,1178,0)=" ;;"
^XMB(3.9,145834,2,1179,0)="""RTN"",""MAGDFCNV"",18,0)"
^XMB(3.9,145834,2,1180,0)=" ;"
^XMB(3.9,145834,2,1181,0)="""RTN"",""MAGDFCNV"",19,0)"
^XMB(3.9,145834,2,1182,0)=" ; Supported IA #2171 reference $$STA^XUAF4 function call"
^XMB(3.9,145834,2,1183,0)="""RTN"",""MAGDFCNV"",20,0)"
^XMB(3.9,145834,2,1184,0)=" ; Supported IA #2541 reference $$KSP^XUPARAM function call"
^XMB(3.9,145834,2,1185,0)="""RTN"",""MAGDFCNV"",21,0)"
^XMB(3.9,145834,2,1186,0)=" ; Supported IA #2051 reference $$FIND1^DIC function call"
^XMB(3.9,145834,2,1187,0)="""RTN"",""MAGDFCNV"",22,0)"
^XMB(3.9,145834,2,1188,0)=" ; Supported IA #2056 reference $$GET1^DIQ function call"
^XMB(3.9,145834,2,1189,0)="""RTN"",""MAGDFCNV"",23,0)"
^XMB(3.9,145834,2,1190,0)=" ;"
^XMB(3.9,145834,2,1191,0)="""RTN"",""MAGDFCNV"",24,0)"
^XMB(3.9,145834,2,1192,0)="CONSOLID() ; check if this is a consolidated site or not"
^XMB(3.9,145834,2,1193,0)="""RTN"",""MAGDFCNV"",25,0)"
^XMB(3.9,145834,2,1194,0)=" ; return 0 = non-consolidated (normal) site"
^XMB(3.9,145834,2,1195,0)="""RTN"",""MAGDFCNV"",26,0)"
^XMB(3.9,145834,2,1196,0)=" ; return 1 = consolidated site"
^XMB(3.9,145834,2,1197,0)="""RTN"",""MAGDFCNV"",27,0)"
^XMB(3.9,145834,2,1198,0)=" ;"
^XMB(3.9,145834,2,1199,0)="""RTN"",""MAGDFCNV"",28,0)"
^XMB(3.9,145834,2,1200,0)=" ; code for the main VistA HIS"
^XMB(3.9,145834,2,1201,0)="""RTN"",""MAGDFCNV"",29,0)"
^XMB(3.9,145834,2,1202,0)=" Q $GET(^MAG(2006.1,""CONSOLIDATED""))=""YES"""
^XMB(3.9,145834,2,1203,0)="""RTN"",""MAGDFCNV"",30,0)"
^XMB(3.9,145834,2,1204,0)=" ;"
^XMB(3.9,145834,2,1205,0)="""RTN"",""MAGDFCNV"",31,0)"
^XMB(3.9,145834,2,1206,0)="ACQDEV(MFGR,MODEL,SITE) ; get pointer to the Acquisition Device file"
^XMB(3.9,145834,2,1207,0)="""RTN"",""MAGDFCNV"",32,0)"
^XMB(3.9,145834,2,1208,0)=" N ACQDEV ;--- name of acquisition device"
^XMB(3.9,145834,2,1209,0)="""RTN"",""MAGDFCNV"",33,0)"
^XMB(3.9,145834,2,1210,0)=" N ACQDEVP ;-- pointer to acquisition device file (#2006.04)"
^XMB(3.9,145834,2,1211,0)="""RTN"",""MAGDFCNV"",34,0)"
^XMB(3.9,145834,2,1212,0)=" ;"
^XMB(3.9,145834,2,1213,0)="""RTN"",""MAGDFCNV"",35,0)"
^XMB(3.9,145834,2,1214,0)=" S ACQDEV=$$UP^MAGDFCNV(MFGR_"" (""_MODEL_"")"")"
^XMB(3.9,145834,2,1215,0)="""RTN"",""MAGDFCNV"",36,0)"
^XMB(3.9,145834,2,1216,0)=" S ACQDEVP=$O(^MAG(2006.04,""B"",ACQDEV,""""))"
^XMB(3.9,145834,2,1217,0)="""RTN"",""MAGDFCNV"",37,0)"
^XMB(3.9,145834,2,1218,0)=" I 'ACQDEVP D  ; create the entry"
^XMB(3.9,145834,2,1219,0)="""RTN"",""MAGDFCNV"",38,0)"
^XMB(3.9,145834,2,1220,0)=" . L +^MAG(2006.04,0):1E9 ; serialize name generation code"
^XMB(3.9,145834,2,1221,0)="""RTN"",""MAGDFCNV"",39,0)"
^XMB(3.9,145834,2,1222,0)=" . I '$D(^MAG(2006.04,0)) S ^(0)=""ACQUISITION DEVICE^2006.04^^"""
^XMB(3.9,145834,2,1223,0)="""RTN"",""MAGDFCNV"",40,0)"
^XMB(3.9,145834,2,1224,0)=" . S ACQDEVP=$P(^MAG(2006.04,0),""^"",3)+1"
^XMB(3.9,145834,2,1225,0)="""RTN"",""MAGDFCNV"",41,0)"
^XMB(3.9,145834,2,1226,0)=" . S ^MAG(2006.04,ACQDEVP,0)=ACQDEV_""^""_SITE_""^"" ; 3rd piece is null"
^XMB(3.9,145834,2,1227,0)="""RTN"",""MAGDFCNV"",42,0)"
^XMB(3.9,145834,2,1228,0)=" . S ^MAG(2006.04,""B"",ACQDEV,ACQDEVP)="""""
^XMB(3.9,145834,2,1229,0)="""RTN"",""MAGDFCNV"",43,0)"
^XMB(3.9,145834,2,1230,0)=" . S $P(^MAG(2006.04,0),""^"",3)=ACQDEVP"
^XMB(3.9,145834,2,1231,0)="""RTN"",""MAGDFCNV"",44,0)"
^XMB(3.9,145834,2,1232,0)=" . S $P(^MAG(2006.04,0),""^"",4)=ACQDEVP"
^XMB(3.9,145834,2,1233,0)="""RTN"",""MAGDFCNV"",45,0)"
^XMB(3.9,145834,2,1234,0)=" . L -^MAG(2006.04,0) ; clear the serial name generation code"
^XMB(3.9,145834,2,1235,0)="""RTN"",""MAGDFCNV"",46,0)"
^XMB(3.9,145834,2,1236,0)=" Q ACQDEVP"
^XMB(3.9,145834,2,1237,0)="""RTN"",""MAGDFCNV"",47,0)"
^XMB(3.9,145834,2,1238,0)=" ;"
^XMB(3.9,145834,2,1239,0)="""RTN"",""MAGDFCNV"",48,0)"
^XMB(3.9,145834,2,1240,0)="EQUIVGRP(P1,P2) ; see if two SOP Class pointers are in equivalent groups"
^XMB(3.9,145834,2,1241,0)="""RTN"",""MAGDFCNV"",49,0)"
^XMB(3.9,145834,2,1242,0)=" N G1,G2"
^XMB(3.9,145834,2,1243,0)="""RTN"",""MAGDFCNV"",50,0)"
^XMB(3.9,145834,2,1244,0)=" Q:'$G(P1) 0"
^XMB(3.9,145834,2,1245,0)="""RTN"",""MAGDFCNV"",51,0)"
^XMB(3.9,145834,2,1246,0)=" Q:'$G(P2) 0"
^XMB(3.9,145834,2,1247,0)="""RTN"",""MAGDFCNV"",52,0)"
^XMB(3.9,145834,2,1248,0)=" S G1=$P($G(^MAG(2006.532,P1,0)),""^"",3) S:G1="""" G1=P1"
^XMB(3.9,145834,2,1249,0)="""RTN"",""MAGDFCNV"",53,0)"
^XMB(3.9,145834,2,1250,0)=" S G2=$P($G(^MAG(2006.532,P2,0)),""^"",3) S:G2="""" G2=P2"
^XMB(3.9,145834,2,1251,0)="""RTN"",""MAGDFCNV"",54,0)"
^XMB(3.9,145834,2,1252,0)=" Q G1=G2"
^XMB(3.9,145834,2,1253,0)="""RTN"",""MAGDFCNV"",55,0)"
^XMB(3.9,145834,2,1254,0)=" ;"
^XMB(3.9,145834,2,1255,0)="""RTN"",""MAGDFCNV"",56,0)"
^XMB(3.9,145834,2,1256,0)="UP(X) ; special UPPER CASE function -- removes redundant blanks as well"
^XMB(3.9,145834,2,1257,0)="""RTN"",""MAGDFCNV"",57,0)"
^XMB(3.9,145834,2,1258,0)=" F  Q:X'[""  ""  S $E(X,$F(X,""  "")-1)=""""  ; remove redundant blank"
^XMB(3.9,145834,2,1259,0)="""RTN"",""MAGDFCNV"",58,0)"
^XMB(3.9,145834,2,1260,0)=" I $E(X)="" "" S $E(X)=""""  ; remove leading blank"
^XMB(3.9,145834,2,1261,0)="""RTN"",""MAGDFCNV"",59,0)"
^XMB(3.9,145834,2,1262,0)=" I $E(X,$L(X))="" "" S $E(X,$L(X))=""""  ; remove trailing blank"
^XMB(3.9,145834,2,1263,0)="""RTN"",""MAGDFCNV"",60,0)"
^XMB(3.9,145834,2,1264,0)=" Q $TR(X,""abcdefghijklmnopqrstuvwxyz^|"",""ABCDEFGHIJKLMNOPQRSTUVWXYZ~~"")"
^XMB(3.9,145834,2,1265,0)="""RTN"",""MAGDFCNV"",61,0)"
^XMB(3.9,145834,2,1266,0)=" ;"
^XMB(3.9,145834,2,1267,0)="""RTN"",""MAGDFCNV"",62,0)"
^XMB(3.9,145834,2,1268,0)="STATNUMB() ; return numeric 3-digit station number for the VA"
^XMB(3.9,145834,2,1269,0)="""RTN"",""MAGDFCNV"",63,0)"
^XMB(3.9,145834,2,1270,0)=" N STATNUMB"
^XMB(3.9,145834,2,1271,0)="""RTN"",""MAGDFCNV"",64,0)"
^XMB(3.9,145834,2,1272,0)=" S STATNUMB=$$STA^XUAF4($$KSP^XUPARAM(""INST"")) ; station number"
^XMB(3.9,145834,2,1273,0)="""RTN"",""MAGDFCNV"",65,0)"
^XMB(3.9,145834,2,1274,0)=" ; station number is 3 digits, exclusive of any modifiers or full station number for IHS"
^XMB(3.9,145834,2,1275,0)="""RTN"",""MAGDFCNV"",66,0)"
^XMB(3.9,145834,2,1276,0)=" Q $S($$ISIHS^MAGSPID():STATNUMB,1:$E(STATNUMB,1,3))"
^XMB(3.9,145834,2,1277,0)="""RTN"",""MAGDFCNV"",67,0)"
^XMB(3.9,145834,2,1278,0)=" ;"
^XMB(3.9,145834,2,1279,0)="""RTN"",""MAGDFCNV"",68,0)"
^XMB(3.9,145834,2,1280,0)="GMRCACN(GMRCIEN) ; return a site-specific accession number for clinical specialties"
^XMB(3.9,145834,2,1281,0)="""RTN"",""MAGDFCNV"",69,0)"
^XMB(3.9,145834,2,1282,0)=" ; GMRCIEN is the CPRS Consult Request Tracking GMRC IEN - REQUEST/CONSULTATION file(#123)"
^XMB(3.9,145834,2,1283,0)="""RTN"",""MAGDFCNV"",70,0)"
^XMB(3.9,145834,2,1284,0)=" N ACNUMB ; accession number for a consult/procedure request"
^XMB(3.9,145834,2,1285,0)="""RTN"",""MAGDFCNV"",71,0)"
^XMB(3.9,145834,2,1286,0)=" N EXAMDATE ; date of exam"
^XMB(3.9,145834,2,1287,0)="""RTN"",""MAGDFCNV"",72,0)"
^XMB(3.9,145834,2,1288,0)=" N P162DATE ; installation date for MAG*3.0*162, when site-specific accession numbers started"
^XMB(3.9,145834,2,1289,0)="""RTN"",""MAGDFCNV"",73,0)"
^XMB(3.9,145834,2,1290,0)=" N INSTALLIEN"
^XMB(3.9,145834,2,1291,0)="""RTN"",""MAGDFCNV"",74,0)"
^XMB(3.9,145834,2,1292,0)=" S INSTALLIEN=$$FIND1^DIC(9.7,"""",""B"",""MAG*3.0*162"")"
^XMB(3.9,145834,2,1293,0)="""RTN"",""MAGDFCNV"",75,0)"
^XMB(3.9,145834,2,1294,0)=" S P162DATE=$$GET1^DIQ(9.7,INSTALLIEN,17,""I"") ; install complete date & time"
^XMB(3.9,145834,2,1295,0)="""RTN"",""MAGDFCNV"",76,0)"
^XMB(3.9,145834,2,1296,0)=" S EXAMDATE=$$GET1^DIQ(123,GMRCIEN,.01,""I"")"
^XMB(3.9,145834,2,1297,0)="""RTN"",""MAGDFCNV"",77,0)"
^XMB(3.9,145834,2,1298,0)=" I EXAMDATE<P162DATE D  ; legacy accession number format"
^XMB(3.9,145834,2,1299,0)="""RTN"",""MAGDFCNV"",78,0)"
^XMB(3.9,145834,2,1300,0)=" . ; Format: GMRC-<gmrcien>, where <gmrcien> is the internal entry number of the request "
^XMB(3.9,145834,2,1301,0)="""RTN"",""MAGDFCNV"",79,0)"
^XMB(3.9,145834,2,1302,0)=" . S ACNUMB=""GMRC-""_GMRCIEN"
^XMB(3.9,145834,2,1303,0)="""RTN"",""MAGDFCNV"",80,0)"
^XMB(3.9,145834,2,1304,0)=" . Q "
^XMB(3.9,145834,2,1305,0)="""RTN"",""MAGDFCNV"",81,0)"
^XMB(3.9,145834,2,1306,0)=" E  D  ; site-specific accession number format"
^XMB(3.9,145834,2,1307,0)="""RTN"",""MAGDFCNV"",82,0)"
^XMB(3.9,145834,2,1308,0)=" . ; Format: <sss>-GMR-<gmrcien>, where <sss> is station number, and <gmrcien>"
^XMB(3.9,145834,2,1309,0)="""RTN"",""MAGDFCNV"",83,0)"
^XMB(3.9,145834,2,1310,0)=" . ;         is the internal entry number of the request, up to 8 digits (100 million) "
^XMB(3.9,145834,2,1311,0)="""RTN"",""MAGDFCNV"",84,0)"
^XMB(3.9,145834,2,1312,0)=" . S ACNUMB=$$STATNUMB()_""-GMR-""_GMRCIEN"
^XMB(3.9,145834,2,1313,0)="""RTN"",""MAGDFCNV"",85,0)"
^XMB(3.9,145834,2,1314,0)=" . Q"
^XMB(3.9,145834,2,1315,0)="""RTN"",""MAGDFCNV"",86,0)"
^XMB(3.9,145834,2,1316,0)=" Q ACNUMB"
^XMB(3.9,145834,2,1317,0)="""RTN"",""MAGDFCNV"",87,0)"
^XMB(3.9,145834,2,1318,0)=" ;"
^XMB(3.9,145834,2,1319,0)="""RTN"",""MAGDFCNV"",88,0)"
^XMB(3.9,145834,2,1320,0)="GMRCIEN(ACNUMB) ; return the GMRC IEN, given a consult/procedure accession number"
^XMB(3.9,145834,2,1321,0)="""RTN"",""MAGDFCNV"",89,0)"
^XMB(3.9,145834,2,1322,0)=" ; ACNUMB is the accession number for a consult/procedure request"
^XMB(3.9,145834,2,1323,0)="""RTN"",""MAGDFCNV"",90,0)"
^XMB(3.9,145834,2,1324,0)=" ; OLD Format: GMRC-<gmrcien>, where <gmrcien>is the internal entry number of the request"
^XMB(3.9,145834,2,1325,0)="""RTN"",""MAGDFCNV"",91,0)"
^XMB(3.9,145834,2,1326,0)=" ; New Format: <sss>-GMR-<gmrcien>, where <sss> is station number, and <gmrcien>"
^XMB(3.9,145834,2,1327,0)="""RTN"",""MAGDFCNV"",92,0)"
^XMB(3.9,145834,2,1328,0)=" ;             is the internal entry number of the request, up to 8 digits (100 million)"
^XMB(3.9,145834,2,1329,0)="""RTN"",""MAGDFCNV"",93,0)"
^XMB(3.9,145834,2,1330,0)=" N GMRCIEN ; CPRS Consult Request Tracking GMRC IEN - REQUEST/CONSULTATION file(#123)"
^XMB(3.9,145834,2,1331,0)="""RTN"",""MAGDFCNV"",94,0)"
^XMB(3.9,145834,2,1332,0)=" I ACNUMB?1""GMRC-""1N.N S GMRCIEN=$P(ACNUMB,""-"",2) ; return the second piece"
^XMB(3.9,145834,2,1333,0)="""RTN"",""MAGDFCNV"",95,0)"
^XMB(3.9,145834,2,1334,0)=" E  I ACNUMB?1N.N1""-GMR-""1N.N S GMRCIEN=$P(ACNUMB,""-"",3) ; return the third piece"
^XMB(3.9,145834,2,1335,0)="""RTN"",""MAGDFCNV"",96,0)"
^XMB(3.9,145834,2,1336,0)=" E  S GMRCIEN="""" ; invalid consult request tracking accession number format"
^XMB(3.9,145834,2,1337,0)="""RTN"",""MAGDFCNV"",97,0)"
^XMB(3.9,145834,2,1338,0)=" Q GMRCIEN"
^XMB(3.9,145834,2,1339,0)="""RTN"",""MAGDFCNV"",98,0)"
^XMB(3.9,145834,2,1340,0)=" ;"
^XMB(3.9,145834,2,1341,0)="""RTN"",""MAGDFCNV"",99,0)"
^XMB(3.9,145834,2,1342,0)="HOSTNAME() ;"
^XMB(3.9,145834,2,1343,0)="""RTN"",""MAGDFCNV"",100,0)"
^XMB(3.9,145834,2,1344,0)=" Q $P(##class(%SYS.System).GetNodeName(),""."",1)"
^XMB(3.9,145834,2,1345,0)="""RTN"",""MAGDHOW4"")"
^XMB(3.9,145834,2,1346,0)="0^23^B34588912"
^XMB(3.9,145834,2,1347,0)="""RTN"",""MAGDHOW4"",1,0)"
^XMB(3.9,145834,2,1348,0)="MAGDHOW4 ;WOIFO/PMK - Capture Consult/GMRC data ;17 Sep 2018 9:39 AM"
^XMB(3.9,145834,2,1349,0)="""RTN"",""MAGDHOW4"",2,0)"
^XMB(3.9,145834,2,1350,0)=" ;;3.0;IMAGING;**138,208**;Mar 19, 2002;Build 0;Sep 03, 2013"
^XMB(3.9,145834,2,1351,0)="""RTN"",""MAGDHOW4"",3,0)"
^XMB(3.9,145834,2,1352,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,1353,0)="""RTN"",""MAGDHOW4"",4,0)"
^XMB(3.9,145834,2,1354,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,1355,0)="""RTN"",""MAGDHOW4"",5,0)"
^XMB(3.9,145834,2,1356,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145834,2,1357,0)="""RTN"",""MAGDHOW4"",6,0)"
^XMB(3.9,145834,2,1358,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145834,2,1359,0)="""RTN"",""MAGDHOW4"",7,0)"
^XMB(3.9,145834,2,1360,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145834,2,1361,0)="""RTN"",""MAGDHOW4"",8,0)"
^XMB(3.9,145834,2,1362,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,1363,0)="""RTN"",""MAGDHOW4"",9,0)"
^XMB(3.9,145834,2,1364,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,1365,0)="""RTN"",""MAGDHOW4"",10,0)"
^XMB(3.9,145834,2,1366,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,1367,0)="""RTN"",""MAGDHOW4"",11,0)"
^XMB(3.9,145834,2,1368,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,1369,0)="""RTN"",""MAGDHOW4"",12,0)"
^XMB(3.9,145834,2,1370,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,1371,0)="""RTN"",""MAGDHOW4"",13,0)"
^XMB(3.9,145834,2,1372,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,1373,0)="""RTN"",""MAGDHOW4"",14,0)"
^XMB(3.9,145834,2,1374,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,1375,0)="""RTN"",""MAGDHOW4"",15,0)"
^XMB(3.9,145834,2,1376,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,1377,0)="""RTN"",""MAGDHOW4"",16,0)"
^XMB(3.9,145834,2,1378,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,1379,0)="""RTN"",""MAGDHOW4"",17,0)"
^XMB(3.9,145834,2,1380,0)=" ;;"
^XMB(3.9,145834,2,1381,0)="""RTN"",""MAGDHOW4"",18,0)"
^XMB(3.9,145834,2,1382,0)=" ; Supported IA #2056 reference $$GET1^DIQ function call"
^XMB(3.9,145834,2,1383,0)="""RTN"",""MAGDHOW4"",19,0)"
^XMB(3.9,145834,2,1384,0)=" ; Supported IA #4716 reference ^HLOAPI function calls"
^XMB(3.9,145834,2,1385,0)="""RTN"",""MAGDHOW4"",20,0)"
^XMB(3.9,145834,2,1386,0)=" ; Supported IA 3536 reference GETDOCS^TIUSRVLR subroutine call"
^XMB(3.9,145834,2,1387,0)="""RTN"",""MAGDHOW4"",21,0)"
^XMB(3.9,145834,2,1388,0)=" ; Supported IA #10103 reference $$FMTHL7^XLFDT function call"
^XMB(3.9,145834,2,1389,0)="""RTN"",""MAGDHOW4"",22,0)"
^XMB(3.9,145834,2,1390,0)=" ; Controlled IA #4110 to read REQUEST/CONSULTATION file (#123)"
^XMB(3.9,145834,2,1391,0)="""RTN"",""MAGDHOW4"",23,0)"
^XMB(3.9,145834,2,1392,0)=" ; Controlled IA #4171 to read REQUEST SERVICES file (#123.5)"
^XMB(3.9,145834,2,1393,0)="""RTN"",""MAGDHOW4"",24,0)"
^XMB(3.9,145834,2,1394,0)=" ; Controlled IA #1373 to read PROTOCOL file (#101)"
^XMB(3.9,145834,2,1395,0)="""RTN"",""MAGDHOW4"",25,0)"
^XMB(3.9,145834,2,1396,0)=" ; Supported IA #1995 to call CPT^ICPTCOD to get CPT code and short name"
^XMB(3.9,145834,2,1397,0)="""RTN"",""MAGDHOW4"",26,0)"
^XMB(3.9,145834,2,1398,0)=" ; Supported IA #10090 to read INSTITUTION file (#4)"
^XMB(3.9,145834,2,1399,0)="""RTN"",""MAGDHOW4"",27,0)"
^XMB(3.9,145834,2,1400,0)=" ; Supported IA #10040 to read HOSPITAL LOCATION file (#44)"
^XMB(3.9,145834,2,1401,0)="""RTN"",""MAGDHOW4"",28,0)"
^XMB(3.9,145834,2,1402,0)=" ;"
^XMB(3.9,145834,2,1403,0)="""RTN"",""MAGDHOW4"",29,0)"
^XMB(3.9,145834,2,1404,0)="OBR(HLMSTATE,GMRCIEN,SAVEORCSEG,SERVICE) ; build the OBR segment (see OBR^GMRCHL72)"
^XMB(3.9,145834,2,1405,0)="""RTN"",""MAGDHOW4"",30,0)"
^XMB(3.9,145834,2,1406,0)=" N ACNUMB,AUTHOR,CPTCODE,CPTINFO,CPTNAME,CONPROC,ERROR,HL7USID,I,DEL,DEL2,OBRSEG,SUCCESS"
^XMB(3.9,145834,2,1407,0)="""RTN"",""MAGDHOW4"",31,0)"
^XMB(3.9,145834,2,1408,0)=" N PRIORITY,X,Z"
^XMB(3.9,145834,2,1409,0)="""RTN"",""MAGDHOW4"",32,0)"
^XMB(3.9,145834,2,1410,0)=" D SET^HLOAPI(.OBRSEG,""OBR"",0)"
^XMB(3.9,145834,2,1411,0)="""RTN"",""MAGDHOW4"",33,0)"
^XMB(3.9,145834,2,1412,0)=" D SET^HLOAPI(.OBRSEG,1,1) ; OBR-1"
^XMB(3.9,145834,2,1413,0)="""RTN"",""MAGDHOW4"",34,0)"
^XMB(3.9,145834,2,1414,0)=" M OBRSEG(2)=SAVEORCSEG(2) ; OBR-2 placer order number"
^XMB(3.9,145834,2,1415,0)="""RTN"",""MAGDHOW4"",35,0)"
^XMB(3.9,145834,2,1416,0)=" M OBRSEG(3)=SAVEORCSEG(3) ; OBR-3 filler order number"
^XMB(3.9,145834,2,1417,0)="""RTN"",""MAGDHOW4"",36,0)"
^XMB(3.9,145834,2,1418,0)=" ;"
^XMB(3.9,145834,2,1419,0)="""RTN"",""MAGDHOW4"",37,0)"
^XMB(3.9,145834,2,1420,0)=" ; OBR-4 Universal Service Identifier"
^XMB(3.9,145834,2,1421,0)="""RTN"",""MAGDHOW4"",38,0)"
^XMB(3.9,145834,2,1422,0)=" ; check for Clinical Procedures HL7 Universal Services ID - P208 PMK 4/12/18"
^XMB(3.9,145834,2,1423,0)="""RTN"",""MAGDHOW4"",39,0)"
^XMB(3.9,145834,2,1424,0)=" I $$CPORDER^MAGDHOWP(GMRCIEN,.HL7USID)>0,HL7USID'="""" D  ; Clinical Procedures "
^XMB(3.9,145834,2,1425,0)="""RTN"",""MAGDHOW4"",40,0)"
^XMB(3.9,145834,2,1426,0)=" . D SET^HLOAPI(.OBRSEG,$P(HL7USID,""="",1),4,1)"
^XMB(3.9,145834,2,1427,0)="""RTN"",""MAGDHOW4"",41,0)"
^XMB(3.9,145834,2,1428,0)=" . D SET^HLOAPI(.OBRSEG,$P(HL7USID,""="",2),4,2)"
^XMB(3.9,145834,2,1429,0)="""RTN"",""MAGDHOW4"",42,0)"
^XMB(3.9,145834,2,1430,0)=" . Q"
^XMB(3.9,145834,2,1431,0)="""RTN"",""MAGDHOW4"",43,0)"
^XMB(3.9,145834,2,1432,0)=" E  D  ; not Clinical Procedures - P208 PMK 4/12/18"
^XMB(3.9,145834,2,1433,0)="""RTN"",""MAGDHOW4"",44,0)"
^XMB(3.9,145834,2,1434,0)=" . S CPTINFO=$$CPT^ICPTCOD(CPTIEN) ; get basic info on CPT/HCPCS code"
^XMB(3.9,145834,2,1435,0)="""RTN"",""MAGDHOW4"",45,0)"
^XMB(3.9,145834,2,1436,0)=" . I CPTINFO<0 S CPTINFO="""" ; error - no code selected or no such entry"
^XMB(3.9,145834,2,1437,0)="""RTN"",""MAGDHOW4"",46,0)"
^XMB(3.9,145834,2,1438,0)=" . I $P(CPTINFO,""^"",7)=0 S CPTINFO="""" ; inactive CPT code"
^XMB(3.9,145834,2,1439,0)="""RTN"",""MAGDHOW4"",47,0)"
^XMB(3.9,145834,2,1440,0)=" . S CPTCODE=$P(CPTINFO,""^"",2) ; CPT code"
^XMB(3.9,145834,2,1441,0)="""RTN"",""MAGDHOW4"",48,0)"
^XMB(3.9,145834,2,1442,0)=" . S CPTNAME=$P(CPTINFO,""^"",3) ; short name"
^XMB(3.9,145834,2,1443,0)="""RTN"",""MAGDHOW4"",49,0)"
^XMB(3.9,145834,2,1444,0)=" . D SET^HLOAPI(.OBRSEG,CPTCODE,4,1)"
^XMB(3.9,145834,2,1445,0)="""RTN"",""MAGDHOW4"",50,0)"
^XMB(3.9,145834,2,1446,0)=" . D SET^HLOAPI(.OBRSEG,CPTNAME,4,2)"
^XMB(3.9,145834,2,1447,0)="""RTN"",""MAGDHOW4"",51,0)"
^XMB(3.9,145834,2,1448,0)=" . D SET^HLOAPI(.OBRSEG,""C4"",4,3)"
^XMB(3.9,145834,2,1449,0)="""RTN"",""MAGDHOW4"",52,0)"
^XMB(3.9,145834,2,1450,0)=" . Q"
^XMB(3.9,145834,2,1451,0)="""RTN"",""MAGDHOW4"",53,0)"
^XMB(3.9,145834,2,1452,0)=" S CONPROC=$$GET1^DIQ(123,GMRCIEN,13,""I"") ; consult/procedure request type"
^XMB(3.9,145834,2,1453,0)="""RTN"",""MAGDHOW4"",54,0)"
^XMB(3.9,145834,2,1454,0)=" I CONPROC=""C"" D  ; consult request"
^XMB(3.9,145834,2,1455,0)="""RTN"",""MAGDHOW4"",55,0)"
^XMB(3.9,145834,2,1456,0)=" . D SET^HLOAPI(.OBRSEG,""C""_SERVICE,4,4)"
^XMB(3.9,145834,2,1457,0)="""RTN"",""MAGDHOW4"",56,0)"
^XMB(3.9,145834,2,1458,0)=" . D SET^HLOAPI(.OBRSEG,$$GET1^DIQ(123.5,SERVICE,.01),4,5)"
^XMB(3.9,145834,2,1459,0)="""RTN"",""MAGDHOW4"",57,0)"
^XMB(3.9,145834,2,1460,0)=" . D SET^HLOAPI(.OBRSEG,""99CON"",4,6)"
^XMB(3.9,145834,2,1461,0)="""RTN"",""MAGDHOW4"",58,0)"
^XMB(3.9,145834,2,1462,0)=" . Q"
^XMB(3.9,145834,2,1463,0)="""RTN"",""MAGDHOW4"",59,0)"
^XMB(3.9,145834,2,1464,0)=" E  D  ; procedure request"
^XMB(3.9,145834,2,1465,0)="""RTN"",""MAGDHOW4"",60,0)"
^XMB(3.9,145834,2,1466,0)=" . D SET^HLOAPI(.OBRSEG,""P""_(+$$GET1^DIQ(123,GMRCIEN,4,""I"")),4,4)"
^XMB(3.9,145834,2,1467,0)="""RTN"",""MAGDHOW4"",61,0)"
^XMB(3.9,145834,2,1468,0)=" . D SET^HLOAPI(.OBRSEG,$$GET1^DIQ(123,GMRCIEN,4),4,5)"
^XMB(3.9,145834,2,1469,0)="""RTN"",""MAGDHOW4"",62,0)"
^XMB(3.9,145834,2,1470,0)=" . D SET^HLOAPI(.OBRSEG,""99PROC"",4,6)"
^XMB(3.9,145834,2,1471,0)="""RTN"",""MAGDHOW4"",63,0)"
^XMB(3.9,145834,2,1472,0)=" . Q"
^XMB(3.9,145834,2,1473,0)="""RTN"",""MAGDHOW4"",64,0)"
^XMB(3.9,145834,2,1474,0)=" ;"
^XMB(3.9,145834,2,1475,0)="""RTN"",""MAGDHOW4"",65,0)"
^XMB(3.9,145834,2,1476,0)=" S PRIORITY=$G(SAVEORCSEG(7,1,6,1))"
^XMB(3.9,145834,2,1477,0)="""RTN"",""MAGDHOW4"",66,0)"
^XMB(3.9,145834,2,1478,0)=" I PRIORITY'="""" D SET^HLOAPI(.OBRSEG,PRIORITY,5) ; OBR-5 priority"
^XMB(3.9,145834,2,1479,0)="""RTN"",""MAGDHOW4"",67,0)"
^XMB(3.9,145834,2,1480,0)=" ;"
^XMB(3.9,145834,2,1481,0)="""RTN"",""MAGDHOW4"",68,0)"
^XMB(3.9,145834,2,1482,0)=" ; OBR-6 to OBR-15 are not used"
^XMB(3.9,145834,2,1483,0)="""RTN"",""MAGDHOW4"",69,0)"
^XMB(3.9,145834,2,1484,0)=" ;"
^XMB(3.9,145834,2,1485,0)="""RTN"",""MAGDHOW4"",70,0)"
^XMB(3.9,145834,2,1486,0)=" M OBRSEG(16)=SAVEORCSEG(12) ; OBR-16 ordering provider"
^XMB(3.9,145834,2,1487,0)="""RTN"",""MAGDHOW4"",71,0)"
^XMB(3.9,145834,2,1488,0)=" M OBRSEG(17)=SAVEORCSEG(14) ; OBR-17 call back phone number"
^XMB(3.9,145834,2,1489,0)="""RTN"",""MAGDHOW4"",72,0)"
^XMB(3.9,145834,2,1490,0)=" ;"
^XMB(3.9,145834,2,1491,0)="""RTN"",""MAGDHOW4"",73,0)"
^XMB(3.9,145834,2,1492,0)=" ; store the accession number"
^XMB(3.9,145834,2,1493,0)="""RTN"",""MAGDHOW4"",74,0)"
^XMB(3.9,145834,2,1494,0)=" S ACNUMB=$$GMRCACN^MAGDFCNV(GMRCIEN)"
^XMB(3.9,145834,2,1495,0)="""RTN"",""MAGDHOW4"",75,0)"
^XMB(3.9,145834,2,1496,0)=" D SET^HLOAPI(.OBRSEG,ACNUMB,18) ; OBR-18 placer field 1"
^XMB(3.9,145834,2,1497,0)="""RTN"",""MAGDHOW4"",76,0)"
^XMB(3.9,145834,2,1498,0)=" ;"
^XMB(3.9,145834,2,1499,0)="""RTN"",""MAGDHOW4"",77,0)"
^XMB(3.9,145834,2,1500,0)=" ; store the requested procedure id"
^XMB(3.9,145834,2,1501,0)="""RTN"",""MAGDHOW4"",78,0)"
^XMB(3.9,145834,2,1502,0)=" D SET^HLOAPI(.OBRSEG,$P(ACNUMB,""-"",3),19) ; OBR-19 placer field 2"
^XMB(3.9,145834,2,1503,0)="""RTN"",""MAGDHOW4"",79,0)"
^XMB(3.9,145834,2,1504,0)=" ;"
^XMB(3.9,145834,2,1505,0)="""RTN"",""MAGDHOW4"",80,0)"
^XMB(3.9,145834,2,1506,0)=" ; store misc. consult and clinic info in ""filler field 1"""
^XMB(3.9,145834,2,1507,0)="""RTN"",""MAGDHOW4"",81,0)"
^XMB(3.9,145834,2,1508,0)=" ;   <request type>"
^XMB(3.9,145834,2,1509,0)="""RTN"",""MAGDHOW4"",82,0)"
^XMB(3.9,145834,2,1510,0)=" ; ` <place of consult>"
^XMB(3.9,145834,2,1511,0)="""RTN"",""MAGDHOW4"",83,0)"
^XMB(3.9,145834,2,1512,0)=" ; ` <clinic ien> _ <clinic name>"
^XMB(3.9,145834,2,1513,0)="""RTN"",""MAGDHOW4"",84,0)"
^XMB(3.9,145834,2,1514,0)=" ; ` <requesting service ien> _ <requesting service name> _ VISTA44"
^XMB(3.9,145834,2,1515,0)="""RTN"",""MAGDHOW4"",85,0)"
^XMB(3.9,145834,2,1516,0)=" ;"
^XMB(3.9,145834,2,1517,0)="""RTN"",""MAGDHOW4"",86,0)"
^XMB(3.9,145834,2,1518,0)=" S Z=$S(CONPROC=""C"":""CONSULT"",CONPROC=""P"":""PROCEDURE"",1:""UNKNOWN"")_""```"""
^XMB(3.9,145834,2,1519,0)="""RTN"",""MAGDHOW4"",87,0)"
^XMB(3.9,145834,2,1520,0)=" S X=$$GET1^DIQ(123,GMRCIEN,6,""I"") ; place of consult"
^XMB(3.9,145834,2,1521,0)="""RTN"",""MAGDHOW4"",88,0)"
^XMB(3.9,145834,2,1522,0)=" I X S $P(Z,""`"",2)=$$GET1^DIQ(101,X,1)"
^XMB(3.9,145834,2,1523,0)="""RTN"",""MAGDHOW4"",89,0)"
^XMB(3.9,145834,2,1524,0)=" I $D(APTSCHED(""CLINIC IEN"")),$D(APTSCHED(""CLINIC NAME"")) D"
^XMB(3.9,145834,2,1525,0)="""RTN"",""MAGDHOW4"",90,0)"
^XMB(3.9,145834,2,1526,0)=" . S $P(Z,""`"",3)=APTSCHED(""CLINIC IEN"")_""_""_APTSCHED(""CLINIC NAME"")"
^XMB(3.9,145834,2,1527,0)="""RTN"",""MAGDHOW4"",91,0)"
^XMB(3.9,145834,2,1528,0)=" . Q"
^XMB(3.9,145834,2,1529,0)="""RTN"",""MAGDHOW4"",92,0)"
^XMB(3.9,145834,2,1530,0)=" ; from service (requesting service)"
^XMB(3.9,145834,2,1531,0)="""RTN"",""MAGDHOW4"",93,0)"
^XMB(3.9,145834,2,1532,0)=" S X=$$GET1^DIQ(123,GMRCIEN,2,""I"") ; pointer to ^SC(Z)"
^XMB(3.9,145834,2,1533,0)="""RTN"",""MAGDHOW4"",94,0)"
^XMB(3.9,145834,2,1534,0)=" I X S $P(Z,""`"",4)=X_""_""_$$GET1^DIQ(44,X,.01)_""_VISTA44"""
^XMB(3.9,145834,2,1535,0)="""RTN"",""MAGDHOW4"",95,0)"
^XMB(3.9,145834,2,1536,0)=" D SET^HLOAPI(.OBRSEG,Z,20) ; OBR-20 filler field 1"
^XMB(3.9,145834,2,1537,0)="""RTN"",""MAGDHOW4"",96,0)"
^XMB(3.9,145834,2,1538,0)=" ;"
^XMB(3.9,145834,2,1539,0)="""RTN"",""MAGDHOW4"",97,0)"
^XMB(3.9,145834,2,1540,0)=" ; store consult and clinic identification info in ""filler field 2"""
^XMB(3.9,145834,2,1541,0)="""RTN"",""MAGDHOW4"",98,0)"
^XMB(3.9,145834,2,1542,0)=" ;   <itype code> _ <itype name>"
^XMB(3.9,145834,2,1543,0)="""RTN"",""MAGDHOW4"",99,0)"
^XMB(3.9,145834,2,1544,0)=" ; ` <service ien> _ <service name>"
^XMB(3.9,145834,2,1545,0)="""RTN"",""MAGDHOW4"",100,0)"
^XMB(3.9,145834,2,1546,0)=" ; ` <division station number> _ <division name>"
^XMB(3.9,145834,2,1547,0)="""RTN"",""MAGDHOW4"",101,0)"
^XMB(3.9,145834,2,1548,0)=" ; ` <current CPRS GMRC or Appointment Scheduling status>"
^XMB(3.9,145834,2,1549,0)="""RTN"",""MAGDHOW4"",102,0)"
^XMB(3.9,145834,2,1550,0)=" ;"
^XMB(3.9,145834,2,1551,0)="""RTN"",""MAGDHOW4"",103,0)"
^XMB(3.9,145834,2,1552,0)=" S Z=ITYPCODE_""_""_ITYPNAME_""```"""
^XMB(3.9,145834,2,1553,0)="""RTN"",""MAGDHOW4"",104,0)"
^XMB(3.9,145834,2,1554,0)=" S $P(Z,""`"",2)=SERVICE_""_""_$$GET1^DIQ(123.5,SERVICE,.01)"
^XMB(3.9,145834,2,1555,0)="""RTN"",""MAGDHOW4"",105,0)"
^XMB(3.9,145834,2,1556,0)=" S $P(Z,""`"",3)=DIVISION_""_""_$S(DIVISION:$$GET1^DIQ(4,DIVISION,.01),1:"""")"
^XMB(3.9,145834,2,1557,0)="""RTN"",""MAGDHOW4"",106,0)"
^XMB(3.9,145834,2,1558,0)=" ; store the current CPRS GMRC or Appointment Scheduling status"
^XMB(3.9,145834,2,1559,0)="""RTN"",""MAGDHOW4"",107,0)"
^XMB(3.9,145834,2,1560,0)=" I '$D(FILLER2) S FILLER2=""GMRC-""_$$GET1^DIQ(123,GMRCIEN,8) ; GMRC status"
^XMB(3.9,145834,2,1561,0)="""RTN"",""MAGDHOW4"",108,0)"
^XMB(3.9,145834,2,1562,0)=" S $P(Z,""`"",4)=FILLER2"
^XMB(3.9,145834,2,1563,0)="""RTN"",""MAGDHOW4"",109,0)"
^XMB(3.9,145834,2,1564,0)=" ;"
^XMB(3.9,145834,2,1565,0)="""RTN"",""MAGDHOW4"",110,0)"
^XMB(3.9,145834,2,1566,0)=" D SET^HLOAPI(.OBRSEG,Z,21) ; OBR-21 filler field 2"
^XMB(3.9,145834,2,1567,0)="""RTN"",""MAGDHOW4"",111,0)"
^XMB(3.9,145834,2,1568,0)=" ;"
^XMB(3.9,145834,2,1569,0)="""RTN"",""MAGDHOW4"",112,0)"
^XMB(3.9,145834,2,1570,0)=" ; CPRS Attention - HL7 ""Result Copies To"" field"
^XMB(3.9,145834,2,1571,0)="""RTN"",""MAGDHOW4"",113,0)"
^XMB(3.9,145834,2,1572,0)=" S X=$$GET1^DIQ(123,GMRCIEN,7,""I"") ; pointer to ^VA(200)"
^XMB(3.9,145834,2,1573,0)="""RTN"",""MAGDHOW4"",114,0)"
^XMB(3.9,145834,2,1574,0)=" I X D NAME^MAGDHOW3(X,28,.OBRSEG) ; OBR-28 result copies to"
^XMB(3.9,145834,2,1575,0)="""RTN"",""MAGDHOW4"",115,0)"
^XMB(3.9,145834,2,1576,0)=" ;"
^XMB(3.9,145834,2,1577,0)="""RTN"",""MAGDHOW4"",116,0)"
^XMB(3.9,145834,2,1578,0)=" ; special code for result message or order message, but not both"
^XMB(3.9,145834,2,1579,0)="""RTN"",""MAGDHOW4"",117,0)"
^XMB(3.9,145834,2,1580,0)=" ;"
^XMB(3.9,145834,2,1581,0)="""RTN"",""MAGDHOW4"",118,0)"
^XMB(3.9,145834,2,1582,0)=" I MSGTYPE=""ORU"" D  ; code for result messages, not orders"
^XMB(3.9,145834,2,1583,0)="""RTN"",""MAGDHOW4"",119,0)"
^XMB(3.9,145834,2,1584,0)=" . N AUTHOR"
^XMB(3.9,145834,2,1585,0)="""RTN"",""MAGDHOW4"",120,0)"
^XMB(3.9,145834,2,1586,0)=" . D SET^HLOAPI(.OBRSEG,$$FMTHL7^XLFDT(FMDATETM),22) ; OBR-22"
^XMB(3.9,145834,2,1587,0)="""RTN"",""MAGDHOW4"",121,0)"
^XMB(3.9,145834,2,1588,0)=" . D SET^HLOAPI(.OBRSEG,$S(ORSTATUS=""CM"":""F"",1:""R""),25) ; OBR-25"
^XMB(3.9,145834,2,1589,0)="""RTN"",""MAGDHOW4"",122,0)"
^XMB(3.9,145834,2,1590,0)=" . ; directly call rpc TIU GET DOCUMENTS FOR REQUEST"
^XMB(3.9,145834,2,1591,0)="""RTN"",""MAGDHOW4"",123,0)"
^XMB(3.9,145834,2,1592,0)=" . D GETDOCS^TIUSRVLR(.TIUDOC,GMRCIEN_"";GMR(123,"") ; ICR 3536"
^XMB(3.9,145834,2,1593,0)="""RTN"",""MAGDHOW4"",124,0)"
^XMB(3.9,145834,2,1594,0)=" . ; get author of most recent (last) report"
^XMB(3.9,145834,2,1595,0)="""RTN"",""MAGDHOW4"",125,0)"
^XMB(3.9,145834,2,1596,0)=" . S I=0 F  S I=$O(@TIUDOC@(I)) Q:'I  S X=@TIUDOC@(I) D"
^XMB(3.9,145834,2,1597,0)="""RTN"",""MAGDHOW4"",126,0)"
^XMB(3.9,145834,2,1598,0)=" . . S AUTHOR=$P(X,""^"",5)"
^XMB(3.9,145834,2,1599,0)="""RTN"",""MAGDHOW4"",127,0)"
^XMB(3.9,145834,2,1600,0)=" . . Q"
^XMB(3.9,145834,2,1601,0)="""RTN"",""MAGDHOW4"",128,0)"
^XMB(3.9,145834,2,1602,0)=" . I $D(AUTHOR) D NAME^MAGDHOW3(+AUTHOR,32,.OBRSEG) ; OBR-32"
^XMB(3.9,145834,2,1603,0)="""RTN"",""MAGDHOW4"",129,0)"
^XMB(3.9,145834,2,1604,0)=" . Q"
^XMB(3.9,145834,2,1605,0)="""RTN"",""MAGDHOW4"",130,0)"
^XMB(3.9,145834,2,1606,0)=" ;"
^XMB(3.9,145834,2,1607,0)="""RTN"",""MAGDHOW4"",131,0)"
^XMB(3.9,145834,2,1608,0)=" E  I MSGTYPE=""ORM"" D  ; code for order messages, not results"
^XMB(3.9,145834,2,1609,0)="""RTN"",""MAGDHOW4"",132,0)"
^XMB(3.9,145834,2,1610,0)=" . M OBRSEG(27)=SAVEORCSEG(7) ; quantity/timing - OBR-27"
^XMB(3.9,145834,2,1611,0)="""RTN"",""MAGDHOW4"",133,0)"
^XMB(3.9,145834,2,1612,0)=" . ;"
^XMB(3.9,145834,2,1613,0)="""RTN"",""MAGDHOW4"",134,0)"
^XMB(3.9,145834,2,1614,0)=" . ; date and time of scheduled appointment"
^XMB(3.9,145834,2,1615,0)="""RTN"",""MAGDHOW4"",135,0)"
^XMB(3.9,145834,2,1616,0)=" . I $D(APTSCHED(""FM DATETIME"")) D"
^XMB(3.9,145834,2,1617,0)="""RTN"",""MAGDHOW4"",136,0)"
^XMB(3.9,145834,2,1618,0)=" . . D SET^HLOAPI(.OBRSEG,$$FMTHL7^XLFDT(APTSCHED(""FM DATETIME"")),36) ; OBR-36"
^XMB(3.9,145834,2,1619,0)="""RTN"",""MAGDHOW4"",137,0)"
^XMB(3.9,145834,2,1620,0)=" . . Q"
^XMB(3.9,145834,2,1621,0)="""RTN"",""MAGDHOW4"",138,0)"
^XMB(3.9,145834,2,1622,0)=" . Q"
^XMB(3.9,145834,2,1623,0)="""RTN"",""MAGDHOW4"",139,0)"
^XMB(3.9,145834,2,1624,0)=" ;"
^XMB(3.9,145834,2,1625,0)="""RTN"",""MAGDHOW4"",140,0)"
^XMB(3.9,145834,2,1626,0)=" ;"
^XMB(3.9,145834,2,1627,0)="""RTN"",""MAGDHOW4"",141,0)"
^XMB(3.9,145834,2,1628,0)=" S SUCCESS=$$ADDSEG^HLOAPI(.HLMSTATE,.OBRSEG,.ERROR)"
^XMB(3.9,145834,2,1629,0)="""RTN"",""MAGDHOW4"",142,0)"
^XMB(3.9,145834,2,1630,0)=" I 'SUCCESS D"
^XMB(3.9,145834,2,1631,0)="""RTN"",""MAGDHOW4"",143,0)"
^XMB(3.9,145834,2,1632,0)=" . N MSG,SUBJECT,VARIABLES"
^XMB(3.9,145834,2,1633,0)="""RTN"",""MAGDHOW4"",144,0)"
^XMB(3.9,145834,2,1634,0)=" . S SUBJECT=""VistA Imaging Clinical Specialty (CPRS) HL7 Generation"""
^XMB(3.9,145834,2,1635,0)="""RTN"",""MAGDHOW4"",145,0)"
^XMB(3.9,145834,2,1636,0)=" . S MSG(1)=""An error occurred in OBR^""_$T(+0)_"" where the ADDSEG^HLOAPI invocation"""
^XMB(3.9,145834,2,1637,0)="""RTN"",""MAGDHOW4"",146,0)"
^XMB(3.9,145834,2,1638,0)=" . S MSG(2)=""for the OBR segment failed.  The error message is as follows:"""
^XMB(3.9,145834,2,1639,0)="""RTN"",""MAGDHOW4"",147,0)"
^XMB(3.9,145834,2,1640,0)=" . S MSG(3)=""""""""_SUCCESS_"""""""""
^XMB(3.9,145834,2,1641,0)="""RTN"",""MAGDHOW4"",148,0)"
^XMB(3.9,145834,2,1642,0)=" . S VARIABLES(""HLMSTATE"")="""""
^XMB(3.9,145834,2,1643,0)="""RTN"",""MAGDHOW4"",149,0)"
^XMB(3.9,145834,2,1644,0)=" . S VARIABLES(""OBRSEG"")="""""
^XMB(3.9,145834,2,1645,0)="""RTN"",""MAGDHOW4"",150,0)"
^XMB(3.9,145834,2,1646,0)=" . S VARIABLES(""ERROR"")="""""
^XMB(3.9,145834,2,1647,0)="""RTN"",""MAGDHOW4"",151,0)"
^XMB(3.9,145834,2,1648,0)=" . D ERROR^MAGDHOWA(SUBJECT,.MSG,.VARIABLES)"
^XMB(3.9,145834,2,1649,0)="""RTN"",""MAGDHOW4"",152,0)"
^XMB(3.9,145834,2,1650,0)=" . Q"
^XMB(3.9,145834,2,1651,0)="""RTN"",""MAGDHOW4"",153,0)"
^XMB(3.9,145834,2,1652,0)=" Q"
