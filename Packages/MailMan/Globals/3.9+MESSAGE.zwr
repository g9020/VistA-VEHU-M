^XMB(3.9,144657,2,9843,0)="""RTN"",""IBJPI"",190,0)"
^XMB(3.9,144657,2,9844,0)=" S ELINE=$$SETN(""Batch Extracts"",ELINE,1,1)"
^XMB(3.9,144657,2,9845,0)="""RTN"",""IBJPI"",191,0)"
^XMB(3.9,144657,2,9846,0)=" ;/vd-IB*2*687 - Commented the following section of code and re-wrote it to make it cleaner."
^XMB(3.9,144657,2,9847,0)="""RTN"",""IBJPI"",192,0)"
^XMB(3.9,144657,2,9848,0)=" ;               Also renamed variable IBIIVB to IBEIVB to better reflect the application name"
^XMB(3.9,144657,2,9849,0)="""RTN"",""IBJPI"",193,0)"
^XMB(3.9,144657,2,9850,0)=" ;S ELINE=$$SET("" Extract               Selection    Maximum # to"","""",ELINE,1)"
^XMB(3.9,144657,2,9851,0)="""RTN"",""IBJPI"",194,0)"
^XMB(3.9,144657,2,9852,0)=" ;S ELINE=$$SETN(""Name         On/Off   Criteria     Extract/Day"",ELINE,1,"""",1)"
^XMB(3.9,144657,2,9853,0)="""RTN"",""IBJPI"",195,0)"
^XMB(3.9,144657,2,9854,0)=" ;"
^XMB(3.9,144657,2,9855,0)="""RTN"",""IBJPI"",196,0)"
^XMB(3.9,144657,2,9856,0)=" ; Loop thru extracts"
^XMB(3.9,144657,2,9857,0)="""RTN"",""IBJPI"",197,0)"
^XMB(3.9,144657,2,9858,0)=" ;S IEN=0"
^XMB(3.9,144657,2,9859,0)="""RTN"",""IBJPI"",198,0)"
^XMB(3.9,144657,2,9860,0)=" ;F  D  Q:'IEN"
^XMB(3.9,144657,2,9861,0)="""RTN"",""IBJPI"",199,0)"
^XMB(3.9,144657,2,9862,0)=" ;. S IEN=$O(^IBE(350.9,1,51.17,IEN))"
^XMB(3.9,144657,2,9863,0)="""RTN"",""IBJPI"",200,0)"
^XMB(3.9,144657,2,9864,0)=" ;. Q:'IEN"
^XMB(3.9,144657,2,9865,0)="""RTN"",""IBJPI"",201,0)"
^XMB(3.9,144657,2,9866,0)=" ;. S IBIIVB=$G(^IBE(350.9,1,51.17,IEN,0))       ; Batch Extract multiple line"
^XMB(3.9,144657,2,9867,0)="""RTN"",""IBJPI"",202,0)"
^XMB(3.9,144657,2,9868,0)=" ;. S IBEX=+$P(IBIIVB,""^"",1)                     ; Type"
^XMB(3.9,144657,2,9869,0)="""RTN"",""IBJPI"",203,0)"
^XMB(3.9,144657,2,9870,0)=" ;. Q:'$F("".1.2."","".""_IBEX_""."")"
^XMB(3.9,144657,2,9871,0)="""RTN"",""IBJPI"",204,0)"
^XMB(3.9,144657,2,9872,0)=" ;. S IBST=$$FO^IBCNEUT1($S($P(IBIIVB,""^"",1)'="""":$$GET1^DIQ(350.9002,IEN_"",1,"",.01,""E""),1:""""),14)"
^XMB(3.9,144657,2,9873,0)="""RTN"",""IBJPI"",205,0)"
^XMB(3.9,144657,2,9874,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1($S(+$P(IBIIVB,""^"",2):""ON"",1:""OFF""),9)"
^XMB(3.9,144657,2,9875,0)="""RTN"",""IBJPI"",206,0)"
^XMB(3.9,144657,2,9876,0)=" ;. S IBEX1=$S(+$P(IBIIVB,U,3)'=0:+$P(IBIIVB,""^"",3),1:$P(IBIIVB,""^"",3))"
^XMB(3.9,144657,2,9877,0)="""RTN"",""IBJPI"",207,0)"
^XMB(3.9,144657,2,9878,0)=" ;. S IBEX2=$S(+$P(IBIIVB,U,4)'=0:+$P(IBIIVB,""^"",4),1:$P(IBIIVB,""^"",4))"
^XMB(3.9,144657,2,9879,0)="""RTN"",""IBJPI"",208,0)"
^XMB(3.9,144657,2,9880,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1($S(IBEX=1:""n/a"",IBEX=2:IBEX1,IBEX=3:IBEX1_""/""_IBEX2,1:""ERROR""),13)"
^XMB(3.9,144657,2,9881,0)="""RTN"",""IBJPI"",209,0)"
^XMB(3.9,144657,2,9882,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1($S(+$P(IBIIVB,""^"",5):+$P(IBIIVB,""^"",5),1:$P(IBIIVB,""^"",5)),14)"
^XMB(3.9,144657,2,9883,0)="""RTN"",""IBJPI"",210,0)"
^XMB(3.9,144657,2,9884,0)=" ;. S ELINE=$$SET(IBST,"""",ELINE,1)"
^XMB(3.9,144657,2,9885,0)="""RTN"",""IBJPI"",211,0)"
