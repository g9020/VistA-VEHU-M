^XMB(3.9,144657,2,4143,0)="""RTN"",""IBCNEHL5A"",7,0)"
^XMB(3.9,144657,2,4144,0)="LOAD(RIEN) ; Load Medicare policy as a new policy on patient record"
^XMB(3.9,144657,2,4145,0)="""RTN"",""IBCNEHL5A"",8,0)"
^XMB(3.9,144657,2,4146,0)=" ; RIEN - IEN OF THE EIV REPONSE IN FILE #365"
