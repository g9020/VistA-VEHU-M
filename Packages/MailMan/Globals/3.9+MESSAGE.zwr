^XMB(3.9,145834,2,6438,0)=" . . Q"
^XMB(3.9,145834,2,6439,0)="""RTN"",""MAGDSTAS"",109,0)"
^XMB(3.9,145834,2,6440,0)=" . E  D"
^XMB(3.9,145834,2,6441,0)="""RTN"",""MAGDSTAS"",110,0)"
^XMB(3.9,145834,2,6442,0)=" . . W !,""The process has not been run for the following date intervals:"""
^XMB(3.9,145834,2,6443,0)="""RTN"",""MAGDSTAS"",111,0)"
^XMB(3.9,145834,2,6444,0)=" . . S HDATE1="""" F  D  Q:HDATE1="""""
^XMB(3.9,145834,2,6445,0)="""RTN"",""MAGDSTAS"",112,0)"
^XMB(3.9,145834,2,6446,0)=" . . . S HDATE1=$O(^TMP(""MAG"",$J,""BATCH Q/R"",""DATE"",HDATE1))"
^XMB(3.9,145834,2,6447,0)="""RTN"",""MAGDSTAS"",113,0)"
^XMB(3.9,145834,2,6448,0)=" . . . I HDATE1="""" Q  ; no more date intervals"
^XMB(3.9,145834,2,6449,0)="""RTN"",""MAGDSTAS"",114,0)"
^XMB(3.9,145834,2,6450,0)=" . . . F HDATE2=HDATE1:1 Q:'$D(^TMP(""MAG"",$J,""BATCH Q/R"",""DATE"",HDATE2))"
^XMB(3.9,145834,2,6451,0)="""RTN"",""MAGDSTAS"",115,0)"
^XMB(3.9,145834,2,6452,0)=" . . . W ! I $Y>(IOSL-4) D CONTINUE^MAGDSTQ(1)"
^XMB(3.9,145834,2,6453,0)="""RTN"",""MAGDSTAS"",116,0)"
^XMB(3.9,145834,2,6454,0)=" . . . W ?15,$$HTE^XLFDT(HDATE1),"" -- "",$$HTE^XLFDT(HDATE2)"
^XMB(3.9,145834,2,6455,0)="""RTN"",""MAGDSTAS"",117,0)"
