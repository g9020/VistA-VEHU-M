^XMB(3.9,145836,2,639,0)="""RTN"",""GMTSPST1"",198,0)"
^XMB(3.9,145836,2,640,0)=" W !?10,""Rx# ""_$G(^TMP($J,""GMTSPST1"",DFN,PACKREF,.01))_"" Last Released: ""_$$FMTE^XLFDT(LASTREL,""2D""),?50,""Qty/Days Supply: ""_$G(^TMP($J,""GMTSPST1"",DFN,PACKREF,7))_""/""_$G(^TMP($J,""GMTSPST1"",DFN,PACKREF,8)) D CKP Q:$D(GMTSQIT)"
