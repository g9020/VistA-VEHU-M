^XMB(3.9,145837,2,239,0)="""RTN"",""XQALSET"")"
^XMB(3.9,145837,2,240,0)="0^1^B72706141"
^XMB(3.9,145837,2,241,0)="""RTN"",""XQALSET"",1,0)"
^XMB(3.9,145837,2,242,0)="XQALSET ;ISC-SF.SEA/JLI - SETUP ALERTS ;10/19/18  14:06"
^XMB(3.9,145837,2,243,0)="""RTN"",""XQALSET"",2,0)"
^XMB(3.9,145837,2,244,0)=" ;;8.0;KERNEL;**1,6,65,75,114,125,173,207,285,443,602,653**;Jul 10, 1995;Build 0"
^XMB(3.9,145837,2,245,0)="""RTN"",""XQALSET"",3,0)"
^XMB(3.9,145837,2,246,0)=" ;Per VHA Directive 2004-038, this routine should not be modified"
^XMB(3.9,145837,2,247,0)="""RTN"",""XQALSET"",4,0)"
^XMB(3.9,145837,2,248,0)=" ;;"
^XMB(3.9,145837,2,249,0)="""RTN"",""XQALSET"",5,0)"
^XMB(3.9,145837,2,250,0)=" Q"
^XMB(3.9,145837,2,251,0)="""RTN"",""XQALSET"",6,0)"
^XMB(3.9,145837,2,252,0)=" ; Original entry point - throw away return value since no value expected"
^XMB(3.9,145837,2,253,0)="""RTN"",""XQALSET"",7,0)"
^XMB(3.9,145837,2,254,0)="SETUP ;"
^XMB(3.9,145837,2,255,0)="""RTN"",""XQALSET"",8,0)"
^XMB(3.9,145837,2,256,0)=" N I S I=$$SETUP1() K XQALERR"
^XMB(3.9,145837,2,257,0)="""RTN"",""XQALSET"",9,0)"
^XMB(3.9,145837,2,258,0)=" Q"
^XMB(3.9,145837,2,259,0)="""RTN"",""XQALSET"",10,0)"
^XMB(3.9,145837,2,260,0)=" ;"
^XMB(3.9,145837,2,261,0)="""RTN"",""XQALSET"",11,0)"
^XMB(3.9,145837,2,262,0)="SETUP1() ; .SR Returns a string beginning with 1 if successful, 0 if not successful, the second piece is the IEN in the Alert Tracking File and the third piece is the value of XQAID."
^XMB(3.9,145837,2,263,0)="""RTN"",""XQALSET"",12,0)"
^XMB(3.9,145837,2,264,0)=" ; If not successful XQALERR is defined and contains reason for failure."
^XMB(3.9,145837,2,265,0)="""RTN"",""XQALSET"",13,0)"
^XMB(3.9,145837,2,266,0)=" K XQALERR"
^XMB(3.9,145837,2,267,0)="""RTN"",""XQALSET"",14,0)"
^XMB(3.9,145837,2,268,0)=" I $O(XQA(0))="""" S XQALERR=""No recipient list in XQA array"" Q 0"
^XMB(3.9,145837,2,269,0)="""RTN"",""XQALSET"",15,0)"
^XMB(3.9,145837,2,270,0)=" I '($D(XQAMSG)#2)!($G(XQAMSG)="""") S XQALERR=""No valid XQAMSG for display"" Q 0"
^XMB(3.9,145837,2,271,0)="""RTN"",""XQALSET"",16,0)"
^XMB(3.9,145837,2,272,0)=" N X,XQI,XQJ,XQX,XQK,XQACOMNT,XQARESET,DA,XQADA,XQALTYPE"
^XMB(3.9,145837,2,273,0)="""RTN"",""XQALSET"",17,0)"
^XMB(3.9,145837,2,274,0)=" S XQALTYPE=""INITIAL RECIPIENT"""
^XMB(3.9,145837,2,275,0)="""RTN"",""XQALSET"",18,0)"
^XMB(3.9,145837,2,276,0)=" S XQAOPT1=$S('($D(XQAROU)#2):U,XQAROU'[U:U_XQAROU,1:XQAROU),XQAOPT1=$S(XQAOPT1'=U:XQAOPT1,$D(XQAOPT)#2:XQAOPT_U,1:XQAOPT1) S:XQAOPT1=U XQAOPT1=U_"" """
^XMB(3.9,145837,2,277,0)="""RTN"",""XQALSET"",19,0)"
^XMB(3.9,145837,2,278,0)="NOW S XQX=$$NOW^XLFDT()"
^XMB(3.9,145837,2,279,0)="""RTN"",""XQALSET"",20,0)"
^XMB(3.9,145837,2,280,0)=" S:$S('$D(XQAID):1,XQAID="""":1,1:0) XQAID=""NO-ID"" S:XQAID["";"" XQAID=$P(XQAID,"";"") S XQA1=XQAID,XQI=XQX"
^XMB(3.9,145837,2,281,0)="""RTN"",""XQALSET"",21,0)"
^XMB(3.9,145837,2,282,0)=" S XQAID=$$SETIEN(XQA1,XQX),XQADA="""""
^XMB(3.9,145837,2,283,0)="""RTN"",""XQALSET"",22,0)"
^XMB(3.9,145837,2,284,0)=" Q $$REENT()"
^XMB(3.9,145837,2,285,0)="""RTN"",""XQALSET"",23,0)"
^XMB(3.9,145837,2,286,0)=" ;"
^XMB(3.9,145837,2,287,0)="""RTN"",""XQALSET"",24,0)"
^XMB(3.9,145837,2,288,0)="REENT() ; Entry for forwarding, etc."
^XMB(3.9,145837,2,289,0)="""RTN"",""XQALSET"",25,0)"
^XMB(3.9,145837,2,290,0)=" N RETVAL S RETVAL=1"
^XMB(3.9,145837,2,291,0)="""RTN"",""XQALSET"",26,0)"
^XMB(3.9,145837,2,292,0)=" K ^TMP(""XQAGROUP"",$J) ; P443 - clear location for storage of groups processed"
^XMB(3.9,145837,2,293,0)="""RTN"",""XQALSET"",27,0)"
^XMB(3.9,145837,2,294,0)=" N XQADATIM,XQALIST,XQALIST1,XQNRECIP S XQNRECIP=0 S XQADATIM=$$NOW^XLFDT()"
^XMB(3.9,145837,2,295,0)="""RTN"",""XQALSET"",28,0)"
^XMB(3.9,145837,2,296,0)=" S XQALIN1=$S($D(XQAID)#2:XQAID,1:"""")_U_$E(XQAMSG,1,95)_""^1^""_$S(XQAOPT1=U:""D"",1:""R"")_U_$S($D(XQACTMSG):$E(XQACTMSG,1,40),1:"""")_U_XQAOPT1"
^XMB(3.9,145837,2,297,0)="""RTN"",""XQALSET"",29,0)"
^XMB(3.9,145837,2,298,0)=" S:$D(XQACNDEL) $P(XQALIN1,U,9)=1 S:$D(XQASURO) $P(XQALIN1,U,12)=XQASURO S:$D(XQASUPV) $P(XQALIN1,U,13)=XQASUPV S:$D(XQAREVUE) $P(XQALIN1,U,14)=XQAREVUE"
^XMB(3.9,145837,2,299,0)="""RTN"",""XQALSET"",30,0)"
^XMB(3.9,145837,2,300,0)=" S XQALIN=XQX_U_XQALIN1,XQJ=0"
^XMB(3.9,145837,2,301,0)="""RTN"",""XQALSET"",31,0)"
^XMB(3.9,145837,2,302,0)=" K XQALIN1 S:$D(XQADATA) XQALIN1=XQADATA"
^XMB(3.9,145837,2,303,0)="""RTN"",""XQALSET"",32,0)"
^XMB(3.9,145837,2,304,0)="LOOP1 S XQJ=$O(XQA("" "")) I XQJ'="""" K:""G.g.""'[$E(XQJ_"",,"",1,2) XQA(XQJ) D:$D(XQA(XQJ)) GROUP^XQALSET1 G LOOP1"
^XMB(3.9,145837,2,305,0)="""RTN"",""XQALSET"",33,0)"
^XMB(3.9,145837,2,306,0)="LOOP2 ; RE-ENTRY FOR FORWARDING IF ALL RECIPIENTS ARE UNDELIVERABLE"
^XMB(3.9,145837,2,307,0)="""RTN"",""XQALSET"",34,0)"
^XMB(3.9,145837,2,308,0)=" N:'$D(XQAUSER) XQAUSER M XQALIST=XQA F I=0:0 S I=$O(XQALIST(I)) Q:I'>0  S XQALIST(I,XQALTYPE)="""" I '$D(XQAUSER) S XQAUSER=I ; SAVE ORIGINAL LIST OF RECIPIENTS AND REASON"
^XMB(3.9,145837,2,309,0)="""RTN"",""XQALSET"",35,0)"
^XMB(3.9,145837,2,310,0)=" ; The following section of code was added to provide a generalized way to handle surrogates"
^XMB(3.9,145837,2,311,0)="""RTN"",""XQALSET"",36,0)"
^XMB(3.9,145837,2,312,0)=" F XQJ=0:0 S XQJ=$O(XQA(XQJ)) Q:XQJ=""""  D"
^XMB(3.9,145837,2,313,0)="""RTN"",""XQALSET"",37,0)"
^XMB(3.9,145837,2,314,0)=" . N X S X=$$ACTVSURO^XQALSURO(XQJ) I X>0 D  ; Modified to get final surrogate if a sequence of them"
^XMB(3.9,145837,2,315,0)="""RTN"",""XQALSET"",38,0)"
^XMB(3.9,145837,2,316,0)=" . . S XQA(X)="""" K XQA(XQJ) ; Add Surrogate to XQA array, delete XQJ entry"
^XMB(3.9,145837,2,317,0)="""RTN"",""XQALSET"",39,0)"
^XMB(3.9,145837,2,318,0)=" . . S XQALIST(X,$O(XQALIST(XQJ,""""))_""-SURROGATE"")="""" ; Add Surrogate to XQALIST with same type as original"
^XMB(3.9,145837,2,319,0)="""RTN"",""XQALSET"",40,0)"
^XMB(3.9,145837,2,320,0)=" . . S XQALIST(X,""z AS_SURO"",XQJ)="""" ; Mark user as in list as a surrogate, subscript for surrogate to"
^XMB(3.9,145837,2,321,0)="""RTN"",""XQALSET"",41,0)"
^XMB(3.9,145837,2,322,0)=" . . S XQALIST(XQJ,""z TO_SURO"",X)="""""
^XMB(3.9,145837,2,323,0)="""RTN"",""XQALSET"",42,0)"
^XMB(3.9,145837,2,324,0)=" . . Q"
^XMB(3.9,145837,2,325,0)="""RTN"",""XQALSET"",43,0)"
^XMB(3.9,145837,2,326,0)=" . Q"
^XMB(3.9,145837,2,327,0)="""RTN"",""XQALSET"",44,0)"
^XMB(3.9,145837,2,328,0)=" ;"
^XMB(3.9,145837,2,329,0)="""RTN"",""XQALSET"",45,0)"
^XMB(3.9,145837,2,330,0)=" S XQJ=0"
^XMB(3.9,145837,2,331,0)="""RTN"",""XQALSET"",46,0)"
^XMB(3.9,145837,2,332,0)="LOOP ;"
^XMB(3.9,145837,2,333,0)="""RTN"",""XQALSET"",47,0)"
^XMB(3.9,145837,2,334,0)=" S XQJ=$O(XQA(XQJ)) G:XQJ="""" WRAP"
^XMB(3.9,145837,2,335,0)="""RTN"",""XQALSET"",48,0)"
^XMB(3.9,145837,2,336,0)=" ;"
^XMB(3.9,145837,2,337,0)="""RTN"",""XQALSET"",49,0)"
^XMB(3.9,145837,2,338,0)=" I '(+$$ACTIVE^XUSER(XQJ)) K XQA(XQJ) N XX S XX=$O(XQALIST(XQJ,"""")) K XQALIST(XQJ,XX) S XQALIST(XQJ,XX_""-UNDELIVERABLE"")="""" G LOOP ;Don't send to users that can't sign-on"
^XMB(3.9,145837,2,339,0)="""RTN"",""XQALSET"",50,0)"
^XMB(3.9,145837,2,340,0)=" ;"
^XMB(3.9,145837,2,341,0)="""RTN"",""XQALSET"",51,0)"
^XMB(3.9,145837,2,342,0)=" I '$D(^XTV(8992,XQJ,0)) D  I '$D(^XTV(8992,XQJ,0)) S ^(0)=XQJ"
^XMB(3.9,145837,2,343,0)="""RTN"",""XQALSET"",52,0)"
^XMB(3.9,145837,2,344,0)=" . N FDA,IENS"
^XMB(3.9,145837,2,345,0)="""RTN"",""XQALSET"",53,0)"
^XMB(3.9,145837,2,346,0)=" . F  D  Q:'$D(DIERR)  Q:'$D(^TMP(""DIERR"",$J,""E"",110))&'$D(^TMP(""DIERR"",$J,""E"",111))"
^XMB(3.9,145837,2,347,0)="""RTN"",""XQALSET"",54,0)"
^XMB(3.9,145837,2,348,0)=" . . K DIERR,^TMP(""DIERR"",$J)"
^XMB(3.9,145837,2,349,0)="""RTN"",""XQALSET"",55,0)"
^XMB(3.9,145837,2,350,0)=" . . S FDA=$NA(^TMP($J,""XQALSET"")) K @FDA S @FDA@(8992,""+1,"",.01)=XQJ"
^XMB(3.9,145837,2,351,0)="""RTN"",""XQALSET"",56,0)"
^XMB(3.9,145837,2,352,0)=" . . S IENS(1)=XQJ"
^XMB(3.9,145837,2,353,0)="""RTN"",""XQALSET"",57,0)"
^XMB(3.9,145837,2,354,0)=" . . D UPDATE^DIE(""S"",FDA,""IENS"")"
^XMB(3.9,145837,2,355,0)="""RTN"",""XQALSET"",58,0)"
^XMB(3.9,145837,2,356,0)=" . . Q"
^XMB(3.9,145837,2,357,0)="""RTN"",""XQALSET"",59,0)"
^XMB(3.9,145837,2,358,0)=" . Q"
^XMB(3.9,145837,2,359,0)="""RTN"",""XQALSET"",60,0)"
^XMB(3.9,145837,2,360,0)=" L +^XTV(8992,XQJ):10 S XQXI=XQX S:'$D(^XTV(8992,XQJ,""XQA"",0)) ^(0)=""^8992.01DA^"""
^XMB(3.9,145837,2,361,0)="""RTN"",""XQALSET"",61,0)"
^XMB(3.9,145837,2,362,0)="REP I $D(^XTV(8992,XQJ,""XQA"",XQXI,0)) S XQXI=XQXI+.00000001 G REP"
^XMB(3.9,145837,2,363,0)="""RTN"",""XQALSET"",62,0)"
^XMB(3.9,145837,2,364,0)=" S ^XTV(8992,XQJ,""XQA"",XQXI,0)=XQALIN S:$D(XQALIN1) ^(1)=XQALIN1 S:$D(XQAGUID)!$D(XQADFN) ^(3)=$G(XQAGUID)_U_$G(XQADFN) S:$D(XQARESET) ^(2)=XQAUSER_U_XQX_U_$G(XQACOMNT) S ^(0)=$P(^XTV(8992,XQJ,""XQA"",0),U,1,2)_U_XQXI_U_($P(^(0),U,4)+1)"
^XMB(3.9,145837,2,365,0)="""RTN"",""XQALSET"",63,0)"
^XMB(3.9,145837,2,366,0)=" I $D(XQATEXT) S:($D(XQATEXT)#2) XQATEXT(.1)=XQATEXT D WP^DIE(8992.01,(XQXI_"",""_XQJ_"",""),4,"""",""XQATEXT"") ; P443 PUT DATA IN XQATEXT INTO ARRAY"
^XMB(3.9,145837,2,367,0)="""RTN"",""XQALSET"",64,0)"
^XMB(3.9,145837,2,368,0)=" L -^XTV(8992,XQJ)"
^XMB(3.9,145837,2,369,0)="""RTN"",""XQALSET"",65,0)"
^XMB(3.9,145837,2,370,0)=" K XQA(XQJ) S:XQAID'="""" ^XTV(8992,""AXQA"",XQAID,XQJ,XQXI)="""",^XTV(8992,""AXQAN"",XQA1,XQJ,XQXI)="""""
^XMB(3.9,145837,2,371,0)="""RTN"",""XQALSET"",66,0)"
^XMB(3.9,145837,2,372,0)=" S XQNRECIP=XQNRECIP+1"
^XMB(3.9,145837,2,373,0)="""RTN"",""XQALSET"",67,0)"
^XMB(3.9,145837,2,374,0)=" G LOOP"
^XMB(3.9,145837,2,375,0)="""RTN"",""XQALSET"",68,0)"
^XMB(3.9,145837,2,376,0)=" ;"
^XMB(3.9,145837,2,377,0)="""RTN"",""XQALSET"",69,0)"
^XMB(3.9,145837,2,378,0)="WRAP ;"
^XMB(3.9,145837,2,379,0)="""RTN"",""XQALSET"",70,0)"
^XMB(3.9,145837,2,380,0)=" M XQALIST1=XQALIST"
^XMB(3.9,145837,2,381,0)="""RTN"",""XQALSET"",71,0)"
^XMB(3.9,145837,2,382,0)=" I XQNRECIP=0,'$$SNDNACTV(XQAID) S RETVAL=0,XQALERR=""NO ACTIVE RECIPIENTS - OLDER TIU ALERTS"""
^XMB(3.9,145837,2,383,0)="""RTN"",""XQALSET"",72,0)"
^XMB(3.9,145837,2,384,0)=" E  I XQNRECIP=0 D  I $D(XQA) S XQACOMNT=$E(""None of recipients were active users. ""_$G(XQACOMNT),1,245),XQNRECIP=1,XQARESET=1 K XQALIST G LOOP2 ; SET NUMBER OF RECIPIENTS TO 1 SO WE WON'T COME HERE AGAIN"
^XMB(3.9,145837,2,385,0)="""RTN"",""XQALSET"",73,0)"
^XMB(3.9,145837,2,386,0)=" . N XQAA,XQJ F XQI=0:0 S XQI=$O(XQALIST(XQI)) Q:XQI'>0  D GETBKUP^XQALDEL(.XQAA,XQI) S XQALTYPE=""BACKUP REVIEWER"" F XQJ=0:0 S XQJ=$O(XQAA(XQJ)) Q:XQJ'>0  S XQA(XQAA(XQJ))="""""
^XMB(3.9,145837,2,387,0)="""RTN"",""XQALSET"",74,0)"
^XMB(3.9,145837,2,388,0)=" . I $D(XQA) D CHEKACTV^XQALSET1(.XQA)"
^XMB(3.9,145837,2,389,0)="""RTN"",""XQALSET"",75,0)"
^XMB(3.9,145837,2,390,0)=" . I '$D(XQA) S XQJ=""G.XQAL UNPROCESSED ALERTS"" D GROUP^XQALSET1 S XQALTYPE=""UNPROCESSED ALERTS MAIL GROUP"" ;D GETMLGRP(.XQA,XQI) ; COULDN'T FIND ANY BACKUP, GET A MAILGROUP AND MEMBERS TO SEND IT TO"
^XMB(3.9,145837,2,391,0)="""RTN"",""XQALSET"",76,0)"
^XMB(3.9,145837,2,392,0)=" . I '$D(XQA) S XQJ=""G.PATCHES"" D GROUP^XQALSET1 S XQALTYPE=""LAST HOPE"" ; Last gasp, send it to G.PATCHES"
^XMB(3.9,145837,2,393,0)="""RTN"",""XQALSET"",77,0)"
^XMB(3.9,145837,2,394,0)=" . I '$D(XQA) S XQJ=""G.PATCH"" D GROUP^XQALSET1 S XQALTYPE=""LAST HOPE"" ; Last gasp, send it to G.PATCH"
^XMB(3.9,145837,2,395,0)="""RTN"",""XQALSET"",78,0)"
^XMB(3.9,145837,2,396,0)=" . I '$D(XQA) S RETVAL=0,XQALERR=""Could not find any active user to send it to"" ; Should not get here, this is only if all backups and mail groups tried don't have any active users"
^XMB(3.9,145837,2,397,0)="""RTN"",""XQALSET"",79,0)"
^XMB(3.9,145837,2,398,0)=" . Q"
^XMB(3.9,145837,2,399,0)="""RTN"",""XQALSET"",80,0)"
^XMB(3.9,145837,2,400,0)=" ; END OF JLI 030129 INSERTION P285"
^XMB(3.9,145837,2,401,0)="""RTN"",""XQALSET"",81,0)"
^XMB(3.9,145837,2,402,0)=" ; moved recording of users in Alert Tracking file to here to include all of them  030220"
^XMB(3.9,145837,2,403,0)="""RTN"",""XQALSET"",82,0)"
^XMB(3.9,145837,2,404,0)=" ; modified code to use FM calls instead of direct global references"
^XMB(3.9,145837,2,405,0)="""RTN"",""XQALSET"",83,0)"
^XMB(3.9,145837,2,406,0)=" I RETVAL,$G(XQADA)'>0,XQAID'="""" D SETTRACK ; moved to here to avoid tracking entries with no users"
^XMB(3.9,145837,2,407,0)="""RTN"",""XQALSET"",84,0)"
^XMB(3.9,145837,2,408,0)=" ;"
^XMB(3.9,145837,2,409,0)="""RTN"",""XQALSET"",85,0)"
^XMB(3.9,145837,2,410,0)=" I RETVAL,$G(XQADA)>0 L +^XTV(8992.1,XQADA):10 D  L -^XTV(8992.1,XQADA) ; 030131"
^XMB(3.9,145837,2,411,0)="""RTN"",""XQALSET"",86,0)"
^XMB(3.9,145837,2,412,0)=" . F XQJ=0:0 S XQJ=$O(XQALIST1(XQJ)) Q:XQJ'>0  D"
^XMB(3.9,145837,2,413,0)="""RTN"",""XQALSET"",87,0)"
^XMB(3.9,145837,2,414,0)=" . . N NCOUNT,SUBSCRPT,SUBSCRPN,KCNT,IENVAL"
^XMB(3.9,145837,2,415,0)="""RTN"",""XQALSET"",88,0)"
^XMB(3.9,145837,2,416,0)=" . . S IENVAL=XQADA_"","",KCNT=$$FIND1^DIC(8992.11,"",""_IENVAL,""Q"",XQJ)"
^XMB(3.9,145837,2,417,0)="""RTN"",""XQALSET"",89,0)"
^XMB(3.9,145837,2,418,0)=" . . S FDA=$NA(^TMP($J,""XQALSET"")) K @FDA I KCNT=0 S @FDA@(8992.11,""+1,""_IENVAL,.01)=XQJ,KCNT=""+1"""
^XMB(3.9,145837,2,419,0)="""RTN"",""XQALSET"",90,0)"
^XMB(3.9,145837,2,420,0)=" . . S IENVAL="",""_KCNT_"",""_IENVAL,NCOUNT=1 S SUBSCRPT="""" F  S SUBSCRPT=$O(XQALIST1(XQJ,SUBSCRPT)) Q:SUBSCRPT=""""  I $E(SUBSCRPT,1)'=""z"" D"
^XMB(3.9,145837,2,421,0)="""RTN"",""XQALSET"",91,0)"
^XMB(3.9,145837,2,422,0)=" . . . S SUBSCRPN=$$FIND1^DIC(8992.2,"""",""X"",SUBSCRPT) I SUBSCRPN'>0 D"
^XMB(3.9,145837,2,423,0)="""RTN"",""XQALSET"",92,0)"
^XMB(3.9,145837,2,424,0)=" . . . . N FDA1,IENROOT S FDA1=$NA(^TMP($J,""XQALSET1"")) K @FDA1 S @FDA1@(8992.2,""+1,"",.01)=SUBSCRPT D UPDATE^DIE("""",FDA1,""IENROOT"") S SUBSCRPN=$G(IENROOT(1))"
^XMB(3.9,145837,2,425,0)="""RTN"",""XQALSET"",93,0)"
^XMB(3.9,145837,2,426,0)=" . . . . Q"
^XMB(3.9,145837,2,427,0)="""RTN"",""XQALSET"",94,0)"
^XMB(3.9,145837,2,428,0)=" . . . S NCOUNT=NCOUNT+1,@FDA@(8992.111,""+""_NCOUNT_IENVAL,.01)=SUBSCRPN,@FDA@(8992.111,""+""_NCOUNT_IENVAL,.04)=XQADATIM"
^XMB(3.9,145837,2,429,0)="""RTN"",""XQALSET"",95,0)"
^XMB(3.9,145837,2,430,0)=" . . . Q"
^XMB(3.9,145837,2,431,0)="""RTN"",""XQALSET"",96,0)"
^XMB(3.9,145837,2,432,0)=" . . I $D(XQALIST1(XQJ,""z TO_SURO"")) S @FDA@(8992.111,""+""_NCOUNT_IENVAL,.02)=$O(XQALIST1(XQJ,""z TO_SURO"",0))"
^XMB(3.9,145837,2,433,0)="""RTN"",""XQALSET"",97,0)"
^XMB(3.9,145837,2,434,0)=" . . I $D(XQALIST1(XQJ,""z AS_SURO"")) D"
^XMB(3.9,145837,2,435,0)="""RTN"",""XQALSET"",98,0)"
^XMB(3.9,145837,2,436,0)=" . . . S @FDA@(8992.111,""+""_NCOUNT_IENVAL,.03)=""Y"""
^XMB(3.9,145837,2,437,0)="""RTN"",""XQALSET"",99,0)"
^XMB(3.9,145837,2,438,0)=" . . . N XQK S NCOUNT=NCOUNT+1 F XQK=0:0 S XQK=$O(XQALIST1(XQJ,""z AS_SURO"",XQK)) Q:XQK'>0  S @FDA@(8992.113,""+""_NCOUNT_IENVAL,.01)=XQK,@FDA@(8992.113,""+""_NCOUNT_IENVAL,.02)=XQADATIM"
^XMB(3.9,145837,2,439,0)="""RTN"",""XQALSET"",100,0)"
^XMB(3.9,145837,2,440,0)=" . . . Q"
^XMB(3.9,145837,2,441,0)="""RTN"",""XQALSET"",101,0)"
^XMB(3.9,145837,2,442,0)=" . . S SUBSCRPT=$O(XQALIST1(XQJ,"""")) I SUBSCRPT'[""INITIAL"" S SUBSCRPT=$P(SUBSCRPT,""-"") D  ; FORWARDING"
^XMB(3.9,145837,2,443,0)="""RTN"",""XQALSET"",102,0)"
^XMB(3.9,145837,2,444,0)=" . . . S SUBSCRPN=$$FIND1^DIC(8992.2,"""",""X"",SUBSCRPT) I SUBSCRPN'>0 D"
^XMB(3.9,145837,2,445,0)="""RTN"",""XQALSET"",103,0)"
^XMB(3.9,145837,2,446,0)=" . . . . N FDA1,IENROOT S FDA1=$NA(^TMP($J,""XQALSET1"")) K @FDA1 S @FDA1@(8992.2,""+1,"",.01)=SUBSCRPT D UPDATE^DIE("""",FDA1,""IENROOT"") S SUBSCRPN=$G(IENROOT(1))"
