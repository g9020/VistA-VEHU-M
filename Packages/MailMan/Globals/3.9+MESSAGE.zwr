^XMB(3.9,145834,2,6481,0)="""RTN"",""MAGDSTAS"",130,0)"
^XMB(3.9,145834,2,6482,0)=" . . S X=^TMP(""MAG"",$J,""BATCH Q/R"",""NUMBER"",MOD100)"
^XMB(3.9,145834,2,6483,0)="""RTN"",""MAGDSTAS"",131,0)"
^XMB(3.9,145834,2,6484,0)=" . . F I=1:1:100 D"
^XMB(3.9,145834,2,6485,0)="""RTN"",""MAGDSTAS"",132,0)"
^XMB(3.9,145834,2,6486,0)=" . . . I $E(X,I)=""0"" D  ; ""0"""
