^XMB(3.9,144657,2,5129,0)="""RTN"",""IBCNEQU"",211,0)"
^XMB(3.9,144657,2,5130,0)=" S DIR(""A"")=""Select entry to request electronic inquiry"""
^XMB(3.9,144657,2,5131,0)="""RTN"",""IBCNEQU"",212,0)"
^XMB(3.9,144657,2,5132,0)=" S DIR(""?"",1)=""  Select an entry to initiate an insurance inquiry."""
