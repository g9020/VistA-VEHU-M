^XMB(3.9,144661,2,240,0)="0^1^B176971702"
^XMB(3.9,144661,2,241,0)="""RTN"",""ORAM1"",1,0)"
^XMB(3.9,144661,2,242,0)="ORAM1 ;POR/RSF - ANTICOAGULATION MANAGEMENT RPCS (2 of 4) ; 3/23/18 3:14pm"
^XMB(3.9,144661,2,243,0)="""RTN"",""ORAM1"",2,0)"
^XMB(3.9,144661,2,244,0)=" ;;3.0;ORDER ENTRY/RESULTS REPORTING;**307,339,351,361,391,474,463**;Dec 17, 1997;Build 0"
^XMB(3.9,144661,2,245,0)="""RTN"",""ORAM1"",3,0)"
^XMB(3.9,144661,2,246,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified"
^XMB(3.9,144661,2,247,0)="""RTN"",""ORAM1"",4,0)"
^XMB(3.9,144661,2,248,0)=" Q"
^XMB(3.9,144661,2,249,0)="""RTN"",""ORAM1"",5,0)"
^XMB(3.9,144661,2,250,0)=" ;"
^XMB(3.9,144661,2,251,0)="""RTN"",""ORAM1"",6,0)"
^XMB(3.9,144661,2,252,0)=" ;  External References:"
^XMB(3.9,144661,2,253,0)="""RTN"",""ORAM1"",7,0)"
^XMB(3.9,144661,2,254,0)=" ;  $$EXTERNAL^DILFD     ICR #2055"
^XMB(3.9,144661,2,255,0)="""RTN"",""ORAM1"",8,0)"
^XMB(3.9,144661,2,256,0)=" ;  $$FMTE/$$NOW^XLFDT   ICR #10103"
^XMB(3.9,144661,2,257,0)="""RTN"",""ORAM1"",9,0)"
^XMB(3.9,144661,2,258,0)=" ;  $$GET^XPAR           ICR #2263"
^XMB(3.9,144661,2,259,0)="""RTN"",""ORAM1"",10,0)"
^XMB(3.9,144661,2,260,0)=" ;"
^XMB(3.9,144661,2,261,0)="""RTN"",""ORAM1"",11,0)"
^XMB(3.9,144661,2,262,0)="TERASE(RESULT,ORAMDFN,ORAMCOMP) ; Manage Team Lists"
^XMB(3.9,144661,2,263,0)="""RTN"",""ORAM1"",12,0)"
^XMB(3.9,144661,2,264,0)=" N ORAMKEY,ORAMTMP,ORAMCEY,ORAMCLIN,ORAMCLNM,ORAMCOM,ORAMALL,ORAMCPLX,ORAMENT,QQ,DA,DIK,D0"
^XMB(3.9,144661,2,265,0)="""RTN"",""ORAM1"",13,0)"
^XMB(3.9,144661,2,266,0)=" Q:'+$G(ORAMDFN)"
^XMB(3.9,144661,2,267,0)="""RTN"",""ORAM1"",14,0)"
^XMB(3.9,144661,2,268,0)=" S ORAMCLIN=+$P($G(^ORAM(103,ORAMDFN,6)),U,2),ORAMENT=$S(+ORAMCLIN>0:ORAMCLIN_"";SC("",1:""ALL"")"
^XMB(3.9,144661,2,269,0)="""RTN"",""ORAM1"",15,0)"
^XMB(3.9,144661,2,270,0)=" I +ORAMCLIN S ORAMCLNM=$$EXTERNAL^DILFD(103,101,"""",ORAMCLIN)"
^XMB(3.9,144661,2,271,0)="""RTN"",""ORAM1"",16,0)"
^XMB(3.9,144661,2,272,0)=" S ORAMALL=$$GET^XPAR(ORAMENT,""ORAM TEAM LIST (ALL)"",1,""I""),ORAMCPLX=$$GET^XPAR(ORAMENT,""ORAM TEAM LIST (COMPLEX)"",1,""I"")"
^XMB(3.9,144661,2,273,0)="""RTN"",""ORAM1"",17,0)"
^XMB(3.9,144661,2,274,0)=" I +$G(ORAMALL) D  I 1"
^XMB(3.9,144661,2,275,0)="""RTN"",""ORAM1"",18,0)"
^XMB(3.9,144661,2,276,0)=" . S DA(1)=ORAMALL,DIK=""^OR(100.21""_"",""_DA(1)_"",10,"""
^XMB(3.9,144661,2,277,0)="""RTN"",""ORAM1"",19,0)"
^XMB(3.9,144661,2,278,0)=" . S ORAMTMP=ORAMDFN_"";DPT("""
^XMB(3.9,144661,2,279,0)="""RTN"",""ORAM1"",20,0)"
^XMB(3.9,144661,2,280,0)=" . S ORAMKEY=$O(^OR(100.21,ORAMALL,10,""B"",ORAMTMP,0)) Q:+ORAMKEY'>0  S DA=ORAMKEY"
^XMB(3.9,144661,2,281,0)="""RTN"",""ORAM1"",21,0)"
^XMB(3.9,144661,2,282,0)=" . D ^DIK"
^XMB(3.9,144661,2,283,0)="""RTN"",""ORAM1"",22,0)"
^XMB(3.9,144661,2,284,0)=" . K DA,DIK"
^XMB(3.9,144661,2,285,0)="""RTN"",""ORAM1"",23,0)"
^XMB(3.9,144661,2,286,0)=" . K D0"
^XMB(3.9,144661,2,287,0)="""RTN"",""ORAM1"",24,0)"
^XMB(3.9,144661,2,288,0)=" . S RESULT=1"
^XMB(3.9,144661,2,289,0)="""RTN"",""ORAM1"",25,0)"
^XMB(3.9,144661,2,290,0)=" E  S RESULT=""0^ORAM TEAM LIST (ALL) not defined for Clinic ""_ORAMCLNM_""."""
^XMB(3.9,144661,2,291,0)="""RTN"",""ORAM1"",26,0)"
^XMB(3.9,144661,2,292,0)=" I +$G(ORAMCPLX) D  I 1"
^XMB(3.9,144661,2,293,0)="""RTN"",""ORAM1"",27,0)"
^XMB(3.9,144661,2,294,0)=" . S DA(1)=ORAMCPLX,DIK=""^OR(100.21""_"",""_DA(1)_"",10,"""
^XMB(3.9,144661,2,295,0)="""RTN"",""ORAM1"",28,0)"
^XMB(3.9,144661,2,296,0)=" . S ORAMCEY=$O(^OR(100.21,ORAMCPLX,10,""B"",ORAMTMP,0)) Q:+ORAMCEY'>0  S DA=ORAMCEY"
^XMB(3.9,144661,2,297,0)="""RTN"",""ORAM1"",29,0)"
^XMB(3.9,144661,2,298,0)=" . D ^DIK"
^XMB(3.9,144661,2,299,0)="""RTN"",""ORAM1"",30,0)"
^XMB(3.9,144661,2,300,0)=" . K DA,DIK"
^XMB(3.9,144661,2,301,0)="""RTN"",""ORAM1"",31,0)"
^XMB(3.9,144661,2,302,0)=" . S:'$D(RESULT) RESULT=1"
^XMB(3.9,144661,2,303,0)="""RTN"",""ORAM1"",32,0)"
^XMB(3.9,144661,2,304,0)=" E  S RESULT=""0^ORAM TEAM LIST (COMPLEX) not defined for Clinic ""_ORAMCLNM_""."""
^XMB(3.9,144661,2,305,0)="""RTN"",""ORAM1"",33,0)"
^XMB(3.9,144661,2,306,0)=" Q"
^XMB(3.9,144661,2,307,0)="""RTN"",""ORAM1"",34,0)"
^XMB(3.9,144661,2,308,0)=" ;"
^XMB(3.9,144661,2,309,0)="""RTN"",""ORAM1"",35,0)"
^XMB(3.9,144661,2,310,0)=" ;ICDCODE(RESULT,ICODE); Map ICD Code //REMOVED BECAUSE OF DIRECT READ OF ^ICD9( FILE"
