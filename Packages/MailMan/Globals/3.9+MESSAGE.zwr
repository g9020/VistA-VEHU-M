^XMB(3.9,145839,2,299,0)="""RTN"",""TIUCCHL7UT"",26,0)"
^XMB(3.9,145839,2,300,0)=" N PATNAME,EID,EIDS,MSGN,SITE,CONPAT,CS,FS,RS,ES,SS,RES,ICN  ;Jan 21,2020 - PB - patch 735 new and then set FS,CS,RS,ES,SS"
^XMB(3.9,145839,2,301,0)="""RTN"",""TIUCCHL7UT"",27,0)"
^XMB(3.9,145839,2,302,0)=" ;D INIT^HLFNC2(""TIU CCRA-HSRM MDM-T02 SERVER"",.HL)"
^XMB(3.9,145839,2,303,0)="""RTN"",""TIUCCHL7UT"",28,0)"
^XMB(3.9,145839,2,304,0)=" S HL(""FS"")=""|"",HL(""ECH"")=""^~\&"""
^XMB(3.9,145839,2,305,0)="""RTN"",""TIUCCHL7UT"",29,0)"
