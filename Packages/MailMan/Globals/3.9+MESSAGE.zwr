^XMB(3.9,144657,2,603,0)="""RTN"",""IBCNBAA"",5,0)"
^XMB(3.9,144657,2,604,0)=" ;"
^XMB(3.9,144657,2,605,0)="""RTN"",""IBCNBAA"",6,0)"
^XMB(3.9,144657,2,606,0)=" ;/vd-IB*2*668 - Removed the SSVI logic introduced with IB*2*528 in its entirety within VistA."
^XMB(3.9,144657,2,607,0)="""RTN"",""IBCNBAA"",7,0)"
^XMB(3.9,144657,2,608,0)="ACCEPT(IBBUFDA,IBINSDA,IBGRPDA,IBPOLDA) ; process a buffer entry for acceptance then save in Insurance files"
^XMB(3.9,144657,2,609,0)="""RTN"",""IBCNBAA"",8,0)"
^XMB(3.9,144657,2,610,0)=" ;    1) for Insurance Company, Group/Plan and Policy sets of data:"
^XMB(3.9,144657,2,611,0)="""RTN"",""IBCNBAA"",9,0)"
^XMB(3.9,144657,2,612,0)=" ;        a) display the set of buffer data and corresponding existing selected ins data"
^XMB(3.9,144657,2,613,0)="""RTN"",""IBCNBAA"",10,0)"
^XMB(3.9,144657,2,614,0)=" ;        b) if ins record exists confirm with user that it is the correct one to use"
^XMB(3.9,144657,2,615,0)="""RTN"",""IBCNBAA"",11,0)"
^XMB(3.9,144657,2,616,0)=" ;        c) if ins record exists user selects method of saving to ins record: Merge/Overwrite/Replace/No Change/Individually Accept(skip blanks)"
^XMB(3.9,144657,2,617,0)="""RTN"",""IBCNBAA"",12,0)"
^XMB(3.9,144657,2,618,0)=" ;        d) if new record needs to be created get user confirmation"
^XMB(3.9,144657,2,619,0)="""RTN"",""IBCNBAA"",13,0)"
^XMB(3.9,144657,2,620,0)=" ;    2) display the actions that will be taken"
^XMB(3.9,144657,2,621,0)="""RTN"",""IBCNBAA"",14,0)"
^XMB(3.9,144657,2,622,0)=" ;    3) user confirms that is correct"
^XMB(3.9,144657,2,623,0)="""RTN"",""IBCNBAA"",15,0)"
^XMB(3.9,144657,2,624,0)=" ;    4) data moved into insurance files, new records created if needed or edit existing ones"
^XMB(3.9,144657,2,625,0)="""RTN"",""IBCNBAA"",16,0)"
^XMB(3.9,144657,2,626,0)=" ;    5) complete some general functions that are executed whenever insurance is entered/edited"
^XMB(3.9,144657,2,627,0)="""RTN"",""IBCNBAA"",17,0)"
^XMB(3.9,144657,2,628,0)=" ;    6) allow user to view buffer entry and new/updated insurance records"
^XMB(3.9,144657,2,629,0)="""RTN"",""IBCNBAA"",18,0)"
^XMB(3.9,144657,2,630,0)=" ;    7) buffer ins/group/policy data deleted"
^XMB(3.9,144657,2,631,0)="""RTN"",""IBCNBAA"",19,0)"
^XMB(3.9,144657,2,632,0)=" ;    8) buffer entry status updated"
^XMB(3.9,144657,2,633,0)="""RTN"",""IBCNBAA"",20,0)"
^XMB(3.9,144657,2,634,0)=" ;"
^XMB(3.9,144657,2,635,0)="""RTN"",""IBCNBAA"",21,0)"
^XMB(3.9,144657,2,636,0)=" N DFN,IBX,IBELIG,IBHELP,IBNEWINS,IBNEWGRP,IBNEWPOL,IBNEWSUB,IBMVINS,IBMVGRP,IBMVPOL,IBMVSUB,IBACCPT,IBVAL"
^XMB(3.9,144657,2,637,0)="""RTN"",""IBCNBAA"",22,0)"
^XMB(3.9,144657,2,638,0)=" N DIR,X,Y,DIRUT,IBDONE,IBQ,IBYR,IBDA,IBEAB,IBXREF,IBO,IBISEL,IBERR,IBOUT,IBASAV,IBCSAV,IBIEN,IBRIEN,IBSIEN,IBFNAM,IBHOLD,IBXHOLD,IBSEL,IBSOURCE,IBIIU"
^XMB(3.9,144657,2,639,0)="""RTN"",""IBCNBAA"",23,0)"
^XMB(3.9,144657,2,640,0)=" N DIERR"
^XMB(3.9,144657,2,641,0)="""RTN"",""IBCNBAA"",24,0)"
^XMB(3.9,144657,2,642,0)=" S (IBDONE,IBIEN)=0"
^XMB(3.9,144657,2,643,0)="""RTN"",""IBCNBAA"",25,0)"
^XMB(3.9,144657,2,644,0)=" K ^TMP($J,""IB BUFFER SELECTED"")  ; initialize selection file"
^XMB(3.9,144657,2,645,0)="""RTN"",""IBCNBAA"",26,0)"
^XMB(3.9,144657,2,646,0)=" S IBINSDA=+$G(IBINSDA),IBGRPDA=+$G(IBGRPDA),IBPOLDA=+$G(IBPOLDA),(IBNEWINS,IBNEWGRP,IBNEWPOL,IBNEWSUB,IBMVINS,IBMVGRP,IBMVPOL,IBMVSUB,IBOUT,IBASAV,IBCSAV)=0"
^XMB(3.9,144657,2,647,0)="""RTN"",""IBCNBAA"",27,0)"
^XMB(3.9,144657,2,648,0)=" S DFN=+$G(^IBA(355.33,+$G(IBBUFDA),60)) I 'DFN G ACCPTQ"
^XMB(3.9,144657,2,649,0)="""RTN"",""IBCNBAA"",28,0)"
^XMB(3.9,144657,2,650,0)=" I +IBINSDA,+IBGRPDA,'IBPOLDA S IBPOLDA=$$PTGRP^IBCNBU1(DFN,IBINSDA,IBGRPDA) ; patient already member of plan"
^XMB(3.9,144657,2,651,0)="""RTN"",""IBCNBAA"",29,0)"
^XMB(3.9,144657,2,652,0)=" ;"
^XMB(3.9,144657,2,653,0)="""RTN"",""IBCNBAA"",30,0)"
^XMB(3.9,144657,2,654,0)=" I $P($G(^IBA(355.33,$G(IBBUFDA),0)),U,4)'=""E"" G ACCPTQ"
^XMB(3.9,144657,2,655,0)="""RTN"",""IBCNBAA"",31,0)"
^XMB(3.9,144657,2,656,0)=" I +IBINSDA,$G(^DIC(36,IBINSDA,0))="""" G ACCPTQ"
^XMB(3.9,144657,2,657,0)="""RTN"",""IBCNBAA"",32,0)"
^XMB(3.9,144657,2,658,0)=" I +IBGRPDA,+$G(^IBA(355.3,IBGRPDA,0))'=IBINSDA G ACCPTQ"
^XMB(3.9,144657,2,659,0)="""RTN"",""IBCNBAA"",33,0)"
^XMB(3.9,144657,2,660,0)=" I +IBGRPDA S IBX=$G(^IBA(355.3,IBGRPDA,0)) I $P(IBX,U,2)=0,+$P(IBX,U,10),$P(IBX,U,10)'=DFN G ACCPTQ"
^XMB(3.9,144657,2,661,0)="""RTN"",""IBCNBAA"",34,0)"
^XMB(3.9,144657,2,662,0)=" I +IBPOLDA,+$G(^DPT(DFN,.312,IBPOLDA,0))'=IBINSDA G ACCPTQ"
^XMB(3.9,144657,2,663,0)="""RTN"",""IBCNBAA"",35,0)"
^XMB(3.9,144657,2,664,0)=" I +IBPOLDA,$P($G(^DPT(DFN,.312,IBPOLDA,0)),U,18)'=IBGRPDA G ACCPTQ"
^XMB(3.9,144657,2,665,0)="""RTN"",""IBCNBAA"",36,0)"
^XMB(3.9,144657,2,666,0)=" ;"
^XMB(3.9,144657,2,667,0)="""RTN"",""IBCNBAA"",37,0)"
^XMB(3.9,144657,2,668,0)="ACINS ;"
^XMB(3.9,144657,2,669,0)="""RTN"",""IBCNBAA"",38,0)"
^XMB(3.9,144657,2,670,0)=" W @IOF S IBHELP="",INS^IBCNBCD(""_IBBUFDA_"",""_IBINSDA_"")"""
^XMB(3.9,144657,2,671,0)="""RTN"",""IBCNBAA"",39,0)"
^XMB(3.9,144657,2,672,0)=" D INS^IBCNBCD(IBBUFDA,IBINSDA)"
^XMB(3.9,144657,2,673,0)="""RTN"",""IBCNBAA"",40,0)"
^XMB(3.9,144657,2,674,0)=" I +IBINSDA S IBACCPT=$$MATCH(""INSURANCE COMPANY"") S:'IBACCPT (IBINSDA,IBGRPDA,IBPOLDA)=0 I $D(DIRUT) G ACCPTQ"
^XMB(3.9,144657,2,675,0)="""RTN"",""IBCNBAA"",41,0)"
^XMB(3.9,144657,2,676,0)=" I +IBINSDA D  I $D(DIRUT)!(IBMVINS="""") G ACCPTQ"
^XMB(3.9,144657,2,677,0)="""RTN"",""IBCNBAA"",42,0)"
^XMB(3.9,144657,2,678,0)=" . I '$D(^XUSEC(""IB INSURANCE COMPANY EDIT"",DUZ)) S IBMVINS=0 Q"
^XMB(3.9,144657,2,679,0)="""RTN"",""IBCNBAA"",43,0)"
^XMB(3.9,144657,2,680,0)=" . S IBMVINS=$$MOVE(""INSURANCE COMPANY"",IBHELP)"
^XMB(3.9,144657,2,681,0)="""RTN"",""IBCNBAA"",44,0)"
^XMB(3.9,144657,2,682,0)=" I 'IBINSDA S IBNEWINS=$$NEW(""INSURANCE COMPANY""),IBMVINS=3,(IBGRPDA,IBPOLDA)=0 I 'IBNEWINS G ACCPTQ"
^XMB(3.9,144657,2,683,0)="""RTN"",""IBCNBAA"",45,0)"
^XMB(3.9,144657,2,684,0)=" ;"
^XMB(3.9,144657,2,685,0)="""RTN"",""IBCNBAA"",46,0)"
^XMB(3.9,144657,2,686,0)=" I +IBMVINS=4 D INS^IBCNBAC(IBBUFDA,IBINSDA,1) ; Ind. Accept-Skip Blanks"
^XMB(3.9,144657,2,687,0)="""RTN"",""IBCNBAA"",47,0)"
^XMB(3.9,144657,2,688,0)=" ;"
^XMB(3.9,144657,2,689,0)="""RTN"",""IBCNBAA"",48,0)"
^XMB(3.9,144657,2,690,0)="ACGRP ;"
^XMB(3.9,144657,2,691,0)="""RTN"",""IBCNBAA"",49,0)"
^XMB(3.9,144657,2,692,0)=" W @IOF S IBHELP="",GRP^IBCNBCD(""_IBBUFDA_"",""_IBGRPDA_"")"""
^XMB(3.9,144657,2,693,0)="""RTN"",""IBCNBAA"",50,0)"
^XMB(3.9,144657,2,694,0)=" I +IBGRPDA W !,?14,""Patient is ""_$S(+IBPOLDA:"""",1:""NOT "")_""a member of this Insurance Group/Plan"",!"
^XMB(3.9,144657,2,695,0)="""RTN"",""IBCNBAA"",51,0)"
^XMB(3.9,144657,2,696,0)=" D GRP^IBCNBCD(IBBUFDA,IBGRPDA)"
^XMB(3.9,144657,2,697,0)="""RTN"",""IBCNBAA"",52,0)"
^XMB(3.9,144657,2,698,0)=" ;"
^XMB(3.9,144657,2,699,0)="""RTN"",""IBCNBAA"",53,0)"
^XMB(3.9,144657,2,700,0)=" I +IBGRPDA S IBACCPT=$$MATCH(""GROUP/PLAN"") S:'IBACCPT (IBGRPDA,IBPOLDA)=0 I $D(DIRUT) G ACCPTQ"
^XMB(3.9,144657,2,701,0)="""RTN"",""IBCNBAA"",54,0)"
^XMB(3.9,144657,2,702,0)=" I +IBGRPDA D  I $D(DIRUT)!(IBMVGRP="""") G ACCPTQ"
^XMB(3.9,144657,2,703,0)="""RTN"",""IBCNBAA"",55,0)"
^XMB(3.9,144657,2,704,0)=" . I '$D(^XUSEC(""IB GROUP PLAN EDIT"",DUZ)) S IBMVGRP=0 Q"
^XMB(3.9,144657,2,705,0)="""RTN"",""IBCNBAA"",56,0)"
^XMB(3.9,144657,2,706,0)=" . S IBMVGRP=$$MOVE(""GROUP/PLAN"",IBHELP)"
^XMB(3.9,144657,2,707,0)="""RTN"",""IBCNBAA"",57,0)"
^XMB(3.9,144657,2,708,0)=" I 'IBGRPDA S IBNEWGRP=$$NEW(""GROUP/PLAN""),IBMVGRP=3,IBPOLDA=0 I 'IBNEWGRP G ACCPTQ"
^XMB(3.9,144657,2,709,0)="""RTN"",""IBCNBAA"",58,0)"
^XMB(3.9,144657,2,710,0)=" ;"
^XMB(3.9,144657,2,711,0)="""RTN"",""IBCNBAA"",59,0)"
^XMB(3.9,144657,2,712,0)=" I +IBMVGRP=4 D GRP^IBCNBAC(IBBUFDA,IBGRPDA,1) ; Ind. Accept-Skip Blanks"
^XMB(3.9,144657,2,713,0)="""RTN"",""IBCNBAA"",60,0)"
^XMB(3.9,144657,2,714,0)=" ;"
^XMB(3.9,144657,2,715,0)="""RTN"",""IBCNBAA"",61,0)"
^XMB(3.9,144657,2,716,0)="ACANB ; -- Annual Benefits /awc"
^XMB(3.9,144657,2,717,0)="""RTN"",""IBCNBAA"",62,0)"
^XMB(3.9,144657,2,718,0)=" I +IBGRPDA D ANNBEN^IBCNBCD1(IBBUFDA,IBGRPDA,.IBASAV,.IBQ,.IBERR) I IBQ=U!($D(IBERR))!($D(DTOUT)) G ACCPTQ"
^XMB(3.9,144657,2,719,0)="""RTN"",""IBCNBAA"",63,0)"
^XMB(3.9,144657,2,720,0)=" ;"
^XMB(3.9,144657,2,721,0)="""RTN"",""IBCNBAA"",64,0)"
^XMB(3.9,144657,2,722,0)="ACCOV ; -- Coverage Limitations /awc"
^XMB(3.9,144657,2,723,0)="""RTN"",""IBCNBAA"",65,0)"
^XMB(3.9,144657,2,724,0)=" I +IBGRPDA D COVLIM^IBCNBCD2(IBBUFDA,IBGRPDA,.IBCSAV,.IBQ,.IBERR) I IBQ=U!($D(IBERR))!($D(DTOUT)) G ACCPTQ"
^XMB(3.9,144657,2,725,0)="""RTN"",""IBCNBAA"",66,0)"
^XMB(3.9,144657,2,726,0)=" ;"
^XMB(3.9,144657,2,727,0)="""RTN"",""IBCNBAA"",67,0)"
^XMB(3.9,144657,2,728,0)="ACPOL ;"
^XMB(3.9,144657,2,729,0)="""RTN"",""IBCNBAA"",68,0)"
^XMB(3.9,144657,2,730,0)=" W @IOF S IBHELP="",POLICY^IBCNBCD(""_IBBUFDA_"",""_IBPOLDA_"")"""
^XMB(3.9,144657,2,731,0)="""RTN"",""IBCNBAA"",69,0)"
^XMB(3.9,144657,2,732,0)=" I 'IBPOLDA W !,""This will be a New policy for this group and patient."",!"
^XMB(3.9,144657,2,733,0)="""RTN"",""IBCNBAA"",70,0)"
^XMB(3.9,144657,2,734,0)=" D POLICY^IBCNBCD(IBBUFDA,IBPOLDA)"
^XMB(3.9,144657,2,735,0)="""RTN"",""IBCNBAA"",71,0)"
^XMB(3.9,144657,2,736,0)=" I +IBPOLDA S IBACCPT=$$MATCH(""PATIENT POLICY"") S:'IBACCPT IBPOLDA=0 I $D(DIRUT) G ACCPTQ"
^XMB(3.9,144657,2,737,0)="""RTN"",""IBCNBAA"",72,0)"
^XMB(3.9,144657,2,738,0)=" I +IBPOLDA S IBMVPOL=$$MOVE(""PATIENT POLICY"",IBHELP) I $D(DIRUT)!(IBMVPOL="""") G ACCPTQ"
^XMB(3.9,144657,2,739,0)="""RTN"",""IBCNBAA"",73,0)"
^XMB(3.9,144657,2,740,0)=" I 'IBPOLDA S IBNEWPOL=$$NEW(""PATIENT POLICY""),IBMVPOL=3 I 'IBNEWPOL G ACCPTQ"
^XMB(3.9,144657,2,741,0)="""RTN"",""IBCNBAA"",74,0)"
^XMB(3.9,144657,2,742,0)=" ;"
^XMB(3.9,144657,2,743,0)="""RTN"",""IBCNBAA"",75,0)"
^XMB(3.9,144657,2,744,0)=" I +IBMVPOL=4 D POLICY^IBCNBAC(IBBUFDA,IBPOLDA,1) ; Ind. Accept-Skip Blanks"
^XMB(3.9,144657,2,745,0)="""RTN"",""IBCNBAA"",76,0)"
^XMB(3.9,144657,2,746,0)=" ;"
^XMB(3.9,144657,2,747,0)="""RTN"",""IBCNBAA"",77,0)"
^XMB(3.9,144657,2,748,0)="ACSUB ; -- Subscriber screens"
^XMB(3.9,144657,2,749,0)="""RTN"",""IBCNBAA"",78,0)"
^XMB(3.9,144657,2,750,0)=" W @IOF"
^XMB(3.9,144657,2,751,0)="""RTN"",""IBCNBAA"",79,0)"
^XMB(3.9,144657,2,752,0)=" S IBMVSUB=""0^NO CHANGE"",(IBFNAM,IBVAL,IBHOLD,IBXHOLD)="""",IBRIEN=0"
^XMB(3.9,144657,2,753,0)="""RTN"",""IBCNBAA"",80,0)"
^XMB(3.9,144657,2,754,0)=" S IBSIEN=$S(+IBPOLDA:IBPOLDA_"",""_DFN_"","",1:0)"
^XMB(3.9,144657,2,755,0)="""RTN"",""IBCNBAA"",81,0)"
^XMB(3.9,144657,2,756,0)=" ;"
^XMB(3.9,144657,2,757,0)="""RTN"",""IBCNBAA"",82,0)"
^XMB(3.9,144657,2,758,0)=" S IBSEL=+$$SUASK(.IBVAL) I $D(DUOUT)!($D(DTOUT)) G ACCPTQ"
^XMB(3.9,144657,2,759,0)="""RTN"",""IBCNBAA"",83,0)"
^XMB(3.9,144657,2,760,0)=" ;"
^XMB(3.9,144657,2,761,0)="""RTN"",""IBCNBAA"",84,0)"
^XMB(3.9,144657,2,762,0)=" I IBSEL'=1&(IBSEL'=18) W !,!,""*** Warning - Please Complete Subscriber Update Fields Manually via the Patient Insurance File."" D WAIT G ACEB"
^XMB(3.9,144657,2,763,0)="""RTN"",""IBCNBAA"",85,0)"
^XMB(3.9,144657,2,764,0)=" E  D  I IBOUT!($D(DTOUT)) G ACCPTQ"
^XMB(3.9,144657,2,765,0)="""RTN"",""IBCNBAA"",86,0)"
^XMB(3.9,144657,2,766,0)=" . ;"
^XMB(3.9,144657,2,767,0)="""RTN"",""IBCNBAA"",87,0)"
^XMB(3.9,144657,2,768,0)=" . I 'IBPOLDA S IBMVSUB=3 W !,""A NEW Subscriber Insurance policy must be created for this group/patient before Subscriber updates."",! D WAIT Q"
^XMB(3.9,144657,2,769,0)="""RTN"",""IBCNBAA"",88,0)"
^XMB(3.9,144657,2,770,0)=" . ;"
^XMB(3.9,144657,2,771,0)="""RTN"",""IBCNBAA"",89,0)"
^XMB(3.9,144657,2,772,0)=" . ; -- display subscriber screens"
^XMB(3.9,144657,2,773,0)="""RTN"",""IBCNBAA"",90,0)"
^XMB(3.9,144657,2,774,0)=" . D SBDISP^IBCNBCD4(IBBUFDA,DFN,IBPOLDA,IBSEL,IBRIEN,IBSIEN,.IBFNAM,IBVAL,.IBHOLD,.IBXHOLD) I $D(DIERR) S IBOUT=1 Q"
^XMB(3.9,144657,2,775,0)="""RTN"",""IBCNBAA"",91,0)"
^XMB(3.9,144657,2,776,0)=" . ;"
^XMB(3.9,144657,2,777,0)="""RTN"",""IBCNBAA"",92,0)"
^XMB(3.9,144657,2,778,0)=" . ; -- display M/O/R/N/I screens"
^XMB(3.9,144657,2,779,0)="""RTN"",""IBCNBAA"",93,0)"
^XMB(3.9,144657,2,780,0)=" . I +IBPOLDA S IBACCPT=$$SBMATCH(""SUBSCRIBER INSURANCE"") S:'IBACCPT IBPOLDA=0 I $D(DIRUT) S IBOUT=1 Q"
^XMB(3.9,144657,2,781,0)="""RTN"",""IBCNBAA"",94,0)"
^XMB(3.9,144657,2,782,0)=" . I +IBPOLDA S IBMVSUB=$$SBMOVE(""SUBSCRIBER INSURANCE"") I $D(DIRUT)!(IBMVSUB="""") S IBOUT=1 Q"
^XMB(3.9,144657,2,783,0)="""RTN"",""IBCNBAA"",95,0)"
^XMB(3.9,144657,2,784,0)=" . ;"
^XMB(3.9,144657,2,785,0)="""RTN"",""IBCNBAA"",96,0)"
^XMB(3.9,144657,2,786,0)=" . I +IBMVSUB=4 D SUB^IBCNBAC(1,IBFNAM,.IBHOLD,.IBXHOLD) ; Ind. Accept-Skip Blanks"
^XMB(3.9,144657,2,787,0)="""RTN"",""IBCNBAA"",97,0)"
^XMB(3.9,144657,2,788,0)=" ;"
^XMB(3.9,144657,2,789,0)="""RTN"",""IBCNBAA"",98,0)"
^XMB(3.9,144657,2,790,0)="ACEB ;"
^XMB(3.9,144657,2,791,0)="""RTN"",""IBCNBAA"",99,0)"
^XMB(3.9,144657,2,792,0)=" W @IOF"
^XMB(3.9,144657,2,793,0)="""RTN"",""IBCNBAA"",100,0)"
^XMB(3.9,144657,2,794,0)=" D ELIG^IBCNBCD(IBBUFDA,IBPOLDA) S IBELIG=$$REPL() I $D(DIRUT) G ACCPTQ"
^XMB(3.9,144657,2,795,0)="""RTN"",""IBCNBAA"",101,0)"
^XMB(3.9,144657,2,796,0)=" ;"
^XMB(3.9,144657,2,797,0)="""RTN"",""IBCNBAA"",102,0)"
^XMB(3.9,144657,2,798,0)="CHECK ; display changes that will be made and ask user for confirmation"
^XMB(3.9,144657,2,799,0)="""RTN"",""IBCNBAA"",103,0)"
^XMB(3.9,144657,2,800,0)=" W @IOF"
^XMB(3.9,144657,2,801,0)="""RTN"",""IBCNBAA"",104,0)"
^XMB(3.9,144657,2,802,0)=" ;"
^XMB(3.9,144657,2,803,0)="""RTN"",""IBCNBAA"",105,0)"
^XMB(3.9,144657,2,804,0)=" I +IBINSDA S IBX=""The Buffer data will ""_$P(IBMVINS,U,2)_"" the existing Insurance Company data."""
^XMB(3.9,144657,2,805,0)="""RTN"",""IBCNBAA"",106,0)"
