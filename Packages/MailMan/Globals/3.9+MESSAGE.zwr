^XMB(3.9,144657,2,9890,0)=" ;S ELINE=$$SET("""",$J("""",40),ELINE,1)  ; Spacing Blank Line"
^XMB(3.9,144657,2,9891,0)="""RTN"",""IBJPI"",214,0)"
^XMB(3.9,144657,2,9892,0)=" ;S ELINE=$$SET("" Extract               Start Days   Days After           Maximum # to"","""",ELINE,1)"
^XMB(3.9,144657,2,9893,0)="""RTN"",""IBJPI"",215,0)"
^XMB(3.9,144657,2,9894,0)=" ;S ELINE=$$SETN(""Name         On/Off   From Today   Start        Freq.   Extract/Day"",ELINE,1,"""",1)"
^XMB(3.9,144657,2,9895,0)="""RTN"",""IBJPI"",216,0)"
^XMB(3.9,144657,2,9896,0)=" ;I $$GET1^DIQ(350.9002,""4,1,"",.01)=""EICD"" D "
^XMB(3.9,144657,2,9897,0)="""RTN"",""IBJPI"",217,0)"
^XMB(3.9,144657,2,9898,0)=" ;. S IBEX=$$SETTINGS^IBCNEDE7(4) ; collect EICD parameters "
^XMB(3.9,144657,2,9899,0)="""RTN"",""IBJPI"",218,0)"
^XMB(3.9,144657,2,9900,0)=" ;. S IBST=$$FO^IBCNEUT1(""EICD"",14)"
^XMB(3.9,144657,2,9901,0)="""RTN"",""IBJPI"",219,0)"
^XMB(3.9,144657,2,9902,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1($S(+IBEX:""ON"",1:""OFF""),9)"
^XMB(3.9,144657,2,9903,0)="""RTN"",""IBJPI"",220,0)"
^XMB(3.9,144657,2,9904,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1(+$P(IBEX,""^"",6),13) ; Start Days"
^XMB(3.9,144657,2,9905,0)="""RTN"",""IBJPI"",221,0)"
^XMB(3.9,144657,2,9906,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1(+$P(IBEX,""^"",7),13) ; Days After "
^XMB(3.9,144657,2,9907,0)="""RTN"",""IBJPI"",222,0)"
^XMB(3.9,144657,2,9908,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1(+$P(IBEX,""^"",8),8) ; Frequency"
^XMB(3.9,144657,2,9909,0)="""RTN"",""IBJPI"",223,0)"
^XMB(3.9,144657,2,9910,0)=" ;. S IBST=IBST_$$FO^IBCNEUT1(+$P(IBEX,""^"",4),8) ; Max extract"
^XMB(3.9,144657,2,9911,0)="""RTN"",""IBJPI"",224,0)"
^XMB(3.9,144657,2,9912,0)=" ;. S ELINE=$$SET(IBST,"""",ELINE,1)"
^XMB(3.9,144657,2,9913,0)="""RTN"",""IBJPI"",225,0)"
^XMB(3.9,144657,2,9914,0)=" ;"
^XMB(3.9,144657,2,9915,0)="""RTN"",""IBJPI"",226,0)"
^XMB(3.9,144657,2,9916,0)=" ;/vd-IB*2*687 - Beginning of new/restructured code."
^XMB(3.9,144657,2,9917,0)="""RTN"",""IBJPI"",227,0)"
^XMB(3.9,144657,2,9918,0)=" N APPTBE,BENAME,FRESHDAY"
^XMB(3.9,144657,2,9919,0)="""RTN"",""IBJPI"",228,0)"
^XMB(3.9,144657,2,9920,0)=" S FRESHDAY=$$GET1^DIQ(350.9,""1,"",51.01)  ; FRESHNESS DAYS - used by Buffer/Appt as ""Frequency"""
^XMB(3.9,144657,2,9921,0)="""RTN"",""IBJPI"",229,0)"
^XMB(3.9,144657,2,9922,0)=" S ELINE=$$SET("" Extract               Start Days   Days After           Maximum # to"","""",ELINE,1)"
^XMB(3.9,144657,2,9923,0)="""RTN"",""IBJPI"",230,0)"
^XMB(3.9,144657,2,9924,0)=" S ELINE=$$SETN(""Name         On/Off   From Today   Start        Freq.   Extract/Day"",ELINE,1,"""",1)"
^XMB(3.9,144657,2,9925,0)="""RTN"",""IBJPI"",231,0)"
^XMB(3.9,144657,2,9926,0)=" ;"
^XMB(3.9,144657,2,9927,0)="""RTN"",""IBJPI"",232,0)"
^XMB(3.9,144657,2,9928,0)=" ; Loop thru Batch Extracts."
^XMB(3.9,144657,2,9929,0)="""RTN"",""IBJPI"",233,0)"
^XMB(3.9,144657,2,9930,0)=" S IEN=0"
^XMB(3.9,144657,2,9931,0)="""RTN"",""IBJPI"",234,0)"
^XMB(3.9,144657,2,9932,0)=" F  S IEN=$O(^IBE(350.9,1,51.17,IEN)) Q:'IEN  D"
^XMB(3.9,144657,2,9933,0)="""RTN"",""IBJPI"",235,0)"
^XMB(3.9,144657,2,9934,0)=" . S IBEX=+$P($G(^IBE(350.9,1,51.17,IEN,0)),U)    ; Type"
^XMB(3.9,144657,2,9935,0)="""RTN"",""IBJPI"",236,0)"
^XMB(3.9,144657,2,9936,0)=" . I ""^1^2^4^""'[(U_IBEX_U) Q          ; Only want Buffer, Appt and EICD Batch Extracts."
^XMB(3.9,144657,2,9937,0)="""RTN"",""IBJPI"",237,0)"
^XMB(3.9,144657,2,9938,0)=" . S IBEIVB=$$SETTINGS^IBCNEDE7(IBEX) ; collect specific extract's site parameter settings"
^XMB(3.9,144657,2,9939,0)="""RTN"",""IBJPI"",238,0)"
^XMB(3.9,144657,2,9940,0)=" . S BENAME=$S($P(IBEIVB,U,1)'="""":$$GET1^DIQ(350.9002,IEN_"",1,"",.01,""E""),1:"""")"
^XMB(3.9,144657,2,9941,0)="""RTN"",""IBJPI"",239,0)"
^XMB(3.9,144657,2,9942,0)=" . I BENAME=""Appt"" S APPTBE=1,BENAME=BENAME_"" *""   ; If this is the APPT extract, need to add footnote."
^XMB(3.9,144657,2,9943,0)="""RTN"",""IBJPI"",240,0)"
^XMB(3.9,144657,2,9944,0)=" . S IBST=$$FO^IBCNEUT1(BENAME,14)    ; Extract Name "
^XMB(3.9,144657,2,9945,0)="""RTN"",""IBJPI"",241,0)"
^XMB(3.9,144657,2,9946,0)=" . S IBST=IBST_$$FO^IBCNEUT1($S(+$P(IBEIVB,""^"",1):""ON"",1:""OFF""),9)"
^XMB(3.9,144657,2,9947,0)="""RTN"",""IBJPI"",242,0)"
^XMB(3.9,144657,2,9948,0)=" . S IBEX1=$P(IBEIVB,U,6)"
^XMB(3.9,144657,2,9949,0)="""RTN"",""IBJPI"",243,0)"
^XMB(3.9,144657,2,9950,0)=" . S IBST=IBST_$$FO^IBCNEUT1($S(""^1^2^""[(U_IBEX_U):""Today"",IBEX=4:IBEX1,1:""n/a""),13) ; Start Days"
^XMB(3.9,144657,2,9951,0)="""RTN"",""IBJPI"",244,0)"
^XMB(3.9,144657,2,9952,0)=" . S IBST=IBST_$$FO^IBCNEUT1($S(IBEX=1:""Today"",IBEX=2:$$GET1^DIQ(350.9002,IEN_"",1,"",.03),IBEX=4:+$P(IBEIVB,U,7),1:""n/a""),13)   ; Days After Start"
^XMB(3.9,144657,2,9953,0)="""RTN"",""IBJPI"",245,0)"
^XMB(3.9,144657,2,9954,0)=" . S IBST=IBST_$$FO^IBCNEUT1($S(IBEX=4:+$P(IBEIVB,U,8),1:FRESHDAY),8) ; Frequency"
^XMB(3.9,144657,2,9955,0)="""RTN"",""IBJPI"",246,0)"
^XMB(3.9,144657,2,9956,0)=" . S IBST=IBST_$$FO^IBCNEUT1(+$P(IBEIVB,U,4),8)                       ; Max extract"
^XMB(3.9,144657,2,9957,0)="""RTN"",""IBJPI"",247,0)"
^XMB(3.9,144657,2,9958,0)=" . S ELINE=$$SET(IBST,"""",ELINE,1)"
^XMB(3.9,144657,2,9959,0)="""RTN"",""IBJPI"",248,0)"
^XMB(3.9,144657,2,9960,0)=" ;/vd-IB*2*687 - End of new/restructured code."
^XMB(3.9,144657,2,9961,0)="""RTN"",""IBJPI"",249,0)"
^XMB(3.9,144657,2,9962,0)=" ;"
^XMB(3.9,144657,2,9963,0)="""RTN"",""IBJPI"",250,0)"
^XMB(3.9,144657,2,9964,0)=" I +APPTBE D   ;/vd-IB*2*687 - Added to indicate ""APPT"" Buffer Entry."
^XMB(3.9,144657,2,9965,0)="""RTN"",""IBJPI"",251,0)"
^XMB(3.9,144657,2,9966,0)=" . S ELINE=$$SET("""","""",ELINE,1)            ; Spacing Blank Line"
^XMB(3.9,144657,2,9967,0)="""RTN"",""IBJPI"",252,0)"
^XMB(3.9,144657,2,9968,0)=" . S ELINE=$$SET(""   * Appt extract - Medicare frequency is ""_$$GET1^DIQ(350.9,""1,"",51.32)_"" days"","""",ELINE,1)"
^XMB(3.9,144657,2,9969,0)="""RTN"",""IBJPI"",253,0)"
^XMB(3.9,144657,2,9970,0)=" Q"
^XMB(3.9,144657,2,9971,0)="""RTN"",""IBJPI"",254,0)"
^XMB(3.9,144657,2,9972,0)=" ;"
^XMB(3.9,144657,2,9973,0)="""RTN"",""IBJPI"",255,0)"
^XMB(3.9,144657,2,9974,0)=" ;/vd - IB*2.0*687 - The BLDGENNS module was added for the IIU Parameters."
^XMB(3.9,144657,2,9975,0)="""RTN"",""IBJPI"",256,0)"
^XMB(3.9,144657,2,9976,0)="BLDGENNS(ELINE) ; Build the IIU Parameters Non-editable Section"
^XMB(3.9,144657,2,9977,0)="""RTN"",""IBJPI"",257,0)"
^XMB(3.9,144657,2,9978,0)=" ; Input: SLINE - Starting Section Line Number"
^XMB(3.9,144657,2,9979,0)="""RTN"",""IBJPI"",258,0)"
^XMB(3.9,144657,2,9980,0)=" ; ELINE - Current Ending Section Line Number"
^XMB(3.9,144657,2,9981,0)="""RTN"",""IBJPI"",259,0)"
^XMB(3.9,144657,2,9982,0)=" ; Output: ELINE - Updated Ending Section Line Number"
^XMB(3.9,144657,2,9983,0)="""RTN"",""IBJPI"",260,0)"
^XMB(3.9,144657,2,9984,0)=" ;"
^XMB(3.9,144657,2,9985,0)="""RTN"",""IBJPI"",261,0)"
^XMB(3.9,144657,2,9986,0)=" N STRTLN,XX"
^XMB(3.9,144657,2,9987,0)="""RTN"",""IBJPI"",262,0)"
^XMB(3.9,144657,2,9988,0)=" S ELINE=$$SET("""",$J("""",40),ELINE,1) ; Spacing Blank Line"
^XMB(3.9,144657,2,9989,0)="""RTN"",""IBJPI"",263,0)"
^XMB(3.9,144657,2,9990,0)=" S ELINE=$$SETN(""IIU Parameters (non-editable)"",ELINE,1,1)"
^XMB(3.9,144657,2,9991,0)="""RTN"",""IBJPI"",264,0)"
^XMB(3.9,144657,2,9992,0)=" S STRTLN=ELINE"
^XMB(3.9,144657,2,9993,0)="""RTN"",""IBJPI"",265,0)"
^XMB(3.9,144657,2,9994,0)=" S ELINE=$$SET(""     Max Days of Recent Visit: "",$$GET1^DIQ(350.9,""1,"",53.03),ELINE,1)"
^XMB(3.9,144657,2,9995,0)="""RTN"",""IBJPI"",266,0)"
^XMB(3.9,144657,2,9996,0)=" S ELINE=$$SET(""Min Days Before Sharing Again: "",$$GET1^DIQ(350.9,""1,"",53.04),ELINE,1)"
^XMB(3.9,144657,2,9997,0)="""RTN"",""IBJPI"",267,0)"
^XMB(3.9,144657,2,9998,0)=" S ELINE=$$SET(""            IIU Master Switch: "",$$GET1^DIQ(350.9,""1,"",53.01),ELINE,1)"
^XMB(3.9,144657,2,9999,0)="""RTN"",""IBJPI"",268,0)"
^XMB(3.9,144657,2,10000,0)=" S ELINE=STRTLN"
^XMB(3.9,144657,2,10001,0)="""RTN"",""IBJPI"",269,0)"
^XMB(3.9,144657,2,10002,0)=" S ELINE=$$SET(""      Purging Sent Records: "",$$GET1^DIQ(350.9,""1,"",53.05),ELINE,41)"
^XMB(3.9,144657,2,10003,0)="""RTN"",""IBJPI"",270,0)"
^XMB(3.9,144657,2,10004,0)=" S ELINE=$$SET(""  Purging Received Records: "",$$GET1^DIQ(350.9,""1,"",53.07),ELINE,41)"
^XMB(3.9,144657,2,10005,0)="""RTN"",""IBJPI"",271,0)"
^XMB(3.9,144657,2,10006,0)=" S ELINE=$$SET("" Purging Candidate Records: "",$$GET1^DIQ(350.9,""1,"",53.06),ELINE,41)"
^XMB(3.9,144657,2,10007,0)="""RTN"",""IBJPI"",272,0)"
^XMB(3.9,144657,2,10008,0)=" Q"
^XMB(3.9,144657,2,10009,0)="""RTN"",""IBJPI"",273,0)"
^XMB(3.9,144657,2,10010,0)=" ;"
^XMB(3.9,144657,2,10011,0)="""RTN"",""IBJPI"",274,0)"
^XMB(3.9,144657,2,10012,0)="SET(LABEL,DATA,LINE,COL) ; Sets text into the body of the worklist"
^XMB(3.9,144657,2,10013,0)="""RTN"",""IBJPI"",275,0)"
^XMB(3.9,144657,2,10014,0)=" ; Input:   LABEL   - Label text to set into the line"
^XMB(3.9,144657,2,10015,0)="""RTN"",""IBJPI"",276,0)"
^XMB(3.9,144657,2,10016,0)=" ;          DATA    - Field Data to set into the line"
^XMB(3.9,144657,2,10017,0)="""RTN"",""IBJPI"",277,0)"
^XMB(3.9,144657,2,10018,0)=" ;          LINE    - Line to set LABEL and DATA into"
^XMB(3.9,144657,2,10019,0)="""RTN"",""IBJPI"",278,0)"
^XMB(3.9,144657,2,10020,0)=" ;          COL     - Starting column position in LINE to insert"
^XMB(3.9,144657,2,10021,0)="""RTN"",""IBJPI"",279,0)"
^XMB(3.9,144657,2,10022,0)=" ;                    LABEL_DATA text"
^XMB(3.9,144657,2,10023,0)="""RTN"",""IBJPI"",280,0)"
^XMB(3.9,144657,2,10024,0)=" ; Returns: LINE    - Updated Line by 1"
^XMB(3.9,144657,2,10025,0)="""RTN"",""IBJPI"",281,0)"
^XMB(3.9,144657,2,10026,0)=" ;"
^XMB(3.9,144657,2,10027,0)="""RTN"",""IBJPI"",282,0)"
^XMB(3.9,144657,2,10028,0)=" N IBY"
^XMB(3.9,144657,2,10029,0)="""RTN"",""IBJPI"",283,0)"
^XMB(3.9,144657,2,10030,0)=" S IBY=LABEL_DATA"
^XMB(3.9,144657,2,10031,0)="""RTN"",""IBJPI"",284,0)"
^XMB(3.9,144657,2,10032,0)=" D SET1(IBY,LINE,COL,$L(IBY))"
^XMB(3.9,144657,2,10033,0)="""RTN"",""IBJPI"",285,0)"
^XMB(3.9,144657,2,10034,0)=" S LINE=LINE+1"
^XMB(3.9,144657,2,10035,0)="""RTN"",""IBJPI"",286,0)"
^XMB(3.9,144657,2,10036,0)=" Q LINE"
^XMB(3.9,144657,2,10037,0)="""RTN"",""IBJPI"",287,0)"
^XMB(3.9,144657,2,10038,0)=" ;"
^XMB(3.9,144657,2,10039,0)="""RTN"",""IBJPI"",288,0)"
^XMB(3.9,144657,2,10040,0)="SETN(TITLE,LINE,COL,RV,ULINE) ; Sets a field Section title into the body of the worklist"
^XMB(3.9,144657,2,10041,0)="""RTN"",""IBJPI"",289,0)"
^XMB(3.9,144657,2,10042,0)=" ; Input:   TITLE   - Text to be used for the field Section Title"
^XMB(3.9,144657,2,10043,0)="""RTN"",""IBJPI"",290,0)"
^XMB(3.9,144657,2,10044,0)=" ;          LINE    - Line number in the body to insert the field section title"
^XMB(3.9,144657,2,10045,0)="""RTN"",""IBJPI"",291,0)"
^XMB(3.9,144657,2,10046,0)=" ;          COL     - Starting Column position to set Section Title into"
^XMB(3.9,144657,2,10047,0)="""RTN"",""IBJPI"",292,0)"
^XMB(3.9,144657,2,10048,0)=" ;          RV      - 1 - Set Reverse Video, 0 or null don't use Reverse Video"
^XMB(3.9,144657,2,10049,0)="""RTN"",""IBJPI"",293,0)"
^XMB(3.9,144657,2,10050,0)=" ;                        Optional, defaults to """""
^XMB(3.9,144657,2,10051,0)="""RTN"",""IBJPI"",294,0)"
^XMB(3.9,144657,2,10052,0)=" ;          ULINE   - 1 - Set Underline, 0 or null don't use underline"
^XMB(3.9,144657,2,10053,0)="""RTN"",""IBJPI"",295,0)"
^XMB(3.9,144657,2,10054,0)=" ;                        Optional, defaults to """""
^XMB(3.9,144657,2,10055,0)="""RTN"",""IBJPI"",296,0)"
^XMB(3.9,144657,2,10056,0)=" ; Returns: LINE    - Line number increased by 1"
^XMB(3.9,144657,2,10057,0)="""RTN"",""IBJPI"",297,0)"
^XMB(3.9,144657,2,10058,0)=" ;"
^XMB(3.9,144657,2,10059,0)="""RTN"",""IBJPI"",298,0)"
^XMB(3.9,144657,2,10060,0)=" N IBY"
^XMB(3.9,144657,2,10061,0)="""RTN"",""IBJPI"",299,0)"
^XMB(3.9,144657,2,10062,0)=" S IBY="" ""_TITLE_"" """
^XMB(3.9,144657,2,10063,0)="""RTN"",""IBJPI"",300,0)"
^XMB(3.9,144657,2,10064,0)=" D SET1(IBY,LINE,COL,$L(IBY),$G(RV),$G(ULINE))"
^XMB(3.9,144657,2,10065,0)="""RTN"",""IBJPI"",301,0)"
^XMB(3.9,144657,2,10066,0)=" S LINE=LINE+1"
^XMB(3.9,144657,2,10067,0)="""RTN"",""IBJPI"",302,0)"
^XMB(3.9,144657,2,10068,0)=" Q LINE"
^XMB(3.9,144657,2,10069,0)="""RTN"",""IBJPI"",303,0)"
^XMB(3.9,144657,2,10070,0)=" ;"
^XMB(3.9,144657,2,10071,0)="""RTN"",""IBJPI"",304,0)"
^XMB(3.9,144657,2,10072,0)="SET1(TEXT,LINE,COL,WIDTH,RV,ULINE) ; Sets the TMP array with body data"
^XMB(3.9,144657,2,10073,0)="""RTN"",""IBJPI"",305,0)"
^XMB(3.9,144657,2,10074,0)=" ; Input:   TEXT                - Text to be set into the specified line"
^XMB(3.9,144657,2,10075,0)="""RTN"",""IBJPI"",306,0)"
^XMB(3.9,144657,2,10076,0)=" ;          LINE                - Line to set TEXT into"
^XMB(3.9,144657,2,10077,0)="""RTN"",""IBJPI"",307,0)"
^XMB(3.9,144657,2,10078,0)=" ;          COL                 - Column of LINE to set TEXT into"
^XMB(3.9,144657,2,10079,0)="""RTN"",""IBJPI"",308,0)"
^XMB(3.9,144657,2,10080,0)=" ;          WIDTH               - Width of the TEXT being set into line"
^XMB(3.9,144657,2,10081,0)="""RTN"",""IBJPI"",309,0)"
^XMB(3.9,144657,2,10082,0)=" ;          RV                  - 1 - Set Reverse Video, 0 or null don't use"
^XMB(3.9,144657,2,10083,0)="""RTN"",""IBJPI"",310,0)"
^XMB(3.9,144657,2,10084,0)=" ;                                    Reverse Video"
^XMB(3.9,144657,2,10085,0)="""RTN"",""IBJPI"",311,0)"
^XMB(3.9,144657,2,10086,0)=" ;                                Optional, defaults to """""
^XMB(3.9,144657,2,10087,0)="""RTN"",""IBJPI"",312,0)"
^XMB(3.9,144657,2,10088,0)=" ;          ULINE               - 1 - Set Underline, 0 or null don't use"
^XMB(3.9,144657,2,10089,0)="""RTN"",""IBJPI"",313,0)"
^XMB(3.9,144657,2,10090,0)=" ;                                    Underline"
^XMB(3.9,144657,2,10091,0)="""RTN"",""IBJPI"",314,0)"
^XMB(3.9,144657,2,10092,0)=" ;                                Optional, defaults to """""
^XMB(3.9,144657,2,10093,0)="""RTN"",""IBJPI"",315,0)"
^XMB(3.9,144657,2,10094,0)=" ;          ^TMP($J,""IBJPI"")   - Current ^TMP array"
^XMB(3.9,144657,2,10095,0)="""RTN"",""IBJPI"",316,0)"
^XMB(3.9,144657,2,10096,0)=" ; Output:  ^TMP($J,""IBJPI"")   - Updated ^TMP array"
^XMB(3.9,144657,2,10097,0)="""RTN"",""IBJPI"",317,0)"
^XMB(3.9,144657,2,10098,0)=" ;"
