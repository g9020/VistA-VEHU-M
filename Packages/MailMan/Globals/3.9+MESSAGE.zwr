^XMB(3.9,145831,2,342,0)=" F CTYP=""status"",""disposition"",""delay"",""arrival"" D"
^XMB(3.9,145831,2,343,0)="""RTN"",""EDPBSL"",48,0)"
^XMB(3.9,145831,2,344,0)=" . I $E($O(REQ(CTYP)),1,$L(CTYP))'=CTYP Q"
^XMB(3.9,145831,2,345,0)="""RTN"",""EDPBSL"",49,0)"
^XMB(3.9,145831,2,346,0)=" . S SETNM=EDPSTA_"".""_CTYP,SET=$O(^EDPB(233.2,""B"",SETNM,0))"
^XMB(3.9,145831,2,347,0)="""RTN"",""EDPBSL"",50,0)"
^XMB(3.9,145831,2,348,0)=" . I 'SET D NEWSET(SETNM) S SET=$O(^EDPB(233.2,""B"",SETNM,0))"
