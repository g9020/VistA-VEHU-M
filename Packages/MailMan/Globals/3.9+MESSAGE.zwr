^XMB(3.9,145839,2,893,0)="""RTN"",""TIUCCRHL7P1"",173,0)"
^XMB(3.9,145839,2,894,0)=" K T2 S T2($C(160)_$C(160)_""CONSULT AND REFERRAL INFORMATION "")=$C(10)_""CONSULT AND REFERRAL INFORMATION "" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,895,0)="""RTN"",""TIUCCRHL7P1"",174,0)"
^XMB(3.9,145839,2,896,0)=" K T2 S T2(""Name of Referring VA Provider:"")=$C(10)_""Name of Referring VA Provider:"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,897,0)="""RTN"",""TIUCCRHL7P1"",175,0)"
