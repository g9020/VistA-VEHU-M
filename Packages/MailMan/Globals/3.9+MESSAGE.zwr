^XMB(3.9,145834,2,2850,0)=" . . E  D"
^XMB(3.9,145834,2,2851,0)="""RTN"",""MAGDSTA1"",102,0)"
^XMB(3.9,145834,2,2852,0)=" . . . K ^TMP(""MAG"",$J,""BATCH Q/R"",""PATIENT DFN"")"
^XMB(3.9,145834,2,2853,0)="""RTN"",""MAGDSTA1"",103,0)"
