^XMB(3.9,144657,2,992,0)=" W ! S DIR(0)=""SOB^M:MERGE;O:OVERWRITE;R:REPLACE;N:NO CHANGE;I:INDIVIDUALLY ACCEPT (SKIP BLANKS)"" D ^DIR"
^XMB(3.9,144657,2,993,0)="""RTN"",""IBCNBAA"",200,0)"
^XMB(3.9,144657,2,994,0)=" S IBX=$S(Y=""M"":1,Y=""O"":2,Y=""R"":3,Y=""I"":4,Y=""N"":0,1:"""") I IBX'="""" S IBX=IBX_U_$G(Y(0))_$S(+IBX=1:"" with"",1:"""")"
