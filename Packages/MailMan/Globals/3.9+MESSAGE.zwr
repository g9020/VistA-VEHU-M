^XMB(3.9,145849,2,22,0)="    (CMOP A0913)             ASCORBIC ACID 500MG/ML INJ         3/16/2026"
^XMB(3.9,145849,2,23,0)="    STRENGTH: 500UNITS: MG/ML"
^XMB(3.9,145849,2,24,0)="    POSSIBLE DOSES"
^XMB(3.9,145849,2,25,0)="    DISP UNITS/DOSE     DOSE    PACKAGE   BCMA UNITS/DOSE"
^XMB(3.9,145849,2,26,0)="       1                 500      I       "
^XMB(3.9,145849,2,27,0)="       2                1000      I       "
^XMB(3.9,145849,2,28,0)=" "
^XMB(3.9,145849,2,29,0)="The following investigational entries in your DRUG file (#50) have been "
^XMB(3.9,145849,2,30,0)="unmatched from the National Drug File (NDF).  The VA Product name and CMOP ID"
^XMB(3.9,145849,2,31,0)="corresponding to the unmatched local drug file name are listed on the"
^XMB(3.9,145849,2,32,0)="indented line beneath each entry.  An Inactivation Date may be listed for"
^XMB(3.9,145849,2,33,0)="entries when this reason applies.  Until you rematch these entries to NDF,"
^XMB(3.9,145849,2,34,0)="they will not transmit to CMOP and drug-drug interaction checks will not"
^XMB(3.9,145849,2,35,0)="check for these products.  It is critical that you rematch these products"
^XMB(3.9,145849,2,36,0)="immediately.  You may also need to match a new orderable item.  Any possible"
^XMB(3.9,145849,2,37,0)="dosages and local possible dosages for these unmatched products have been"
^XMB(3.9,145849,2,38,0)="deleted. Therefore, the dosages for each unmatched product should be reviewed"
^XMB(3.9,145849,2,39,0)="after the rematch or recreated if the product can not be rematched to a VA"
^XMB(3.9,145849,2,40,0)="Product through the NDF matching process.  "
^XMB(3.9,145849,2,41,0)=" "
