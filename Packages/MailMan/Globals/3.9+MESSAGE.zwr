^XMB(3.9,145834,2,2920,0)=" I $G(^TMP(""MAG"",$J,""BATCH Q/R"",""PACS Q/R RETRIEVE SCP""))="""" W "" -- Exiting"" Q"
^XMB(3.9,145834,2,2921,0)="""RTN"",""MAGDSTA1"",137,0)"
^XMB(3.9,145834,2,2922,0)=" ;"
^XMB(3.9,145834,2,2923,0)="""RTN"",""MAGDSTA1"",138,0)"
^XMB(3.9,145834,2,2924,0)=" I SCANMODE=""ACCESSION"" D  Q  ; single accession number compare/retrieve"
^XMB(3.9,145834,2,2925,0)="""RTN"",""MAGDSTA1"",139,0)"
^XMB(3.9,145834,2,2926,0)=" . D ACNUM^MAGDSTA2"
^XMB(3.9,145834,2,2927,0)="""RTN"",""MAGDSTA1"",140,0)"
