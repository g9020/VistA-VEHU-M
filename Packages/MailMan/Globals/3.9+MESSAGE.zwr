^XMB(3.9,144657,2,3045,0)="""RTN"",""IBCNBLE2"",131,0)"
^XMB(3.9,144657,2,3046,0)=" I IBY'="""" D"
^XMB(3.9,144657,2,3047,0)="""RTN"",""IBCNBLE2"",132,0)"
^XMB(3.9,144657,2,3048,0)=" . N HDPQ"
^XMB(3.9,144657,2,3049,0)="""RTN"",""IBCNBLE2"",133,0)"
^XMB(3.9,144657,2,3050,0)=" . S HDPQ=$G(BPSM(9002313.0301,ZM,549,""E"")) Q:HDPQ=""""    ; help desk phone# qualifier"
^XMB(3.9,144657,2,3051,0)="""RTN"",""IBCNBLE2"",134,0)"
^XMB(3.9,144657,2,3052,0)=" . S HDPQ=$S(+HDPQ=1:""Switch"",+HDPQ=2:""Intermediary"",+HDPQ=3:""Processor/PBM"",1:""Other"")"
