^XMB(3.9,145831,2,485,0)="""RTN"",""EDPLPCE"",1,0)"
^XMB(3.9,145831,2,486,0)="EDPLPCE ;SLC/KCM - Create a Visit ;2/28/12 08:33am"
^XMB(3.9,145831,2,487,0)="""RTN"",""EDPLPCE"",2,0)"
^XMB(3.9,145831,2,488,0)=" ;;2.0;EMERGENCY DEPARTMENT;**2,12**;Feb 24, 2012;Build 0"
^XMB(3.9,145831,2,489,0)="""RTN"",""EDPLPCE"",3,0)"
^XMB(3.9,145831,2,490,0)=" ;"
^XMB(3.9,145831,2,491,0)="""RTN"",""EDPLPCE"",4,0)"
^XMB(3.9,145831,2,492,0)=" ; DBIA#  SUPPORTED"
^XMB(3.9,145831,2,493,0)="""RTN"",""EDPLPCE"",5,0)"
^XMB(3.9,145831,2,494,0)=" ; -----  ---------  ------------------------------------"
^XMB(3.9,145831,2,495,0)="""RTN"",""EDPLPCE"",6,0)"
^XMB(3.9,145831,2,496,0)=" ;  1894  Cont Sub   ENCEVENT^PXAPI"
^XMB(3.9,145831,2,497,0)="""RTN"",""EDPLPCE"",7,0)"
^XMB(3.9,145831,2,498,0)=" ;  1889  Cont Sub   DATA2PCE^PXAPI"
^XMB(3.9,145831,2,499,0)="""RTN"",""EDPLPCE"",8,0)"
^XMB(3.9,145831,2,500,0)=" ;  5747  Sup        $$CODEC^ICDEX"
^XMB(3.9,145831,2,501,0)="""RTN"",""EDPLPCE"",9,0)"
^XMB(3.9,145831,2,502,0)=" ; 10103  Sup        $$NOW^XLFDT,$$FMADD^XLFDT"
^XMB(3.9,145831,2,503,0)="""RTN"",""EDPLPCE"",10,0)"
^XMB(3.9,145831,2,504,0)=" ;  2053  Sup        FILE^DIE"
^XMB(3.9,145831,2,505,0)="""RTN"",""EDPLPCE"",11,0)"
^XMB(3.9,145831,2,506,0)=" ;  2263  Sup        $$GET^XPAR,GETLST^XPAR"
^XMB(3.9,145831,2,507,0)="""RTN"",""EDPLPCE"",12,0)"
^XMB(3.9,145831,2,508,0)=" ;  1890  Cont Sub   $$DELVFILE^PXAPI"
^XMB(3.9,145831,2,509,0)="""RTN"",""EDPLPCE"",13,0)"
^XMB(3.9,145831,2,510,0)=" ;  5679  Sup        $$ONE^LEXU"
^XMB(3.9,145831,2,511,0)="""RTN"",""EDPLPCE"",14,0)"
^XMB(3.9,145831,2,512,0)=" ;  1573  Sup        $$CPTONE^LEXU"
^XMB(3.9,145831,2,513,0)="""RTN"",""EDPLPCE"",15,0)"
^XMB(3.9,145831,2,514,0)=" ;  2028  Cont Sub   ^AUPNVSIT("
^XMB(3.9,145831,2,515,0)="""RTN"",""EDPLPCE"",16,0)"
^XMB(3.9,145831,2,516,0)=" ; 10048  Sup        ^DIC(9.4"
^XMB(3.9,145831,2,517,0)="""RTN"",""EDPLPCE"",17,0)"
^XMB(3.9,145831,2,518,0)=" ;  2815  Sup        ^ICPT(""B"""
^XMB(3.9,145831,2,519,0)="""RTN"",""EDPLPCE"",18,0)"
^XMB(3.9,145831,2,520,0)=" ;"
^XMB(3.9,145831,2,521,0)="""RTN"",""EDPLPCE"",19,0)"
^XMB(3.9,145831,2,522,0)="UPDVISIT(LOG,PCE) ; Get / Create a Visit"
^XMB(3.9,145831,2,523,0)="""RTN"",""EDPLPCE"",20,0)"
^XMB(3.9,145831,2,524,0)=" ; PCE is list of potential updates to the visit"
^XMB(3.9,145831,2,525,0)="""RTN"",""EDPLPCE"",21,0)"
^XMB(3.9,145831,2,526,0)=" ; PCE(TYP,n)=type^ien^code^label^add^del^upd^prim^qty"
^XMB(3.9,145831,2,527,0)="""RTN"",""EDPLPCE"",22,0)"
^XMB(3.9,145831,2,528,0)=" N DFN,TS,LOC,X0,I,X,PRVVISIT"
^XMB(3.9,145831,2,529,0)="""RTN"",""EDPLPCE"",23,0)"
^XMB(3.9,145831,2,530,0)=" S X0=^EDP(230,LOG,0),DFN=$P(X0,U,6),TS=$P(X0,U,8),LOC=$P(X0,U,14)"
^XMB(3.9,145831,2,531,0)="""RTN"",""EDPLPCE"",24,0)"
^XMB(3.9,145831,2,532,0)=" I 'LOC S LOC=$$DFLTLOC(DFN)"
^XMB(3.9,145831,2,533,0)="""RTN"",""EDPLPCE"",25,0)"
^XMB(3.9,145831,2,534,0)=" I 'DFN!('TS)!('LOC) Q 0  ; not enough info"
^XMB(3.9,145831,2,535,0)="""RTN"",""EDPLPCE"",26,0)"
^XMB(3.9,145831,2,536,0)=" ;"
^XMB(3.9,145831,2,537,0)="""RTN"",""EDPLPCE"",27,0)"
^XMB(3.9,145831,2,538,0)=" N EDPDATA,EDPVISIT,EDPPCHG"
^XMB(3.9,145831,2,539,0)="""RTN"",""EDPLPCE"",28,0)"
^XMB(3.9,145831,2,540,0)=" S EDPVISIT=$P(X0,U,12),EDPPCHG=0 S:'EDPVISIT TS=$$TS4VISIT(DFN,LOC,TS,.PRVVISIT)"
^XMB(3.9,145831,2,541,0)="""RTN"",""EDPLPCE"",29,0)"
^XMB(3.9,145831,2,542,0)=" ;"
^XMB(3.9,145831,2,543,0)="""RTN"",""EDPLPCE"",30,0)"
^XMB(3.9,145831,2,544,0)=" ; if closed record and no visit, bail"
^XMB(3.9,145831,2,545,0)="""RTN"",""EDPLPCE"",31,0)"
^XMB(3.9,145831,2,546,0)=" I $P(X0,U,7),'EDPVISIT Q 0"
^XMB(3.9,145831,2,547,0)="""RTN"",""EDPLPCE"",32,0)"
^XMB(3.9,145831,2,548,0)=" ;"
^XMB(3.9,145831,2,549,0)="""RTN"",""EDPLPCE"",33,0)"
^XMB(3.9,145831,2,550,0)=" ; if no visit, but diagnoses exist, xfer the diagnoses"
^XMB(3.9,145831,2,551,0)="""RTN"",""EDPLPCE"",34,0)"
^XMB(3.9,145831,2,552,0)=" I 'EDPVISIT D XFERDIAG(LOG,.PCE)"
^XMB(3.9,145831,2,553,0)="""RTN"",""EDPLPCE"",35,0)"
^XMB(3.9,145831,2,554,0)=" ; remove current primary provider(s) if there is a new one"
^XMB(3.9,145831,2,555,0)="""RTN"",""EDPLPCE"",36,0)"
^XMB(3.9,145831,2,556,0)=" I $G(PCE(""PRI"")) D"
^XMB(3.9,145831,2,557,0)="""RTN"",""EDPLPCE"",37,0)"
^XMB(3.9,145831,2,558,0)=" . N IPRV,XPRV,OLDPRI,EDPLCSYS,EDPLCIEN,GETVISIT ; Begin EDP*2.0*2 changes"
^XMB(3.9,145831,2,559,0)="""RTN"",""EDPLPCE"",38,0)"
^XMB(3.9,145831,2,560,0)=" . S GETVISIT=0"
^XMB(3.9,145831,2,561,0)="""RTN"",""EDPLPCE"",39,0)"
^XMB(3.9,145831,2,562,0)=" . I $G(PRVVISIT) S GETVISIT=PRVVISIT ;if we have no current visit but there is a recent visit we'll link to."
^XMB(3.9,145831,2,563,0)="""RTN"",""EDPLPCE"",40,0)"
^XMB(3.9,145831,2,564,0)=" . I $G(EDPVISIT) S GETVISIT=EDPVISIT ;we have a current visit"
^XMB(3.9,145831,2,565,0)="""RTN"",""EDPLPCE"",41,0)"
^XMB(3.9,145831,2,566,0)=" . I 'GETVISIT Q"
^XMB(3.9,145831,2,567,0)="""RTN"",""EDPLPCE"",42,0)"
^XMB(3.9,145831,2,568,0)=" . K ^TMP(""PXKENC"",$J)"
^XMB(3.9,145831,2,569,0)="""RTN"",""EDPLPCE"",43,0)"
^XMB(3.9,145831,2,570,0)=" . D ENCEVENT^PXAPI(GETVISIT)"
^XMB(3.9,145831,2,571,0)="""RTN"",""EDPLPCE"",44,0)"
^XMB(3.9,145831,2,572,0)=" . S IPRV=0 F  S IPRV=$O(^TMP(""PXKENC"",$J,GETVISIT,""PRV"",IPRV)) Q:'IPRV  D"
^XMB(3.9,145831,2,573,0)="""RTN"",""EDPLPCE"",45,0)"
^XMB(3.9,145831,2,574,0)=" .. S XPRV=^TMP(""PXKENC"",$J,GETVISIT,""PRV"",IPRV,0)"
^XMB(3.9,145831,2,575,0)="""RTN"",""EDPLPCE"",46,0)"
^XMB(3.9,145831,2,576,0)=" .. Q:$P(XPRV,U,4)'=""P"""
^XMB(3.9,145831,2,577,0)="""RTN"",""EDPLPCE"",47,0)"
^XMB(3.9,145831,2,578,0)=" .. I +XPRV'=$G(PCE(""PRI"")) S EDPDATA(""PROVIDER"",IPRV,""NAME"")=+XPRV,EDPDATA(""PROVIDER"",IPRV,""PRIMARY"")=0"
^XMB(3.9,145831,2,579,0)="""RTN"",""EDPLPCE"",48,0)"
^XMB(3.9,145831,2,580,0)=" ; add any new providers that were entered"
^XMB(3.9,145831,2,581,0)="""RTN"",""EDPLPCE"",49,0)"
^XMB(3.9,145831,2,582,0)=" S I=0 F  S I=$O(PCE(""PRV"",I)) Q:'I  D"
^XMB(3.9,145831,2,583,0)="""RTN"",""EDPLPCE"",50,0)"
^XMB(3.9,145831,2,584,0)=" . S EDPDATA(""PROVIDER"",I,""NAME"")=+PCE(""PRV"",I)"
^XMB(3.9,145831,2,585,0)="""RTN"",""EDPLPCE"",51,0)"
^XMB(3.9,145831,2,586,0)=" . I +PCE(""PRV"",I)=$G(PCE(""PRI"")) S EDPDATA(""PROVIDER"",I,""PRIMARY"")=1,EDPPCHG=1"
^XMB(3.9,145831,2,587,0)="""RTN"",""EDPLPCE"",52,0)"
^XMB(3.9,145831,2,588,0)=" ; update diagnoses"
^XMB(3.9,145831,2,589,0)="""RTN"",""EDPLPCE"",53,0)"
^XMB(3.9,145831,2,590,0)=" ; DRP 04062012 Begin EDP*2.0*2 Changes  "
^XMB(3.9,145831,2,591,0)="""RTN"",""EDPLPCE"",54,0)"
^XMB(3.9,145831,2,592,0)=" S I=0 F  S I=$O(PCE(""POV"",I)) Q:'I  D"
^XMB(3.9,145831,2,593,0)="""RTN"",""EDPLPCE"",55,0)"
^XMB(3.9,145831,2,594,0)=" . S X=PCE(""POV"",I)"
^XMB(3.9,145831,2,595,0)="""RTN"",""EDPLPCE"",56,0)"
^XMB(3.9,145831,2,596,0)=" . Q:'($P(X,U,5)!$P(X,U,6)!$P(X,U,7))  ; no updates for this diagnosis"
^XMB(3.9,145831,2,597,0)="""RTN"",""EDPLPCE"",57,0)"
^XMB(3.9,145831,2,598,0)=" . I $P(X,U,2) D"
^XMB(3.9,145831,2,599,0)="""RTN"",""EDPLPCE"",58,0)"
^XMB(3.9,145831,2,600,0)=" .. S EDPLCSYS=$$CSYS^EDPLEX(TS)"
^XMB(3.9,145831,2,601,0)="""RTN"",""EDPLPCE"",59,0)"
^XMB(3.9,145831,2,602,0)=" .. I EDPLCSYS=""ICD"" D"
^XMB(3.9,145831,2,603,0)="""RTN"",""EDPLPCE"",60,0)"
^XMB(3.9,145831,2,604,0)=" ... N EDPLCIEN S EDPLCIEN=$$ONE^LEXU($P(X,U,2),TS,EDPLCSYS)"
^XMB(3.9,145831,2,605,0)="""RTN"",""EDPLPCE"",61,0)"
^XMB(3.9,145831,2,606,0)=" ... Q:'$L(EDPLCIEN)"
^XMB(3.9,145831,2,607,0)="""RTN"",""EDPLPCE"",62,0)"
^XMB(3.9,145831,2,608,0)=" ... S:$L(EDPLCIEN) $P(X,U,2)=$P($$ICDDATA^EDPLEX(EDPLCSYS,EDPLCIEN,TS,""E""),U,1) ;drp patch 2"
^XMB(3.9,145831,2,609,0)="""RTN"",""EDPLPCE"",63,0)"
^XMB(3.9,145831,2,610,0)=" ...Q"
^XMB(3.9,145831,2,611,0)="""RTN"",""EDPLPCE"",64,0)"
^XMB(3.9,145831,2,612,0)=" .. N CODE S CODE=$$CODEC^ICDEX(80,$P(X,U,2))"
^XMB(3.9,145831,2,613,0)="""RTN"",""EDPLPCE"",65,0)"
^XMB(3.9,145831,2,614,0)=" .. S $P(X,U,3)=CODE"
^XMB(3.9,145831,2,615,0)="""RTN"",""EDPLPCE"",66,0)"
^XMB(3.9,145831,2,616,0)=" . Q:'$L($P(X,U,3))                   ; not coded"
^XMB(3.9,145831,2,617,0)="""RTN"",""EDPLPCE"",67,0)"
^XMB(3.9,145831,2,618,0)=" . S EDPLCIEN=$P($$ICDDATA^EDPLEX(""DIAG"",$P(X,U,3),TS,""E""),U,1) Q:'EDPLCIEN"
^XMB(3.9,145831,2,619,0)="""RTN"",""EDPLPCE"",68,0)"
^XMB(3.9,145831,2,620,0)=" . S EDPDATA(""DX/PL"",I,""DIAGNOSIS"")=EDPLCIEN"
^XMB(3.9,145831,2,621,0)="""RTN"",""EDPLPCE"",69,0)"
^XMB(3.9,145831,2,622,0)=" . ;DRP end EDP*2.0*2 changes"
^XMB(3.9,145831,2,623,0)="""RTN"",""EDPLPCE"",70,0)"
^XMB(3.9,145831,2,624,0)=" . S EDPDATA(""DX/PL"",I,""NARRATIVE"")=$P(X,U,4)"
^XMB(3.9,145831,2,625,0)="""RTN"",""EDPLPCE"",71,0)"
^XMB(3.9,145831,2,626,0)=" . I $P(X,U,8) S EDPDATA(""DX/PL"",I,""PRIMARY"")=1"
^XMB(3.9,145831,2,627,0)="""RTN"",""EDPLPCE"",72,0)"
^XMB(3.9,145831,2,628,0)=" . I $P(X,U,6) S EDPDATA(""DX/PL"",I,""DELETE"")=1"
^XMB(3.9,145831,2,629,0)="""RTN"",""EDPLPCE"",73,0)"
^XMB(3.9,145831,2,630,0)=" ; update procedures"
^XMB(3.9,145831,2,631,0)="""RTN"",""EDPLPCE"",74,0)"
^XMB(3.9,145831,2,632,0)=" S I=0 F  S I=$O(PCE(""CPT"",I)) Q:'I  D"
^XMB(3.9,145831,2,633,0)="""RTN"",""EDPLPCE"",75,0)"
^XMB(3.9,145831,2,634,0)=" . S X=PCE(""CPT"",I)"
^XMB(3.9,145831,2,635,0)="""RTN"",""EDPLPCE"",76,0)"
^XMB(3.9,145831,2,636,0)=" . Q:'($P(X,U,5)!$P(X,U,6)!$P(X,U,7))  ; no updates for this procedure"
^XMB(3.9,145831,2,637,0)="""RTN"",""EDPLPCE"",77,0)"
^XMB(3.9,145831,2,638,0)=" . I $P(X,U,2) D"
^XMB(3.9,145831,2,639,0)="""RTN"",""EDPLPCE"",78,0)"
^XMB(3.9,145831,2,640,0)=" .. N CODE S CODE=$$CPTONE^LEXU($P(X,U,2),TS)"
^XMB(3.9,145831,2,641,0)="""RTN"",""EDPLPCE"",79,0)"
^XMB(3.9,145831,2,642,0)=" .. S $P(X,U,3)=CODE"
^XMB(3.9,145831,2,643,0)="""RTN"",""EDPLPCE"",80,0)"
^XMB(3.9,145831,2,644,0)=" . Q:'$L($P(X,U,3))                   ; not coded"
^XMB(3.9,145831,2,645,0)="""RTN"",""EDPLPCE"",81,0)"
^XMB(3.9,145831,2,646,0)=" . S IEN=+$O(^ICPT(""B"",$P(X,U,3),0))"
^XMB(3.9,145831,2,647,0)="""RTN"",""EDPLPCE"",82,0)"
^XMB(3.9,145831,2,648,0)=" . S EDPDATA(""PROCEDURE"",I,""PROCEDURE"")=IEN"
^XMB(3.9,145831,2,649,0)="""RTN"",""EDPLPCE"",83,0)"
^XMB(3.9,145831,2,650,0)=" . S EDPDATA(""PROCEDURE"",I,""QTY"")=$S($P(X,U,9):$P(X,U,9),1:1)"
^XMB(3.9,145831,2,651,0)="""RTN"",""EDPLPCE"",84,0)"
^XMB(3.9,145831,2,652,0)=" . S EDPDATA(""PROCEDURE"",I,""NARRATIVE"")=$P(X,U,4)"
^XMB(3.9,145831,2,653,0)="""RTN"",""EDPLPCE"",85,0)"
^XMB(3.9,145831,2,654,0)=" . I $P(X,U,6) S EDPDATA(""PROCEDURE"",I,""DELETE"")=1"
^XMB(3.9,145831,2,655,0)="""RTN"",""EDPLPCE"",86,0)"
^XMB(3.9,145831,2,656,0)=" ; exit if no updates"
^XMB(3.9,145831,2,657,0)="""RTN"",""EDPLPCE"",87,0)"
^XMB(3.9,145831,2,658,0)=" Q:'$D(EDPDATA) 0"
^XMB(3.9,145831,2,659,0)="""RTN"",""EDPLPCE"",88,0)"
^XMB(3.9,145831,2,660,0)=" ;"
^XMB(3.9,145831,2,661,0)="""RTN"",""EDPLPCE"",89,0)"
^XMB(3.9,145831,2,662,0)=" N EDPKG,EDPSRC,EDPERR,OK"
^XMB(3.9,145831,2,663,0)="""RTN"",""EDPLPCE"",90,0)"
^XMB(3.9,145831,2,664,0)=" S EDPKG=$O(^DIC(9.4,""B"",""EMERGENCY DEPARTMENT"",0))"
^XMB(3.9,145831,2,665,0)="""RTN"",""EDPLPCE"",91,0)"
^XMB(3.9,145831,2,666,0)=" S EDPSRC=""EDP TRACKING LOG"""
^XMB(3.9,145831,2,667,0)="""RTN"",""EDPLPCE"",92,0)"
^XMB(3.9,145831,2,668,0)=" S EDPDATA(""ENCOUNTER"",1,""PATIENT"")=DFN"
^XMB(3.9,145831,2,669,0)="""RTN"",""EDPLPCE"",93,0)"
^XMB(3.9,145831,2,670,0)=" S EDPDATA(""ENCOUNTER"",1,""HOS LOC"")=LOC"
^XMB(3.9,145831,2,671,0)="""RTN"",""EDPLPCE"",94,0)"
^XMB(3.9,145831,2,672,0)=" S EDPDATA(""ENCOUNTER"",1,""SERVICE CATEGORY"")=""A"""
^XMB(3.9,145831,2,673,0)="""RTN"",""EDPLPCE"",95,0)"
^XMB(3.9,145831,2,674,0)=" S EDPDATA(""ENCOUNTER"",1,""ENCOUNTER TYPE"")=""P"""
^XMB(3.9,145831,2,675,0)="""RTN"",""EDPLPCE"",96,0)"
^XMB(3.9,145831,2,676,0)=" I 'EDPVISIT S EDPDATA(""ENCOUNTER"",1,""ENC D/T"")=TS"
^XMB(3.9,145831,2,677,0)="""RTN"",""EDPLPCE"",97,0)"
^XMB(3.9,145831,2,678,0)=" ;"
^XMB(3.9,145831,2,679,0)="""RTN"",""EDPLPCE"",98,0)"
^XMB(3.9,145831,2,680,0)=" S OK=$$DATA2PCE^PXAPI(""EDPDATA"",EDPKG,EDPSRC,.EDPVISIT,,,,EDPPCHG,.EDPERR)"
^XMB(3.9,145831,2,681,0)="""RTN"",""EDPLPCE"",99,0)"
^XMB(3.9,145831,2,682,0)=" I OK<1 D"
^XMB(3.9,145831,2,683,0)="""RTN"",""EDPLPCE"",100,0)"
^XMB(3.9,145831,2,684,0)=" . N NOW S NOW=$$NOW^XLFDT"
^XMB(3.9,145831,2,685,0)="""RTN"",""EDPLPCE"",101,0)"
^XMB(3.9,145831,2,686,0)=" . S ^XTMP(""EDPERR-PCE-""_LOG,0)=$$FMADD^XLFDT(NOW,7)_U_NOW_U_""ED PCE Error"""
^XMB(3.9,145831,2,687,0)="""RTN"",""EDPLPCE"",102,0)"
^XMB(3.9,145831,2,688,0)=" . S ^XTMP(""EDPERR-PCE-""_LOG,""VISIT"")=EDPVISIT_U_OK"
^XMB(3.9,145831,2,689,0)="""RTN"",""EDPLPCE"",103,0)"
^XMB(3.9,145831,2,690,0)=" . M ^XTMP(""EDPERR-PCE-""_LOG,""DATA"")=EDPDATA"
^XMB(3.9,145831,2,691,0)="""RTN"",""EDPLPCE"",104,0)"
^XMB(3.9,145831,2,692,0)=" . M ^XTMP(""EDPERR-PCE-""_LOG,""ERR"")=EDPERR"
^XMB(3.9,145831,2,693,0)="""RTN"",""EDPLPCE"",105,0)"
^XMB(3.9,145831,2,694,0)=" ;"
^XMB(3.9,145831,2,695,0)="""RTN"",""EDPLPCE"",106,0)"
^XMB(3.9,145831,2,696,0)=" ; update the visit pointer in 230"
^XMB(3.9,145831,2,697,0)="""RTN"",""EDPLPCE"",107,0)"
^XMB(3.9,145831,2,698,0)=" I EDPVISIT,OK,($P(X0,U,12)'=EDPVISIT) D"
^XMB(3.9,145831,2,699,0)="""RTN"",""EDPLPCE"",108,0)"
^XMB(3.9,145831,2,700,0)=" . N FDA,DIERR,ERR"
^XMB(3.9,145831,2,701,0)="""RTN"",""EDPLPCE"",109,0)"
^XMB(3.9,145831,2,702,0)=" . S FDA(230,LOG_"","",.12)=EDPVISIT"
^XMB(3.9,145831,2,703,0)="""RTN"",""EDPLPCE"",110,0)"
^XMB(3.9,145831,2,704,0)=" . D FILE^DIE("""",""FDA"",""ERR"")"
^XMB(3.9,145831,2,705,0)="""RTN"",""EDPLPCE"",111,0)"
^XMB(3.9,145831,2,706,0)=" Q"
^XMB(3.9,145831,2,707,0)="""RTN"",""EDPLPCE"",112,0)"
^XMB(3.9,145831,2,708,0)="XFERDIAG(LOG,PCE) ; Setup diagnosis list based on entries in 230"
^XMB(3.9,145831,2,709,0)="""RTN"",""EDPLPCE"",113,0)"
^XMB(3.9,145831,2,710,0)=" ;DRP 04062012 Begin EDP*2.0*2 ICD10 CHANGES"
^XMB(3.9,145831,2,711,0)="""RTN"",""EDPLPCE"",114,0)"
^XMB(3.9,145831,2,712,0)=" N IEN,X0,CODE,EDPDOI,EDPLCIEN"
^XMB(3.9,145831,2,713,0)="""RTN"",""EDPLPCE"",115,0)"
^XMB(3.9,145831,2,714,0)=" K PCE(""POV"")  ; not worried about adds & subtracts, so start over"
^XMB(3.9,145831,2,715,0)="""RTN"",""EDPLPCE"",116,0)"
^XMB(3.9,145831,2,716,0)=" S IEN=0 F  S IEN=$O(^EDP(230,LOG,4,IEN)) Q:'IEN  D"
^XMB(3.9,145831,2,717,0)="""RTN"",""EDPLPCE"",117,0)"
^XMB(3.9,145831,2,718,0)=" . S X0=$G(^EDP(230,LOG,4,IEN,0)),EDPDOI=$P(^EDP(230,LOG,0),U,8) ; GET DATE OF INTEREST"
^XMB(3.9,145831,2,719,0)="""RTN"",""EDPLPCE"",118,0)"
^XMB(3.9,145831,2,720,0)=" . S PCE(""POV"",IEN)=""POV^^^^1"",EDPLCIEN=$P(X0,U,2)"
^XMB(3.9,145831,2,721,0)="""RTN"",""EDPLPCE"",119,0)"
^XMB(3.9,145831,2,722,0)=" . S CODE=$P($$ICDDATA^EDPLEX(""DIAG"",EDPLCIEN,EDPDOI),U,2)"
^XMB(3.9,145831,2,723,0)="""RTN"",""EDPLPCE"",120,0)"
^XMB(3.9,145831,2,724,0)=" . ;DRP End EDP*2.0*2 Changes"
^XMB(3.9,145831,2,725,0)="""RTN"",""EDPLPCE"",121,0)"
^XMB(3.9,145831,2,726,0)=" . S $P(PCE(""POV"",IEN),U,3)=CODE        ; code"
^XMB(3.9,145831,2,727,0)="""RTN"",""EDPLPCE"",122,0)"
^XMB(3.9,145831,2,728,0)=" . S $P(PCE(""POV"",IEN),U,4)=$P(X0,U)    ; text"
^XMB(3.9,145831,2,729,0)="""RTN"",""EDPLPCE"",123,0)"
^XMB(3.9,145831,2,730,0)=" . S $P(PCE(""POV"",IEN),U,8)=$P(X0,U,3)  ; primary"
^XMB(3.9,145831,2,731,0)="""RTN"",""EDPLPCE"",124,0)"
^XMB(3.9,145831,2,732,0)=" Q"
^XMB(3.9,145831,2,733,0)="""RTN"",""EDPLPCE"",125,0)"
^XMB(3.9,145831,2,734,0)="DELVISIT(LOG) ; Delete visit for stub entry"
^XMB(3.9,145831,2,735,0)="""RTN"",""EDPLPCE"",126,0)"
^XMB(3.9,145831,2,736,0)=" N EDPVISIT S EDPVISIT=$P(^EDP(230,LOG,0),U,12)"
^XMB(3.9,145831,2,737,0)="""RTN"",""EDPLPCE"",127,0)"
^XMB(3.9,145831,2,738,0)=" Q:'EDPVISIT"
^XMB(3.9,145831,2,739,0)="""RTN"",""EDPLPCE"",128,0)"
^XMB(3.9,145831,2,740,0)=" ;"
^XMB(3.9,145831,2,741,0)="""RTN"",""EDPLPCE"",129,0)"
^XMB(3.9,145831,2,742,0)=" N FDA,DIERR,ERR"
^XMB(3.9,145831,2,743,0)="""RTN"",""EDPLPCE"",130,0)"
^XMB(3.9,145831,2,744,0)=" S FDA(230,LOG_"","",.12)=""@"""
^XMB(3.9,145831,2,745,0)="""RTN"",""EDPLPCE"",131,0)"
^XMB(3.9,145831,2,746,0)=" D FILE^DIE("""",""FDA"",""ERR"")"
^XMB(3.9,145831,2,747,0)="""RTN"",""EDPLPCE"",132,0)"
^XMB(3.9,145831,2,748,0)=" ;"
^XMB(3.9,145831,2,749,0)="""RTN"",""EDPLPCE"",133,0)"
^XMB(3.9,145831,2,750,0)=" S OK=$$DELVFILE^PXAPI(""ALL"",EDPVISIT,""EMERGENCY DEPARTMENT"",""EDP TRACKING LOG"")"
^XMB(3.9,145831,2,751,0)="""RTN"",""EDPLPCE"",134,0)"
^XMB(3.9,145831,2,752,0)=" Q"
^XMB(3.9,145831,2,753,0)="""RTN"",""EDPLPCE"",135,0)"
^XMB(3.9,145831,2,754,0)="DFLTLOC(DFN) ; Return the default location for the ED"
^XMB(3.9,145831,2,755,0)="""RTN"",""EDPLPCE"",136,0)"
^XMB(3.9,145831,2,756,0)=" N EDPLST,I,LST,TM,BEG,END,LOCS"
^XMB(3.9,145831,2,757,0)="""RTN"",""EDPLPCE"",137,0)"
^XMB(3.9,145831,2,758,0)=" D GETLST^XPAR(.EDPLST,EDPSITE_"";DIC(4,"",""EDPF LOCATION"",""Q"")"
^XMB(3.9,145831,2,759,0)="""RTN"",""EDPLPCE"",138,0)"
^XMB(3.9,145831,2,760,0)=" S TM=$E($P($$NOW^XLFDT,""."",2)_""0000"",1,4)"
^XMB(3.9,145831,2,761,0)="""RTN"",""EDPLPCE"",139,0)"
^XMB(3.9,145831,2,762,0)=" ; put time ranges first, then sequence"
^XMB(3.9,145831,2,763,0)="""RTN"",""EDPLPCE"",140,0)"
^XMB(3.9,145831,2,764,0)=" S I=0 F  S I=$O(EDPLST(I)) Q:'I  D"
^XMB(3.9,145831,2,765,0)="""RTN"",""EDPLPCE"",141,0)"
^XMB(3.9,145831,2,766,0)=" . ; put sequence at end of list"
^XMB(3.9,145831,2,767,0)="""RTN"",""EDPLPCE"",142,0)"
^XMB(3.9,145831,2,768,0)=" . I EDPLST(I)'[""-"" S LST(+EDPLST(I)*1000)=EDPLST(I),LOCS(+$P(EDPLST(I),U,2))="""" Q"
^XMB(3.9,145831,2,769,0)="""RTN"",""EDPLPCE"",143,0)"
^XMB(3.9,145831,2,770,0)=" . ; put time ranges at top of list"
^XMB(3.9,145831,2,771,0)="""RTN"",""EDPLPCE"",144,0)"
^XMB(3.9,145831,2,772,0)=" . S BEG=+$P(EDPLST(I),""-""),END=+$P(EDPLST(I),""-"",2)"
^XMB(3.9,145831,2,773,0)="""RTN"",""EDPLPCE"",145,0)"
^XMB(3.9,145831,2,774,0)=" . I (TM<BEG)!(TM>END) Q  ; eliminating times that don't include NOW"
^XMB(3.9,145831,2,775,0)="""RTN"",""EDPLPCE"",146,0)"
^XMB(3.9,145831,2,776,0)=" . S LST(I)=EDPLST(I),LOCS(+$P(EDPLST(I),U,2))="""""
^XMB(3.9,145831,2,777,0)="""RTN"",""EDPLPCE"",147,0)"
^XMB(3.9,145831,2,778,0)=" ;"
^XMB(3.9,145831,2,779,0)="""RTN"",""EDPLPCE"",148,0)"
^XMB(3.9,145831,2,780,0)=" ; look for visits to ED locations within the last hour"
^XMB(3.9,145831,2,781,0)="""RTN"",""EDPLPCE"",149,0)"
^XMB(3.9,145831,2,782,0)=" N BACKTO,VTM,VLOC,LOC"
^XMB(3.9,145831,2,783,0)="""RTN"",""EDPLPCE"",150,0)"
^XMB(3.9,145831,2,784,0)=" S BACKTO=$$FMADD^XLFDT($$NOW^XLFDT,0,-1),LOC=0"
^XMB(3.9,145831,2,785,0)="""RTN"",""EDPLPCE"",151,0)"
^XMB(3.9,145831,2,786,0)=" I $G(DFN) D"
^XMB(3.9,145831,2,787,0)="""RTN"",""EDPLPCE"",152,0)"
^XMB(3.9,145831,2,788,0)=" . S VTM="""" F  S VTM=$O(^AUPNVSIT(""AET"",DFN,VTM),-1) Q:VTM<BACKTO  D"
^XMB(3.9,145831,2,789,0)="""RTN"",""EDPLPCE"",153,0)"
^XMB(3.9,145831,2,790,0)=" .. S VLOC=0 F  S VLOC=$O(^AUPNVSIT(""AET"",DFN,VTM,VLOC)) Q:'VLOC  D  Q:LOC"
^XMB(3.9,145831,2,791,0)="""RTN"",""EDPLPCE"",154,0)"
^XMB(3.9,145831,2,792,0)=" ... I $D(LOCS(VLOC)) S LOC=VLOC"
^XMB(3.9,145831,2,793,0)="""RTN"",""EDPLPCE"",155,0)"
^XMB(3.9,145831,2,794,0)=" Q:LOC LOC"
^XMB(3.9,145831,2,795,0)="""RTN"",""EDPLPCE"",156,0)"
^XMB(3.9,145831,2,796,0)=" ;"
^XMB(3.9,145831,2,797,0)="""RTN"",""EDPLPCE"",157,0)"
^XMB(3.9,145831,2,798,0)=" ; otherwise, return the highest ranked location"
^XMB(3.9,145831,2,799,0)="""RTN"",""EDPLPCE"",158,0)"
^XMB(3.9,145831,2,800,0)=" S I=$O(LST(0)) S:I LOC=$P(LST(I),U,2)"
^XMB(3.9,145831,2,801,0)="""RTN"",""EDPLPCE"",159,0)"
^XMB(3.9,145831,2,802,0)=" Q LOC"
^XMB(3.9,145831,2,803,0)="""RTN"",""EDPLPCE"",160,0)"
^XMB(3.9,145831,2,804,0)=" ;"
^XMB(3.9,145831,2,805,0)="""RTN"",""EDPLPCE"",161,0)"
^XMB(3.9,145831,2,806,0)="TS4VISIT(DFN,LOC,TS,PRVVISIT) ; Return visit time if there is already a visit"
^XMB(3.9,145831,2,807,0)="""RTN"",""EDPLPCE"",162,0)"
^XMB(3.9,145831,2,808,0)=" N BACKTO,VTM,VLOC,VCAT,NEWTS"
^XMB(3.9,145831,2,809,0)="""RTN"",""EDPLPCE"",163,0)"
^XMB(3.9,145831,2,810,0)=" S BACKTO=$$FMADD^XLFDT($$NOW^XLFDT,0,-1),NEWTS="""""
^XMB(3.9,145831,2,811,0)="""RTN"",""EDPLPCE"",164,0)"
^XMB(3.9,145831,2,812,0)=" S VTM="""" F  S VTM=$O(^AUPNVSIT(""AET"",DFN,VTM),-1) Q:VTM<BACKTO  D"
^XMB(3.9,145831,2,813,0)="""RTN"",""EDPLPCE"",165,0)"
^XMB(3.9,145831,2,814,0)=" . S VLOC=0 F  S VLOC=$O(^AUPNVSIT(""AET"",DFN,VTM,VLOC)) Q:'VLOC  Q:VLOC'=LOC  D"
^XMB(3.9,145831,2,815,0)="""RTN"",""EDPLPCE"",166,0)"
^XMB(3.9,145831,2,816,0)=" .. S VCAT="""" F  S VCAT=$O(^AUPNVSIT(""AET"",DFN,VTM,VLOC,VCAT)) Q:VCAT'=""P""  D"
^XMB(3.9,145831,2,817,0)="""RTN"",""EDPLPCE"",167,0)"
^XMB(3.9,145831,2,818,0)=" ... S NEWTS=VTM"
^XMB(3.9,145831,2,819,0)="""RTN"",""EDPLPCE"",168,0)"
^XMB(3.9,145831,2,820,0)=" ... S PRVVISIT=$O(^AUPNVSIT(""AET"",DFN,VTM,VLOC,VCAT,""""))"
^XMB(3.9,145831,2,821,0)="""RTN"",""EDPLPCE"",169,0)"
^XMB(3.9,145831,2,822,0)=" Q:NEWTS NEWTS"
^XMB(3.9,145831,2,823,0)="""RTN"",""EDPLPCE"",170,0)"
^XMB(3.9,145831,2,824,0)=" Q TS"
^XMB(3.9,145831,2,825,0)="""RTN"",""EDPLPCE"",171,0)"
^XMB(3.9,145831,2,826,0)=" ;"
^XMB(3.9,145831,2,827,0)="""RTN"",""EDPLPCE"",172,0)"
^XMB(3.9,145831,2,828,0)="TEST ; Test creation of encounter"
^XMB(3.9,145831,2,829,0)="""RTN"",""EDPLPCE"",173,0)"
^XMB(3.9,145831,2,830,0)=" N DFN S DFN=100679"
^XMB(3.9,145831,2,831,0)="""RTN"",""EDPLPCE"",174,0)"
^XMB(3.9,145831,2,832,0)=" S LOC=$$GET^XPAR(DUZ(2)_"";DIC(4,"",""EDPF LOCATION"")"
^XMB(3.9,145831,2,833,0)="""RTN"",""EDPLPCE"",175,0)"
^XMB(3.9,145831,2,834,0)=" ;"
^XMB(3.9,145831,2,835,0)="""RTN"",""EDPLPCE"",176,0)"
^XMB(3.9,145831,2,836,0)=" N EDPKG,EDPSRC,OK"
^XMB(3.9,145831,2,837,0)="""RTN"",""EDPLPCE"",177,0)"
^XMB(3.9,145831,2,838,0)=" S EDPKG=$O(^DIC(9.4,""B"",""EMERGENCY DEPARTMENT"",0))"
^XMB(3.9,145831,2,839,0)="""RTN"",""EDPLPCE"",178,0)"
^XMB(3.9,145831,2,840,0)=" S EDPSRC=""EDP TRACKING LOG"""
^XMB(3.9,145831,2,841,0)="""RTN"",""EDPLPCE"",179,0)"
^XMB(3.9,145831,2,842,0)=" S EDPDATA(""ENCOUNTER"",1,""PATIENT"")=DFN"
^XMB(3.9,145831,2,843,0)="""RTN"",""EDPLPCE"",180,0)"
^XMB(3.9,145831,2,844,0)=" S EDPDATA(""ENCOUNTER"",1,""HOS LOC"")=LOC"
^XMB(3.9,145831,2,845,0)="""RTN"",""EDPLPCE"",181,0)"
^XMB(3.9,145831,2,846,0)=" S EDPDATA(""ENCOUNTER"",1,""SERVICE CATEGORY"")=""A"""
^XMB(3.9,145831,2,847,0)="""RTN"",""EDPLPCE"",182,0)"
^XMB(3.9,145831,2,848,0)=" S EDPDATA(""ENCOUNTER"",1,""ENCOUNTER TYPE"")=""P"""
^XMB(3.9,145831,2,849,0)="""RTN"",""EDPLPCE"",183,0)"
^XMB(3.9,145831,2,850,0)=" S EDPDATA(""ENCOUNTER"",1,""ENC D/T"")=$$NOW^XLFDT"
^XMB(3.9,145831,2,851,0)="""RTN"",""EDPLPCE"",184,0)"
^XMB(3.9,145831,2,852,0)=" ;"
^XMB(3.9,145831,2,853,0)="""RTN"",""EDPLPCE"",185,0)"
^XMB(3.9,145831,2,854,0)=" ;S EDPDATA(""DX/PL"",1,""DIAGNOSIS"")=$O(^ICD9(""BA"",""V70.3 "",0))"
^XMB(3.9,145831,2,855,0)="""RTN"",""EDPLPCE"",186,0)"
^XMB(3.9,145831,2,856,0)=" ;S EDPDATA(""PROCEDURE"",1,""PROCEDURE"")=$O(^ICPT(""B"",""99201"",0))"
^XMB(3.9,145831,2,857,0)="""RTN"",""EDPLPCE"",187,0)"
^XMB(3.9,145831,2,858,0)=" S EDPDATA(""PROVIDER"",1,""NAME"")=9066"
^XMB(3.9,145831,2,859,0)="""RTN"",""EDPLPCE"",188,0)"
^XMB(3.9,145831,2,860,0)=" ;"
^XMB(3.9,145831,2,861,0)="""RTN"",""EDPLPCE"",189,0)"
^XMB(3.9,145831,2,862,0)=" S OK=$$DATA2PCE^PXAPI(""EDPDATA"",EDPKG,EDPSRC,.EDPVISIT)"
^XMB(3.9,145831,2,863,0)="""RTN"",""EDPLPCE"",190,0)"
^XMB(3.9,145831,2,864,0)=" Q"
^XMB(3.9,145831,2,865,0)="""RTN"",""EDPVIT"")"
^XMB(3.9,145831,2,866,0)="0^1^B32884634"
^XMB(3.9,145831,2,867,0)="""RTN"",""EDPVIT"",1,0)"
^XMB(3.9,145831,2,868,0)="EDPVIT ;SLC/MKB -- Vitals utilities ;4/25/12 12:51pm"
^XMB(3.9,145831,2,869,0)="""RTN"",""EDPVIT"",2,0)"
^XMB(3.9,145831,2,870,0)=" ;;2.0;EMERGENCY DEPARTMENT;;May 2, 2012;Build 0"
^XMB(3.9,145831,2,871,0)="""RTN"",""EDPVIT"",3,0)"
^XMB(3.9,145831,2,872,0)=" ;"
^XMB(3.9,145831,2,873,0)="""RTN"",""EDPVIT"",4,0)"
^XMB(3.9,145831,2,874,0)="GET(DFN,BEG,END) ; -- Return vitals measurements from BEG to END"
^XMB(3.9,145831,2,875,0)="""RTN"",""EDPVIT"",5,0)"
^XMB(3.9,145831,2,876,0)=" D XML^EDPX(""<Vitals dfn=""""""_$G(DFN)_"""""" >"")"
^XMB(3.9,145831,2,877,0)="""RTN"",""EDPVIT"",6,0)"
^XMB(3.9,145831,2,878,0)=" ;D XML^EDPX(""<Vitals>"")"
^XMB(3.9,145831,2,879,0)="""RTN"",""EDPVIT"",7,0)"
^XMB(3.9,145831,2,880,0)=" S DFN=+$G(DFN) I DFN<1 D ERR(""Missing or invalid patient DFN"") D XML^EDPX(""</Vitals>"") Q"
^XMB(3.9,145831,2,881,0)="""RTN"",""EDPVIT"",8,0)"
^XMB(3.9,145831,2,882,0)=" N LOG,GMRVSTR,IDT,TYPE,IEN,REC,EDPX,LAST,X"
^XMB(3.9,145831,2,883,0)="""RTN"",""EDPVIT"",9,0)"
^XMB(3.9,145831,2,884,0)=" S LOG=+$O(^EDP(230,""APA"",DFN,0))"
^XMB(3.9,145831,2,885,0)="""RTN"",""EDPVIT"",10,0)"
^XMB(3.9,145831,2,886,0)=" S:'$G(END) END=9999999 I '$G(BEG) D"
^XMB(3.9,145831,2,887,0)="""RTN"",""EDPVIT"",11,0)"
^XMB(3.9,145831,2,888,0)=" . I LOG S BEG=+$P($G(^EDP(230,LOG,0)),U,8) ;Time In"
^XMB(3.9,145831,2,889,0)="""RTN"",""EDPVIT"",12,0)"
^XMB(3.9,145831,2,890,0)=" . E  S BEG=$$FMADD^XLFDT($$NOW^XLFDT,-1)   ;Last 24 hours"
^XMB(3.9,145831,2,891,0)="""RTN"",""EDPVIT"",13,0)"
^XMB(3.9,145831,2,892,0)=" S GMRVSTR=""BP;T;R;P;HT;WT;PN"",GMRVSTR(0)=BEG_U_END_""^9999999^1"""
^XMB(3.9,145831,2,893,0)="""RTN"",""EDPVIT"",14,0)"
^XMB(3.9,145831,2,894,0)=" K ^UTILITY($J,""GMRVD"") D EN1^GMRVUT0"
^XMB(3.9,145831,2,895,0)="""RTN"",""EDPVIT"",15,0)"
^XMB(3.9,145831,2,896,0)=" ; ^UTILITY($J,""GMRVD"",IDT,TYPE,IEN) = $P(^GMR(120.5,IEN,0),U,1,9)_"
^XMB(3.9,145831,2,897,0)="""RTN"",""EDPVIT"",16,0)"
^XMB(3.9,145831,2,898,0)=" ;  ^ Qual1 ^ Qual2 ^ * ^ metric ^ BMI ^ L/Min ^ SuppO2% ^ all qual's"
^XMB(3.9,145831,2,899,0)="""RTN"",""EDPVIT"",17,0)"
^XMB(3.9,145831,2,900,0)=" S IDT=""A"" F  S IDT=$O(^UTILITY($J,""GMRVD"",IDT),-1) Q:IDT<1  D"
^XMB(3.9,145831,2,901,0)="""RTN"",""EDPVIT"",18,0)"
^XMB(3.9,145831,2,902,0)=" . K EDPX S EDPX(""time"")=9999999-IDT"
^XMB(3.9,145831,2,903,0)="""RTN"",""EDPVIT"",19,0)"
^XMB(3.9,145831,2,904,0)=" . S TYPE="""" F  S TYPE=$O(^UTILITY($J,""GMRVD"",IDT,TYPE)) Q:TYPE=""""  D"
^XMB(3.9,145831,2,905,0)="""RTN"",""EDPVIT"",20,0)"
^XMB(3.9,145831,2,906,0)=" .. S IEN=$O(^UTILITY($J,""GMRVD"",IDT,TYPE,0)),REC=$G(^(IEN))"
^XMB(3.9,145831,2,907,0)="""RTN"",""EDPVIT"",21,0)"
^XMB(3.9,145831,2,908,0)=" .. S EDPX(TYPE)=$P(REC,U,8),LAST=9999999-IDT"
^XMB(3.9,145831,2,909,0)="""RTN"",""EDPVIT"",22,0)"
^XMB(3.9,145831,2,910,0)=" . ; EDPX(""error"")=""false"" ;for now"
^XMB(3.9,145831,2,911,0)="""RTN"",""EDPVIT"",23,0)"
^XMB(3.9,145831,2,912,0)=" . D XML^EDPX($$XMLA^EDPX(""vital"",.EDPX))"
