^XMB(3.9,144657,2,7977,0)="""RTN"",""IBCNICB"",218,0)"
^XMB(3.9,144657,2,7978,0)=" ;   IBPOLCOM = patient policy COMMENT data"
^XMB(3.9,144657,2,7979,0)="""RTN"",""IBCNICB"",219,0)"
^XMB(3.9,144657,2,7980,0)=" ;"
^XMB(3.9,144657,2,7981,0)="""RTN"",""IBCNICB"",220,0)"
^XMB(3.9,144657,2,7982,0)=" ; Output:"
^XMB(3.9,144657,2,7983,0)="""RTN"",""IBCNICB"",221,0)"
^XMB(3.9,144657,2,7984,0)=" ;   RESULT   = Returned Parameter Array with results of call"
^XMB(3.9,144657,2,7985,0)="""RTN"",""IBCNICB"",222,0)"
^XMB(3.9,144657,2,7986,0)=" ;"
^XMB(3.9,144657,2,7987,0)="""RTN"",""IBCNICB"",223,0)"
^XMB(3.9,144657,2,7988,0)=" N IBDT,IBVCOM"
^XMB(3.9,144657,2,7989,0)="""RTN"",""IBCNICB"",224,0)"
^XMB(3.9,144657,2,7990,0)=" S IBVCOM="""""
^XMB(3.9,144657,2,7991,0)="""RTN"",""IBCNICB"",225,0)"
^XMB(3.9,144657,2,7992,0)=" ;"
^XMB(3.9,144657,2,7993,0)="""RTN"",""IBCNICB"",226,0)"
^XMB(3.9,144657,2,7994,0)=" ; -- get the last comment made for the policy within VistA"
^XMB(3.9,144657,2,7995,0)="""RTN"",""IBCNICB"",227,0)"
^XMB(3.9,144657,2,7996,0)=" S IBDT=$O(^DPT(DFN,.312,IBPOLDA,13,""B"",""""),-1)"
^XMB(3.9,144657,2,7997,0)="""RTN"",""IBCNICB"",228,0)"
^XMB(3.9,144657,2,7998,0)=" I IBDT]"""" S IBCDA=$O(^DPT(DFN,.312,IBPOLDA,13,""B"",IBDT,""""),-1) S IBVCOM=$G(^DPT(DFN,.312,IBPOLDA,13,IBCDA,1))"
^XMB(3.9,144657,2,7999,0)="""RTN"",""IBCNICB"",229,0)"
^XMB(3.9,144657,2,8000,0)=" ;"
^XMB(3.9,144657,2,8001,0)="""RTN"",""IBCNICB"",230,0)"
^XMB(3.9,144657,2,8002,0)=" ; -- no VistA comments for patient policy so go add the new ICB comment"
^XMB(3.9,144657,2,8003,0)="""RTN"",""IBCNICB"",231,0)"
^XMB(3.9,144657,2,8004,0)=" I IBVCOM="""",IBPOLCOM]"""" D ADCOM(DFN,IBPOLDA,IBPOLCOM,.RESULT) Q"
^XMB(3.9,144657,2,8005,0)="""RTN"",""IBCNICB"",232,0)"
^XMB(3.9,144657,2,8006,0)=" ;"
^XMB(3.9,144657,2,8007,0)="""RTN"",""IBCNICB"",233,0)"
^XMB(3.9,144657,2,8008,0)=" ; -- the last comment within VistA is the same comment as the new ICB comment"
^XMB(3.9,144657,2,8009,0)="""RTN"",""IBCNICB"",234,0)"
^XMB(3.9,144657,2,8010,0)=" I IBVCOM=IBPOLCOM Q"
^XMB(3.9,144657,2,8011,0)="""RTN"",""IBCNICB"",235,0)"
^XMB(3.9,144657,2,8012,0)=" ;"
^XMB(3.9,144657,2,8013,0)="""RTN"",""IBCNICB"",236,0)"
^XMB(3.9,144657,2,8014,0)=" ; -- VistA comment is different from ICB comment so add the ICB comment"
^XMB(3.9,144657,2,8015,0)="""RTN"",""IBCNICB"",237,0)"
^XMB(3.9,144657,2,8016,0)=" D ADCOM(DFN,IBPOLDA,IBPOLCOM,.RESULT)"
^XMB(3.9,144657,2,8017,0)="""RTN"",""IBCNICB"",238,0)"
^XMB(3.9,144657,2,8018,0)=" Q"
^XMB(3.9,144657,2,8019,0)="""RTN"",""IBCNICB"",239,0)"
^XMB(3.9,144657,2,8020,0)=" ;"
^XMB(3.9,144657,2,8021,0)="""RTN"",""IBCNICB"",240,0)"
^XMB(3.9,144657,2,8022,0)="ADCOM(DFN,IBPOLDA,IBPOLCOM,RESULT) ; add new entry to the COMMENT - SUBSCRIBER POLICY multiple"
^XMB(3.9,144657,2,8023,0)="""RTN"",""IBCNICB"",241,0)"
^XMB(3.9,144657,2,8024,0)=" ; Input:"
^XMB(3.9,144657,2,8025,0)="""RTN"",""IBCNICB"",242,0)"
^XMB(3.9,144657,2,8026,0)=" ;   DFN      = patient IEN"
^XMB(3.9,144657,2,8027,0)="""RTN"",""IBCNICB"",243,0)"
^XMB(3.9,144657,2,8028,0)=" ;   IBPOLDA  = ien of INSURANCE POLICY at ^DPT(""_DFN_"",.312,"
^XMB(3.9,144657,2,8029,0)="""RTN"",""IBCNICB"",244,0)"
^XMB(3.9,144657,2,8030,0)=" ;   IBPOLCOM = patient policy COMMENT data"
^XMB(3.9,144657,2,8031,0)="""RTN"",""IBCNICB"",245,0)"
^XMB(3.9,144657,2,8032,0)=" ;   DUZ      = user IEN - system wide variable   "
^XMB(3.9,144657,2,8033,0)="""RTN"",""IBCNICB"",246,0)"
^XMB(3.9,144657,2,8034,0)=" ;"
^XMB(3.9,144657,2,8035,0)="""RTN"",""IBCNICB"",247,0)"
^XMB(3.9,144657,2,8036,0)=" ; Output:"
^XMB(3.9,144657,2,8037,0)="""RTN"",""IBCNICB"",248,0)"
^XMB(3.9,144657,2,8038,0)=" ;   RESULT   = Returned Parameter Array with results of call"
^XMB(3.9,144657,2,8039,0)="""RTN"",""IBCNICB"",249,0)"
^XMB(3.9,144657,2,8040,0)=" ;"
^XMB(3.9,144657,2,8041,0)="""RTN"",""IBCNICB"",250,0)"
^XMB(3.9,144657,2,8042,0)=" ; -- lock the COMMENT - SUBSCRIBER POLICY multiple so that previous comments can't be edited"
^XMB(3.9,144657,2,8043,0)="""RTN"",""IBCNICB"",251,0)"
^XMB(3.9,144657,2,8044,0)=" L +^DPT(DFN,.312,IBPOLDA,13):5 I '$T S RESULT(1)=""-1^INSURANCE TYPE (#2.312,1.18) sub-file entry locked, data not updated"" Q"
^XMB(3.9,144657,2,8045,0)="""RTN"",""IBCNICB"",252,0)"
^XMB(3.9,144657,2,8046,0)=" ;"
^XMB(3.9,144657,2,8047,0)="""RTN"",""IBCNICB"",253,0)"
^XMB(3.9,144657,2,8048,0)=" N FDA,IENS,DIERR"
^XMB(3.9,144657,2,8049,0)="""RTN"",""IBCNICB"",254,0)"
^XMB(3.9,144657,2,8050,0)=" ;"
^XMB(3.9,144657,2,8051,0)="""RTN"",""IBCNICB"",255,0)"
^XMB(3.9,144657,2,8052,0)=" ; -- populate the FDA array with data"
^XMB(3.9,144657,2,8053,0)="""RTN"",""IBCNICB"",256,0)"
^XMB(3.9,144657,2,8054,0)=" S IENS=""+1,""_IBPOLDA_"",""_DFN_"","""
^XMB(3.9,144657,2,8055,0)="""RTN"",""IBCNICB"",257,0)"
^XMB(3.9,144657,2,8056,0)=" S FDA(2.342,IENS,.01)=$$NOW^XLFDT()"
^XMB(3.9,144657,2,8057,0)="""RTN"",""IBCNICB"",258,0)"
^XMB(3.9,144657,2,8058,0)=" S FDA(2.342,IENS,.02)=DUZ"
^XMB(3.9,144657,2,8059,0)="""RTN"",""IBCNICB"",259,0)"
^XMB(3.9,144657,2,8060,0)=" S FDA(2.342,IENS,.03)=IBPOLCOM"
^XMB(3.9,144657,2,8061,0)="""RTN"",""IBCNICB"",260,0)"
^XMB(3.9,144657,2,8062,0)=" ;"
^XMB(3.9,144657,2,8063,0)="""RTN"",""IBCNICB"",261,0)"
^XMB(3.9,144657,2,8064,0)=" ; -- update comment"
^XMB(3.9,144657,2,8065,0)="""RTN"",""IBCNICB"",262,0)"
^XMB(3.9,144657,2,8066,0)=" D UPDATE^DIE(,""FDA"",,""DIERR"")"
^XMB(3.9,144657,2,8067,0)="""RTN"",""IBCNICB"",263,0)"
^XMB(3.9,144657,2,8068,0)=" ;"
^XMB(3.9,144657,2,8069,0)="""RTN"",""IBCNICB"",264,0)"
^XMB(3.9,144657,2,8070,0)=" ; -- check for error"
^XMB(3.9,144657,2,8071,0)="""RTN"",""IBCNICB"",265,0)"
^XMB(3.9,144657,2,8072,0)=" I $D(DIERR) S RESULT(1)=""-1^INSURANCE TYPE (#2.312,1.18) error adding comment to INSURANCE TYPE (#2.312,1.18)"""
^XMB(3.9,144657,2,8073,0)="""RTN"",""IBCNICB"",266,0)"
^XMB(3.9,144657,2,8074,0)=" E  S RESULT(1)=0"
^XMB(3.9,144657,2,8075,0)="""RTN"",""IBCNICB"",267,0)"
^XMB(3.9,144657,2,8076,0)=" ;"
^XMB(3.9,144657,2,8077,0)="""RTN"",""IBCNICB"",268,0)"
^XMB(3.9,144657,2,8078,0)=" ; -- unlock comment multiple"
^XMB(3.9,144657,2,8079,0)="""RTN"",""IBCNICB"",269,0)"
^XMB(3.9,144657,2,8080,0)=" L -^DPT(DFN,.312,IBPOLDA,13)"
^XMB(3.9,144657,2,8081,0)="""RTN"",""IBCNICB"",270,0)"
^XMB(3.9,144657,2,8082,0)=" Q"
^XMB(3.9,144657,2,8083,0)="""RTN"",""IBCNICB"",271,0)"
^XMB(3.9,144657,2,8084,0)=" ;"
^XMB(3.9,144657,2,8085,0)="""RTN"",""IBCNICB"",272,0)"
^XMB(3.9,144657,2,8086,0)="EDCOM(IBPOLDA,IBPOLCOM,IBDT) ; edit the existing entry at 2.312,1.18 multiple"
^XMB(3.9,144657,2,8087,0)="""RTN"",""IBCNICB"",273,0)"
^XMB(3.9,144657,2,8088,0)=" ; input - IBPOLDA = ien of INSURANCE POLICY at ^DPT(""_DFN_"",.312,"
^XMB(3.9,144657,2,8089,0)="""RTN"",""IBCNICB"",274,0)"
^XMB(3.9,144657,2,8090,0)=" ;         IBDT = date/time that comment was made"
^XMB(3.9,144657,2,8091,0)="""RTN"",""IBCNICB"",275,0)"
^XMB(3.9,144657,2,8092,0)=" N DA,DIE,DR,IBNM"
^XMB(3.9,144657,2,8093,0)="""RTN"",""IBCNICB"",276,0)"
^XMB(3.9,144657,2,8094,0)=" ; retrieve the latest comment made by the user"
^XMB(3.9,144657,2,8095,0)="""RTN"",""IBCNICB"",277,0)"
^XMB(3.9,144657,2,8096,0)=" S DA=$O(^DPT(DFN,.312,IBPOLDA,13,""BB"",DUZ,IBDT,""""),-1)"
^XMB(3.9,144657,2,8097,0)="""RTN"",""IBCNICB"",278,0)"
^XMB(3.9,144657,2,8098,0)=" S DIE=""^DPT(""_DFN_"",.312,""_IBPOLDA_"",13,"""
^XMB(3.9,144657,2,8099,0)="""RTN"",""IBCNICB"",279,0)"
^XMB(3.9,144657,2,8100,0)=" S DA(2)=DFN,DA(1)=IBPOLDA"
^XMB(3.9,144657,2,8101,0)="""RTN"",""IBCNICB"",280,0)"
^XMB(3.9,144657,2,8102,0)=" ;  retrieve the latest comment made by the user"
^XMB(3.9,144657,2,8103,0)="""RTN"",""IBCNICB"",281,0)"
^XMB(3.9,144657,2,8104,0)=" S IBNM=$$GET1^DIQ(200,DUZ_"","",.01,""E"")"
^XMB(3.9,144657,2,8105,0)="""RTN"",""IBCNICB"",282,0)"
^XMB(3.9,144657,2,8106,0)=" I $G(^DPT(DFN,.312,IBPOLDA,13,DA,1))]"""" S DR="".01///""_$$NOW^XLFDT()_"";.02///""_IBNM_"";.03///""_IBPOLCOM"
^XMB(3.9,144657,2,8107,0)="""RTN"",""IBCNICB"",283,0)"
^XMB(3.9,144657,2,8108,0)=" E  S DR="".01///@;.02///@"""
^XMB(3.9,144657,2,8109,0)="""RTN"",""IBCNICB"",284,0)"
^XMB(3.9,144657,2,8110,0)=" D ^DIE"
^XMB(3.9,144657,2,8111,0)="""RTN"",""IBCNICB"",285,0)"
^XMB(3.9,144657,2,8112,0)=" Q"
^XMB(3.9,144657,2,8113,0)="""RTN"",""IBCNICB"",286,0)"
^XMB(3.9,144657,2,8114,0)=" ;"
^XMB(3.9,144657,2,8115,0)="""RTN"",""IBCNICB"",287,0)"
^XMB(3.9,144657,2,8116,0)="UPDPOL(RESULT,IBBUFDA,DFN,IBINSDA,IBGRPDA,IBPOLDA) ;update a new group into "
^XMB(3.9,144657,2,8117,0)="""RTN"",""IBCNICB"",288,0)"
^XMB(3.9,144657,2,8118,0)=" ;an existing patient policy entry for ICB interface"
^XMB(3.9,144657,2,8119,0)="""RTN"",""IBCNICB"",289,0)"
^XMB(3.9,144657,2,8120,0)=" ;Input"
^XMB(3.9,144657,2,8121,0)="""RTN"",""IBCNICB"",290,0)"
^XMB(3.9,144657,2,8122,0)=" ;  IBBUFDA  - INSURANCE BUFFER (#355.33) file internal entry number (IEN) (Required)"
^XMB(3.9,144657,2,8123,0)="""RTN"",""IBCNICB"",291,0)"
^XMB(3.9,144657,2,8124,0)=" ;  DFN      - PATIENT (#2) file IEN (Required)"
^XMB(3.9,144657,2,8125,0)="""RTN"",""IBCNICB"",292,0)"
^XMB(3.9,144657,2,8126,0)=" ;  IBINSDA  - INSURANCE COMPANY (#36) File IEN if not adding new entry (Optional)"
^XMB(3.9,144657,2,8127,0)="""RTN"",""IBCNICB"",293,0)"
^XMB(3.9,144657,2,8128,0)=" ;  IBGRPDA  - GROUP INSURANCE PLAN (#355.3) File IEN if not adding new entry (Required)"
^XMB(3.9,144657,2,8129,0)="""RTN"",""IBCNICB"",294,0)"
^XMB(3.9,144657,2,8130,0)=" ;  IBPOLDA  - INSURANCE TYPE (#2.312) sub-file of PATIENT (#2) IEN if"
^XMB(3.9,144657,2,8131,0)="""RTN"",""IBCNICB"",295,0)"
^XMB(3.9,144657,2,8132,0)=" ;             not adding new entry (Required)"
^XMB(3.9,144657,2,8133,0)="""RTN"",""IBCNICB"",296,0)"
^XMB(3.9,144657,2,8134,0)=" ;Output:"
^XMB(3.9,144657,2,8135,0)="""RTN"",""IBCNICB"",297,0)"
^XMB(3.9,144657,2,8136,0)=" ;  RESULT(4) - Returned Parameter Array with results of call"
^XMB(3.9,144657,2,8137,0)="""RTN"",""IBCNICB"",298,0)"
^XMB(3.9,144657,2,8138,0)=" ;     RESULT(4) =-1^error message"
^XMB(3.9,144657,2,8139,0)="""RTN"",""IBCNICB"",299,0)"
^XMB(3.9,144657,2,8140,0)=" ;     RESULT(4) =0 ^ message that process was successful or not require"
^XMB(3.9,144657,2,8141,0)="""RTN"",""IBCNICB"",300,0)"
^XMB(3.9,144657,2,8142,0)=" ;"
^XMB(3.9,144657,2,8143,0)="""RTN"",""IBCNICB"",301,0)"
^XMB(3.9,144657,2,8144,0)=" N IBPAT"
^XMB(3.9,144657,2,8145,0)="""RTN"",""IBCNICB"",302,0)"
^XMB(3.9,144657,2,8146,0)=" I $G(IBBUFDA)'>0 S RESULT(4)=""-1^INSURANCE BUFFER (#355.33) IEN required"" Q"
^XMB(3.9,144657,2,8147,0)="""RTN"",""IBCNICB"",303,0)"
^XMB(3.9,144657,2,8148,0)=" I $G(DFN)'>0 S RESULT(4)=""-1^PATIENT (#2) IEN required"" Q"
^XMB(3.9,144657,2,8149,0)="""RTN"",""IBCNICB"",304,0)"
^XMB(3.9,144657,2,8150,0)=" I $G(IBPOLDA)'>0 S RESULT(4)=""-1^INSURANCE TYPE (#2.312) SUB-FILE IEN required"" Q"
^XMB(3.9,144657,2,8151,0)="""RTN"",""IBCNICB"",305,0)"
^XMB(3.9,144657,2,8152,0)=" I $G(^DPT(DFN,.312,IBPOLDA,0))'>0 S RESULT(4)=""-1^PATIENT INSURANCE TYPE(#2.312) entry doesn't exist"" Q"
^XMB(3.9,144657,2,8153,0)="""RTN"",""IBCNICB"",306,0)"
^XMB(3.9,144657,2,8154,0)=" I $G(IBGRPDA)'>0 S RESULT(4)=""-1^GROUP INSURANCE PLAN (#355.3) IEN required"" Q"
^XMB(3.9,144657,2,8155,0)="""RTN"",""IBCNICB"",307,0)"
^XMB(3.9,144657,2,8156,0)=" ;"
^XMB(3.9,144657,2,8157,0)="""RTN"",""IBCNICB"",308,0)"
^XMB(3.9,144657,2,8158,0)=" ; NO changes required"
^XMB(3.9,144657,2,8159,0)="""RTN"",""IBCNICB"",309,0)"
^XMB(3.9,144657,2,8160,0)=" S IBPAT=$G(^DPT(DFN,.312,IBPOLDA,0))"
^XMB(3.9,144657,2,8161,0)="""RTN"",""IBCNICB"",310,0)"
^XMB(3.9,144657,2,8162,0)=" I $G(IBINSDA)>0,$P(IBPAT,U,1)=IBINSDA,$P(IBPAT,U,18)=IBGRPDA S RESULT(4)=""0^NO CHANGE REQUIRE"" Q"
^XMB(3.9,144657,2,8163,0)="""RTN"",""IBCNICB"",311,0)"
^XMB(3.9,144657,2,8164,0)=" I $G(IBINSDA)'>0,$P(IBPAT,U,18)=IBGRPDA S RESULT(4)=""0^NO CHANGE REQUIRE"" Q"
^XMB(3.9,144657,2,8165,0)="""RTN"",""IBCNICB"",312,0)"
^XMB(3.9,144657,2,8166,0)=" ;"
^XMB(3.9,144657,2,8167,0)="""RTN"",""IBCNICB"",313,0)"
^XMB(3.9,144657,2,8168,0)=" ;Additional error checks"
^XMB(3.9,144657,2,8169,0)="""RTN"",""IBCNICB"",314,0)"
^XMB(3.9,144657,2,8170,0)=" I $G(^IBA(355.3,IBGRPDA,0))="""" S RESULT(4)=""-1^GROUP INSURANCE PLAN (#355.3) entry doesn't exist"" Q"
^XMB(3.9,144657,2,8171,0)="""RTN"",""IBCNICB"",315,0)"
^XMB(3.9,144657,2,8172,0)=" I $G(IBINSDA)>0,$G(^DIC(36,IBINSDA,0))="""" S RESULT(4)=""-1^INSURANCE COMPANY (#36) entry doesn't exist"" Q"
^XMB(3.9,144657,2,8173,0)="""RTN"",""IBCNICB"",316,0)"
^XMB(3.9,144657,2,8174,0)=" I $G(IBINSDA)>0,$P($G(^IBA(355.3,IBGRPDA,0)),U,1)'=IBINSDA S RESULT(4)=""-1^GROUP INSURANCE PLAN (#355.3) entry points to different INSURANCE COMPANY (#36) entry"" Q"
^XMB(3.9,144657,2,8175,0)="""RTN"",""IBCNICB"",317,0)"
^XMB(3.9,144657,2,8176,0)=" I $G(IBINSDA)'>0,$P($G(^IBA(355.3,IBGRPDA,0)),U,1)'=$P(IBPAT,U,1) S RESULT(4)=""-1^GROUP INSURANCE PLAN (#355.3) entry points to different INSURANCE COMPANY (#36) entry"" Q"
^XMB(3.9,144657,2,8177,0)="""RTN"",""IBCNICB"",318,0)"
^XMB(3.9,144657,2,8178,0)=" ;"
^XMB(3.9,144657,2,8179,0)="""RTN"",""IBCNICB"",319,0)"
^XMB(3.9,144657,2,8180,0)=" D CLEANUP"
^XMB(3.9,144657,2,8181,0)="""RTN"",""IBCNICB"",320,0)"
^XMB(3.9,144657,2,8182,0)=" ;"
^XMB(3.9,144657,2,8183,0)="""RTN"",""IBCNICB"",321,0)"
^XMB(3.9,144657,2,8184,0)=" L +^DPT(DFN,.312,IBPOLDA):5 I '$T S RESULT(4)=""-1^INSURANCE TYPE (#2.312) SUB-FILE ENTRY LOCKED, DATA NOT UPDATED"" Q"
^XMB(3.9,144657,2,8185,0)="""RTN"",""IBCNICB"",322,0)"
^XMB(3.9,144657,2,8186,0)=" ;"
^XMB(3.9,144657,2,8187,0)="""RTN"",""IBCNICB"",323,0)"
^XMB(3.9,144657,2,8188,0)=" N IBXIFN,IBFIELDS,IBERR"
^XMB(3.9,144657,2,8189,0)="""RTN"",""IBCNICB"",324,0)"
^XMB(3.9,144657,2,8190,0)=" S IBXIFN=IBPOLDA_"",""_DFN_"","""
^XMB(3.9,144657,2,8191,0)="""RTN"",""IBCNICB"",325,0)"
^XMB(3.9,144657,2,8192,0)=" I $G(IBINSDA) S IBFIELDS(2.312,IBXIFN,.01)=IBINSDA"
^XMB(3.9,144657,2,8193,0)="""RTN"",""IBCNICB"",326,0)"
^XMB(3.9,144657,2,8194,0)=" S IBFIELDS(2.312,IBXIFN,.18)=IBGRPDA ;policy's group/plan always update "
^XMB(3.9,144657,2,8195,0)="""RTN"",""IBCNICB"",327,0)"
^XMB(3.9,144657,2,8196,0)=" Q:'$D(IBFIELDS)"
^XMB(3.9,144657,2,8197,0)="""RTN"",""IBCNICB"",328,0)"
^XMB(3.9,144657,2,8198,0)=" ;Source"
^XMB(3.9,144657,2,8199,0)="""RTN"",""IBCNICB"",329,0)"
^XMB(3.9,144657,2,8200,0)=" S IBFIELDS(2.312,IBXIFN,1.09)=$P($G(^IBA(355.33,+$G(IBBUFDA),0)),U,3)"
^XMB(3.9,144657,2,8201,0)="""RTN"",""IBCNICB"",330,0)"
^XMB(3.9,144657,2,8202,0)=" ;Source Date"
^XMB(3.9,144657,2,8203,0)="""RTN"",""IBCNICB"",331,0)"
^XMB(3.9,144657,2,8204,0)=" S IBFIELDS(2.312,IBXIFN,1.1)=+$G(^IBA(355.33,+$G(IBBUFDA),0))"
^XMB(3.9,144657,2,8205,0)="""RTN"",""IBCNICB"",332,0)"
^XMB(3.9,144657,2,8206,0)=" D FILE^DIE("""",""IBFIELDS"",""IBERR"")"
^XMB(3.9,144657,2,8207,0)="""RTN"",""IBCNICB"",333,0)"
^XMB(3.9,144657,2,8208,0)=" I $D(IBERR)>0 S RESULT(4)=""-1^Fileman DIE error"""
^XMB(3.9,144657,2,8209,0)="""RTN"",""IBCNICB"",334,0)"
^XMB(3.9,144657,2,8210,0)=" I $D(IBERR)'>0 S RESULT(4)=""0^Data successfully updated"""
^XMB(3.9,144657,2,8211,0)="""RTN"",""IBCNICB"",335,0)"
^XMB(3.9,144657,2,8212,0)=" L -^DPT(DFN,.312,IBPOLDA)"
^XMB(3.9,144657,2,8213,0)="""RTN"",""IBCNICB"",336,0)"
^XMB(3.9,144657,2,8214,0)=" Q"
^XMB(3.9,144657,2,8215,0)="""RTN"",""IBCNICB"",337,0)"
^XMB(3.9,144657,2,8216,0)=" ;"
^XMB(3.9,144657,2,8217,0)="""RTN"",""IBCNICB"",338,0)"
^XMB(3.9,144657,2,8218,0)="CLEANUP ;This logic will delete obsolete Individual Plans, Repoint Insurance "
^XMB(3.9,144657,2,8219,0)="""RTN"",""IBCNICB"",339,0)"
^XMB(3.9,144657,2,8220,0)=" ;Reviews if Insurance Company changes, and Remove any Old Benefits Used."
^XMB(3.9,144657,2,8221,0)="""RTN"",""IBCNICB"",340,0)"
^XMB(3.9,144657,2,8222,0)=" N IBPAT,IBOLDINS,IBOLDGRP,IBIP,IBT,IBTNODE0,IBTNODE1,IBFIELDS,IBARR"
^XMB(3.9,144657,2,8223,0)="""RTN"",""IBCNICB"",341,0)"
^XMB(3.9,144657,2,8224,0)=" S IBPAT=$G(^DPT(DFN,.312,IBPOLDA,0))"
^XMB(3.9,144657,2,8225,0)="""RTN"",""IBCNICB"",342,0)"
^XMB(3.9,144657,2,8226,0)=" S IBOLDINS=$P(IBPAT,U,1),IBOLDGRP=$P(IBPAT,U,18)"
^XMB(3.9,144657,2,8227,0)="""RTN"",""IBCNICB"",343,0)"
^XMB(3.9,144657,2,8228,0)=" S IBIP=$P($G(^IBA(355.3,+$P(IBPAT,U,18),0)),U,2)"
^XMB(3.9,144657,2,8229,0)="""RTN"",""IBCNICB"",344,0)"
^XMB(3.9,144657,2,8230,0)=" ;If Old Group Insurance Plan is an Individual Plan with only one"
^XMB(3.9,144657,2,8231,0)="""RTN"",""IBCNICB"",345,0)"
^XMB(3.9,144657,2,8232,0)=" ;subscriber for the same Patient Insurance Policy Entry, delete it"
^XMB(3.9,144657,2,8233,0)="""RTN"",""IBCNICB"",346,0)"
^XMB(3.9,144657,2,8234,0)=" I IBIP=0,$$SUBS^IBCNSJ(IBOLDINS,IBOLDGRP,,""IBARR"")'>1,($D(IBARR(DFN,IBPOLDA))>0) D DEL^IBCNSJ(IBOLDGRP)"
^XMB(3.9,144657,2,8235,0)="""RTN"",""IBCNICB"",347,0)"
^XMB(3.9,144657,2,8236,0)=" ;If changing to a new Insurance Company"
^XMB(3.9,144657,2,8237,0)="""RTN"",""IBCNICB"",348,0)"
^XMB(3.9,144657,2,8238,0)=" I $G(IBINSDA)>0,IBOLDINS'=IBINSDA D  Q"
^XMB(3.9,144657,2,8239,0)="""RTN"",""IBCNICB"",349,0)"
^XMB(3.9,144657,2,8240,0)=" . ; - repoint all Insurance Reviews to new company"
^XMB(3.9,144657,2,8241,0)="""RTN"",""IBCNICB"",350,0)"
^XMB(3.9,144657,2,8242,0)=" . I $$IR^IBCNSJ21(DFN,IBPOLDA) D"
^XMB(3.9,144657,2,8243,0)="""RTN"",""IBCNICB"",351,0)"
^XMB(3.9,144657,2,8244,0)=" . S IBT=0"
^XMB(3.9,144657,2,8245,0)="""RTN"",""IBCNICB"",352,0)"
^XMB(3.9,144657,2,8246,0)=" . F  S IBT=$O(^IBT(356.2,""D"",DFN,IBT)) Q:'IBT  D"
^XMB(3.9,144657,2,8247,0)="""RTN"",""IBCNICB"",353,0)"
^XMB(3.9,144657,2,8248,0)=" . . S IBTNODE0=$G(^IBT(356.2,IBT,0)),IBTNODE1=$G(^IBT(356.2,IBT,1))"
^XMB(3.9,144657,2,8249,0)="""RTN"",""IBCNICB"",354,0)"
^XMB(3.9,144657,2,8250,0)=" . . I $P(IBTNODE1,U,5)=IBPOLDA,$P(IBTNODE0,U,8)'=IBINSDA D"
^XMB(3.9,144657,2,8251,0)="""RTN"",""IBCNICB"",355,0)"
^XMB(3.9,144657,2,8252,0)=" . . . S IBFIELDS(356.2,IBT_"","",.08)=IBINSDA"
^XMB(3.9,144657,2,8253,0)="""RTN"",""IBCNICB"",356,0)"
^XMB(3.9,144657,2,8254,0)=" . . . D FILE^DIE("""",""IBFIELDS"")"
^XMB(3.9,144657,2,8255,0)="""RTN"",""IBCNICB"",357,0)"
^XMB(3.9,144657,2,8256,0)=" ;Delete Benefits Used (#355.5) corresponding to old Patient Group Plan"
^XMB(3.9,144657,2,8257,0)="""RTN"",""IBCNICB"",358,0)"
^XMB(3.9,144657,2,8258,0)=" D DELBU"
^XMB(3.9,144657,2,8259,0)="""RTN"",""IBCNICB"",359,0)"
^XMB(3.9,144657,2,8260,0)=" Q"
^XMB(3.9,144657,2,8261,0)="""RTN"",""IBCNICB"",360,0)"
^XMB(3.9,144657,2,8262,0)=" ;"
^XMB(3.9,144657,2,8263,0)="""RTN"",""IBCNICB"",361,0)"
^XMB(3.9,144657,2,8264,0)="DELBU ;Delete Benefits Used"
^XMB(3.9,144657,2,8265,0)="""RTN"",""IBCNICB"",362,0)"
^XMB(3.9,144657,2,8266,0)=" N IBCDFN,IBPLAN,IBBU"
^XMB(3.9,144657,2,8267,0)="""RTN"",""IBCNICB"",363,0)"
^XMB(3.9,144657,2,8268,0)=" S IBCDFN=IBPOLDA,IBPLAN=IBOLDGRP"
^XMB(3.9,144657,2,8269,0)="""RTN"",""IBCNICB"",364,0)"
^XMB(3.9,144657,2,8270,0)=" ;Get Benefits Used"
^XMB(3.9,144657,2,8271,0)="""RTN"",""IBCNICB"",365,0)"
^XMB(3.9,144657,2,8272,0)=" D BU^IBCNSJ21"
^XMB(3.9,144657,2,8273,0)="""RTN"",""IBCNICB"",366,0)"
^XMB(3.9,144657,2,8274,0)=" ;If there are Benefits Used, then delete them"
^XMB(3.9,144657,2,8275,0)="""RTN"",""IBCNICB"",367,0)"
^XMB(3.9,144657,2,8276,0)=" I $O(IBBU(0)) D"
^XMB(3.9,144657,2,8277,0)="""RTN"",""IBCNICB"",368,0)"
^XMB(3.9,144657,2,8278,0)=" . N IBDAT"
^XMB(3.9,144657,2,8279,0)="""RTN"",""IBCNICB"",369,0)"
^XMB(3.9,144657,2,8280,0)=" . S IBDAT="""""
^XMB(3.9,144657,2,8281,0)="""RTN"",""IBCNICB"",370,0)"
^XMB(3.9,144657,2,8282,0)=" . F  S IBDAT=$O(IBBU(IBDAT)) Q:IBDAT=""""  D DBU^IBCNSJ(IBBU(IBDAT))"
^XMB(3.9,144657,2,8283,0)="""RTN"",""IBCNICB"",371,0)"
^XMB(3.9,144657,2,8284,0)=" Q"
^XMB(3.9,144657,2,8285,0)="""RTN"",""IBCNINS"")"
^XMB(3.9,144657,2,8286,0)="0^2^B9824142"
^XMB(3.9,144657,2,8287,0)="""RTN"",""IBCNINS"",1,0)"
^XMB(3.9,144657,2,8288,0)="IBCNINS ;AITC/TAZ - NIGHTLY INSURANCE PROCESS ; 23-NOV-2020"
^XMB(3.9,144657,2,8289,0)="""RTN"",""IBCNINS"",2,0)"
^XMB(3.9,144657,2,8290,0)=" ;;2.0;INTEGRATED BILLING;**687,771,806**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,8291,0)="""RTN"",""IBCNINS"",3,0)"
^XMB(3.9,144657,2,8292,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,8293,0)="""RTN"",""IBCNINS"",4,0)"
^XMB(3.9,144657,2,8294,0)=" ;"
^XMB(3.9,144657,2,8295,0)="""RTN"",""IBCNINS"",5,0)"
^XMB(3.9,144657,2,8296,0)=" Q"
^XMB(3.9,144657,2,8297,0)="""RTN"",""IBCNINS"",6,0)"
^XMB(3.9,144657,2,8298,0)=" ;"
^XMB(3.9,144657,2,8299,0)="""RTN"",""IBCNINS"",7,0)"
^XMB(3.9,144657,2,8300,0)="EN ;Main Entry Point for Nightly Process"
^XMB(3.9,144657,2,8301,0)="""RTN"",""IBCNINS"",8,0)"
^XMB(3.9,144657,2,8302,0)=" ;"
^XMB(3.9,144657,2,8303,0)="""RTN"",""IBCNINS"",9,0)"
^XMB(3.9,144657,2,8304,0)=" ; Checking for non-human users"
^XMB(3.9,144657,2,8305,0)="""RTN"",""IBCNINS"",10,0)"
^XMB(3.9,144657,2,8306,0)=" D CHKPER"
^XMB(3.9,144657,2,8307,0)="""RTN"",""IBCNINS"",11,0)"
^XMB(3.9,144657,2,8308,0)=" ;"
^XMB(3.9,144657,2,8309,0)="""RTN"",""IBCNINS"",12,0)"
^XMB(3.9,144657,2,8310,0)=" ; Add Buffer Cleanup, Reject Duplicate entries - IB*806/CKB"
^XMB(3.9,144657,2,8311,0)="""RTN"",""IBCNINS"",13,0)"
^XMB(3.9,144657,2,8312,0)=" N IBNUM,IBQUAL,IBRUN"
^XMB(3.9,144657,2,8313,0)="""RTN"",""IBCNINS"",14,0)"
^XMB(3.9,144657,2,8314,0)=" ; Only run if the proxy user 'IB,BUFFER CLEANUP' exists"
^XMB(3.9,144657,2,8315,0)="""RTN"",""IBCNINS"",15,0)"
^XMB(3.9,144657,2,8316,0)=" I +$$FIND1^DIC(200,,""MX"",""IB,BUFFER CLEANUP"") D"
^XMB(3.9,144657,2,8317,0)="""RTN"",""IBCNINS"",16,0)"
^XMB(3.9,144657,2,8318,0)=" . ;IBRUN=1 Run cleanup ; IBQUAL=""A""=All/""N""=# of entries ; IBNUM=(IBQUAL=A)=""""/(IBQUAL=N)=# of entries"
^XMB(3.9,144657,2,8319,0)="""RTN"",""IBCNINS"",17,0)"
^XMB(3.9,144657,2,8320,0)=" . S IBRUN=1,IBQUAL=""A"",IBNUM="""""
^XMB(3.9,144657,2,8321,0)="""RTN"",""IBCNINS"",18,0)"
^XMB(3.9,144657,2,8322,0)=" . D BUFCLN^IBJPI3(IBRUN,IBQUAL,IBNUM)"
^XMB(3.9,144657,2,8323,0)="""RTN"",""IBCNINS"",19,0)"
^XMB(3.9,144657,2,8324,0)=" ; "
^XMB(3.9,144657,2,8325,0)="""RTN"",""IBCNINS"",20,0)"
^XMB(3.9,144657,2,8326,0)=" ; Process Nightly IIU Cleanup if IIU is Nationally Enabled."
^XMB(3.9,144657,2,8327,0)="""RTN"",""IBCNINS"",21,0)"
^XMB(3.9,144657,2,8328,0)=" I $$GET1^DIQ(350.9,""1,"",53.01,""I"")=""Y"" D NIGHT^IBCNIUHL"
^XMB(3.9,144657,2,8329,0)="""RTN"",""IBCNINS"",22,0)"
^XMB(3.9,144657,2,8330,0)=" ;"
^XMB(3.9,144657,2,8331,0)="""RTN"",""IBCNINS"",23,0)"
^XMB(3.9,144657,2,8332,0)=" ; Purge IIU File (#365.19) honoring the parameters in file (#350.9)"
^XMB(3.9,144657,2,8333,0)="""RTN"",""IBCNINS"",24,0)"
^XMB(3.9,144657,2,8334,0)=" D EN^IBCNIUK"
^XMB(3.9,144657,2,8335,0)="""RTN"",""IBCNINS"",25,0)"
^XMB(3.9,144657,2,8336,0)=" ;"
^XMB(3.9,144657,2,8337,0)="""RTN"",""IBCNINS"",26,0)"
^XMB(3.9,144657,2,8338,0)=" ; Process Nightly eIV Process"
^XMB(3.9,144657,2,8339,0)="""RTN"",""IBCNINS"",27,0)"
^XMB(3.9,144657,2,8340,0)=" D EN^IBCNEDE"
^XMB(3.9,144657,2,8341,0)="""RTN"",""IBCNINS"",28,0)"
^XMB(3.9,144657,2,8342,0)=" ;"
^XMB(3.9,144657,2,8343,0)="""RTN"",""IBCNINS"",29,0)"
^XMB(3.9,144657,2,8344,0)=" ; Send Daily Buffer Report email - Summary Version from production sites only"
^XMB(3.9,144657,2,8345,0)="""RTN"",""IBCNINS"",30,0)"
^XMB(3.9,144657,2,8346,0)=" I $$PROD^XUPROD(1) D DBR^IBCNOR2"
^XMB(3.9,144657,2,8347,0)="""RTN"",""IBCNINS"",31,0)"
^XMB(3.9,144657,2,8348,0)=" ;"
^XMB(3.9,144657,2,8349,0)="""RTN"",""IBCNINS"",32,0)"
^XMB(3.9,144657,2,8350,0)="ENQ ;Exit"
^XMB(3.9,144657,2,8351,0)="""RTN"",""IBCNINS"",33,0)"
^XMB(3.9,144657,2,8352,0)=" Q"
^XMB(3.9,144657,2,8353,0)="""RTN"",""IBCNINS"",34,0)"
^XMB(3.9,144657,2,8354,0)=" ;"
^XMB(3.9,144657,2,8355,0)="""RTN"",""IBCNINS"",35,0)"
^XMB(3.9,144657,2,8356,0)=" ;-------------------------------------------------------"
^XMB(3.9,144657,2,8357,0)="""RTN"",""IBCNINS"",36,0)"
^XMB(3.9,144657,2,8358,0)="CHKPER ;"
^XMB(3.9,144657,2,8359,0)="""RTN"",""IBCNINS"",37,0)"
^XMB(3.9,144657,2,8360,0)=" ; Check for the existence of the New Person (#200) entries listed below."
^XMB(3.9,144657,2,8361,0)="""RTN"",""IBCNINS"",38,0)"
^XMB(3.9,144657,2,8362,0)=" ; Send a mailman message to ""VHAeInsuranceRapidResponse@domain.ext"" if any are missing."
^XMB(3.9,144657,2,8363,0)="""RTN"",""IBCNINS"",39,0)"
^XMB(3.9,144657,2,8364,0)=" ; Entries to check: ""INTERFACE,IB IIU"", ""INTERFACE,IB EIV"", ""AUTOUPDATE,IBEIV"", ""IB,BUFFER CLEANUP"""
^XMB(3.9,144657,2,8365,0)="""RTN"",""IBCNINS"",40,0)"
^XMB(3.9,144657,2,8366,0)=" N IBAUTO,IBEIV,IBIIU,WKDT,IBMCT,MSG,MGRP,IBXMY"
^XMB(3.9,144657,2,8367,0)="""RTN"",""IBCNINS"",41,0)"
^XMB(3.9,144657,2,8368,0)=" N IBBUFCLN S IBBUFCLN=""""  ;IB*806/DTG new var for IB Buffer Cleanup"
^XMB(3.9,144657,2,8369,0)="""RTN"",""IBCNINS"",42,0)"
^XMB(3.9,144657,2,8370,0)=" ;"
^XMB(3.9,144657,2,8371,0)="""RTN"",""IBCNINS"",43,0)"
^XMB(3.9,144657,2,8372,0)=" S IBIIU=+$$FIND1^DIC(200,,""MX"",""INTERFACE,IB IIU"")"
^XMB(3.9,144657,2,8373,0)="""RTN"",""IBCNINS"",44,0)"
^XMB(3.9,144657,2,8374,0)=" S IBAUTO=+$$FIND1^DIC(200,,""MX"",""AUTOUPDATE,IBEIV""),IBEIV=+$$FIND1^DIC(200,,""MX"",""INTERFACE,IB EIV"")"
^XMB(3.9,144657,2,8375,0)="""RTN"",""IBCNINS"",45,0)"
^XMB(3.9,144657,2,8376,0)=" S IBBUFCLN=+$$FIND1^DIC(200,,""MX"",""IB,BUFFER CLEANUP"")  ; IB*806/DTG new var for IB Buffer Cleanup"
^XMB(3.9,144657,2,8377,0)="""RTN"",""IBCNINS"",46,0)"
^XMB(3.9,144657,2,8378,0)=" ;I IBIIU,IBAUTO,IBEIV Q"
^XMB(3.9,144657,2,8379,0)="""RTN"",""IBCNINS"",47,0)"
^XMB(3.9,144657,2,8380,0)=" I IBIIU,IBAUTO,IBEIV,IBBUFCLN Q  ; IB*806/DTG new var for IB Buffer Cleanup"
^XMB(3.9,144657,2,8381,0)="""RTN"",""IBCNINS"",48,0)"
^XMB(3.9,144657,2,8382,0)=" ;"
^XMB(3.9,144657,2,8383,0)="""RTN"",""IBCNINS"",49,0)"
^XMB(3.9,144657,2,8384,0)=" S WKDT=$$SITE^VASITE()"
^XMB(3.9,144657,2,8385,0)="""RTN"",""IBCNINS"",50,0)"
^XMB(3.9,144657,2,8386,0)=" S MSG(1)=""Missing EIV New Person entries, for station ""_$P(WKDT,U,3)_"":""_$P(WKDT,U,2)"
^XMB(3.9,144657,2,8387,0)="""RTN"",""IBCNINS"",51,0)"
^XMB(3.9,144657,2,8388,0)=" S MSG(2)=""-------------------------------------------------------------------------------"""
^XMB(3.9,144657,2,8389,0)="""RTN"",""IBCNINS"",52,0)"
^XMB(3.9,144657,2,8390,0)=" S IBMCT=2"
^XMB(3.9,144657,2,8391,0)="""RTN"",""IBCNINS"",53,0)"
^XMB(3.9,144657,2,8392,0)=" I 'IBIIU S MSG(IBMCT)=""Entry for 'INTERFACE,IB IIU' is missing"",IBMCT=IBMCT+1"
^XMB(3.9,144657,2,8393,0)="""RTN"",""IBCNINS"",54,0)"
^XMB(3.9,144657,2,8394,0)=" I 'IBAUTO S MSG(IBMCT)=""Entry for 'AUTOUPDATE,IBEIV' is missing"",IBMCT=IBMCT+1"
^XMB(3.9,144657,2,8395,0)="""RTN"",""IBCNINS"",55,0)"
^XMB(3.9,144657,2,8396,0)=" I 'IBEIV S MSG(IBMCT)=""Entry for 'INTERFACE,IB EIV' is missing"",IBMCT=IBMCT+1"
^XMB(3.9,144657,2,8397,0)="""RTN"",""IBCNINS"",56,0)"
^XMB(3.9,144657,2,8398,0)=" I 'IBBUFCLN S MSG(IBMCT)=""Entry for 'IB,BUFFER CLEANUP' is missing"",IBMCT=IBMCT+1"
^XMB(3.9,144657,2,8399,0)="""RTN"",""IBCNINS"",57,0)"
^XMB(3.9,144657,2,8400,0)=" S MSG(IBMCT)=""-------------------------------------------------------------------------------"""
^XMB(3.9,144657,2,8401,0)="""RTN"",""IBCNINS"",58,0)"
^XMB(3.9,144657,2,8402,0)=" S MGRP=$$MGRP^IBCNEUT5()"
^XMB(3.9,144657,2,8403,0)="""RTN"",""IBCNINS"",59,0)"
^XMB(3.9,144657,2,8404,0)=" ;"
^XMB(3.9,144657,2,8405,0)="""RTN"",""IBCNINS"",60,0)"
^XMB(3.9,144657,2,8406,0)=" ; Check for production account and made sure eInsurance mailgroup is self documenting"
^XMB(3.9,144657,2,8407,0)="""RTN"",""IBCNINS"",61,0)"
^XMB(3.9,144657,2,8408,0)=" I $$PROD^XUPROD(1) S IBXMY(""VHAeInsuranceRapidResponse@domain.ext"")="""""
^XMB(3.9,144657,2,8409,0)="""RTN"",""IBCNINS"",62,0)"
^XMB(3.9,144657,2,8410,0)=" D MSG^IBCNEUT5(MGRP,""Missing eInsurance New Person entries (""_$P(WKDT,U,3)_"")"",""MSG("",,.IBXMY)  ;sends to postmaster if IBXMY is empty"
^XMB(3.9,144657,2,8411,0)="""RTN"",""IBCNINS"",63,0)"
^XMB(3.9,144657,2,8412,0)=" Q"
^XMB(3.9,144657,2,8413,0)="""RTN"",""IBCNINSU"")"
^XMB(3.9,144657,2,8414,0)="0^3^B16859178"
^XMB(3.9,144657,2,8415,0)="""RTN"",""IBCNINSU"",1,0)"
^XMB(3.9,144657,2,8416,0)="IBCNINSU ;AITC/TAZ - GENERAL INSURANCE UTILITIES ;8/20/20 12:46p.m."
^XMB(3.9,144657,2,8417,0)="""RTN"",""IBCNINSU"",2,0)"
^XMB(3.9,144657,2,8418,0)=" ;;2.0;INTEGRATED BILLING;**668,687,713,737**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,8419,0)="""RTN"",""IBCNINSU"",3,0)"
^XMB(3.9,144657,2,8420,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,8421,0)="""RTN"",""IBCNINSU"",4,0)"
^XMB(3.9,144657,2,8422,0)=" ;"
^XMB(3.9,144657,2,8423,0)="""RTN"",""IBCNINSU"",5,0)"
^XMB(3.9,144657,2,8424,0)="PAYER(PIEN,APP,FLDS,FLGS,ARRAY) ;Payer Data Retrieval"
^XMB(3.9,144657,2,8425,0)="""RTN"",""IBCNINSU"",6,0)"
^XMB(3.9,144657,2,8426,0)=" ;INPUT"
^XMB(3.9,144657,2,8427,0)="""RTN"",""IBCNINSU"",7,0)"
^XMB(3.9,144657,2,8428,0)=" ; * = required input"
^XMB(3.9,144657,2,8429,0)="""RTN"",""IBCNINSU"",8,0)"
^XMB(3.9,144657,2,8430,0)=" ; * PIEN     - Payer IEN"
^XMB(3.9,144657,2,8431,0)="""RTN"",""IBCNINSU"",9,0)"
^XMB(3.9,144657,2,8432,0)=" ;   APP      - EIV - Returns all fields for Payer Level and EIV level of file (overrides FLDS)"
^XMB(3.9,144657,2,8433,0)="""RTN"",""IBCNINSU"",10,0)"
^XMB(3.9,144657,2,8434,0)=" ;            - IIU - Returns all fields for Payer Level and IIU level of file (overrides FLDS)"
^XMB(3.9,144657,2,8435,0)="""RTN"",""IBCNINSU"",11,0)"
^XMB(3.9,144657,2,8436,0)=" ; * FLDS     - Required only if APP is null; If APP is populated this parameter is ignored"
^XMB(3.9,144657,2,8437,0)="""RTN"",""IBCNINSU"",12,0)"
^XMB(3.9,144657,2,8438,0)=" ;            - A single field number"
^XMB(3.9,144657,2,8439,0)="""RTN"",""IBCNINSU"",13,0)"
^XMB(3.9,144657,2,8440,0)=" ;            - A list of field numbers, separated by semicolons"
^XMB(3.9,144657,2,8441,0)="""RTN"",""IBCNINSU"",14,0)"
^XMB(3.9,144657,2,8442,0)=" ;            - A range of field numbers, in the form M:N, where M and N are the end points of the inclusive range. "
^XMB(3.9,144657,2,8443,0)="""RTN"",""IBCNINSU"",15,0)"
^XMB(3.9,144657,2,8444,0)=" ;              All field numbers within this range are retrieved."
^XMB(3.9,144657,2,8445,0)="""RTN"",""IBCNINSU"",16,0)"
^XMB(3.9,144657,2,8446,0)=" ;            - * for all fields at the top level (no sub-multiple record)."
^XMB(3.9,144657,2,8447,0)="""RTN"",""IBCNINSU"",17,0)"
^XMB(3.9,144657,2,8448,0)=" ;            - ** for all fields including all fields and data in sub-multiple fields."
^XMB(3.9,144657,2,8449,0)="""RTN"",""IBCNINSU"",18,0)"
^XMB(3.9,144657,2,8450,0)=" ;            - Field number of a multiple followed by an * to indicate all fields and records in the sub-multiple "
^XMB(3.9,144657,2,8451,0)="""RTN"",""IBCNINSU"",19,0)"
^XMB(3.9,144657,2,8452,0)=" ;              for that field."
^XMB(3.9,144657,2,8453,0)="""RTN"",""IBCNINSU"",20,0)"
^XMB(3.9,144657,2,8454,0)=" ;   FLGS     - E Returns External values in nodes ending with ""E""."
^XMB(3.9,144657,2,8455,0)="""RTN"",""IBCNINSU"",21,0)"
^XMB(3.9,144657,2,8456,0)=" ;            - I Returns Internal values in nodes ending with ""I"". "
^XMB(3.9,144657,2,8457,0)="""RTN"",""IBCNINSU"",22,0)"
^XMB(3.9,144657,2,8458,0)=" ;            - NULL Returns External values."
^XMB(3.9,144657,2,8459,0)="""RTN"",""IBCNINSU"",23,0)"
^XMB(3.9,144657,2,8460,0)=" ; * ARRAY    - Name of the Array that will contain the data (passed by reference)"
^XMB(3.9,144657,2,8461,0)="""RTN"",""IBCNINSU"",24,0)"
^XMB(3.9,144657,2,8462,0)=" ;"
^XMB(3.9,144657,2,8463,0)="""RTN"",""IBCNINSU"",25,0)"
^XMB(3.9,144657,2,8464,0)=" ;OUTPUT"
^XMB(3.9,144657,2,8465,0)="""RTN"",""IBCNINSU"",26,0)"
^XMB(3.9,144657,2,8466,0)=" ;   ARRAY    - Data requested is returned in the array that was passed by reference"
^XMB(3.9,144657,2,8467,0)="""RTN"",""IBCNINSU"",27,0)"
^XMB(3.9,144657,2,8468,0)=" ;"
^XMB(3.9,144657,2,8469,0)="""RTN"",""IBCNINSU"",28,0)"
^XMB(3.9,144657,2,8470,0)=" N APPIEN,APPIENI,IENS"
^XMB(3.9,144657,2,8471,0)="""RTN"",""IBCNINSU"",29,0)"
^XMB(3.9,144657,2,8472,0)=" I '$G(PIEN) S ARRAY(0)=""Payer IEN is null or invalid"" G PAYERX"
^XMB(3.9,144657,2,8473,0)="""RTN"",""IBCNINSU"",30,0)"
^XMB(3.9,144657,2,8474,0)=" I $G(APP)="""",($G(FLDS)="""") S ARRAY(0)=""No fields requested."" G PAYERX"
^XMB(3.9,144657,2,8475,0)="""RTN"",""IBCNINSU"",31,0)"
^XMB(3.9,144657,2,8476,0)=" S FLGS=$G(FLGS)"
^XMB(3.9,144657,2,8477,0)="""RTN"",""IBCNINSU"",32,0)"
^XMB(3.9,144657,2,8478,0)=" I $G(APP)'="""" D  G PAYERX"
^XMB(3.9,144657,2,8479,0)="""RTN"",""IBCNINSU"",33,0)"
^XMB(3.9,144657,2,8480,0)=" . S APPIEN=$$FIND1^DIC(365.13,,,APP) I 'APPIEN S ARRAY(0)=""Invalid Application"" Q"
^XMB(3.9,144657,2,8481,0)="""RTN"",""IBCNINSU"",34,0)"
^XMB(3.9,144657,2,8482,0)=" . S APPIENI=$O(^IBE(365.12,PIEN,1,""B"",APPIEN,""""))   ; Get the app's internal id for the current payer."
^XMB(3.9,144657,2,8483,0)="""RTN"",""IBCNINSU"",35,0)"
^XMB(3.9,144657,2,8484,0)=" . ; Get all fields at Top Level"
^XMB(3.9,144657,2,8485,0)="""RTN"",""IBCNINSU"",36,0)"
^XMB(3.9,144657,2,8486,0)=" . S IENS=PIEN_"","",FLDS=""*"""
^XMB(3.9,144657,2,8487,0)="""RTN"",""IBCNINSU"",37,0)"
^XMB(3.9,144657,2,8488,0)=" . D GETS^DIQ(365.12,IENS,FLDS,FLGS,""ARRAY"")"
^XMB(3.9,144657,2,8489,0)="""RTN"",""IBCNINSU"",38,0)"
^XMB(3.9,144657,2,8490,0)=" . ; Get all fields at Application Level"
^XMB(3.9,144657,2,8491,0)="""RTN"",""IBCNINSU"",39,0)"
^XMB(3.9,144657,2,8492,0)=" . S IENS=APPIENI_"",""_IENS,FLDS="".01:5.01""  ;ignores the log data (history of the settings)"
^XMB(3.9,144657,2,8493,0)="""RTN"",""IBCNINSU"",40,0)"
^XMB(3.9,144657,2,8494,0)=" . D GETS^DIQ(365.121,IENS,FLDS,FLGS,""ARRAY"")"
^XMB(3.9,144657,2,8495,0)="""RTN"",""IBCNINSU"",41,0)"
^XMB(3.9,144657,2,8496,0)=" S IENS=PIEN_"","""
^XMB(3.9,144657,2,8497,0)="""RTN"",""IBCNINSU"",42,0)"
^XMB(3.9,144657,2,8498,0)=" D GETS^DIQ(365.12,IENS,FLDS,FLGS,""ARRAY"")"
^XMB(3.9,144657,2,8499,0)="""RTN"",""IBCNINSU"",43,0)"
^XMB(3.9,144657,2,8500,0)=" ;"
^XMB(3.9,144657,2,8501,0)="""RTN"",""IBCNINSU"",44,0)"
^XMB(3.9,144657,2,8502,0)="PAYERX ; Exit subroutine"
^XMB(3.9,144657,2,8503,0)="""RTN"",""IBCNINSU"",45,0)"
^XMB(3.9,144657,2,8504,0)=" Q"
^XMB(3.9,144657,2,8505,0)="""RTN"",""IBCNINSU"",46,0)"
^XMB(3.9,144657,2,8506,0)=" ;"
^XMB(3.9,144657,2,8507,0)="""RTN"",""IBCNINSU"",47,0)"
^XMB(3.9,144657,2,8508,0)="PYRDEACT(PIEN) ;Check if payer is deactivated"
^XMB(3.9,144657,2,8509,0)="""RTN"",""IBCNINSU"",48,0)"
^XMB(3.9,144657,2,8510,0)=" ;INPUT"
^XMB(3.9,144657,2,8511,0)="""RTN"",""IBCNINSU"",49,0)"
^XMB(3.9,144657,2,8512,0)=" ;  PIEN - Payer IEN"
^XMB(3.9,144657,2,8513,0)="""RTN"",""IBCNINSU"",50,0)"
^XMB(3.9,144657,2,8514,0)=" ;OUTPUT"
^XMB(3.9,144657,2,8515,0)="""RTN"",""IBCNINSU"",51,0)"
^XMB(3.9,144657,2,8516,0)=" ;  DEACTIVATE - Payer Deactivated (Internal Format)"
^XMB(3.9,144657,2,8517,0)="""RTN"",""IBCNINSU"",52,0)"
^XMB(3.9,144657,2,8518,0)=" ;                  0 - No"
^XMB(3.9,144657,2,8519,0)="""RTN"",""IBCNINSU"",53,0)"
^XMB(3.9,144657,2,8520,0)=" ;                  1 - Yes"
^XMB(3.9,144657,2,8521,0)="""RTN"",""IBCNINSU"",54,0)"
^XMB(3.9,144657,2,8522,0)=" ;  DATE/TIME DEACTIVATE - Date and Time the Payer was deactivated (Internal Fileman Format)"
^XMB(3.9,144657,2,8523,0)="""RTN"",""IBCNINSU"",55,0)"
^XMB(3.9,144657,2,8524,0)=" ;"
^XMB(3.9,144657,2,8525,0)="""RTN"",""IBCNINSU"",56,0)"
^XMB(3.9,144657,2,8526,0)=" N PYRARR,IENS"
^XMB(3.9,144657,2,8527,0)="""RTN"",""IBCNINSU"",57,0)"
^XMB(3.9,144657,2,8528,0)=" S IENS=PIEN_"","""
^XMB(3.9,144657,2,8529,0)="""RTN"",""IBCNINSU"",58,0)"
^XMB(3.9,144657,2,8530,0)=" D PAYER(PIEN,,"".07;.08"",""I"",.PYRARR)"
^XMB(3.9,144657,2,8531,0)="""RTN"",""IBCNINSU"",59,0)"
^XMB(3.9,144657,2,8532,0)=" ;"
^XMB(3.9,144657,2,8533,0)="""RTN"",""IBCNINSU"",60,0)"
^XMB(3.9,144657,2,8534,0)=" Q PYRARR(365.12,IENS,.07,""I"")_U_PYRARR(365.12,IENS,.08,""I"")"
^XMB(3.9,144657,2,8535,0)="""RTN"",""IBCNINSU"",61,0)"
^XMB(3.9,144657,2,8536,0)=" ;"
^XMB(3.9,144657,2,8537,0)="""RTN"",""IBCNINSU"",62,0)"
^XMB(3.9,144657,2,8538,0)="STOP() ; Determine if user wants to exit out of the whole option"
^XMB(3.9,144657,2,8539,0)="""RTN"",""IBCNINSU"",63,0)"
^XMB(3.9,144657,2,8540,0)=" ; Init vars"
^XMB(3.9,144657,2,8541,0)="""RTN"",""IBCNINSU"",64,0)"
^XMB(3.9,144657,2,8542,0)=" N DIR,DIRUT,STOP,X,Y"
^XMB(3.9,144657,2,8543,0)="""RTN"",""IBCNINSU"",65,0)"
^XMB(3.9,144657,2,8544,0)=" ;"
^XMB(3.9,144657,2,8545,0)="""RTN"",""IBCNINSU"",66,0)"
^XMB(3.9,144657,2,8546,0)=" W !"
^XMB(3.9,144657,2,8547,0)="""RTN"",""IBCNINSU"",67,0)"
^XMB(3.9,144657,2,8548,0)=" S DIR(0)=""Y"""
^XMB(3.9,144657,2,8549,0)="""RTN"",""IBCNINSU"",68,0)"
^XMB(3.9,144657,2,8550,0)=" S DIR(""A"")=""Do you want to exit out of this option entirely"""
^XMB(3.9,144657,2,8551,0)="""RTN"",""IBCNINSU"",69,0)"
^XMB(3.9,144657,2,8552,0)=" S DIR(""B"")=""YES"""
^XMB(3.9,144657,2,8553,0)="""RTN"",""IBCNINSU"",70,0)"
^XMB(3.9,144657,2,8554,0)=" S DIR(""?"",1)=""  Enter YES to immediately exit out of this option."""
^XMB(3.9,144657,2,8555,0)="""RTN"",""IBCNINSU"",71,0)"
^XMB(3.9,144657,2,8556,0)=" S DIR(""?"")=""  Enter NO to return to the previous question."""
^XMB(3.9,144657,2,8557,0)="""RTN"",""IBCNINSU"",72,0)"
^XMB(3.9,144657,2,8558,0)=" D ^DIR K DIR"
^XMB(3.9,144657,2,8559,0)="""RTN"",""IBCNINSU"",73,0)"
^XMB(3.9,144657,2,8560,0)=" I $D(DIRUT) S (STOP,Y)=1 G STOPX"
^XMB(3.9,144657,2,8561,0)="""RTN"",""IBCNINSU"",74,0)"
^XMB(3.9,144657,2,8562,0)=" I 'Y S STOP=0"
^XMB(3.9,144657,2,8563,0)="""RTN"",""IBCNINSU"",75,0)"
^XMB(3.9,144657,2,8564,0)=" ;"
^XMB(3.9,144657,2,8565,0)="""RTN"",""IBCNINSU"",76,0)"
^XMB(3.9,144657,2,8566,0)="STOPX ; STOP exit pt"
^XMB(3.9,144657,2,8567,0)="""RTN"",""IBCNINSU"",77,0)"
^XMB(3.9,144657,2,8568,0)=" Q Y"
^XMB(3.9,144657,2,8569,0)="""RTN"",""IBCNINSU"",78,0)"
^XMB(3.9,144657,2,8570,0)=" ;"
^XMB(3.9,144657,2,8571,0)="""RTN"",""IBCNINSU"",79,0)"
^XMB(3.9,144657,2,8572,0)="FOREIGN(VALUE,PIECES,BLANK) ; check for ASCII chars outside (32-126 inclusive)"
^XMB(3.9,144657,2,8573,0)="""RTN"",""IBCNINSU"",80,0)"
^XMB(3.9,144657,2,8574,0)=" ;INPUT:"
^XMB(3.9,144657,2,8575,0)="""RTN"",""IBCNINSU"",81,0)"
^XMB(3.9,144657,2,8576,0)=" ;  VALUE  = the string/field to check"
^XMB(3.9,144657,2,8577,0)="""RTN"",""IBCNINSU"",82,0)"
^XMB(3.9,144657,2,8578,0)=" ;  PIECES = populate if a subcomponent has to be checked (defaults as 1)"
^XMB(3.9,144657,2,8579,0)="""RTN"",""IBCNINSU"",83,0)"
^XMB(3.9,144657,2,8580,0)=" ;  BLANK  = populated if the value is to be cleared out if foreign char"
^XMB(3.9,144657,2,8581,0)="""RTN"",""IBCNINSU"",84,0)"
^XMB(3.9,144657,2,8582,0)=" ;           is encountered (1 tells program to clear out field if it cotains foreign)"
^XMB(3.9,144657,2,8583,0)="""RTN"",""IBCNINSU"",85,0)"
^XMB(3.9,144657,2,8584,0)=" ;"
^XMB(3.9,144657,2,8585,0)="""RTN"",""IBCNINSU"",86,0)"
^XMB(3.9,144657,2,8586,0)=" ; I VALUE had a character, in the pieces that were to be examined, that is"
^XMB(3.9,144657,2,8587,0)="""RTN"",""IBCNINSU"",87,0)"
^XMB(3.9,144657,2,8588,0)=" ;   outside of the ASCII range (32-126) a 1 is returned; otherwise returns ZERO"
^XMB(3.9,144657,2,8589,0)="""RTN"",""IBCNINSU"",88,0)"
^XMB(3.9,144657,2,8590,0)=" ;"
^XMB(3.9,144657,2,8591,0)="""RTN"",""IBCNINSU"",89,0)"
^XMB(3.9,144657,2,8592,0)=" N BAD,DONE,IBI,IBY,PCE,STRNG,XX"
^XMB(3.9,144657,2,8593,0)="""RTN"",""IBCNINSU"",90,0)"
^XMB(3.9,144657,2,8594,0)=" S IBY="""",BAD=0"
^XMB(3.9,144657,2,8595,0)="""RTN"",""IBCNINSU"",91,0)"
^XMB(3.9,144657,2,8596,0)=" I '$G(PIECES) S PIECES=1"
^XMB(3.9,144657,2,8597,0)="""RTN"",""IBCNINSU"",92,0)"
^XMB(3.9,144657,2,8598,0)=" F PCE=1:1:$L(PIECES,"";"") S XX=$P(PIECES,"";"",PCE) D"
^XMB(3.9,144657,2,8599,0)="""RTN"",""IBCNINSU"",93,0)"
^XMB(3.9,144657,2,8600,0)=" . S STRNG=$P(VALUE,HLECH,XX),DONE=0"
^XMB(3.9,144657,2,8601,0)="""RTN"",""IBCNINSU"",94,0)"
^XMB(3.9,144657,2,8602,0)=" . I STRNG'="""" F IBI=1:1 S IBY=$E(STRNG,IBI) Q:IBY=""""  D  Q:DONE"
^XMB(3.9,144657,2,8603,0)="""RTN"",""IBCNINSU"",95,0)"
^XMB(3.9,144657,2,8604,0)=" .. I $A(IBY)<32!($A(IBY)>126) D  Q"
^XMB(3.9,144657,2,8605,0)="""RTN"",""IBCNINSU"",96,0)"
^XMB(3.9,144657,2,8606,0)=" ... S (DONE,BAD)=1   ;Foreign character found"
^XMB(3.9,144657,2,8607,0)="""RTN"",""IBCNINSU"",97,0)"
^XMB(3.9,144657,2,8608,0)=" ... I $G(BLANK) S $P(VALUE,HLECH,XX)="""""
^XMB(3.9,144657,2,8609,0)="""RTN"",""IBCNINSU"",98,0)"
^XMB(3.9,144657,2,8610,0)=" Q BAD"
^XMB(3.9,144657,2,8611,0)="""RTN"",""IBCNINSU"",99,0)"
^XMB(3.9,144657,2,8612,0)=" ;"
^XMB(3.9,144657,2,8613,0)="""RTN"",""IBCNINSU"",100,0)"
^XMB(3.9,144657,2,8614,0)="FILTER(STR,FLT) ; Filter Insurance Name, Group Name or Number"
^XMB(3.9,144657,2,8615,0)="""RTN"",""IBCNINSU"",101,0)"
^XMB(3.9,144657,2,8616,0)=" ;IBFLT A^B^C"
^XMB(3.9,144657,2,8617,0)="""RTN"",""IBCNINSU"",102,0)"
^XMB(3.9,144657,2,8618,0)=" ;         A - 1 - Search for Name(s) that begin with"
^XMB(3.9,144657,2,8619,0)="""RTN"",""IBCNINSU"",103,0)"
^XMB(3.9,144657,2,8620,0)=" ;                 the specified text (case insensitive)"
^XMB(3.9,144657,2,8621,0)="""RTN"",""IBCNINSU"",104,0)"
^XMB(3.9,144657,2,8622,0)=" ;             2 - Search for Name(s) that contain"
^XMB(3.9,144657,2,8623,0)="""RTN"",""IBCNINSU"",105,0)"
^XMB(3.9,144657,2,8624,0)=" ;                 the specified text (case insensitive)"
^XMB(3.9,144657,2,8625,0)="""RTN"",""IBCNINSU"",106,0)"
^XMB(3.9,144657,2,8626,0)=" ;             3 - Search for Name(s) in a specified"
^XMB(3.9,144657,2,8627,0)="""RTN"",""IBCNINSU"",107,0)"
^XMB(3.9,144657,2,8628,0)=" ;                 range (inclusive, case insensitive)"
^XMB(3.9,144657,2,8629,0)="""RTN"",""IBCNINSU"",108,0)"
^XMB(3.9,144657,2,8630,0)=" ;             4 - Search for Name(s) that are blank (null)"
^XMB(3.9,144657,2,8631,0)="""RTN"",""IBCNINSU"",109,0)"
^XMB(3.9,144657,2,8632,0)=" ;             5 - Filter by Selected Payer only (ONLY used by 'eIV Auto Update Report' (IBCNERPF)) ;IB*737/CKB"
^XMB(3.9,144657,2,8633,0)="""RTN"",""IBCNINSU"",110,0)"
^XMB(3.9,144657,2,8634,0)=" ;         B - Begin with text if A=1, Contains Text if A=2 or"
^XMB(3.9,144657,2,8635,0)="""RTN"",""IBCNINSU"",111,0)"
^XMB(3.9,144657,2,8636,0)=" ;             the range start if A=3"
^XMB(3.9,144657,2,8637,0)="""RTN"",""IBCNINSU"",112,0)"
^XMB(3.9,144657,2,8638,0)=" ;         C - Range End text (only present when A=3)"
^XMB(3.9,144657,2,8639,0)="""RTN"",""IBCNINSU"",113,0)"
^XMB(3.9,144657,2,8640,0)=" ;OUTPUT:"
^XMB(3.9,144657,2,8641,0)="""RTN"",""IBCNINSU"",114,0)"
^XMB(3.9,144657,2,8642,0)=" ;  OK -  0 - Does not match Filter, do not include"
^XMB(3.9,144657,2,8643,0)="""RTN"",""IBCNINSU"",115,0)"
^XMB(3.9,144657,2,8644,0)=" ;        1 - Matches Filter, include"
^XMB(3.9,144657,2,8645,0)="""RTN"",""IBCNINSU"",116,0)"
^XMB(3.9,144657,2,8646,0)=" ;"
^XMB(3.9,144657,2,8647,0)="""RTN"",""IBCNINSU"",117,0)"
^XMB(3.9,144657,2,8648,0)=" N BEG,CHR,END,OK,TYPE,YY"
^XMB(3.9,144657,2,8649,0)="""RTN"",""IBCNINSU"",118,0)"
^XMB(3.9,144657,2,8650,0)=" S STR=$$UP^XLFSTR(STR)"
^XMB(3.9,144657,2,8651,0)="""RTN"",""IBCNINSU"",119,0)"
^XMB(3.9,144657,2,8652,0)=" S TYPE=$P(FLT,U,1)"
^XMB(3.9,144657,2,8653,0)="""RTN"",""IBCNINSU"",120,0)"
^XMB(3.9,144657,2,8654,0)=" S BEG=$$UP^XLFSTR($P(FLT,U,2))"
^XMB(3.9,144657,2,8655,0)="""RTN"",""IBCNINSU"",121,0)"
^XMB(3.9,144657,2,8656,0)=" S END=$$UP^XLFSTR($P(FLT,U,3))"
^XMB(3.9,144657,2,8657,0)="""RTN"",""IBCNINSU"",122,0)"
^XMB(3.9,144657,2,8658,0)=" S OK=0"
^XMB(3.9,144657,2,8659,0)="""RTN"",""IBCNINSU"",123,0)"
^XMB(3.9,144657,2,8660,0)=" ;IB*737/CKB - added Payer (TYPE=5)"
^XMB(3.9,144657,2,8661,0)="""RTN"",""IBCNINSU"",124,0)"
^XMB(3.9,144657,2,8662,0)=" ;Payer"
^XMB(3.9,144657,2,8663,0)="""RTN"",""IBCNINSU"",125,0)"
^XMB(3.9,144657,2,8664,0)=" I TYPE=5 S OK=1 G FILTERX"
^XMB(3.9,144657,2,8665,0)="""RTN"",""IBCNINSU"",126,0)"
^XMB(3.9,144657,2,8666,0)=" ;Blank"
^XMB(3.9,144657,2,8667,0)="""RTN"",""IBCNINSU"",127,0)"
^XMB(3.9,144657,2,8668,0)=" I TYPE=4 D  G FILTERX"
^XMB(3.9,144657,2,8669,0)="""RTN"",""IBCNINSU"",128,0)"
^XMB(3.9,144657,2,8670,0)=" . I STR="""" S OK=1"
^XMB(3.9,144657,2,8671,0)="""RTN"",""IBCNINSU"",129,0)"
^XMB(3.9,144657,2,8672,0)=" ;Test begins with"
^XMB(3.9,144657,2,8673,0)="""RTN"",""IBCNINSU"",130,0)"
^XMB(3.9,144657,2,8674,0)=" I TYPE=1 D  G FILTERX"
^XMB(3.9,144657,2,8675,0)="""RTN"",""IBCNINSU"",131,0)"
^XMB(3.9,144657,2,8676,0)=" . I ($E(STR,1,$L(BEG))=BEG) S OK=1"
^XMB(3.9,144657,2,8677,0)="""RTN"",""IBCNINSU"",132,0)"
^XMB(3.9,144657,2,8678,0)=" ;Test contains"
^XMB(3.9,144657,2,8679,0)="""RTN"",""IBCNINSU"",133,0)"
^XMB(3.9,144657,2,8680,0)=" I TYPE=2 D  G FILTERX"
^XMB(3.9,144657,2,8681,0)="""RTN"",""IBCNINSU"",134,0)"
^XMB(3.9,144657,2,8682,0)=" . I (STR[BEG) S OK=1"
^XMB(3.9,144657,2,8683,0)="""RTN"",""IBCNINSU"",135,0)"
^XMB(3.9,144657,2,8684,0)=" ;Test range"
^XMB(3.9,144657,2,8685,0)="""RTN"",""IBCNINSU"",136,0)"
^XMB(3.9,144657,2,8686,0)=" I TYPE=3 D  G FILTERX"
^XMB(3.9,144657,2,8687,0)="""RTN"",""IBCNINSU"",137,0)"
^XMB(3.9,144657,2,8688,0)=" . N XX"
^XMB(3.9,144657,2,8689,0)="""RTN"",""IBCNINSU"",138,0)"
^XMB(3.9,144657,2,8690,0)=" . S XX=$E(STR,1,$L(BEG))"
^XMB(3.9,144657,2,8691,0)="""RTN"",""IBCNINSU"",139,0)"
^XMB(3.9,144657,2,8692,0)=" . I XX=BEG D  Q"
^XMB(3.9,144657,2,8693,0)="""RTN"",""IBCNINSU"",140,0)"
^XMB(3.9,144657,2,8694,0)=" .. S YY=$E(STR,1,$L(END)) I YY]END Q"
^XMB(3.9,144657,2,8695,0)="""RTN"",""IBCNINSU"",141,0)"
^XMB(3.9,144657,2,8696,0)=" .. S OK=1             ;Matches begining characters of BEG - include"
^XMB(3.9,144657,2,8697,0)="""RTN"",""IBCNINSU"",142,0)"
^XMB(3.9,144657,2,8698,0)=" . I XX']BEG Q         ;Preceeds Beg search"
^XMB(3.9,144657,2,8699,0)="""RTN"",""IBCNINSU"",143,0)"
^XMB(3.9,144657,2,8700,0)=" . S XX=$E(STR,1,$L(END))"
^XMB(3.9,144657,2,8701,0)="""RTN"",""IBCNINSU"",144,0)"
^XMB(3.9,144657,2,8702,0)=" . I XX=END S OK=1 Q   ;Matches beginning characters of END - include"
^XMB(3.9,144657,2,8703,0)="""RTN"",""IBCNINSU"",145,0)"
^XMB(3.9,144657,2,8704,0)=" . I XX]END Q          ;Follows End search"
^XMB(3.9,144657,2,8705,0)="""RTN"",""IBCNINSU"",146,0)"
^XMB(3.9,144657,2,8706,0)=" . S OK=1"
^XMB(3.9,144657,2,8707,0)="""RTN"",""IBCNINSU"",147,0)"
^XMB(3.9,144657,2,8708,0)="FILTERX ; Exit"
^XMB(3.9,144657,2,8709,0)="""RTN"",""IBCNINSU"",148,0)"
^XMB(3.9,144657,2,8710,0)=" Q OK"
^XMB(3.9,144657,2,8711,0)="""RTN"",""IBCNINSU"",149,0)"
^XMB(3.9,144657,2,8712,0)=" ;"
^XMB(3.9,144657,2,8713,0)="""RTN"",""IBCNINSU"",150,0)"
^XMB(3.9,144657,2,8714,0)="VALIDDT(X) ; Check for validate date (internal form of the date)  ;IB*737/CKB"
^XMB(3.9,144657,2,8715,0)="""RTN"",""IBCNINSU"",151,0)"
^XMB(3.9,144657,2,8716,0)=" ;   Input:  X - internal date, FM format"
^XMB(3.9,144657,2,8717,0)="""RTN"",""IBCNINSU"",152,0)"
^XMB(3.9,144657,2,8718,0)=" ; Returns:  Y - if date if NOT valid, returns -1"
^XMB(3.9,144657,2,8719,0)="""RTN"",""IBCNINSU"",153,0)"
^XMB(3.9,144657,2,8720,0)=" ;               if the date is """" (null), returns a """" (null)"
^XMB(3.9,144657,2,8721,0)="""RTN"",""IBCNINSU"",154,0)"
^XMB(3.9,144657,2,8722,0)=" ;               if valid date, returns the internal date"
^XMB(3.9,144657,2,8723,0)="""RTN"",""IBCNINSU"",155,0)"
^XMB(3.9,144657,2,8724,0)=" N %DT,Y"
^XMB(3.9,144657,2,8725,0)="""RTN"",""IBCNINSU"",156,0)"
^XMB(3.9,144657,2,8726,0)=" Q:X="""" """""
^XMB(3.9,144657,2,8727,0)="""RTN"",""IBCNINSU"",157,0)"
^XMB(3.9,144657,2,8728,0)=" S %DT=""X"" D ^%DT"
^XMB(3.9,144657,2,8729,0)="""RTN"",""IBCNINSU"",158,0)"
^XMB(3.9,144657,2,8730,0)=" Q Y"
^XMB(3.9,144657,2,8731,0)="""RTN"",""IBCNIUF"")"
^XMB(3.9,144657,2,8732,0)="0^20^B40326268"
^XMB(3.9,144657,2,8733,0)="""RTN"",""IBCNIUF"",1,0)"
^XMB(3.9,144657,2,8734,0)="IBCNIUF ;AITC/TAZ - IIU FILER ;01/14/21 2:23p.m."
^XMB(3.9,144657,2,8735,0)="""RTN"",""IBCNIUF"",2,0)"
^XMB(3.9,144657,2,8736,0)=" ;;2.0;INTEGRATED BILLING;**687**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,8737,0)="""RTN"",""IBCNIUF"",3,0)"
^XMB(3.9,144657,2,8738,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,8739,0)="""RTN"",""IBCNIUF"",4,0)"
^XMB(3.9,144657,2,8740,0)=" ;"
^XMB(3.9,144657,2,8741,0)="""RTN"",""IBCNIUF"",5,0)"
^XMB(3.9,144657,2,8742,0)=" ;IA/ICR #2990 and #10112 Used in tag TFL"
^XMB(3.9,144657,2,8743,0)="""RTN"",""IBCNIUF"",6,0)"
^XMB(3.9,144657,2,8744,0)=" ;"
^XMB(3.9,144657,2,8745,0)="""RTN"",""IBCNIUF"",7,0)"
^XMB(3.9,144657,2,8746,0)=" Q"
^XMB(3.9,144657,2,8747,0)="""RTN"",""IBCNIUF"",8,0)"
^XMB(3.9,144657,2,8748,0)=" ;"
^XMB(3.9,144657,2,8749,0)="""RTN"",""IBCNIUF"",9,0)"
^XMB(3.9,144657,2,8750,0)="LOC(DFN,INSCOIEN,IEN312,AUTO,BUFFER,SOI,ICB) ; Entry point to file locally generated data"
^XMB(3.9,144657,2,8751,0)="""RTN"",""IBCNIUF"",10,0)"
^XMB(3.9,144657,2,8752,0)=" ;INPUT:"
^XMB(3.9,144657,2,8753,0)="""RTN"",""IBCNIUF"",11,0)"
^XMB(3.9,144657,2,8754,0)=" ;  DFN              - Pointer to Patient file"
^XMB(3.9,144657,2,8755,0)="""RTN"",""IBCNIUF"",12,0)"
^XMB(3.9,144657,2,8756,0)=" ;  IEN312           - Pointer to the INSURANCE TYPE record"
^XMB(3.9,144657,2,8757,0)="""RTN"",""IBCNIUF"",13,0)"
^XMB(3.9,144657,2,8758,0)=" ;  AUTO             - AUTO UPDATE Yes/No"
^XMB(3.9,144657,2,8759,0)="""RTN"",""IBCNIUF"",14,0)"
^XMB(3.9,144657,2,8760,0)=" ;  BUFFER           - Pointer to Buffer File"
^XMB(3.9,144657,2,8761,0)="""RTN"",""IBCNIUF"",15,0)"
^XMB(3.9,144657,2,8762,0)=" ;  SOI              - Source of Information"
^XMB(3.9,144657,2,8763,0)="""RTN"",""IBCNIUF"",16,0)"
^XMB(3.9,144657,2,8764,0)=" ;  ICB              - ICB processed buffer Yes/No"
^XMB(3.9,144657,2,8765,0)="""RTN"",""IBCNIUF"",17,0)"
^XMB(3.9,144657,2,8766,0)=" ;                     ICB was set in routine IBCNICB. It will be used to set ICB PROCESSED BUFFER (365.19,1.08)"
^XMB(3.9,144657,2,8767,0)="""RTN"",""IBCNIUF"",18,0)"
^XMB(3.9,144657,2,8768,0)=" ;"
^XMB(3.9,144657,2,8769,0)="""RTN"",""IBCNIUF"",19,0)"
^XMB(3.9,144657,2,8770,0)=" ;OUTPUT:"
^XMB(3.9,144657,2,8771,0)="""RTN"",""IBCNIUF"",20,0)"
^XMB(3.9,144657,2,8772,0)=" ;  None"
^XMB(3.9,144657,2,8773,0)="""RTN"",""IBCNIUF"",21,0)"
^XMB(3.9,144657,2,8774,0)=" ;"
^XMB(3.9,144657,2,8775,0)="""RTN"",""IBCNIUF"",22,0)"
^XMB(3.9,144657,2,8776,0)=" N DATA,IBDFDA,IEN,IENS,PIEN,SITE,SITES"
^XMB(3.9,144657,2,8777,0)="""RTN"",""IBCNIUF"",23,0)"
^XMB(3.9,144657,2,8778,0)=" ;"
^XMB(3.9,144657,2,8779,0)="""RTN"",""IBCNIUF"",24,0)"
^XMB(3.9,144657,2,8780,0)=" ;If Manila and not participating in IIU, quit and don't file into #365.19"
^XMB(3.9,144657,2,8781,0)="""RTN"",""IBCNIUF"",25,0)"
^XMB(3.9,144657,2,8782,0)=" I (+$P($$SITE^VASITE,U,3)=358),$$GET1^DIQ(350.9,""1,"",51.33,""I"")=""N"" G LOCQ"
^XMB(3.9,144657,2,8783,0)="""RTN"",""IBCNIUF"",26,0)"
^XMB(3.9,144657,2,8784,0)=" ;"
^XMB(3.9,144657,2,8785,0)="""RTN"",""IBCNIUF"",27,0)"
^XMB(3.9,144657,2,8786,0)=" ;Quit if the IIU MASTER SWITCH is off"
^XMB(3.9,144657,2,8787,0)="""RTN"",""IBCNIUF"",28,0)"
^XMB(3.9,144657,2,8788,0)=" I $$GET1^DIQ(350.9,1_"","",53.01,""I"")'=""Y"" G LOCQ"
^XMB(3.9,144657,2,8789,0)="""RTN"",""IBCNIUF"",29,0)"
^XMB(3.9,144657,2,8790,0)=" ;"
^XMB(3.9,144657,2,8791,0)="""RTN"",""IBCNIUF"",30,0)"
^XMB(3.9,144657,2,8792,0)=" S PIEN=$$GET1^DIQ(36,INSCOIEN_"","",3.1,""I"") ; payer IEN associated with ins company"
^XMB(3.9,144657,2,8793,0)="""RTN"",""IBCNIUF"",31,0)"
^XMB(3.9,144657,2,8794,0)=" S IENS=IEN312_"",""_DFN_"","""
^XMB(3.9,144657,2,8795,0)="""RTN"",""IBCNIUF"",32,0)"
^XMB(3.9,144657,2,8796,0)=" ;"
^XMB(3.9,144657,2,8797,0)="""RTN"",""IBCNIUF"",33,0)"
^XMB(3.9,144657,2,8798,0)=" I '$$OKTOFILE G LOCQ  ;Not a valid policy for IIU"
^XMB(3.9,144657,2,8799,0)="""RTN"",""IBCNIUF"",34,0)"
^XMB(3.9,144657,2,8800,0)=" ;"
^XMB(3.9,144657,2,8801,0)="""RTN"",""IBCNIUF"",35,0)"
^XMB(3.9,144657,2,8802,0)=" ;Set Header Nodes"
^XMB(3.9,144657,2,8803,0)="""RTN"",""IBCNIUF"",36,0)"
^XMB(3.9,144657,2,8804,0)=" S DATA(.01)=DFN"
^XMB(3.9,144657,2,8805,0)="""RTN"",""IBCNIUF"",37,0)"
^XMB(3.9,144657,2,8806,0)=" S DATA(.02)=$$NOW^XLFDT"
^XMB(3.9,144657,2,8807,0)="""RTN"",""IBCNIUF"",38,0)"
^XMB(3.9,144657,2,8808,0)=" S DATA(.03)=""S"""
^XMB(3.9,144657,2,8809,0)="""RTN"",""IBCNIUF"",39,0)"
^XMB(3.9,144657,2,8810,0)=" ;"
^XMB(3.9,144657,2,8811,0)="""RTN"",""IBCNIUF"",40,0)"
^XMB(3.9,144657,2,8812,0)=" ;Set SENDER nodes"
^XMB(3.9,144657,2,8813,0)="""RTN"",""IBCNIUF"",41,0)"
^XMB(3.9,144657,2,8814,0)=" S DATA(1.01)=""W""                               ;SENDER STATUS"
^XMB(3.9,144657,2,8815,0)="""RTN"",""IBCNIUF"",42,0)"
^XMB(3.9,144657,2,8816,0)=" S DATA(1.02)=PIEN                              ;Pointer to the Payer File (#365.12)"
^XMB(3.9,144657,2,8817,0)="""RTN"",""IBCNIUF"",43,0)"
^XMB(3.9,144657,2,8818,0)=" S DATA(1.03)=IEN312                            ;Pointer to INSURANCE TYPE subfile (#2.312)"
^XMB(3.9,144657,2,8819,0)="""RTN"",""IBCNIUF"",44,0)"
^XMB(3.9,144657,2,8820,0)=" S DATA(1.04)=$G(AUTO,0)                        ;Auto Updated Yes/No"
^XMB(3.9,144657,2,8821,0)="""RTN"",""IBCNIUF"",45,0)"
^XMB(3.9,144657,2,8822,0)=" S DATA(1.05)=$G(BUFFER)                        ;Pointer to the INSURANCE VERIFICATION PROCESSOR File (#355.33)"
^XMB(3.9,144657,2,8823,0)="""RTN"",""IBCNIUF"",46,0)"
^XMB(3.9,144657,2,8824,0)=" I $G(AUTO) D"
^XMB(3.9,144657,2,8825,0)="""RTN"",""IBCNIUF"",47,0)"
^XMB(3.9,144657,2,8826,0)=" . S DATA(1.06)=$$GET1^DIQ(2.312,IENS,7.02,""I"") ;Subscriber ID to be sent to remote facility"
^XMB(3.9,144657,2,8827,0)="""RTN"",""IBCNIUF"",48,0)"
^XMB(3.9,144657,2,8828,0)=" . S DATA(1.07)=$$GET1^DIQ(2.312,IENS,.2,""I"")   ;Coordination of Benefits to be sent to remote facility"
^XMB(3.9,144657,2,8829,0)="""RTN"",""IBCNIUF"",49,0)"
^XMB(3.9,144657,2,8830,0)=" S DATA(1.08)=+$G(ICB)                          ;ICB Processed Buffer Yes/No"
^XMB(3.9,144657,2,8831,0)="""RTN"",""IBCNIUF"",50,0)"
^XMB(3.9,144657,2,8832,0)=" ;"
^XMB(3.9,144657,2,8833,0)="""RTN"",""IBCNIUF"",51,0)"
^XMB(3.9,144657,2,8834,0)=" ; File Main Level Data"
^XMB(3.9,144657,2,8835,0)="""RTN"",""IBCNIUF"",52,0)"
^XMB(3.9,144657,2,8836,0)=" S IEN=$$ADD^IBDFDBS(365.19,,.DATA)"
^XMB(3.9,144657,2,8837,0)="""RTN"",""IBCNIUF"",53,0)"
^XMB(3.9,144657,2,8838,0)=" K DATA"
^XMB(3.9,144657,2,8839,0)="""RTN"",""IBCNIUF"",54,0)"
^XMB(3.9,144657,2,8840,0)=" ;"
^XMB(3.9,144657,2,8841,0)="""RTN"",""IBCNIUF"",55,0)"
^XMB(3.9,144657,2,8842,0)=" ; File VAMC Level"
^XMB(3.9,144657,2,8843,0)="""RTN"",""IBCNIUF"",56,0)"
^XMB(3.9,144657,2,8844,0)=" S SITE=0"
^XMB(3.9,144657,2,8845,0)="""RTN"",""IBCNIUF"",57,0)"
^XMB(3.9,144657,2,8846,0)=" F  S SITE=$O(SITES(SITE)) Q:'SITE  D"
^XMB(3.9,144657,2,8847,0)="""RTN"",""IBCNIUF"",58,0)"
^XMB(3.9,144657,2,8848,0)=" . N X"
^XMB(3.9,144657,2,8849,0)="""RTN"",""IBCNIUF"",59,0)"
^XMB(3.9,144657,2,8850,0)=" . S IBDFDA(1)=IEN"
^XMB(3.9,144657,2,8851,0)="""RTN"",""IBCNIUF"",60,0)"
^XMB(3.9,144657,2,8852,0)=" . S DATA(.01)=SITE"
^XMB(3.9,144657,2,8853,0)="""RTN"",""IBCNIUF"",61,0)"
^XMB(3.9,144657,2,8854,0)=" . S DATA(.02)=""R"""
^XMB(3.9,144657,2,8855,0)="""RTN"",""IBCNIUF"",62,0)"
^XMB(3.9,144657,2,8856,0)=" . S DATA(.03)=$$NOW^XLFDT"
^XMB(3.9,144657,2,8857,0)="""RTN"",""IBCNIUF"",63,0)"
^XMB(3.9,144657,2,8858,0)=" . S X=$$ADD^IBDFDBS(365.191,.IBDFDA,.DATA)"
^XMB(3.9,144657,2,8859,0)="""RTN"",""IBCNIUF"",64,0)"
^XMB(3.9,144657,2,8860,0)=" . K DATA"
^XMB(3.9,144657,2,8861,0)="""RTN"",""IBCNIUF"",65,0)"
^XMB(3.9,144657,2,8862,0)=" ;"
^XMB(3.9,144657,2,8863,0)="""RTN"",""IBCNIUF"",66,0)"
^XMB(3.9,144657,2,8864,0)=" ;Send to remote site in real time"
^XMB(3.9,144657,2,8865,0)="""RTN"",""IBCNIUF"",67,0)"
^XMB(3.9,144657,2,8866,0)=" D RT^IBCNIUHL(IEN)"
^XMB(3.9,144657,2,8867,0)="""RTN"",""IBCNIUF"",68,0)"
^XMB(3.9,144657,2,8868,0)=" ;"
^XMB(3.9,144657,2,8869,0)="""RTN"",""IBCNIUF"",69,0)"
^XMB(3.9,144657,2,8870,0)="LOCQ ;Exit Local processing"
^XMB(3.9,144657,2,8871,0)="""RTN"",""IBCNIUF"",70,0)"
^XMB(3.9,144657,2,8872,0)=" Q"
^XMB(3.9,144657,2,8873,0)="""RTN"",""IBCNIUF"",71,0)"
^XMB(3.9,144657,2,8874,0)=" ;===================================="
^XMB(3.9,144657,2,8875,0)="""RTN"",""IBCNIUF"",72,0)"
^XMB(3.9,144657,2,8876,0)="OKTOFILE() ; Confirm that we can/should send to remote facilities"
^XMB(3.9,144657,2,8877,0)="""RTN"",""IBCNIUF"",73,0)"
^XMB(3.9,144657,2,8878,0)=" N OK"
^XMB(3.9,144657,2,8879,0)="""RTN"",""IBCNIUF"",74,0)"
^XMB(3.9,144657,2,8880,0)=" S OK=0"
^XMB(3.9,144657,2,8881,0)="""RTN"",""IBCNIUF"",75,0)"
^XMB(3.9,144657,2,8882,0)=" K SITES  ;array of sites that will receive the verified active policy"
^XMB(3.9,144657,2,8883,0)="""RTN"",""IBCNIUF"",76,0)"
^XMB(3.9,144657,2,8884,0)=" ;"
^XMB(3.9,144657,2,8885,0)="""RTN"",""IBCNIUF"",77,0)"
^XMB(3.9,144657,2,8886,0)=" ;Check Insurance Co"
^XMB(3.9,144657,2,8887,0)="""RTN"",""IBCNIUF"",78,0)"
^XMB(3.9,144657,2,8888,0)=" I ""^VACAA-WNR^CAMPLEJEUNE-WNR^IVF-WNR^VHADIRECTIVE1029WNR""[$TR($$GET1^DIQ(36,INSCOIEN_"","",.01,""E""),"" "","""") G OKTOFILEQ"
^XMB(3.9,144657,2,8889,0)="""RTN"",""IBCNIUF"",79,0)"
^XMB(3.9,144657,2,8890,0)=" ;"
^XMB(3.9,144657,2,8891,0)="""RTN"",""IBCNIUF"",80,0)"
^XMB(3.9,144657,2,8892,0)=" ;Check Payer"
^XMB(3.9,144657,2,8893,0)="""RTN"",""IBCNIUF"",81,0)"
^XMB(3.9,144657,2,8894,0)=" I '$$PYRAPP^IBCNEUT5(""IIU"",PIEN) G OKTOFILEQ ;Payer is not IIU"
^XMB(3.9,144657,2,8895,0)="""RTN"",""IBCNIUF"",82,0)"
^XMB(3.9,144657,2,8896,0)=" I $$PYRDEACT^IBCNINSU(PIEN) G OKTOFILEQ ;Payer is Deactivated"
^XMB(3.9,144657,2,8897,0)="""RTN"",""IBCNIUF"",83,0)"
^XMB(3.9,144657,2,8898,0)=" ;"
^XMB(3.9,144657,2,8899,0)="""RTN"",""IBCNIUF"",84,0)"
^XMB(3.9,144657,2,8900,0)=" ;Check Patient"
^XMB(3.9,144657,2,8901,0)="""RTN"",""IBCNIUF"",85,0)"
^XMB(3.9,144657,2,8902,0)=" I $$GET1^DIQ(2,DFN_"","",.6,""I"") G OKTOFILEQ ;Is a test patient"
^XMB(3.9,144657,2,8903,0)="""RTN"",""IBCNIUF"",86,0)"
^XMB(3.9,144657,2,8904,0)=" I $E($$GET1^DIQ(2,DFN_"","",.09,""I"")=""P"") G OKTOFILEQ  ;Has Pseudo SSN"
^XMB(3.9,144657,2,8905,0)="""RTN"",""IBCNIUF"",87,0)"
^XMB(3.9,144657,2,8906,0)=" ;"
^XMB(3.9,144657,2,8907,0)="""RTN"",""IBCNIUF"",88,0)"
^XMB(3.9,144657,2,8908,0)=" ;Check Policy"
^XMB(3.9,144657,2,8909,0)="""RTN"",""IBCNIUF"",89,0)"
^XMB(3.9,144657,2,8910,0)=" I "",INTERFACILITY INS UPDATE,INSURANCE IMPORT,""[("",""_SOI_"","") G OKTOFILEQ ;Source of Information is IMPORT OR IIU"
^XMB(3.9,144657,2,8911,0)="""RTN"",""IBCNIUF"",90,0)"
^XMB(3.9,144657,2,8912,0)=" I '$$ACTIVE() G OKTOFILEQ"
^XMB(3.9,144657,2,8913,0)="""RTN"",""IBCNIUF"",91,0)"
^XMB(3.9,144657,2,8914,0)=" I '$$TOP() G OKTOFILEQ"
^XMB(3.9,144657,2,8915,0)="""RTN"",""IBCNIUF"",92,0)"
^XMB(3.9,144657,2,8916,0)=" ;"
^XMB(3.9,144657,2,8917,0)="""RTN"",""IBCNIUF"",93,0)"
^XMB(3.9,144657,2,8918,0)=" ;Check Sites"
^XMB(3.9,144657,2,8919,0)="""RTN"",""IBCNIUF"",94,0)"
^XMB(3.9,144657,2,8920,0)=" S SITES=$$TFL(DFN,.SITES) ;Build list of remote facilities visited."
^XMB(3.9,144657,2,8921,0)="""RTN"",""IBCNIUF"",95,0)"
^XMB(3.9,144657,2,8922,0)=" I 'SITES G OKTOFILEQ ;No sites were visited"
^XMB(3.9,144657,2,8923,0)="""RTN"",""IBCNIUF"",96,0)"
^XMB(3.9,144657,2,8924,0)=" ;"
^XMB(3.9,144657,2,8925,0)="""RTN"",""IBCNIUF"",97,0)"
^XMB(3.9,144657,2,8926,0)=" ;IIU days before sending violated"
^XMB(3.9,144657,2,8927,0)="""RTN"",""IBCNIUF"",98,0)"
^XMB(3.9,144657,2,8928,0)=" ; check the combination of patient, policy, and facility we sent it to"
^XMB(3.9,144657,2,8929,0)="""RTN"",""IBCNIUF"",99,0)"
^XMB(3.9,144657,2,8930,0)=" N DEST,DESTDT,DESTIEN,DESTSTAT,IEN,SHAREDT"
^XMB(3.9,144657,2,8931,0)="""RTN"",""IBCNIUF"",100,0)"
^XMB(3.9,144657,2,8932,0)=" ; TODAY - IIU MIN DAYS BEFORE SHARING (#53.04) to determine if it is too soon"
^XMB(3.9,144657,2,8933,0)="""RTN"",""IBCNIUF"",101,0)"
^XMB(3.9,144657,2,8934,0)=" S SHAREDT=$$FMADD^XLFDT(DT,-$$GET1^DIQ(350.9,1_"","",53.04,""I""))"
^XMB(3.9,144657,2,8935,0)="""RTN"",""IBCNIUF"",102,0)"
^XMB(3.9,144657,2,8936,0)=" I $D(^IBCN(365.19,""D"",DFN,IEN312)) D"
^XMB(3.9,144657,2,8937,0)="""RTN"",""IBCNIUF"",103,0)"
^XMB(3.9,144657,2,8938,0)=" . S IEN="""" F  S IEN=$O(^IBCN(365.19,""D"",DFN,IEN312,IEN)) Q:'IEN  D"
^XMB(3.9,144657,2,8939,0)="""RTN"",""IBCNIUF"",104,0)"
^XMB(3.9,144657,2,8940,0)=" . . S DESTIEN=0 F  S DESTIEN=$O(^IBCN(365.19,IEN,1.1,DESTIEN)) Q:'DESTIEN  D"
^XMB(3.9,144657,2,8941,0)="""RTN"",""IBCNIUF"",105,0)"
^XMB(3.9,144657,2,8942,0)=" . . . S DEST=$$GET1^DIQ(365.191,DESTIEN_"",""_IEN_"","",.01,""I"")"
^XMB(3.9,144657,2,8943,0)="""RTN"",""IBCNIUF"",106,0)"
^XMB(3.9,144657,2,8944,0)=" . . . S DESTSTAT=$$GET1^DIQ(365.191,DESTIEN_"",""_IEN_"","",.02,""I"")"
^XMB(3.9,144657,2,8945,0)="""RTN"",""IBCNIUF"",107,0)"
^XMB(3.9,144657,2,8946,0)=" . . . I DESTSTAT=""R"",$D(SITES(DEST)) K SITES(DEST) S SITES=SITES-1 Q  ; waiting to send to site"
^XMB(3.9,144657,2,8947,0)="""RTN"",""IBCNIUF"",108,0)"
^XMB(3.9,144657,2,8948,0)=" . . . S DESTDT=$P($$GET1^DIQ(365.191,DESTIEN_"",""_IEN_"","",.03,""I""),""."") ;date only"
^XMB(3.9,144657,2,8949,0)="""RTN"",""IBCNIUF"",109,0)"
^XMB(3.9,144657,2,8950,0)=" . . . ;"
^XMB(3.9,144657,2,8951,0)="""RTN"",""IBCNIUF"",110,0)"
^XMB(3.9,144657,2,8952,0)=" . . . ; SUBTRACT IIU MIN DAYS BEFORE SHARING (#53.04) from Today.  If the date is less than DATE/TIME CREATED (#.02) it is too soon."
^XMB(3.9,144657,2,8953,0)="""RTN"",""IBCNIUF"",111,0)"
^XMB(3.9,144657,2,8954,0)=" . . . I SHAREDT<DESTDT K SITES(DEST) S SITES=SITES-1"
^XMB(3.9,144657,2,8955,0)="""RTN"",""IBCNIUF"",112,0)"
^XMB(3.9,144657,2,8956,0)=" ;"
^XMB(3.9,144657,2,8957,0)="""RTN"",""IBCNIUF"",113,0)"
^XMB(3.9,144657,2,8958,0)=" I 'SITES G OKTOFILEQ ;No sites to send to"
^XMB(3.9,144657,2,8959,0)="""RTN"",""IBCNIUF"",114,0)"
^XMB(3.9,144657,2,8960,0)=" ;"
^XMB(3.9,144657,2,8961,0)="""RTN"",""IBCNIUF"",115,0)"
^XMB(3.9,144657,2,8962,0)=" S OK=1"
^XMB(3.9,144657,2,8963,0)="""RTN"",""IBCNIUF"",116,0)"
^XMB(3.9,144657,2,8964,0)=" ;"
^XMB(3.9,144657,2,8965,0)="""RTN"",""IBCNIUF"",117,0)"
^XMB(3.9,144657,2,8966,0)="OKTOFILEQ ;"
^XMB(3.9,144657,2,8967,0)="""RTN"",""IBCNIUF"",118,0)"
^XMB(3.9,144657,2,8968,0)=" Q OK"
^XMB(3.9,144657,2,8969,0)="""RTN"",""IBCNIUF"",119,0)"
^XMB(3.9,144657,2,8970,0)=" ;"
^XMB(3.9,144657,2,8971,0)="""RTN"",""IBCNIUF"",120,0)"
^XMB(3.9,144657,2,8972,0)="TFL(DFN,IBT,DIR) ; returns treating facility list (pass IBT by reference)"
^XMB(3.9,144657,2,8973,0)="""RTN"",""IBCNIUF"",121,0)"
^XMB(3.9,144657,2,8974,0)=" ;INPUT:"
^XMB(3.9,144657,2,8975,0)="""RTN"",""IBCNIUF"",122,0)"
^XMB(3.9,144657,2,8976,0)=" ;    DFN  - Patient's IEN in the Patient File"
^XMB(3.9,144657,2,8977,0)="""RTN"",""IBCNIUF"",123,0)"
^XMB(3.9,144657,2,8978,0)=" ;    IBT  - Array of visited facilities"
^XMB(3.9,144657,2,8979,0)="""RTN"",""IBCNIUF"",124,0)"
^XMB(3.9,144657,2,8980,0)=" ;    DIR  - Direction of data flow"
^XMB(3.9,144657,2,8981,0)="""RTN"",""IBCNIUF"",125,0)"
^XMB(3.9,144657,2,8982,0)=" ;           S = Sending"
^XMB(3.9,144657,2,8983,0)="""RTN"",""IBCNIUF"",126,0)"
^XMB(3.9,144657,2,8984,0)=" ;           R = Receiving"
^XMB(3.9,144657,2,8985,0)="""RTN"",""IBCNIUF"",127,0)"
^XMB(3.9,144657,2,8986,0)=" ;OUTPUT:"
^XMB(3.9,144657,2,8987,0)="""RTN"",""IBCNIUF"",128,0)"
^XMB(3.9,144657,2,8988,0)=" ;    IBT  - Array of sites"
^XMB(3.9,144657,2,8989,0)="""RTN"",""IBCNIUF"",129,0)"
^XMB(3.9,144657,2,8990,0)=" ;           Can have multiple entries for Sending"
^XMB(3.9,144657,2,8991,0)="""RTN"",""IBCNIUF"",130,0)"
^XMB(3.9,144657,2,8992,0)=" ;           Will have 1 entry for receiving"
^XMB(3.9,144657,2,8993,0)="""RTN"",""IBCNIUF"",131,0)"
^XMB(3.9,144657,2,8994,0)=" ; supported references IA #2990 and #10112, value returned is count"
^XMB(3.9,144657,2,8995,0)="""RTN"",""IBCNIUF"",132,0)"
^XMB(3.9,144657,2,8996,0)=" ; needed to new Y because VAFCTFU1 will kill it"
^XMB(3.9,144657,2,8997,0)="""RTN"",""IBCNIUF"",133,0)"
^XMB(3.9,144657,2,8998,0)=" N FTLIEN,IBC,IBZ,IBS,IBFT,Y"
^XMB(3.9,144657,2,8999,0)="""RTN"",""IBCNIUF"",134,0)"
^XMB(3.9,144657,2,9000,0)=" ;"
^XMB(3.9,144657,2,9001,0)="""RTN"",""IBCNIUF"",135,0)"
^XMB(3.9,144657,2,9002,0)=" K IBT"
^XMB(3.9,144657,2,9003,0)="""RTN"",""IBCNIUF"",136,0)"
^XMB(3.9,144657,2,9004,0)=" S DIR=$G(DIR,""S"")"
^XMB(3.9,144657,2,9005,0)="""RTN"",""IBCNIUF"",137,0)"
^XMB(3.9,144657,2,9006,0)=" D TFL^VAFCTFU1(.IBZ,DFN) Q:-$G(IBZ(1))=1 0"
^XMB(3.9,144657,2,9007,0)="""RTN"",""IBCNIUF"",138,0)"
^XMB(3.9,144657,2,9008,0)=" ; Setup current site and initialize variables"
^XMB(3.9,144657,2,9009,0)="""RTN"",""IBCNIUF"",139,0)"
^XMB(3.9,144657,2,9010,0)=" S IBS=+$P($$SITE^VASITE,""^"",3),(IBZ,IBC)=0"
^XMB(3.9,144657,2,9011,0)="""RTN"",""IBCNIUF"",140,0)"
^XMB(3.9,144657,2,9012,0)=" ; Return only remote facilities of certain types:"
^XMB(3.9,144657,2,9013,0)="""RTN"",""IBCNIUF"",141,0)"
^XMB(3.9,144657,2,9014,0)=" S IBFT=""^VAMC^"""
^XMB(3.9,144657,2,9015,0)="""RTN"",""IBCNIUF"",142,0)"
^XMB(3.9,144657,2,9016,0)=" F  S IBZ=$O(IBZ(IBZ)) Q:IBZ<1  I +IBZ(IBZ)>0 D"
^XMB(3.9,144657,2,9017,0)="""RTN"",""IBCNIUF"",143,0)"
^XMB(3.9,144657,2,9018,0)=" . I (+IBZ(IBZ)=358),$$GET1^DIQ(350.9,""1,"",51.33,""I"")=""N"" Q  ;Manila is not participating"
^XMB(3.9,144657,2,9019,0)="""RTN"",""IBCNIUF"",144,0)"
^XMB(3.9,144657,2,9020,0)=" . S FTLIEN=$$FIND1^DIC(4,,""X"",+IBZ(IBZ),""D"") I 'FTLIEN Q"
^XMB(3.9,144657,2,9021,0)="""RTN"",""IBCNIUF"",145,0)"
^XMB(3.9,144657,2,9022,0)=" . ;If it is the current site and Sending, Q.  If receiving set array."
^XMB(3.9,144657,2,9023,0)="""RTN"",""IBCNIUF"",146,0)"
^XMB(3.9,144657,2,9024,0)=" . I +IBZ(IBZ)=IBS Q:(DIR'=""R"")  S IBT(FTLIEN)=IBZ(IBZ),IBC=IBC+1 Q"
^XMB(3.9,144657,2,9025,0)="""RTN"",""IBCNIUF"",147,0)"
^XMB(3.9,144657,2,9026,0)=" . ; build array for sending sites"
^XMB(3.9,144657,2,9027,0)="""RTN"",""IBCNIUF"",148,0)"
^XMB(3.9,144657,2,9028,0)=" . I DIR=""R"" Q"
^XMB(3.9,144657,2,9029,0)="""RTN"",""IBCNIUF"",149,0)"
^XMB(3.9,144657,2,9030,0)=" . I $$INSTS^IBCNINSL(FTLIEN) S IBT(FTLIEN)=IBZ(IBZ),IBC=IBC+1"
^XMB(3.9,144657,2,9031,0)="""RTN"",""IBCNIUF"",150,0)"
^XMB(3.9,144657,2,9032,0)=" Q IBC"
^XMB(3.9,144657,2,9033,0)="""RTN"",""IBCNIUF"",151,0)"
^XMB(3.9,144657,2,9034,0)=" ;"
^XMB(3.9,144657,2,9035,0)="""RTN"",""IBCNIUF"",152,0)"
^XMB(3.9,144657,2,9036,0)="ACTIVE() ;Check active policy status"
^XMB(3.9,144657,2,9037,0)="""RTN"",""IBCNIUF"",153,0)"
^XMB(3.9,144657,2,9038,0)=" N OK,EFFDT,EXPDT"
^XMB(3.9,144657,2,9039,0)="""RTN"",""IBCNIUF"",154,0)"
^XMB(3.9,144657,2,9040,0)=" S OK=0"
^XMB(3.9,144657,2,9041,0)="""RTN"",""IBCNIUF"",155,0)"
^XMB(3.9,144657,2,9042,0)=" S EFFDT=$$GET1^DIQ(2.312,IENS,8,""I"")"
^XMB(3.9,144657,2,9043,0)="""RTN"",""IBCNIUF"",156,0)"
^XMB(3.9,144657,2,9044,0)=" S EXPDT=$$GET1^DIQ(2.312,IENS,3,""I"")"
^XMB(3.9,144657,2,9045,0)="""RTN"",""IBCNIUF"",157,0)"
^XMB(3.9,144657,2,9046,0)=" I 'EFFDT G ACTIVEQ"
^XMB(3.9,144657,2,9047,0)="""RTN"",""IBCNIUF"",158,0)"
^XMB(3.9,144657,2,9048,0)=" I EXPDT,(EXPDT<DT) G ACTIVEQ"
^XMB(3.9,144657,2,9049,0)="""RTN"",""IBCNIUF"",159,0)"
^XMB(3.9,144657,2,9050,0)=" S OK=1"
^XMB(3.9,144657,2,9051,0)="""RTN"",""IBCNIUF"",160,0)"
^XMB(3.9,144657,2,9052,0)=" ;"
^XMB(3.9,144657,2,9053,0)="""RTN"",""IBCNIUF"",161,0)"
^XMB(3.9,144657,2,9054,0)="ACTIVEQ ;"
^XMB(3.9,144657,2,9055,0)="""RTN"",""IBCNIUF"",162,0)"
^XMB(3.9,144657,2,9056,0)=" Q OK"
^XMB(3.9,144657,2,9057,0)="""RTN"",""IBCNIUF"",163,0)"
^XMB(3.9,144657,2,9058,0)=" ;"
^XMB(3.9,144657,2,9059,0)="""RTN"",""IBCNIUF"",164,0)"
^XMB(3.9,144657,2,9060,0)="TOP() ;Screen Type of Plan"
^XMB(3.9,144657,2,9061,0)="""RTN"",""IBCNIUF"",165,0)"
^XMB(3.9,144657,2,9062,0)=" N GRPIEN,OK,TOP"
^XMB(3.9,144657,2,9063,0)="""RTN"",""IBCNIUF"",166,0)"
