^XMB(3.9,145839,2,1085,0)="""RTN"",""TIUCCRHL7P4"",47,0)"
^XMB(3.9,145839,2,1086,0)=" S D1=$P(WORDS,""Original CCP Note Date (mm/dd/yyyy):"",2),D2=$P(D1,""CCPN Number:"",1)"
^XMB(3.9,145839,2,1087,0)="""RTN"",""TIUCCRHL7P4"",48,0)"
