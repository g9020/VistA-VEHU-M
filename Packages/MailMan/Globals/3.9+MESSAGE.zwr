^XMB(3.9,145833,2,2109,0)="""RTN"",""SDESUTIL"",1,0)"
^XMB(3.9,145833,2,2110,0)="SDESUTIL ;ALB/TAW,KML,LAB,MGD,ANU,MGD,ANU,BWF,TJB,MCB,MCB,TAW- SDES Utilities ;Oct 03,2025"
^XMB(3.9,145833,2,2111,0)="""RTN"",""SDESUTIL"",2,0)"
^XMB(3.9,145833,2,2112,0)=" ;;5.3;Scheduling;**801,804,805,814,816,818,820,823,824,825,831,836,838,845,851,877,878,887,897,910,920**;Aug 13, 1993;Build 0"
^XMB(3.9,145833,2,2113,0)="""RTN"",""SDESUTIL"",3,0)"
^XMB(3.9,145833,2,2114,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
^XMB(3.9,145833,2,2115,0)="""RTN"",""SDESUTIL"",4,0)"
^XMB(3.9,145833,2,2116,0)=" ;"
^XMB(3.9,145833,2,2117,0)="""RTN"",""SDESUTIL"",5,0)"
^XMB(3.9,145833,2,2118,0)=" ; Reference to INSTITUTION in #2251"
^XMB(3.9,145833,2,2119,0)="""RTN"",""SDESUTIL"",6,0)"
^XMB(3.9,145833,2,2120,0)=" ; Reference to KERNEL SYSTEM PARAMETERS in #1518"
^XMB(3.9,145833,2,2121,0)="""RTN"",""SDESUTIL"",7,0)"
^XMB(3.9,145833,2,2122,0)=" ; Reference to ^ECX(728.44 in #7340"
^XMB(3.9,145833,2,2123,0)="""RTN"",""SDESUTIL"",8,0)"
^XMB(3.9,145833,2,2124,0)=" Q"
^XMB(3.9,145833,2,2125,0)="""RTN"",""SDESUTIL"",9,0)"
^XMB(3.9,145833,2,2126,0)=" ;"
^XMB(3.9,145833,2,2127,0)="""RTN"",""SDESUTIL"",10,0)"
^XMB(3.9,145833,2,2128,0)="PADCLTIME(TIME) ;"
^XMB(3.9,145833,2,2129,0)="""RTN"",""SDESUTIL"",11,0)"
^XMB(3.9,145833,2,2130,0)=" ; TIME - Time to Pad"
^XMB(3.9,145833,2,2131,0)="""RTN"",""SDESUTIL"",12,0)"
^XMB(3.9,145833,2,2132,0)=" S TIME=$S($G(TIME)'="""":TIME,1:8)"
^XMB(3.9,145833,2,2133,0)="""RTN"",""SDESUTIL"",13,0)"
^XMB(3.9,145833,2,2134,0)=" I TIME'?1.2N Q -1"
^XMB(3.9,145833,2,2135,0)="""RTN"",""SDESUTIL"",14,0)"
^XMB(3.9,145833,2,2136,0)=" S TIME=TIME_""00"""
^XMB(3.9,145833,2,2137,0)="""RTN"",""SDESUTIL"",15,0)"
^XMB(3.9,145833,2,2138,0)=" Q TIME"
^XMB(3.9,145833,2,2139,0)="""RTN"",""SDESUTIL"",16,0)"
^XMB(3.9,145833,2,2140,0)=" ;"
^XMB(3.9,145833,2,2141,0)="""RTN"",""SDESUTIL"",17,0)"
^XMB(3.9,145833,2,2142,0)="PADFMTIME(TIME) ;"
^XMB(3.9,145833,2,2143,0)="""RTN"",""SDESUTIL"",18,0)"
^XMB(3.9,145833,2,2144,0)=" ; TIME - Time to Pad"
^XMB(3.9,145833,2,2145,0)="""RTN"",""SDESUTIL"",19,0)"
^XMB(3.9,145833,2,2146,0)=" I TIME'?1.4N Q -1"
^XMB(3.9,145833,2,2147,0)="""RTN"",""SDESUTIL"",20,0)"
^XMB(3.9,145833,2,2148,0)=" S TIME=$E(TIME_""0000"",1,4)"
^XMB(3.9,145833,2,2149,0)="""RTN"",""SDESUTIL"",21,0)"
^XMB(3.9,145833,2,2150,0)=" Q TIME"
^XMB(3.9,145833,2,2151,0)="""RTN"",""SDESUTIL"",22,0)"
^XMB(3.9,145833,2,2152,0)=" ;"
^XMB(3.9,145833,2,2153,0)="""RTN"",""SDESUTIL"",23,0)"
^XMB(3.9,145833,2,2154,0)="PADLENGTH(STRING,CHAR,LENGTH,WHERE) ;"
^XMB(3.9,145833,2,2155,0)="""RTN"",""SDESUTIL"",24,0)"
^XMB(3.9,145833,2,2156,0)=" N PAD,PADST"
^XMB(3.9,145833,2,2157,0)="""RTN"",""SDESUTIL"",25,0)"
^XMB(3.9,145833,2,2158,0)=" I $L(STRING)'<LENGTH Q STRING"
^XMB(3.9,145833,2,2159,0)="""RTN"",""SDESUTIL"",26,0)"
^XMB(3.9,145833,2,2160,0)=" S PADST=LENGTH-$L(STRING)"
^XMB(3.9,145833,2,2161,0)="""RTN"",""SDESUTIL"",27,0)"
^XMB(3.9,145833,2,2162,0)=" S $P(PAD,CHAR,PADST)=CHAR"
^XMB(3.9,145833,2,2163,0)="""RTN"",""SDESUTIL"",28,0)"
^XMB(3.9,145833,2,2164,0)=" I WHERE=""F"" S STRING=PAD_STRING"
^XMB(3.9,145833,2,2165,0)="""RTN"",""SDESUTIL"",29,0)"
^XMB(3.9,145833,2,2166,0)=" I WHERE=""E"" S STRING=STRING_PAD"
^XMB(3.9,145833,2,2167,0)="""RTN"",""SDESUTIL"",30,0)"
^XMB(3.9,145833,2,2168,0)=" Q STRING"
^XMB(3.9,145833,2,2169,0)="""RTN"",""SDESUTIL"",31,0)"
^XMB(3.9,145833,2,2170,0)=" ;"
^XMB(3.9,145833,2,2171,0)="""RTN"",""SDESUTIL"",32,0)"
^XMB(3.9,145833,2,2172,0)="EASVALIDATE(SDEAS) ;"
^XMB(3.9,145833,2,2173,0)="""RTN"",""SDESUTIL"",33,0)"
^XMB(3.9,145833,2,2174,0)=" I SDEAS="""" S SDEAS=-1 Q SDEAS"
^XMB(3.9,145833,2,2175,0)="""RTN"",""SDESUTIL"",34,0)"
^XMB(3.9,145833,2,2176,0)=" S SDEAS=$$STRIP(SDEAS)"
^XMB(3.9,145833,2,2177,0)="""RTN"",""SDESUTIL"",35,0)"
^XMB(3.9,145833,2,2178,0)=" I $L(SDEAS)>40 S SDEAS=-1"
^XMB(3.9,145833,2,2179,0)="""RTN"",""SDESUTIL"",36,0)"
^XMB(3.9,145833,2,2180,0)=" Q SDEAS"
^XMB(3.9,145833,2,2181,0)="""RTN"",""SDESUTIL"",37,0)"
^XMB(3.9,145833,2,2182,0)=" ;"
^XMB(3.9,145833,2,2183,0)="""RTN"",""SDESUTIL"",38,0)"
^XMB(3.9,145833,2,2184,0)="STRIP(SDECZ) ;Replace control characters with spaces"
^XMB(3.9,145833,2,2185,0)="""RTN"",""SDESUTIL"",39,0)"
^XMB(3.9,145833,2,2186,0)=" N SDECI"
^XMB(3.9,145833,2,2187,0)="""RTN"",""SDESUTIL"",40,0)"
^XMB(3.9,145833,2,2188,0)=" F SDECI=1:1:$L(SDECZ) I (32>$A($E(SDECZ,SDECI))) S SDECZ=$E(SDECZ,1,SDECI-1)_"" ""_$E(SDECZ,SDECI+1,999)"
^XMB(3.9,145833,2,2189,0)="""RTN"",""SDESUTIL"",41,0)"
^XMB(3.9,145833,2,2190,0)=" Q SDECZ"
^XMB(3.9,145833,2,2191,0)="""RTN"",""SDESUTIL"",42,0)"
^XMB(3.9,145833,2,2192,0)=" ;"
^XMB(3.9,145833,2,2193,0)="""RTN"",""SDESUTIL"",43,0)"
^XMB(3.9,145833,2,2194,0)="ISDATEDST(DATE,DSTSUM) ;Does this date use Daylight Savings"
^XMB(3.9,145833,2,2195,0)="""RTN"",""SDESUTIL"",44,0)"
^XMB(3.9,145833,2,2196,0)=" ; DATE -    FM format"
^XMB(3.9,145833,2,2197,0)="""RTN"",""SDESUTIL"",45,0)"
^XMB(3.9,145833,2,2198,0)=" ; DSTSUM - ""DST"" or ""SUM"""
^XMB(3.9,145833,2,2199,0)="""RTN"",""SDESUTIL"",46,0)"
^XMB(3.9,145833,2,2200,0)=" ; Return 1 = DATE is considered DST or SUM"
^XMB(3.9,145833,2,2201,0)="""RTN"",""SDESUTIL"",47,0)"
^XMB(3.9,145833,2,2202,0)=" ;        0 = DATE is not DST and not SUM"
^XMB(3.9,145833,2,2203,0)="""RTN"",""SDESUTIL"",48,0)"
^XMB(3.9,145833,2,2204,0)=" ;       -1 = DATE is not FM format"
^XMB(3.9,145833,2,2205,0)="""RTN"",""SDESUTIL"",49,0)"
^XMB(3.9,145833,2,2206,0)=" N YR"
^XMB(3.9,145833,2,2207,0)="""RTN"",""SDESUTIL"",50,0)"
^XMB(3.9,145833,2,2208,0)=" S DATE=$G(DATE),DSTSUM=$G(DSTSUM)"
^XMB(3.9,145833,2,2209,0)="""RTN"",""SDESUTIL"",51,0)"
^XMB(3.9,145833,2,2210,0)=" I '$$VALIDFMFORMAT^SDECDATE(DATE) Q -1"
^XMB(3.9,145833,2,2211,0)="""RTN"",""SDESUTIL"",52,0)"
^XMB(3.9,145833,2,2212,0)=" S YR=$E(DATE,2,3)"
^XMB(3.9,145833,2,2213,0)="""RTN"",""SDESUTIL"",53,0)"
^XMB(3.9,145833,2,2214,0)=" I DATE<$$DSTSTART(YR,DSTSUM) Q 0"
^XMB(3.9,145833,2,2215,0)="""RTN"",""SDESUTIL"",54,0)"
^XMB(3.9,145833,2,2216,0)=" I DATE>=$$DSTEND(YR,DSTSUM) Q 0"
^XMB(3.9,145833,2,2217,0)="""RTN"",""SDESUTIL"",55,0)"
^XMB(3.9,145833,2,2218,0)=" Q 1"
^XMB(3.9,145833,2,2219,0)="""RTN"",""SDESUTIL"",56,0)"
^XMB(3.9,145833,2,2220,0)="DSTSTART(YR,DSTSUM) ;Daylight Savings or Summer start date"
^XMB(3.9,145833,2,2221,0)="""RTN"",""SDESUTIL"",57,0)"
^XMB(3.9,145833,2,2222,0)=" ; countries that observe DST or Summer ST (e.g., USA observes DST and Europe observes SUM ST)"
^XMB(3.9,145833,2,2223,0)="""RTN"",""SDESUTIL"",58,0)"
^XMB(3.9,145833,2,2224,0)=" ; YR - 2 digit year"
^XMB(3.9,145833,2,2225,0)="""RTN"",""SDESUTIL"",59,0)"
^XMB(3.9,145833,2,2226,0)=" ; DSTSUM - ""DST"" or ""SUM"""
^XMB(3.9,145833,2,2227,0)="""RTN"",""SDESUTIL"",60,0)"
^XMB(3.9,145833,2,2228,0)=" ; Return is the FM date for the FIRST day of DST or SUM"
^XMB(3.9,145833,2,2229,0)="""RTN"",""SDESUTIL"",61,0)"
^XMB(3.9,145833,2,2230,0)=" N DSTMONTH,DOW,DSTDT,SUNDAY"
^XMB(3.9,145833,2,2231,0)="""RTN"",""SDESUTIL"",62,0)"
^XMB(3.9,145833,2,2232,0)=" S DSTMONTH=""0301"",DSTSUM=$G(DSTSUM)"
^XMB(3.9,145833,2,2233,0)="""RTN"",""SDESUTIL"",63,0)"
^XMB(3.9,145833,2,2234,0)=" ; SUNDAY will be 2nd Sunday in March OR Last Sunday in March"
^XMB(3.9,145833,2,2235,0)="""RTN"",""SDESUTIL"",64,0)"
^XMB(3.9,145833,2,2236,0)=" S SUNDAY=$S(DSTSUM=""DST"":2,DSTSUM=""SUM"":""4,5"",1:2) ;if not DST or SUM, treat as DST"
^XMB(3.9,145833,2,2237,0)="""RTN"",""SDESUTIL"",65,0)"
^XMB(3.9,145833,2,2238,0)=" S YR=$G(YR)"
^XMB(3.9,145833,2,2239,0)="""RTN"",""SDESUTIL"",66,0)"
^XMB(3.9,145833,2,2240,0)=" I YR="""" S DSTDT=$E(DT,1,3)_DSTMONTH"
^XMB(3.9,145833,2,2241,0)="""RTN"",""SDESUTIL"",67,0)"
^XMB(3.9,145833,2,2242,0)=" E  S DSTDT=$E(DT)_YR_DSTMONTH"
^XMB(3.9,145833,2,2243,0)="""RTN"",""SDESUTIL"",68,0)"
^XMB(3.9,145833,2,2244,0)=" S DOW=$$DOW^XLFDT(DSTDT,1)"
^XMB(3.9,145833,2,2245,0)="""RTN"",""SDESUTIL"",69,0)"
^XMB(3.9,145833,2,2246,0)=" I DOW D"
^XMB(3.9,145833,2,2247,0)="""RTN"",""SDESUTIL"",70,0)"
^XMB(3.9,145833,2,2248,0)=" .I DSTSUM=""DST"" S DSTDT=DSTDT+(SUNDAY*7)-DOW"
^XMB(3.9,145833,2,2249,0)="""RTN"",""SDESUTIL"",71,0)"
^XMB(3.9,145833,2,2250,0)=" .E  S DSTDT=$$SUMMER(DSTDT,DOW,SUNDAY)"
^XMB(3.9,145833,2,2251,0)="""RTN"",""SDESUTIL"",72,0)"
^XMB(3.9,145833,2,2252,0)=" I (DSTSUM=""DST"")&(DOW=0) S DSTDT=DSTDT+(7)-DOW"
^XMB(3.9,145833,2,2253,0)="""RTN"",""SDESUTIL"",73,0)"
^XMB(3.9,145833,2,2254,0)=" Q DSTDT"
^XMB(3.9,145833,2,2255,0)="""RTN"",""SDESUTIL"",74,0)"
^XMB(3.9,145833,2,2256,0)="DSTEND(YR,DSTSUM) ;Daylight Savings END date"
^XMB(3.9,145833,2,2257,0)="""RTN"",""SDESUTIL"",75,0)"
^XMB(3.9,145833,2,2258,0)=" ; YR - 2 digit year"
^XMB(3.9,145833,2,2259,0)="""RTN"",""SDESUTIL"",76,0)"
^XMB(3.9,145833,2,2260,0)=" ; DSTSUM - ""DST"" or ""SUM"""
^XMB(3.9,145833,2,2261,0)="""RTN"",""SDESUTIL"",77,0)"
^XMB(3.9,145833,2,2262,0)=" ; Return is the FM date for the LAST day of DST or SUM"
^XMB(3.9,145833,2,2263,0)="""RTN"",""SDESUTIL"",78,0)"
^XMB(3.9,145833,2,2264,0)=" N DSTMONTH,DOW,DSTDT,SUNDAY"
^XMB(3.9,145833,2,2265,0)="""RTN"",""SDESUTIL"",79,0)"
^XMB(3.9,145833,2,2266,0)=" S DSTSUM=$G(DSTSUM)"
^XMB(3.9,145833,2,2267,0)="""RTN"",""SDESUTIL"",80,0)"
^XMB(3.9,145833,2,2268,0)=" S DSTMONTH=$S(DSTSUM=""DST"":""1101"",DSTSUM=""SUM"":""1001"",1:""1101"")"
^XMB(3.9,145833,2,2269,0)="""RTN"",""SDESUTIL"",81,0)"
^XMB(3.9,145833,2,2270,0)=" ; SUNDAY will be first Sunday in November or last Sunday in October"
^XMB(3.9,145833,2,2271,0)="""RTN"",""SDESUTIL"",82,0)"
^XMB(3.9,145833,2,2272,0)=" S SUNDAY=$S(DSTSUM=""DST"":1,DSTSUM=""SUM"":""4,5"",1:1)  ; if not DST or SUM treat as DST"
^XMB(3.9,145833,2,2273,0)="""RTN"",""SDESUTIL"",83,0)"
^XMB(3.9,145833,2,2274,0)=" S YR=$G(YR)"
^XMB(3.9,145833,2,2275,0)="""RTN"",""SDESUTIL"",84,0)"
^XMB(3.9,145833,2,2276,0)=" I YR="""" S DSTDT=$E(DT,1,3)_DSTMONTH"
^XMB(3.9,145833,2,2277,0)="""RTN"",""SDESUTIL"",85,0)"
^XMB(3.9,145833,2,2278,0)=" E  S DSTDT=$E(DT)_YR_DSTMONTH"
^XMB(3.9,145833,2,2279,0)="""RTN"",""SDESUTIL"",86,0)"
^XMB(3.9,145833,2,2280,0)=" S DOW=$$DOW^XLFDT(DSTDT,1)"
^XMB(3.9,145833,2,2281,0)="""RTN"",""SDESUTIL"",87,0)"
^XMB(3.9,145833,2,2282,0)=" I DOW D"
^XMB(3.9,145833,2,2283,0)="""RTN"",""SDESUTIL"",88,0)"
^XMB(3.9,145833,2,2284,0)=" .I DSTSUM=""DST"" S DSTDT=DSTDT+(SUNDAY*7)-DOW"
^XMB(3.9,145833,2,2285,0)="""RTN"",""SDESUTIL"",89,0)"
^XMB(3.9,145833,2,2286,0)=" .E  S DSTDT=$$SUMMER(DSTDT,DOW,SUNDAY)"
^XMB(3.9,145833,2,2287,0)="""RTN"",""SDESUTIL"",90,0)"
^XMB(3.9,145833,2,2288,0)=" Q DSTDT"
^XMB(3.9,145833,2,2289,0)="""RTN"",""SDESUTIL"",91,0)"
^XMB(3.9,145833,2,2290,0)=" ;"
^XMB(3.9,145833,2,2291,0)="""RTN"",""SDESUTIL"",92,0)"
^XMB(3.9,145833,2,2292,0)="SUMMER(DSTDT,DOW,SUNDAY) ; determine last Sunday of MARCH or OCTOBER"
^XMB(3.9,145833,2,2293,0)="""RTN"",""SDESUTIL"",93,0)"
^XMB(3.9,145833,2,2294,0)=" ; DSTDT - March or October (e.g, CYY0301 or CYY1001)"
^XMB(3.9,145833,2,2295,0)="""RTN"",""SDESUTIL"",94,0)"
^XMB(3.9,145833,2,2296,0)=" ; DOW - 1, 2, 3, 4, 5, or 6"
^XMB(3.9,145833,2,2297,0)="""RTN"",""SDESUTIL"",95,0)"
^XMB(3.9,145833,2,2298,0)=" ; SUNDAY - ""4,5"" representing 4th or 5th Sunday of March or October"
^XMB(3.9,145833,2,2299,0)="""RTN"",""SDESUTIL"",96,0)"
^XMB(3.9,145833,2,2300,0)=" ; Returns the date when SUMMER offset begins or ends (e.g., eastern Europe uses Summer offset)"
^XMB(3.9,145833,2,2301,0)="""RTN"",""SDESUTIL"",97,0)"
^XMB(3.9,145833,2,2302,0)=" N X,VALIDSUNDAY,LASTSUNDAY"
^XMB(3.9,145833,2,2303,0)="""RTN"",""SDESUTIL"",98,0)"
^XMB(3.9,145833,2,2304,0)=" S DSTDT=$G(DSTDT),DOW=$G(DOW),SUNDAY=$G(SUNDAY)"
^XMB(3.9,145833,2,2305,0)="""RTN"",""SDESUTIL"",99,0)"
^XMB(3.9,145833,2,2306,0)=" S LASTSUNDAY=0"
^XMB(3.9,145833,2,2307,0)="""RTN"",""SDESUTIL"",100,0)"
^XMB(3.9,145833,2,2308,0)=" F X=1,2 S VALIDSUNDAY=DSTDT+($P(SUNDAY,"","",X)*7)-DOW I $$VALIDFMFORMAT^SDECDATE(VALIDSUNDAY) S LASTSUNDAY=VALIDSUNDAY"
^XMB(3.9,145833,2,2309,0)="""RTN"",""SDESUTIL"",101,0)"
^XMB(3.9,145833,2,2310,0)=" Q LASTSUNDAY"
^XMB(3.9,145833,2,2311,0)="""RTN"",""SDESUTIL"",102,0)"
^XMB(3.9,145833,2,2312,0)=" ;"
^XMB(3.9,145833,2,2313,0)="""RTN"",""SDESUTIL"",103,0)"
^XMB(3.9,145833,2,2314,0)="TIMEZONEDATA(CLINICIEN) ;Get timezone and offsets"
^XMB(3.9,145833,2,2315,0)="""RTN"",""SDESUTIL"",104,0)"
^XMB(3.9,145833,2,2316,0)=" ; CLINIC - IEN from Hospital Location #44"
^XMB(3.9,145833,2,2317,0)="""RTN"",""SDESUTIL"",105,0)"
^XMB(3.9,145833,2,2318,0)=" ;    If clinic is not passed, use default Facility/Institution"
^XMB(3.9,145833,2,2319,0)="""RTN"",""SDESUTIL"",106,0)"
^XMB(3.9,145833,2,2320,0)=" ; Output:"
^XMB(3.9,145833,2,2321,0)="""RTN"",""SDESUTIL"",107,0)"
^XMB(3.9,145833,2,2322,0)=" ;   Returns TimeZone Name ^ TimeZone IEN ^ TimeZone Exception ^ Offset for Standard Time ^ Offset for DST or SUMMER ^"
^XMB(3.9,145833,2,2323,0)="""RTN"",""SDESUTIL"",108,0)"
^XMB(3.9,145833,2,2324,0)=" N SDINST,SDDIV,SDTIMEZONEE,SDTIMEZONEI,TIMEZONEEXECPT,X,POP,TIMEFRAMEARY,OFFSET,OFFSETDSTSUM,DSTSUM,RETURN,TIMEFRAMEIEN,SDMSG"
^XMB(3.9,145833,2,2325,0)="""RTN"",""SDESUTIL"",109,0)"
^XMB(3.9,145833,2,2326,0)=" N EXECPTFLG"
^XMB(3.9,145833,2,2327,0)="""RTN"",""SDESUTIL"",110,0)"
^XMB(3.9,145833,2,2328,0)=" S (POP,SDINST,DSTSUM,EXECPTFLG)="""",(OFFSET,OFFSETDSTSUM)=-9999"
^XMB(3.9,145833,2,2329,0)="""RTN"",""SDESUTIL"",111,0)"
^XMB(3.9,145833,2,2330,0)=" I $G(CLINICIEN) D"
^XMB(3.9,145833,2,2331,0)="""RTN"",""SDESUTIL"",112,0)"
^XMB(3.9,145833,2,2332,0)=" .S SDDIV=$$GET1^DIQ(44,CLINICIEN_"","",3.5,""I"")"
^XMB(3.9,145833,2,2333,0)="""RTN"",""SDESUTIL"",113,0)"
^XMB(3.9,145833,2,2334,0)=" .S:SDDIV SDINST=$$GET1^DIQ(40.8,SDDIV_"","",.07,""I"")"
^XMB(3.9,145833,2,2335,0)="""RTN"",""SDESUTIL"",114,0)"
^XMB(3.9,145833,2,2336,0)=" ; 831 - BEGIN"
^XMB(3.9,145833,2,2337,0)="""RTN"",""SDESUTIL"",115,0)"
^XMB(3.9,145833,2,2338,0)=" I $$GET1^DIQ(4,SDINST,800,""I"")="""" S SDINST="""""
^XMB(3.9,145833,2,2339,0)="""RTN"",""SDESUTIL"",116,0)"
^XMB(3.9,145833,2,2340,0)=" ; 831 - END"
^XMB(3.9,145833,2,2341,0)="""RTN"",""SDESUTIL"",117,0)"
^XMB(3.9,145833,2,2342,0)=" I SDINST="""" S SDINST=$$GET1^DIQ(8989.3,1,217,""I"")"
^XMB(3.9,145833,2,2343,0)="""RTN"",""SDESUTIL"",118,0)"
^XMB(3.9,145833,2,2344,0)=" S SDTIMEZONEE=$$GET1^DIQ(4,SDINST,800,""E"")"
^XMB(3.9,145833,2,2345,0)="""RTN"",""SDESUTIL"",119,0)"
^XMB(3.9,145833,2,2346,0)=" S SDTIMEZONEI=$$GET1^DIQ(4,SDINST,800,""I"")"
^XMB(3.9,145833,2,2347,0)="""RTN"",""SDESUTIL"",120,0)"
^XMB(3.9,145833,2,2348,0)=" S EXECPTFLG=$$GET1^DIQ(4,SDINST,802,""I"")"
^XMB(3.9,145833,2,2349,0)="""RTN"",""SDESUTIL"",121,0)"
^XMB(3.9,145833,2,2350,0)=" S TIMEZONEEXECPT=$S(EXECPTFLG=0:1,1:0) ;if except value = 0 then exception is present"
^XMB(3.9,145833,2,2351,0)="""RTN"",""SDESUTIL"",122,0)"
^XMB(3.9,145833,2,2352,0)=" ;"
^XMB(3.9,145833,2,2353,0)="""RTN"",""SDESUTIL"",123,0)"
^XMB(3.9,145833,2,2354,0)=" F X=1:1:3 D  Q:POP"
^XMB(3.9,145833,2,2355,0)="""RTN"",""SDESUTIL"",124,0)"
^XMB(3.9,145833,2,2356,0)=" .S TIMEFRAMEIEN=X_"",""_SDTIMEZONEI_"","""
^XMB(3.9,145833,2,2357,0)="""RTN"",""SDESUTIL"",125,0)"
^XMB(3.9,145833,2,2358,0)=" .D GETS^DIQ(1.711,TIMEFRAMEIEN,"".01;.02"",""IE"",""TIMEFRAMEARY"",""SDMSG"") ;Data from WORLD TIMEZONE file"
^XMB(3.9,145833,2,2359,0)="""RTN"",""SDESUTIL"",126,0)"
^XMB(3.9,145833,2,2360,0)=" .I '$D(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01)) S POP=1 Q"
^XMB(3.9,145833,2,2361,0)="""RTN"",""SDESUTIL"",127,0)"
^XMB(3.9,145833,2,2362,0)=" .I $G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01,""I""))=""SST"" S OFFSET=$G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.02,""E""))"
^XMB(3.9,145833,2,2363,0)="""RTN"",""SDESUTIL"",128,0)"
^XMB(3.9,145833,2,2364,0)=" .I $G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01,""I""))=""DST"" S DSTSUM=""DST"",OFFSETDSTSUM=$G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.02,""E"")) ;vse-2705"
^XMB(3.9,145833,2,2365,0)="""RTN"",""SDESUTIL"",129,0)"
^XMB(3.9,145833,2,2366,0)=" .I $G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01,""I""))=""SUM"" S DSTSUM=""SUM"",OFFSETDSTSUM=$G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.02,""E"")) ;vse-2705"
^XMB(3.9,145833,2,2367,0)="""RTN"",""SDESUTIL"",130,0)"
^XMB(3.9,145833,2,2368,0)=" ;"
^XMB(3.9,145833,2,2369,0)="""RTN"",""SDESUTIL"",131,0)"
^XMB(3.9,145833,2,2370,0)=" Q SDTIMEZONEE_""^""_SDTIMEZONEI_""^""_TIMEZONEEXECPT_""^""_OFFSET_""^""_OFFSETDSTSUM_""^""_DSTSUM  ;vse-2705"
^XMB(3.9,145833,2,2371,0)="""RTN"",""SDESUTIL"",132,0)"
^XMB(3.9,145833,2,2372,0)=" ;"
^XMB(3.9,145833,2,2373,0)="""RTN"",""SDESUTIL"",133,0)"
^XMB(3.9,145833,2,2374,0)="GETTZOFFSET(SDDATE,SDCLINIC) ;Get Time Zone offset based on clinic and daylight savings"
^XMB(3.9,145833,2,2375,0)="""RTN"",""SDESUTIL"",134,0)"
^XMB(3.9,145833,2,2376,0)=" ; SDCLINIC - OPT - IEN from Hospital Location #44"
^XMB(3.9,145833,2,2377,0)="""RTN"",""SDESUTIL"",135,0)"
^XMB(3.9,145833,2,2378,0)=" ; SDDATE   - REQ - FM formatted date"
^XMB(3.9,145833,2,2379,0)="""RTN"",""SDESUTIL"",136,0)"
^XMB(3.9,145833,2,2380,0)=" ; Return"
^XMB(3.9,145833,2,2381,0)="""RTN"",""SDESUTIL"",137,0)"
^XMB(3.9,145833,2,2382,0)=" ;   If clinic is passed in get Division then Institution"
^XMB(3.9,145833,2,2383,0)="""RTN"",""SDESUTIL"",138,0)"
^XMB(3.9,145833,2,2384,0)=" ;   Otherwise get Institution from Kernel System Parameters"
^XMB(3.9,145833,2,2385,0)="""RTN"",""SDESUTIL"",139,0)"
^XMB(3.9,145833,2,2386,0)=" ;   Get the Time Zone and Time Zone Exception from the Institution"
^XMB(3.9,145833,2,2387,0)="""RTN"",""SDESUTIL"",140,0)"
^XMB(3.9,145833,2,2388,0)=" N OFFSET,TZINFO"
^XMB(3.9,145833,2,2389,0)="""RTN"",""SDESUTIL"",141,0)"
^XMB(3.9,145833,2,2390,0)=" S SDDATE=$G(SDDATE)"
^XMB(3.9,145833,2,2391,0)="""RTN"",""SDESUTIL"",142,0)"
^XMB(3.9,145833,2,2392,0)=" I '$$VALIDFMFORMAT^SDECDATE(SDDATE) Q """""
^XMB(3.9,145833,2,2393,0)="""RTN"",""SDESUTIL"",143,0)"
^XMB(3.9,145833,2,2394,0)=" S SDCLINIC=$G(SDCLINIC)"
^XMB(3.9,145833,2,2395,0)="""RTN"",""SDESUTIL"",144,0)"
^XMB(3.9,145833,2,2396,0)=" S TZINFO=$$TIMEZONEDATA(SDCLINIC)"
^XMB(3.9,145833,2,2397,0)="""RTN"",""SDESUTIL"",145,0)"
^XMB(3.9,145833,2,2398,0)=" S OFFSET=$P(TZINFO,""^"",4)   ;assume non DST"
^XMB(3.9,145833,2,2399,0)="""RTN"",""SDESUTIL"",146,0)"
^XMB(3.9,145833,2,2400,0)=" ; If the Institution uses DST or SUMMER & SDDATE is in the daylight savings period, then send the DST/SUMMER Offset"
^XMB(3.9,145833,2,2401,0)="""RTN"",""SDESUTIL"",147,0)"
^XMB(3.9,145833,2,2402,0)=" I $P(TZINFO,""^"",3)=0 S OFFSET=$S($$ISDATEDST(SDDATE,$P(TZINFO,""^"",6)):$P(TZINFO,""^"",5),1:OFFSET)"
^XMB(3.9,145833,2,2403,0)="""RTN"",""SDESUTIL"",148,0)"
^XMB(3.9,145833,2,2404,0)=" Q OFFSET"
^XMB(3.9,145833,2,2405,0)="""RTN"",""SDESUTIL"",149,0)"
^XMB(3.9,145833,2,2406,0)=" ;"
^XMB(3.9,145833,2,2407,0)="""RTN"",""SDESUTIL"",150,0)"
^XMB(3.9,145833,2,2408,0)="CHAR4(CLINNAME) ;"
^XMB(3.9,145833,2,2409,0)="""RTN"",""SDESUTIL"",151,0)"
^XMB(3.9,145833,2,2410,0)=" ; CLINNAME - REQ - Name of clinic from #44"
^XMB(3.9,145833,2,2411,0)="""RTN"",""SDESUTIL"",152,0)"
^XMB(3.9,145833,2,2412,0)=" ; Return"
^XMB(3.9,145833,2,2413,0)="""RTN"",""SDESUTIL"",153,0)"
^XMB(3.9,145833,2,2414,0)=" ;  The CODE (#.01) field from NATIONAL CLINIC (#728.411) file or null"
^XMB(3.9,145833,2,2415,0)="""RTN"",""SDESUTIL"",154,0)"
^XMB(3.9,145833,2,2416,0)=" N IEN,NATLCODE"
^XMB(3.9,145833,2,2417,0)="""RTN"",""SDESUTIL"",155,0)"
^XMB(3.9,145833,2,2418,0)=" I CLINNAME="""" Q """""
^XMB(3.9,145833,2,2419,0)="""RTN"",""SDESUTIL"",156,0)"
^XMB(3.9,145833,2,2420,0)=" I '$D(^SC(""B"",CLINNAME)) Q """""
^XMB(3.9,145833,2,2421,0)="""RTN"",""SDESUTIL"",157,0)"
^XMB(3.9,145833,2,2422,0)=" S IEN=$$FIND1^DIC(728.44,"""",""X"",CLINNAME)"
^XMB(3.9,145833,2,2423,0)="""RTN"",""SDESUTIL"",158,0)"
^XMB(3.9,145833,2,2424,0)=" I 'IEN Q """""
^XMB(3.9,145833,2,2425,0)="""RTN"",""SDESUTIL"",159,0)"
^XMB(3.9,145833,2,2426,0)=" S NATLCODE=$$GET1^DIQ(728.44,IEN_"","",7,""E"")"
^XMB(3.9,145833,2,2427,0)="""RTN"",""SDESUTIL"",160,0)"
^XMB(3.9,145833,2,2428,0)=" Q NATLCODE"
^XMB(3.9,145833,2,2429,0)="""RTN"",""SDESUTIL"",161,0)"
^XMB(3.9,145833,2,2430,0)=" ;"
^XMB(3.9,145833,2,2431,0)="""RTN"",""SDESUTIL"",162,0)"
^XMB(3.9,145833,2,2432,0)="TELEPHONE(PHONE) ; Format all numeric Telephone Number"
^XMB(3.9,145833,2,2433,0)="""RTN"",""SDESUTIL"",163,0)"
^XMB(3.9,145833,2,2434,0)=" ; PHONE - The Telephone Number"
^XMB(3.9,145833,2,2435,0)="""RTN"",""SDESUTIL"",164,0)"
^XMB(3.9,145833,2,2436,0)=" ; Return"
^XMB(3.9,145833,2,2437,0)="""RTN"",""SDESUTIL"",165,0)"
^XMB(3.9,145833,2,2438,0)=" ; If PHONE is all numeric it will be formatted as follows"
^XMB(3.9,145833,2,2439,0)="""RTN"",""SDESUTIL"",166,0)"
^XMB(3.9,145833,2,2440,0)=" ; 1234567890 will be formatted as (123)456-7890"
^XMB(3.9,145833,2,2441,0)="""RTN"",""SDESUTIL"",167,0)"
^XMB(3.9,145833,2,2442,0)=" ; otherwise the passed in PHONE is returned."
^XMB(3.9,145833,2,2443,0)="""RTN"",""SDESUTIL"",168,0)"
^XMB(3.9,145833,2,2444,0)=" S PHONE=$G(PHONE,"""")"
^XMB(3.9,145833,2,2445,0)="""RTN"",""SDESUTIL"",169,0)"
^XMB(3.9,145833,2,2446,0)=" I PHONE?10N S PHONE=""(""_$E(PHONE,1,3)_"")""_$E(PHONE,4,6)_""-""_$E(PHONE,7,10)"
^XMB(3.9,145833,2,2447,0)="""RTN"",""SDESUTIL"",170,0)"
^XMB(3.9,145833,2,2448,0)=" Q PHONE"
^XMB(3.9,145833,2,2449,0)="""RTN"",""SDESUTIL"",171,0)"
^XMB(3.9,145833,2,2450,0)=" ;"
^XMB(3.9,145833,2,2451,0)="""RTN"",""SDESUTIL"",172,0)"
^XMB(3.9,145833,2,2452,0)="EXT(EXT) ; Add an x to the beginning of an all numeric Telephone Extension field."
^XMB(3.9,145833,2,2453,0)="""RTN"",""SDESUTIL"",173,0)"
^XMB(3.9,145833,2,2454,0)=" ; EXT - The Telephone Extension."
^XMB(3.9,145833,2,2455,0)="""RTN"",""SDESUTIL"",174,0)"
^XMB(3.9,145833,2,2456,0)=" ; Return"
^XMB(3.9,145833,2,2457,0)="""RTN"",""SDESUTIL"",175,0)"
^XMB(3.9,145833,2,2458,0)=" ; If EXT is all numeric, a lowercase x concantenated to the passed in EXT."
^XMB(3.9,145833,2,2459,0)="""RTN"",""SDESUTIL"",176,0)"
^XMB(3.9,145833,2,2460,0)=" ; otherwise the passed in EXT is returned."
^XMB(3.9,145833,2,2461,0)="""RTN"",""SDESUTIL"",177,0)"
^XMB(3.9,145833,2,2462,0)=" S EXT=$G(EXT,"""")"
^XMB(3.9,145833,2,2463,0)="""RTN"",""SDESUTIL"",178,0)"
^XMB(3.9,145833,2,2464,0)=" I EXT?1.N S EXT=""x""_EXT"
^XMB(3.9,145833,2,2465,0)="""RTN"",""SDESUTIL"",179,0)"
^XMB(3.9,145833,2,2466,0)=" Q EXT"
^XMB(3.9,145833,2,2467,0)="""RTN"",""SDESUTIL"",180,0)"
^XMB(3.9,145833,2,2468,0)=" ;"
^XMB(3.9,145833,2,2469,0)="""RTN"",""SDESUTIL"",181,0)"
^XMB(3.9,145833,2,2470,0)="INACTIVE(SDCL,SDDT) ; determine if clinic is active"
^XMB(3.9,145833,2,2471,0)="""RTN"",""SDESUTIL"",182,0)"
^XMB(3.9,145833,2,2472,0)=" ; Input:"
^XMB(3.9,145833,2,2473,0)="""RTN"",""SDESUTIL"",183,0)"
^XMB(3.9,145833,2,2474,0)=" ;  SDCL = (Req) IEN of Clinic from file #44."
^XMB(3.9,145833,2,2475,0)="""RTN"",""SDESUTIL"",184,0)"
^XMB(3.9,145833,2,2476,0)=" ;  SDDT = (Opt) Date to use for determining Status. If not passed in, defaults to DT."
^XMB(3.9,145833,2,2477,0)="""RTN"",""SDESUTIL"",185,0)"
^XMB(3.9,145833,2,2478,0)=" ; Return:"
^XMB(3.9,145833,2,2479,0)="""RTN"",""SDESUTIL"",186,0)"
^XMB(3.9,145833,2,2480,0)=" ;  0=ACTIVE"
^XMB(3.9,145833,2,2481,0)="""RTN"",""SDESUTIL"",187,0)"
^XMB(3.9,145833,2,2482,0)=" ;  1=INACTIVE"
^XMB(3.9,145833,2,2483,0)="""RTN"",""SDESUTIL"",188,0)"
^XMB(3.9,145833,2,2484,0)=" Q $$INACTIVE^SDES2UTIL($G(SDCL),$G(SDDT))"
^XMB(3.9,145833,2,2485,0)="""RTN"",""SDESUTIL"",189,0)"
^XMB(3.9,145833,2,2486,0)=" ;"
^XMB(3.9,145833,2,2487,0)="""RTN"",""SDESUTIL"",190,0)"
^XMB(3.9,145833,2,2488,0)="STATIONNUMBER(CLINICIEN) ;"
^XMB(3.9,145833,2,2489,0)="""RTN"",""SDESUTIL"",191,0)"
^XMB(3.9,145833,2,2490,0)=" ; Input:"
^XMB(3.9,145833,2,2491,0)="""RTN"",""SDESUTIL"",192,0)"
^XMB(3.9,145833,2,2492,0)=" ; CLINICIEN (Opt) = IEN of the Clinic from File #44. If not passed in, the default"
^XMB(3.9,145833,2,2493,0)="""RTN"",""SDESUTIL"",193,0)"
^XMB(3.9,145833,2,2494,0)=" ;   Institution for the VistA Instance it used."
^XMB(3.9,145833,2,2495,0)="""RTN"",""SDESUTIL"",194,0)"
^XMB(3.9,145833,2,2496,0)=" ; Output: The STATION NUMBER (#99) field from the INSTITUTION (#4) file."
^XMB(3.9,145833,2,2497,0)="""RTN"",""SDESUTIL"",195,0)"
^XMB(3.9,145833,2,2498,0)=" N DIVISION,INSTIEN,STATIONNUMBER"
^XMB(3.9,145833,2,2499,0)="""RTN"",""SDESUTIL"",196,0)"
^XMB(3.9,145833,2,2500,0)=" I $G(CLINICIEN)="""" D  Q STATIONNUMBER"
^XMB(3.9,145833,2,2501,0)="""RTN"",""SDESUTIL"",197,0)"
^XMB(3.9,145833,2,2502,0)=" . S STATIONNUMBER=$$KSP^XUPARAM(""INST"")_"","""
^XMB(3.9,145833,2,2503,0)="""RTN"",""SDESUTIL"",198,0)"
^XMB(3.9,145833,2,2504,0)=" . S STATIONNUMBER=$$GET1^DIQ(4,STATIONNUMBER,99)"
^XMB(3.9,145833,2,2505,0)="""RTN"",""SDESUTIL"",199,0)"
^XMB(3.9,145833,2,2506,0)=" I +$G(CLINICIEN) D  Q STATIONNUMBER"
^XMB(3.9,145833,2,2507,0)="""RTN"",""SDESUTIL"",200,0)"
^XMB(3.9,145833,2,2508,0)=" . S DIVISION=$$GET1^DIQ(44,CLINICIEN,3.5,""I"")"
^XMB(3.9,145833,2,2509,0)="""RTN"",""SDESUTIL"",201,0)"
^XMB(3.9,145833,2,2510,0)=" . S INSTIEN=$$GET1^DIQ(40.8,DIVISION,.07,""I"")"
^XMB(3.9,145833,2,2511,0)="""RTN"",""SDESUTIL"",202,0)"
^XMB(3.9,145833,2,2512,0)=" . S STATIONNUMBER=$$GET1^DIQ(4,INSTIEN,99,""I"")"
^XMB(3.9,145833,2,2513,0)="""RTN"",""SDESUTIL"",203,0)"
^XMB(3.9,145833,2,2514,0)=" Q"
^XMB(3.9,145833,2,2515,0)="""RTN"",""SDESUTIL"",204,0)"
^XMB(3.9,145833,2,2516,0)=" ;"
^XMB(3.9,145833,2,2517,0)="""RTN"",""SDESUTIL"",205,0)"
^XMB(3.9,145833,2,2518,0)="VALIDATEAMIS(AMIS,RESTYP) ;"
^XMB(3.9,145833,2,2519,0)="""RTN"",""SDESUTIL"",206,0)"
^XMB(3.9,145833,2,2520,0)=" ; Input:"
^XMB(3.9,145833,2,2521,0)="""RTN"",""SDESUTIL"",207,0)"
^XMB(3.9,145833,2,2522,0)=" ;  AMIS: The AMIS Stop Code to validate"
^XMB(3.9,145833,2,2523,0)="""RTN"",""SDESUTIL"",208,0)"
^XMB(3.9,145833,2,2524,0)=" ;  RESTYP: P:Primary, C:Credit"
^XMB(3.9,145833,2,2525,0)="""RTN"",""SDESUTIL"",209,0)"
^XMB(3.9,145833,2,2526,0)=" ; Output:"
^XMB(3.9,145833,2,2527,0)="""RTN"",""SDESUTIL"",210,0)"
^XMB(3.9,145833,2,2528,0)=" ;  0 = AMIS Stop Code is Valid"
^XMB(3.9,145833,2,2529,0)="""RTN"",""SDESUTIL"",211,0)"
^XMB(3.9,145833,2,2530,0)=" ;  # = Error number to log"
^XMB(3.9,145833,2,2531,0)="""RTN"",""SDESUTIL"",212,0)"
^XMB(3.9,145833,2,2532,0)=" S AMIS=$G(AMIS),RESTYP=$G(RESTYP)"
