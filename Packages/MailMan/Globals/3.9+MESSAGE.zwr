^XMB(3.9,145836,2,277,0)="""RTN"",""GMTSPST1"",17,0)"
^XMB(3.9,145836,2,278,0)="TOOL1 ;ENTRY POINT FOR HEALTH SUMMARY"
^XMB(3.9,145836,2,279,0)="""RTN"",""GMTSPST1"",18,0)"
^XMB(3.9,145836,2,280,0)=" N ALPHA,DRUGNM,EXPDAYS,IND1,LIST,ORDER,PSNUM,RPC,RPCT,RPCNODE,SAVE,SAVERD"
^XMB(3.9,145836,2,281,0)="""RTN"",""GMTSPST1"",19,0)"
^XMB(3.9,145836,2,282,0)=" D ADD^GMTSPSTR(""GMTSPST1"")"
^XMB(3.9,145836,2,283,0)="""RTN"",""GMTSPST1"",20,0)"
^XMB(3.9,145836,2,284,0)=" S IND1=7,EXPDAYS=90"
^XMB(3.9,145836,2,285,0)="""RTN"",""GMTSPST1"",21,0)"
^XMB(3.9,145836,2,286,0)=" D COVER^ORWPS(.RPC,DFN)"
^XMB(3.9,145836,2,287,0)="""RTN"",""GMTSPST1"",22,0)"
^XMB(3.9,145836,2,288,0)=" S RPCT=0 F  S RPCT=$O(RPC(RPCT)) Q:'+RPCT  D"
^XMB(3.9,145836,2,289,0)="""RTN"",""GMTSPST1"",23,0)"
^XMB(3.9,145836,2,290,0)=" . S RPCNODE=RPC(RPCT)"
^XMB(3.9,145836,2,291,0)="""RTN"",""GMTSPST1"",24,0)"
^XMB(3.9,145836,2,292,0)=" . S PSNUM=$P(RPCNODE,U)"
^XMB(3.9,145836,2,293,0)="""RTN"",""GMTSPST1"",25,0)"
^XMB(3.9,145836,2,294,0)=" . S DRUGNM=$$UP^XLFSTR($P(RPCNODE,U,2))"
^XMB(3.9,145836,2,295,0)="""RTN"",""GMTSPST1"",26,0)"
^XMB(3.9,145836,2,296,0)=" . S ORDER=+$P(RPCNODE,U,3)"
^XMB(3.9,145836,2,297,0)="""RTN"",""GMTSPST1"",27,0)"
^XMB(3.9,145836,2,298,0)=" . Q:DRUGNM']""""!(ORDER=0)!(PSNUM']"""")"
^XMB(3.9,145836,2,299,0)="""RTN"",""GMTSPST1"",28,0)"
^XMB(3.9,145836,2,300,0)=" . S SAVERD=9999999-$$LRD(+$G(^OR(100,ORDER,4)))"
^XMB(3.9,145836,2,301,0)="""RTN"",""GMTSPST1"",29,0)"
^XMB(3.9,145836,2,302,0)=" . S SAVE(DRUGNM,SAVERD,ORDER,PSNUM)="""""
^XMB(3.9,145836,2,303,0)="""RTN"",""GMTSPST1"",30,0)"
^XMB(3.9,145836,2,304,0)=" . Q:(""ACTIVE^ACTIVE/SUSP^ACTIVE/PARKED^HOLD^PENDING^ON CALL""'[$P(RPCNODE,U,4))&($P(PSNUM,"";"")[""N"")"
^XMB(3.9,145836,2,305,0)="""RTN"",""GMTSPST1"",31,0)"
^XMB(3.9,145836,2,306,0)=" . S ALPHA(1,DRUGNM,ORDER,PSNUM)=$P(RPCNODE,U,4)"
^XMB(3.9,145836,2,307,0)="""RTN"",""GMTSPST1"",32,0)"
^XMB(3.9,145836,2,308,0)=" D ADDREM"
^XMB(3.9,145836,2,309,0)="""RTN"",""GMTSPST1"",33,0)"
^XMB(3.9,145836,2,310,0)=" D HEADER"
^XMB(3.9,145836,2,311,0)="""RTN"",""GMTSPST1"",34,0)"
^XMB(3.9,145836,2,312,0)=" S LIST=1 D OUTPUT"
^XMB(3.9,145836,2,313,0)="""RTN"",""GMTSPST1"",35,0)"
^XMB(3.9,145836,2,314,0)=" D CKP Q:$D(GMTSQIT)  W !"
^XMB(3.9,145836,2,315,0)="""RTN"",""GMTSPST1"",36,0)"
^XMB(3.9,145836,2,316,0)=" D CKP Q:$D(GMTSQIT)  W !,$$REPEAT^XLFSTR(""-"",IOM-8)"
^XMB(3.9,145836,2,317,0)="""RTN"",""GMTSPST1"",37,0)"
^XMB(3.9,145836,2,318,0)=" D CKP Q:$D(GMTSQIT)  W !,$$CJ^XLFSTR(""SUPPLIES"",IOM-8)"
^XMB(3.9,145836,2,319,0)="""RTN"",""GMTSPST1"",38,0)"
^XMB(3.9,145836,2,320,0)=" D CKP Q:$D(GMTSQIT)  W !,$$REPEAT^XLFSTR(""-"",IOM-8)"
^XMB(3.9,145836,2,321,0)="""RTN"",""GMTSPST1"",39,0)"
