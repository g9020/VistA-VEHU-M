^XMB(3.9,144654,2,581,0)="""RTN"",""PSOHLDS2"",171,0)"
^XMB(3.9,144654,2,582,0)=" Q"
^XMB(3.9,144654,2,583,0)="""RTN"",""PSOHLDS2"",172,0)"
^XMB(3.9,144654,2,584,0)="NTE5(PSI) ;Drug Interactions"
