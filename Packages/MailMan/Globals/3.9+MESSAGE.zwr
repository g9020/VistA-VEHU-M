^XMB(3.9,145834,2,5266,0)="SERVICE4(CONSULTSERVICES,GETQRSCP,LIST,PICK) ; build list of selected services, by ien"
^XMB(3.9,145834,2,5267,0)="""RTN"",""MAGDSTA8"",307,0)"
^XMB(3.9,145834,2,5268,0)=" N I,IEN,MAGIEN0,N,PROCEDURE,QRPROVIDER,SERVICE,SVCNAME"
^XMB(3.9,145834,2,5269,0)="""RTN"",""MAGDSTA8"",308,0)"
^XMB(3.9,145834,2,5270,0)=" S N=$O(LIST(""""),-1)"
^XMB(3.9,145834,2,5271,0)="""RTN"",""MAGDSTA8"",309,0)"
^XMB(3.9,145834,2,5272,0)=" F I=1:1:N I $G(PICK(I)) D"
^XMB(3.9,145834,2,5273,0)="""RTN"",""MAGDSTA8"",310,0)"
^XMB(3.9,145834,2,5274,0)=" . S SVCNAME=$P(LIST(I),""^"",1),SERVICE=$P(LIST(I),""^"",2)"
^XMB(3.9,145834,2,5275,0)="""RTN"",""MAGDSTA8"",311,0)"
^XMB(3.9,145834,2,5276,0)=" . S CONSULTSERVICES(SERVICE)=SVCNAME"
^XMB(3.9,145834,2,5277,0)="""RTN"",""MAGDSTA8"",312,0)"
^XMB(3.9,145834,2,5278,0)=" . I GETQRSCP=""NO"" Q  ; ignore Q/R Provider "
^XMB(3.9,145834,2,5279,0)="""RTN"",""MAGDSTA8"",313,0)"
^XMB(3.9,145834,2,5280,0)=" . ; check each service for QUERY/RETRIEVE PROVIDER value"
^XMB(3.9,145834,2,5281,0)="""RTN"",""MAGDSTA8"",314,0)"
^XMB(3.9,145834,2,5282,0)=" . S IEN="""" F  S IEN=$O(^MAG(2006.5831,""B"",SERVICE,IEN)) Q:'IEN  D"
^XMB(3.9,145834,2,5283,0)="""RTN"",""MAGDSTA8"",315,0)"
^XMB(3.9,145834,2,5284,0)=" . . S MAGIEN0=$G(^MAG(2006.5831,IEN,0))"
^XMB(3.9,145834,2,5285,0)="""RTN"",""MAGDSTA8"",316,0)"
^XMB(3.9,145834,2,5286,0)=" . . S PROCEDURE=+$P(MAGIEN0,""^"",2) ; null becomes 0"
^XMB(3.9,145834,2,5287,0)="""RTN"",""MAGDSTA8"",317,0)"
^XMB(3.9,145834,2,5288,0)=" . . ; check for a special Q/R provider"
^XMB(3.9,145834,2,5289,0)="""RTN"",""MAGDSTA8"",318,0)"
^XMB(3.9,145834,2,5290,0)=" . . S QRPROVIDER=$P(MAGIEN0,""^"",8)"
^XMB(3.9,145834,2,5291,0)="""RTN"",""MAGDSTA8"",319,0)"
^XMB(3.9,145834,2,5292,0)=" . . I QRPROVIDER'="""" D"
^XMB(3.9,145834,2,5293,0)="""RTN"",""MAGDSTA8"",320,0)"
^XMB(3.9,145834,2,5294,0)=" . . . S PROCNAME=$S(PROCEDURE:$$GET1^DIQ(123.3,PROCEDURE,.01,""E""),1:""CONSULT"")"
^XMB(3.9,145834,2,5295,0)="""RTN"",""MAGDSTA8"",321,0)"
^XMB(3.9,145834,2,5296,0)=" . . . S CONSULTSERVICES(SERVICE,PROCEDURE)=PROCNAME_""^""_QRPROVIDER"
^XMB(3.9,145834,2,5297,0)="""RTN"",""MAGDSTA8"",322,0)"
^XMB(3.9,145834,2,5298,0)=" . . . Q"
^XMB(3.9,145834,2,5299,0)="""RTN"",""MAGDSTA8"",323,0)"
^XMB(3.9,145834,2,5300,0)=" . . Q"
^XMB(3.9,145834,2,5301,0)="""RTN"",""MAGDSTA8"",324,0)"
^XMB(3.9,145834,2,5302,0)=" . Q"
^XMB(3.9,145834,2,5303,0)="""RTN"",""MAGDSTA8"",325,0)"
^XMB(3.9,145834,2,5304,0)=" Q"
^XMB(3.9,145834,2,5305,0)="""RTN"",""MAGDSTA8"",326,0)"
^XMB(3.9,145834,2,5306,0)=" ;"
^XMB(3.9,145834,2,5307,0)="""RTN"",""MAGDSTA8"",327,0)"
^XMB(3.9,145834,2,5308,0)="QRSCP() ; get the q/r scp for the consult"
^XMB(3.9,145834,2,5309,0)="""RTN"",""MAGDSTA8"",328,0)"
^XMB(3.9,145834,2,5310,0)=" N MAG5831,QRSCP,TOSERVICE,X"
^XMB(3.9,145834,2,5311,0)="""RTN"",""MAGDSTA8"",329,0)"
^XMB(3.9,145834,2,5312,0)=" ;"
^XMB(3.9,145834,2,5313,0)="""RTN"",""MAGDSTA8"",330,0)"
^XMB(3.9,145834,2,5314,0)=" S QRSCP=^TMP(""MAG"",$J,""BATCH Q/R"",""PACS Q/R RETRIEVE SCP"")"
^XMB(3.9,145834,2,5315,0)="""RTN"",""MAGDSTA8"",331,0)"
^XMB(3.9,145834,2,5316,0)=" ;"
^XMB(3.9,145834,2,5317,0)="""RTN"",""MAGDSTA8"",332,0)"
^XMB(3.9,145834,2,5318,0)=" ; does the consult modality worklist have a designated q/r scp?"
^XMB(3.9,145834,2,5319,0)="""RTN"",""MAGDSTA8"",333,0)"
^XMB(3.9,145834,2,5320,0)=" I IMAGINGSERVICE=""CONSULTS"" D"
^XMB(3.9,145834,2,5321,0)="""RTN"",""MAGDSTA8"",334,0)"
^XMB(3.9,145834,2,5322,0)=" . S TOSERVICE=$$GET1^DIQ(123,GMRCIEN,1,""I"")"
^XMB(3.9,145834,2,5323,0)="""RTN"",""MAGDSTA8"",335,0)"
^XMB(3.9,145834,2,5324,0)=" . S MAG5831=$$MWLFIND^MAGDHOW1(TOSERVICE,GMRCIEN)"
^XMB(3.9,145834,2,5325,0)="""RTN"",""MAGDSTA8"",336,0)"
^XMB(3.9,145834,2,5326,0)=" . I MAG5831 D  ; get designated q/r scp for the worklist"
^XMB(3.9,145834,2,5327,0)="""RTN"",""MAGDSTA8"",337,0)"
^XMB(3.9,145834,2,5328,0)=" . . S X=$$GET1^DIQ(2006.5831,MAG5831,8,""E"")"
^XMB(3.9,145834,2,5329,0)="""RTN"",""MAGDSTA8"",338,0)"
^XMB(3.9,145834,2,5330,0)=" . . I X'="""" S QRSCP=X W !?20,""<<< Q/R SCP: "",QRSCP,"" >>>"""
^XMB(3.9,145834,2,5331,0)="""RTN"",""MAGDSTA8"",339,0)"
^XMB(3.9,145834,2,5332,0)=" . . Q"
^XMB(3.9,145834,2,5333,0)="""RTN"",""MAGDSTA8"",340,0)"
^XMB(3.9,145834,2,5334,0)=" . Q"
^XMB(3.9,145834,2,5335,0)="""RTN"",""MAGDSTA8"",341,0)"
^XMB(3.9,145834,2,5336,0)=" ;"
^XMB(3.9,145834,2,5337,0)="""RTN"",""MAGDSTA8"",342,0)"
^XMB(3.9,145834,2,5338,0)=" Q QRSCP"
^XMB(3.9,145834,2,5339,0)="""RTN"",""MAGDSTA9"")"
^XMB(3.9,145834,2,5340,0)="0^18^B26490456"
^XMB(3.9,145834,2,5341,0)="""RTN"",""MAGDSTA9"",1,0)"
^XMB(3.9,145834,2,5342,0)="MAGDSTA9 ;WOIFO/PMK - Q/R Retrieve of DICOM images from PACS to VistA ; Jul 06, 2021@08:12:09"
^XMB(3.9,145834,2,5343,0)="""RTN"",""MAGDSTA9"",2,0)"
^XMB(3.9,145834,2,5344,0)=" ;;3.0;IMAGING;**231,306**;MAR 19, 2002;Build 0"
^XMB(3.9,145834,2,5345,0)="""RTN"",""MAGDSTA9"",3,0)"
^XMB(3.9,145834,2,5346,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,5347,0)="""RTN"",""MAGDSTA9"",4,0)"
