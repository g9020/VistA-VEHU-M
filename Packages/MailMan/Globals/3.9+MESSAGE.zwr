^XMB(3.9,145834,2,7484,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,7485,0)="""RTN"",""MAGDSTV1"",9,0)"
^XMB(3.9,145834,2,7486,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,7487,0)="""RTN"",""MAGDSTV1"",10,0)"
