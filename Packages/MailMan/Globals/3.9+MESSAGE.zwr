^XMB(3.9,145838,2,402,0)="0^15"
^XMB(3.9,145838,2,403,0)="""KRN"",19,7828,0)"
^XMB(3.9,145838,2,404,0)="FBUC ALL CLAIMS OUTPUT^All Claims by Vendor/Veteran/Other^^R^^^^^^^^"
^XMB(3.9,145838,2,405,0)="""KRN"",19,7828,1,0)"
^XMB(3.9,145838,2,406,0)="^^15^15^2930608^^^"
^XMB(3.9,145838,2,407,0)="""KRN"",19,7828,1,1,0)"
^XMB(3.9,145838,2,408,0)="This option allows the user to display/print all unauthorized claims for"
^XMB(3.9,145838,2,409,0)="""KRN"",19,7828,1,2,0)"
^XMB(3.9,145838,2,410,0)="a single vendor or veteran or other party."
^XMB(3.9,145838,2,411,0)="""KRN"",19,7828,1,3,0)"
^XMB(3.9,145838,2,412,0)="The output is sorted by episode of care, grouping claims which are associated"
^XMB(3.9,145838,2,413,0)="""KRN"",19,7828,1,4,0)"
^XMB(3.9,145838,2,414,0)="with one another.  Since the primary may not be the first to display, the"
^XMB(3.9,145838,2,415,0)="""KRN"",19,7828,1,5,0)"
^XMB(3.9,145838,2,416,0)="secondaries are flagged with an asterisk ('*'), which preceeds the name."
^XMB(3.9,145838,2,417,0)="""KRN"",19,7828,1,6,0)"
^XMB(3.9,145838,2,418,0)="If you select a vendor, the output will display veteran, otherwise it"
^XMB(3.9,145838,2,419,0)="""KRN"",19,7828,1,7,0)"
^XMB(3.9,145838,2,420,0)="will display vendor.  The Fee program, status and disposition codes are"
^XMB(3.9,145838,2,421,0)="""KRN"",19,7828,1,8,0)"
^XMB(3.9,145838,2,422,0)="also displayed."
^XMB(3.9,145838,2,423,0)="""KRN"",19,7828,1,9,0)"
^XMB(3.9,145838,2,424,0)="  "
^XMB(3.9,145838,2,425,0)="""KRN"",19,7828,1,10,0)"
^XMB(3.9,145838,2,426,0)="  (Note:  The disposition code will only display if the unauthorized claim"
^XMB(3.9,145838,2,427,0)="""KRN"",19,7828,1,11,0)"
^XMB(3.9,145838,2,428,0)="has a status of either DISPOSITIONED, APPEAL DISPOSITIONED or"
^XMB(3.9,145838,2,429,0)="""KRN"",19,7828,1,12,0)"
^XMB(3.9,145838,2,430,0)="BVA DISPOSITION.)"
^XMB(3.9,145838,2,431,0)="""KRN"",19,7828,1,13,0)"
^XMB(3.9,145838,2,432,0)="  The codes are:"
