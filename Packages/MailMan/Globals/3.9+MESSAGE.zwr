^XMB(3.9,145833,2,782,0)=" Q"
^XMB(3.9,145833,2,783,0)="""RTN"",""SDES2UTDT"",36,0)"
^XMB(3.9,145833,2,784,0)=" ;"
^XMB(3.9,145833,2,785,0)="""RTN"",""SDES2UTDT"",37,0)"
