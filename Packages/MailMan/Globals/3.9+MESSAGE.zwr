^XMB(3.9,144657,2,940,0)=" S DIR(""?"",5)=IBDESC_"" data does not match any existing ""_IBDESC_""."",DIR(""?"",6)="""""
^XMB(3.9,144657,2,941,0)="""RTN"",""IBCNBAA"",174,0)"
