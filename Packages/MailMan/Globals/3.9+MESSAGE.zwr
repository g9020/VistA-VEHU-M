^XMB(3.9,144657,2,3344,0)="EN ; - main entry point for screen"
^XMB(3.9,144657,2,3345,0)="""RTN"",""IBCNBLL"",9,0)"
^XMB(3.9,144657,2,3346,0)=" N VIEW,AVIEW,DFLG,IBKEYS"
