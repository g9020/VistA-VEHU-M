^XMB(3.9,145834,2,683,0)="""RTN"",""MAGBRTE4"",16,0)"
^XMB(3.9,145834,2,684,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,685,0)="""RTN"",""MAGBRTE4"",17,0)"
^XMB(3.9,145834,2,686,0)=" ;;"
^XMB(3.9,145834,2,687,0)="""RTN"",""MAGBRTE4"",18,0)"
^XMB(3.9,145834,2,688,0)=" Q"
^XMB(3.9,145834,2,689,0)="""RTN"",""MAGBRTE4"",19,0)"
^XMB(3.9,145834,2,690,0)=" ;"
^XMB(3.9,145834,2,691,0)="""RTN"",""MAGBRTE4"",20,0)"
^XMB(3.9,145834,2,692,0)="EVAL ;"
^XMB(3.9,145834,2,693,0)="""RTN"",""MAGBRTE4"",21,0)"
^XMB(3.9,145834,2,694,0)=" N ACTIVE ;--- Switch that controls start/stop queue processor"
^XMB(3.9,145834,2,695,0)="""RTN"",""MAGBRTE4"",22,0)"
^XMB(3.9,145834,2,696,0)=" N ANY ;------ Flag: processed any rule"
^XMB(3.9,145834,2,697,0)="""RTN"",""MAGBRTE4"",23,0)"
^XMB(3.9,145834,2,698,0)=" N CONS ;----- Switch that indicates whether or not site has ""consolidated"" code"
^XMB(3.9,145834,2,699,0)="""RTN"",""MAGBRTE4"",24,0)"
^XMB(3.9,145834,2,700,0)=" N KEYWORD ;-- Array with all keywords"
^XMB(3.9,145834,2,701,0)="""RTN"",""MAGBRTE4"",25,0)"
^XMB(3.9,145834,2,702,0)=" N MAGFILE1 ;- Name of file"
^XMB(3.9,145834,2,703,0)="""RTN"",""MAGBRTE4"",26,0)"
^XMB(3.9,145834,2,704,0)=" N XMSG ;----- Message counter"
^XMB(3.9,145834,2,705,0)="""RTN"",""MAGBRTE4"",27,0)"
^XMB(3.9,145834,2,706,0)=" ;"
^XMB(3.9,145834,2,707,0)="""RTN"",""MAGBRTE4"",28,0)"
^XMB(3.9,145834,2,708,0)=" F I=""MAGEVAL"",""MAGEVALSTUDY"" K ^XTMP(I,ZTSK)"
^XMB(3.9,145834,2,709,0)="""RTN"",""MAGBRTE4"",29,0)"
^XMB(3.9,145834,2,710,0)=" D LOG^MAGBRTE5(""Started at ""_$H)"
^XMB(3.9,145834,2,711,0)="""RTN"",""MAGBRTE4"",30,0)"
^XMB(3.9,145834,2,712,0)=" S XMSG=1,CONS=$$CONSOLID^MAGBAPI()"
^XMB(3.9,145834,2,713,0)="""RTN"",""MAGBRTE4"",31,0)"
^XMB(3.9,145834,2,714,0)=" S PLACE=$S(CONS:$O(^MAG(2006.1,""B"",LOCATION,"""")),1:1)"
^XMB(3.9,145834,2,715,0)="""RTN"",""MAGBRTE4"",32,0)"
^XMB(3.9,145834,2,716,0)=" L +^MAGDICOM(2006.563,1,""EVAL"",LOCATION):0 E  D  Q"
^XMB(3.9,145834,2,717,0)="""RTN"",""MAGBRTE4"",33,0)"
^XMB(3.9,145834,2,718,0)=" . D LOG^MAGBRTE5(""A rule evaluator is already running for ""_$$GET1^DIQ(4,LOCATION,.01))"
^XMB(3.9,145834,2,719,0)="""RTN"",""MAGBRTE4"",34,0)"
^XMB(3.9,145834,2,720,0)=" . Q"
^XMB(3.9,145834,2,721,0)="""RTN"",""MAGBRTE4"",35,0)"
^XMB(3.9,145834,2,722,0)=" S ^MAGDICOM(2006.563,1,""EVAL"")=1"
^XMB(3.9,145834,2,723,0)="""RTN"",""MAGBRTE4"",36,0)"
^XMB(3.9,145834,2,724,0)=" ;"
^XMB(3.9,145834,2,725,0)="""RTN"",""MAGBRTE4"",37,0)"
^XMB(3.9,145834,2,726,0)=" S I="""" F  S I=$O(RULES(I)) Q:I=""""  D"
^XMB(3.9,145834,2,727,0)="""RTN"",""MAGBRTE4"",38,0)"
^XMB(3.9,145834,2,728,0)=" . N D0,D1,D2,L,Q1"
^XMB(3.9,145834,2,729,0)="""RTN"",""MAGBRTE4"",39,0)"
^XMB(3.9,145834,2,730,0)=" . S X=RULES(I),D0=$P(X,""^"",1),Q1=$P(X,""^"",2),L=$L(X,""^"")"
^XMB(3.9,145834,2,731,0)="""RTN"",""MAGBRTE4"",40,0)"
^XMB(3.9,145834,2,732,0)=" . I L=3 S RULE(D0,Q1)=$P(X,""^"",3) Q"
^XMB(3.9,145834,2,733,0)="""RTN"",""MAGBRTE4"",41,0)"
^XMB(3.9,145834,2,734,0)=" . I Q1=""ACTION"" S RULE(D0,Q1,$P(X,""^"",3))=$P(X,""^"",4,L) Q"
^XMB(3.9,145834,2,735,0)="""RTN"",""MAGBRTE4"",42,0)"
^XMB(3.9,145834,2,736,0)=" . I Q1'=""CONDITION"" D LOG^MAGBRTE5(""Rule ""_D0_"" has a qualifier """"""_Q1_""""""."") Q"
^XMB(3.9,145834,2,737,0)="""RTN"",""MAGBRTE4"",43,0)"
^XMB(3.9,145834,2,738,0)=" . I L=5 S RULE(D0,Q1,$P(X,""^"",3),$P(X,""^"",4))=$P(X,""^"",5) Q"
^XMB(3.9,145834,2,739,0)="""RTN"",""MAGBRTE4"",44,0)"
^XMB(3.9,145834,2,740,0)=" . S RULE(D0,Q1,$P(X,""^"",3),$P(X,""^"",4),$P(X,""^"",6),$P(X,""^"",5))=$P(X,""^"",7)"
^XMB(3.9,145834,2,741,0)="""RTN"",""MAGBRTE4"",45,0)"
^XMB(3.9,145834,2,742,0)=" . Q"
^XMB(3.9,145834,2,743,0)="""RTN"",""MAGBRTE4"",46,0)"
^XMB(3.9,145834,2,744,0)=" K RULES"
^XMB(3.9,145834,2,745,0)="""RTN"",""MAGBRTE4"",47,0)"
^XMB(3.9,145834,2,746,0)=" ;"
^XMB(3.9,145834,2,747,0)="""RTN"",""MAGBRTE4"",48,0)"
^XMB(3.9,145834,2,748,0)=" S ACTIVE=1 F  D  Q:'ACTIVE"
^XMB(3.9,145834,2,749,0)="""RTN"",""MAGBRTE4"",49,0)"
^XMB(3.9,145834,2,750,0)=" . S ANY=0"
^XMB(3.9,145834,2,751,0)="""RTN"",""MAGBRTE4"",50,0)"
^XMB(3.9,145834,2,752,0)=" . S ACTIVE=+$G(^MAGDICOM(2006.563,1,""EVAL"")) I 'ACTIVE D  Q"
^XMB(3.9,145834,2,753,0)="""RTN"",""MAGBRTE4"",51,0)"
^XMB(3.9,145834,2,754,0)=" . . D LOG^MAGBRTE5(""Stopped at ""_$H)"
^XMB(3.9,145834,2,755,0)="""RTN"",""MAGBRTE4"",52,0)"
^XMB(3.9,145834,2,756,0)=" . . Q"
^XMB(3.9,145834,2,757,0)="""RTN"",""MAGBRTE4"",53,0)"
^XMB(3.9,145834,2,758,0)=" . D"
^XMB(3.9,145834,2,759,0)="""RTN"",""MAGBRTE4"",54,0)"
^XMB(3.9,145834,2,760,0)=" . . N IMAGE,QPTR,QPTR2,STATUS,X"
^XMB(3.9,145834,2,761,0)="""RTN"",""MAGBRTE4"",55,0)"
^XMB(3.9,145834,2,762,0)=" . . D:'CONS ADD^MAGBAPI(0,""EVAL"")"
^XMB(3.9,145834,2,763,0)="""RTN"",""MAGBRTE4"",56,0)"
^XMB(3.9,145834,2,764,0)=" . . D:CONS ADD^MAGBAPI(0,""EVAL"",PLACE)"
^XMB(3.9,145834,2,765,0)="""RTN"",""MAGBRTE4"",57,0)"
^XMB(3.9,145834,2,766,0)=" . . ;S QPTR2=$O(^MAGQUEUE(2006.031,""B"",""EVAL"",""""))"
^XMB(3.9,145834,2,767,0)="""RTN"",""MAGBRTE4"",58,0)"
^XMB(3.9,145834,2,768,0)=" . . S QPTR2=$O(^MAGQUEUE(2006.031,""C"",PLACE,""EVAL"","""")) ; ""C"",PLACE    was  ""B"" ;p196"
^XMB(3.9,145834,2,769,0)="""RTN"",""MAGBRTE4"",59,0)"
^XMB(3.9,145834,2,770,0)=" . . S QPTR=$S(QPTR2:$P(^MAGQUEUE(2006.031,QPTR2,0),""^"",2),1:"""")"
^XMB(3.9,145834,2,771,0)="""RTN"",""MAGBRTE4"",60,0)"
^XMB(3.9,145834,2,772,0)=" . . ; Get next queue pointer value"
^XMB(3.9,145834,2,773,0)="""RTN"",""MAGBRTE4"",61,0)"
^XMB(3.9,145834,2,774,0)=" . . S:'CONS QPTR=$O(^MAGQUEUE(2006.03,""C"",""EVAL"",QPTR)) ;    ""C""  WAS ""B""  ;p196"
^XMB(3.9,145834,2,775,0)="""RTN"",""MAGBRTE4"",62,0)"
^XMB(3.9,145834,2,776,0)=" . . S:CONS QPTR=$O(^MAGQUEUE(2006.03,""C"",PLACE,""EVAL"",QPTR))"
^XMB(3.9,145834,2,777,0)="""RTN"",""MAGBRTE4"",63,0)"
^XMB(3.9,145834,2,778,0)=" . . I QPTR="""" Q  ; Nothing to do"
^XMB(3.9,145834,2,779,0)="""RTN"",""MAGBRTE4"",64,0)"
^XMB(3.9,145834,2,780,0)=" . . ;"
^XMB(3.9,145834,2,781,0)="""RTN"",""MAGBRTE4"",65,0)"
^XMB(3.9,145834,2,782,0)=" . . S X=$G(^MAGQUEUE(2006.03,QPTR,0))"
^XMB(3.9,145834,2,783,0)="""RTN"",""MAGBRTE4"",66,0)"
^XMB(3.9,145834,2,784,0)=" . . ; After an error, sometimes the entry is purged,"
^XMB(3.9,145834,2,785,0)="""RTN"",""MAGBRTE4"",67,0)"
^XMB(3.9,145834,2,786,0)=" . . ; but the cross reference is still present."
^XMB(3.9,145834,2,787,0)="""RTN"",""MAGBRTE4"",68,0)"
^XMB(3.9,145834,2,788,0)=" . . ; In such a case, remove the cross reference."
^XMB(3.9,145834,2,789,0)="""RTN"",""MAGBRTE4"",69,0)"
^XMB(3.9,145834,2,790,0)=" . . I X="""" D  Q"
^XMB(3.9,145834,2,791,0)="""RTN"",""MAGBRTE4"",70,0)"
^XMB(3.9,145834,2,792,0)=" . . . K:'CONS ^MAGQUEUE(2006.03,""C"",""EVAL"",QPTR) ; ""C""   was   ""B""  ;p196"
^XMB(3.9,145834,2,793,0)="""RTN"",""MAGBRTE4"",71,0)"
^XMB(3.9,145834,2,794,0)=" . . . K:CONS ^MAGQUEUE(2006.03,""C"",PLACE,""EVAL"",QPTR)"
^XMB(3.9,145834,2,795,0)="""RTN"",""MAGBRTE4"",72,0)"
^XMB(3.9,145834,2,796,0)=" . . . Q"
^XMB(3.9,145834,2,797,0)="""RTN"",""MAGBRTE4"",73,0)"
^XMB(3.9,145834,2,798,0)=" . . ;"
^XMB(3.9,145834,2,799,0)="""RTN"",""MAGBRTE4"",74,0)"
^XMB(3.9,145834,2,800,0)=" . . S IMAGE=$P(X,""^"",7),ANY=1"
^XMB(3.9,145834,2,801,0)="""RTN"",""MAGBRTE4"",75,0)"
^XMB(3.9,145834,2,802,0)=" . . I IMAGE,$D(^MAG(2005,IMAGE,0)) D"
^XMB(3.9,145834,2,803,0)="""RTN"",""MAGBRTE4"",76,0)"
^XMB(3.9,145834,2,804,0)=" . . . S STATUS=$$RULES() Q:STATUS'<0"
^XMB(3.9,145834,2,805,0)="""RTN"",""MAGBRTE4"",77,0)"
^XMB(3.9,145834,2,806,0)=" . . . I STATUS[""NO NETWORK LOCATION"" D  Q"
^XMB(3.9,145834,2,807,0)="""RTN"",""MAGBRTE4"",78,0)"
^XMB(3.9,145834,2,808,0)=" . . . . D LOG^MAGBRTE5(""Image ""_IMAGE_"" has no files associated with it"")"
^XMB(3.9,145834,2,809,0)="""RTN"",""MAGBRTE4"",79,0)"
^XMB(3.9,145834,2,810,0)=" . . . . Q"
^XMB(3.9,145834,2,811,0)="""RTN"",""MAGBRTE4"",80,0)"
^XMB(3.9,145834,2,812,0)=" . . . D LOG^MAGBRTE5(""*** EVAL queue error: ""_STATUS_"" ***"")"
^XMB(3.9,145834,2,813,0)="""RTN"",""MAGBRTE4"",81,0)"
