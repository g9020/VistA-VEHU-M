^XMB(3.9,144657,2,1163,0)="""RTN"",""IBCNBAA"",285,0)"
^XMB(3.9,144657,2,1164,0)=" ;"
^XMB(3.9,144657,2,1165,0)="""RTN"",""IBCNBAA"",286,0)"
^XMB(3.9,144657,2,1166,0)=" S DIR(0)=IBRTYP"
^XMB(3.9,144657,2,1167,0)="""RTN"",""IBCNBAA"",287,0)"
^XMB(3.9,144657,2,1168,0)=" S:$G(IBPROM)]"""" DIR(""A"")=IBPROM"
^XMB(3.9,144657,2,1169,0)="""RTN"",""IBCNBAA"",288,0)"
^XMB(3.9,144657,2,1170,0)=" S:$G(IBDFLT)]"""" DIR(""B"")=IBDFLT"
^XMB(3.9,144657,2,1171,0)="""RTN"",""IBCNBAA"",289,0)"
^XMB(3.9,144657,2,1172,0)=" S:$G(IBHELP)]"""" DIR(""?"")=IBHELP"
^XMB(3.9,144657,2,1173,0)="""RTN"",""IBCNBAA"",290,0)"
^XMB(3.9,144657,2,1174,0)=" S:$G(IBSCRN)]"""" DIR(""S"")=IBSCRN"
^XMB(3.9,144657,2,1175,0)="""RTN"",""IBCNBAA"",291,0)"
^XMB(3.9,144657,2,1176,0)=" D ^DIR"
^XMB(3.9,144657,2,1177,0)="""RTN"",""IBCNBAA"",292,0)"
