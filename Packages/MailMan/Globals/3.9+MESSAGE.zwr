^XMB(3.9,145831,2,1031,0)="""RTN"",""EDPVIT"",83,0)"
^XMB(3.9,145831,2,1032,0)=" . S TYPE="""" F  S TYPE=$O(^UTILITY($J,""GMRVD"",IDT,TYPE)) Q:TYPE=""""  D"
