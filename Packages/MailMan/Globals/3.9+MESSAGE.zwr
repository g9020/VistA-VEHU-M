^XMB(3.9,145833,2,2842,0)="EN(MSG) ; -- main entry point for OR RECEIVE where MSG contains HL7 msg"
^XMB(3.9,145833,2,2843,0)="""RTN"",""SDHL7"",30,0)"
^XMB(3.9,145833,2,2844,0)=" N ACTION,AIG,AIL,ARQ,DATE,ENTER,ERROR,FREQ,FAILMSA,HASMSA,INST,MSH,NODE,NUM,NXT,PAT,RESULT,SDMSG,X,PID,PV1,SEG,SIGN"
^XMB(3.9,145833,2,2845,0)="""RTN"",""SDHL7"",31,0)"
^XMB(3.9,145833,2,2846,0)=" S ERROR="""""
^XMB(3.9,145833,2,2847,0)="""RTN"",""SDHL7"",32,0)"
^XMB(3.9,145833,2,2848,0)=" S SDMSG=$S($L($G(MSG)):MSG,1:""MSG"") ; MSG=""NAME"" or MSG(#)=message"
^XMB(3.9,145833,2,2849,0)="""RTN"",""SDHL7"",33,0)"
^XMB(3.9,145833,2,2850,0)=" I '$O(@SDMSG@(0)) S ERROR=""Missing HL7 message"" Q"
