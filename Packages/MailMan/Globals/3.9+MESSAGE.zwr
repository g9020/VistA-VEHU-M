^XMB(3.9,144657,2,7792,0)=" S RESULT=""-1^INSURANCE BUFFER IEN required"" Q:'$G(IBBUFDA)"
^XMB(3.9,144657,2,7793,0)="""RTN"",""IBCNICB"",126,0)"
