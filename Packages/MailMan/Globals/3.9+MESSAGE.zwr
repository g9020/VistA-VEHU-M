^XMB(3.9,144657,2,4150,0)=" ; Only allowed to load Medicare (WNR) policies if the patient has no"
^XMB(3.9,144657,2,4151,0)="""RTN"",""IBCNEHL5A"",11,0)"
^XMB(3.9,144657,2,4152,0)=" ; history of any MEDICARE (WNR) on file in #2.312 and if the patient has"
^XMB(3.9,144657,2,4153,0)="""RTN"",""IBCNEHL5A"",12,0)"
^XMB(3.9,144657,2,4154,0)=" ; no other policies on file that meet a specific criteria and if the MEDICARE"
^XMB(3.9,144657,2,4155,0)="""RTN"",""IBCNEHL5A"",13,0)"
^XMB(3.9,144657,2,4156,0)=" ; policy is active according to the Medicare payer's 271 eIV response"
^XMB(3.9,144657,2,4157,0)="""RTN"",""IBCNEHL5A"",14,0)"
^XMB(3.9,144657,2,4158,0)=" ; "
^XMB(3.9,144657,2,4159,0)="""RTN"",""IBCNEHL5A"",15,0)"
^XMB(3.9,144657,2,4160,0)=" ; Returns 1 if at least 1 policy was loaded; otherwise, returns a zero"
^XMB(3.9,144657,2,4161,0)="""RTN"",""IBCNEHL5A"",16,0)"
^XMB(3.9,144657,2,4162,0)=" ;"
^XMB(3.9,144657,2,4163,0)="""RTN"",""IBCNEHL5A"",17,0)"
^XMB(3.9,144657,2,4164,0)=" ; ** DEVELOPER: This tag purposely locks the patient's insurance subfile as we don't want"
^XMB(3.9,144657,2,4165,0)="""RTN"",""IBCNEHL5A"",18,0)"
^XMB(3.9,144657,2,4166,0)=" ;               anything loading insurance to the patient's record while we are evaluating."
^XMB(3.9,144657,2,4167,0)="""RTN"",""IBCNEHL5A"",19,0)"
^XMB(3.9,144657,2,4168,0)=" ;               This checks if the patient's record meets the requirements to allow Medicare"
^XMB(3.9,144657,2,4169,0)="""RTN"",""IBCNEHL5A"",20,0)"
^XMB(3.9,144657,2,4170,0)=" ;               Part A and B to be loaded automatically to the patient's record."
^XMB(3.9,144657,2,4171,0)="""RTN"",""IBCNEHL5A"",21,0)"
^XMB(3.9,144657,2,4172,0)=" ;"
^XMB(3.9,144657,2,4173,0)="""RTN"",""IBCNEHL5A"",22,0)"
^XMB(3.9,144657,2,4174,0)=" N ACTIVE,CONTINUE,DFN,ELIG,GRPNUM,IBNEW,IENS,INSRIEN,MWNRIEN,MWNRTYP,MWNRA,MWNRB"
^XMB(3.9,144657,2,4175,0)="""RTN"",""IBCNEHL5A"",23,0)"
^XMB(3.9,144657,2,4176,0)=" N PIEN,POLCT,POLEFF,POLICY,POLTERM,RDATA0,SOI,TQN"
^XMB(3.9,144657,2,4177,0)="""RTN"",""IBCNEHL5A"",24,0)"
^XMB(3.9,144657,2,4178,0)=" ;"
^XMB(3.9,144657,2,4179,0)="""RTN"",""IBCNEHL5A"",25,0)"
^XMB(3.9,144657,2,4180,0)=" K ACTIVE,LOAD,POLICY"
^XMB(3.9,144657,2,4181,0)="""RTN"",""IBCNEHL5A"",26,0)"
^XMB(3.9,144657,2,4182,0)=" S (LOAD,MWNRTYP,POLCT)=0,(MWNRA,MWNRB)="""""
^XMB(3.9,144657,2,4183,0)="""RTN"",""IBCNEHL5A"",27,0)"
^XMB(3.9,144657,2,4184,0)=" S RDATA0=$G(^IBCN(365,RIEN,0))"
^XMB(3.9,144657,2,4185,0)="""RTN"",""IBCNEHL5A"",28,0)"
^XMB(3.9,144657,2,4186,0)=" S PIEN=$P(RDATA0,U,3)"
^XMB(3.9,144657,2,4187,0)="""RTN"",""IBCNEHL5A"",29,0)"
^XMB(3.9,144657,2,4188,0)=" S TQN=$P(RDATA0,U,5)"
^XMB(3.9,144657,2,4189,0)="""RTN"",""IBCNEHL5A"",30,0)"
^XMB(3.9,144657,2,4190,0)=" I TQN'="""" S SOI=$$GET1^DIQ(365.1,TQN_"","",3.02,""I"")"
^XMB(3.9,144657,2,4191,0)="""RTN"",""IBCNEHL5A"",31,0)"
^XMB(3.9,144657,2,4192,0)=" ; If SOI is null, hardcoded it to '5' for eIV - SOI should never be null, this is a safety valve "
^XMB(3.9,144657,2,4193,0)="""RTN"",""IBCNEHL5A"",32,0)"
^XMB(3.9,144657,2,4194,0)=" I SOI="""" S SOI=5"
^XMB(3.9,144657,2,4195,0)="""RTN"",""IBCNEHL5A"",33,0)"
^XMB(3.9,144657,2,4196,0)=" S MWNRIEN=$P($G(^IBE(350.9,1,51)),U,25)"
^XMB(3.9,144657,2,4197,0)="""RTN"",""IBCNEHL5A"",34,0)"
^XMB(3.9,144657,2,4198,0)=" I PIEN=MWNRIEN S MWNRTYP=$$ISMCR^IBCNEHLU(RIEN)"
^XMB(3.9,144657,2,4199,0)="""RTN"",""IBCNEHL5A"",35,0)"
^XMB(3.9,144657,2,4200,0)=" I 'MWNRTYP G XLOAD  ; Did not load policy as a new policy to patient record"
^XMB(3.9,144657,2,4201,0)="""RTN"",""IBCNEHL5A"",36,0)"
^XMB(3.9,144657,2,4202,0)=" ;"
^XMB(3.9,144657,2,4203,0)="""RTN"",""IBCNEHL5A"",37,0)"
^XMB(3.9,144657,2,4204,0)=" S DFN=$P(RDATA0,U,2),CONTINUE=1"
^XMB(3.9,144657,2,4205,0)="""RTN"",""IBCNEHL5A"",38,0)"
^XMB(3.9,144657,2,4206,0)=" L +^DPT(DFN,.312):90 I '$T S CONTINUE=0 G XLOAD  ;LOCK ins subfile"
^XMB(3.9,144657,2,4207,0)="""RTN"",""IBCNEHL5A"",39,0)"
^XMB(3.9,144657,2,4208,0)=" ;"
^XMB(3.9,144657,2,4209,0)="""RTN"",""IBCNEHL5A"",40,0)"
^XMB(3.9,144657,2,4210,0)=" S INSRIEN=0 F  S INSRIEN=$O(^DPT(DFN,.312,INSRIEN)) Q:'INSRIEN!('CONTINUE)  D"
^XMB(3.9,144657,2,4211,0)="""RTN"",""IBCNEHL5A"",41,0)"
^XMB(3.9,144657,2,4212,0)=" . S IENS=INSRIEN_"",""_DFN"
^XMB(3.9,144657,2,4213,0)="""RTN"",""IBCNEHL5A"",42,0)"
^XMB(3.9,144657,2,4214,0)=" . ; If external name of (#2.312,.01)=""MEDICARE (WNR)"" S CONTINUE=0 Q"
^XMB(3.9,144657,2,4215,0)="""RTN"",""IBCNEHL5A"",43,0)"
^XMB(3.9,144657,2,4216,0)=" . I $$GET1^DIQ(2.312,IENS,.01)=""MEDICARE (WNR)"" S CONTINUE=0 Q"
^XMB(3.9,144657,2,4217,0)="""RTN"",""IBCNEHL5A"",44,0)"
^XMB(3.9,144657,2,4218,0)=" . S POLEFF=$$GET1^DIQ(2.312,IENS,8,""I"")"
^XMB(3.9,144657,2,4219,0)="""RTN"",""IBCNEHL5A"",45,0)"
^XMB(3.9,144657,2,4220,0)=" . S POLTERM=$$GET1^DIQ(2.312,IENS,3,""I"")"
^XMB(3.9,144657,2,4221,0)="""RTN"",""IBCNEHL5A"",46,0)"
^XMB(3.9,144657,2,4222,0)=" . I POLEFF>DT S CONTINUE=0 Q"
^XMB(3.9,144657,2,4223,0)="""RTN"",""IBCNEHL5A"",47,0)"
^XMB(3.9,144657,2,4224,0)=" . I POLEFF="""",((POLTERM="""")!(POLTERM>DT)) S CONTINUE=0 Q"
^XMB(3.9,144657,2,4225,0)="""RTN"",""IBCNEHL5A"",48,0)"
^XMB(3.9,144657,2,4226,0)=" . ; Regardless if expiration is null, today, future or bad date"
^XMB(3.9,144657,2,4227,0)="""RTN"",""IBCNEHL5A"",49,0)"
^XMB(3.9,144657,2,4228,0)=" . I (POLTERM="""")!(POLTERM>(DT-1))!($$VALIDDT^IBCNINSU(POLTERM)=-1) S CONTINUE=0 Q"
^XMB(3.9,144657,2,4229,0)="""RTN"",""IBCNEHL5A"",50,0)"
^XMB(3.9,144657,2,4230,0)=" . ; Bad POLEFF and POLTERM is bad,null, today or future"
^XMB(3.9,144657,2,4231,0)="""RTN"",""IBCNEHL5A"",51,0)"
^XMB(3.9,144657,2,4232,0)=" . I ($$VALIDDT^IBCNINSU(POLEFF)=-1),(POLTERM'<DT) S CONTINUE=0 Q"
^XMB(3.9,144657,2,4233,0)="""RTN"",""IBCNEHL5A"",52,0)"
^XMB(3.9,144657,2,4234,0)=" ;"
^XMB(3.9,144657,2,4235,0)="""RTN"",""IBCNEHL5A"",53,0)"
^XMB(3.9,144657,2,4236,0)=" I 'CONTINUE G XLOAD  ; Existing policies on file doesn't allow us to add this policy to patient record"
^XMB(3.9,144657,2,4237,0)="""RTN"",""IBCNEHL5A"",54,0)"
^XMB(3.9,144657,2,4238,0)=" ;"
^XMB(3.9,144657,2,4239,0)="""RTN"",""IBCNEHL5A"",55,0)"
^XMB(3.9,144657,2,4240,0)=" ;Get list of insurance identified in the EB loops of the 271 payer response"
^XMB(3.9,144657,2,4241,0)="""RTN"",""IBCNEHL5A"",56,0)"
^XMB(3.9,144657,2,4242,0)=" D EBSUMMARY^IBCNEUT2(DFN,RIEN,SOI,.POLICY)"
^XMB(3.9,144657,2,4243,0)="""RTN"",""IBCNEHL5A"",57,0)"
^XMB(3.9,144657,2,4244,0)=" ;"
^XMB(3.9,144657,2,4245,0)="""RTN"",""IBCNEHL5A"",58,0)"
^XMB(3.9,144657,2,4246,0)=" I '$O(POLICY(0)) G XLOAD       ;if none was returned on payer response (safety valve)"
^XMB(3.9,144657,2,4247,0)="""RTN"",""IBCNEHL5A"",59,0)"
^XMB(3.9,144657,2,4248,0)=" I $G(POLICY(""OHI""))=1 G XLOAD    ;Indicates Other potential insurance indicated on payer response"
^XMB(3.9,144657,2,4249,0)="""RTN"",""IBCNEHL5A"",60,0)"
^XMB(3.9,144657,2,4250,0)=" ;If the Medicare Policy in the Response is missing the Effective Date, don't load ANY Medicare policies"
^XMB(3.9,144657,2,4251,0)="""RTN"",""IBCNEHL5A"",61,0)"
^XMB(3.9,144657,2,4252,0)=" I $G(POLICY(""MISSING_EFFDT""))=1 G XLOAD"
^XMB(3.9,144657,2,4253,0)="""RTN"",""IBCNEHL5A"",62,0)"
^XMB(3.9,144657,2,4254,0)=" ;"
^XMB(3.9,144657,2,4255,0)="""RTN"",""IBCNEHL5A"",63,0)"
^XMB(3.9,144657,2,4256,0)=" ;Loop through list of insurance (.POLICY) and keep only ACTIVE policies (according to the payer's response)"
^XMB(3.9,144657,2,4257,0)="""RTN"",""IBCNEHL5A"",64,0)"
^XMB(3.9,144657,2,4258,0)=" ; Only add 'Active' policies to the ACTIVE array - ACTIVE(GRPNUM)=DFN_U_GRPNUM_U_EFFDT_U_SOI_U_ELIG"
^XMB(3.9,144657,2,4259,0)="""RTN"",""IBCNEHL5A"",65,0)"
^XMB(3.9,144657,2,4260,0)=" S POLCT="""" F  S POLCT=$O(POLICY(POLCT)) Q:POLCT=""""  D"
^XMB(3.9,144657,2,4261,0)="""RTN"",""IBCNEHL5A"",66,0)"
^XMB(3.9,144657,2,4262,0)=" . S GRPNUM="""" F  S GRPNUM=$O(POLICY(POLCT,GRPNUM)) Q:GRPNUM=""""  D"
^XMB(3.9,144657,2,4263,0)="""RTN"",""IBCNEHL5A"",67,0)"
^XMB(3.9,144657,2,4264,0)=" . . I $TR(GRPNUM,""abcdefghijklmnopqrstuvwxyz"",""ABCDEFGHIJKLMNOPQRSTUVWXYZ"")'[""MEDICARE"" Q"
^XMB(3.9,144657,2,4265,0)="""RTN"",""IBCNEHL5A"",68,0)"
^XMB(3.9,144657,2,4266,0)=" . . S ELIG=$P(POLICY(POLCT,GRPNUM),U,5)   ; ELIG='Inactive' or 'Active Coverage'"
^XMB(3.9,144657,2,4267,0)="""RTN"",""IBCNEHL5A"",69,0)"
^XMB(3.9,144657,2,4268,0)=" . . I $TR(ELIG,""abcdefghijklmnopqrstuvwxyz"",""ABCDEFGHIJKLMNOPQRSTUVWXYZ"")[""INACTIVE"" Q"
^XMB(3.9,144657,2,4269,0)="""RTN"",""IBCNEHL5A"",70,0)"
^XMB(3.9,144657,2,4270,0)=" . . S ACTIVE(GRPNUM)=POLICY(POLCT,GRPNUM)"
^XMB(3.9,144657,2,4271,0)="""RTN"",""IBCNEHL5A"",71,0)"
^XMB(3.9,144657,2,4272,0)=" ;"
^XMB(3.9,144657,2,4273,0)="""RTN"",""IBCNEHL5A"",72,0)"
^XMB(3.9,144657,2,4274,0)=" ;Loop through the ACTIVE policies, determine what policy(s) can be added to the patient record"
^XMB(3.9,144657,2,4275,0)="""RTN"",""IBCNEHL5A"",73,0)"
^XMB(3.9,144657,2,4276,0)=" ;     GRPNUM ='Medicare Part A' or 'Medicare Part B'"
^XMB(3.9,144657,2,4277,0)="""RTN"",""IBCNEHL5A"",74,0)"
^XMB(3.9,144657,2,4278,0)=" S GRPNUM="""" F  S GRPNUM=$O(ACTIVE(GRPNUM)) Q:GRPNUM=""""  D"
^XMB(3.9,144657,2,4279,0)="""RTN"",""IBCNEHL5A"",75,0)"
^XMB(3.9,144657,2,4280,0)=" . N IBCDFN,IBCOVP,IBCPOL,IBCDFN,IBEVTACT,IBEVTP0,IBEVTP1,IBEVTP2,IBEVTP3,IBEVTP7,IBNEW"
^XMB(3.9,144657,2,4281,0)="""RTN"",""IBCNEHL5A"",76,0)"
^XMB(3.9,144657,2,4282,0)=" . ; Note: SAVEMWR calls BEFORE^IBCNSEVT"
^XMB(3.9,144657,2,4283,0)="""RTN"",""IBCNEHL5A"",77,0)"
^XMB(3.9,144657,2,4284,0)=" . S LOAD=$$SAVEMWR(RIEN)"
^XMB(3.9,144657,2,4285,0)="""RTN"",""IBCNEHL5A"",78,0)"
^XMB(3.9,144657,2,4286,0)=" . ;"
^XMB(3.9,144657,2,4287,0)="""RTN"",""IBCNEHL5A"",79,0)"
^XMB(3.9,144657,2,4288,0)=" . ;Check to see if patient is 'COVERED BY HEALTH INSURANCE?' regardless of what LOAD is set to."
^XMB(3.9,144657,2,4289,0)="""RTN"",""IBCNEHL5A"",80,0)"
^XMB(3.9,144657,2,4290,0)=" . ; It is possible that a policy could have been partially loaded (LOAD=0) and should be evaluated."
^XMB(3.9,144657,2,4291,0)="""RTN"",""IBCNEHL5A"",81,0)"
^XMB(3.9,144657,2,4292,0)=" . S IBCOVP=$$GET1^DIQ(2,DFN_"","",.3192,""I"")           ;COVERED BY INSURANCE?"
^XMB(3.9,144657,2,4293,0)="""RTN"",""IBCNEHL5A"",82,0)"
^XMB(3.9,144657,2,4294,0)=" . S IBCPOL=$$GET1^DIQ(2.312,IBCDFN_"",""_DFN,.18,""I"")  ;GROUP PLAN"
^XMB(3.9,144657,2,4295,0)="""RTN"",""IBCNEHL5A"",83,0)"
^XMB(3.9,144657,2,4296,0)=" . D COVERED^IBCNSM31(DFN,IBCOVP) ;this code updates field (#2,.3192)"
^XMB(3.9,144657,2,4297,0)="""RTN"",""IBCNEHL5A"",84,0)"
^XMB(3.9,144657,2,4298,0)=" . ;"
^XMB(3.9,144657,2,4299,0)="""RTN"",""IBCNEHL5A"",85,0)"
^XMB(3.9,144657,2,4300,0)=" . ;IBCNSEVT calls the protocol IBCN NEW INSURANCE EVENTS which in turn calls the following"
^XMB(3.9,144657,2,4301,0)="""RTN"",""IBCNEHL5A"",86,0)"
^XMB(3.9,144657,2,4302,0)=" . ; protocols: IBCN INSURANCE BULLETIN, IVM INSURANCE EVENT and VPR IBCN EVENTS"
^XMB(3.9,144657,2,4303,0)="""RTN"",""IBCNEHL5A"",87,0)"
^XMB(3.9,144657,2,4304,0)=" . ; Note: the protocol IBCN INSURANCE BULLETIN deletes field NO VERIFICATION DATE (#354,60)"
^XMB(3.9,144657,2,4305,0)="""RTN"",""IBCNEHL5A"",88,0)"
^XMB(3.9,144657,2,4306,0)=" . I $G(IBCDFN)>0 D AFTER^IBCNSEVT,^IBCNSEVT"
^XMB(3.9,144657,2,4307,0)="""RTN"",""IBCNEHL5A"",89,0)"
^XMB(3.9,144657,2,4308,0)=" . Q"
^XMB(3.9,144657,2,4309,0)="""RTN"",""IBCNEHL5A"",90,0)"
^XMB(3.9,144657,2,4310,0)=" ;"
^XMB(3.9,144657,2,4311,0)="""RTN"",""IBCNEHL5A"",91,0)"
^XMB(3.9,144657,2,4312,0)="XLOAD ;"
^XMB(3.9,144657,2,4313,0)="""RTN"",""IBCNEHL5A"",92,0)"
^XMB(3.9,144657,2,4314,0)=" D MWRUNLOCK   ; unlock ins subfile"
^XMB(3.9,144657,2,4315,0)="""RTN"",""IBCNEHL5A"",93,0)"
^XMB(3.9,144657,2,4316,0)=" Q LOAD"
^XMB(3.9,144657,2,4317,0)="""RTN"",""IBCNEHL5A"",94,0)"
^XMB(3.9,144657,2,4318,0)=" ;"
^XMB(3.9,144657,2,4319,0)="""RTN"",""IBCNEHL5A"",95,0)"
^XMB(3.9,144657,2,4320,0)=" ;--------------------------------------------------"
^XMB(3.9,144657,2,4321,0)="""RTN"",""IBCNEHL5A"",96,0)"
^XMB(3.9,144657,2,4322,0)=" ;"
^XMB(3.9,144657,2,4323,0)="""RTN"",""IBCNEHL5A"",97,0)"
^XMB(3.9,144657,2,4324,0)="SAVEMWR(RIEN) ;autoload of Medicare policy(s)"
^XMB(3.9,144657,2,4325,0)="""RTN"",""IBCNEHL5A"",98,0)"
^XMB(3.9,144657,2,4326,0)=" ; The logic in this tag is from AUTOFIL^IBCNEHL5, with minor modifications for Medicare autoload"
^XMB(3.9,144657,2,4327,0)="""RTN"",""IBCNEHL5A"",99,0)"
^XMB(3.9,144657,2,4328,0)=" ;"
^XMB(3.9,144657,2,4329,0)="""RTN"",""IBCNEHL5A"",100,0)"
^XMB(3.9,144657,2,4330,0)=" ;INPUT:"
^XMB(3.9,144657,2,4331,0)="""RTN"",""IBCNEHL5A"",101,0)"
^XMB(3.9,144657,2,4332,0)=" ;   RIEN - IEN of file #365 IIV RESPONSE "
^XMB(3.9,144657,2,4333,0)="""RTN"",""IBCNEHL5A"",102,0)"
^XMB(3.9,144657,2,4334,0)=" ;"
^XMB(3.9,144657,2,4335,0)="""RTN"",""IBCNEHL5A"",103,0)"
^XMB(3.9,144657,2,4336,0)=" ;    DFN - IEN in file #2"
^XMB(3.9,144657,2,4337,0)="""RTN"",""IBCNEHL5A"",104,0)"
^XMB(3.9,144657,2,4338,0)=" ; IEN312 - IEN in file #2.312"
^XMB(3.9,144657,2,4339,0)="""RTN"",""IBCNEHL5A"",105,0)"
^XMB(3.9,144657,2,4340,0)=" ;  EFFDT - Effective Date of Policy (in FileMan format)"
^XMB(3.9,144657,2,4341,0)="""RTN"",""IBCNEHL5A"",106,0)"
^XMB(3.9,144657,2,4342,0)=" ;    SOI - Source of Information"
^XMB(3.9,144657,2,4343,0)="""RTN"",""IBCNEHL5A"",107,0)"
^XMB(3.9,144657,2,4344,0)=" ;"
^XMB(3.9,144657,2,4345,0)="""RTN"",""IBCNEHL5A"",108,0)"
^XMB(3.9,144657,2,4346,0)=" N ADDFLG,DATA,DFN,DOBCMT,EFFDT,ERFLG,ERROR,IBAUUSR,IBEIVUSR,IBFLDS,IBIFN,IBINS,IBGRP,IBMSG,IENS,IEN312"
^XMB(3.9,144657,2,4347,0)="""RTN"",""IBCNEHL5A"",109,0)"
^XMB(3.9,144657,2,4348,0)=" N MGRP,PTLOAD,SOI,TQN"
^XMB(3.9,144657,2,4349,0)="""RTN"",""IBCNEHL5A"",110,0)"
^XMB(3.9,144657,2,4350,0)=" ;"
^XMB(3.9,144657,2,4351,0)="""RTN"",""IBCNEHL5A"",111,0)"
^XMB(3.9,144657,2,4352,0)=" S PTLOAD=1"
^XMB(3.9,144657,2,4353,0)="""RTN"",""IBCNEHL5A"",112,0)"
^XMB(3.9,144657,2,4354,0)=" I (RIEN="""") S PTLOAD=0 G SAVEMWRX"
^XMB(3.9,144657,2,4355,0)="""RTN"",""IBCNEHL5A"",113,0)"
^XMB(3.9,144657,2,4356,0)=" S MGRP=$$MGRP^IBCNEUT5()"
^XMB(3.9,144657,2,4357,0)="""RTN"",""IBCNEHL5A"",114,0)"
^XMB(3.9,144657,2,4358,0)=" ;"
^XMB(3.9,144657,2,4359,0)="""RTN"",""IBCNEHL5A"",115,0)"
^XMB(3.9,144657,2,4360,0)=" N RDATA0,RDATA1,RDATA4,RDATA5,RDATA12,RDATA13"
^XMB(3.9,144657,2,4361,0)="""RTN"",""IBCNEHL5A"",116,0)"
^XMB(3.9,144657,2,4362,0)=" S DFN=$P(ACTIVE(GRPNUM),U)"
^XMB(3.9,144657,2,4363,0)="""RTN"",""IBCNEHL5A"",117,0)"
^XMB(3.9,144657,2,4364,0)=" S EFFDT=$P(ACTIVE(GRPNUM),U,3)"
^XMB(3.9,144657,2,4365,0)="""RTN"",""IBCNEHL5A"",118,0)"
^XMB(3.9,144657,2,4366,0)=" S SOI=$P(ACTIVE(GRPNUM),U,4)"
^XMB(3.9,144657,2,4367,0)="""RTN"",""IBCNEHL5A"",119,0)"
^XMB(3.9,144657,2,4368,0)=" S ADDFLG=365"
^XMB(3.9,144657,2,4369,0)="""RTN"",""IBCNEHL5A"",120,0)"
^XMB(3.9,144657,2,4370,0)=" ; Required fields needed to save the policy "
^XMB(3.9,144657,2,4371,0)="""RTN"",""IBCNEHL5A"",121,0)"
^XMB(3.9,144657,2,4372,0)=" I ($G(DFN)="""")!($G(GRPNUM)="""")!($G(EFFDT)="""")!($G(SOI)="""") S PTLOAD=0 G SAVEMWRX"
^XMB(3.9,144657,2,4373,0)="""RTN"",""IBCNEHL5A"",122,0)"
^XMB(3.9,144657,2,4374,0)=" ; Get data from the eIV Response"
^XMB(3.9,144657,2,4375,0)="""RTN"",""IBCNEHL5A"",123,0)"
^XMB(3.9,144657,2,4376,0)=" S RDATA0=$G(^IBCN(365,RIEN,0)),RDATA1=$G(^IBCN(365,RIEN,1))"
^XMB(3.9,144657,2,4377,0)="""RTN"",""IBCNEHL5A"",124,0)"
^XMB(3.9,144657,2,4378,0)=" S RDATA4=$G(^IBCN(365,RIEN,4)),RDATA5=$G(^IBCN(365,RIEN,5))"
^XMB(3.9,144657,2,4379,0)="""RTN"",""IBCNEHL5A"",125,0)"
^XMB(3.9,144657,2,4380,0)=" S RDATA12=$G(^IBCN(365,RIEN,12)),RDATA13=$G(^IBCN(365,RIEN,13))"
^XMB(3.9,144657,2,4381,0)="""RTN"",""IBCNEHL5A"",126,0)"
^XMB(3.9,144657,2,4382,0)=" S TQN=$P(RDATA0,U,5)"
^XMB(3.9,144657,2,4383,0)="""RTN"",""IBCNEHL5A"",127,0)"
^XMB(3.9,144657,2,4384,0)=" ; Get other required data"
^XMB(3.9,144657,2,4385,0)="""RTN"",""IBCNEHL5A"",128,0)"
^XMB(3.9,144657,2,4386,0)=" S (IBINS,IBGRP,IBAUUSR,IBEIVUSR)="""""
^XMB(3.9,144657,2,4387,0)="""RTN"",""IBCNEHL5A"",129,0)"
^XMB(3.9,144657,2,4388,0)=" S IBINS=$O(^DIC(36,""B"",""MEDICARE (WNR)"",""""))"
^XMB(3.9,144657,2,4389,0)="""RTN"",""IBCNEHL5A"",130,0)"
^XMB(3.9,144657,2,4390,0)=" ;find the Medicare Group Plan - Part A or Part B. There could be more than 1 Part A or Part B"
^XMB(3.9,144657,2,4391,0)="""RTN"",""IBCNEHL5A"",131,0)"
^XMB(3.9,144657,2,4392,0)=" I IBINS'="""" D GETGRP"
^XMB(3.9,144657,2,4393,0)="""RTN"",""IBCNEHL5A"",132,0)"
^XMB(3.9,144657,2,4394,0)=" S IBAUUSR=$O(^VA(200,""B"",""AUTOUPDATE,IBEIV"",""""))"
^XMB(3.9,144657,2,4395,0)="""RTN"",""IBCNEHL5A"",133,0)"
^XMB(3.9,144657,2,4396,0)=" S IBEIVUSR=$O(^VA(200,""B"",""INTERFACE,IB EIV"",""""))"
^XMB(3.9,144657,2,4397,0)="""RTN"",""IBCNEHL5A"",134,0)"
^XMB(3.9,144657,2,4398,0)=" I (IBINS="""")!(IBGRP="""")!(IBAUUSR="""")!(IBEIVUSR="""") S PTLOAD=0 G SAVEMWRX"
^XMB(3.9,144657,2,4399,0)="""RTN"",""IBCNEHL5A"",135,0)"
^XMB(3.9,144657,2,4400,0)=" ;"
^XMB(3.9,144657,2,4401,0)="""RTN"",""IBCNEHL5A"",136,0)"
^XMB(3.9,144657,2,4402,0)=" ; --Medicare Required fields--"
^XMB(3.9,144657,2,4403,0)="""RTN"",""IBCNEHL5A"",137,0)"
^XMB(3.9,144657,2,4404,0)=" ; Add a new patient policy"
^XMB(3.9,144657,2,4405,0)="""RTN"",""IBCNEHL5A"",138,0)"
^XMB(3.9,144657,2,4406,0)=" K DA,DD,DIC,DO,X,Y"
^XMB(3.9,144657,2,4407,0)="""RTN"",""IBCNEHL5A"",139,0)"
^XMB(3.9,144657,2,4408,0)=" S DIC(""DR"")="".01///""_IBINS_"";.18///""_IBGRP_"";1.01///NOW;1.02///""_IBEIVUSR_"";1.05///NOW"""
^XMB(3.9,144657,2,4409,0)="""RTN"",""IBCNEHL5A"",140,0)"
^XMB(3.9,144657,2,4410,0)=" S DA(1)=DFN,DIC=""^DPT(""_DFN_"",.312,"",DIC(0)=""L"",X=IBINS"
^XMB(3.9,144657,2,4411,0)="""RTN"",""IBCNEHL5A"",141,0)"
^XMB(3.9,144657,2,4412,0)=" D FILE^DICN S (IEN312,IBCDFN)=+Y,IBNEW=1"
^XMB(3.9,144657,2,4413,0)="""RTN"",""IBCNEHL5A"",142,0)"
^XMB(3.9,144657,2,4414,0)=" D BEFORE^IBCNSEVT    ;this sets variables that will be used in COVERED"
^XMB(3.9,144657,2,4415,0)="""RTN"",""IBCNEHL5A"",143,0)"
^XMB(3.9,144657,2,4416,0)=" S IENS=IEN312_"",""_DFN_"","""
^XMB(3.9,144657,2,4417,0)="""RTN"",""IBCNEHL5A"",144,0)"
^XMB(3.9,144657,2,4418,0)=" ;"
^XMB(3.9,144657,2,4419,0)="""RTN"",""IBCNEHL5A"",145,0)"
^XMB(3.9,144657,2,4420,0)=" K DATA"
^XMB(3.9,144657,2,4421,0)="""RTN"",""IBCNEHL5A"",146,0)"
^XMB(3.9,144657,2,4422,0)=" S DATA(2.312,IENS,.2)=1    ;'1' for PRIMARY"
^XMB(3.9,144657,2,4423,0)="""RTN"",""IBCNEHL5A"",147,0)"
^XMB(3.9,144657,2,4424,0)=" S DATA(2.312,IENS,4.03)=18 ;'18' for SELF"
^XMB(3.9,144657,2,4425,0)="""RTN"",""IBCNEHL5A"",148,0)"
^XMB(3.9,144657,2,4426,0)=" S DATA(2.312,IENS,1.09)=SOI             ;SOURCE OF INFORMATION (from 270 Inquiry)"
^XMB(3.9,144657,2,4427,0)="""RTN"",""IBCNEHL5A"",149,0)"
^XMB(3.9,144657,2,4428,0)=" S DATA(2.312,IENS,7.02)=$P(RDATA13,U,2) ;SUBSCRIBER ID"
^XMB(3.9,144657,2,4429,0)="""RTN"",""IBCNEHL5A"",150,0)"
^XMB(3.9,144657,2,4430,0)=" S DATA(2.312,IENS,8)=EFFDT              ;EFFECTIVE DATE"
^XMB(3.9,144657,2,4431,0)="""RTN"",""IBCNEHL5A"",151,0)"
^XMB(3.9,144657,2,4432,0)=" ; --Medicare - Optional fields on 271 Payer Response--"
^XMB(3.9,144657,2,4433,0)="""RTN"",""IBCNEHL5A"",152,0)"
^XMB(3.9,144657,2,4434,0)=" S DATA(2.312,IENS,6)=""v""                ;WHOSE INSURANCE - 'v' for VETERAN"
^XMB(3.9,144657,2,4435,0)="""RTN"",""IBCNEHL5A"",153,0)"
^XMB(3.9,144657,2,4436,0)=" S DATA(2.312,IENS,7.01)=$P(RDATA13,U)   ;NAME OF INSURED"
^XMB(3.9,144657,2,4437,0)="""RTN"",""IBCNEHL5A"",154,0)"
^XMB(3.9,144657,2,4438,0)=" ;"
^XMB(3.9,144657,2,4439,0)="""RTN"",""IBCNEHL5A"",155,0)"
^XMB(3.9,144657,2,4440,0)=" ; Get DOB from 271 Payer Response, if null pull from the PATIENT file"
^XMB(3.9,144657,2,4441,0)="""RTN"",""IBCNEHL5A"",156,0)"
^XMB(3.9,144657,2,4442,0)=" N PRDOB S PRDOB=$P(RDATA1,U,2)"
^XMB(3.9,144657,2,4443,0)="""RTN"",""IBCNEHL5A"",157,0)"
^XMB(3.9,144657,2,4444,0)=" S DATA(2.312,IENS,3.01)=$S(PRDOB'="""":PRDOB,1:$$GET1^DIQ(2,DFN_"","",.03))"
^XMB(3.9,144657,2,4445,0)="""RTN"",""IBCNEHL5A"",158,0)"
^XMB(3.9,144657,2,4446,0)=" ;"
^XMB(3.9,144657,2,4447,0)="""RTN"",""IBCNEHL5A"",159,0)"
^XMB(3.9,144657,2,4448,0)=" ; if DOB from 271 Payer Response DOESN'T match the DOB on the PATIENT file, then store"
^XMB(3.9,144657,2,4449,0)="""RTN"",""IBCNEHL5A"",160,0)"
^XMB(3.9,144657,2,4450,0)=" ;  the DOB from the 271 and add a patient policy comment indicating there is a difference"
^XMB(3.9,144657,2,4451,0)="""RTN"",""IBCNEHL5A"",161,0)"
^XMB(3.9,144657,2,4452,0)=" I PRDOB'="""" I PRDOB'=$$GET1^DIQ(2,DFN_"","",.03,""I"") D"
^XMB(3.9,144657,2,4453,0)="""RTN"",""IBCNEHL5A"",162,0)"
^XMB(3.9,144657,2,4454,0)=" . S DATA(2.312,IENS,3.01)=PRDOB"
^XMB(3.9,144657,2,4455,0)="""RTN"",""IBCNEHL5A"",163,0)"
^XMB(3.9,144657,2,4456,0)=" . S DOBCMT=""The DOB on the Patient record is ""_$$GET1^DIQ(2,DFN_"","",.03)_"". The DOB on the eIV Payer Response, which was saved to the insurance record, is ""_$$FMTE^XLFDT(PRDOB,5)_""."""
^XMB(3.9,144657,2,4457,0)="""RTN"",""IBCNEHL5A"",164,0)"
^XMB(3.9,144657,2,4458,0)=" . D ADDCOM(DFN,IEN312,DOBCMT)"
^XMB(3.9,144657,2,4459,0)="""RTN"",""IBCNEHL5A"",165,0)"
^XMB(3.9,144657,2,4460,0)=" ;"
^XMB(3.9,144657,2,4461,0)="""RTN"",""IBCNEHL5A"",166,0)"
^XMB(3.9,144657,2,4462,0)=" ; Get SEX from 271 Payer Response, if null pull from the PATIENT file"
^XMB(3.9,144657,2,4463,0)="""RTN"",""IBCNEHL5A"",167,0)"
^XMB(3.9,144657,2,4464,0)=" S DATA(2.312,IENS,3.12)=$S($P(RDATA1,U,4)'="""":$P(RDATA1,U,4),1:$$GET1^DIQ(2,DFN_"","",.02))"
^XMB(3.9,144657,2,4465,0)="""RTN"",""IBCNEHL5A"",168,0)"
^XMB(3.9,144657,2,4466,0)=" ;"
^XMB(3.9,144657,2,4467,0)="""RTN"",""IBCNEHL5A"",169,0)"
^XMB(3.9,144657,2,4468,0)=" ; Get Address from 271 Payer Response - the Response MUST contain Address Line 1,"
^XMB(3.9,144657,2,4469,0)="""RTN"",""IBCNEHL5A"",170,0)"
^XMB(3.9,144657,2,4470,0)=" ;  City, State, Zip. Otherwise pull from PATIENT file"
^XMB(3.9,144657,2,4471,0)="""RTN"",""IBCNEHL5A"",171,0)"
^XMB(3.9,144657,2,4472,0)=" I ($P(RDATA5,U)="""")!($P(RDATA5,U,3)="""")!($P(RDATA5,U,4)="""")!($P(RDATA5,U,5)="""") S ADDFLG=2"
^XMB(3.9,144657,2,4473,0)="""RTN"",""IBCNEHL5A"",172,0)"
^XMB(3.9,144657,2,4474,0)=" I ADDFLG=365 D"
^XMB(3.9,144657,2,4475,0)="""RTN"",""IBCNEHL5A"",173,0)"
^XMB(3.9,144657,2,4476,0)=" . S DATA(2.312,IENS,3.06)=$P(RDATA5,U)   ;Street line 1"
^XMB(3.9,144657,2,4477,0)="""RTN"",""IBCNEHL5A"",174,0)"
^XMB(3.9,144657,2,4478,0)=" . S DATA(2.312,IENS,3.08)=$P(RDATA5,U,3) ;City"
^XMB(3.9,144657,2,4479,0)="""RTN"",""IBCNEHL5A"",175,0)"
^XMB(3.9,144657,2,4480,0)=" . S DATA(2.312,IENS,3.09)=$P(RDATA5,U,4) ;State"
^XMB(3.9,144657,2,4481,0)="""RTN"",""IBCNEHL5A"",176,0)"
^XMB(3.9,144657,2,4482,0)=" . S DATA(2.312,IENS,3.1)=$P(RDATA5,U,5)  ;Zip"
^XMB(3.9,144657,2,4483,0)="""RTN"",""IBCNEHL5A"",177,0)"
^XMB(3.9,144657,2,4484,0)=" I ADDFLG=2 D"
^XMB(3.9,144657,2,4485,0)="""RTN"",""IBCNEHL5A"",178,0)"
^XMB(3.9,144657,2,4486,0)=" . S DATA(2.312,IENS,3.06)=$$GET1^DIQ(2,DFN_"","",.111) ;Street line 1"
^XMB(3.9,144657,2,4487,0)="""RTN"",""IBCNEHL5A"",179,0)"
^XMB(3.9,144657,2,4488,0)=" . S DATA(2.312,IENS,3.08)=$$GET1^DIQ(2,DFN_"","",.114) ;City"
^XMB(3.9,144657,2,4489,0)="""RTN"",""IBCNEHL5A"",180,0)"
^XMB(3.9,144657,2,4490,0)=" . S DATA(2.312,IENS,3.09)=$$GET1^DIQ(2,DFN_"","",.115) ;State"
^XMB(3.9,144657,2,4491,0)="""RTN"",""IBCNEHL5A"",181,0)"
^XMB(3.9,144657,2,4492,0)=" . S DATA(2.312,IENS,3.1)=$$GET1^DIQ(2,DFN_"","",.116)  ;Zip"
^XMB(3.9,144657,2,4493,0)="""RTN"",""IBCNEHL5A"",182,0)"
^XMB(3.9,144657,2,4494,0)=" ; --Medicare - other fields from 271 Payer Response--"
^XMB(3.9,144657,2,4495,0)="""RTN"",""IBCNEHL5A"",183,0)"
^XMB(3.9,144657,2,4496,0)=" N XX"
^XMB(3.9,144657,2,4497,0)="""RTN"",""IBCNEHL5A"",184,0)"
^XMB(3.9,144657,2,4498,0)=" S XX=$P(RDATA4,U,2)"
^XMB(3.9,144657,2,4499,0)="""RTN"",""IBCNEHL5A"",185,0)"
^XMB(3.9,144657,2,4500,0)=" I XX'="""" S DATA(2.312,IENS,3.07)=XX       ;Street 2"
^XMB(3.9,144657,2,4501,0)="""RTN"",""IBCNEHL5A"",186,0)"
^XMB(3.9,144657,2,4502,0)=" S XX=$P(RDATA4,U,6)"
^XMB(3.9,144657,2,4503,0)="""RTN"",""IBCNEHL5A"",187,0)"
^XMB(3.9,144657,2,4504,0)=" I XX'="""" S DATA(2.312,IENS,3.13)=XX       ;Country"
^XMB(3.9,144657,2,4505,0)="""RTN"",""IBCNEHL5A"",188,0)"
^XMB(3.9,144657,2,4506,0)=" S XX=$P(RDATA4,U,9)"
^XMB(3.9,144657,2,4507,0)="""RTN"",""IBCNEHL5A"",189,0)"
^XMB(3.9,144657,2,4508,0)=" I XX'="""" S DATA(2.312,IENS,3.14)=XX       ;Country subdivision"
^XMB(3.9,144657,2,4509,0)="""RTN"",""IBCNEHL5A"",190,0)"
^XMB(3.9,144657,2,4510,0)=" S XX=$P(RDATA12,U)"
^XMB(3.9,144657,2,4511,0)="""RTN"",""IBCNEHL5A"",191,0)"
^XMB(3.9,144657,2,4512,0)=" I XX'="""" S DATA(2.312,IENS,12.01)=XX      ;Military Info Status Code"
^XMB(3.9,144657,2,4513,0)="""RTN"",""IBCNEHL5A"",192,0)"
^XMB(3.9,144657,2,4514,0)=" S XX=$P(RDATA12,U,7)"
^XMB(3.9,144657,2,4515,0)="""RTN"",""IBCNEHL5A"",193,0)"
^XMB(3.9,144657,2,4516,0)=" I XX'="""" S DATA(2.312,IENS,12.07)=XX      ;Date Time Period"
^XMB(3.9,144657,2,4517,0)="""RTN"",""IBCNEHL5A"",194,0)"
^XMB(3.9,144657,2,4518,0)=" ;"
^XMB(3.9,144657,2,4519,0)="""RTN"",""IBCNEHL5A"",195,0)"
^XMB(3.9,144657,2,4520,0)=" I $D(DATA) D FILE^DIE("""",""DATA"",""ERROR"")"
^XMB(3.9,144657,2,4521,0)="""RTN"",""IBCNEHL5A"",196,0)"
^XMB(3.9,144657,2,4522,0)=" I $D(ERROR) D WARN^IBCNEHL3 K ERROR D FIL^IBCNEHL1 S PTLOAD=0 G SAVEMWRX"
^XMB(3.9,144657,2,4523,0)="""RTN"",""IBCNEHL5A"",197,0)"
^XMB(3.9,144657,2,4524,0)=" K DATA"
^XMB(3.9,144657,2,4525,0)="""RTN"",""IBCNEHL5A"",198,0)"
^XMB(3.9,144657,2,4526,0)=" S DATA(2.312,IENS,1.03)=$$NOW^XLFDT       ;DATE LAST VERIFIED"
^XMB(3.9,144657,2,4527,0)="""RTN"",""IBCNEHL5A"",199,0)"
^XMB(3.9,144657,2,4528,0)=" S DATA(2.312,IENS,1.04)=IBAUUSR           ;VERIFIED BY - AUTOUPDATE,IBEIV"
^XMB(3.9,144657,2,4529,0)="""RTN"",""IBCNEHL5A"",200,0)"
^XMB(3.9,144657,2,4530,0)=" S DATA(2.312,IENS,1.06)=IBAUUSR           ;LAST EDITED BY - AUTOUPDATE,IBEIV"
^XMB(3.9,144657,2,4531,0)="""RTN"",""IBCNEHL5A"",201,0)"
^XMB(3.9,144657,2,4532,0)=" D FILE^DIE("""",""DATA"",""ERROR"")"
^XMB(3.9,144657,2,4533,0)="""RTN"",""IBCNEHL5A"",202,0)"
^XMB(3.9,144657,2,4534,0)=" I $D(ERROR) D WARN^IBCNEHL3 Q"
^XMB(3.9,144657,2,4535,0)="""RTN"",""IBCNEHL5A"",203,0)"
^XMB(3.9,144657,2,4536,0)=" ;"
^XMB(3.9,144657,2,4537,0)="""RTN"",""IBCNEHL5A"",204,0)"
^XMB(3.9,144657,2,4538,0)=" ; Set the insurance record IEN in the IIV Response file to track"
^XMB(3.9,144657,2,4539,0)="""RTN"",""IBCNEHL5A"",205,0)"
^XMB(3.9,144657,2,4540,0)=" ; which policy was updated based on the response"
^XMB(3.9,144657,2,4541,0)="""RTN"",""IBCNEHL5A"",206,0)"
^XMB(3.9,144657,2,4542,0)=" D UPDIREC^IBCNEHL3(RIEN,IEN312)"
^XMB(3.9,144657,2,4543,0)="""RTN"",""IBCNEHL5A"",207,0)"
^XMB(3.9,144657,2,4544,0)=" ;"
^XMB(3.9,144657,2,4545,0)="""RTN"",""IBCNEHL5A"",208,0)"
^XMB(3.9,144657,2,4546,0)=" ; Set the EIV AUTO-LOAD field (#.16) in the response file #365 to '1' for ""YES"" to indicate auto load occurred "
^XMB(3.9,144657,2,4547,0)="""RTN"",""IBCNEHL5A"",209,0)"
^XMB(3.9,144657,2,4548,0)=" K DATA"
^XMB(3.9,144657,2,4549,0)="""RTN"",""IBCNEHL5A"",210,0)"
^XMB(3.9,144657,2,4550,0)=" S DATA(365,RIEN_"","",.16)=1"
^XMB(3.9,144657,2,4551,0)="""RTN"",""IBCNEHL5A"",211,0)"
^XMB(3.9,144657,2,4552,0)=" D FILE^DIE("""",""DATA"")"
^XMB(3.9,144657,2,4553,0)="""RTN"",""IBCNEHL5A"",212,0)"
^XMB(3.9,144657,2,4554,0)=" ;"
^XMB(3.9,144657,2,4555,0)="""RTN"",""IBCNEHL5A"",213,0)"
^XMB(3.9,144657,2,4556,0)=" ; File data at 2.312, 9, 10 & 11 subfiles; if error is produced update buffer entry & then quit processing"
^XMB(3.9,144657,2,4557,0)="""RTN"",""IBCNEHL5A"",214,0)"
^XMB(3.9,144657,2,4558,0)=" S ERFLG=$$GRPFILE^IBCNEHL1(DFN,IEN312,RIEN,1)"
^XMB(3.9,144657,2,4559,0)="""RTN"",""IBCNEHL5A"",215,0)"
^XMB(3.9,144657,2,4560,0)=" I $G(ERFLG) Q"
^XMB(3.9,144657,2,4561,0)="""RTN"",""IBCNEHL5A"",216,0)"
^XMB(3.9,144657,2,4562,0)=" ;"
^XMB(3.9,144657,2,4563,0)="""RTN"",""IBCNEHL5A"",217,0)"
^XMB(3.9,144657,2,4564,0)=" ; File new EB data"
^XMB(3.9,144657,2,4565,0)="""RTN"",""IBCNEHL5A"",218,0)"
^XMB(3.9,144657,2,4566,0)=" S ERFLG=$$EBFILE^IBCNEHL1(DFN,IEN312,RIEN,1)"
^XMB(3.9,144657,2,4567,0)="""RTN"",""IBCNEHL5A"",219,0)"
^XMB(3.9,144657,2,4568,0)=" I $G(ERFLG) Q   ;bail out if something went wrong during filing of EB data"
^XMB(3.9,144657,2,4569,0)="""RTN"",""IBCNEHL5A"",220,0)"
^XMB(3.9,144657,2,4570,0)=" ;"
^XMB(3.9,144657,2,4571,0)="""RTN"",""IBCNEHL5A"",221,0)"
^XMB(3.9,144657,2,4572,0)=" ; File Auto Updated policy in INTERFACILITY INSURANCE UPDATE File (#365.19)"
^XMB(3.9,144657,2,4573,0)="""RTN"",""IBCNEHL5A"",222,0)"
^XMB(3.9,144657,2,4574,0)=" ; IBCNBAR added a field the param list when calling LOC^IBCNIUF. For consistency we added a 'null'."
^XMB(3.9,144657,2,4575,0)="""RTN"",""IBCNEHL5A"",223,0)"
^XMB(3.9,144657,2,4576,0)=" D LOC^IBCNIUF(DFN,$$GET1^DIQ(2.312,IEN312_"",""_DFN_"","",.01,""I""),IEN312,$$GET1^DIQ(365,RIEN_"","",.13,""I""),"""",$$GET1^DIQ(365.1,TQN_"","",3.02,""E""),"""")"
^XMB(3.9,144657,2,4577,0)="""RTN"",""IBCNEHL5A"",224,0)"
^XMB(3.9,144657,2,4578,0)=" ;"
^XMB(3.9,144657,2,4579,0)="""RTN"",""IBCNEHL5A"",225,0)"
^XMB(3.9,144657,2,4580,0)=" ; Get the buffer entry from the IIV RESPONSE File (#365)"
^XMB(3.9,144657,2,4581,0)="""RTN"",""IBCNEHL5A"",226,0)"
^XMB(3.9,144657,2,4582,0)=" S BUFF=+$P($G(^IBCN(365,RIEN,0)),U,4)"
^XMB(3.9,144657,2,4583,0)="""RTN"",""IBCNEHL5A"",227,0)"
^XMB(3.9,144657,2,4584,0)=" ;"
^XMB(3.9,144657,2,4585,0)="""RTN"",""IBCNEHL5A"",228,0)"
^XMB(3.9,144657,2,4586,0)=" ; If there is a Buffer entry associated with the Response and it is already processed,"
^XMB(3.9,144657,2,4587,0)="""RTN"",""IBCNEHL5A"",229,0)"
^XMB(3.9,144657,2,4588,0)=" ; DO NOT touch/update files #355.33 or #355.36"
^XMB(3.9,144657,2,4589,0)="""RTN"",""IBCNEHL5A"",230,0)"
^XMB(3.9,144657,2,4590,0)=" I BUFF,$$GET1^DIQ(355.33,BUFF,.04,""I"")'=""E"" S PTLOAD=0 G SAVEMWRX"
^XMB(3.9,144657,2,4591,0)="""RTN"",""IBCNEHL5A"",231,0)"
^XMB(3.9,144657,2,4592,0)=" ;"
^XMB(3.9,144657,2,4593,0)="""RTN"",""IBCNEHL5A"",232,0)"
^XMB(3.9,144657,2,4594,0)=" ; Update the buffer status to ACCEPTED, then call DELDATA^IBCNBED so only the stub remains "
^XMB(3.9,144657,2,4595,0)="""RTN"",""IBCNEHL5A"",233,0)"
^XMB(3.9,144657,2,4596,0)=" I BUFF D"
^XMB(3.9,144657,2,4597,0)="""RTN"",""IBCNEHL5A"",234,0)"
^XMB(3.9,144657,2,4598,0)=" . D STATUS^IBCNBEE(BUFF,""A"",0,0,1) ;update status to accepted"
^XMB(3.9,144657,2,4599,0)="""RTN"",""IBCNEHL5A"",235,0)"
^XMB(3.9,144657,2,4600,0)=" . ;save auto update user to buffer"
^XMB(3.9,144657,2,4601,0)="""RTN"",""IBCNEHL5A"",236,0)"
^XMB(3.9,144657,2,4602,0)=" . S IBIFN=BUFF_"","" K IBARR"
^XMB(3.9,144657,2,4603,0)="""RTN"",""IBCNEHL5A"",237,0)"
^XMB(3.9,144657,2,4604,0)=" . S IBARR(355.33,IBIFN,.06)=$G(IBEIVUSR)"
^XMB(3.9,144657,2,4605,0)="""RTN"",""IBCNEHL5A"",238,0)"
^XMB(3.9,144657,2,4606,0)=" . D FILE^DIE("""",""IBARR"")"
^XMB(3.9,144657,2,4607,0)="""RTN"",""IBCNEHL5A"",239,0)"
^XMB(3.9,144657,2,4608,0)=" . D DELDATA^IBCNBED(BUFF) ;delete buffer's insurance/patient data"
^XMB(3.9,144657,2,4609,0)="""RTN"",""IBCNEHL5A"",240,0)"
^XMB(3.9,144657,2,4610,0)=" ;"
^XMB(3.9,144657,2,4611,0)="""RTN"",""IBCNEHL5A"",241,0)"
^XMB(3.9,144657,2,4612,0)=" ; File data to #355.36 file."
^XMB(3.9,144657,2,4613,0)="""RTN"",""IBCNEHL5A"",242,0)"
^XMB(3.9,144657,2,4614,0)=" N BUFF,ERROR,FDA,WE"
^XMB(3.9,144657,2,4615,0)="""RTN"",""IBCNEHL5A"",243,0)"
^XMB(3.9,144657,2,4616,0)=" S WE=$$GET1^DIQ(365.1,TQN_"","",.1,""I"")"
^XMB(3.9,144657,2,4617,0)="""RTN"",""IBCNEHL5A"",244,0)"
^XMB(3.9,144657,2,4618,0)=" S BUFF=$$GET1^DIQ(365,RIEN_"","",.04,""I"")"
^XMB(3.9,144657,2,4619,0)="""RTN"",""IBCNEHL5A"",245,0)"
^XMB(3.9,144657,2,4620,0)=" S FDA(355.36,""+1,"",.01)=$$NOW^XLFDT ;Date Processed"
^XMB(3.9,144657,2,4621,0)="""RTN"",""IBCNEHL5A"",246,0)"
^XMB(3.9,144657,2,4622,0)=" S FDA(355.36,""+1,"",.02)=$S(""^6^""[(U_WE_U):3,""^1^""[(U_WE_U):1,1:"""") ;""WE"" can only be a 1 or a 6 at this point"
^XMB(3.9,144657,2,4623,0)="""RTN"",""IBCNEHL5A"",247,0)"
^XMB(3.9,144657,2,4624,0)=" S FDA(355.36,""+1,"",.03)=$$GET1^DIQ(365.1,TQN_"","",3.02,""I"") ;Source of Information"
^XMB(3.9,144657,2,4625,0)="""RTN"",""IBCNEHL5A"",248,0)"
^XMB(3.9,144657,2,4626,0)=" S FDA(355.36,""+1,"",.05)=TQN            ;EIV Inquiry"
^XMB(3.9,144657,2,4627,0)="""RTN"",""IBCNEHL5A"",249,0)"
^XMB(3.9,144657,2,4628,0)=" S FDA(355.36,""+1,"",.06)=RIEN           ;EIV Response"
^XMB(3.9,144657,2,4629,0)="""RTN"",""IBCNEHL5A"",250,0)"
^XMB(3.9,144657,2,4630,0)=" S FDA(355.36,""+1,"",.07)=BUFF           ;Buffer"
^XMB(3.9,144657,2,4631,0)="""RTN"",""IBCNEHL5A"",251,0)"
^XMB(3.9,144657,2,4632,0)=" S FDA(355.36,""+1,"",.08)=WE             ;Source of Request (Which Extract)"
^XMB(3.9,144657,2,4633,0)="""RTN"",""IBCNEHL5A"",252,0)"
^XMB(3.9,144657,2,4634,0)=" S FDA(355.36,""+1,"",.09)=$$GET1^DIQ(365,RIEN_"","",.16,""I"") ;EIV Auto-load"
^XMB(3.9,144657,2,4635,0)="""RTN"",""IBCNEHL5A"",253,0)"
^XMB(3.9,144657,2,4636,0)=" D UPDATE^DIE("""",""FDA"",,""ERROR"")"
^XMB(3.9,144657,2,4637,0)="""RTN"",""IBCNEHL5A"",254,0)"
^XMB(3.9,144657,2,4638,0)=" I $D(ERROR) D"
^XMB(3.9,144657,2,4639,0)="""RTN"",""IBCNEHL5A"",255,0)"
^XMB(3.9,144657,2,4640,0)=" . D MSG003^IBCNEMS1(.IBMSG,.ERROR,TQN,RIEN,BUFF)"
^XMB(3.9,144657,2,4641,0)="""RTN"",""IBCNEHL5A"",256,0)"
^XMB(3.9,144657,2,4642,0)=" . D MSG^IBCNEUT5($$MGRP^IBCNEUT5(),""eIV Problem: Error writing to the CREATION TO PROCESSING TRACKING File (#355.36)"",""IBMSG("")"
^XMB(3.9,144657,2,4643,0)="""RTN"",""IBCNEHL5A"",257,0)"
^XMB(3.9,144657,2,4644,0)=" ;"
^XMB(3.9,144657,2,4645,0)="""RTN"",""IBCNEHL5A"",258,0)"
^XMB(3.9,144657,2,4646,0)="SAVEMWRX ;"
^XMB(3.9,144657,2,4647,0)="""RTN"",""IBCNEHL5A"",259,0)"
^XMB(3.9,144657,2,4648,0)=" Q PTLOAD"
^XMB(3.9,144657,2,4649,0)="""RTN"",""IBCNEHL5A"",260,0)"
^XMB(3.9,144657,2,4650,0)=" ;"
^XMB(3.9,144657,2,4651,0)="""RTN"",""IBCNEHL5A"",261,0)"
^XMB(3.9,144657,2,4652,0)="MWRUNLOCK ;unlock ins subfile"
^XMB(3.9,144657,2,4653,0)="""RTN"",""IBCNEHL5A"",262,0)"
^XMB(3.9,144657,2,4654,0)=" L -^DPT(DFN,.312)"
^XMB(3.9,144657,2,4655,0)="""RTN"",""IBCNEHL5A"",263,0)"
^XMB(3.9,144657,2,4656,0)=" Q "
^XMB(3.9,144657,2,4657,0)="""RTN"",""IBCNEHL5A"",264,0)"
^XMB(3.9,144657,2,4658,0)=" ;"
^XMB(3.9,144657,2,4659,0)="""RTN"",""IBCNEHL5A"",265,0)"
^XMB(3.9,144657,2,4660,0)="GETGRP  ;find the Medicare Group Plan - Part A or Part B"
^XMB(3.9,144657,2,4661,0)="""RTN"",""IBCNEHL5A"",266,0)"
^XMB(3.9,144657,2,4662,0)=" N FOUND,GIEN"
^XMB(3.9,144657,2,4663,0)="""RTN"",""IBCNEHL5A"",267,0)"
^XMB(3.9,144657,2,4664,0)=" S FOUND=0"
^XMB(3.9,144657,2,4665,0)="""RTN"",""IBCNEHL5A"",268,0)"
^XMB(3.9,144657,2,4666,0)=" S GIEN="""" F  S GIEN=$O(^IBA(355.3,""B"",IBINS,GIEN)) Q:(GIEN="""")!(FOUND=1)  D"
^XMB(3.9,144657,2,4667,0)="""RTN"",""IBCNEHL5A"",269,0)"
^XMB(3.9,144657,2,4668,0)=" . I $G(^IBA(355.3,GIEN,0))="""" Q"
^XMB(3.9,144657,2,4669,0)="""RTN"",""IBCNEHL5A"",270,0)"
^XMB(3.9,144657,2,4670,0)=" . I $P(^IBA(355.3,GIEN,0),U,3)=$S(GRPNUM=""Medicare Part A"":""PART A"",1:""PART B"") S FOUND=1,IBGRP=GIEN"
^XMB(3.9,144657,2,4671,0)="""RTN"",""IBCNEHL5A"",271,0)"
^XMB(3.9,144657,2,4672,0)=" Q"
^XMB(3.9,144657,2,4673,0)="""RTN"",""IBCNEHL5A"",272,0)"
^XMB(3.9,144657,2,4674,0)=" ;"
^XMB(3.9,144657,2,4675,0)="""RTN"",""IBCNEHL5A"",273,0)"
^XMB(3.9,144657,2,4676,0)="ADDCOM(IBDFN,IBPOLDA,IBPOLCOM) ;"
^XMB(3.9,144657,2,4677,0)="""RTN"",""IBCNEHL5A"",274,0)"
^XMB(3.9,144657,2,4678,0)=" ; Add new patient policy comment (2.312, 1.18) Multiple #2.342"
^XMB(3.9,144657,2,4679,0)="""RTN"",""IBCNEHL5A"",275,0)"
^XMB(3.9,144657,2,4680,0)=" N CIEN,FDA"
^XMB(3.9,144657,2,4681,0)="""RTN"",""IBCNEHL5A"",276,0)"
^XMB(3.9,144657,2,4682,0)=" ;"
^XMB(3.9,144657,2,4683,0)="""RTN"",""IBCNEHL5A"",277,0)"
^XMB(3.9,144657,2,4684,0)=" ;To keep the Patient Policy Comment trigger from looping and creating two entries"
^XMB(3.9,144657,2,4685,0)="""RTN"",""IBCNEHL5A"",278,0)"
^XMB(3.9,144657,2,4686,0)=" ; we need to set DUZ to the INTERFACE,IB EIV user (IBEIVUSR)"
^XMB(3.9,144657,2,4687,0)="""RTN"",""IBCNEHL5A"",279,0)"
^XMB(3.9,144657,2,4688,0)=" I +$G(IBEIVUSR)'=0 N DUZ S DUZ=$G(IBEIVUSR)"
^XMB(3.9,144657,2,4689,0)="""RTN"",""IBCNEHL5A"",280,0)"
^XMB(3.9,144657,2,4690,0)=" ;"
^XMB(3.9,144657,2,4691,0)="""RTN"",""IBCNEHL5A"",281,0)"
^XMB(3.9,144657,2,4692,0)=" ; -- populate FDA array"
^XMB(3.9,144657,2,4693,0)="""RTN"",""IBCNEHL5A"",282,0)"
^XMB(3.9,144657,2,4694,0)=" S CIEN=""+1""_"",""_IBPOLDA_"",""_IBDFN_"","""
^XMB(3.9,144657,2,4695,0)="""RTN"",""IBCNEHL5A"",283,0)"
^XMB(3.9,144657,2,4696,0)=" S FDA(2.342,CIEN,.01)=$$NOW^XLFDT()"
^XMB(3.9,144657,2,4697,0)="""RTN"",""IBCNEHL5A"",284,0)"
^XMB(3.9,144657,2,4698,0)=" S FDA(2.342,CIEN,.02)=DUZ"
^XMB(3.9,144657,2,4699,0)="""RTN"",""IBCNEHL5A"",285,0)"
^XMB(3.9,144657,2,4700,0)=" S FDA(2.342,CIEN,.03)=IBPOLCOM"
^XMB(3.9,144657,2,4701,0)="""RTN"",""IBCNEHL5A"",286,0)"
^XMB(3.9,144657,2,4702,0)=" ; -- add comments"
^XMB(3.9,144657,2,4703,0)="""RTN"",""IBCNEHL5A"",287,0)"
^XMB(3.9,144657,2,4704,0)=" D UPDATE^DIE(,""FDA"")"
^XMB(3.9,144657,2,4705,0)="""RTN"",""IBCNEHL5A"",288,0)"
^XMB(3.9,144657,2,4706,0)=" Q"
^XMB(3.9,144657,2,4707,0)="""RTN"",""IBCNEQU"")"
^XMB(3.9,144657,2,4708,0)="0^24^B154705853"
^XMB(3.9,144657,2,4709,0)="""RTN"",""IBCNEQU"",1,0)"
^XMB(3.9,144657,2,4710,0)="IBCNEQU ;DAOU/BHS - eIV REQUEST ELECTRONIC INSURANCE INQUIRY ; 24-JUN-2002"
^XMB(3.9,144657,2,4711,0)="""RTN"",""IBCNEQU"",2,0)"
^XMB(3.9,144657,2,4712,0)=" ;;2.0;INTEGRATED BILLING;**184,271,416,438,497,582,601,631,668,702,732,737**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,4713,0)="""RTN"",""IBCNEQU"",3,0)"
^XMB(3.9,144657,2,4714,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144657,2,4715,0)="""RTN"",""IBCNEQU"",4,0)"
^XMB(3.9,144657,2,4716,0)=" ;"
^XMB(3.9,144657,2,4717,0)="""RTN"",""IBCNEQU"",5,0)"
^XMB(3.9,144657,2,4718,0)=" ; eIV - Insurance Verification Interface"
^XMB(3.9,144657,2,4719,0)="""RTN"",""IBCNEQU"",6,0)"
^XMB(3.9,144657,2,4720,0)=" ;"
^XMB(3.9,144657,2,4721,0)="""RTN"",""IBCNEQU"",7,0)"
^XMB(3.9,144657,2,4722,0)=" ; Must call from EN"
^XMB(3.9,144657,2,4723,0)="""RTN"",""IBCNEQU"",8,0)"
^XMB(3.9,144657,2,4724,0)=" ;"
^XMB(3.9,144657,2,4725,0)="""RTN"",""IBCNEQU"",9,0)"
^XMB(3.9,144657,2,4726,0)=" ; IB*737/TAZ - Remove References to ~NO PAYER"
^XMB(3.9,144657,2,4727,0)="""RTN"",""IBCNEQU"",10,0)"
^XMB(3.9,144657,2,4728,0)=" Q"
^XMB(3.9,144657,2,4729,0)="""RTN"",""IBCNEQU"",11,0)"
^XMB(3.9,144657,2,4730,0)=" ;"
^XMB(3.9,144657,2,4731,0)="""RTN"",""IBCNEQU"",12,0)"
^XMB(3.9,144657,2,4732,0)="EN ; Entry pt"
^XMB(3.9,144657,2,4733,0)="""RTN"",""IBCNEQU"",13,0)"
^XMB(3.9,144657,2,4734,0)=" ; Init vars"
^XMB(3.9,144657,2,4735,0)="""RTN"",""IBCNEQU"",14,0)"
^XMB(3.9,144657,2,4736,0)=" N DFN,X,POP,IBFASTXT,VALMCNT,VALMBG,VALMHDR,VALMBCK,IDUZ"
^XMB(3.9,144657,2,4737,0)="""RTN"",""IBCNEQU"",15,0)"
^XMB(3.9,144657,2,4738,0)=" ;"
^XMB(3.9,144657,2,4739,0)="""RTN"",""IBCNEQU"",16,0)"
^XMB(3.9,144657,2,4740,0)="EN1 I $G(IBFASTXT) G ENX"
^XMB(3.9,144657,2,4741,0)="""RTN"",""IBCNEQU"",17,0)"
^XMB(3.9,144657,2,4742,0)=" S DFN=$$PAT I 'DFN G ENX"
^XMB(3.9,144657,2,4743,0)="""RTN"",""IBCNEQU"",18,0)"
^XMB(3.9,144657,2,4744,0)=" D EN^VALM(""IBCNE REQUEST INS INQUIRY LIST"")"
^XMB(3.9,144657,2,4745,0)="""RTN"",""IBCNEQU"",19,0)"
^XMB(3.9,144657,2,4746,0)=" G EN1"
^XMB(3.9,144657,2,4747,0)="""RTN"",""IBCNEQU"",20,0)"
^XMB(3.9,144657,2,4748,0)=" ;"
^XMB(3.9,144657,2,4749,0)="""RTN"",""IBCNEQU"",21,0)"
^XMB(3.9,144657,2,4750,0)="ENX ; EN exit pt"
^XMB(3.9,144657,2,4751,0)="""RTN"",""IBCNEQU"",22,0)"
^XMB(3.9,144657,2,4752,0)=" Q"
^XMB(3.9,144657,2,4753,0)="""RTN"",""IBCNEQU"",23,0)"
^XMB(3.9,144657,2,4754,0)=" ;"
^XMB(3.9,144657,2,4755,0)="""RTN"",""IBCNEQU"",24,0)"
^XMB(3.9,144657,2,4756,0)="INIT ; -- set up initial variables"
^XMB(3.9,144657,2,4757,0)="""RTN"",""IBCNEQU"",25,0)"
^XMB(3.9,144657,2,4758,0)=" S VALMCNT=0,VALMBG=1,IDUZ=DUZ"
^XMB(3.9,144657,2,4759,0)="""RTN"",""IBCNEQU"",26,0)"
^XMB(3.9,144657,2,4760,0)=" K ^TMP(""IBCNEQU"",$J),^TMP(""IBCNEQUX"",$J),^TMP(""IBCNEQUDTS"",$J)"
^XMB(3.9,144657,2,4761,0)="""RTN"",""IBCNEQU"",27,0)"
^XMB(3.9,144657,2,4762,0)=" D HDR"
^XMB(3.9,144657,2,4763,0)="""RTN"",""IBCNEQU"",28,0)"
^XMB(3.9,144657,2,4764,0)=" D BLD(DFN)"
^XMB(3.9,144657,2,4765,0)="""RTN"",""IBCNEQU"",29,0)"
^XMB(3.9,144657,2,4766,0)=" ;"
^XMB(3.9,144657,2,4767,0)="""RTN"",""IBCNEQU"",30,0)"
^XMB(3.9,144657,2,4768,0)="INITX ; INIT exit pt"
^XMB(3.9,144657,2,4769,0)="""RTN"",""IBCNEQU"",31,0)"
^XMB(3.9,144657,2,4770,0)=" Q"
^XMB(3.9,144657,2,4771,0)="""RTN"",""IBCNEQU"",32,0)"
^XMB(3.9,144657,2,4772,0)=" ;"
^XMB(3.9,144657,2,4773,0)="""RTN"",""IBCNEQU"",33,0)"
^XMB(3.9,144657,2,4774,0)="HDR ; -- screen header for initial screen"
^XMB(3.9,144657,2,4775,0)="""RTN"",""IBCNEQU"",34,0)"
^XMB(3.9,144657,2,4776,0)=" N VA,VAERR,%DT,II"
^XMB(3.9,144657,2,4777,0)="""RTN"",""IBCNEQU"",35,0)"
^XMB(3.9,144657,2,4778,0)=" D PID^VADPT"
^XMB(3.9,144657,2,4779,0)="""RTN"",""IBCNEQU"",36,0)"
^XMB(3.9,144657,2,4780,0)=" S VALMHDR(1)=""Request Electronic Insurance Inquiry for Patient: ""_$E($P($G(^DPT(DFN,0)),U),1,20)_"" ""_$E($G(^(0)),1)_VA(""BID"")"
^XMB(3.9,144657,2,4781,0)="""RTN"",""IBCNEQU"",37,0)"
^XMB(3.9,144657,2,4782,0)=" S VALMHDR(2)="" """
^XMB(3.9,144657,2,4783,0)="""RTN"",""IBCNEQU"",38,0)"
^XMB(3.9,144657,2,4784,0)=" S VALMHDR(3)="" """
^XMB(3.9,144657,2,4785,0)="""RTN"",""IBCNEQU"",39,0)"
^XMB(3.9,144657,2,4786,0)=" S II=1"
^XMB(3.9,144657,2,4787,0)="""RTN"",""IBCNEQU"",40,0)"
^XMB(3.9,144657,2,4788,0)=" I +$$BUFFER^IBCNBU1(DFN) S II=II+1,VALMHDR(II)=""*** Patient has Insurance Buffer Records"""
^XMB(3.9,144657,2,4789,0)="""RTN"",""IBCNEQU"",41,0)"
^XMB(3.9,144657,2,4790,0)=" I $P($G(^DPT(DFN,.35)),U)'="""" S II=II+1,VALMHDR(II)=""*** Date of Death: ""_$$FMTE^XLFDT($P($G(^DPT(DFN,.35)),U)\1,""5Z"")"
^XMB(3.9,144657,2,4791,0)="""RTN"",""IBCNEQU"",42,0)"
^XMB(3.9,144657,2,4792,0)=" Q"
^XMB(3.9,144657,2,4793,0)="""RTN"",""IBCNEQU"",43,0)"
^XMB(3.9,144657,2,4794,0)=" ;"
^XMB(3.9,144657,2,4795,0)="""RTN"",""IBCNEQU"",44,0)"
^XMB(3.9,144657,2,4796,0)="HELP ; -- help code"
^XMB(3.9,144657,2,4797,0)="""RTN"",""IBCNEQU"",45,0)"
^XMB(3.9,144657,2,4798,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,4799,0)="""RTN"",""IBCNEQU"",46,0)"
^XMB(3.9,144657,2,4800,0)=" W @IOF"
^XMB(3.9,144657,2,4801,0)="""RTN"",""IBCNEQU"",47,0)"
^XMB(3.9,144657,2,4802,0)=" W !,""When requesting an Electronic Insurance Inquiry..."" ; IB*2*601/DM"
^XMB(3.9,144657,2,4803,0)="""RTN"",""IBCNEQU"",48,0)"
^XMB(3.9,144657,2,4804,0)=" W !,""This screen lists all eligible (non-Medicaid) Insurance policies for the"""
^XMB(3.9,144657,2,4805,0)="""RTN"",""IBCNEQU"",49,0)"
^XMB(3.9,144657,2,4806,0)=" W !,""patient. Selecting an entry here creates an Insurance Buffer entry with Source"""
^XMB(3.9,144657,2,4807,0)="""RTN"",""IBCNEQU"",50,0)"
^XMB(3.9,144657,2,4808,0)=" W !,""'eIV' and Override Freshness Flag 'Yes'. Setting this flag is designed to force"""
^XMB(3.9,144657,2,4809,0)="""RTN"",""IBCNEQU"",51,0)"
^XMB(3.9,144657,2,4810,0)=" W !,""the eIV extract to attempt to create an insurance inquiry based on this entry."""
^XMB(3.9,144657,2,4811,0)="""RTN"",""IBCNEQU"",52,0)"
^XMB(3.9,144657,2,4812,0)=" W !!,""Entries with an asterisk (*) preceding the Insurance Co name already exist in"""
^XMB(3.9,144657,2,4813,0)="""RTN"",""IBCNEQU"",53,0)"
^XMB(3.9,144657,2,4814,0)=" W !,""the Insurance Buffer with the exact same name, the exact same Group Number,"""
^XMB(3.9,144657,2,4815,0)="""RTN"",""IBCNEQU"",54,0)"
^XMB(3.9,144657,2,4816,0)=" W !,""and the Override Freshness Flag set to 'Yes'."""
^XMB(3.9,144657,2,4817,0)="""RTN"",""IBCNEQU"",55,0)"
^XMB(3.9,144657,2,4818,0)=" ; IB*2*601/DM"
^XMB(3.9,144657,2,4819,0)="""RTN"",""IBCNEQU"",56,0)"
^XMB(3.9,144657,2,4820,0)=" W !!,""When requesting a MBI lookup..."""
^XMB(3.9,144657,2,4821,0)="""RTN"",""IBCNEQU"",57,0)"
^XMB(3.9,144657,2,4822,0)=" W !,""Policies will be listed as described above for electronic insurance inquiry;"""
^XMB(3.9,144657,2,4823,0)="""RTN"",""IBCNEQU"",58,0)"
^XMB(3.9,144657,2,4824,0)=" W !,""however, no special 'checks' will be made. The MBI request will be initiated """
^XMB(3.9,144657,2,4825,0)="""RTN"",""IBCNEQU"",59,0)"
^XMB(3.9,144657,2,4826,0)=" W !,""immediately, regardless of policies above and resulting buffer entry will have"""
^XMB(3.9,144657,2,4827,0)="""RTN"",""IBCNEQU"",60,0)"
^XMB(3.9,144657,2,4828,0)=" W !,""source 'Medicare'."""
^XMB(3.9,144657,2,4829,0)="""RTN"",""IBCNEQU"",61,0)"
^XMB(3.9,144657,2,4830,0)=" ; IB*2*702/TAZ - Added following lines"
^XMB(3.9,144657,2,4831,0)="""RTN"",""IBCNEQU"",62,0)"
^XMB(3.9,144657,2,4832,0)=" W !!,""When initiating an EICD Request..."""
^XMB(3.9,144657,2,4833,0)="""RTN"",""IBCNEQU"",63,0)"
^XMB(3.9,144657,2,4834,0)=" W !,""An EICD request will be initiated if the following conditions are met:"""
^XMB(3.9,144657,2,4835,0)="""RTN"",""IBCNEQU"",64,0)"
^XMB(3.9,144657,2,4836,0)=" W !,"" - The patient does not have active insurance on file."""
^XMB(3.9,144657,2,4837,0)="""RTN"",""IBCNEQU"",65,0)"
^XMB(3.9,144657,2,4838,0)=" W !,"" - The patient does not have an eligibility exclusion."""
^XMB(3.9,144657,2,4839,0)="""RTN"",""IBCNEQU"",66,0)"
^XMB(3.9,144657,2,4840,0)=" W !,"" - There have been no other recent EICD requests."""
^XMB(3.9,144657,2,4841,0)="""RTN"",""IBCNEQU"",67,0)"
^XMB(3.9,144657,2,4842,0)=" W !"
^XMB(3.9,144657,2,4843,0)="""RTN"",""IBCNEQU"",68,0)"
^XMB(3.9,144657,2,4844,0)=" ;"
^XMB(3.9,144657,2,4845,0)="""RTN"",""IBCNEQU"",69,0)"
^XMB(3.9,144657,2,4846,0)=" S VALMBCK=""R"""
^XMB(3.9,144657,2,4847,0)="""RTN"",""IBCNEQU"",70,0)"
^XMB(3.9,144657,2,4848,0)=" Q"
^XMB(3.9,144657,2,4849,0)="""RTN"",""IBCNEQU"",71,0)"
^XMB(3.9,144657,2,4850,0)=" ;"
^XMB(3.9,144657,2,4851,0)="""RTN"",""IBCNEQU"",72,0)"
^XMB(3.9,144657,2,4852,0)="EXIT ; -- exit code"
^XMB(3.9,144657,2,4853,0)="""RTN"",""IBCNEQU"",73,0)"
^XMB(3.9,144657,2,4854,0)=" K ^TMP(""IBCNEQU"",$J),^TMP(""IBCNEQUX"",$J)"
^XMB(3.9,144657,2,4855,0)="""RTN"",""IBCNEQU"",74,0)"
^XMB(3.9,144657,2,4856,0)=" Q"
^XMB(3.9,144657,2,4857,0)="""RTN"",""IBCNEQU"",75,0)"
^XMB(3.9,144657,2,4858,0)=" ;"
^XMB(3.9,144657,2,4859,0)="""RTN"",""IBCNEQU"",76,0)"
^XMB(3.9,144657,2,4860,0)="PAT() ; Prompt user to select a patient"
^XMB(3.9,144657,2,4861,0)="""RTN"",""IBCNEQU"",77,0)"
^XMB(3.9,144657,2,4862,0)=" ; Init vars"
^XMB(3.9,144657,2,4863,0)="""RTN"",""IBCNEQU"",78,0)"
^XMB(3.9,144657,2,4864,0)=" N DIC,X,Y,DISYS,%H,%I,DUOUT,DTOUT"
^XMB(3.9,144657,2,4865,0)="""RTN"",""IBCNEQU"",79,0)"
^XMB(3.9,144657,2,4866,0)=" ;"
^XMB(3.9,144657,2,4867,0)="""RTN"",""IBCNEQU"",80,0)"
^XMB(3.9,144657,2,4868,0)=" W !"
^XMB(3.9,144657,2,4869,0)="""RTN"",""IBCNEQU"",81,0)"
^XMB(3.9,144657,2,4870,0)=" ; Exclude non-Veterans"
^XMB(3.9,144657,2,4871,0)="""RTN"",""IBCNEQU"",82,0)"
^XMB(3.9,144657,2,4872,0)=" S DIC(0)=""AEQMN"""
^XMB(3.9,144657,2,4873,0)="""RTN"",""IBCNEQU"",83,0)"
^XMB(3.9,144657,2,4874,0)=" S DIC(""S"")=""I $G(^(""""VET""""))=""""Y"""",('$P($G(^(0)),U,21))"",DIC=""^DPT("""
^XMB(3.9,144657,2,4875,0)="""RTN"",""IBCNEQU"",84,0)"
^XMB(3.9,144657,2,4876,0)=" D ^DIC"
^XMB(3.9,144657,2,4877,0)="""RTN"",""IBCNEQU"",85,0)"
^XMB(3.9,144657,2,4878,0)=" I $D(DUOUT)!$D(DTOUT)!(Y<1) Q """""
^XMB(3.9,144657,2,4879,0)="""RTN"",""IBCNEQU"",86,0)"
^XMB(3.9,144657,2,4880,0)=" ;"
^XMB(3.9,144657,2,4881,0)="""RTN"",""IBCNEQU"",87,0)"
^XMB(3.9,144657,2,4882,0)=" Q +Y"
^XMB(3.9,144657,2,4883,0)="""RTN"",""IBCNEQU"",88,0)"
^XMB(3.9,144657,2,4884,0)=" ;"
^XMB(3.9,144657,2,4885,0)="""RTN"",""IBCNEQU"",89,0)"
^XMB(3.9,144657,2,4886,0)="BLD(DFN) ; Build list of all insurance for patient"
^XMB(3.9,144657,2,4887,0)="""RTN"",""IBCNEQU"",90,0)"
^XMB(3.9,144657,2,4888,0)=" N IBCT,IBINS,IBDATA0,IBDATA1,IBDATA2,II,STR,IBINSIEN,IBINAME,IBHOLD"
^XMB(3.9,144657,2,4889,0)="""RTN"",""IBCNEQU"",91,0)"
^XMB(3.9,144657,2,4890,0)=" N VNODT,X,POP,IBBUF,IBBUFNM,IBIEN,IBBUFDT,TMPNM,GRPNUM,SFANAME"
^XMB(3.9,144657,2,4891,0)="""RTN"",""IBCNEQU"",92,0)"
^XMB(3.9,144657,2,4892,0)=" ;"
^XMB(3.9,144657,2,4893,0)="""RTN"",""IBCNEQU"",93,0)"
^XMB(3.9,144657,2,4894,0)=" K ^TMP(""IBCNEQU"",$J),^TMP(""IBCNEQUX"",$J)"
^XMB(3.9,144657,2,4895,0)="""RTN"",""IBCNEQU"",94,0)"
^XMB(3.9,144657,2,4896,0)=" ;"
^XMB(3.9,144657,2,4897,0)="""RTN"",""IBCNEQU"",95,0)"
^XMB(3.9,144657,2,4898,0)=" S (IBCT,VALMCNT)=0"
^XMB(3.9,144657,2,4899,0)="""RTN"",""IBCNEQU"",96,0)"
^XMB(3.9,144657,2,4900,0)=" ;"
^XMB(3.9,144657,2,4901,0)="""RTN"",""IBCNEQU"",97,0)"
^XMB(3.9,144657,2,4902,0)=" ; Determine if buffer entries exist for this DFN and build array by name"
^XMB(3.9,144657,2,4903,0)="""RTN"",""IBCNEQU"",98,0)"
^XMB(3.9,144657,2,4904,0)=" S IBIEN=0"
^XMB(3.9,144657,2,4905,0)="""RTN"",""IBCNEQU"",99,0)"
^XMB(3.9,144657,2,4906,0)=" F  S IBIEN=$O(^IBA(355.33,""C"",DFN,IBIEN)) Q:'IBIEN  D"
^XMB(3.9,144657,2,4907,0)="""RTN"",""IBCNEQU"",100,0)"
^XMB(3.9,144657,2,4908,0)=" . S IBBUFDT=$G(^IBA(355.33,IBIEN,0))"
^XMB(3.9,144657,2,4909,0)="""RTN"",""IBCNEQU"",101,0)"
^XMB(3.9,144657,2,4910,0)=" . ; Include E status only"
^XMB(3.9,144657,2,4911,0)="""RTN"",""IBCNEQU"",102,0)"
^XMB(3.9,144657,2,4912,0)=" . I $P(IBBUFDT,U,4)'=""E"" Q"
^XMB(3.9,144657,2,4913,0)="""RTN"",""IBCNEQU"",103,0)"
^XMB(3.9,144657,2,4914,0)=" . S IBBUFNM=$$TRIM^XLFSTR($P($G(^IBA(355.33,IBIEN,20)),U))"
^XMB(3.9,144657,2,4915,0)="""RTN"",""IBCNEQU"",104,0)"
^XMB(3.9,144657,2,4916,0)=" . I IBBUFNM="""" Q"
^XMB(3.9,144657,2,4917,0)="""RTN"",""IBCNEQU"",105,0)"
^XMB(3.9,144657,2,4918,0)=" . ;S GRPNUM=$$TRIM^XLFSTR($P($G(^IBA(355.33,IBIEN,40)),U,3))"
^XMB(3.9,144657,2,4919,0)="""RTN"",""IBCNEQU"",106,0)"
^XMB(3.9,144657,2,4920,0)=" . S GRPNUM=$$TRIM^XLFSTR($P($G(^IBA(355.33,IBIEN,90)),U,2))  ; ib*2*497  get group number from it's new location"
^XMB(3.9,144657,2,4921,0)="""RTN"",""IBCNEQU"",107,0)"
^XMB(3.9,144657,2,4922,0)=" . S IBBUF(IBBUFNM,"" ""_GRPNUM)="""""
^XMB(3.9,144657,2,4923,0)="""RTN"",""IBCNEQU"",108,0)"
^XMB(3.9,144657,2,4924,0)=" . Q"
^XMB(3.9,144657,2,4925,0)="""RTN"",""IBCNEQU"",109,0)"
^XMB(3.9,144657,2,4926,0)=" ;"
^XMB(3.9,144657,2,4927,0)="""RTN"",""IBCNEQU"",110,0)"
^XMB(3.9,144657,2,4928,0)=" ; Populate IBINS array with Patient Insurance records"
^XMB(3.9,144657,2,4929,0)="""RTN"",""IBCNEQU"",111,0)"
^XMB(3.9,144657,2,4930,0)=" D ALL^IBCNS1(DFN,""IBINS"")"
^XMB(3.9,144657,2,4931,0)="""RTN"",""IBCNEQU"",112,0)"
^XMB(3.9,144657,2,4932,0)=" I $G(IBINS(0)) S II=0 F  S II=$O(IBINS(II)) Q:'II  D"
^XMB(3.9,144657,2,4933,0)="""RTN"",""IBCNEQU"",113,0)"
^XMB(3.9,144657,2,4934,0)=" . S IBDATA0=$G(IBINS(II,0))"
^XMB(3.9,144657,2,4935,0)="""RTN"",""IBCNEQU"",114,0)"
^XMB(3.9,144657,2,4936,0)=" . S IBDATA1=$G(IBINS(II,1))"
^XMB(3.9,144657,2,4937,0)="""RTN"",""IBCNEQU"",115,0)"
^XMB(3.9,144657,2,4938,0)=" . S IBDATA2=$G(^IBA(355.3,+$P(IBDATA0,U,18),0))"
^XMB(3.9,144657,2,4939,0)="""RTN"",""IBCNEQU"",116,0)"
^XMB(3.9,144657,2,4940,0)=" . S GRPNUM=$$TRIM^XLFSTR($P($G(^IBA(355.3,+$P(IBDATA0,U,18),2)),U,2))  ; ib*2*497  get group number from it's new location"
^XMB(3.9,144657,2,4941,0)="""RTN"",""IBCNEQU"",117,0)"
^XMB(3.9,144657,2,4942,0)=" . ;S GRPNUM=$$TRIM^XLFSTR($P(GRPNUM,U,2))"
^XMB(3.9,144657,2,4943,0)="""RTN"",""IBCNEQU"",118,0)"
^XMB(3.9,144657,2,4944,0)=" . ;S GRPNUM=$$TRIM^XLFSTR($P(IBDATA2,U,4))"
^XMB(3.9,144657,2,4945,0)="""RTN"",""IBCNEQU"",119,0)"
^XMB(3.9,144657,2,4946,0)=" . S IBINSIEN=+$P(IBDATA0,U)"
^XMB(3.9,144657,2,4947,0)="""RTN"",""IBCNEQU"",120,0)"
^XMB(3.9,144657,2,4948,0)=" . Q:'IBINSIEN!'$D(^DIC(36,IBINSIEN,0))"
^XMB(3.9,144657,2,4949,0)="""RTN"",""IBCNEQU"",121,0)"
^XMB(3.9,144657,2,4950,0)=" . S IBINAME=$P($G(^DIC(36,IBINSIEN,0)),U)"
^XMB(3.9,144657,2,4951,0)="""RTN"",""IBCNEQU"",122,0)"
^XMB(3.9,144657,2,4952,0)=" . S TMPNM=$$TRIM^XLFSTR(IBINAME)"
^XMB(3.9,144657,2,4953,0)="""RTN"",""IBCNEQU"",123,0)"
^XMB(3.9,144657,2,4954,0)=" . ; Filter Ins Co's by name - currently filter Medicaid"
^XMB(3.9,144657,2,4955,0)="""RTN"",""IBCNEQU"",124,0)"
^XMB(3.9,144657,2,4956,0)=" . I $$EXCLUDE^IBCNEUT4(TMPNM) Q"
^XMB(3.9,144657,2,4957,0)="""RTN"",""IBCNEQU"",125,0)"
^XMB(3.9,144657,2,4958,0)=" . S IBCT=IBCT+1"
^XMB(3.9,144657,2,4959,0)="""RTN"",""IBCNEQU"",126,0)"
^XMB(3.9,144657,2,4960,0)=" . S STR="""""
^XMB(3.9,144657,2,4961,0)="""RTN"",""IBCNEQU"",127,0)"
^XMB(3.9,144657,2,4962,0)=" . S STR=$$SETFLD^VALM1(IBCT,STR,""NUMBER"")"
^XMB(3.9,144657,2,4963,0)="""RTN"",""IBCNEQU"",128,0)"
^XMB(3.9,144657,2,4964,0)=" . ; Update IBINAME if found in buffer already"
^XMB(3.9,144657,2,4965,0)="""RTN"",""IBCNEQU"",129,0)"
^XMB(3.9,144657,2,4966,0)=" . S IBINAME=$S($D(IBBUF(TMPNM,"" ""_GRPNUM)):""*"",1:"""")_IBINAME"
^XMB(3.9,144657,2,4967,0)="""RTN"",""IBCNEQU"",130,0)"
^XMB(3.9,144657,2,4968,0)=" . S STR=$$SETFLD^VALM1(IBINAME,STR,""NAME"")"
^XMB(3.9,144657,2,4969,0)="""RTN"",""IBCNEQU"",131,0)"
^XMB(3.9,144657,2,4970,0)=" . S STR=$$SETFLD^VALM1($E($P(IBDATA0,U,2),1,14),STR,""POLICY"")"
^XMB(3.9,144657,2,4971,0)="""RTN"",""IBCNEQU"",132,0)"
^XMB(3.9,144657,2,4972,0)=" . S IBHOLD=$P(IBDATA0,U,6),STR=$$SETFLD^VALM1($S(IBHOLD=""v"":""SELF"",IBHOLD=""s"":""SPOUSE"",IBHOLD=""o"":""OTHER"",1:""UNKNOWN""),STR,""HOLDER"")"
^XMB(3.9,144657,2,4973,0)="""RTN"",""IBCNEQU"",133,0)"
^XMB(3.9,144657,2,4974,0)=" . S STR=$$SETFLD^VALM1($E($$GRP^IBCNS($P(IBDATA0,U,18)),1,10),STR,""GROUP"")"
^XMB(3.9,144657,2,4975,0)="""RTN"",""IBCNEQU"",134,0)"
^XMB(3.9,144657,2,4976,0)=" . S STR=$$SETFLD^VALM1($$FMTE^XLFDT($P(IBDATA0,U,8),""5Z""),STR,""EFFDT"")"
^XMB(3.9,144657,2,4977,0)="""RTN"",""IBCNEQU"",135,0)"
^XMB(3.9,144657,2,4978,0)=" . S STR=$$SETFLD^VALM1($$FMTE^XLFDT($P(IBDATA0,U,4),""5Z""),STR,""EXPIRE"")"
^XMB(3.9,144657,2,4979,0)="""RTN"",""IBCNEQU"",136,0)"
