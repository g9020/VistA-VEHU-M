^XMB(3.9,145836,2,592,0)=" .. W ?50,""Qty/Days Supply: ""_$G(^TMP($J,""GMTSPST1"",DFN,+PACKREF,12))_""/""_$G(^TMP($J,""GMTSPST1"",DFN,+PACKREF,101))"
