^XMB(3.9,144654,2,331,0)="""RTN"",""PSOHLDS2"",46,0)"
^XMB(3.9,144654,2,332,0)=" Q"
^XMB(3.9,144654,2,333,0)="""RTN"",""PSOHLDS2"",47,0)"
^XMB(3.9,144654,2,334,0)="RXR(PSI) ;pharmacy route segment"
^XMB(3.9,144654,2,335,0)="""RTN"",""PSOHLDS2"",48,0)"
^XMB(3.9,144654,2,336,0)=" Q:'$D(DFN)  N RXR S (PSROUTE,RTNAME)="""""""""""""
^XMB(3.9,144654,2,337,0)="""RTN"",""PSOHLDS2"",49,0)"
^XMB(3.9,144654,2,338,0)=" F PSRTLP=0:0 S PSRTLP=$O(^PSRX(IRXN,6,PSRTLP)) Q:'PSRTLP  D"
^XMB(3.9,144654,2,339,0)="""RTN"",""PSOHLDS2"",50,0)"
^XMB(3.9,144654,2,340,0)=" .S PSROUTE=$P($G(^PSRX(IRXN,6,PSRTLP,0)),""^"",7)"
^XMB(3.9,144654,2,341,0)="""RTN"",""PSOHLDS2"",51,0)"
^XMB(3.9,144654,2,342,0)=" .I PSROUTE,$D(^PS(51.2,PSROUTE,0))  S RTNAME=$P(^PS(51.2,PSROUTE,0),""^"")"
^XMB(3.9,144654,2,343,0)="""RTN"",""PSOHLDS2"",52,0)"
^XMB(3.9,144654,2,344,0)=" I RTNAME="""" K PSROUTE,RTNAME,PSRTLP Q"
^XMB(3.9,144654,2,345,0)="""RTN"",""PSOHLDS2"",53,0)"
^XMB(3.9,144654,2,346,0)=" S RXR=""RXR""_FS_$G(PSROUTE)_CS_$G(RTNAME)_CS_""99PSR""_FS_FS_FS_FS"
