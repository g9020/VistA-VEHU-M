^XMB(3.9,144657,2,1009,0)="""RTN"",""IBCNBAA"",208,0)"
^XMB(3.9,144657,2,1010,0)=" S DIR(""?"")=""^D HELP^IBCNBUH,WAIT^IBCNBAA""_"",""_""SBDISP^IBCNBCD4(IBBUFDA,DFN,IBPOLDA,IBSEL,IBRIEN,IBSIEN,.IBFNAM,IBVAL,.IBHOLD,.IBXHOLD)"""
^XMB(3.9,144657,2,1011,0)="""RTN"",""IBCNBAA"",209,0)"
^XMB(3.9,144657,2,1012,0)=" S DIR(""??"")=""^D HELP2^IBCNBUH,WAIT^IBCNBAA""_"",""_""SBDISP^IBCNBCD4(IBBUFDA,DFN,IBPOLDA,IBSEL,IBRIEN,IBSIEN,.IBFNAM,IBVAL,.IBHOLD,.IBXHOLD)"""
^XMB(3.9,144657,2,1013,0)="""RTN"",""IBCNBAA"",210,0)"
^XMB(3.9,144657,2,1014,0)=" S DIR(""A"")=""Select the method to update the ""_IBDESC"
^XMB(3.9,144657,2,1015,0)="""RTN"",""IBCNBAA"",211,0)"
^XMB(3.9,144657,2,1016,0)=" ; DAOU/BHS - 08/28/2002 - Added INDIVIDUALLY ACCEPT methods"
^XMB(3.9,144657,2,1017,0)="""RTN"",""IBCNBAA"",212,0)"
^XMB(3.9,144657,2,1018,0)=" W ! S DIR(0)=""SOB^M:MERGE;O:OVERWRITE;R:REPLACE;N:NO CHANGE;I:INDIVIDUALLY ACCEPT (SKIP BLANKS)"" D ^DIR"
^XMB(3.9,144657,2,1019,0)="""RTN"",""IBCNBAA"",213,0)"
^XMB(3.9,144657,2,1020,0)=" S IBX=$S(Y=""M"":1,Y=""O"":2,Y=""R"":3,Y=""I"":4,Y=""N"":0,1:"""") I IBX'="""" S IBX=IBX_U_$G(Y(0))_$S(+IBX=1:"" with"",1:"""")"
^XMB(3.9,144657,2,1021,0)="""RTN"",""IBCNBAA"",214,0)"
^XMB(3.9,144657,2,1022,0)=" Q IBX"
^XMB(3.9,144657,2,1023,0)="""RTN"",""IBCNBAA"",215,0)"
^XMB(3.9,144657,2,1024,0)=" ;"
^XMB(3.9,144657,2,1025,0)="""RTN"",""IBCNBAA"",216,0)"
^XMB(3.9,144657,2,1026,0)="NEW(IBDESC) ; ask user if they want to add a new entry to the insurance files (36, 355.3, or 2.312)"
^XMB(3.9,144657,2,1027,0)="""RTN"",""IBCNBAA"",217,0)"
^XMB(3.9,144657,2,1028,0)=" ; returns 1 if Yes create a new entry, 0 otherwise"
^XMB(3.9,144657,2,1029,0)="""RTN"",""IBCNBAA"",218,0)"
^XMB(3.9,144657,2,1030,0)=" N DIR,X,Y,IBX S IBX=0"
^XMB(3.9,144657,2,1031,0)="""RTN"",""IBCNBAA"",219,0)"
^XMB(3.9,144657,2,1032,0)=" ;"
^XMB(3.9,144657,2,1033,0)="""RTN"",""IBCNBAA"",220,0)"
^XMB(3.9,144657,2,1034,0)=" ; The following was changed with patch IB*2.0*506"
^XMB(3.9,144657,2,1035,0)="""RTN"",""IBCNBAA"",221,0)"
^XMB(3.9,144657,2,1036,0)=" S DIR(""?"")=""Enter Yes to create a new ""_IBDESC_"". Enter No to stop this process."""
^XMB(3.9,144657,2,1037,0)="""RTN"",""IBCNBAA"",222,0)"
^XMB(3.9,144657,2,1038,0)=" S DIR(""?"",1)=""Enter Yes to create a new ""_IBDESC_"" in the Insurance files for"""
^XMB(3.9,144657,2,1039,0)="""RTN"",""IBCNBAA"",223,0)"
^XMB(3.9,144657,2,1040,0)=" S DIR(""?"",2)=""this Buffer entry only if no existing ""_IBDESC_"" could be found"""
^XMB(3.9,144657,2,1041,0)="""RTN"",""IBCNBAA"",224,0)"
^XMB(3.9,144657,2,1042,0)=" S DIR(""?"",3)=""that matches this buffer entry."",DIR(""?"",4)="""""
^XMB(3.9,144657,2,1043,0)="""RTN"",""IBCNBAA"",225,0)"
^XMB(3.9,144657,2,1044,0)=" W ! S DIR(0)=""YO"",DIR(""A"")=""NO ""_IBDESC_"" Selected, do you need a New ""_IBDESC D ^DIR I +Y=1 S IBX=1"
^XMB(3.9,144657,2,1045,0)="""RTN"",""IBCNBAA"",226,0)"
^XMB(3.9,144657,2,1046,0)=" ;"
^XMB(3.9,144657,2,1047,0)="""RTN"",""IBCNBAA"",227,0)"
^XMB(3.9,144657,2,1048,0)=" ;I IBDESC=""INSURANCE COMPANY"",'$D(^XUSEC(""IB INSURANCE COMPANY ADD"",DUZ)) W !!,""Sorry, but you do not have the required privileges to add"",!,""new Insurance Companies."" D WAIT G NEWQ"
^XMB(3.9,144657,2,1049,0)="""RTN"",""IBCNBAA"",228,0)"
^XMB(3.9,144657,2,1050,0)=" I IBX=1 D  G NEWQ"
^XMB(3.9,144657,2,1051,0)="""RTN"",""IBCNBAA"",229,0)"
^XMB(3.9,144657,2,1052,0)=" . I IBDESC=""INSURANCE COMPANY"" D  Q"
^XMB(3.9,144657,2,1053,0)="""RTN"",""IBCNBAA"",230,0)"
^XMB(3.9,144657,2,1054,0)=" . . I '$D(^XUSEC(""IB INSURANCE COMPANY EDIT"",DUZ)) W !!,""A Supervisor will need to add the ""_IBDESC_"" before processing can"",!,""continue."" S IBX=0 D WAIT Q"
^XMB(3.9,144657,2,1055,0)="""RTN"",""IBCNBAA"",231,0)"
^XMB(3.9,144657,2,1056,0)=" . . W !!,""You must create an ""_IBDESC_"" first."" S IBX=0 D WAIT"
^XMB(3.9,144657,2,1057,0)="""RTN"",""IBCNBAA"",232,0)"
^XMB(3.9,144657,2,1058,0)=" . I IBDESC=""GROUP/PLAN"" D  Q"
^XMB(3.9,144657,2,1059,0)="""RTN"",""IBCNBAA"",233,0)"
^XMB(3.9,144657,2,1060,0)=" . . I '$D(^XUSEC(""IB GROUP PLAN EDIT"",DUZ)) W !!,""A Supervisor will need to add the ""_IBDESC_"" before processing can continue."" S IBX=0 D WAIT Q"
^XMB(3.9,144657,2,1061,0)="""RTN"",""IBCNBAA"",234,0)"
^XMB(3.9,144657,2,1062,0)=" . . W !!,""You must create a ""_IBDESC_"" first."" S IBX=0 D WAIT"
^XMB(3.9,144657,2,1063,0)="""RTN"",""IBCNBAA"",235,0)"
^XMB(3.9,144657,2,1064,0)=" ;/IB*2.0*506 End"
^XMB(3.9,144657,2,1065,0)="""RTN"",""IBCNBAA"",236,0)"
^XMB(3.9,144657,2,1066,0)="NEWQ Q IBX"
