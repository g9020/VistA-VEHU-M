^XMB(3.9,145834,2,6535,0)="""RTN"",""MAGDSTAS"",157,0)"
^XMB(3.9,145834,2,6536,0)=" . S HDATE1=$$FMTH^XLFDT(BEGDATE)"
^XMB(3.9,145834,2,6537,0)="""RTN"",""MAGDSTAS"",158,0)"
^XMB(3.9,145834,2,6538,0)=" . S HDATE2=$$FMTH^XLFDT(ENDDATE)"
