^XMB(3.9,145837,2,490,0)=" S:$G(XQA1)="""" XQA1=""NO-ID"" F  S XQAID=XQA1_"";""_DUZ_"";""_XQI L +^XTV(8992,""AXQA"",XQAID):10 D  L -^XTV(8992,""AXQA"",XQAID) Q:XQI=""""  S XQI=XQI+.00000001"
^XMB(3.9,145837,2,491,0)="""RTN"",""XQALSET"",126,0)"
^XMB(3.9,145837,2,492,0)=" . I $D(^XTV(8992,""AXQA"",XQAID)) Q"
^XMB(3.9,145837,2,493,0)="""RTN"",""XQALSET"",127,0)"
^XMB(3.9,145837,2,494,0)=" . S ^XTV(8992,""AXQA"",XQAID,0,0)="""",XQI="""""
^XMB(3.9,145837,2,495,0)="""RTN"",""XQALSET"",128,0)"
