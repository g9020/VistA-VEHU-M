^XMB(3.9,145834,2,815,0)="""RTN"",""MAGBRTE4"",82,0)"
^XMB(3.9,145834,2,816,0)=" . . ;D DQUE^MAGQBUT2(QPTR)  ; replaced with line below p196"
^XMB(3.9,145834,2,817,0)="""RTN"",""MAGBRTE4"",83,0)"
