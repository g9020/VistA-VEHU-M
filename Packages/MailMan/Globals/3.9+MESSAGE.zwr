^XMB(3.9,145834,2,3337,0)="""RTN"",""MAGDSTA1"",345,0)"
^XMB(3.9,145834,2,3338,0)=" . . S ^TMP(""MAG"",$J,""BATCH Q/R"",""END DATE"")="""""
^XMB(3.9,145834,2,3339,0)="""RTN"",""MAGDSTA1"",346,0)"
^XMB(3.9,145834,2,3340,0)=" . . Q"
^XMB(3.9,145834,2,3341,0)="""RTN"",""MAGDSTA1"",347,0)"
^XMB(3.9,145834,2,3342,0)=" . E  D  ; DESCENDING -- set END DATE to the last date of the previous run"
^XMB(3.9,145834,2,3343,0)="""RTN"",""MAGDSTA1"",348,0)"
^XMB(3.9,145834,2,3344,0)=" . . I NORMALRUN S ^TMP(""MAG"",$J,""BATCH Q/R"",""END DATE"")=$$NEXTDATE(BEGDATE,DIRECTION)"
^XMB(3.9,145834,2,3345,0)="""RTN"",""MAGDSTA1"",349,0)"
^XMB(3.9,145834,2,3346,0)=" . . E  S ^TMP(""MAG"",$J,""BATCH Q/R"",""END DATE"")=STUDYDATE\1"
^XMB(3.9,145834,2,3347,0)="""RTN"",""MAGDSTA1"",350,0)"
^XMB(3.9,145834,2,3348,0)=" . . S ^TMP(""MAG"",$J,""BATCH Q/R"",""BEGIN DATE"")="""""
^XMB(3.9,145834,2,3349,0)="""RTN"",""MAGDSTA1"",351,0)"
^XMB(3.9,145834,2,3350,0)=" . . Q"
^XMB(3.9,145834,2,3351,0)="""RTN"",""MAGDSTA1"",352,0)"
^XMB(3.9,145834,2,3352,0)=" . Q"
^XMB(3.9,145834,2,3353,0)="""RTN"",""MAGDSTA1"",353,0)"
^XMB(3.9,145834,2,3354,0)=" E  I SCANMODE=""NUMBER"" D"
^XMB(3.9,145834,2,3355,0)="""RTN"",""MAGDSTA1"",354,0)"
^XMB(3.9,145834,2,3356,0)=" . ; set REPORT/STUDY IEN to the last IEN of the previous run"
^XMB(3.9,145834,2,3357,0)="""RTN"",""MAGDSTA1"",355,0)"
^XMB(3.9,145834,2,3358,0)=" . S ^TMP(""MAG"",$J,""BATCH Q/R"",""REPORT/STUDY IEN"")=(STUDYIEN+DIRECTION)"
^XMB(3.9,145834,2,3359,0)="""RTN"",""MAGDSTA1"",356,0)"
^XMB(3.9,145834,2,3360,0)=" . S ^TMP(""MAG"",$J,""BATCH Q/R"",""BATCH SIZE"")=BATCHSIZE"
^XMB(3.9,145834,2,3361,0)="""RTN"",""MAGDSTA1"",357,0)"
^XMB(3.9,145834,2,3362,0)=" . Q"
^XMB(3.9,145834,2,3363,0)="""RTN"",""MAGDSTA1"",358,0)"
^XMB(3.9,145834,2,3364,0)=" ;"
^XMB(3.9,145834,2,3365,0)="""RTN"",""MAGDSTA1"",359,0)"
^XMB(3.9,145834,2,3366,0)=" ; get consult services"
^XMB(3.9,145834,2,3367,0)="""RTN"",""MAGDSTA1"",360,0)"
^XMB(3.9,145834,2,3368,0)=" M ^TMP(""MAG"",$J,""BATCH Q/R"",""CONSULT SERVICES"")=CONSULTSERVICES"
^XMB(3.9,145834,2,3369,0)="""RTN"",""MAGDSTA1"",361,0)"
^XMB(3.9,145834,2,3370,0)=" Q"
^XMB(3.9,145834,2,3371,0)="""RTN"",""MAGDSTA1"",362,0)"
^XMB(3.9,145834,2,3372,0)=" ;"
^XMB(3.9,145834,2,3373,0)="""RTN"",""MAGDSTA1"",363,0)"
^XMB(3.9,145834,2,3374,0)="NEXTDATE(DATE,DIRECTION) ; get the next date, but not in the future"
^XMB(3.9,145834,2,3375,0)="""RTN"",""MAGDSTA1"",364,0)"
^XMB(3.9,145834,2,3376,0)=" N NEXTDATE,NOW"
^XMB(3.9,145834,2,3377,0)="""RTN"",""MAGDSTA1"",365,0)"
^XMB(3.9,145834,2,3378,0)=" S NOW=$$NOW^XLFDT\1"
^XMB(3.9,145834,2,3379,0)="""RTN"",""MAGDSTA1"",366,0)"
^XMB(3.9,145834,2,3380,0)=" S NEXTDATE=$$FMADD^XLFDT(DATE\1,DIRECTION)"
^XMB(3.9,145834,2,3381,0)="""RTN"",""MAGDSTA1"",367,0)"
^XMB(3.9,145834,2,3382,0)=" I NEXTDATE>NOW S NEXTDATE=NOW ; no future dates"
^XMB(3.9,145834,2,3383,0)="""RTN"",""MAGDSTA1"",368,0)"
^XMB(3.9,145834,2,3384,0)=" Q NEXTDATE"
^XMB(3.9,145834,2,3385,0)="""RTN"",""MAGDSTA2"")"
^XMB(3.9,145834,2,3386,0)="0^16^B85486784"
^XMB(3.9,145834,2,3387,0)="""RTN"",""MAGDSTA2"",1,0)"
^XMB(3.9,145834,2,3388,0)="MAGDSTA2 ;WOIFO/PMK - Q/R Retrieve of DICOM images from PACS to VistA ; Aug 19, 2020@16:04:13"
^XMB(3.9,145834,2,3389,0)="""RTN"",""MAGDSTA2"",2,0)"
^XMB(3.9,145834,2,3390,0)=" ;;3.0;IMAGING;**231**;MAR 19, 2002;Build 0;Feb 27, 2015"
^XMB(3.9,145834,2,3391,0)="""RTN"",""MAGDSTA2"",3,0)"
^XMB(3.9,145834,2,3392,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,3393,0)="""RTN"",""MAGDSTA2"",4,0)"
^XMB(3.9,145834,2,3394,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,3395,0)="""RTN"",""MAGDSTA2"",5,0)"
^XMB(3.9,145834,2,3396,0)=" ;; | Property of the US Government.                                |"
