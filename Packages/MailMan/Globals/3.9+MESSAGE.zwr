^XMB(3.9,144657,2,985,0)="""RTN"",""IBCNBAA"",196,0)"
^XMB(3.9,144657,2,986,0)=" S DIR(""?"")=""^D HELP^IBCNBUH,WAIT^IBCNBAA""_$G(IBHELP),DIR(""??"")=""^D HELP2^IBCNBUH,WAIT^IBCNBAA""_$G(IBHELP)"
^XMB(3.9,144657,2,987,0)="""RTN"",""IBCNBAA"",197,0)"
^XMB(3.9,144657,2,988,0)=" S DIR(""A"")=""Select the method to update the ""_IBDESC"
