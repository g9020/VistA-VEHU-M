^XMB(3.9,145834,2,7305,0)="""RTN"",""MAGDSTQ8"",155,0)"
^XMB(3.9,145834,2,7306,0)=" . S MEANING=""Error: Data Set does not match SOP Class"""
^XMB(3.9,145834,2,7307,0)="""RTN"",""MAGDSTQ8"",156,0)"
