^XMB(3.9,145834,2,2941,0)="""RTN"",""MAGDSTA1"",147,0)"
^XMB(3.9,145834,2,2942,0)=" . Q"
^XMB(3.9,145834,2,2943,0)="""RTN"",""MAGDSTA1"",148,0)"
^XMB(3.9,145834,2,2944,0)=" I X<0 W !,""Exiting"" Q"
^XMB(3.9,145834,2,2945,0)="""RTN"",""MAGDSTA1"",149,0)"
^XMB(3.9,145834,2,2946,0)=" ;"
^XMB(3.9,145834,2,2947,0)="""RTN"",""MAGDSTA1"",150,0)"
^XMB(3.9,145834,2,2948,0)=" I SCANMODE=""NUMBER"" D"
^XMB(3.9,145834,2,2949,0)="""RTN"",""MAGDSTA1"",151,0)"
^XMB(3.9,145834,2,2950,0)=" . S QUESTION=""SORTORDR^MAGDSTA2"""
^XMB(3.9,145834,2,2951,0)="""RTN"",""MAGDSTA1"",152,0)"
^XMB(3.9,145834,2,2952,0)=" . I IMAGINGSERVICE=""RADIOLOGY"" D"
^XMB(3.9,145834,2,2953,0)="""RTN"",""MAGDSTA1"",153,0)"
^XMB(3.9,145834,2,2954,0)=" . . S QUESTION=QUESTION_"" RARPT1^MAGDSTA4"""
^XMB(3.9,145834,2,2955,0)="""RTN"",""MAGDSTA1"",154,0)"
^XMB(3.9,145834,2,2956,0)=" . . Q"
^XMB(3.9,145834,2,2957,0)="""RTN"",""MAGDSTA1"",155,0)"
^XMB(3.9,145834,2,2958,0)=" . E  D  ; consults"
^XMB(3.9,145834,2,2959,0)="""RTN"",""MAGDSTA1"",156,0)"
^XMB(3.9,145834,2,2960,0)=" . . S QUESTION=QUESTION_"" STUDY1^MAGDSTA6"""
^XMB(3.9,145834,2,2961,0)="""RTN"",""MAGDSTA1"",157,0)"
