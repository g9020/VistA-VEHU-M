^XMB(3.9,144661,2,357,0)="""RTN"",""ORAM1"",59,0)"
^XMB(3.9,144661,2,358,0)=" Q"
^XMB(3.9,144661,2,359,0)="""RTN"",""ORAM1"",60,0)"
^XMB(3.9,144661,2,360,0)=" ;"
^XMB(3.9,144661,2,361,0)="""RTN"",""ORAM1"",61,0)"
^XMB(3.9,144661,2,362,0)="ACDATA(RESULT,DFN,ORAMEDT) ; HEADING DATA"
^XMB(3.9,144661,2,363,0)="""RTN"",""ORAM1"",62,0)"
