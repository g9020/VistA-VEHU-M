^XMB(3.9,145833,2,796,0)=" ;"
^XMB(3.9,145833,2,797,0)="""RTN"",""SDES2UTDT"",43,0)"
^XMB(3.9,145833,2,798,0)=" N SDFM,SDTIME,X,Y,%DT,POP,TMPFM,SDOFFSET,SDISOOFFSET,VALID,SDISOTIME,ISOOFFSET"
^XMB(3.9,145833,2,799,0)="""RTN"",""SDES2UTDT"",44,0)"
^XMB(3.9,145833,2,800,0)=" S (POP,SDOFFSET,TMPFM)="""""
^XMB(3.9,145833,2,801,0)="""RTN"",""SDES2UTDT"",45,0)"
^XMB(3.9,145833,2,802,0)=" I $G(SDGMTDT)="""" S SDFMDTM="""" Q"
^XMB(3.9,145833,2,803,0)="""RTN"",""SDES2UTDT"",46,0)"
^XMB(3.9,145833,2,804,0)=" ;pattern match date(/time) for correctness"
^XMB(3.9,145833,2,805,0)="""RTN"",""SDES2UTDT"",47,0)"
^XMB(3.9,145833,2,806,0)=" D VALIDISO(.VALID,SDGMTDT)"
