^XMB(3.9,144661,2,506,0)=" . S ORAMBRGL=$L(ORAMBRGC,""^""),^ORAM(103,DFN,7,0)=""^^""_ORAMBRGL_""^""_ORAMBRGL_""^""_ORAMDAY_""^"""
^XMB(3.9,144661,2,507,0)="""RTN"",""ORAM1"",134,0)"
^XMB(3.9,144661,2,508,0)=" . F R=1:1:ORAMBRGL S ^ORAM(103,DFN,7,R,0)=$P(ORAMBRGC,""^"",R)"
^XMB(3.9,144661,2,509,0)="""RTN"",""ORAM1"",135,0)"
^XMB(3.9,144661,2,510,0)=" I $P($G(ORAM0),""^"",4)'="""" S X="""",ORAMBACK=$P(ORAM0,""^"",4) D DT^DILF(""TS"",ORAMBACK,.X) S $P(ORAM0,""^"",4)=X"
