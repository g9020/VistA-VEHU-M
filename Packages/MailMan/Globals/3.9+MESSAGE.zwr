^XMB(3.9,145839,2,1035,0)="""RTN"",""TIUCCRHL7P4"",22,0)"
^XMB(3.9,145839,2,1036,0)=" .I ADDENDUM[""DISCHARGE DISPOSITION ADDENDUM"" D DISP^TIUCCRHL7P5,FORMAT  ;done"
^XMB(3.9,145839,2,1037,0)="""RTN"",""TIUCCRHL7P4"",23,0)"
^XMB(3.9,145839,2,1038,0)=" .I ADDENDUM[""DISEASE MANAGEMENT ADDENDUM"" D DMA^TIUCCRHL7P5,FORMAT  ;done"
^XMB(3.9,145839,2,1039,0)="""RTN"",""TIUCCRHL7P4"",24,0)"
^XMB(3.9,145839,2,1040,0)=" .I ADDENDUM[""PROVIDER CONTACT ADDENDUM"" D PCA^TIUCCRHL7P7,FORMAT  ;done"
^XMB(3.9,145839,2,1041,0)="""RTN"",""TIUCCRHL7P4"",25,0)"
^XMB(3.9,145839,2,1042,0)=" .I ADDENDUM[""TRANSFER ADDENDUM"" D TA^TIUCCRHL7P7,FORMAT  ;done"
^XMB(3.9,145839,2,1043,0)="""RTN"",""TIUCCRHL7P4"",26,0)"
^XMB(3.9,145839,2,1044,0)=" .I ADDENDUM[""VETERAN CONTACT ADDENDUM"" D VCA^TIUCCRHL7P7,FORMAT  ;done"
^XMB(3.9,145839,2,1045,0)="""RTN"",""TIUCCRHL7P4"",27,0)"
