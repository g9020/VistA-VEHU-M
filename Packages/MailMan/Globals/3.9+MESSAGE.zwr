^XMB(3.9,145834,2,4207,0)="""RTN"",""MAGDSTA5"",130,0)"
^XMB(3.9,145834,2,4208,0)=" . S MAGIEN=$G(^RARPT(RARPT1,2005,RARPT3,0))"
^XMB(3.9,145834,2,4209,0)="""RTN"",""MAGDSTA5"",131,0)"
^XMB(3.9,145834,2,4210,0)=" . S MAGIENLIST(MAGIEN)="""""
^XMB(3.9,145834,2,4211,0)="""RTN"",""MAGDSTA5"",132,0)"
^XMB(3.9,145834,2,4212,0)=" . Q"
^XMB(3.9,145834,2,4213,0)="""RTN"",""MAGDSTA5"",133,0)"
^XMB(3.9,145834,2,4214,0)=" Q $$LOOKUP^MAGDSTAA(DFN,EXAMDATE,RARPT1,ACNUMB,.MAGIENLIST)"
^XMB(3.9,145834,2,4215,0)="""RTN"",""MAGDSTA5"",134,0)"
^XMB(3.9,145834,2,4216,0)=" ;"
^XMB(3.9,145834,2,4217,0)="""RTN"",""MAGDSTA5"",135,0)"
^XMB(3.9,145834,2,4218,0)="SETDATES(DATEBEG,DATESTOP,BEGDATE,ENDDATE,DIRECTION) ; get date range"
^XMB(3.9,145834,2,4219,0)="""RTN"",""MAGDSTA5"",136,0)"
^XMB(3.9,145834,2,4220,0)=" ; get the beginning and ending dates for the FOR loop"
^XMB(3.9,145834,2,4221,0)="""RTN"",""MAGDSTA5"",137,0)"
^XMB(3.9,145834,2,4222,0)=" ; these are in RARPT reverse date format"
^XMB(3.9,145834,2,4223,0)="""RTN"",""MAGDSTA5"",138,0)"
^XMB(3.9,145834,2,4224,0)=" ; they are also DIRECTION specific"
^XMB(3.9,145834,2,4225,0)="""RTN"",""MAGDSTA5"",139,0)"
^XMB(3.9,145834,2,4226,0)=" I DIRECTION=1 D  ; ascending direction"
^XMB(3.9,145834,2,4227,0)="""RTN"",""MAGDSTA5"",140,0)"
^XMB(3.9,145834,2,4228,0)=" . S DATEBEG=$$RADTI(BEGDATE)"
^XMB(3.9,145834,2,4229,0)="""RTN"",""MAGDSTA5"",141,0)"
^XMB(3.9,145834,2,4230,0)=" . S DATESTOP=$$RADTI(ENDDATE)"
^XMB(3.9,145834,2,4231,0)="""RTN"",""MAGDSTA5"",142,0)"
^XMB(3.9,145834,2,4232,0)=" . Q"
^XMB(3.9,145834,2,4233,0)="""RTN"",""MAGDSTA5"",143,0)"
^XMB(3.9,145834,2,4234,0)=" E  D  ; descending direction"
^XMB(3.9,145834,2,4235,0)="""RTN"",""MAGDSTA5"",144,0)"
^XMB(3.9,145834,2,4236,0)=" . S DATEBEG=$$RADTI(ENDDATE)"
^XMB(3.9,145834,2,4237,0)="""RTN"",""MAGDSTA5"",145,0)"
^XMB(3.9,145834,2,4238,0)=" . S DATESTOP=$$RADTI(BEGDATE)"
^XMB(3.9,145834,2,4239,0)="""RTN"",""MAGDSTA5"",146,0)"
^XMB(3.9,145834,2,4240,0)=" . Q "
^XMB(3.9,145834,2,4241,0)="""RTN"",""MAGDSTA5"",147,0)"
^XMB(3.9,145834,2,4242,0)=" Q"
^XMB(3.9,145834,2,4243,0)="""RTN"",""MAGDSTA5"",148,0)"
^XMB(3.9,145834,2,4244,0)=" ;"
^XMB(3.9,145834,2,4245,0)="""RTN"",""MAGDSTA5"",149,0)"
^XMB(3.9,145834,2,4246,0)="RADTI(RADTI) ; convert a reverse date to a FM date and vice versa"
^XMB(3.9,145834,2,4247,0)="""RTN"",""MAGDSTA5"",150,0)"
^XMB(3.9,145834,2,4248,0)=" Q 9999999.9999-RADTI ; 9's complement conversion"
^XMB(3.9,145834,2,4249,0)="""RTN"",""MAGDSTA7"")"
^XMB(3.9,145834,2,4250,0)="0^30^B46290220"
^XMB(3.9,145834,2,4251,0)="""RTN"",""MAGDSTA7"",1,0)"
^XMB(3.9,145834,2,4252,0)="MAGDSTA7 ;WOIFO/PMK - Q/R Retrieve of DICOM images from PACS to VistA ; Mar 04, 2022@13:42:59"
^XMB(3.9,145834,2,4253,0)="""RTN"",""MAGDSTA7"",2,0)"
^XMB(3.9,145834,2,4254,0)=" ;;3.0;IMAGING;**231,305**;Mar 19, 2002;Build 0"
^XMB(3.9,145834,2,4255,0)="""RTN"",""MAGDSTA7"",3,0)"
^XMB(3.9,145834,2,4256,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,4257,0)="""RTN"",""MAGDSTA7"",4,0)"
^XMB(3.9,145834,2,4258,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,4259,0)="""RTN"",""MAGDSTA7"",5,0)"
^XMB(3.9,145834,2,4260,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145834,2,4261,0)="""RTN"",""MAGDSTA7"",6,0)"
^XMB(3.9,145834,2,4262,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145834,2,4263,0)="""RTN"",""MAGDSTA7"",7,0)"
^XMB(3.9,145834,2,4264,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145834,2,4265,0)="""RTN"",""MAGDSTA7"",8,0)"
^XMB(3.9,145834,2,4266,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,4267,0)="""RTN"",""MAGDSTA7"",9,0)"
^XMB(3.9,145834,2,4268,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,4269,0)="""RTN"",""MAGDSTA7"",10,0)"
^XMB(3.9,145834,2,4270,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,4271,0)="""RTN"",""MAGDSTA7"",11,0)"
^XMB(3.9,145834,2,4272,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,4273,0)="""RTN"",""MAGDSTA7"",12,0)"
^XMB(3.9,145834,2,4274,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,4275,0)="""RTN"",""MAGDSTA7"",13,0)"
^XMB(3.9,145834,2,4276,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,4277,0)="""RTN"",""MAGDSTA7"",14,0)"
^XMB(3.9,145834,2,4278,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,4279,0)="""RTN"",""MAGDSTA7"",15,0)"
^XMB(3.9,145834,2,4280,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,4281,0)="""RTN"",""MAGDSTA7"",16,0)"
^XMB(3.9,145834,2,4282,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,4283,0)="""RTN"",""MAGDSTA7"",17,0)"
^XMB(3.9,145834,2,4284,0)=" ;;"
^XMB(3.9,145834,2,4285,0)="""RTN"",""MAGDSTA7"",18,0)"
^XMB(3.9,145834,2,4286,0)=" ;"
^XMB(3.9,145834,2,4287,0)="""RTN"",""MAGDSTA7"",19,0)"
^XMB(3.9,145834,2,4288,0)=" ; Supported IA #2056 reference $$GET1^DIQ function call"
^XMB(3.9,145834,2,4289,0)="""RTN"",""MAGDSTA7"",20,0)"
^XMB(3.9,145834,2,4290,0)=" ; Supported IA #2056 reference GETS^DIQ subroutine call"
^XMB(3.9,145834,2,4291,0)="""RTN"",""MAGDSTA7"",21,0)"
^XMB(3.9,145834,2,4292,0)=" ; Supported IA #10103 reference $$FMTE^XLFDT function call"
^XMB(3.9,145834,2,4293,0)="""RTN"",""MAGDSTA7"",22,0)"
^XMB(3.9,145834,2,4294,0)=" ; Controlled IA #4110 to read REQUEST/CONSULTATION file (#123)"
^XMB(3.9,145834,2,4295,0)="""RTN"",""MAGDSTA7"",23,0)"
^XMB(3.9,145834,2,4296,0)=" ; Controlled IA #3461 to read TIU EXTERNAL DATA LINK (#8825.91)"
^XMB(3.9,145834,2,4297,0)="""RTN"",""MAGDSTA7"",24,0)"
^XMB(3.9,145834,2,4298,0)=" ;"
^XMB(3.9,145834,2,4299,0)="""RTN"",""MAGDSTA7"",25,0)"
^XMB(3.9,145834,2,4300,0)=" Q"
^XMB(3.9,145834,2,4301,0)="""RTN"",""MAGDSTA7"",26,0)"
^XMB(3.9,145834,2,4302,0)=" ;"
^XMB(3.9,145834,2,4303,0)="""RTN"",""MAGDSTA7"",27,0)"
^XMB(3.9,145834,2,4304,0)=" ; Look for images for partially resulted or completed studies."
^XMB(3.9,145834,2,4305,0)="""RTN"",""MAGDSTA7"",28,0)"
^XMB(3.9,145834,2,4306,0)=" ;"
^XMB(3.9,145834,2,4307,0)="""RTN"",""MAGDSTA7"",29,0)"
^XMB(3.9,145834,2,4308,0)="MAIN() ; The main loop for the program for consults and procedures"
^XMB(3.9,145834,2,4309,0)="""RTN"",""MAGDSTA7"",30,0)"
^XMB(3.9,145834,2,4310,0)=" ; Input Variables "
^XMB(3.9,145834,2,4311,0)="""RTN"",""MAGDSTA7"",31,0)"
^XMB(3.9,145834,2,4312,0)=" ; SCANMODE ;-- ""PATIENT"", ""DATE"", or ""NUMBER"""
^XMB(3.9,145834,2,4313,0)="""RTN"",""MAGDSTA7"",32,0)"
^XMB(3.9,145834,2,4314,0)=" ; DIRECTION ;- 1=""ASCENDING"" or 0=""DESCENDING"""
^XMB(3.9,145834,2,4315,0)="""RTN"",""MAGDSTA7"",33,0)"
^XMB(3.9,145834,2,4316,0)=" ; BATCHSIZE ;- number of consult & procedure requests to process on this run"
^XMB(3.9,145834,2,4317,0)="""RTN"",""MAGDSTA7"",34,0)"
^XMB(3.9,145834,2,4318,0)=" ; BEGDATE ;--- begin date for search"
^XMB(3.9,145834,2,4319,0)="""RTN"",""MAGDSTA7"",35,0)"
^XMB(3.9,145834,2,4320,0)=" ; ENDDATE ;-- end date for search"
^XMB(3.9,145834,2,4321,0)="""RTN"",""MAGDSTA7"",36,0)"
^XMB(3.9,145834,2,4322,0)=" ; QRSCP ;----- default query/retrieve provider"
^XMB(3.9,145834,2,4323,0)="""RTN"",""MAGDSTA7"",37,0)"
^XMB(3.9,145834,2,4324,0)=" ; HOURS ;----- 24 character string of Y's and N's indicating active times"
^XMB(3.9,145834,2,4325,0)="""RTN"",""MAGDSTA7"",38,0)"
^XMB(3.9,145834,2,4326,0)=" ; "
^XMB(3.9,145834,2,4327,0)="""RTN"",""MAGDSTA7"",39,0)"
^XMB(3.9,145834,2,4328,0)=" N GMRCIEN,RUNTIME,STOP,X"
^XMB(3.9,145834,2,4329,0)="""RTN"",""MAGDSTA7"",40,0)"
^XMB(3.9,145834,2,4330,0)=" ;"
^XMB(3.9,145834,2,4331,0)="""RTN"",""MAGDSTA7"",41,0)"
^XMB(3.9,145834,2,4332,0)=" D HEADER^MAGDSTAA(0)"
^XMB(3.9,145834,2,4333,0)="""RTN"",""MAGDSTA7"",42,0)"
^XMB(3.9,145834,2,4334,0)=" ;"
^XMB(3.9,145834,2,4335,0)="""RTN"",""MAGDSTA7"",43,0)"
^XMB(3.9,145834,2,4336,0)=" ; STOP: -1=error, 0=run completed, 1=run stopped"
^XMB(3.9,145834,2,4337,0)="""RTN"",""MAGDSTA7"",44,0)"
^XMB(3.9,145834,2,4338,0)=" S STOP=$$CONLKUP()"
^XMB(3.9,145834,2,4339,0)="""RTN"",""MAGDSTA7"",45,0)"
^XMB(3.9,145834,2,4340,0)=" Q STOP"
^XMB(3.9,145834,2,4341,0)="""RTN"",""MAGDSTA7"",46,0)"
^XMB(3.9,145834,2,4342,0)=" ;"
^XMB(3.9,145834,2,4343,0)="""RTN"",""MAGDSTA7"",47,0)"
^XMB(3.9,145834,2,4344,0)="CONLKUP() ; Find the next study to retrieve"
^XMB(3.9,145834,2,4345,0)="""RTN"",""MAGDSTA7"",48,0)"
^XMB(3.9,145834,2,4346,0)=" N STOP"
^XMB(3.9,145834,2,4347,0)="""RTN"",""MAGDSTA7"",49,0)"
^XMB(3.9,145834,2,4348,0)=" I SCANMODE=""PATIENT"" D"
^XMB(3.9,145834,2,4349,0)="""RTN"",""MAGDSTA7"",50,0)"
^XMB(3.9,145834,2,4350,0)=" . S STOP=$$PATIENT()"
^XMB(3.9,145834,2,4351,0)="""RTN"",""MAGDSTA7"",51,0)"
^XMB(3.9,145834,2,4352,0)=" . Q"
^XMB(3.9,145834,2,4353,0)="""RTN"",""MAGDSTA7"",52,0)"
^XMB(3.9,145834,2,4354,0)=" E  I SCANMODE=""DATE"" D"
^XMB(3.9,145834,2,4355,0)="""RTN"",""MAGDSTA7"",53,0)"
^XMB(3.9,145834,2,4356,0)=" . S STOP=$$DATE()"
^XMB(3.9,145834,2,4357,0)="""RTN"",""MAGDSTA7"",54,0)"
^XMB(3.9,145834,2,4358,0)=" . Q"
^XMB(3.9,145834,2,4359,0)="""RTN"",""MAGDSTA7"",55,0)"
^XMB(3.9,145834,2,4360,0)=" E  I SCANMODE=""NUMBER"" D"
^XMB(3.9,145834,2,4361,0)="""RTN"",""MAGDSTA7"",56,0)"
^XMB(3.9,145834,2,4362,0)=" . S STOP=$$NUMBER()"
^XMB(3.9,145834,2,4363,0)="""RTN"",""MAGDSTA7"",57,0)"
^XMB(3.9,145834,2,4364,0)=" . Q"
^XMB(3.9,145834,2,4365,0)="""RTN"",""MAGDSTA7"",58,0)"
^XMB(3.9,145834,2,4366,0)=" E  D"
^XMB(3.9,145834,2,4367,0)="""RTN"",""MAGDSTA7"",59,0)"
^XMB(3.9,145834,2,4368,0)=" . W !!,""*** Illegal SCAN MODE: """""",SCANMODE,"""""""""
^XMB(3.9,145834,2,4369,0)="""RTN"",""MAGDSTA7"",60,0)"
^XMB(3.9,145834,2,4370,0)=" . S STOP=-1"
^XMB(3.9,145834,2,4371,0)="""RTN"",""MAGDSTA7"",61,0)"
^XMB(3.9,145834,2,4372,0)=" . Q"
^XMB(3.9,145834,2,4373,0)="""RTN"",""MAGDSTA7"",62,0)"
^XMB(3.9,145834,2,4374,0)=" Q STOP"
^XMB(3.9,145834,2,4375,0)="""RTN"",""MAGDSTA7"",63,0)"
^XMB(3.9,145834,2,4376,0)=" ;"
^XMB(3.9,145834,2,4377,0)="""RTN"",""MAGDSTA7"",64,0)"
^XMB(3.9,145834,2,4378,0)="PATIENT() ; use ""AD"" cross-reference to find studies for a single patient"
^XMB(3.9,145834,2,4379,0)="""RTN"",""MAGDSTA7"",65,0)"
^XMB(3.9,145834,2,4380,0)=" ; ^GMR(123,""AD"",DFN,GMRCDATE,GMRCIEN)="""""
^XMB(3.9,145834,2,4381,0)="""RTN"",""MAGDSTA7"",66,0)"
^XMB(3.9,145834,2,4382,0)=" N DATEBEG,DATESTOP,DONE,GMRCDATE,STOP"
^XMB(3.9,145834,2,4383,0)="""RTN"",""MAGDSTA7"",67,0)"
^XMB(3.9,145834,2,4384,0)=" S STOP=0 ; set to stop the q/r process"
^XMB(3.9,145834,2,4385,0)="""RTN"",""MAGDSTA7"",68,0)"
^XMB(3.9,145834,2,4386,0)=" D SETDATES(.DATEBEG,.DATESTOP,BEGDATE,ENDDATE,DIRECTION)"
^XMB(3.9,145834,2,4387,0)="""RTN"",""MAGDSTA7"",69,0)"
^XMB(3.9,145834,2,4388,0)=" S GMRCDATE=DATEBEG,DONE=0"
^XMB(3.9,145834,2,4389,0)="""RTN"",""MAGDSTA7"",70,0)"
^XMB(3.9,145834,2,4390,0)=" ; reverse date, opposite sort order"
^XMB(3.9,145834,2,4391,0)="""RTN"",""MAGDSTA7"",71,0)"
^XMB(3.9,145834,2,4392,0)=" F  S GMRCDATE=$O(^GMR(123,""AD"",DFN,GMRCDATE),-DIRECTION) Q:'GMRCDATE  Q:DONE  Q:STOP  D"
^XMB(3.9,145834,2,4393,0)="""RTN"",""MAGDSTA7"",72,0)"
^XMB(3.9,145834,2,4394,0)=" . I DIRECTION=1 S DONE=GMRCDATE<DATESTOP Q:DONE"
^XMB(3.9,145834,2,4395,0)="""RTN"",""MAGDSTA7"",73,0)"
^XMB(3.9,145834,2,4396,0)=" . E  S DONE=GMRCDATE>DATESTOP Q:DONE"
^XMB(3.9,145834,2,4397,0)="""RTN"",""MAGDSTA7"",74,0)"
^XMB(3.9,145834,2,4398,0)=" . S GMRCIEN="""""
^XMB(3.9,145834,2,4399,0)="""RTN"",""MAGDSTA7"",75,0)"
^XMB(3.9,145834,2,4400,0)=" . F  S GMRCIEN=$O(^GMR(123,""AD"",DFN,GMRCDATE,GMRCIEN),DIRECTION) Q:'GMRCIEN  Q:STOP  D"
^XMB(3.9,145834,2,4401,0)="""RTN"",""MAGDSTA7"",76,0)"
^XMB(3.9,145834,2,4402,0)=" . . ; does this consult get images?"
^XMB(3.9,145834,2,4403,0)="""RTN"",""MAGDSTA7"",77,0)"
^XMB(3.9,145834,2,4404,0)=" . . I $$CHECK^MAGDSTA6(GMRCIEN)'=1 Q  ; nope"
^XMB(3.9,145834,2,4405,0)="""RTN"",""MAGDSTA7"",78,0)"
^XMB(3.9,145834,2,4406,0)=" . . S STOP=$$CONLKUP1(GMRCIEN)"
^XMB(3.9,145834,2,4407,0)="""RTN"",""MAGDSTA7"",79,0)"
^XMB(3.9,145834,2,4408,0)=" . . Q"
^XMB(3.9,145834,2,4409,0)="""RTN"",""MAGDSTA7"",80,0)"
^XMB(3.9,145834,2,4410,0)=" . Q"
^XMB(3.9,145834,2,4411,0)="""RTN"",""MAGDSTA7"",81,0)"
^XMB(3.9,145834,2,4412,0)=" Q STOP"
^XMB(3.9,145834,2,4413,0)="""RTN"",""MAGDSTA7"",82,0)"
^XMB(3.9,145834,2,4414,0)=" ;"
^XMB(3.9,145834,2,4415,0)="""RTN"",""MAGDSTA7"",83,0)"
^XMB(3.9,145834,2,4416,0)="DATE() ; use ""AE"" cross-reference to find completed studies"
^XMB(3.9,145834,2,4417,0)="""RTN"",""MAGDSTA7"",84,0)"
^XMB(3.9,145834,2,4418,0)=" ; ^GMR(123,""AE"",SERVICE,STATUS,GMRCDATE,GMRCIEN)="""""
^XMB(3.9,145834,2,4419,0)="""RTN"",""MAGDSTA7"",85,0)"
^XMB(3.9,145834,2,4420,0)=" ; only look for COMPLETED studies and PARTIAL RESULTS"
^XMB(3.9,145834,2,4421,0)="""RTN"",""MAGDSTA7"",86,0)"
^XMB(3.9,145834,2,4422,0)=" N DATEBEG,DATESTOP,DONE,GMRCDATE,STATUS,STOP"
^XMB(3.9,145834,2,4423,0)="""RTN"",""MAGDSTA7"",87,0)"
^XMB(3.9,145834,2,4424,0)=" S STOP=0 ; set to stop the q/r process"
^XMB(3.9,145834,2,4425,0)="""RTN"",""MAGDSTA7"",88,0)"
^XMB(3.9,145834,2,4426,0)=" D SETDATES(.DATEBEG,.DATESTOP,BEGDATE,ENDDATE,DIRECTION)"
^XMB(3.9,145834,2,4427,0)="""RTN"",""MAGDSTA7"",89,0)"
^XMB(3.9,145834,2,4428,0)=" S SERVICE="""" F  S SERVICE=$O(CONSULTSERVICES(SERVICE)) Q:SERVICE=""""  Q:STOP  D"
^XMB(3.9,145834,2,4429,0)="""RTN"",""MAGDSTA7"",90,0)"
^XMB(3.9,145834,2,4430,0)=" . F STATUS=2,9 D  ; STATUS=2 for COMPLETE, STATUS=9 for PARTIAL RESULTS"
^XMB(3.9,145834,2,4431,0)="""RTN"",""MAGDSTA7"",91,0)"
^XMB(3.9,145834,2,4432,0)=" . . W !!,CONSULTSERVICES(SERVICE),"" -- """
^XMB(3.9,145834,2,4433,0)="""RTN"",""MAGDSTA7"",92,0)"
^XMB(3.9,145834,2,4434,0)=" . . W $S(STATUS=2:""COMPLETE"",STATUS=9:""PARTIAL RESULTS"",1:""Unknown Status ""_STATUS)"
^XMB(3.9,145834,2,4435,0)="""RTN"",""MAGDSTA7"",93,0)"
^XMB(3.9,145834,2,4436,0)=" . . S GMRCDATE=DATEBEG,DONE=0"
^XMB(3.9,145834,2,4437,0)="""RTN"",""MAGDSTA7"",94,0)"
^XMB(3.9,145834,2,4438,0)=" . . ; reverse date, opposite sort order"
^XMB(3.9,145834,2,4439,0)="""RTN"",""MAGDSTA7"",95,0)"
^XMB(3.9,145834,2,4440,0)=" . . F  S GMRCDATE=$O(^GMR(123,""AE"",SERVICE,STATUS,GMRCDATE),-DIRECTION) Q:'GMRCDATE  Q:DONE  Q:STOP  D"
^XMB(3.9,145834,2,4441,0)="""RTN"",""MAGDSTA7"",96,0)"
^XMB(3.9,145834,2,4442,0)=" . . . I DIRECTION=1 S DONE=GMRCDATE<DATESTOP Q:DONE"
^XMB(3.9,145834,2,4443,0)="""RTN"",""MAGDSTA7"",97,0)"
^XMB(3.9,145834,2,4444,0)=" . . . E  S DONE=GMRCDATE>DATESTOP Q:DONE"
^XMB(3.9,145834,2,4445,0)="""RTN"",""MAGDSTA7"",98,0)"
^XMB(3.9,145834,2,4446,0)=" . . . S GMRCIEN="""""
^XMB(3.9,145834,2,4447,0)="""RTN"",""MAGDSTA7"",99,0)"
^XMB(3.9,145834,2,4448,0)=" . . . F  S GMRCIEN=$O(^GMR(123,""AE"",SERVICE,STATUS,GMRCDATE,GMRCIEN),DIRECTION) Q:'GMRCIEN  Q:STOP  D"
^XMB(3.9,145834,2,4449,0)="""RTN"",""MAGDSTA7"",100,0)"
^XMB(3.9,145834,2,4450,0)=" . . . . ; does this consult get images?"
^XMB(3.9,145834,2,4451,0)="""RTN"",""MAGDSTA7"",101,0)"
^XMB(3.9,145834,2,4452,0)=" . . . . I $$CHECK^MAGDSTA6(GMRCIEN)'=1 Q  ; nope"
^XMB(3.9,145834,2,4453,0)="""RTN"",""MAGDSTA7"",102,0)"
^XMB(3.9,145834,2,4454,0)=" . . . . S STOP=$$CONLKUP1(GMRCIEN)"
^XMB(3.9,145834,2,4455,0)="""RTN"",""MAGDSTA7"",103,0)"
^XMB(3.9,145834,2,4456,0)=" . . . . Q"
^XMB(3.9,145834,2,4457,0)="""RTN"",""MAGDSTA7"",104,0)"
^XMB(3.9,145834,2,4458,0)=" . . . Q"
^XMB(3.9,145834,2,4459,0)="""RTN"",""MAGDSTA7"",105,0)"
^XMB(3.9,145834,2,4460,0)=" . . Q"
^XMB(3.9,145834,2,4461,0)="""RTN"",""MAGDSTA7"",106,0)"
^XMB(3.9,145834,2,4462,0)=" . Q"
^XMB(3.9,145834,2,4463,0)="""RTN"",""MAGDSTA7"",107,0)"
^XMB(3.9,145834,2,4464,0)=" Q STOP"
^XMB(3.9,145834,2,4465,0)="""RTN"",""MAGDSTA7"",108,0)"
^XMB(3.9,145834,2,4466,0)=" ;"
^XMB(3.9,145834,2,4467,0)="""RTN"",""MAGDSTA7"",109,0)"
^XMB(3.9,145834,2,4468,0)="NUMBER() ; use GMRCIEN to find completed studies"
^XMB(3.9,145834,2,4469,0)="""RTN"",""MAGDSTA7"",110,0)"
^XMB(3.9,145834,2,4470,0)=" ; ^GMR(123,GMRC)=<consult record>"
^XMB(3.9,145834,2,4471,0)="""RTN"",""MAGDSTA7"",111,0)"
^XMB(3.9,145834,2,4472,0)=" N BATCHSIZE,GMRCIEN,STOP,STUDYCNT"
^XMB(3.9,145834,2,4473,0)="""RTN"",""MAGDSTA7"",112,0)"
^XMB(3.9,145834,2,4474,0)=" S STOP=0 ; set to stop the q/r process"
^XMB(3.9,145834,2,4475,0)="""RTN"",""MAGDSTA7"",113,0)"
^XMB(3.9,145834,2,4476,0)=" S STUDYCNT=0"
^XMB(3.9,145834,2,4477,0)="""RTN"",""MAGDSTA7"",114,0)"
^XMB(3.9,145834,2,4478,0)=" S BATCHSIZE=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""BATCH SIZE""))"
^XMB(3.9,145834,2,4479,0)="""RTN"",""MAGDSTA7"",115,0)"
^XMB(3.9,145834,2,4480,0)=" S GMRCIEN=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""REPORT/STUDY IEN""))"
^XMB(3.9,145834,2,4481,0)="""RTN"",""MAGDSTA7"",116,0)"
^XMB(3.9,145834,2,4482,0)=" S GMRCIEN=GMRCIEN-DIRECTION ; Massage value for $O"
^XMB(3.9,145834,2,4483,0)="""RTN"",""MAGDSTA7"",117,0)"
^XMB(3.9,145834,2,4484,0)=" F  S GMRCIEN=$O(^GMR(123,GMRCIEN),DIRECTION) Q:'GMRCIEN  Q:STUDYCNT>=BATCHSIZE  Q:STOP  D"
^XMB(3.9,145834,2,4485,0)="""RTN"",""MAGDSTA7"",118,0)"
^XMB(3.9,145834,2,4486,0)=" . ; does this consult get images?"
^XMB(3.9,145834,2,4487,0)="""RTN"",""MAGDSTA7"",119,0)"
^XMB(3.9,145834,2,4488,0)=" . I $$CHECK^MAGDSTA6(GMRCIEN)'=1 Q  ; nope"
^XMB(3.9,145834,2,4489,0)="""RTN"",""MAGDSTA7"",120,0)"
^XMB(3.9,145834,2,4490,0)=" . S STUDYCNT=STUDYCNT+1"
^XMB(3.9,145834,2,4491,0)="""RTN"",""MAGDSTA7"",121,0)"
^XMB(3.9,145834,2,4492,0)=" . S STOP=$$CONLKUP1(GMRCIEN)"
^XMB(3.9,145834,2,4493,0)="""RTN"",""MAGDSTA7"",122,0)"
^XMB(3.9,145834,2,4494,0)=" . Q"
^XMB(3.9,145834,2,4495,0)="""RTN"",""MAGDSTA7"",123,0)"
^XMB(3.9,145834,2,4496,0)=" Q STOP"
^XMB(3.9,145834,2,4497,0)="""RTN"",""MAGDSTA7"",124,0)"
^XMB(3.9,145834,2,4498,0)=" ;"
^XMB(3.9,145834,2,4499,0)="""RTN"",""MAGDSTA7"",125,0)"
^XMB(3.9,145834,2,4500,0)="CONLKUP1(GMRCIEN) ; check consult"
^XMB(3.9,145834,2,4501,0)="""RTN"",""MAGDSTA7"",126,0)"
^XMB(3.9,145834,2,4502,0)=" N ACNUMB,DFN,EXAMDATE,I,ORDERINGFACILITY,MAGIENLIST"
^XMB(3.9,145834,2,4503,0)="""RTN"",""MAGDSTA7"",127,0)"
^XMB(3.9,145834,2,4504,0)=" ;"
^XMB(3.9,145834,2,4505,0)="""RTN"",""MAGDSTA7"",128,0)"
^XMB(3.9,145834,2,4506,0)=" S ORDERINGFACILITY=$$GET1^DIQ(123,GMRCIEN,.05,""I"")"
^XMB(3.9,145834,2,4507,0)="""RTN"",""MAGDSTA7"",129,0)"
^XMB(3.9,145834,2,4508,0)=" I $$CHECKDIV^MAGDSTAB()=""Y"",ORDERINGFACILITY'=DIVISION Q 0  ; not this division"
^XMB(3.9,145834,2,4509,0)="""RTN"",""MAGDSTA7"",130,0)"
^XMB(3.9,145834,2,4510,0)=" ;"
^XMB(3.9,145834,2,4511,0)="""RTN"",""MAGDSTA7"",131,0)"
^XMB(3.9,145834,2,4512,0)=" S ACNUMB=$$GMRCACN^MAGDFCNV(GMRCIEN) ; legacy or site-specific"
^XMB(3.9,145834,2,4513,0)="""RTN"",""MAGDSTA7"",132,0)"
^XMB(3.9,145834,2,4514,0)=" S EXAMDATE=$$GET1^DIQ(123,GMRCIEN,.01,""I"")"
^XMB(3.9,145834,2,4515,0)="""RTN"",""MAGDSTA7"",133,0)"
^XMB(3.9,145834,2,4516,0)=" S DFN=$$GET1^DIQ(123,GMRCIEN,.02,""I"")"
^XMB(3.9,145834,2,4517,0)="""RTN"",""MAGDSTA7"",134,0)"
^XMB(3.9,145834,2,4518,0)=" I $$CONSULT(GMRCIEN,.MAGIENLIST)<0 Q 0"
^XMB(3.9,145834,2,4519,0)="""RTN"",""MAGDSTA7"",135,0)"
^XMB(3.9,145834,2,4520,0)=" Q $$LOOKUP^MAGDSTAA(DFN,EXAMDATE,GMRCIEN,ACNUMB,.MAGIENLIST)"
^XMB(3.9,145834,2,4521,0)="""RTN"",""MAGDSTA7"",136,0)"
^XMB(3.9,145834,2,4522,0)=" ;"
^XMB(3.9,145834,2,4523,0)="""RTN"",""MAGDSTA7"",137,0)"
^XMB(3.9,145834,2,4524,0)="CONSULT(GMRCIEN,MAGIENLIST) ; return a list of MAG Group IENs"
^XMB(3.9,145834,2,4525,0)="""RTN"",""MAGDSTA7"",138,0)"
^XMB(3.9,145834,2,4526,0)=" ; A consult may have multiple TIU notes and a TIU note may have multiple image groups."
^XMB(3.9,145834,2,4527,0)="""RTN"",""MAGDSTA7"",139,0)"
^XMB(3.9,145834,2,4528,0)=" ; A consult may also have images associated in the DICOM TEMP LIST file (#2006.5839)."
^XMB(3.9,145834,2,4529,0)="""RTN"",""MAGDSTA7"",140,0)"
^XMB(3.9,145834,2,4530,0)=" N ERROR,GROUPIEN,I,MAG20065839,TIULIST,X"
^XMB(3.9,145834,2,4531,0)="""RTN"",""MAGDSTA7"",141,0)"
^XMB(3.9,145834,2,4532,0)=" S ERROR=$$CONSULT1(GMRCIEN,.TIULIST)"
^XMB(3.9,145834,2,4533,0)="""RTN"",""MAGDSTA7"",142,0)"
^XMB(3.9,145834,2,4534,0)=" I ERROR<0 Q ERROR"
^XMB(3.9,145834,2,4535,0)="""RTN"",""MAGDSTA7"",143,0)"
^XMB(3.9,145834,2,4536,0)=" ; a TIU note may have multiple image groups - get the list"
^XMB(3.9,145834,2,4537,0)="""RTN"",""MAGDSTA7"",144,0)"
^XMB(3.9,145834,2,4538,0)=" F I=1:1:TIULIST(0) D"
^XMB(3.9,145834,2,4539,0)="""RTN"",""MAGDSTA7"",145,0)"
^XMB(3.9,145834,2,4540,0)=" . D T892591(TIULIST(I),.MAGIENLIST)"
^XMB(3.9,145834,2,4541,0)="""RTN"",""MAGDSTA7"",146,0)"
^XMB(3.9,145834,2,4542,0)=" . Q"
^XMB(3.9,145834,2,4543,0)="""RTN"",""MAGDSTA7"",147,0)"
^XMB(3.9,145834,2,4544,0)=" S MAG20065839="""""
^XMB(3.9,145834,2,4545,0)="""RTN"",""MAGDSTA7"",148,0)"
^XMB(3.9,145834,2,4546,0)=" F  S MAG20065839=$O(^MAG(2006.5839,""C"",123,GMRCIEN,MAG20065839)) Q:MAG20065839=""""  D"
^XMB(3.9,145834,2,4547,0)="""RTN"",""MAGDSTA7"",149,0)"
^XMB(3.9,145834,2,4548,0)=" . S X=$G(^MAG(2006.5839,MAG20065839,0))"
^XMB(3.9,145834,2,4549,0)="""RTN"",""MAGDSTA7"",150,0)"
^XMB(3.9,145834,2,4550,0)=" . S GROUPIEN=$P(X,""^"",3)"
^XMB(3.9,145834,2,4551,0)="""RTN"",""MAGDSTA7"",151,0)"
^XMB(3.9,145834,2,4552,0)=" . S MAGIENLIST(GROUPIEN)="""""
^XMB(3.9,145834,2,4553,0)="""RTN"",""MAGDSTA7"",152,0)"
^XMB(3.9,145834,2,4554,0)=" . Q"
^XMB(3.9,145834,2,4555,0)="""RTN"",""MAGDSTA7"",153,0)"
^XMB(3.9,145834,2,4556,0)=" Q 0"
^XMB(3.9,145834,2,4557,0)="""RTN"",""MAGDSTA7"",154,0)"
^XMB(3.9,145834,2,4558,0)=" ;"
^XMB(3.9,145834,2,4559,0)="""RTN"",""MAGDSTA7"",155,0)"
^XMB(3.9,145834,2,4560,0)="CONSULT1(GMRCIEN,TIULIST) ; return a list of TIU IENs"
^XMB(3.9,145834,2,4561,0)="""RTN"",""MAGDSTA7"",156,0)"
^XMB(3.9,145834,2,4562,0)=" ; a consult may have multiple TIU notes - get the list"
^XMB(3.9,145834,2,4563,0)="""RTN"",""MAGDSTA7"",157,0)"
^XMB(3.9,145834,2,4564,0)=" N A,I,SS2,TIUIEN"
^XMB(3.9,145834,2,4565,0)="""RTN"",""MAGDSTA7"",158,0)"
^XMB(3.9,145834,2,4566,0)=" K TIULIST ; initialize list of TIU IENs"
^XMB(3.9,145834,2,4567,0)="""RTN"",""MAGDSTA7"",159,0)"
^XMB(3.9,145834,2,4568,0)=" S TIULIST(0)=0"
^XMB(3.9,145834,2,4569,0)="""RTN"",""MAGDSTA7"",160,0)"
^XMB(3.9,145834,2,4570,0)=" D GETS^DIQ(123,GMRCIEN,""**"",""I"",""A"")"
^XMB(3.9,145834,2,4571,0)="""RTN"",""MAGDSTA7"",161,0)"
^XMB(3.9,145834,2,4572,0)=" I '$D(A) S OUT(1)=""-1,Error in CONSULT1 with file #123 GMRCIEN Lookup"" Q"
^XMB(3.9,145834,2,4573,0)="""RTN"",""MAGDSTA7"",162,0)"
^XMB(3.9,145834,2,4574,0)=" S I=0,SS2="""",I=0 F  S SS2=$O(A(123.03,SS2)) Q:SS2=""""  D"
^XMB(3.9,145834,2,4575,0)="""RTN"",""MAGDSTA7"",163,0)"
^XMB(3.9,145834,2,4576,0)=" . S TIUIEN=A(123.03,SS2,.01,""I"")"
^XMB(3.9,145834,2,4577,0)="""RTN"",""MAGDSTA7"",164,0)"
^XMB(3.9,145834,2,4578,0)=" . I $P(TIUIEN,"";"",2)=""TIU(8925,"" D"
^XMB(3.9,145834,2,4579,0)="""RTN"",""MAGDSTA7"",165,0)"
^XMB(3.9,145834,2,4580,0)=" . . S I=I+1,TIULIST(0)=I"
^XMB(3.9,145834,2,4581,0)="""RTN"",""MAGDSTA7"",166,0)"
^XMB(3.9,145834,2,4582,0)=" . . S TIULIST(I)=$P(TIUIEN,"";"",1)"
^XMB(3.9,145834,2,4583,0)="""RTN"",""MAGDSTA7"",167,0)"
^XMB(3.9,145834,2,4584,0)=" . . Q"
^XMB(3.9,145834,2,4585,0)="""RTN"",""MAGDSTA7"",168,0)"
^XMB(3.9,145834,2,4586,0)=" . Q"
^XMB(3.9,145834,2,4587,0)="""RTN"",""MAGDSTA7"",169,0)"
^XMB(3.9,145834,2,4588,0)=" Q 0"
^XMB(3.9,145834,2,4589,0)="""RTN"",""MAGDSTA7"",170,0)"
^XMB(3.9,145834,2,4590,0)=" ;"
^XMB(3.9,145834,2,4591,0)="""RTN"",""MAGDSTA7"",171,0)"
^XMB(3.9,145834,2,4592,0)="T892591(TIUIEN,MAGIENLIST) ;"
^XMB(3.9,145834,2,4593,0)="""RTN"",""MAGDSTA7"",172,0)"
^XMB(3.9,145834,2,4594,0)=" N GROUPIEN,TIU892591"
^XMB(3.9,145834,2,4595,0)="""RTN"",""MAGDSTA7"",173,0)"
^XMB(3.9,145834,2,4596,0)=" S TIU892591="""""
^XMB(3.9,145834,2,4597,0)="""RTN"",""MAGDSTA7"",174,0)"
^XMB(3.9,145834,2,4598,0)=" F  S TIU892591=$O(^TIU(8925.91,""B"",TIUIEN,TIU892591)) Q:'TIU892591  D"
^XMB(3.9,145834,2,4599,0)="""RTN"",""MAGDSTA7"",175,0)"
^XMB(3.9,145834,2,4600,0)=" . S GROUPIEN=$$GET1^DIQ(8925.91,TIU892591,.02,""I"")"
^XMB(3.9,145834,2,4601,0)="""RTN"",""MAGDSTA7"",176,0)"
^XMB(3.9,145834,2,4602,0)=" . S MAGIENLIST(GROUPIEN)="""""
^XMB(3.9,145834,2,4603,0)="""RTN"",""MAGDSTA7"",177,0)"
^XMB(3.9,145834,2,4604,0)=" . Q"
^XMB(3.9,145834,2,4605,0)="""RTN"",""MAGDSTA7"",178,0)"
^XMB(3.9,145834,2,4606,0)=" Q"
^XMB(3.9,145834,2,4607,0)="""RTN"",""MAGDSTA7"",179,0)"
^XMB(3.9,145834,2,4608,0)=" ;"
^XMB(3.9,145834,2,4609,0)="""RTN"",""MAGDSTA7"",180,0)"
^XMB(3.9,145834,2,4610,0)="SETDATES(DATEBEG,DATESTOP,BEGDATE,ENDDATE,DIRECTION) ; get date range"
^XMB(3.9,145834,2,4611,0)="""RTN"",""MAGDSTA7"",181,0)"
^XMB(3.9,145834,2,4612,0)=" ; get the beginning and ending dates for the FOR loop"
^XMB(3.9,145834,2,4613,0)="""RTN"",""MAGDSTA7"",182,0)"
^XMB(3.9,145834,2,4614,0)=" ; these are in GMRC reverse date format"
^XMB(3.9,145834,2,4615,0)="""RTN"",""MAGDSTA7"",183,0)"
^XMB(3.9,145834,2,4616,0)=" ; they are also DIRECTION specific"
^XMB(3.9,145834,2,4617,0)="""RTN"",""MAGDSTA7"",184,0)"
^XMB(3.9,145834,2,4618,0)=" I DIRECTION=1 D  ; ascending direction"
^XMB(3.9,145834,2,4619,0)="""RTN"",""MAGDSTA7"",185,0)"
^XMB(3.9,145834,2,4620,0)="  . S DATEBEG=$$GMRCDATE(BEGDATE)"
^XMB(3.9,145834,2,4621,0)="""RTN"",""MAGDSTA7"",186,0)"
^XMB(3.9,145834,2,4622,0)="  . S DATESTOP=$$GMRCDATE(ENDDATE)"
^XMB(3.9,145834,2,4623,0)="""RTN"",""MAGDSTA7"",187,0)"
^XMB(3.9,145834,2,4624,0)="  . Q"
^XMB(3.9,145834,2,4625,0)="""RTN"",""MAGDSTA7"",188,0)"
^XMB(3.9,145834,2,4626,0)=" E  D  ; descending direction"
^XMB(3.9,145834,2,4627,0)="""RTN"",""MAGDSTA7"",189,0)"
^XMB(3.9,145834,2,4628,0)=" . S DATEBEG=$$GMRCDATE(ENDDATE)"
^XMB(3.9,145834,2,4629,0)="""RTN"",""MAGDSTA7"",190,0)"
^XMB(3.9,145834,2,4630,0)=" . S DATESTOP=$$GMRCDATE(BEGDATE)"
^XMB(3.9,145834,2,4631,0)="""RTN"",""MAGDSTA7"",191,0)"
^XMB(3.9,145834,2,4632,0)=" . Q "
^XMB(3.9,145834,2,4633,0)="""RTN"",""MAGDSTA7"",192,0)"
^XMB(3.9,145834,2,4634,0)=" Q"
^XMB(3.9,145834,2,4635,0)="""RTN"",""MAGDSTA7"",193,0)"
^XMB(3.9,145834,2,4636,0)=" ;"
^XMB(3.9,145834,2,4637,0)="""RTN"",""MAGDSTA7"",194,0)"
^XMB(3.9,145834,2,4638,0)="GMRCDATE(GMRCDATE) ; convert a GMRC date to a FM date and vice versa"
^XMB(3.9,145834,2,4639,0)="""RTN"",""MAGDSTA7"",195,0)"
^XMB(3.9,145834,2,4640,0)=" Q 9999999-GMRCDATE ; unlike radiology which uses 9999999.9999"
^XMB(3.9,145834,2,4641,0)="""RTN"",""MAGDSTA7"",196,0)"
^XMB(3.9,145834,2,4642,0)=" ;"
^XMB(3.9,145834,2,4643,0)="""RTN"",""MAGDSTA7"",197,0)"
^XMB(3.9,145834,2,4644,0)="HEADER(CONTINUE) ;"
^XMB(3.9,145834,2,4645,0)="""RTN"",""MAGDSTA7"",198,0)"
^XMB(3.9,145834,2,4646,0)=" I CONTINUE D CONTINUE^MAGDSTQ(0)"
^XMB(3.9,145834,2,4647,0)="""RTN"",""MAGDSTA7"",199,0)"
^XMB(3.9,145834,2,4648,0)=" W @IOF,"" Patient"",?12,""   Accession   "",?30,""  Date"",?40,""Images"",?51,""Group #"",?60,""VistA"",?68,""PACS"",?75,""Need"""
^XMB(3.9,145834,2,4649,0)="""RTN"",""MAGDSTA7"",200,0)"
^XMB(3.9,145834,2,4650,0)=" W !,""---------"",?12,""----------------"",?30,""--------"",?40,""------"",?51,""-------"",?60,""-----"",?68,""----"",?75,""----"""
^XMB(3.9,145834,2,4651,0)="""RTN"",""MAGDSTA7"",201,0)"
^XMB(3.9,145834,2,4652,0)=" Q"
^XMB(3.9,145834,2,4653,0)="""RTN"",""MAGDSTA8"")"
^XMB(3.9,145834,2,4654,0)="0^31^B156327044"
^XMB(3.9,145834,2,4655,0)="""RTN"",""MAGDSTA8"",1,0)"
^XMB(3.9,145834,2,4656,0)="MAGDSTA8 ;WOIFO/PMK - Q/R Retrieve of DICOM images from PACS to VistA ; Feb 15, 2022@10:50:15"
^XMB(3.9,145834,2,4657,0)="""RTN"",""MAGDSTA8"",2,0)"
^XMB(3.9,145834,2,4658,0)=" ;;3.0;IMAGING;**231,305**;Mar 19, 2002;Build 0"
^XMB(3.9,145834,2,4659,0)="""RTN"",""MAGDSTA8"",3,0)"
^XMB(3.9,145834,2,4660,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,4661,0)="""RTN"",""MAGDSTA8"",4,0)"
^XMB(3.9,145834,2,4662,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,4663,0)="""RTN"",""MAGDSTA8"",5,0)"
^XMB(3.9,145834,2,4664,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145834,2,4665,0)="""RTN"",""MAGDSTA8"",6,0)"
^XMB(3.9,145834,2,4666,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145834,2,4667,0)="""RTN"",""MAGDSTA8"",7,0)"
^XMB(3.9,145834,2,4668,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145834,2,4669,0)="""RTN"",""MAGDSTA8"",8,0)"
^XMB(3.9,145834,2,4670,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,4671,0)="""RTN"",""MAGDSTA8"",9,0)"
^XMB(3.9,145834,2,4672,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,4673,0)="""RTN"",""MAGDSTA8"",10,0)"
^XMB(3.9,145834,2,4674,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,4675,0)="""RTN"",""MAGDSTA8"",11,0)"
^XMB(3.9,145834,2,4676,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,4677,0)="""RTN"",""MAGDSTA8"",12,0)"
^XMB(3.9,145834,2,4678,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,4679,0)="""RTN"",""MAGDSTA8"",13,0)"
^XMB(3.9,145834,2,4680,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,4681,0)="""RTN"",""MAGDSTA8"",14,0)"
^XMB(3.9,145834,2,4682,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,4683,0)="""RTN"",""MAGDSTA8"",15,0)"
^XMB(3.9,145834,2,4684,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,4685,0)="""RTN"",""MAGDSTA8"",16,0)"
^XMB(3.9,145834,2,4686,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,4687,0)="""RTN"",""MAGDSTA8"",17,0)"
^XMB(3.9,145834,2,4688,0)=" ;;"
^XMB(3.9,145834,2,4689,0)="""RTN"",""MAGDSTA8"",18,0)"
^XMB(3.9,145834,2,4690,0)=" ;"
^XMB(3.9,145834,2,4691,0)="""RTN"",""MAGDSTA8"",19,0)"
^XMB(3.9,145834,2,4692,0)=" ; Supported IA #2056 reference $$GET1^DIQ function call"
^XMB(3.9,145834,2,4693,0)="""RTN"",""MAGDSTA8"",20,0)"
^XMB(3.9,145834,2,4694,0)=" ; Controlled IA #4171 to read REQUEST SERVICES file (#123.5)"
^XMB(3.9,145834,2,4695,0)="""RTN"",""MAGDSTA8"",21,0)"
^XMB(3.9,145834,2,4696,0)=" ; Controlled IA #7095 to read GMRC PROCEDURE file (#123.3)"
^XMB(3.9,145834,2,4697,0)="""RTN"",""MAGDSTA8"",22,0)"
^XMB(3.9,145834,2,4698,0)=" ; Controlled IA #4110 to read REQUEST/CONSULTATION file (#123)"
^XMB(3.9,145834,2,4699,0)="""RTN"",""MAGDSTA8"",23,0)"
^XMB(3.9,145834,2,4700,0)=" ;"
^XMB(3.9,145834,2,4701,0)="""RTN"",""MAGDSTA8"",24,0)"
^XMB(3.9,145834,2,4702,0)=" Q"
^XMB(3.9,145834,2,4703,0)="""RTN"",""MAGDSTA8"",25,0)"
^XMB(3.9,145834,2,4704,0)=" ;"
^XMB(3.9,145834,2,4705,0)="""RTN"",""MAGDSTA8"",26,0)"
^XMB(3.9,145834,2,4706,0)="LEGACY(GROUPIEN,SERIESCOUNT,IMAGECOUNT) ; get all the UIDs for the imaging group"
^XMB(3.9,145834,2,4707,0)="""RTN"",""MAGDSTA8"",27,0)"
^XMB(3.9,145834,2,4708,0)=" N I,IMAGEIEN,VISTASTUDYUID,SERIESUID,SOPUID,X,Y,Z"
^XMB(3.9,145834,2,4709,0)="""RTN"",""MAGDSTA8"",28,0)"
^XMB(3.9,145834,2,4710,0)=" S (SERIESCOUNT,IMAGECOUNT)=0 ; want series/image counts for this group ien"
^XMB(3.9,145834,2,4711,0)="""RTN"",""MAGDSTA8"",29,0)"
^XMB(3.9,145834,2,4712,0)=" S X=$G(^MAG(2005,GROUPIEN,""PACS""))"
^XMB(3.9,145834,2,4713,0)="""RTN"",""MAGDSTA8"",30,0)"
^XMB(3.9,145834,2,4714,0)=" S VISTASTUDYUID=$P(X,""^"",1)"
^XMB(3.9,145834,2,4715,0)="""RTN"",""MAGDSTA8"",31,0)"
^XMB(3.9,145834,2,4716,0)=" I VISTASTUDYUID="""" Q  ; invoked for a group without a study uid"
^XMB(3.9,145834,2,4717,0)="""RTN"",""MAGDSTA8"",32,0)"
^XMB(3.9,145834,2,4718,0)=" ; there may be multiple study instance uids"
^XMB(3.9,145834,2,4719,0)="""RTN"",""MAGDSTA8"",33,0)"
^XMB(3.9,145834,2,4720,0)=" I '$D(^TMP(""MAG"",$J,""UIDS"",""VISTA"",VISTASTUDYUID)) D"
^XMB(3.9,145834,2,4721,0)="""RTN"",""MAGDSTA8"",34,0)"
^XMB(3.9,145834,2,4722,0)=" . ; increment study uid count for PACS lookup, if needed"
^XMB(3.9,145834,2,4723,0)="""RTN"",""MAGDSTA8"",35,0)"
^XMB(3.9,145834,2,4724,0)=" . S ^(0)=($G(^TMP(""MAG"",$J,""UIDS"",""VISTA"",0))+1)_"" ; legacy study count"""
^XMB(3.9,145834,2,4725,0)="""RTN"",""MAGDSTA8"",36,0)"
^XMB(3.9,145834,2,4726,0)=" . Q"
^XMB(3.9,145834,2,4727,0)="""RTN"",""MAGDSTA8"",37,0)"
^XMB(3.9,145834,2,4728,0)=" S I=0 ; skip zero-node of group multiple"
^XMB(3.9,145834,2,4729,0)="""RTN"",""MAGDSTA8"",38,0)"
^XMB(3.9,145834,2,4730,0)=" F  S I=$O(^MAG(2005,GROUPIEN,1,I)) Q:'I  D"
^XMB(3.9,145834,2,4731,0)="""RTN"",""MAGDSTA8"",39,0)"
^XMB(3.9,145834,2,4732,0)=" . S Y=$G(^MAG(2005,GROUPIEN,1,I,0))"
^XMB(3.9,145834,2,4733,0)="""RTN"",""MAGDSTA8"",40,0)"
^XMB(3.9,145834,2,4734,0)=" . S IMAGEIEN=$P(Y,""^"",1)"
^XMB(3.9,145834,2,4735,0)="""RTN"",""MAGDSTA8"",41,0)"
^XMB(3.9,145834,2,4736,0)=" . S Z=$G(^MAG(2005,IMAGEIEN,""PACS"")),SERIESUID=$G(^(""SERIESUID""))"
^XMB(3.9,145834,2,4737,0)="""RTN"",""MAGDSTA8"",42,0)"
^XMB(3.9,145834,2,4738,0)=" . S SOPUID=$P(Z,""^"",1)"
^XMB(3.9,145834,2,4739,0)="""RTN"",""MAGDSTA8"",43,0)"
^XMB(3.9,145834,2,4740,0)=" . ; require both series instance uid and sop instance uid"
^XMB(3.9,145834,2,4741,0)="""RTN"",""MAGDSTA8"",44,0)"
^XMB(3.9,145834,2,4742,0)=" . Q:SERIESUID=""""  Q:SOPUID=""""  ; can't do PACS lookup"
^XMB(3.9,145834,2,4743,0)="""RTN"",""MAGDSTA8"",45,0)"
^XMB(3.9,145834,2,4744,0)=" . D SERIES(VISTASTUDYUID,SERIESUID,.SERIESCOUNT)"
^XMB(3.9,145834,2,4745,0)="""RTN"",""MAGDSTA8"",46,0)"
^XMB(3.9,145834,2,4746,0)=" . D IMAGE(VISTASTUDYUID,SERIESUID,SOPUID,.IMAGECOUNT)"
^XMB(3.9,145834,2,4747,0)="""RTN"",""MAGDSTA8"",47,0)"
^XMB(3.9,145834,2,4748,0)=" . Q"
^XMB(3.9,145834,2,4749,0)="""RTN"",""MAGDSTA8"",48,0)"
^XMB(3.9,145834,2,4750,0)=" Q"
^XMB(3.9,145834,2,4751,0)="""RTN"",""MAGDSTA8"",49,0)"
^XMB(3.9,145834,2,4752,0)=" ;"
^XMB(3.9,145834,2,4753,0)="""RTN"",""MAGDSTA8"",50,0)"
^XMB(3.9,145834,2,4754,0)="NEWSOPDB(ACNUMB,SERIESCOUNT,IMAGECOUNT) ; look for UIDs in the P34 database for the new SOP Classes"
^XMB(3.9,145834,2,4755,0)="""RTN"",""MAGDSTA8"",51,0)"
^XMB(3.9,145834,2,4756,0)=" ; Rules:"
^XMB(3.9,145834,2,4757,0)="""RTN"",""MAGDSTA8"",52,0)"
^XMB(3.9,145834,2,4758,0)=" ; 1) the Attribute On File field is not checked at all."
^XMB(3.9,145834,2,4759,0)="""RTN"",""MAGDSTA8"",53,0)"
^XMB(3.9,145834,2,4760,0)=" ; 2) for the Procedure Reference file (#2005.61), there has to be a pointer to the Patient"
^XMB(3.9,145834,2,4761,0)="""RTN"",""MAGDSTA8"",54,0)"
^XMB(3.9,145834,2,4762,0)=" ;    Reference file (#2005.6) and the patient id type in file #2005.6 needs to be ""DFN""."
^XMB(3.9,145834,2,4763,0)="""RTN"",""MAGDSTA8"",55,0)"
^XMB(3.9,145834,2,4764,0)=" ; 3) for the Image Study file (#2005.62), the study must be ""accessible"" and AOF"
^XMB(3.9,145834,2,4765,0)="""RTN"",""MAGDSTA8"",56,0)"
^XMB(3.9,145834,2,4766,0)=" ; 4) for the Image Series file (#2006.63), the series must be  ""accessible"" and AOF"
^XMB(3.9,145834,2,4767,0)="""RTN"",""MAGDSTA8"",57,0)"
^XMB(3.9,145834,2,4768,0)=" ; 5) for the SOP Instance file (""2006.64), the SOP instance must be ""accessible"" and AOF"
^XMB(3.9,145834,2,4769,0)="""RTN"",""MAGDSTA8"",58,0)"
^XMB(3.9,145834,2,4770,0)=" ;"
^XMB(3.9,145834,2,4771,0)="""RTN"",""MAGDSTA8"",59,0)"
^XMB(3.9,145834,2,4772,0)=" ; Rules 1, 2, and 3 are from the logic in ADD1STD^MAGDQR74"
^XMB(3.9,145834,2,4773,0)="""RTN"",""MAGDSTA8"",60,0)"
^XMB(3.9,145834,2,4774,0)=" ; Rules 4 and 5 are from the logic in STYSERKT^MAGVD010"
^XMB(3.9,145834,2,4775,0)="""RTN"",""MAGDSTA8"",61,0)"
^XMB(3.9,145834,2,4776,0)=" ;  "
^XMB(3.9,145834,2,4777,0)="""RTN"",""MAGDSTA8"",62,0)"
^XMB(3.9,145834,2,4778,0)=" N PROCIX,SERIESDATA0,SERIESIX,SERIESUID,STUDYDATA0,STUDYIX"
^XMB(3.9,145834,2,4779,0)="""RTN"",""MAGDSTA8"",63,0)"
^XMB(3.9,145834,2,4780,0)=" N SOPDATA0,SOPIX,SOPUID,VISTASTUDYUID"
^XMB(3.9,145834,2,4781,0)="""RTN"",""MAGDSTA8"",64,0)"
^XMB(3.9,145834,2,4782,0)=" ;"
^XMB(3.9,145834,2,4783,0)="""RTN"",""MAGDSTA8"",65,0)"
^XMB(3.9,145834,2,4784,0)=" S (SERIESCOUNT,IMAGECOUNT)=0 ; want series/image counts for this accession number"
^XMB(3.9,145834,2,4785,0)="""RTN"",""MAGDSTA8"",66,0)"
^XMB(3.9,145834,2,4786,0)=" I $G(ACNUMB)="""" Q  ; invoked without an accession number"
^XMB(3.9,145834,2,4787,0)="""RTN"",""MAGDSTA8"",67,0)"
^XMB(3.9,145834,2,4788,0)=" ;"
^XMB(3.9,145834,2,4789,0)="""RTN"",""MAGDSTA8"",68,0)"
^XMB(3.9,145834,2,4790,0)=" S PROCIX="""" ; procedure level indexed by accession number"
^XMB(3.9,145834,2,4791,0)="""RTN"",""MAGDSTA8"",69,0)"
^XMB(3.9,145834,2,4792,0)=" F  S PROCIX=$O(^MAGV(2005.61,""B"",ACNUMB,PROCIX)) Q:'PROCIX  D"
^XMB(3.9,145834,2,4793,0)="""RTN"",""MAGDSTA8"",70,0)"
^XMB(3.9,145834,2,4794,0)=" . I $$PROBLEM61(PROCIX) Q  ; patient not available - quit"
^XMB(3.9,145834,2,4795,0)="""RTN"",""MAGDSTA8"",71,0)"
^XMB(3.9,145834,2,4796,0)=" . ;"
^XMB(3.9,145834,2,4797,0)="""RTN"",""MAGDSTA8"",72,0)"
^XMB(3.9,145834,2,4798,0)=" . S STUDYIX="""" ; study level"
^XMB(3.9,145834,2,4799,0)="""RTN"",""MAGDSTA8"",73,0)"
^XMB(3.9,145834,2,4800,0)=" . F  S STUDYIX=$O(^MAGV(2005.62,""C"",PROCIX,STUDYIX)) Q:'STUDYIX  D"
^XMB(3.9,145834,2,4801,0)="""RTN"",""MAGDSTA8"",74,0)"
^XMB(3.9,145834,2,4802,0)=" . . I $$PROBLEM62(STUDYIX) Q  ; study not available - quit"
^XMB(3.9,145834,2,4803,0)="""RTN"",""MAGDSTA8"",75,0)"
^XMB(3.9,145834,2,4804,0)=" . . S STUDYDATA0=$G(^MAGV(2005.62,STUDYIX,0))"
^XMB(3.9,145834,2,4805,0)="""RTN"",""MAGDSTA8"",76,0)"
^XMB(3.9,145834,2,4806,0)=" . . S VISTASTUDYUID=$P(STUDYDATA0,""^"",1)"
^XMB(3.9,145834,2,4807,0)="""RTN"",""MAGDSTA8"",77,0)"
^XMB(3.9,145834,2,4808,0)=" . . S ^(0)=($G(^TMP(""MAG"",$J,""UIDS"",""VISTA"",0))+1)_"" ; new sop class db study count"" ; increment study count"
^XMB(3.9,145834,2,4809,0)="""RTN"",""MAGDSTA8"",78,0)"
^XMB(3.9,145834,2,4810,0)=" . . ;"
^XMB(3.9,145834,2,4811,0)="""RTN"",""MAGDSTA8"",79,0)"
^XMB(3.9,145834,2,4812,0)=" . . S SERIESIX="""" ; series level"
^XMB(3.9,145834,2,4813,0)="""RTN"",""MAGDSTA8"",80,0)"
^XMB(3.9,145834,2,4814,0)=" . . F  S SERIESIX=$O(^MAGV(2005.63,""C"",STUDYIX,SERIESIX)) Q:'SERIESIX  D"
^XMB(3.9,145834,2,4815,0)="""RTN"",""MAGDSTA8"",81,0)"
^XMB(3.9,145834,2,4816,0)=" . . . I $$PROBLEM63(SERIESIX) Q  ; if the series is not available, don't count it - quit"
^XMB(3.9,145834,2,4817,0)="""RTN"",""MAGDSTA8"",82,0)"
^XMB(3.9,145834,2,4818,0)=" . . . S SERIESDATA0=$G(^MAGV(2005.63,SERIESIX,0))"
^XMB(3.9,145834,2,4819,0)="""RTN"",""MAGDSTA8"",83,0)"
^XMB(3.9,145834,2,4820,0)=" . . . S SERIESUID=$P(SERIESDATA0,""^"",1)"
^XMB(3.9,145834,2,4821,0)="""RTN"",""MAGDSTA8"",84,0)"
^XMB(3.9,145834,2,4822,0)=" . . . D SERIES(VISTASTUDYUID,SERIESUID,.SERIESCOUNT)"
^XMB(3.9,145834,2,4823,0)="""RTN"",""MAGDSTA8"",85,0)"
^XMB(3.9,145834,2,4824,0)=" . . . ;"
^XMB(3.9,145834,2,4825,0)="""RTN"",""MAGDSTA8"",86,0)"
^XMB(3.9,145834,2,4826,0)=" . . . S SOPIX="""" ; sop instance level"
^XMB(3.9,145834,2,4827,0)="""RTN"",""MAGDSTA8"",87,0)"
^XMB(3.9,145834,2,4828,0)=" . . . F  S SOPIX=$O(^MAGV(2005.64,""C"",SERIESIX,SOPIX)) Q:'SOPIX  D"
^XMB(3.9,145834,2,4829,0)="""RTN"",""MAGDSTA8"",88,0)"
^XMB(3.9,145834,2,4830,0)=" . . . . I $$PROBLEM64(SOPIX) Q  ; if the sop instance is not available, don't count it - quit"
^XMB(3.9,145834,2,4831,0)="""RTN"",""MAGDSTA8"",89,0)"
^XMB(3.9,145834,2,4832,0)=" . . . . S SOPDATA0=^MAGV(2005.64,SOPIX,0)"
^XMB(3.9,145834,2,4833,0)="""RTN"",""MAGDSTA8"",90,0)"
^XMB(3.9,145834,2,4834,0)=" . . . . S SOPUID=$P(SOPDATA0,""^"",1)"
^XMB(3.9,145834,2,4835,0)="""RTN"",""MAGDSTA8"",91,0)"
^XMB(3.9,145834,2,4836,0)=" . . . . ;"
^XMB(3.9,145834,2,4837,0)="""RTN"",""MAGDSTA8"",92,0)"
^XMB(3.9,145834,2,4838,0)=" . . . . S IMAGEIX="""" ; image instance level"
^XMB(3.9,145834,2,4839,0)="""RTN"",""MAGDSTA8"",93,0)"
^XMB(3.9,145834,2,4840,0)=" . . . . F  S IMAGEIX=$O(^MAGV(2005.65,""C"",SOPIX,IMAGEIX)) Q:'IMAGEIX  D"
^XMB(3.9,145834,2,4841,0)="""RTN"",""MAGDSTA8"",94,0)"
^XMB(3.9,145834,2,4842,0)=" . . . . . I $$PROBLEM65(IMAGEIX) Q  ; if the original image is not available, don't count it - quit"
^XMB(3.9,145834,2,4843,0)="""RTN"",""MAGDSTA8"",95,0)"
