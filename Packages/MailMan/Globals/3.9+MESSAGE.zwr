^XMB(3.9,145834,2,506,0)="^8994.03^18^18^3050614^"
^XMB(3.9,145834,2,507,0)="""KRN"",8994,1844,3,1,0)"
^XMB(3.9,145834,2,508,0)="The first element of the output array indicates whether there"
^XMB(3.9,145834,2,509,0)="""KRN"",8994,1844,3,2,0)"
^XMB(3.9,145834,2,510,0)="are any images to be transmitted."
^XMB(3.9,145834,2,511,0)="""KRN"",8994,1844,3,3,0)"
^XMB(3.9,145834,2,512,0)="If there are none, or if there is an error in one or more input parameters,"
^XMB(3.9,145834,2,513,0)="""KRN"",8994,1844,3,4,0)"
^XMB(3.9,145834,2,514,0)="OUT(1) will reflect this. Otherwise:"
^XMB(3.9,145834,2,515,0)="""KRN"",8994,1844,3,5,0)"
^XMB(3.9,145834,2,516,0)=" OUT(1) = 1"
^XMB(3.9,145834,2,517,0)="""KRN"",8994,1844,3,6,0)"
^XMB(3.9,145834,2,518,0)=" OUT(2) = New value for D0"
^XMB(3.9,145834,2,519,0)="""KRN"",8994,1844,3,7,0)"
^XMB(3.9,145834,2,520,0)=" OUT(3) = New value for D1"
^XMB(3.9,145834,2,521,0)="""KRN"",8994,1844,3,8,0)"
^XMB(3.9,145834,2,522,0)=" OUT(4) = Destination Application"
^XMB(3.9,145834,2,523,0)="""KRN"",8994,1844,3,9,0)"
^XMB(3.9,145834,2,524,0)=" OUT(5) = Group"
^XMB(3.9,145834,2,525,0)="""KRN"",8994,1844,3,10,0)"
^XMB(3.9,145834,2,526,0)=" OUT(6) = Accession number"
