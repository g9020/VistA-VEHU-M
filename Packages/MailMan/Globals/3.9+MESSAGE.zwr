^XMB(3.9,144657,2,963,0)="""RTN"",""IBCNBAA"",185,0)"
^XMB(3.9,144657,2,964,0)=" S DIR(""?"",4)=""Enter No to create a new ""_IBDESC_"" policy if the Patient Registration entry's """
