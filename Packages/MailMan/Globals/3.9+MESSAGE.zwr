^XMB(3.9,144657,2,9655,0)="""RTN"",""IBJPI"",96,0)"
^XMB(3.9,144657,2,9656,0)=" S ELINE=$$SET(""  eIV Settings "","""",ELINE,1)"
^XMB(3.9,144657,2,9657,0)="""RTN"",""IBJPI"",97,0)"
^XMB(3.9,144657,2,9658,0)=" S ELINE=$$SET(""               Medicare Payer: "",$$GET1^DIQ(350.9,""1,"",51.25),ELINE,1)"
^XMB(3.9,144657,2,9659,0)="""RTN"",""IBJPI"",98,0)"
^XMB(3.9,144657,2,9660,0)=" ;IB*702/TAZ - Added display for EIV NO GRP NUM A/U"
^XMB(3.9,144657,2,9661,0)="""RTN"",""IBJPI"",99,0)"
^XMB(3.9,144657,2,9662,0)=" ;S ELINE=STRTLN"
^XMB(3.9,144657,2,9663,0)="""RTN"",""IBJPI"",100,0)"
