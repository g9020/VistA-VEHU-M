^XMB(3.9,145838,2,1036,0)=" S LIST(""FBSH REINSTATE AUTH"")=""@"""
^XMB(3.9,145838,2,1037,0)="""RTN"",""FBP192R"",38,0)"
^XMB(3.9,145838,2,1038,0)=" S LIST(""FBUC ALL CLAIMS OUTPUT"")=""@"""
^XMB(3.9,145838,2,1039,0)="""RTN"",""FBP192R"",39,0)"
^XMB(3.9,145838,2,1040,0)=" S LIST(""FBUC INITIATE APPEAL"")=""@"""
^XMB(3.9,145838,2,1041,0)="""RTN"",""FBP192R"",40,0)"
