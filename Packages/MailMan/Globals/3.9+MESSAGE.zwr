^XMB(3.9,145839,2,335,0)="""RTN"",""TIUCCHL7UT"",44,0)"
^XMB(3.9,145839,2,336,0)=" ;S HLA(""HLA"",1)=""MSA|AE|""_$G(MSGN)_""|""_$G(USERMAIL)_"" ""_$G(NAKMSG)_""|||""_$G(ICN)_""^""_$G(PATNAME)_""^""_SITE_""^""_CONID_""^""_APTTM"
^XMB(3.9,145839,2,337,0)="""RTN"",""TIUCCHL7UT"",45,0)"
^XMB(3.9,145839,2,338,0)=" S HLA(""HLA"",1)=""MSA""_HL(""FS"")_""AE""_HL(""FS"")_$G(MSGID)_HL(""FS"")_$G(TIUEMAIL)_"" ""_$G(MSGTEXT)_HL(""FS"")_HL(""FS"")_HL(""FS"")_$G(ICN)_""^""_$G(TIU(""PTNAME""))_""^""_SITE_""^""_CONID_""^""_$$FMTHL7^XLFDT($$NOW^XLFDT())"
