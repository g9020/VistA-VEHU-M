^XMB(3.9,145834,2,6543,0)="""RTN"",""MAGDSTAS"",161,0)"
^XMB(3.9,145834,2,6544,0)=" E  I SCANMODE=""NUMBER"" D"
^XMB(3.9,145834,2,6545,0)="""RTN"",""MAGDSTAS"",162,0)"
^XMB(3.9,145834,2,6546,0)="  . D SETONES(+STARTIEN,+STUDYIEN)"
^XMB(3.9,145834,2,6547,0)="""RTN"",""MAGDSTAS"",163,0)"
^XMB(3.9,145834,2,6548,0)=" . Q"
^XMB(3.9,145834,2,6549,0)="""RTN"",""MAGDSTAS"",164,0)"
^XMB(3.9,145834,2,6550,0)=" D STATS(RUNNUMBER,.STATS)"
