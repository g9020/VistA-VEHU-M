^XMB(3.9,145833,2,716,0)=" ;;5.3;Scheduling;**922**;13 Aug 1993;Build 0"
^XMB(3.9,145833,2,717,0)="""RTN"",""SDES2UTDT"",3,0)"
^XMB(3.9,145833,2,718,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
^XMB(3.9,145833,2,719,0)="""RTN"",""SDES2UTDT"",4,0)"
^XMB(3.9,145833,2,720,0)=" ;"
^XMB(3.9,145833,2,721,0)="""RTN"",""SDES2UTDT"",5,0)"
^XMB(3.9,145833,2,722,0)="FMTISO(SDGMT,SDFMDT,SDCLINIC) ;convert internal fileman format to extended GMT"
^XMB(3.9,145833,2,723,0)="""RTN"",""SDES2UTDT"",6,0)"
^XMB(3.9,145833,2,724,0)=" ;INPUT  SDFMDT - Fileman date/time"
^XMB(3.9,145833,2,725,0)="""RTN"",""SDES2UTDT"",7,0)"
^XMB(3.9,145833,2,726,0)=" ;       SDCLINIC - OPT IEN from file 44"
^XMB(3.9,145833,2,727,0)="""RTN"",""SDES2UTDT"",8,0)"
^XMB(3.9,145833,2,728,0)=" ;OUTPUT -1 error occurred in translation"
^XMB(3.9,145833,2,729,0)="""RTN"",""SDES2UTDT"",9,0)"
^XMB(3.9,145833,2,730,0)=" ;       GMT date/time in ISO 8601 extended format (No Errors)"
^XMB(3.9,145833,2,731,0)="""RTN"",""SDES2UTDT"",10,0)"
^XMB(3.9,145833,2,732,0)=" ;"
^XMB(3.9,145833,2,733,0)="""RTN"",""SDES2UTDT"",11,0)"
^XMB(3.9,145833,2,734,0)=" N SDDTM,SDTIME,SDOFFSET,OFFSET"
^XMB(3.9,145833,2,735,0)="""RTN"",""SDES2UTDT"",12,0)"
^XMB(3.9,145833,2,736,0)=" I +$G(SDFMDT)=0 S SDGMT="""" Q"
^XMB(3.9,145833,2,737,0)="""RTN"",""SDES2UTDT"",13,0)"
^XMB(3.9,145833,2,738,0)=" D FILEMANTOHL7^SDES2UTIL(.SDFMDT,.SDDTM)"
^XMB(3.9,145833,2,739,0)="""RTN"",""SDES2UTDT"",14,0)"
^XMB(3.9,145833,2,740,0)=" I SDDTM<0 S SDGMT=-1 Q"
^XMB(3.9,145833,2,741,0)="""RTN"",""SDES2UTDT"",15,0)"
^XMB(3.9,145833,2,742,0)=" S SDCLINIC=$G(SDCLINIC)"
^XMB(3.9,145833,2,743,0)="""RTN"",""SDES2UTDT"",16,0)"
^XMB(3.9,145833,2,744,0)=" ;Extract out date and convert to ISO 8601 extended format"
