^XMB(3.9,145837,2,209,0)="""QUES"",""XPO1"",""??"")"
^XMB(3.9,145837,2,210,0)="^D MENU^XPDH"
^XMB(3.9,145837,2,211,0)="""QUES"",""XPO1"",""A"")"
^XMB(3.9,145837,2,212,0)="Want KIDS to Rebuild Menu Trees Upon Completion of Install"
