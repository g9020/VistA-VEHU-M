^XMB(3.9,145837,2,450,0)=" . . . S NCOUNT=NCOUNT+1,@FDA@(8992.112,""+""_NCOUNT_IENVAL,.01)=XQADATIM,@FDA@(8992.112,""+""_NCOUNT_IENVAL,.02)=SUBSCRPN I $G(XQACOMNT)'="""" S @FDA@(8992.112,""+""_NCOUNT_IENVAL,1.01)=XQACOMNT"
