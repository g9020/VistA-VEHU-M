^XMB(3.9,145834,2,1677,0)="""RTN"",""MAGDRPC4"",12,0)"
^XMB(3.9,145834,2,1678,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,1679,0)="""RTN"",""MAGDRPC4"",13,0)"
^XMB(3.9,145834,2,1680,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,1681,0)="""RTN"",""MAGDRPC4"",14,0)"
^XMB(3.9,145834,2,1682,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,1683,0)="""RTN"",""MAGDRPC4"",15,0)"
^XMB(3.9,145834,2,1684,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,1685,0)="""RTN"",""MAGDRPC4"",16,0)"
^XMB(3.9,145834,2,1686,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,1687,0)="""RTN"",""MAGDRPC4"",17,0)"
^XMB(3.9,145834,2,1688,0)=" ;;"
^XMB(3.9,145834,2,1689,0)="""RTN"",""MAGDRPC4"",18,0)"
^XMB(3.9,145834,2,1690,0)=" Q"
^XMB(3.9,145834,2,1691,0)="""RTN"",""MAGDRPC4"",19,0)"
^XMB(3.9,145834,2,1692,0)=" ;"
^XMB(3.9,145834,2,1693,0)="""RTN"",""MAGDRPC4"",20,0)"
^XMB(3.9,145834,2,1694,0)="LOOKUP(OUT,NUMBER) ; RPC = MAG DICOM LOOKUP STUDY"
^XMB(3.9,145834,2,1695,0)="""RTN"",""MAGDRPC4"",21,0)"
^XMB(3.9,145834,2,1696,0)=" ; Look Up for Radiology, Consults, and Lab (anatomic pathology)"
^XMB(3.9,145834,2,1697,0)="""RTN"",""MAGDRPC4"",22,0)"
^XMB(3.9,145834,2,1698,0)=" N ACNUMB ;--- Accession Number"
^XMB(3.9,145834,2,1699,0)="""RTN"",""MAGDRPC4"",23,0)"
^XMB(3.9,145834,2,1700,0)=" N CPTCODE ;-- CPT code for the procedure"
^XMB(3.9,145834,2,1701,0)="""RTN"",""MAGDRPC4"",24,0)"
^XMB(3.9,145834,2,1702,0)=" N CPTNAME ;-- CPT name for the procedure"
^XMB(3.9,145834,2,1703,0)="""RTN"",""MAGDRPC4"",25,0)"
^XMB(3.9,145834,2,1704,0)=" N DFN ;------ Patient pointer"
^XMB(3.9,145834,2,1705,0)="""RTN"",""MAGDRPC4"",26,0)"
^XMB(3.9,145834,2,1706,0)=" N EXAMSTS ;-- Exam status (don't post images to CANCELLED exams)"
^XMB(3.9,145834,2,1707,0)="""RTN"",""MAGDRPC4"",27,0)"
^XMB(3.9,145834,2,1708,0)=" N EXAMTYPE ;- Type of exam (Rad,Con, or Lab)"
^XMB(3.9,145834,2,1709,0)="""RTN"",""MAGDRPC4"",28,0)"
^XMB(3.9,145834,2,1710,0)=" N GMRCIEN ;-- Pointer for GMRC"
^XMB(3.9,145834,2,1711,0)="""RTN"",""MAGDRPC4"",29,0)"
^XMB(3.9,145834,2,1712,0)=" N INFO ;----- return array from $$ACCRPT^RAAPI()"
^XMB(3.9,145834,2,1713,0)="""RTN"",""MAGDRPC4"",30,0)"
^XMB(3.9,145834,2,1714,0)=" N PROCIEN ;-- Radiology procedure IEN in ^RAMIS(71)"
^XMB(3.9,145834,2,1715,0)="""RTN"",""MAGDRPC4"",31,0)"
^XMB(3.9,145834,2,1716,0)=" N RAA ;------ Radiology array (for $$ACCFIND)"
^XMB(3.9,145834,2,1717,0)="""RTN"",""MAGDRPC4"",32,0)"
^XMB(3.9,145834,2,1718,0)=" N RAIX ;----- cross reference subscript for case number lookup"
^XMB(3.9,145834,2,1719,0)="""RTN"",""MAGDRPC4"",33,0)"
^XMB(3.9,145834,2,1720,0)=" N RADFN ;---- first level subscript in ^RADPT"
^XMB(3.9,145834,2,1721,0)="""RTN"",""MAGDRPC4"",34,0)"
^XMB(3.9,145834,2,1722,0)=" N RADTI ;---- second level subscript in ^RADPT (after ""DT"")"
^XMB(3.9,145834,2,1723,0)="""RTN"",""MAGDRPC4"",35,0)"
^XMB(3.9,145834,2,1724,0)=" N RACNI ;---- third level subscript in ^RADPT (after ""P"")"
^XMB(3.9,145834,2,1725,0)="""RTN"",""MAGDRPC4"",36,0)"
^XMB(3.9,145834,2,1726,0)=" N RARPT ;---- Radiology Report pointer"
^XMB(3.9,145834,2,1727,0)="""RTN"",""MAGDRPC4"",37,0)"
^XMB(3.9,145834,2,1728,0)=" N I,LIST,NOUT,X,Y,Z"
^XMB(3.9,145834,2,1729,0)="""RTN"",""MAGDRPC4"",38,0)"
^XMB(3.9,145834,2,1730,0)=" ;"
^XMB(3.9,145834,2,1731,0)="""RTN"",""MAGDRPC4"",39,0)"
^XMB(3.9,145834,2,1732,0)=" K OUT S NOUT=1"
^XMB(3.9,145834,2,1733,0)="""RTN"",""MAGDRPC4"",40,0)"
^XMB(3.9,145834,2,1734,0)=" I $G(NUMBER)="""" S OUT(1)=""-1,No Case or Consult Number Specified"" Q"
^XMB(3.9,145834,2,1735,0)="""RTN"",""MAGDRPC4"",41,0)"
^XMB(3.9,145834,2,1736,0)=" I $E(NUMBER,2)=""`"" D  Q"
^XMB(3.9,145834,2,1737,0)="""RTN"",""MAGDRPC4"",42,0)"
^XMB(3.9,145834,2,1738,0)=" . ; lookup the image by the IEN"
^XMB(3.9,145834,2,1739,0)="""RTN"",""MAGDRPC4"",43,0)"
^XMB(3.9,145834,2,1740,0)=" . D IENLOOK^MAGDRPC9"
^XMB(3.9,145834,2,1741,0)="""RTN"",""MAGDRPC4"",44,0)"
^XMB(3.9,145834,2,1742,0)=" . Q"
^XMB(3.9,145834,2,1743,0)="""RTN"",""MAGDRPC4"",45,0)"
^XMB(3.9,145834,2,1744,0)=" ;"
^XMB(3.9,145834,2,1745,0)="""RTN"",""MAGDRPC4"",46,0)"
^XMB(3.9,145834,2,1746,0)=" S EXAMTYPE=$E(NUMBER,1)"
^XMB(3.9,145834,2,1747,0)="""RTN"",""MAGDRPC4"",47,0)"
^XMB(3.9,145834,2,1748,0)=" I ""RCL""[EXAMTYPE S NUMBER=$E(NUMBER,2,$L(NUMBER))"
^XMB(3.9,145834,2,1749,0)="""RTN"",""MAGDRPC4"",48,0)"
^XMB(3.9,145834,2,1750,0)=" E  S OUT(1)=""-2,Need to specify Radiology, Consults, or Lab"" Q"
^XMB(3.9,145834,2,1751,0)="""RTN"",""MAGDRPC4"",49,0)"
^XMB(3.9,145834,2,1752,0)=" K DFN"
^XMB(3.9,145834,2,1753,0)="""RTN"",""MAGDRPC4"",50,0)"
^XMB(3.9,145834,2,1754,0)=" I EXAMTYPE=""R"" D"
^XMB(3.9,145834,2,1755,0)="""RTN"",""MAGDRPC4"",51,0)"
^XMB(3.9,145834,2,1756,0)=" . D RADLKUP(.NOUT,.OUT,.ACNUMB,NUMBER) ; radiology lookup"
^XMB(3.9,145834,2,1757,0)="""RTN"",""MAGDRPC4"",52,0)"
^XMB(3.9,145834,2,1758,0)=" . Q"
^XMB(3.9,145834,2,1759,0)="""RTN"",""MAGDRPC4"",53,0)"
^XMB(3.9,145834,2,1760,0)=" E  I EXAMTYPE=""C"" D"
^XMB(3.9,145834,2,1761,0)="""RTN"",""MAGDRPC4"",54,0)"
^XMB(3.9,145834,2,1762,0)=" . D CONLKUP(.NOUT,.OUT,.ACNUMB,NUMBER) ; CPRS consult/procedure lookup"
^XMB(3.9,145834,2,1763,0)="""RTN"",""MAGDRPC4"",55,0)"
^XMB(3.9,145834,2,1764,0)=" . Q"
^XMB(3.9,145834,2,1765,0)="""RTN"",""MAGDRPC4"",56,0)"
^XMB(3.9,145834,2,1766,0)=" E  D"
^XMB(3.9,145834,2,1767,0)="""RTN"",""MAGDRPC4"",57,0)"
^XMB(3.9,145834,2,1768,0)=" . D LABLKUP(.NOUT,.OUT,.ACNUMB,NUMBER) ; anatomic pathology lab lookup"
^XMB(3.9,145834,2,1769,0)="""RTN"",""MAGDRPC4"",58,0)"
^XMB(3.9,145834,2,1770,0)=" . Q"
^XMB(3.9,145834,2,1771,0)="""RTN"",""MAGDRPC4"",59,0)"
^XMB(3.9,145834,2,1772,0)=" ;"
^XMB(3.9,145834,2,1773,0)="""RTN"",""MAGDRPC4"",60,0)"
^XMB(3.9,145834,2,1774,0)=" D NEWLKUP^MAGDRPCD(.NOUT,.OUT,ACNUMB) ; check if there are any DICOM objects in the new SOP Class database"
^XMB(3.9,145834,2,1775,0)="""RTN"",""MAGDRPC4"",61,0)"
^XMB(3.9,145834,2,1776,0)=" ;"
^XMB(3.9,145834,2,1777,0)="""RTN"",""MAGDRPC4"",62,0)"
^XMB(3.9,145834,2,1778,0)=" I '$D(OUT(1)) S OUT(1)=NOUT-1 ; allow error messages to be passed back in OUT(1)"
^XMB(3.9,145834,2,1779,0)="""RTN"",""MAGDRPC4"",63,0)"
^XMB(3.9,145834,2,1780,0)=" Q"
^XMB(3.9,145834,2,1781,0)="""RTN"",""MAGDRPC4"",64,0)"
^XMB(3.9,145834,2,1782,0)=" ;"
^XMB(3.9,145834,2,1783,0)="""RTN"",""MAGDRPC4"",65,0)"
^XMB(3.9,145834,2,1784,0)="RADLKUP(NOUT,OUT,ACNUMB,NUMBER) ; Radiology lookup"
^XMB(3.9,145834,2,1785,0)="""RTN"",""MAGDRPC4"",66,0)"
^XMB(3.9,145834,2,1786,0)=" S ACNUMB="""""
^XMB(3.9,145834,2,1787,0)="""RTN"",""MAGDRPC4"",67,0)"
^XMB(3.9,145834,2,1788,0)=" S RACNI=0 ; must get this value to find study"
^XMB(3.9,145834,2,1789,0)="""RTN"",""MAGDRPC4"",68,0)"
^XMB(3.9,145834,2,1790,0)=" I NUMBER?1N.N D  I 'RACNI S OUT(1)=""-14,Radiology case number not on file"" Q"
^XMB(3.9,145834,2,1791,0)="""RTN"",""MAGDRPC4"",69,0)"
^XMB(3.9,145834,2,1792,0)=" . ; Look for the patient/study in ^RADPT using the Radiology Case Number"
^XMB(3.9,145834,2,1793,0)="""RTN"",""MAGDRPC4"",70,0)"
^XMB(3.9,145834,2,1794,0)=" . N RAIX ;----- cross reference subscript for case number lookup "
^XMB(3.9,145834,2,1795,0)="""RTN"",""MAGDRPC4"",71,0)"
^XMB(3.9,145834,2,1796,0)=" . S RAIX=$S($D(^RADPT(""C"")):""C"",1:""AE"") ; for Radiology Patch RA*5*7"
^XMB(3.9,145834,2,1797,0)="""RTN"",""MAGDRPC4"",72,0)"
^XMB(3.9,145834,2,1798,0)=" . S RAIX=$S(NUMBER[""-"":""ADC"",1:RAIX) ; select the cross-reference"
^XMB(3.9,145834,2,1799,0)="""RTN"",""MAGDRPC4"",73,0)"
^XMB(3.9,145834,2,1800,0)=" . S RADFN=$O(^RADPT(RAIX,NUMBER,"""")) Q:'RADFN"
^XMB(3.9,145834,2,1801,0)="""RTN"",""MAGDRPC4"",74,0)"
^XMB(3.9,145834,2,1802,0)=" . S RADTI=$O(^RADPT(RAIX,NUMBER,RADFN,""""))"
^XMB(3.9,145834,2,1803,0)="""RTN"",""MAGDRPC4"",75,0)"
^XMB(3.9,145834,2,1804,0)=" . S RACNI=$O(^RADPT(RAIX,NUMBER,RADFN,RADTI,""""))"
^XMB(3.9,145834,2,1805,0)="""RTN"",""MAGDRPC4"",76,0)"
^XMB(3.9,145834,2,1806,0)=" . Q"
^XMB(3.9,145834,2,1807,0)="""RTN"",""MAGDRPC4"",77,0)"
^XMB(3.9,145834,2,1808,0)=" E  D  I 'RACNI S OUT(1)=""-15,Radiology accession number not on file"" Q"
^XMB(3.9,145834,2,1809,0)="""RTN"",""MAGDRPC4"",78,0)"
^XMB(3.9,145834,2,1810,0)=" . ; lookup using Radiololgy Package API "
^XMB(3.9,145834,2,1811,0)="""RTN"",""MAGDRPC4"",79,0)"
^XMB(3.9,145834,2,1812,0)=" . S X=$$ACCFIND^RAAPI(NUMBER,.RAA)"
^XMB(3.9,145834,2,1813,0)="""RTN"",""MAGDRPC4"",80,0)"
^XMB(3.9,145834,2,1814,0)=" . I X<0 Q"
^XMB(3.9,145834,2,1815,0)="""RTN"",""MAGDRPC4"",81,0)"
^XMB(3.9,145834,2,1816,0)=" . S Y=RAA(1)"
^XMB(3.9,145834,2,1817,0)="""RTN"",""MAGDRPC4"",82,0)"
^XMB(3.9,145834,2,1818,0)=" . S RADFN=$P(Y,""^"",1),RADTI=$P(Y,""^"",2),RACNI=$P(Y,""^"",3)"
^XMB(3.9,145834,2,1819,0)="""RTN"",""MAGDRPC4"",83,0)"
^XMB(3.9,145834,2,1820,0)=" . Q"
^XMB(3.9,145834,2,1821,0)="""RTN"",""MAGDRPC4"",84,0)"
^XMB(3.9,145834,2,1822,0)=" I '$D(^RADPT(RADFN,0)) S OUT(1)=""-12,No patient demographics file pointer"" Q"
^XMB(3.9,145834,2,1823,0)="""RTN"",""MAGDRPC4"",85,0)"
^XMB(3.9,145834,2,1824,0)=" S DFN=$P(^RADPT(RADFN,0),""^"",1)"
^XMB(3.9,145834,2,1825,0)="""RTN"",""MAGDRPC4"",86,0)"
^XMB(3.9,145834,2,1826,0)=" I '$G(DFN) S OUT(1)=""-13,Radiology exam not on file"" Q"
^XMB(3.9,145834,2,1827,0)="""RTN"",""MAGDRPC4"",87,0)"
^XMB(3.9,145834,2,1828,0)=" S EXAMSTS=$P($G(^RADPT(DFN,""DT"",RADTI,""P"",RACNI,0)),""^"",3)"
^XMB(3.9,145834,2,1829,0)="""RTN"",""MAGDRPC4"",88,0)"
^XMB(3.9,145834,2,1830,0)=" I 'EXAMSTS S OUT(1)=""-16,Radiology EXAM STATUS field not present"" Q"
^XMB(3.9,145834,2,1831,0)="""RTN"",""MAGDRPC4"",89,0)"
^XMB(3.9,145834,2,1832,0)=" I $$GET1^DIQ(72,EXAMSTS,3)=0  S OUT(1)=""-17,Radiology exam cancelled"" Q"
^XMB(3.9,145834,2,1833,0)="""RTN"",""MAGDRPC4"",90,0)"
^XMB(3.9,145834,2,1834,0)=" D:$D(^RADPT(DFN,""DT"",RADTI,0))  ; p305 PMK 03/30/2021"
^XMB(3.9,145834,2,1835,0)="""RTN"",""MAGDRPC4"",91,0)"
^XMB(3.9,145834,2,1836,0)=" . S RARPT=$P($G(^RADPT(DFN,""DT"",RADTI,""P"",RACNI,0)),""^"",17) Q:'RARPT"
^XMB(3.9,145834,2,1837,0)="""RTN"",""MAGDRPC4"",92,0)"
^XMB(3.9,145834,2,1838,0)=" . S X=$$ACCRPT^RAAPI(RARPT,.INFO)"
^XMB(3.9,145834,2,1839,0)="""RTN"",""MAGDRPC4"",93,0)"
^XMB(3.9,145834,2,1840,0)=" . I X<0 S OUT(1)=""-11,Radiology Problem: ""_X Q"
^XMB(3.9,145834,2,1841,0)="""RTN"",""MAGDRPC4"",94,0)"
^XMB(3.9,145834,2,1842,0)=" . S ACNUMB=INFO(1)"
^XMB(3.9,145834,2,1843,0)="""RTN"",""MAGDRPC4"",95,0)"
^XMB(3.9,145834,2,1844,0)=" . S I=0 F  S I=$O(^RARPT(RARPT,2005,I)) Q:'I  D"
^XMB(3.9,145834,2,1845,0)="""RTN"",""MAGDRPC4"",96,0)"
^XMB(3.9,145834,2,1846,0)=" . . S X=""74^""_RARPT_""^""_$P($G(^RARPT(RARPT,2005,I,0)),""^"",1)_""^""_ACNUMB"
^XMB(3.9,145834,2,1847,0)="""RTN"",""MAGDRPC4"",97,0)"
^XMB(3.9,145834,2,1848,0)=" . . S NOUT=NOUT+1,OUT(NOUT)=X"
^XMB(3.9,145834,2,1849,0)="""RTN"",""MAGDRPC4"",98,0)"
^XMB(3.9,145834,2,1850,0)=" . . Q"
^XMB(3.9,145834,2,1851,0)="""RTN"",""MAGDRPC4"",99,0)"
^XMB(3.9,145834,2,1852,0)=" . Q"
^XMB(3.9,145834,2,1853,0)="""RTN"",""MAGDRPC4"",100,0)"
^XMB(3.9,145834,2,1854,0)=" Q"
^XMB(3.9,145834,2,1855,0)="""RTN"",""MAGDRPC4"",101,0)"
^XMB(3.9,145834,2,1856,0)=" ;"
^XMB(3.9,145834,2,1857,0)="""RTN"",""MAGDRPC4"",102,0)"
^XMB(3.9,145834,2,1858,0)="CONLKUP(NOUT,OUT,ACNUMB,NUMBER) ; CPRS Consult/Procedure study lookup"
^XMB(3.9,145834,2,1859,0)="""RTN"",""MAGDRPC4"",103,0)"
^XMB(3.9,145834,2,1860,0)=" N MAGIEN,MAGPTR,REPORTF,REPORTI,TIUIEN,TIUPTR,TIUXIEN,X"
^XMB(3.9,145834,2,1861,0)="""RTN"",""MAGDRPC4"",104,0)"
^XMB(3.9,145834,2,1862,0)=" S X=$$GMRCIEN^MAGDFCNV(NUMBER) S GMRCIEN=$S(X:X,1:NUMBER)"
^XMB(3.9,145834,2,1863,0)="""RTN"",""MAGDRPC4"",105,0)"
^XMB(3.9,145834,2,1864,0)=" S ACNUMB=$$GMRCACN^MAGDFCNV(GMRCIEN)"
^XMB(3.9,145834,2,1865,0)="""RTN"",""MAGDRPC4"",106,0)"
^XMB(3.9,145834,2,1866,0)=" D"
^XMB(3.9,145834,2,1867,0)="""RTN"",""MAGDRPC4"",107,0)"
^XMB(3.9,145834,2,1868,0)=" . S DFN=$$GET1^DIQ(123,GMRCIEN,.02,""I"") Q:'DFN"
^XMB(3.9,145834,2,1869,0)="""RTN"",""MAGDRPC4"",108,0)"
^XMB(3.9,145834,2,1870,0)=" . S EXAMSTS=$$GET1^DIQ(123,GMRCIEN,8,""I"") ; check acceptable status"
^XMB(3.9,145834,2,1871,0)="""RTN"",""MAGDRPC4"",109,0)"
^XMB(3.9,145834,2,1872,0)=" . ; EXAMSTS=2 for COMPLETE, 5=PENDING, 6=ACTIVE, 8=SCHEDULED, STATUS=9 for PARTIAL RESULTS"
^XMB(3.9,145834,2,1873,0)="""RTN"",""MAGDRPC4"",110,0)"
^XMB(3.9,145834,2,1874,0)=" . I EXAMSTS'=2,EXAMSTS'=5,EXAMSTS'=6,EXAMSTS'=8,EXAMSTS'=9 D  Q"
^XMB(3.9,145834,2,1875,0)="""RTN"",""MAGDRPC4"",111,0)"
^XMB(3.9,145834,2,1876,0)=" . . S EXAMSTS=$$GET1^DIQ(123,GMRCIEN,8,""E"") ; get name of status"
^XMB(3.9,145834,2,1877,0)="""RTN"",""MAGDRPC4"",112,0)"
^XMB(3.9,145834,2,1878,0)=" . . S OUT(1)=""-4,Consult is ""_EXAMSTS Q"
^XMB(3.9,145834,2,1879,0)="""RTN"",""MAGDRPC4"",113,0)"
^XMB(3.9,145834,2,1880,0)=" . . Q"
^XMB(3.9,145834,2,1881,0)="""RTN"",""MAGDRPC4"",114,0)"
^XMB(3.9,145834,2,1882,0)=" . Q"
^XMB(3.9,145834,2,1883,0)="""RTN"",""MAGDRPC4"",115,0)"
^XMB(3.9,145834,2,1884,0)=" I $D(OUT(1)) Q  ; bad EXAMSTS"
^XMB(3.9,145834,2,1885,0)="""RTN"",""MAGDRPC4"",116,0)"
^XMB(3.9,145834,2,1886,0)=" I '$G(DFN) S OUT(1)=""-5,Consult/procedure not on file"" Q"
^XMB(3.9,145834,2,1887,0)="""RTN"",""MAGDRPC4"",117,0)"
^XMB(3.9,145834,2,1888,0)=" ; Find the images - they can be linked to TIU or imaging file 2006.5839"
^XMB(3.9,145834,2,1889,0)="""RTN"",""MAGDRPC4"",118,0)"
^XMB(3.9,145834,2,1890,0)=" S MAGPTR=0 ; find in ^MAG(2006.5839) - may not be in ^TIU yet"
^XMB(3.9,145834,2,1891,0)="""RTN"",""MAGDRPC4"",119,0)"
^XMB(3.9,145834,2,1892,0)=" F  S MAGPTR=$O(^MAG(2006.5839,""C"",123,GMRCIEN,MAGPTR)) Q:'MAGPTR  D"
^XMB(3.9,145834,2,1893,0)="""RTN"",""MAGDRPC4"",120,0)"
^XMB(3.9,145834,2,1894,0)=" . S X=^MAG(2006.5839,MAGPTR,0)"
^XMB(3.9,145834,2,1895,0)="""RTN"",""MAGDRPC4"",121,0)"
^XMB(3.9,145834,2,1896,0)=" . S X=$P(X,""^"",1)_""^""_$P(X,""^"",2)_""^""_$P(X,""^"",3)_""^""_ACNUMB"
^XMB(3.9,145834,2,1897,0)="""RTN"",""MAGDRPC4"",122,0)"
^XMB(3.9,145834,2,1898,0)=" . S NOUT=NOUT+1,OUT(NOUT)=X"
^XMB(3.9,145834,2,1899,0)="""RTN"",""MAGDRPC4"",123,0)"
^XMB(3.9,145834,2,1900,0)=" . Q"
^XMB(3.9,145834,2,1901,0)="""RTN"",""MAGDRPC4"",124,0)"
^XMB(3.9,145834,2,1902,0)=" ; also try to find images in ^TIU"
^XMB(3.9,145834,2,1903,0)="""RTN"",""MAGDRPC4"",125,0)"
^XMB(3.9,145834,2,1904,0)=" N I,RESULT,X"
^XMB(3.9,145834,2,1905,0)="""RTN"",""MAGDRPC4"",126,0)"
^XMB(3.9,145834,2,1906,0)=" D TIUALL^MAGDGMRC(GMRCIEN,.RESULT)"
^XMB(3.9,145834,2,1907,0)="""RTN"",""MAGDRPC4"",127,0)"
^XMB(3.9,145834,2,1908,0)=" S I="""" F  S I=$O(RESULT(I)) Q:I=""""  D"
^XMB(3.9,145834,2,1909,0)="""RTN"",""MAGDRPC4"",128,0)"
^XMB(3.9,145834,2,1910,0)=" . S X=""8925^""_$P(RESULT(I),""^"",1)_""^""_$P(RESULT(I),""^"",3)_""^""_$P(RESULT(I),""^"",2)"
^XMB(3.9,145834,2,1911,0)="""RTN"",""MAGDRPC4"",129,0)"
^XMB(3.9,145834,2,1912,0)=" . S NOUT=NOUT+1,OUT(NOUT)=X"
^XMB(3.9,145834,2,1913,0)="""RTN"",""MAGDRPC4"",130,0)"
^XMB(3.9,145834,2,1914,0)=" . Q"
^XMB(3.9,145834,2,1915,0)="""RTN"",""MAGDRPC4"",131,0)"
^XMB(3.9,145834,2,1916,0)=" Q"
^XMB(3.9,145834,2,1917,0)="""RTN"",""MAGDRPC4"",132,0)"
^XMB(3.9,145834,2,1918,0)=" ;"
^XMB(3.9,145834,2,1919,0)="""RTN"",""MAGDRPC4"",133,0)"
^XMB(3.9,145834,2,1920,0)="LABLKUP(NOUT,OUT,ACNUMB,NUMBER) ; Lab (Anatomic Pathology) study lookup"
^XMB(3.9,145834,2,1921,0)="""RTN"",""MAGDRPC4"",134,0)"
^XMB(3.9,145834,2,1922,0)=" N DFN,FILEDATA,LRDFN,LRI,LRSS,MAGIEN,MAGPTR,PARENTFILE,TIUIEN,TIUXIEN,X"
^XMB(3.9,145834,2,1923,0)="""RTN"",""MAGDRPC4"",135,0)"
^XMB(3.9,145834,2,1924,0)=" S ACNUMB=NUMBER D LABLKUP^MAGDIR8A"
^XMB(3.9,145834,2,1925,0)="""RTN"",""MAGDRPC4"",136,0)"
^XMB(3.9,145834,2,1926,0)=" I '$G(DFN) S OUT(1)=""-6,Anatomic Pathology case not on file"" Q"
^XMB(3.9,145834,2,1927,0)="""RTN"",""MAGDRPC4"",137,0)"
^XMB(3.9,145834,2,1928,0)=" D SUBFILES^MAGDIR9F(LRSS)"
^XMB(3.9,145834,2,1929,0)="""RTN"",""MAGDRPC4"",138,0)"
^XMB(3.9,145834,2,1930,0)=" ; Find the images - they can be linked to TIU or imaging file 2006.5838"
^XMB(3.9,145834,2,1931,0)="""RTN"",""MAGDRPC4"",139,0)"
^XMB(3.9,145834,2,1932,0)=" S MAGPTR=$O(^MAG(2006.5838,""C"",PARENTFILE,LRDFN,LRI,0))"
^XMB(3.9,145834,2,1933,0)="""RTN"",""MAGDRPC4"",140,0)"
^XMB(3.9,145834,2,1934,0)=" I MAGPTR D  Q  ; Found it in ^MAG(2006.5838) - not in ^TIU yet"
^XMB(3.9,145834,2,1935,0)="""RTN"",""MAGDRPC4"",141,0)"
^XMB(3.9,145834,2,1936,0)=" . S X=^MAG(2006.5838,MAGPTR,0)"
^XMB(3.9,145834,2,1937,0)="""RTN"",""MAGDRPC4"",142,0)"
^XMB(3.9,145834,2,1938,0)=" . ; separate the two subscripts that point to the study with a comma"
^XMB(3.9,145834,2,1939,0)="""RTN"",""MAGDRPC4"",143,0)"
^XMB(3.9,145834,2,1940,0)=" . S X=$P(X,""^"",1)_""^""_$P(X,""^"",2)_"",""_$P(X,""^"",3)_""^""_$P(X,""^"",4)_""^""_ACNUMB"
^XMB(3.9,145834,2,1941,0)="""RTN"",""MAGDRPC4"",144,0)"
^XMB(3.9,145834,2,1942,0)=" . S NOUT=NOUT+1,OUT(NOUT)=X"
^XMB(3.9,145834,2,1943,0)="""RTN"",""MAGDRPC4"",145,0)"
^XMB(3.9,145834,2,1944,0)=" . Q"
^XMB(3.9,145834,2,1945,0)="""RTN"",""MAGDRPC4"",146,0)"
^XMB(3.9,145834,2,1946,0)=" D  ; Otherwise find images in ^TIU"
^XMB(3.9,145834,2,1947,0)="""RTN"",""MAGDRPC4"",147,0)"
^XMB(3.9,145834,2,1948,0)=" . S TIUIEN=$$TIUIEN^MAGT7MA(LRSS,LRDFN,LRI)"
^XMB(3.9,145834,2,1949,0)="""RTN"",""MAGDRPC4"",148,0)"
^XMB(3.9,145834,2,1950,0)=" . I TIUIEN D"
^XMB(3.9,145834,2,1951,0)="""RTN"",""MAGDRPC4"",149,0)"
^XMB(3.9,145834,2,1952,0)=" . . S TIUXIEN=$O(^TIU(8925.91,""B"",TIUIEN,""""))"
^XMB(3.9,145834,2,1953,0)="""RTN"",""MAGDRPC4"",150,0)"
^XMB(3.9,145834,2,1954,0)=" . . I TIUXIEN D"
^XMB(3.9,145834,2,1955,0)="""RTN"",""MAGDRPC4"",151,0)"
^XMB(3.9,145834,2,1956,0)=" . . . S MAGIEN=$$GET1^DIQ(8925.91,TIUXIEN,.02,""I"")"
^XMB(3.9,145834,2,1957,0)="""RTN"",""MAGDRPC4"",152,0)"
^XMB(3.9,145834,2,1958,0)=" . . . S X=""8925^""_TIUIEN_""^""_MAGIEN_""^""_ACNUMB"
^XMB(3.9,145834,2,1959,0)="""RTN"",""MAGDRPC4"",153,0)"
^XMB(3.9,145834,2,1960,0)=" . . . S NOUT=NOUT+1,OUT(NOUT)=X"
^XMB(3.9,145834,2,1961,0)="""RTN"",""MAGDRPC4"",154,0)"
^XMB(3.9,145834,2,1962,0)=" . . . Q"
^XMB(3.9,145834,2,1963,0)="""RTN"",""MAGDRPC4"",155,0)"
^XMB(3.9,145834,2,1964,0)=" . . Q"
^XMB(3.9,145834,2,1965,0)="""RTN"",""MAGDRPC4"",156,0)"
^XMB(3.9,145834,2,1966,0)=" . Q"
^XMB(3.9,145834,2,1967,0)="""RTN"",""MAGDRPC4"",157,0)"
^XMB(3.9,145834,2,1968,0)=" Q"
^XMB(3.9,145834,2,1969,0)="""RTN"",""MAGDRPC4"",158,0)"
^XMB(3.9,145834,2,1970,0)=" ;"
^XMB(3.9,145834,2,1971,0)="""RTN"",""MAGDRPC4"",159,0)"
^XMB(3.9,145834,2,1972,0)="NEXTIMG(OUT,FROMS,ONLYCHECK,SENT) ; RPC = MAG DICOM GET NEXT QUEUE ENTRY"
^XMB(3.9,145834,2,1973,0)="""RTN"",""MAGDRPC4"",160,0)"
^XMB(3.9,145834,2,1974,0)=" ; Get next file to be DICOM transmitted"
^XMB(3.9,145834,2,1975,0)="""RTN"",""MAGDRPC4"",161,0)"
^XMB(3.9,145834,2,1976,0)=" N D0,D1,F1,F2,F3,FAILTIME,FROM,GROUP,I,JBTOHD,LOC,N,PRIORITY,SITE,STATE,TYPE,X,XMITTIME"
^XMB(3.9,145834,2,1977,0)="""RTN"",""MAGDRPC4"",162,0)"
^XMB(3.9,145834,2,1978,0)=" N ARTIFACTIX,ARTIFACTINSTIX,DFN,DISKVOLUME,FILEPATH,PHYSICALREF,STUDYIX"
^XMB(3.9,145834,2,1979,0)="""RTN"",""MAGDRPC4"",163,0)"
^XMB(3.9,145834,2,1980,0)=" S X=$G(FROMS) S:X FROM(X)=1"
^XMB(3.9,145834,2,1981,0)="""RTN"",""MAGDRPC4"",164,0)"
^XMB(3.9,145834,2,1982,0)=" S I="""" F  S I=$O(FROMS(I)) Q:I=""""  S X=$P($G(FROMS(I)),""^"",1) S:X FROM(X)=1"
^XMB(3.9,145834,2,1983,0)="""RTN"",""MAGDRPC4"",165,0)"
^XMB(3.9,145834,2,1984,0)=" I '$O(FROM("""")) S OUT(1)=""-1,No Origin Specified"" Q"
^XMB(3.9,145834,2,1985,0)="""RTN"",""MAGDRPC4"",166,0)"
^XMB(3.9,145834,2,1986,0)=" ;"
^XMB(3.9,145834,2,1987,0)="""RTN"",""MAGDRPC4"",167,0)"
^XMB(3.9,145834,2,1988,0)=" L +^MAGDOUTP(2006.574):1E9 ; P305 PMK 09/23/2021 - Lock entire global, RPC MUST wait"
^XMB(3.9,145834,2,1989,0)="""RTN"",""MAGDRPC4"",168,0)"
^XMB(3.9,145834,2,1990,0)=" ;"
^XMB(3.9,145834,2,1991,0)="""RTN"",""MAGDRPC4"",169,0)"
^XMB(3.9,145834,2,1992,0)=" ; First clean up transmitted queue entries"
^XMB(3.9,145834,2,1993,0)="""RTN"",""MAGDRPC4"",170,0)"
^XMB(3.9,145834,2,1994,0)=" S I="""" F  S I=$O(SENT(I)) Q:I=""""  D CLEAN"
^XMB(3.9,145834,2,1995,0)="""RTN"",""MAGDRPC4"",171,0)"
^XMB(3.9,145834,2,1996,0)=" S SITE=$O(^MAG(2006.1,""B"",DUZ(2),"""")) ; parameters are defined for the sending site"
^XMB(3.9,145834,2,1997,0)="""RTN"",""MAGDRPC4"",172,0)"
^XMB(3.9,145834,2,1998,0)=" S XMITTIME=$$GET1^DIQ(2006.1,SITE,208)"
^XMB(3.9,145834,2,1999,0)="""RTN"",""MAGDRPC4"",173,0)"
^XMB(3.9,145834,2,2000,0)=" S FAILTIME=$$GET1^DIQ(2006.1,SITE,209)"
^XMB(3.9,145834,2,2001,0)="""RTN"",""MAGDRPC4"",174,0)"
^XMB(3.9,145834,2,2002,0)=" S H=$$SECOND($H)"
^XMB(3.9,145834,2,2003,0)="""RTN"",""MAGDRPC4"",175,0)"
^XMB(3.9,145834,2,2004,0)=" ;"
^XMB(3.9,145834,2,2005,0)="""RTN"",""MAGDRPC4"",176,0)"
^XMB(3.9,145834,2,2006,0)=" ; ONLYCHECK=1 for batch export (^MAGDIWBE) but 0 for a transmission process (^MAGDIWB2)"
^XMB(3.9,145834,2,2007,0)="""RTN"",""MAGDRPC4"",177,0)"
^XMB(3.9,145834,2,2008,0)=" I 'ONLYCHECK D  ; do only when called from a transmission process, not batch export"
^XMB(3.9,145834,2,2009,0)="""RTN"",""MAGDRPC4"",178,0)"
^XMB(3.9,145834,2,2010,0)=" . ; check for DICOM objects stuck in XMIT state or that previously failed to be transmitted"
^XMB(3.9,145834,2,2011,0)="""RTN"",""MAGDRPC4"",179,0)"
^XMB(3.9,145834,2,2012,0)=" . S FROM="""" F  S FROM=$O(FROM(FROM)) Q:FROM=""""  D"
^XMB(3.9,145834,2,2013,0)="""RTN"",""MAGDRPC4"",180,0)"
^XMB(3.9,145834,2,2014,0)=" . . S PRIORITY="""" F  S PRIORITY=$O(^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY)) Q:PRIORITY=""""  D"
^XMB(3.9,145834,2,2015,0)="""RTN"",""MAGDRPC4"",181,0)"
^XMB(3.9,145834,2,2016,0)=" . . . D RETRYXMT(FROM,PRIORITY,""XMIT"",XMITTIME,0) ; XMIT is disabled by default"
^XMB(3.9,145834,2,2017,0)="""RTN"",""MAGDRPC4"",182,0)"
^XMB(3.9,145834,2,2018,0)=" . . . D RETRYXMT(FROM,PRIORITY,""FAIL"",FAILTIME,300) ; default for FAIL is 5 minutes"
^XMB(3.9,145834,2,2019,0)="""RTN"",""MAGDRPC4"",183,0)"
^XMB(3.9,145834,2,2020,0)=" . . . Q"
^XMB(3.9,145834,2,2021,0)="""RTN"",""MAGDRPC4"",184,0)"
^XMB(3.9,145834,2,2022,0)=" . . Q"
^XMB(3.9,145834,2,2023,0)="""RTN"",""MAGDRPC4"",185,0)"
^XMB(3.9,145834,2,2024,0)=" . Q"
^XMB(3.9,145834,2,2025,0)="""RTN"",""MAGDRPC4"",186,0)"
^XMB(3.9,145834,2,2026,0)=" ;"
^XMB(3.9,145834,2,2027,0)="""RTN"",""MAGDRPC4"",187,0)"
^XMB(3.9,145834,2,2028,0)=" ; Find the highest priority among the selected FROM locations"
^XMB(3.9,145834,2,2029,0)="""RTN"",""MAGDRPC4"",188,0)"
^XMB(3.9,145834,2,2030,0)=" S FROM="""" F  S FROM=$O(FROM(FROM)) Q:FROM=""""  D"
^XMB(3.9,145834,2,2031,0)="""RTN"",""MAGDRPC4"",189,0)"
^XMB(3.9,145834,2,2032,0)=" . S PRIORITY="""" F  S PRIORITY=$O(^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY)) Q:PRIORITY=""""  D"
^XMB(3.9,145834,2,2033,0)="""RTN"",""MAGDRPC4"",190,0)"
^XMB(3.9,145834,2,2034,0)=" . . S X=$O(^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,""WAITING"","""")) S:X PRIORITY(PRIORITY,FROM)="""""
^XMB(3.9,145834,2,2035,0)="""RTN"",""MAGDRPC4"",191,0)"
^XMB(3.9,145834,2,2036,0)=" . . Q"
^XMB(3.9,145834,2,2037,0)="""RTN"",""MAGDRPC4"",192,0)"
^XMB(3.9,145834,2,2038,0)=" . Q"
^XMB(3.9,145834,2,2039,0)="""RTN"",""MAGDRPC4"",193,0)"
^XMB(3.9,145834,2,2040,0)=" K OUT S OUT(1)="""",PRIORITY=$O(PRIORITY(""""),-1) D:PRIORITY'="""""
^XMB(3.9,145834,2,2041,0)="""RTN"",""MAGDRPC4"",194,0)"
^XMB(3.9,145834,2,2042,0)=" . S FROM=$O(PRIORITY(PRIORITY,""""))"
^XMB(3.9,145834,2,2043,0)="""RTN"",""MAGDRPC4"",195,0)"
^XMB(3.9,145834,2,2044,0)=" . S D0="""" F  S D0=$O(^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,""WAITING"",D0)) Q:D0=""""  D  Q:OUT(1)'="""""
^XMB(3.9,145834,2,2045,0)="""RTN"",""MAGDRPC4"",196,0)"
^XMB(3.9,145834,2,2046,0)=" . . S D1="""" F  S D1=$O(^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,""WAITING"",D0,D1)) Q:D1=""""  D  Q:OUT(1)'="""""
^XMB(3.9,145834,2,2047,0)="""RTN"",""MAGDRPC4"",197,0)"
^XMB(3.9,145834,2,2048,0)=" . . . ; ONLYCHECK=1 for batch export; ONLYCHECK=0 for a transmission process "
^XMB(3.9,145834,2,2049,0)="""RTN"",""MAGDRPC4"",198,0)"
^XMB(3.9,145834,2,2050,0)=" . . . I 'ONLYCHECK D  ; do only when called from a transmission process, not batch export"
^XMB(3.9,145834,2,2051,0)="""RTN"",""MAGDRPC4"",199,0)"
^XMB(3.9,145834,2,2052,0)=" . . . . S $P(^MAGDOUTP(2006.574,D0,1,D1,0),""^"",2,3)=""XMIT^""_$H"
^XMB(3.9,145834,2,2053,0)="""RTN"",""MAGDRPC4"",200,0)"
^XMB(3.9,145834,2,2054,0)=" . . . . K ^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,""WAITING"",D0,D1)"
^XMB(3.9,145834,2,2055,0)="""RTN"",""MAGDRPC4"",201,0)"
^XMB(3.9,145834,2,2056,0)=" . . . . S ^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,""XMIT"",D0,D1)="""""
^XMB(3.9,145834,2,2057,0)="""RTN"",""MAGDRPC4"",202,0)"
^XMB(3.9,145834,2,2058,0)=" . . . . Q"
^XMB(3.9,145834,2,2059,0)="""RTN"",""MAGDRPC4"",203,0)"
^XMB(3.9,145834,2,2060,0)=" . . . S OUT(1)=1"
^XMB(3.9,145834,2,2061,0)="""RTN"",""MAGDRPC4"",204,0)"
^XMB(3.9,145834,2,2062,0)=" . . . S OUT(2)=D0"
^XMB(3.9,145834,2,2063,0)="""RTN"",""MAGDRPC4"",205,0)"
^XMB(3.9,145834,2,2064,0)=" . . . S OUT(3)=D1"
^XMB(3.9,145834,2,2065,0)="""RTN"",""MAGDRPC4"",206,0)"
^XMB(3.9,145834,2,2066,0)=" . . . S X=$G(^MAGDOUTP(2006.574,D0,0))"
^XMB(3.9,145834,2,2067,0)="""RTN"",""MAGDRPC4"",207,0)"
^XMB(3.9,145834,2,2068,0)=" . . . S OUT(4)=$P(X,""^"",1) ; Application"
^XMB(3.9,145834,2,2069,0)="""RTN"",""MAGDRPC4"",208,0)"
^XMB(3.9,145834,2,2070,0)=" . . . S (OUT(5),GROUP)=$P(X,""^"",2) ; Group"
^XMB(3.9,145834,2,2071,0)="""RTN"",""MAGDRPC4"",209,0)"
^XMB(3.9,145834,2,2072,0)=" . . . S (ACNUMB,OUT(6))=$P(X,""^"",3) ; Accession Number"
^XMB(3.9,145834,2,2073,0)="""RTN"",""MAGDRPC4"",210,0)"
^XMB(3.9,145834,2,2074,0)=" . . . S JBTOHD=+$P(X,""^"",6)"
^XMB(3.9,145834,2,2075,0)="""RTN"",""MAGDRPC4"",211,0)"
^XMB(3.9,145834,2,2076,0)=" . . . S OUT(7)=$P(^MAGDOUTP(2006.574,D0,1,D1,0),""^"",1) ; Image IEN or Artifact IEN"
^XMB(3.9,145834,2,2077,0)="""RTN"",""MAGDRPC4"",212,0)"
^XMB(3.9,145834,2,2078,0)=" . . . I GROUP=""New SOP Class DB"" D"
^XMB(3.9,145834,2,2079,0)="""RTN"",""MAGDRPC4"",213,0)"
^XMB(3.9,145834,2,2080,0)=" . . . . S ARTIFACTIX=OUT(7) ; ARTIFACT file (#2006.916) IEN"
^XMB(3.9,145834,2,2081,0)="""RTN"",""MAGDRPC4"",214,0)"
^XMB(3.9,145834,2,2082,0)=" . . . . S OUT(8)=GROUP ; no legacy Object Type (2005 field 3)"
^XMB(3.9,145834,2,2083,0)="""RTN"",""MAGDRPC4"",215,0)"
^XMB(3.9,145834,2,2084,0)=" . . . . ; get DFN from IMAGE STUDY file (#2005.62) and IMAGING PATIENT REFERENCE file (#2005.61)"
^XMB(3.9,145834,2,2085,0)="""RTN"",""MAGDRPC4"",216,0)"
^XMB(3.9,145834,2,2086,0)=" . . . . S STUDYIX=$O(^MAGV(2005.62,""D"",ACNUMB,"""")) ; get IMAGE STUDY pointer"
^XMB(3.9,145834,2,2087,0)="""RTN"",""MAGDRPC4"",217,0)"
^XMB(3.9,145834,2,2088,0)=" . . . . S DFN=$$GET1^DIQ(2005.62,STUDYIX,13,""E"") ; get IMAGING PATIENT REFERENCE (DFN)"
^XMB(3.9,145834,2,2089,0)="""RTN"",""MAGDRPC4"",218,0)"
^XMB(3.9,145834,2,2090,0)=" . . . . ; there may be multiple artifact instances - use the first one"
^XMB(3.9,145834,2,2091,0)="""RTN"",""MAGDRPC4"",219,0)"
^XMB(3.9,145834,2,2092,0)=" . . . . ; could check the NETWORK LOCATION file (2005.2) STORAGE TYPE = ""TIER 1"""
^XMB(3.9,145834,2,2093,0)="""RTN"",""MAGDRPC4"",220,0)"
^XMB(3.9,145834,2,2094,0)=" . . . . S ARTIFACTINSTIX=$O(^MAGV(2006.918,""B"",ARTIFACTIX,"""")) ; get first Artifact Instance pointer"
^XMB(3.9,145834,2,2095,0)="""RTN"",""MAGDRPC4"",221,0)"
^XMB(3.9,145834,2,2096,0)=" . . . . S F1=$$UP^MAGDFCNV($$GET1^DIQ(2006.918,ARTIFACTINSTIX,6)) ; FILEREF (filename)"
^XMB(3.9,145834,2,2097,0)="""RTN"",""MAGDRPC4"",222,0)"
^XMB(3.9,145834,2,2098,0)=" . . . . S DISKVOLUME=$$GET1^DIQ(2006.918,ARTIFACTINSTIX,7,""I"") ; DISK VOLUME"
^XMB(3.9,145834,2,2099,0)="""RTN"",""MAGDRPC4"",223,0)"
^XMB(3.9,145834,2,2100,0)=" . . . . S PHYSICALREF=$$GET1^DIQ(2005.2,DISKVOLUME,1) ; PHYSICAL REFERENCE"
^XMB(3.9,145834,2,2101,0)="""RTN"",""MAGDRPC4"",224,0)"
^XMB(3.9,145834,2,2102,0)=" . . . . S FILEPATH=$$GET1^DIQ(2006.918,ARTIFACTINSTIX,8) ; FILEPATH"
^XMB(3.9,145834,2,2103,0)="""RTN"",""MAGDRPC4"",225,0)"
^XMB(3.9,145834,2,2104,0)=" . . . . S (F2,F3)=PHYSICALREF_FILEPATH_F1"
^XMB(3.9,145834,2,2105,0)="""RTN"",""MAGDRPC4"",226,0)"
^XMB(3.9,145834,2,2106,0)=" . . . . Q"
^XMB(3.9,145834,2,2107,0)="""RTN"",""MAGDRPC4"",227,0)"
^XMB(3.9,145834,2,2108,0)=" . . . E  D"
^XMB(3.9,145834,2,2109,0)="""RTN"",""MAGDRPC4"",228,0)"
^XMB(3.9,145834,2,2110,0)=" . . . . S IMAGEIEN=OUT(7)"
^XMB(3.9,145834,2,2111,0)="""RTN"",""MAGDRPC4"",229,0)"
^XMB(3.9,145834,2,2112,0)=" . . . . S OUT(8)=$P($G(^MAG(2005,IMAGEIEN,0)),""^"",6) ; Object Type"
^XMB(3.9,145834,2,2113,0)="""RTN"",""MAGDRPC4"",230,0)"
^XMB(3.9,145834,2,2114,0)=" . . . . S TYPE=$S($G(^MAG(2005,IMAGEIEN,""FBIG""))'="""":""BIG"",1:""FULL"")"
^XMB(3.9,145834,2,2115,0)="""RTN"",""MAGDRPC4"",231,0)"
^XMB(3.9,145834,2,2116,0)=" . . . . ; 3rd parameter set to 1 to allow retrieval from jukebox"
^XMB(3.9,145834,2,2117,0)="""RTN"",""MAGDRPC4"",232,0)"
^XMB(3.9,145834,2,2118,0)=" . . . . D FILEFIND^MAGDFB(IMAGEIEN,TYPE,1,0,.F1,.F2)"
^XMB(3.9,145834,2,2119,0)="""RTN"",""MAGDRPC4"",233,0)"
^XMB(3.9,145834,2,2120,0)=" . . . . S DFN=$P($G(^MAG(2005,+OUT(7),0)),""^"",7) ; P156 DAC - get DFN from image (not group)"
^XMB(3.9,145834,2,2121,0)="""RTN"",""MAGDRPC4"",234,0)"
^XMB(3.9,145834,2,2122,0)=" . . . . ; get path for *.TXT, always the same as the FULL file"
^XMB(3.9,145834,2,2123,0)="""RTN"",""MAGDRPC4"",235,0)"
^XMB(3.9,145834,2,2124,0)=" . . . . D FILEFIND^MAGDFB(IMAGEIEN,""FULL"",JBTOHD,0,.F1,.F3)"
^XMB(3.9,145834,2,2125,0)="""RTN"",""MAGDRPC4"",236,0)"
^XMB(3.9,145834,2,2126,0)=" . . . . Q"
^XMB(3.9,145834,2,2127,0)="""RTN"",""MAGDRPC4"",237,0)"
^XMB(3.9,145834,2,2128,0)=" . . . S OUT(9)=F1 ; file name"
^XMB(3.9,145834,2,2129,0)="""RTN"",""MAGDRPC4"",238,0)"
^XMB(3.9,145834,2,2130,0)=" . . . S OUT(10)=F2 ; full file path"
^XMB(3.9,145834,2,2131,0)="""RTN"",""MAGDRPC4"",239,0)"
^XMB(3.9,145834,2,2132,0)=" . . . S OUT(11)=DFN"
^XMB(3.9,145834,2,2133,0)="""RTN"",""MAGDRPC4"",240,0)"
^XMB(3.9,145834,2,2134,0)=" . . . S OUT(12)=F3 ; full file path"
^XMB(3.9,145834,2,2135,0)="""RTN"",""MAGDRPC4"",241,0)"
^XMB(3.9,145834,2,2136,0)=" . . . S X=$G(^MAGDOUTP(2006.574,D0,1,0))"
^XMB(3.9,145834,2,2137,0)="""RTN"",""MAGDRPC4"",242,0)"
^XMB(3.9,145834,2,2138,0)=" . . . S OUT(13)=$P(X,""^"",4) ; Object count"
^XMB(3.9,145834,2,2139,0)="""RTN"",""MAGDRPC4"",243,0)"
^XMB(3.9,145834,2,2140,0)=" . . . Q"
^XMB(3.9,145834,2,2141,0)="""RTN"",""MAGDRPC4"",244,0)"
^XMB(3.9,145834,2,2142,0)=" . . Q"
^XMB(3.9,145834,2,2143,0)="""RTN"",""MAGDRPC4"",245,0)"
^XMB(3.9,145834,2,2144,0)=" . Q"
^XMB(3.9,145834,2,2145,0)="""RTN"",""MAGDRPC4"",246,0)"
^XMB(3.9,145834,2,2146,0)=" I OUT(1)="""" D"
^XMB(3.9,145834,2,2147,0)="""RTN"",""MAGDRPC4"",247,0)"
^XMB(3.9,145834,2,2148,0)=" . S OUT(1)=""-2,Nothing to be transmitted."""
^XMB(3.9,145834,2,2149,0)="""RTN"",""MAGDRPC4"",248,0)"
^XMB(3.9,145834,2,2150,0)=" . D CLEANUP"
^XMB(3.9,145834,2,2151,0)="""RTN"",""MAGDRPC4"",249,0)"
^XMB(3.9,145834,2,2152,0)=" . Q"
^XMB(3.9,145834,2,2153,0)="""RTN"",""MAGDRPC4"",250,0)"
^XMB(3.9,145834,2,2154,0)=" L -^MAGDOUTP(2006.574) ; P180 DAC - Unlock global"
^XMB(3.9,145834,2,2155,0)="""RTN"",""MAGDRPC4"",251,0)"
^XMB(3.9,145834,2,2156,0)=" Q"
^XMB(3.9,145834,2,2157,0)="""RTN"",""MAGDRPC4"",252,0)"
^XMB(3.9,145834,2,2158,0)=" ;"
^XMB(3.9,145834,2,2159,0)="""RTN"",""MAGDRPC4"",253,0)"
^XMB(3.9,145834,2,2160,0)="RETRYXMT(FROM,PRIORITY,OLDSTATE,TIMEOUT,DEFAULTTIMEOUT) ; retry transmission"
^XMB(3.9,145834,2,2161,0)="""RTN"",""MAGDRPC4"",254,0)"
^XMB(3.9,145834,2,2162,0)=" ; move images from XMIT or FAIL state to WAITING state"
^XMB(3.9,145834,2,2163,0)="""RTN"",""MAGDRPC4"",255,0)"
^XMB(3.9,145834,2,2164,0)=" N D0,D1,H,X"
^XMB(3.9,145834,2,2165,0)="""RTN"",""MAGDRPC4"",256,0)"
^XMB(3.9,145834,2,2166,0)=" ;"
^XMB(3.9,145834,2,2167,0)="""RTN"",""MAGDRPC4"",257,0)"
^XMB(3.9,145834,2,2168,0)=" I TIMEOUT="""" S TIMEOUT=DEFAULTTIMEOUT ; XMIT/FAIL timeout not defined"
^XMB(3.9,145834,2,2169,0)="""RTN"",""MAGDRPC4"",258,0)"
^XMB(3.9,145834,2,2170,0)=" ;"
^XMB(3.9,145834,2,2171,0)="""RTN"",""MAGDRPC4"",259,0)"
^XMB(3.9,145834,2,2172,0)=" I TIMEOUT=0 Q  ; retransmission is disabled"
^XMB(3.9,145834,2,2173,0)="""RTN"",""MAGDRPC4"",260,0)"
^XMB(3.9,145834,2,2174,0)=" ;"
^XMB(3.9,145834,2,2175,0)="""RTN"",""MAGDRPC4"",261,0)"
^XMB(3.9,145834,2,2176,0)=" S H=$$SECOND($H)"
^XMB(3.9,145834,2,2177,0)="""RTN"",""MAGDRPC4"",262,0)"
^XMB(3.9,145834,2,2178,0)=" S D0="""" F  S D0=$O(^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,OLDSTATE,D0)) Q:D0=""""  D"
^XMB(3.9,145834,2,2179,0)="""RTN"",""MAGDRPC4"",263,0)"
^XMB(3.9,145834,2,2180,0)=" . S D1="""" F  S D1=$O(^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,OLDSTATE,D0,D1)) Q:D1=""""  D"
^XMB(3.9,145834,2,2181,0)="""RTN"",""MAGDRPC4"",264,0)"
^XMB(3.9,145834,2,2182,0)=" . . S X=$$SECOND($P($G(^MAGDOUTP(2006.574,D0,1,D1,0),""^^""_$H),""^"",3))"
^XMB(3.9,145834,2,2183,0)="""RTN"",""MAGDRPC4"",265,0)"
^XMB(3.9,145834,2,2184,0)=" . . Q:H-X<TIMEOUT"
^XMB(3.9,145834,2,2185,0)="""RTN"",""MAGDRPC4"",266,0)"
^XMB(3.9,145834,2,2186,0)=" . . S $P(^MAGDOUTP(2006.574,D0,1,D1,0),""^"",2)=""WAITING"""
^XMB(3.9,145834,2,2187,0)="""RTN"",""MAGDRPC4"",267,0)"
^XMB(3.9,145834,2,2188,0)=" . . K ^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,OLDSTATE,D0,D1)"
^XMB(3.9,145834,2,2189,0)="""RTN"",""MAGDRPC4"",268,0)"
^XMB(3.9,145834,2,2190,0)=" . . S ^MAGDOUTP(2006.574,""STATE"",FROM,PRIORITY,""WAITING"",D0,D1)="""""
^XMB(3.9,145834,2,2191,0)="""RTN"",""MAGDRPC4"",269,0)"
^XMB(3.9,145834,2,2192,0)=" . . Q"
^XMB(3.9,145834,2,2193,0)="""RTN"",""MAGDRPC4"",270,0)"
^XMB(3.9,145834,2,2194,0)=" . Q"
^XMB(3.9,145834,2,2195,0)="""RTN"",""MAGDRPC4"",271,0)"
^XMB(3.9,145834,2,2196,0)=" Q"
^XMB(3.9,145834,2,2197,0)="""RTN"",""MAGDRPC4"",272,0)"
^XMB(3.9,145834,2,2198,0)=" ;"
^XMB(3.9,145834,2,2199,0)="""RTN"",""MAGDRPC4"",273,0)"
^XMB(3.9,145834,2,2200,0)="CLEANUP ; remove old studies"
^XMB(3.9,145834,2,2201,0)="""RTN"",""MAGDRPC4"",274,0)"
^XMB(3.9,145834,2,2202,0)=" N D0,D1,I,REQUESTDATETIME,SENT"
^XMB(3.9,145834,2,2203,0)="""RTN"",""MAGDRPC4"",275,0)"
^XMB(3.9,145834,2,2204,0)=" S REQUESTDATETIME=$$FMADD^XLFDT($$NOW^XLFDT,-15,0,0,0) ; delete anything 15 days older or older"
^XMB(3.9,145834,2,2205,0)="""RTN"",""MAGDRPC4"",276,0)"
^XMB(3.9,145834,2,2206,0)=" F  S REQUESTDATETIME=$O(^MAGDOUTP(2006.574,""C"",REQUESTDATETIME),-1) Q:REQUESTDATETIME=""""  D"
^XMB(3.9,145834,2,2207,0)="""RTN"",""MAGDRPC4"",277,0)"
^XMB(3.9,145834,2,2208,0)=" . S D0="""" F  S D0=$O(^MAGDOUTP(2006.574,""C"",REQUESTDATETIME,D0)) Q:D0=""""  D"
^XMB(3.9,145834,2,2209,0)="""RTN"",""MAGDRPC4"",278,0)"
^XMB(3.9,145834,2,2210,0)=" . . S D1=0 F  S D1=$O(^MAGDOUTP(2006.574,D0,1,D1)) Q:D1=""""  D"
^XMB(3.9,145834,2,2211,0)="""RTN"",""MAGDRPC4"",279,0)"
^XMB(3.9,145834,2,2212,0)=" . . . S I=1,SENT(1)=D0_""^""_D1_""^"" D CLEAN ; STATE=<null>"
^XMB(3.9,145834,2,2213,0)="""RTN"",""MAGDRPC4"",280,0)"
^XMB(3.9,145834,2,2214,0)=" . . . Q"
^XMB(3.9,145834,2,2215,0)="""RTN"",""MAGDRPC4"",281,0)"
^XMB(3.9,145834,2,2216,0)=" . . Q"
^XMB(3.9,145834,2,2217,0)="""RTN"",""MAGDRPC4"",282,0)"
^XMB(3.9,145834,2,2218,0)=" . Q"
^XMB(3.9,145834,2,2219,0)="""RTN"",""MAGDRPC4"",283,0)"
^XMB(3.9,145834,2,2220,0)=" Q"
^XMB(3.9,145834,2,2221,0)="""RTN"",""MAGDRPC4"",284,0)"
^XMB(3.9,145834,2,2222,0)=" ;"
^XMB(3.9,145834,2,2223,0)="""RTN"",""MAGDRPC4"",285,0)"
^XMB(3.9,145834,2,2224,0)="CLEAN ; remove one image entry from the queue"
^XMB(3.9,145834,2,2225,0)="""RTN"",""MAGDRPC4"",286,0)"
^XMB(3.9,145834,2,2226,0)=" N D0,D1,REQUESTDATETIME,STUID,PRIORITY,STATE,NEWSTATE ; P305 PMK 09/29/2021"
^XMB(3.9,145834,2,2227,0)="""RTN"",""MAGDRPC4"",287,0)"
^XMB(3.9,145834,2,2228,0)=" S D0=$P(SENT(I),""^"",1),D1=$P(SENT(I),""^"",2),NEWSTATE=$P(SENT(I),""^"",3)"
^XMB(3.9,145834,2,2229,0)="""RTN"",""MAGDRPC4"",288,0)"
^XMB(3.9,145834,2,2230,0)=" Q:'$D(^MAGDOUTP(2006.574,D0,1,D1))"
^XMB(3.9,145834,2,2231,0)="""RTN"",""MAGDRPC4"",289,0)"
^XMB(3.9,145834,2,2232,0)=" ;"
^XMB(3.9,145834,2,2233,0)="""RTN"",""MAGDRPC4"",290,0)"
^XMB(3.9,145834,2,2234,0)=" S X=$G(^MAGDOUTP(2006.574,D0,0)),LOC=$P(X,""^"",4),PRIORITY=+$P(X,""^"",5)"
^XMB(3.9,145834,2,2235,0)="""RTN"",""MAGDRPC4"",291,0)"
^XMB(3.9,145834,2,2236,0)=" S REQUESTDATETIME=$P(X,""^"",7)"
^XMB(3.9,145834,2,2237,0)="""RTN"",""MAGDRPC4"",292,0)"
^XMB(3.9,145834,2,2238,0)=" S STATE=$P($G(^MAGDOUTP(2006.574,D0,1,D1,0)),""^"",2)"
^XMB(3.9,145834,2,2239,0)="""RTN"",""MAGDRPC4"",293,0)"
^XMB(3.9,145834,2,2240,0)=" ;"
^XMB(3.9,145834,2,2241,0)="""RTN"",""MAGDRPC4"",294,0)"
^XMB(3.9,145834,2,2242,0)=" I NEWSTATE'="""" D  Q  ; just update the status and get out"
^XMB(3.9,145834,2,2243,0)="""RTN"",""MAGDRPC4"",295,0)"
^XMB(3.9,145834,2,2244,0)=" . S $P(^MAGDOUTP(2006.574,D0,1,D1,0),""^"",2)=NEWSTATE,$P(^(0),""^"",3)=$H"
^XMB(3.9,145834,2,2245,0)="""RTN"",""MAGDRPC4"",296,0)"
^XMB(3.9,145834,2,2246,0)=" . ; remove the old xref before setting the new one - P305 PMK 09/29/2021"
^XMB(3.9,145834,2,2247,0)="""RTN"",""MAGDRPC4"",297,0)"
^XMB(3.9,145834,2,2248,0)=" . I LOC'="""",PRIORITY'="""",STATE'="""" K ^MAGDOUTP(2006.574,""STATE"",LOC,PRIORITY,STATE,D0,D1)"
^XMB(3.9,145834,2,2249,0)="""RTN"",""MAGDRPC4"",298,0)"
^XMB(3.9,145834,2,2250,0)=" . I LOC'="""",PRIORITY'="""" S ^MAGDOUTP(2006.574,""STATE"",LOC,PRIORITY,NEWSTATE,D0,D1)="""""
^XMB(3.9,145834,2,2251,0)="""RTN"",""MAGDRPC4"",299,0)"
^XMB(3.9,145834,2,2252,0)=" . Q"
^XMB(3.9,145834,2,2253,0)="""RTN"",""MAGDRPC4"",300,0)"
^XMB(3.9,145834,2,2254,0)=" ;"
^XMB(3.9,145834,2,2255,0)="""RTN"",""MAGDRPC4"",301,0)"
^XMB(3.9,145834,2,2256,0)=" K ^MAGDOUTP(2006.574,D0,1,D1)"
^XMB(3.9,145834,2,2257,0)="""RTN"",""MAGDRPC4"",302,0)"
^XMB(3.9,145834,2,2258,0)=" I LOC'="""",PRIORITY'="""",STATE'="""" K ^MAGDOUTP(2006.574,""STATE"",LOC,PRIORITY,STATE,D0,D1)"
^XMB(3.9,145834,2,2259,0)="""RTN"",""MAGDRPC4"",303,0)"
^XMB(3.9,145834,2,2260,0)=" S X=$G(^MAGDOUTP(2006.574,D0,1,0))"
^XMB(3.9,145834,2,2261,0)="""RTN"",""MAGDRPC4"",304,0)"
^XMB(3.9,145834,2,2262,0)=" S $P(X,""^"",4)=$P(X,""^"",4)-1"
^XMB(3.9,145834,2,2263,0)="""RTN"",""MAGDRPC4"",305,0)"
^XMB(3.9,145834,2,2264,0)=" S ^MAGDOUTP(2006.574,D0,1,0)=X"
^XMB(3.9,145834,2,2265,0)="""RTN"",""MAGDRPC4"",306,0)"
^XMB(3.9,145834,2,2266,0)=" ;"
^XMB(3.9,145834,2,2267,0)="""RTN"",""MAGDRPC4"",307,0)"
^XMB(3.9,145834,2,2268,0)=" Q:$O(^MAGDOUTP(2006.574,D0,1,0))  ; don't delete the study node yet"
^XMB(3.9,145834,2,2269,0)="""RTN"",""MAGDRPC4"",308,0)"
^XMB(3.9,145834,2,2270,0)=" ;"
^XMB(3.9,145834,2,2271,0)="""RTN"",""MAGDRPC4"",309,0)"
^XMB(3.9,145834,2,2272,0)=" S STUID=$G(^MAGDOUTP(2006.574,D0,2))"
^XMB(3.9,145834,2,2273,0)="""RTN"",""MAGDRPC4"",310,0)"
^XMB(3.9,145834,2,2274,0)=" K ^MAGDOUTP(2006.574,D0)"
^XMB(3.9,145834,2,2275,0)="""RTN"",""MAGDRPC4"",311,0)"
^XMB(3.9,145834,2,2276,0)=" K:REQUESTDATETIME'="""" ^MAGDOUTP(2006.574,""C"",REQUESTDATETIME,D0)"
^XMB(3.9,145834,2,2277,0)="""RTN"",""MAGDRPC4"",312,0)"
^XMB(3.9,145834,2,2278,0)=" K:STUID'="""" ^MAGDOUTP(2006.574,""STUDY"",STUID)"
^XMB(3.9,145834,2,2279,0)="""RTN"",""MAGDRPC4"",313,0)"
^XMB(3.9,145834,2,2280,0)=" S X=$G(^MAGDOUTP(2006.574,0))"
^XMB(3.9,145834,2,2281,0)="""RTN"",""MAGDRPC4"",314,0)"
^XMB(3.9,145834,2,2282,0)=" S $P(X,""^"",4)=$P(X,""^"",4)-1"
^XMB(3.9,145834,2,2283,0)="""RTN"",""MAGDRPC4"",315,0)"
^XMB(3.9,145834,2,2284,0)=" S ^MAGDOUTP(2006.574,0)=X"
^XMB(3.9,145834,2,2285,0)="""RTN"",""MAGDRPC4"",316,0)"
^XMB(3.9,145834,2,2286,0)=" Q"
^XMB(3.9,145834,2,2287,0)="""RTN"",""MAGDRPC4"",317,0)"
^XMB(3.9,145834,2,2288,0)=" ;"
^XMB(3.9,145834,2,2289,0)="""RTN"",""MAGDRPC4"",318,0)"
^XMB(3.9,145834,2,2290,0)="FIND(DATE,CASE,NUM) ;"
^XMB(3.9,145834,2,2291,0)="""RTN"",""MAGDRPC4"",319,0)"
^XMB(3.9,145834,2,2292,0)=" ; Use the ADC x-reference in the radiology patient file"
^XMB(3.9,145834,2,2293,0)="""RTN"",""MAGDRPC4"",320,0)"
^XMB(3.9,145834,2,2294,0)=" N NDATE"
^XMB(3.9,145834,2,2295,0)="""RTN"",""MAGDRPC4"",321,0)"
^XMB(3.9,145834,2,2296,0)=" S NDATE=$$FMADD^XLFDT(DATE,NUM) Q:NDATE<1 0"
^XMB(3.9,145834,2,2297,0)="""RTN"",""MAGDRPC4"",322,0)"
^XMB(3.9,145834,2,2298,0)=" Q $O(^RADPT(""ADC"",$$MMDDYY(NDATE)_""-""_CASE,""""))"
^XMB(3.9,145834,2,2299,0)="""RTN"",""MAGDRPC4"",323,0)"
^XMB(3.9,145834,2,2300,0)=" ;"
^XMB(3.9,145834,2,2301,0)="""RTN"",""MAGDRPC4"",324,0)"
^XMB(3.9,145834,2,2302,0)="MMDDYY(DAY) ; Convert Fileman date to mmddyy"
^XMB(3.9,145834,2,2303,0)="""RTN"",""MAGDRPC4"",325,0)"
^XMB(3.9,145834,2,2304,0)=" I DAY'?7N Q 0"
^XMB(3.9,145834,2,2305,0)="""RTN"",""MAGDRPC4"",326,0)"
^XMB(3.9,145834,2,2306,0)=" Q $E(DAY,4,7)_$E(DAY,2,3)"
^XMB(3.9,145834,2,2307,0)="""RTN"",""MAGDRPC4"",327,0)"
^XMB(3.9,145834,2,2308,0)=" ;"
^XMB(3.9,145834,2,2309,0)="""RTN"",""MAGDRPC4"",328,0)"
^XMB(3.9,145834,2,2310,0)="SECOND(H) Q H*86400+$P(H,"","",2)"
^XMB(3.9,145834,2,2311,0)="""RTN"",""MAGDRPC4"",329,0)"
^XMB(3.9,145834,2,2312,0)=" ;"
^XMB(3.9,145834,2,2313,0)="""RTN"",""MAGDRPCE"")"
^XMB(3.9,145834,2,2314,0)="0^21^B42732687"
^XMB(3.9,145834,2,2315,0)="""RTN"",""MAGDRPCE"",1,0)"
^XMB(3.9,145834,2,2316,0)="MAGDRPCE ;WOIFO/PMK - Imaging RPCs ; Dec 06, 2021@10:54:46"
^XMB(3.9,145834,2,2317,0)="""RTN"",""MAGDRPCE"",2,0)"
^XMB(3.9,145834,2,2318,0)=" ;;3.0;IMAGING;**305**;Mar 19, 2002;Build 0"
^XMB(3.9,145834,2,2319,0)="""RTN"",""MAGDRPCE"",3,0)"
^XMB(3.9,145834,2,2320,0)=" ;; Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,145834,2,2321,0)="""RTN"",""MAGDRPCE"",4,0)"
^XMB(3.9,145834,2,2322,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,2323,0)="""RTN"",""MAGDRPCE"",5,0)"
^XMB(3.9,145834,2,2324,0)=" ;; | Property of the US Government.                                |"
^XMB(3.9,145834,2,2325,0)="""RTN"",""MAGDRPCE"",6,0)"
^XMB(3.9,145834,2,2326,0)=" ;; | No permission to copy or redistribute this software is given. |"
^XMB(3.9,145834,2,2327,0)="""RTN"",""MAGDRPCE"",7,0)"
^XMB(3.9,145834,2,2328,0)=" ;; | Use of unreleased versions of this software requires the user |"
^XMB(3.9,145834,2,2329,0)="""RTN"",""MAGDRPCE"",8,0)"
^XMB(3.9,145834,2,2330,0)=" ;; | to execute a written test agreement with the VistA Imaging    |"
^XMB(3.9,145834,2,2331,0)="""RTN"",""MAGDRPCE"",9,0)"
^XMB(3.9,145834,2,2332,0)=" ;; | Development Office of the Department of Veterans Affairs,     |"
^XMB(3.9,145834,2,2333,0)="""RTN"",""MAGDRPCE"",10,0)"
^XMB(3.9,145834,2,2334,0)=" ;; | telephone (301) 734-0100.                                     |"
^XMB(3.9,145834,2,2335,0)="""RTN"",""MAGDRPCE"",11,0)"
^XMB(3.9,145834,2,2336,0)=" ;; | The Food and Drug Administration classifies this software as  |"
^XMB(3.9,145834,2,2337,0)="""RTN"",""MAGDRPCE"",12,0)"
^XMB(3.9,145834,2,2338,0)=" ;; | a medical device.  As such, it may not be changed in any way. |"
^XMB(3.9,145834,2,2339,0)="""RTN"",""MAGDRPCE"",13,0)"
^XMB(3.9,145834,2,2340,0)=" ;; | Modifications to this software may result in an adulterated   |"
^XMB(3.9,145834,2,2341,0)="""RTN"",""MAGDRPCE"",14,0)"
^XMB(3.9,145834,2,2342,0)=" ;; | medical device under 21CFR820, the use of which is considered |"
^XMB(3.9,145834,2,2343,0)="""RTN"",""MAGDRPCE"",15,0)"
^XMB(3.9,145834,2,2344,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,2345,0)="""RTN"",""MAGDRPCE"",16,0)"
^XMB(3.9,145834,2,2346,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,2347,0)="""RTN"",""MAGDRPCE"",17,0)"
^XMB(3.9,145834,2,2348,0)=" ;;"
^XMB(3.9,145834,2,2349,0)="""RTN"",""MAGDRPCE"",18,0)"
^XMB(3.9,145834,2,2350,0)=" Q"
^XMB(3.9,145834,2,2351,0)="""RTN"",""MAGDRPCE"",19,0)"
^XMB(3.9,145834,2,2352,0)=" ;"
^XMB(3.9,145834,2,2353,0)="""RTN"",""MAGDRPCE"",20,0)"
^XMB(3.9,145834,2,2354,0)=" ; Called by SERVICES^MAGDIWBG to get the DICOM-enabled consult services"
^XMB(3.9,145834,2,2355,0)="""RTN"",""MAGDRPCE"",21,0)"
^XMB(3.9,145834,2,2356,0)=" ;"
^XMB(3.9,145834,2,2357,0)="""RTN"",""MAGDRPCE"",22,0)"
^XMB(3.9,145834,2,2358,0)="SERVICES(OUT) ; RPC = MAG DICOM GET CON SERVICES"
^XMB(3.9,145834,2,2359,0)="""RTN"",""MAGDRPCE"",23,0)"
^XMB(3.9,145834,2,2360,0)=" N ALPHA,NOUT,SERVICE,SERVICENAME"
^XMB(3.9,145834,2,2361,0)="""RTN"",""MAGDRPCE"",24,0)"
^XMB(3.9,145834,2,2362,0)=" K OUT"
^XMB(3.9,145834,2,2363,0)="""RTN"",""MAGDRPCE"",25,0)"
^XMB(3.9,145834,2,2364,0)=" S SERVICE="""" ; alpha sort services"
^XMB(3.9,145834,2,2365,0)="""RTN"",""MAGDRPCE"",26,0)"
^XMB(3.9,145834,2,2366,0)=" F  S SERVICE=$O(^MAG(2006.5831,""B"",SERVICE)) Q:'SERVICE  D"
^XMB(3.9,145834,2,2367,0)="""RTN"",""MAGDRPCE"",27,0)"
^XMB(3.9,145834,2,2368,0)=" . S SERVICENAME=$$GET1^DIQ(123.5,SERVICE,.01,""E"")"
^XMB(3.9,145834,2,2369,0)="""RTN"",""MAGDRPCE"",28,0)"
^XMB(3.9,145834,2,2370,0)=" . S ALPHA(SERVICENAME)=SERVICE"
^XMB(3.9,145834,2,2371,0)="""RTN"",""MAGDRPCE"",29,0)"
^XMB(3.9,145834,2,2372,0)=" . Q"
^XMB(3.9,145834,2,2373,0)="""RTN"",""MAGDRPCE"",30,0)"
^XMB(3.9,145834,2,2374,0)=" S SERVICENAME="""" ; put sorted services into OUT"
^XMB(3.9,145834,2,2375,0)="""RTN"",""MAGDRPCE"",31,0)"
^XMB(3.9,145834,2,2376,0)=" F NOUT=1:1 S SERVICENAME=$O(ALPHA(SERVICENAME)) Q:SERVICENAME=""""  D"
^XMB(3.9,145834,2,2377,0)="""RTN"",""MAGDRPCE"",32,0)"
^XMB(3.9,145834,2,2378,0)=" . S SERVICE=ALPHA(SERVICENAME)"
^XMB(3.9,145834,2,2379,0)="""RTN"",""MAGDRPCE"",33,0)"
^XMB(3.9,145834,2,2380,0)=" . S OUT(NOUT)=SERVICENAME_""^""_SERVICE"
^XMB(3.9,145834,2,2381,0)="""RTN"",""MAGDRPCE"",34,0)"
^XMB(3.9,145834,2,2382,0)=" . Q"
^XMB(3.9,145834,2,2383,0)="""RTN"",""MAGDRPCE"",35,0)"
^XMB(3.9,145834,2,2384,0)=" I '$D(OUT(1)) S OUT(1)=NOUT-1 ; allow error messages to be passed back in OUT(1)"
^XMB(3.9,145834,2,2385,0)="""RTN"",""MAGDRPCE"",36,0)"
^XMB(3.9,145834,2,2386,0)=" Q"
^XMB(3.9,145834,2,2387,0)="""RTN"",""MAGDRPCE"",37,0)"
^XMB(3.9,145834,2,2388,0)=" ;"
^XMB(3.9,145834,2,2389,0)="""RTN"",""MAGDRPCE"",38,0)"
^XMB(3.9,145834,2,2390,0)="GMRCDATE(OUT,SORTORDER,SERVICE,STATUS,DATE,GMRCIEN) ; RPC = MAG DICOM GET CON BY DATE"
^XMB(3.9,145834,2,2391,0)="""RTN"",""MAGDRPCE"",39,0)"
^XMB(3.9,145834,2,2392,0)=" N DIRECTION,SERVICES"
^XMB(3.9,145834,2,2393,0)="""RTN"",""MAGDRPCE"",40,0)"
^XMB(3.9,145834,2,2394,0)=" K OUT"
^XMB(3.9,145834,2,2395,0)="""RTN"",""MAGDRPCE"",41,0)"
^XMB(3.9,145834,2,2396,0)=" I '$D(SORTORDER) S OUT=""-1,SORTORDER required"" Q"
^XMB(3.9,145834,2,2397,0)="""RTN"",""MAGDRPCE"",42,0)"
^XMB(3.9,145834,2,2398,0)=" I SORTORDER=""ASCENDING"" S DIRECTION=1"
^XMB(3.9,145834,2,2399,0)="""RTN"",""MAGDRPCE"",43,0)"
^XMB(3.9,145834,2,2400,0)=" E  I SORTORDER=""DESCENDING"" S DIRECTION=-1"
^XMB(3.9,145834,2,2401,0)="""RTN"",""MAGDRPCE"",44,0)"
^XMB(3.9,145834,2,2402,0)=" E  S OUT=""-2,SORTORDER must be either ASCENDING or DESCENDING, not """"""_SORTORDER_"""""""" Q"
^XMB(3.9,145834,2,2403,0)="""RTN"",""MAGDRPCE"",45,0)"
^XMB(3.9,145834,2,2404,0)=" I '$D(SERVICE) S OUT=""-3,SERVICE required"" Q"
^XMB(3.9,145834,2,2405,0)="""RTN"",""MAGDRPCE"",46,0)"
^XMB(3.9,145834,2,2406,0)=" ; STATUS=2 for COMPLETE, 5=PENDING, 6=ACTIVE, 8=SCHEDULED, STATUS=9 for PARTIAL RESULTS"
^XMB(3.9,145834,2,2407,0)="""RTN"",""MAGDRPCE"",47,0)"
^XMB(3.9,145834,2,2408,0)=" I '$D(STATUS) S OUT=""-4,STATUS (2, 5, 6, 8 or 9) required"" Q"
^XMB(3.9,145834,2,2409,0)="""RTN"",""MAGDRPCE"",48,0)"
^XMB(3.9,145834,2,2410,0)=" I STATUS'=2,STATUS'=5,STATUS'=6,STATUS'=8,STATUS'=9 D  Q"
^XMB(3.9,145834,2,2411,0)="""RTN"",""MAGDRPCE"",49,0)"
^XMB(3.9,145834,2,2412,0)=" . S OUT=""-5,STATUS (2, 5, 6, 8 or 9) required, not """"""_STATUS_"""""""""
^XMB(3.9,145834,2,2413,0)="""RTN"",""MAGDRPCE"",50,0)"
^XMB(3.9,145834,2,2414,0)=" . Q "
^XMB(3.9,145834,2,2415,0)="""RTN"",""MAGDRPCE"",51,0)"
^XMB(3.9,145834,2,2416,0)=" I '$D(DATE) S OUT=""-6,DATE required (may be null)"" Q"
^XMB(3.9,145834,2,2417,0)="""RTN"",""MAGDRPCE"",52,0)"
^XMB(3.9,145834,2,2418,0)=" I DATE S DATE=$$DATEGMRC(DATE) ; convert to reverse date"
^XMB(3.9,145834,2,2419,0)="""RTN"",""MAGDRPCE"",53,0)"
^XMB(3.9,145834,2,2420,0)=" I '$D(GMRCIEN) D  Q"
^XMB(3.9,145834,2,2421,0)="""RTN"",""MAGDRPCE"",54,0)"
^XMB(3.9,145834,2,2422,0)=" . S DATE=$O(^GMR(123,""AE"",SERVICE,STATUS,DATE),-DIRECTION) ; reverse date"
^XMB(3.9,145834,2,2423,0)="""RTN"",""MAGDRPCE"",55,0)"
^XMB(3.9,145834,2,2424,0)=" . S OUT=$$DATEGMRC(DATE) ; convert back to regular Fileman date"
^XMB(3.9,145834,2,2425,0)="""RTN"",""MAGDRPCE"",56,0)"
^XMB(3.9,145834,2,2426,0)=" . Q"
^XMB(3.9,145834,2,2427,0)="""RTN"",""MAGDRPCE"",57,0)"
^XMB(3.9,145834,2,2428,0)=" F  S GMRCIEN=$O(^GMR(123,""AE"",SERVICE,STATUS,DATE,GMRCIEN)) Q:GMRCIEN=""""  D  Q:OUT  ; normal direction"
^XMB(3.9,145834,2,2429,0)="""RTN"",""MAGDRPCE"",58,0)"
^XMB(3.9,145834,2,2430,0)=" . S SERVICES(SERVICE)=1"
^XMB(3.9,145834,2,2431,0)="""RTN"",""MAGDRPCE"",59,0)"
^XMB(3.9,145834,2,2432,0)=" . S OUT=$$CHKIMAGE(GMRCIEN,.SERVICES) ; only return consults with images"
^XMB(3.9,145834,2,2433,0)="""RTN"",""MAGDRPCE"",60,0)"
^XMB(3.9,145834,2,2434,0)=" . Q"
^XMB(3.9,145834,2,2435,0)="""RTN"",""MAGDRPCE"",61,0)"
^XMB(3.9,145834,2,2436,0)=" S OUT=GMRCIEN"
^XMB(3.9,145834,2,2437,0)="""RTN"",""MAGDRPCE"",62,0)"
^XMB(3.9,145834,2,2438,0)=" Q"
^XMB(3.9,145834,2,2439,0)="""RTN"",""MAGDRPCE"",63,0)"
^XMB(3.9,145834,2,2440,0)=" ;"
^XMB(3.9,145834,2,2441,0)="""RTN"",""MAGDRPCE"",64,0)"
^XMB(3.9,145834,2,2442,0)="GMRCPAT(OUT,SORTORDER,DFN,DATE,GMRCIEN,SERVICES) ; RPC = MAG DICOM GET CON BY PATIENT"
^XMB(3.9,145834,2,2443,0)="""RTN"",""MAGDRPCE"",65,0)"
^XMB(3.9,145834,2,2444,0)=" N DIRECTION"
^XMB(3.9,145834,2,2445,0)="""RTN"",""MAGDRPCE"",66,0)"
^XMB(3.9,145834,2,2446,0)=" K OUT"
^XMB(3.9,145834,2,2447,0)="""RTN"",""MAGDRPCE"",67,0)"
^XMB(3.9,145834,2,2448,0)=" I '$D(SORTORDER) S OUT=""-1,SORTORDER required"" Q"
^XMB(3.9,145834,2,2449,0)="""RTN"",""MAGDRPCE"",68,0)"
^XMB(3.9,145834,2,2450,0)=" I SORTORDER=""ASCENDING"" S DIRECTION=1"
^XMB(3.9,145834,2,2451,0)="""RTN"",""MAGDRPCE"",69,0)"
^XMB(3.9,145834,2,2452,0)=" E  I SORTORDER=""DESCENDING"" S DIRECTION=-1"
^XMB(3.9,145834,2,2453,0)="""RTN"",""MAGDRPCE"",70,0)"
^XMB(3.9,145834,2,2454,0)=" E  S OUT=""-2,SORTORDER must be either ASCENDING or DESCENDING, not """"""_SORTORDER_"""""""" Q"
^XMB(3.9,145834,2,2455,0)="""RTN"",""MAGDRPCE"",71,0)"
^XMB(3.9,145834,2,2456,0)=" I '$G(DFN) S OUT=""-3,DFN required and may not be null"" Q"
^XMB(3.9,145834,2,2457,0)="""RTN"",""MAGDRPCE"",72,0)"
^XMB(3.9,145834,2,2458,0)=" I '$D(DATE) S OUT=""-4,DATE required and may not be null"" Q"
^XMB(3.9,145834,2,2459,0)="""RTN"",""MAGDRPCE"",73,0)"
^XMB(3.9,145834,2,2460,0)=" ;"
^XMB(3.9,145834,2,2461,0)="""RTN"",""MAGDRPCE"",74,0)"
^XMB(3.9,145834,2,2462,0)=" I DATE=0 S DATE="""""
^XMB(3.9,145834,2,2463,0)="""RTN"",""MAGDRPCE"",75,0)"
^XMB(3.9,145834,2,2464,0)=" E  S DATE=$$DATEGMRC(DATE) ; convert to reverse date"
^XMB(3.9,145834,2,2465,0)="""RTN"",""MAGDRPCE"",76,0)"
^XMB(3.9,145834,2,2466,0)=" ;"
^XMB(3.9,145834,2,2467,0)="""RTN"",""MAGDRPCE"",77,0)"
^XMB(3.9,145834,2,2468,0)=" I '$D(GMRCIEN) D  ; $O DATE"
^XMB(3.9,145834,2,2469,0)="""RTN"",""MAGDRPCE"",78,0)"
^XMB(3.9,145834,2,2470,0)=" . S OUT=$O(^GMR(123,""AD"",DFN,DATE),-DIRECTION) ; reverse date"
^XMB(3.9,145834,2,2471,0)="""RTN"",""MAGDRPCE"",79,0)"
^XMB(3.9,145834,2,2472,0)=" . I OUT S OUT=$$DATEGMRC(OUT) ; convert back to regular Fileman date"
^XMB(3.9,145834,2,2473,0)="""RTN"",""MAGDRPCE"",80,0)"
^XMB(3.9,145834,2,2474,0)=" . Q"
^XMB(3.9,145834,2,2475,0)="""RTN"",""MAGDRPCE"",81,0)"
^XMB(3.9,145834,2,2476,0)=" E  D  ; $O GMRCIEN to find next consult for the service for this patient"
^XMB(3.9,145834,2,2477,0)="""RTN"",""MAGDRPCE"",82,0)"
^XMB(3.9,145834,2,2478,0)=" . N HIT,TOSERVICE"
^XMB(3.9,145834,2,2479,0)="""RTN"",""MAGDRPCE"",83,0)"
^XMB(3.9,145834,2,2480,0)=" . I '$D(SERVICES) S OUT=""-4,SERVICES is required"" Q"
^XMB(3.9,145834,2,2481,0)="""RTN"",""MAGDRPCE"",84,0)"
^XMB(3.9,145834,2,2482,0)=" . I GMRCIEN=0 S GMRCIEN="""""
^XMB(3.9,145834,2,2483,0)="""RTN"",""MAGDRPCE"",85,0)"
^XMB(3.9,145834,2,2484,0)=" . S HIT=0"
^XMB(3.9,145834,2,2485,0)="""RTN"",""MAGDRPCE"",86,0)"
^XMB(3.9,145834,2,2486,0)=" . F  S GMRCIEN=$O(^GMR(123,""AD"",DFN,DATE,GMRCIEN),DIRECTION) Q:'GMRCIEN  D  Q:HIT"
^XMB(3.9,145834,2,2487,0)="""RTN"",""MAGDRPCE"",87,0)"
^XMB(3.9,145834,2,2488,0)=" . . S TOSERVICE=$$GET1^DIQ(123,GMRCIEN,1,""I"")"
^XMB(3.9,145834,2,2489,0)="""RTN"",""MAGDRPCE"",88,0)"
^XMB(3.9,145834,2,2490,0)=" . . I $D(SERVICES(+TOSERVICE)) S HIT=1 ; found a consult for a requested TO SERVICE"
^XMB(3.9,145834,2,2491,0)="""RTN"",""MAGDRPCE"",89,0)"
^XMB(3.9,145834,2,2492,0)=" . . S HIT=$$CHKIMAGE(GMRCIEN,.SERVICES)"
^XMB(3.9,145834,2,2493,0)="""RTN"",""MAGDRPCE"",90,0)"
^XMB(3.9,145834,2,2494,0)=" . . Q"
^XMB(3.9,145834,2,2495,0)="""RTN"",""MAGDRPCE"",91,0)"
^XMB(3.9,145834,2,2496,0)=" . S OUT=GMRCIEN"
^XMB(3.9,145834,2,2497,0)="""RTN"",""MAGDRPCE"",92,0)"
^XMB(3.9,145834,2,2498,0)=" . Q"
^XMB(3.9,145834,2,2499,0)="""RTN"",""MAGDRPCE"",93,0)"
^XMB(3.9,145834,2,2500,0)=" Q"
^XMB(3.9,145834,2,2501,0)="""RTN"",""MAGDRPCE"",94,0)"
^XMB(3.9,145834,2,2502,0)=" ;"
^XMB(3.9,145834,2,2503,0)="""RTN"",""MAGDRPCE"",95,0)"
^XMB(3.9,145834,2,2504,0)="GMRCIEN(OUT,DIRECTION,GMRCIEN,SERVICES) ; RPC = MAG DICOM GET CON BY GMRCIEN"
^XMB(3.9,145834,2,2505,0)="""RTN"",""MAGDRPCE"",96,0)"
^XMB(3.9,145834,2,2506,0)=" K OUT"
^XMB(3.9,145834,2,2507,0)="""RTN"",""MAGDRPCE"",97,0)"
^XMB(3.9,145834,2,2508,0)=" I '$D(DIRECTION) S OUT=""-1,DIRECTION required"" Q"
^XMB(3.9,145834,2,2509,0)="""RTN"",""MAGDRPCE"",98,0)"
^XMB(3.9,145834,2,2510,0)=" I DIRECTION=""ASCENDING"" S DIRECTION=1"
^XMB(3.9,145834,2,2511,0)="""RTN"",""MAGDRPCE"",99,0)"
^XMB(3.9,145834,2,2512,0)=" E  I DIRECTION=""DESCENDING"" S DIRECTION=-1"
^XMB(3.9,145834,2,2513,0)="""RTN"",""MAGDRPCE"",100,0)"
^XMB(3.9,145834,2,2514,0)=" E  S OUT=""-2,DIRECTION must be either ASCENDING or DESCENDING, not """"""_DIRECTION_"""""""" Q"
^XMB(3.9,145834,2,2515,0)="""RTN"",""MAGDRPCE"",101,0)"
^XMB(3.9,145834,2,2516,0)=" I '$D(GMRCIEN) S OUT=""-3,GMRCIEN is required (may be null)"" Q"
^XMB(3.9,145834,2,2517,0)="""RTN"",""MAGDRPCE"",102,0)"
^XMB(3.9,145834,2,2518,0)=" I '$D(SERVICES) S OUT=""-4,SERVICES is required"" Q"
^XMB(3.9,145834,2,2519,0)="""RTN"",""MAGDRPCE"",103,0)"
^XMB(3.9,145834,2,2520,0)=" ; find the next consult/procedure for the services"
^XMB(3.9,145834,2,2521,0)="""RTN"",""MAGDRPCE"",104,0)"
^XMB(3.9,145834,2,2522,0)=" S OUT=0"
^XMB(3.9,145834,2,2523,0)="""RTN"",""MAGDRPCE"",105,0)"
^XMB(3.9,145834,2,2524,0)=" F  S GMRCIEN=$O(^GMR(123,GMRCIEN),DIRECTION)  Q:'GMRCIEN  D  Q:OUT"
^XMB(3.9,145834,2,2525,0)="""RTN"",""MAGDRPCE"",106,0)"
^XMB(3.9,145834,2,2526,0)=" . S OUT=$$CHKIMAGE(GMRCIEN,.SERVICES)"
^XMB(3.9,145834,2,2527,0)="""RTN"",""MAGDRPCE"",107,0)"
^XMB(3.9,145834,2,2528,0)=" . Q"
^XMB(3.9,145834,2,2529,0)="""RTN"",""MAGDRPCE"",108,0)"
^XMB(3.9,145834,2,2530,0)=" Q"
^XMB(3.9,145834,2,2531,0)="""RTN"",""MAGDRPCE"",109,0)"
^XMB(3.9,145834,2,2532,0)=" ;"
^XMB(3.9,145834,2,2533,0)="""RTN"",""MAGDRPCE"",110,0)"
^XMB(3.9,145834,2,2534,0)="DATEGMRC(GMRCDATE) ; convert a GMRC date to a FM date and vice versa"
^XMB(3.9,145834,2,2535,0)="""RTN"",""MAGDRPCE"",111,0)"
^XMB(3.9,145834,2,2536,0)=" Q 9999999.999999-GMRCDATE ; unlike radiology which uses 9999999.9999"
^XMB(3.9,145834,2,2537,0)="""RTN"",""MAGDRPCE"",112,0)"
^XMB(3.9,145834,2,2538,0)=" ;"
^XMB(3.9,145834,2,2539,0)="""RTN"",""MAGDRPCE"",113,0)"
^XMB(3.9,145834,2,2540,0)="CHKIMAGE(GMRCIEN,SERVICES) ; check to see if there are images"
^XMB(3.9,145834,2,2541,0)="""RTN"",""MAGDRPCE"",114,0)"
^XMB(3.9,145834,2,2542,0)=" N HIT,STATUS,TIUIEN,TOSERVICE"
^XMB(3.9,145834,2,2543,0)="""RTN"",""MAGDRPCE"",115,0)"
^XMB(3.9,145834,2,2544,0)=" S HIT=0"
^XMB(3.9,145834,2,2545,0)="""RTN"",""MAGDRPCE"",116,0)"
^XMB(3.9,145834,2,2546,0)=" ;"
^XMB(3.9,145834,2,2547,0)="""RTN"",""MAGDRPCE"",117,0)"
^XMB(3.9,145834,2,2548,0)=" ; STATUS=2 for COMPLETE, 5=PENDING, 6=ACTIVE, 8=SCHEDULED, STATUS=9 for PARTIAL RESULTS"
^XMB(3.9,145834,2,2549,0)="""RTN"",""MAGDRPCE"",118,0)"
^XMB(3.9,145834,2,2550,0)=" S STATUS=$$GET1^DIQ(123,GMRCIEN,8,""I"")"
^XMB(3.9,145834,2,2551,0)="""RTN"",""MAGDRPCE"",119,0)"
^XMB(3.9,145834,2,2552,0)=" I STATUS'=2,STATUS'=5,STATUS'=6,STATUS'=8,STATUS'=9 Q HIT"
^XMB(3.9,145834,2,2553,0)="""RTN"",""MAGDRPCE"",120,0)"
^XMB(3.9,145834,2,2554,0)=" ;"
^XMB(3.9,145834,2,2555,0)="""RTN"",""MAGDRPCE"",121,0)"
^XMB(3.9,145834,2,2556,0)=" S TOSERVICE=$$GET1^DIQ(123,GMRCIEN,1,""I"")"
^XMB(3.9,145834,2,2557,0)="""RTN"",""MAGDRPCE"",122,0)"
^XMB(3.9,145834,2,2558,0)=" I $D(SERVICES(+TOSERVICE)) D  ; consult has a requested TO SERVICE"
^XMB(3.9,145834,2,2559,0)="""RTN"",""MAGDRPCE"",123,0)"
^XMB(3.9,145834,2,2560,0)=" . ; images can be assocated with the TIU External Data file (#8925.91),"
^XMB(3.9,145834,2,2561,0)="""RTN"",""MAGDRPCE"",124,0)"
^XMB(3.9,145834,2,2562,0)=" . ; or DICOM GMRC TEMP LIST file (#2006.5839), or stored in the new"
^XMB(3.9,145834,2,2563,0)="""RTN"",""MAGDRPCE"",125,0)"
^XMB(3.9,145834,2,2564,0)=" . ; SOP Class database IMAGE STUDY file (#2005.62) -- check all three"
^XMB(3.9,145834,2,2565,0)="""RTN"",""MAGDRPCE"",126,0)"
^XMB(3.9,145834,2,2566,0)=" . S TIUIEN=$$GET1^DIQ(123,GMRCIEN,16,""I"")"
^XMB(3.9,145834,2,2567,0)="""RTN"",""MAGDRPCE"",127,0)"
^XMB(3.9,145834,2,2568,0)=" . I TIUIEN,$D(^TIU(8925.91,""B"",TIUIEN)) S HIT=GMRCIEN"
^XMB(3.9,145834,2,2569,0)="""RTN"",""MAGDRPCE"",128,0)"
^XMB(3.9,145834,2,2570,0)=" . I $D(^MAG(2006.5839,""C"",123,GMRCIEN)) S HIT=GMRCIEN"
^XMB(3.9,145834,2,2571,0)="""RTN"",""MAGDRPCE"",129,0)"
^XMB(3.9,145834,2,2572,0)=" . I $D(^MAGV(2005.62,""D"",$$GMRCACN^MAGDFCNV(GMRCIEN))) S HIT=GMRCIEN"
^XMB(3.9,145834,2,2573,0)="""RTN"",""MAGDRPCE"",130,0)"
^XMB(3.9,145834,2,2574,0)=" Q HIT"
^XMB(3.9,145834,2,2575,0)="""RTN"",""MAGDRPCE"",131,0)"
^XMB(3.9,145834,2,2576,0)=" ;"
^XMB(3.9,145834,2,2577,0)="""RTN"",""MAGDRPCE"",132,0)"
^XMB(3.9,145834,2,2578,0)="GMRCDATA(OUT,GMRCIEN,FIELD,FORMAT) ; RPC = MAG DICOM GET CON DATA"
^XMB(3.9,145834,2,2579,0)="""RTN"",""MAGDRPCE"",133,0)"
^XMB(3.9,145834,2,2580,0)=" I '$D(GMRCIEN) S OUT=""-1,GMRCIEN required"" Q"
^XMB(3.9,145834,2,2581,0)="""RTN"",""MAGDRPCE"",134,0)"
^XMB(3.9,145834,2,2582,0)=" I '$D(FIELD) S OUT=""-2,FIELD required"" Q"
^XMB(3.9,145834,2,2583,0)="""RTN"",""MAGDRPCE"",135,0)"
^XMB(3.9,145834,2,2584,0)=" I $G(FORMAT)="""" S FORMAT=""E"""
^XMB(3.9,145834,2,2585,0)="""RTN"",""MAGDRPCE"",136,0)"
^XMB(3.9,145834,2,2586,0)=" S OUT=$$GET1^DIQ(123,GMRCIEN,FIELD,FORMAT)"
^XMB(3.9,145834,2,2587,0)="""RTN"",""MAGDRPCE"",137,0)"
^XMB(3.9,145834,2,2588,0)=" Q"
^XMB(3.9,145834,2,2589,0)="""RTN"",""MAGDRPCE"",138,0)"
^XMB(3.9,145834,2,2590,0)=" ;"
^XMB(3.9,145834,2,2591,0)="""RTN"",""MAGDRPCE"",139,0)"
^XMB(3.9,145834,2,2592,0)=" ;"
^XMB(3.9,145834,2,2593,0)="""RTN"",""MAGDRPCE"",140,0)"
^XMB(3.9,145834,2,2594,0)="GMRCMAG(OUT,GMRCIEN) ; RPC = MAG DICOM GET CON IMAGES"
^XMB(3.9,145834,2,2595,0)="""RTN"",""MAGDRPCE"",141,0)"
^XMB(3.9,145834,2,2596,0)=" ; return the image groups, if there are any"
^XMB(3.9,145834,2,2597,0)="""RTN"",""MAGDRPCE"",142,0)"
^XMB(3.9,145834,2,2598,0)=" N I,MAG20065839IEN,MAGIEN,TIU892591IEN,MAG20065839ZERO,TIU892591ZERO,TIUIEN,RETURN"
^XMB(3.9,145834,2,2599,0)="""RTN"",""MAGDRPCE"",143,0)"
^XMB(3.9,145834,2,2600,0)=" K OUT S I=1"
^XMB(3.9,145834,2,2601,0)="""RTN"",""MAGDRPCE"",144,0)"
^XMB(3.9,145834,2,2602,0)=" S TIUIEN=$$GET1^DIQ(123,GMRCIEN,16,""I"")"
^XMB(3.9,145834,2,2603,0)="""RTN"",""MAGDRPCE"",145,0)"
^XMB(3.9,145834,2,2604,0)=" I TIUIEN,$D(^TIU(8925.91,""B"",TIUIEN)) D"
^XMB(3.9,145834,2,2605,0)="""RTN"",""MAGDRPCE"",146,0)"
^XMB(3.9,145834,2,2606,0)=" . S TIU892591IEN="""""
^XMB(3.9,145834,2,2607,0)="""RTN"",""MAGDRPCE"",147,0)"
^XMB(3.9,145834,2,2608,0)=" . F  S TIU892591IEN=$O(^TIU(8925.91,""B"",TIUIEN,TIU892591IEN)) Q:TIU892591IEN=""""  D"
^XMB(3.9,145834,2,2609,0)="""RTN"",""MAGDRPCE"",148,0)"
^XMB(3.9,145834,2,2610,0)=" . . S TIU892591ZERO=$G(^TIU(8925.91,TIU892591IEN,0))"
^XMB(3.9,145834,2,2611,0)="""RTN"",""MAGDRPCE"",149,0)"
^XMB(3.9,145834,2,2612,0)=" . . S MAGIEN=$P(TIU892591ZERO,""^"",2)"
^XMB(3.9,145834,2,2613,0)="""RTN"",""MAGDRPCE"",150,0)"
^XMB(3.9,145834,2,2614,0)=" . . S I=I+1,OUT(I)=MAGIEN"
^XMB(3.9,145834,2,2615,0)="""RTN"",""MAGDRPCE"",151,0)"
^XMB(3.9,145834,2,2616,0)=" . . Q"
^XMB(3.9,145834,2,2617,0)="""RTN"",""MAGDRPCE"",152,0)"
^XMB(3.9,145834,2,2618,0)=" . Q"
^XMB(3.9,145834,2,2619,0)="""RTN"",""MAGDRPCE"",153,0)"
^XMB(3.9,145834,2,2620,0)=" I $D(^MAG(2006.5839,""C"",123,GMRCIEN)) D"
^XMB(3.9,145834,2,2621,0)="""RTN"",""MAGDRPCE"",154,0)"
^XMB(3.9,145834,2,2622,0)=" . S MAG20065839IEN="""""
^XMB(3.9,145834,2,2623,0)="""RTN"",""MAGDRPCE"",155,0)"
^XMB(3.9,145834,2,2624,0)=" . F  S MAG20065839IEN=$O(^MAG(2006.5839,""C"",123,GMRCIEN,MAG20065839IEN)) Q:MAG20065839IEN=""""  D"
^XMB(3.9,145834,2,2625,0)="""RTN"",""MAGDRPCE"",156,0)"
^XMB(3.9,145834,2,2626,0)=" . . S MAG20065839ZERO=$G(^MAG(2006.5839,MAG20065839IEN,0))"
^XMB(3.9,145834,2,2627,0)="""RTN"",""MAGDRPCE"",157,0)"
^XMB(3.9,145834,2,2628,0)=" . . S MAGIEN=$P(MAG20065839ZERO,""^"",3)"
^XMB(3.9,145834,2,2629,0)="""RTN"",""MAGDRPCE"",158,0)"
^XMB(3.9,145834,2,2630,0)=" . . S I=I+1,OUT(I)=MAGIEN"
^XMB(3.9,145834,2,2631,0)="""RTN"",""MAGDRPCE"",159,0)"
^XMB(3.9,145834,2,2632,0)=" . . Q"
^XMB(3.9,145834,2,2633,0)="""RTN"",""MAGDRPCE"",160,0)"
^XMB(3.9,145834,2,2634,0)=" . Q"
^XMB(3.9,145834,2,2635,0)="""RTN"",""MAGDRPCE"",161,0)"
^XMB(3.9,145834,2,2636,0)=" I $D(^MAGV(2005.62,""D"",$$GMRCACN^MAGDFCNV(GMRCIEN))) D"
^XMB(3.9,145834,2,2637,0)="""RTN"",""MAGDRPCE"",162,0)"
^XMB(3.9,145834,2,2638,0)=" . S I=I+1,OUT(I)=""New SOP Class DB"""
^XMB(3.9,145834,2,2639,0)="""RTN"",""MAGDRPCE"",163,0)"
^XMB(3.9,145834,2,2640,0)=" . Q"
^XMB(3.9,145834,2,2641,0)="""RTN"",""MAGDRPCE"",164,0)"
^XMB(3.9,145834,2,2642,0)=" S OUT(1)=I-1"
^XMB(3.9,145834,2,2643,0)="""RTN"",""MAGDRPCE"",165,0)"
^XMB(3.9,145834,2,2644,0)=" Q"
