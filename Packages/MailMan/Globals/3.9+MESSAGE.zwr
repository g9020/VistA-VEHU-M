^XMB(3.9,145833,2,712,0)="0^4^B65806356"
^XMB(3.9,145833,2,713,0)="""RTN"",""SDES2UTDT"",1,0)"
^XMB(3.9,145833,2,714,0)="SDES2UTDT ;ALB/TAW -Scheduling Encapsulation Utilities ;OCT 14,2025"
