^XMB(3.9,144657,2,9640,0)=" S ELINE=$$SET(""                   EII Active: "",$$GET1^DIQ(350.9,""1,"",13.02),ELINE,1)"
^XMB(3.9,144657,2,9641,0)="""RTN"",""IBJPI"",89,0)"
^XMB(3.9,144657,2,9642,0)=" ;S ELINE=STRTLN"
^XMB(3.9,144657,2,9643,0)="""RTN"",""IBJPI"",90,0)"
^XMB(3.9,144657,2,9644,0)=" S ELINE=$$SET("""",$J("""",40),ELINE,1)            ; Spacing Blank Line"
^XMB(3.9,144657,2,9645,0)="""RTN"",""IBJPI"",91,0)"
^XMB(3.9,144657,2,9646,0)=" S ELINE=$$SET(""  IIU Settings "","""",ELINE,1)"
^XMB(3.9,144657,2,9647,0)="""RTN"",""IBJPI"",92,0)"
