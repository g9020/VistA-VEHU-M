^XMB(3.9,144657,2,1146,0)=" ;   IBRTYP : Read Type and Input modifiers^Input Parameters^Input Transform (Required)"
^XMB(3.9,144657,2,1147,0)="""RTN"",""IBCNBAA"",277,0)"
^XMB(3.9,144657,2,1148,0)=" ;   IBPROM : Prompt text that user will see"
^XMB(3.9,144657,2,1149,0)="""RTN"",""IBCNBAA"",278,0)"
^XMB(3.9,144657,2,1150,0)=" ;   IBDFLT : Default response"
^XMB(3.9,144657,2,1151,0)="""RTN"",""IBCNBAA"",279,0)"
^XMB(3.9,144657,2,1152,0)=" ;   IBHELP : Help text to display"
^XMB(3.9,144657,2,1153,0)="""RTN"",""IBCNBAA"",280,0)"
^XMB(3.9,144657,2,1154,0)=" ;   IBSCRN : Screen for pointer, set-of-code, and list/range reads"
^XMB(3.9,144657,2,1155,0)="""RTN"",""IBCNBAA"",281,0)"
^XMB(3.9,144657,2,1156,0)=" ;"
^XMB(3.9,144657,2,1157,0)="""RTN"",""IBCNBAA"",282,0)"
^XMB(3.9,144657,2,1158,0)=" N DIR,X,Y"
^XMB(3.9,144657,2,1159,0)="""RTN"",""IBCNBAA"",283,0)"
^XMB(3.9,144657,2,1160,0)=" ;"
^XMB(3.9,144657,2,1161,0)="""RTN"",""IBCNBAA"",284,0)"
