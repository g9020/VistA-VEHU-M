^XMB(3.9,145837,2,229,0)="""QUES"",""XPZ2"",""??"")"
^XMB(3.9,145837,2,230,0)="^D RTN^XPDH"
^XMB(3.9,145837,2,231,0)="""QUES"",""XPZ2"",""A"")"
^XMB(3.9,145837,2,232,0)="Want to MOVE routines to other CPUs"
^XMB(3.9,145837,2,233,0)="""QUES"",""XPZ2"",""B"")"
