^XMB(3.9,145831,2,1040,0)=" .. S X=$S(TYPE=""T"":""F"",TYPE=""HT"":""in"",TYPE=""WT"":""lb"",TYPE=""CVP"":""cmH2O"",TYPE=""CG"":""in"",1:"""")"
^XMB(3.9,145831,2,1041,0)="""RTN"",""EDPVIT"",88,0)"
^XMB(3.9,145831,2,1042,0)=" .. S:$L(X) EDPX(""ussUnits"")=X I $L($P(REC,U,13)) D"
^XMB(3.9,145831,2,1043,0)="""RTN"",""EDPVIT"",89,0)"
^XMB(3.9,145831,2,1044,0)=" ... S X=$S(TYPE=""T"":""C"",TYPE=""HT"":""cm"",TYPE=""WT"":""kg"",TYPE=""CVP"":""mmHg"",TYPE=""CG"":""cm"",1:"""")"
^XMB(3.9,145831,2,1045,0)="""RTN"",""EDPVIT"",90,0)"
