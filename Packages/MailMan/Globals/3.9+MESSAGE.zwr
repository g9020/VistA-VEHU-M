^XMB(3.9,144659,2,347,0)="""RTN"",""IBCRHBRV"",50,0)"
^XMB(3.9,144659,2,348,0)="VERSITE(SITE) ; returns the list of versions loaded for a particular site"
^XMB(3.9,144659,2,349,0)="""RTN"",""IBCRHBRV"",51,0)"
^XMB(3.9,144659,2,350,0)=" ; *** uses 99201 in the RC PHYSICIAN set to check which versions/dates are loaded"
^XMB(3.9,144659,2,351,0)="""RTN"",""IBCRHBRV"",52,0)"
^XMB(3.9,144659,2,352,0)=" ; *** so 99201 must have a pro charge in all versions, if not it must be replaced with an item that does"
^XMB(3.9,144659,2,353,0)="""RTN"",""IBCRHBRV"",53,0)"
^XMB(3.9,144659,2,354,0)=" ; *693 - 99202 for 4.215 "
^XMB(3.9,144659,2,355,0)="""RTN"",""IBCRHBRV"",54,0)"
^XMB(3.9,144659,2,356,0)=" N IBCS,IBXRF,IBITM,IBITM2,IBVERS,IBCSFN,IBI,IBV,IBX,IBY,IBC"
^XMB(3.9,144659,2,357,0)="""RTN"",""IBCRHBRV"",55,0)"
^XMB(3.9,144659,2,358,0)=" S IBVERS=$$VERSALL,IBITM=99201,IBITM2=99202"
^XMB(3.9,144659,2,359,0)="""RTN"",""IBCRHBRV"",56,0)"
^XMB(3.9,144659,2,360,0)=" ;"
^XMB(3.9,144659,2,361,0)="""RTN"",""IBCRHBRV"",57,0)"
^XMB(3.9,144659,2,362,0)=" I $G(SITE)'="""" S IBCS=""RC-PHYSICIAN"" F  S IBCS=$O(^IBE(363.1,""B"",IBCS)) Q:IBCS'[""RC-PHYSICIAN""  D"
^XMB(3.9,144659,2,363,0)="""RTN"",""IBCRHBRV"",58,0)"
^XMB(3.9,144659,2,364,0)=" . S IBV=$L(IBCS,"" "") I $P(IBCS,"" "",IBV)'=SITE Q"
^XMB(3.9,144659,2,365,0)="""RTN"",""IBCRHBRV"",59,0)"
^XMB(3.9,144659,2,366,0)=" . S IBCSFN=$O(^IBE(363.1,""B"",IBCS,0)) Q:'IBCSFN  S IBXRF=""AIVDTS""_IBCSFN"
^XMB(3.9,144659,2,367,0)="""RTN"",""IBCRHBRV"",60,0)"
^XMB(3.9,144659,2,368,0)=" . F IBI=1:1 S IBV=$P(IBVERS,U,IBI) Q:'IBV  I ($O(^IBA(363.2,IBXRF,IBITM,-$P(IBV,"";"",2),0)))!($O(^IBA(363.2,IBXRF,IBITM2,-$P(IBV,"";"",2),0))) S IBY(+IBV)="""""
^XMB(3.9,144659,2,369,0)="""RTN"",""IBCRHBRV"",61,0)"
^XMB(3.9,144659,2,370,0)=" ;"
^XMB(3.9,144659,2,371,0)="""RTN"",""IBCRHBRV"",62,0)"
^XMB(3.9,144659,2,372,0)=" S (IBX,IBC)="""" F IBI=1:1 S IBV=+$P(IBVERS,U,IBI) Q:'IBV  I $D(IBY(IBV)) S IBX=IBX_IBC_IBV S IBC="","""
^XMB(3.9,144659,2,373,0)="""RTN"",""IBCRHBRV"",63,0)"
^XMB(3.9,144659,2,374,0)=" ;"
^XMB(3.9,144659,2,375,0)="""RTN"",""IBCRHBRV"",64,0)"
^XMB(3.9,144659,2,376,0)=" Q IBX"
^XMB(3.9,144659,2,377,0)="""RTN"",""IBCRHBRV"",65,0)"
^XMB(3.9,144659,2,378,0)=" ;"
^XMB(3.9,144659,2,379,0)="""RTN"",""IBCRHBRV"",66,0)"
^XMB(3.9,144659,2,380,0)="MSGSITE(SITE) ; display a message indicating which versions are loaded for a site"
^XMB(3.9,144659,2,381,0)="""RTN"",""IBCRHBRV"",67,0)"
^XMB(3.9,144659,2,382,0)=" N IBVERS Q:'$G(SITE)"
^XMB(3.9,144659,2,383,0)="""RTN"",""IBCRHBRV"",68,0)"
^XMB(3.9,144659,2,384,0)=" S IBVERS=$$VERSITE(SITE)"
^XMB(3.9,144659,2,385,0)="""RTN"",""IBCRHBRV"",69,0)"
^XMB(3.9,144659,2,386,0)=" I 'IBVERS W !!,?12,""There appear to be no RC charges already loaded for ""_SITE_""."""
^XMB(3.9,144659,2,387,0)="""RTN"",""IBCRHBRV"",70,0)"
^XMB(3.9,144659,2,388,0)=" I +IBVERS W !!,?12,""RC versions ""_IBVERS_"" appear to be already loaded for ""_SITE_""."""
^XMB(3.9,144659,2,389,0)="""RTN"",""IBCRHBRV"",71,0)"
^XMB(3.9,144659,2,390,0)=" Q"
^XMB(3.9,144659,2,391,0)="""RTN"",""IBCRHBRV"",72,0)"
^XMB(3.9,144659,2,392,0)=" ;"
^XMB(3.9,144659,2,393,0)="""RTN"",""IBCRHBRV"",73,0)"
^XMB(3.9,144659,2,394,0)="MSGVERS(SITE) ; check if versions are being loaded in the correct order, should be loaded in date order"
^XMB(3.9,144659,2,395,0)="""RTN"",""IBCRHBRV"",74,0)"
^XMB(3.9,144659,2,396,0)=" ;   - if loading a version that has already been loaded for the site"
^XMB(3.9,144659,2,397,0)="""RTN"",""IBCRHBRV"",75,0)"
^XMB(3.9,144659,2,398,0)=" ;   - if loading a version when any future versions have already been loaded for the site"
^XMB(3.9,144659,2,399,0)="""RTN"",""IBCRHBRV"",76,0)"
^XMB(3.9,144659,2,400,0)=" ;   - if loading a version when the last version has not yet been loaded for the site"
^XMB(3.9,144659,2,401,0)="""RTN"",""IBCRHBRV"",77,0)"
^XMB(3.9,144659,2,402,0)=" ; *** uses 99201 in the RC PHYSICIAN set to check which versions/dates are loaded"
^XMB(3.9,144659,2,403,0)="""RTN"",""IBCRHBRV"",78,0)"
^XMB(3.9,144659,2,404,0)=" ; *** so 99201 must have a pro charge in all versions, if not it must be replaced with an item that does"
^XMB(3.9,144659,2,405,0)="""RTN"",""IBCRHBRV"",79,0)"
^XMB(3.9,144659,2,406,0)=" N IBVERS,IBVDTC,IBVERSIN,IBVERSC,IBVERSO,IBI,VERSTR Q:'$G(SITE)"
^XMB(3.9,144659,2,407,0)="""RTN"",""IBCRHBRV"",80,0)"
^XMB(3.9,144659,2,408,0)=" ;"
^XMB(3.9,144659,2,409,0)="""RTN"",""IBCRHBRV"",81,0)"
^XMB(3.9,144659,2,410,0)=" S IBVERS=$$VERSION Q:'IBVERS  S IBVDTC=$$VERSDT,IBVERSIN="",""_$$VERSITE(SITE)_"","",IBVERSC="",""_IBVERS_"","""
^XMB(3.9,144659,2,411,0)="""RTN"",""IBCRHBRV"",82,0)"
^XMB(3.9,144659,2,412,0)=" ;"
^XMB(3.9,144659,2,413,0)="""RTN"",""IBCRHBRV"",83,0)"
^XMB(3.9,144659,2,414,0)=" ; check if loading a version that has already been loaded"
^XMB(3.9,144659,2,415,0)="""RTN"",""IBCRHBRV"",84,0)"
^XMB(3.9,144659,2,416,0)=" I IBVERSIN[IBVERSC D"
^XMB(3.9,144659,2,417,0)="""RTN"",""IBCRHBRV"",85,0)"
^XMB(3.9,144659,2,418,0)=" . W !!,?5,""*** It appears version RC v"",IBVERS,"" has already been loaded for this site ***"""
^XMB(3.9,144659,2,419,0)="""RTN"",""IBCRHBRV"",86,0)"
^XMB(3.9,144659,2,420,0)=" ;"
^XMB(3.9,144659,2,421,0)="""RTN"",""IBCRHBRV"",87,0)"
^XMB(3.9,144659,2,422,0)=" ; check if loading a version when any future versions have already been loaded"
^XMB(3.9,144659,2,423,0)="""RTN"",""IBCRHBRV"",88,0)"
^XMB(3.9,144659,2,424,0)=" S VERSTR="",""_$$VERSTR()_"","",VERSTR=$P(VERSTR,IBVERSC,2) ; all versions after current version"
^XMB(3.9,144659,2,425,0)="""RTN"",""IBCRHBRV"",89,0)"
^XMB(3.9,144659,2,426,0)=" F IBI=1:1 S IBVERSO=$P(VERSTR,"","",IBI) Q:'IBVERSO  I IBVERSIN[("",""_IBVERSO_"","")  D"
^XMB(3.9,144659,2,427,0)="""RTN"",""IBCRHBRV"",90,0)"
^XMB(3.9,144659,2,428,0)=" . W !!,?5,"">>> Currently trying to load RC v""_IBVERS_"" but RC v""_IBVERSO_"" appears to be already"",!,?9,""loaded for this site.  The versions should be loaded in date order."""
^XMB(3.9,144659,2,429,0)="""RTN"",""IBCRHBRV"",91,0)"
^XMB(3.9,144659,2,430,0)=" ;"
^XMB(3.9,144659,2,431,0)="""RTN"",""IBCRHBRV"",92,0)"
^XMB(3.9,144659,2,432,0)=" ; check if loading a version when the last version has not yet been loaded"
^XMB(3.9,144659,2,433,0)="""RTN"",""IBCRHBRV"",93,0)"
^XMB(3.9,144659,2,434,0)=" S VERSTR="",""_$$VERSTR(1)_"","",VERSTR=$P(VERSTR,IBVERSC,2) ; all versions before current version, reverse order"
^XMB(3.9,144659,2,435,0)="""RTN"",""IBCRHBRV"",94,0)"
^XMB(3.9,144659,2,436,0)=" S IBVERSO=$P(VERSTR,"","",1) I +IBVERSO,IBVERSIN'[("",""_IBVERSO_"","") D"
^XMB(3.9,144659,2,437,0)="""RTN"",""IBCRHBRV"",95,0)"
^XMB(3.9,144659,2,438,0)=" . W !!,?5,""*** Currently trying to load RC v""_IBVERS_"" but RC v""_IBVERSO_"" does not appear to be"",!,?9,""loaded for this site.  The versions should be loaded in date order."""
^XMB(3.9,144659,2,439,0)="""RTN"",""IBCRHBRV"",96,0)"
^XMB(3.9,144659,2,440,0)=" . W !!,?5,"">>> Continue only if there will never be a need to bill events before "",!,?9,$$FMTE^XLFDT(IBVDTC,2),"" for this site.  If RC v""_IBVERSO_"" will be needed for this site then"",!,?9,""load it first."""
^XMB(3.9,144659,2,441,0)="""RTN"",""IBCRHBRV"",97,0)"
^XMB(3.9,144659,2,442,0)=" ;"
^XMB(3.9,144659,2,443,0)="""RTN"",""IBCRHBRV"",98,0)"
^XMB(3.9,144659,2,444,0)=" Q"
^XMB(3.9,144659,2,445,0)="""RTN"",""IBCRHBRV"",99,0)"
^XMB(3.9,144659,2,446,0)=" ;"
^XMB(3.9,144659,2,447,0)="""RTN"",""IBCRHBRV"",100,0)"
^XMB(3.9,144659,2,448,0)="VERSTR(RVRS) ; returns string containing list of all Reasonable Charges versions with charges, separated by "","""
^XMB(3.9,144659,2,449,0)="""RTN"",""IBCRHBRV"",101,0)"
^XMB(3.9,144659,2,450,0)=" ; RVRS - if set, returns the list of versions in reverse order"
^XMB(3.9,144659,2,451,0)="""RTN"",""IBCRHBRV"",102,0)"
^XMB(3.9,144659,2,452,0)=" N IBI,LINE,IBS,IBR,IBC,IBX  S (IBS,IBR,IBC,IBX)="""""
^XMB(3.9,144659,2,453,0)="""RTN"",""IBCRHBRV"",103,0)"
^XMB(3.9,144659,2,454,0)=" F IBI=1:1 S LINE=$P($T(VLIST+IBI),"";;"",2,99) Q:'LINE  S IBS=IBS_IBC_+LINE,IBR=+LINE_IBC_IBR S IBC="","""
^XMB(3.9,144659,2,455,0)="""RTN"",""IBCRHBRV"",104,0)"
^XMB(3.9,144659,2,456,0)=" S IBX=IBS I +$G(RVRS) S IBX=IBR"
^XMB(3.9,144659,2,457,0)="""RTN"",""IBCRHBRV"",105,0)"
^XMB(3.9,144659,2,458,0)=" Q IBX"
^XMB(3.9,144659,2,459,0)="""RTN"",""IBCRHBRV"",106,0)"
^XMB(3.9,144659,2,460,0)=" ;"
^XMB(3.9,144659,2,461,0)="""RTN"",""IBCRHBRV"",107,0)"
^XMB(3.9,144659,2,462,0)=" ;"
^XMB(3.9,144659,2,463,0)="""RTN"",""IBCRHBRV"",108,0)"
^XMB(3.9,144659,2,464,0)=" ;"
^XMB(3.9,144659,2,465,0)="""RTN"",""IBCRHBRV"",109,0)"
^XMB(3.9,144659,2,466,0)=" ;"
^XMB(3.9,144659,2,467,0)="""RTN"",""IBCRHBRV"",110,0)"
^XMB(3.9,144659,2,468,0)=" ;"
^XMB(3.9,144659,2,469,0)="""RTN"",""IBCRHBRV"",111,0)"
^XMB(3.9,144659,2,470,0)=" ; File Names:  'IBRCyymmx.TXT'   w/ yymm - year month of version release (except v1)"
^XMB(3.9,144659,2,471,0)="""RTN"",""IBCRHBRV"",112,0)"
^XMB(3.9,144659,2,472,0)=" ;              'IBRCyymm', file version identifier prefix, from VLIST text version description"
^XMB(3.9,144659,2,473,0)="""RTN"",""IBCRHBRV"",113,0)"
^XMB(3.9,144659,2,474,0)=" ;              x=A-I/F, single character file identifier, from FTYPE text file description"
^XMB(3.9,144659,2,475,0)="""RTN"",""IBCRHBRV"",114,0)"
^XMB(3.9,144659,2,476,0)=" ;"
^XMB(3.9,144659,2,477,0)="""RTN"",""IBCRHBRV"",115,0)"
^XMB(3.9,144659,2,478,0)="FILES(IBFILES,VERS) ; returns array of source Host Files and data for version requested, pass IBFILES by reference"
^XMB(3.9,144659,2,479,0)="""RTN"",""IBCRHBRV"",116,0)"
^XMB(3.9,144659,2,480,0)=" N IBI,LINE,IBTYPE,IBFILE,IBNAME,IBDESC S VERS=+$G(VERS) I 'VERS S VERS=1"
^XMB(3.9,144659,2,481,0)="""RTN"",""IBCRHBRV"",117,0)"
^XMB(3.9,144659,2,482,0)=" ;"
^XMB(3.9,144659,2,483,0)="""RTN"",""IBCRHBRV"",118,0)"
^XMB(3.9,144659,2,484,0)=" ; get requested versions data"
^XMB(3.9,144659,2,485,0)="""RTN"",""IBCRHBRV"",119,0)"
^XMB(3.9,144659,2,486,0)=" F IBI=1:1 S LINE=$P($T(VLIST+IBI),"";;"",2,99) Q:'LINE  I VERS=+LINE S IBTYPE=$P(LINE,U,2),IBFILE=$P(LINE,U,5) Q"
^XMB(3.9,144659,2,487,0)="""RTN"",""IBCRHBRV"",120,0)"
^XMB(3.9,144659,2,488,0)=" ;"
^XMB(3.9,144659,2,489,0)="""RTN"",""IBCRHBRV"",121,0)"
^XMB(3.9,144659,2,490,0)=" ; get requested versions files"
^XMB(3.9,144659,2,491,0)="""RTN"",""IBCRHBRV"",122,0)"
^XMB(3.9,144659,2,492,0)=" I +$G(IBTYPE) F IBI=1:1 S LINE=$P($T(@(""FT""_IBTYPE)+IBI),"";;"",2,99) Q:LINE=""""  D"
^XMB(3.9,144659,2,493,0)="""RTN"",""IBCRHBRV"",123,0)"
^XMB(3.9,144659,2,494,0)=" . S IBNAME=IBFILE_$P(LINE,"":"",1)_"".TXT"",IBDESC=""RC v""_+VERS_"" ""_$P(LINE,"":"",2,99)"
^XMB(3.9,144659,2,495,0)="""RTN"",""IBCRHBRV"",124,0)"
