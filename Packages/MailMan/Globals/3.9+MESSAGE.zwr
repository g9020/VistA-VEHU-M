^XMB(3.9,144657,2,3067,0)="""RTN"",""IBCNBLE2"",142,0)"
^XMB(3.9,144657,2,3068,0)=" I IBY'="""" D"
^XMB(3.9,144657,2,3069,0)="""RTN"",""IBCNBLE2"",143,0)"
^XMB(3.9,144657,2,3070,0)=" . N COL,N,M,Z,URL,J"
^XMB(3.9,144657,2,3071,0)="""RTN"",""IBCNBLE2"",144,0)"
^XMB(3.9,144657,2,3072,0)=" . S COL=28     ; column to start display"
^XMB(3.9,144657,2,3073,0)="""RTN"",""IBCNBLE2"",145,0)"
^XMB(3.9,144657,2,3074,0)=" . S N=79-COL   ; max length of each line"
^XMB(3.9,144657,2,3075,0)="""RTN"",""IBCNBLE2"",146,0)"
^XMB(3.9,144657,2,3076,0)=" . S M=0        ; array subscript"
^XMB(3.9,144657,2,3077,0)="""RTN"",""IBCNBLE2"",147,0)"
^XMB(3.9,144657,2,3078,0)=" . F Z=1:N:400 S M=M+1,URL(M)=$E(IBY,Z,Z+N-1) I URL(M)="""" K URL(M) Q"
