^XMB(3.9,145833,2,1049,0)="""RTN"",""SDES2UTDT"",169,0)"
^XMB(3.9,145833,2,1050,0)=" ;       GMT date/time in ISO 8601 extended format (No Errors)"
^XMB(3.9,145833,2,1051,0)="""RTN"",""SDES2UTDT"",170,0)"
^XMB(3.9,145833,2,1052,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,1053,0)="""RTN"",""SDES2UTDT"",171,0)"
^XMB(3.9,145833,2,1054,0)=" N SDDTM,SDGMT,SDTIME,SDOFFSET"
^XMB(3.9,145833,2,1055,0)="""RTN"",""SDES2UTDT"",172,0)"
^XMB(3.9,145833,2,1056,0)=" S SDDTM=$$FMTHL7^XLFDT(SDFMDT)"
^XMB(3.9,145833,2,1057,0)="""RTN"",""SDES2UTDT"",173,0)"
^XMB(3.9,145833,2,1058,0)=" Q:SDDTM<0 -1"
^XMB(3.9,145833,2,1059,0)="""RTN"",""SDES2UTDT"",174,0)"
^XMB(3.9,145833,2,1060,0)=" ;extract out date and convert to ISO 8601 extended format"
^XMB(3.9,145833,2,1061,0)="""RTN"",""SDES2UTDT"",175,0)"
^XMB(3.9,145833,2,1062,0)=" S SDGMT=$E(SDDTM,1,4)_""-""_$E(SDDTM,5,6)_""-""_$E(SDDTM,7,8)"
^XMB(3.9,145833,2,1063,0)="""RTN"",""SDES2UTDT"",176,0)"
^XMB(3.9,145833,2,1064,0)=" ;if time is included, extract and convert to ISO 8601 external format"
^XMB(3.9,145833,2,1065,0)="""RTN"",""SDES2UTDT"",177,0)"
^XMB(3.9,145833,2,1066,0)=" I $L(SDDTM)>8 D"
^XMB(3.9,145833,2,1067,0)="""RTN"",""SDES2UTDT"",178,0)"
^XMB(3.9,145833,2,1068,0)=" .S SDTIME=$E(+SDDTM,9,99),SDOFFSET=$$TZ^XLFDT()"
^XMB(3.9,145833,2,1069,0)="""RTN"",""SDES2UTDT"",179,0)"
^XMB(3.9,145833,2,1070,0)=" .;determine if seconds are included in time"
^XMB(3.9,145833,2,1071,0)="""RTN"",""SDES2UTDT"",180,0)"
^XMB(3.9,145833,2,1072,0)=" .I $L(SDTIME)<5 D"
^XMB(3.9,145833,2,1073,0)="""RTN"",""SDES2UTDT"",181,0)"
^XMB(3.9,145833,2,1074,0)=" ..;no seconds included in date/time"
^XMB(3.9,145833,2,1075,0)="""RTN"",""SDES2UTDT"",182,0)"
^XMB(3.9,145833,2,1076,0)=" ..S SDGMT=SDGMT_""T""_$E(SDDTM,9,10)_"":""_$E(SDDTM,11,99)"
^XMB(3.9,145833,2,1077,0)="""RTN"",""SDES2UTDT"",183,0)"
^XMB(3.9,145833,2,1078,0)=" .;seconds included in date/time"
^XMB(3.9,145833,2,1079,0)="""RTN"",""SDES2UTDT"",184,0)"
^XMB(3.9,145833,2,1080,0)=" .E  S SDGMT=SDGMT_""T""_$E(SDTIME,1,2)_"":""_$E(SDTIME,3,4)_"":""_$E(SDTIME,5,6)_SDOFFSET"
^XMB(3.9,145833,2,1081,0)="""RTN"",""SDES2UTDT"",185,0)"
^XMB(3.9,145833,2,1082,0)=" Q SDGMT"
^XMB(3.9,145833,2,1083,0)="""RTN"",""SDES2UTDT"",186,0)"
^XMB(3.9,145833,2,1084,0)=" ;"
^XMB(3.9,145833,2,1085,0)="""RTN"",""SDES2UTDT"",187,0)"
^XMB(3.9,145833,2,1086,0)="GMTTFM(SDGMTDT) ;convert ISO 8601 extended GMT date/time to fileman format"
^XMB(3.9,145833,2,1087,0)="""RTN"",""SDES2UTDT"",188,0)"
^XMB(3.9,145833,2,1088,0)=" ;initialize variables"
^XMB(3.9,145833,2,1089,0)="""RTN"",""SDES2UTDT"",189,0)"
^XMB(3.9,145833,2,1090,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,1091,0)="""RTN"",""SDES2UTDT"",190,0)"
^XMB(3.9,145833,2,1092,0)=" ;INPUT  SDGMTDT - ISO 8601 extended GMT date/time"
^XMB(3.9,145833,2,1093,0)="""RTN"",""SDES2UTDT"",191,0)"
^XMB(3.9,145833,2,1094,0)=" ;OUTPUT -1 error occurred in translation"
^XMB(3.9,145833,2,1095,0)="""RTN"",""SDES2UTDT"",192,0)"
^XMB(3.9,145833,2,1096,0)=" ;       FM date/time (No Errors)"
^XMB(3.9,145833,2,1097,0)="""RTN"",""SDES2UTDT"",193,0)"
^XMB(3.9,145833,2,1098,0)=" ;*****************************************************************"
^XMB(3.9,145833,2,1099,0)="""RTN"",""SDES2UTDT"",194,0)"
^XMB(3.9,145833,2,1100,0)=" N SDFM,SDTIME,SDOFFSET,SDFMDTM,X,Y,%DT"
^XMB(3.9,145833,2,1101,0)="""RTN"",""SDES2UTDT"",195,0)"
^XMB(3.9,145833,2,1102,0)=" ;get offset for VistA Instance"
^XMB(3.9,145833,2,1103,0)="""RTN"",""SDES2UTDT"",196,0)"
^XMB(3.9,145833,2,1104,0)=" S SDOFFSET=$$TZ^XLFDT()"
^XMB(3.9,145833,2,1105,0)="""RTN"",""SDES2UTDT"",197,0)"
^XMB(3.9,145833,2,1106,0)=" ;pattern match date(/time) for correctness"
^XMB(3.9,145833,2,1107,0)="""RTN"",""SDES2UTDT"",198,0)"
^XMB(3.9,145833,2,1108,0)=" Q:((SDGMTDT[""T"")&'(SDGMTDT?4N1""-""2N1""-""2N1""T""2N1"":""2N.E)) -1"
^XMB(3.9,145833,2,1109,0)="""RTN"",""SDES2UTDT"",199,0)"
^XMB(3.9,145833,2,1110,0)=" Q:((SDGMTDT'[""T"")&'(SDGMTDT?4N1""-""2N1""-""2N)) -1"
^XMB(3.9,145833,2,1111,0)="""RTN"",""SDES2UTDT"",200,0)"
^XMB(3.9,145833,2,1112,0)=" ;extract out date, removing punctuation"
^XMB(3.9,145833,2,1113,0)="""RTN"",""SDES2UTDT"",201,0)"
^XMB(3.9,145833,2,1114,0)=" S SDFM=$E(SDGMTDT,1,4)_$E(SDGMTDT,6,7)_$E(SDGMTDT,9,10)"
^XMB(3.9,145833,2,1115,0)="""RTN"",""SDES2UTDT"",202,0)"
^XMB(3.9,145833,2,1116,0)=" ;set parameters to validate date/time"
^XMB(3.9,145833,2,1117,0)="""RTN"",""SDES2UTDT"",203,0)"
^XMB(3.9,145833,2,1118,0)=" S %DT=""TXS"""
^XMB(3.9,145833,2,1119,0)="""RTN"",""SDES2UTDT"",204,0)"
^XMB(3.9,145833,2,1120,0)=" ;extract out time if entered, removing all punctuation except for TZ offset"
^XMB(3.9,145833,2,1121,0)="""RTN"",""SDES2UTDT"",205,0)"
^XMB(3.9,145833,2,1122,0)=" I SDGMTDT>10 D"
^XMB(3.9,145833,2,1123,0)="""RTN"",""SDES2UTDT"",206,0)"
^XMB(3.9,145833,2,1124,0)=" .S SDTIME=$P($E(SDGMTDT,12,99),$E(SDOFFSET,1,1))"
^XMB(3.9,145833,2,1125,0)="""RTN"",""SDES2UTDT"",207,0)"
^XMB(3.9,145833,2,1126,0)=" .;exclude time if 0's else FMTE returns previous date with .24"
^XMB(3.9,145833,2,1127,0)="""RTN"",""SDES2UTDT"",208,0)"
^XMB(3.9,145833,2,1128,0)=" .Q:((SDTIME[""00:00"")!(SDTIME[""00:00:00""))"
^XMB(3.9,145833,2,1129,0)="""RTN"",""SDES2UTDT"",209,0)"
^XMB(3.9,145833,2,1130,0)=" .;determine if seconds are included in time"
^XMB(3.9,145833,2,1131,0)="""RTN"",""SDES2UTDT"",210,0)"
^XMB(3.9,145833,2,1132,0)=" .I $L(SDTIME)<6 D"
^XMB(3.9,145833,2,1133,0)="""RTN"",""SDES2UTDT"",211,0)"
^XMB(3.9,145833,2,1134,0)=" ..;no seconds include in date/time"
^XMB(3.9,145833,2,1135,0)="""RTN"",""SDES2UTDT"",212,0)"
^XMB(3.9,145833,2,1136,0)=" ..S SDFM=SDFM_$E(SDGMTDT,12,13)_$E(SDGMTDT,15,99)"
^XMB(3.9,145833,2,1137,0)="""RTN"",""SDES2UTDT"",213,0)"
^XMB(3.9,145833,2,1138,0)=" .;seconds included in date/time"
^XMB(3.9,145833,2,1139,0)="""RTN"",""SDES2UTDT"",214,0)"
^XMB(3.9,145833,2,1140,0)=" .E  S SDFM=SDFM_$E(SDTIME,1,2)_$E(SDTIME,4,5)_$E(SDTIME,7,8)_""-""_SDOFFSET"
^XMB(3.9,145833,2,1141,0)="""RTN"",""SDES2UTDT"",215,0)"
^XMB(3.9,145833,2,1142,0)=" ;convert date(/time) from HL7 format back to Fileman"
^XMB(3.9,145833,2,1143,0)="""RTN"",""SDES2UTDT"",216,0)"
^XMB(3.9,145833,2,1144,0)=" S SDFMDTM=$$HL7TFM^XLFDT(SDFM)"
^XMB(3.9,145833,2,1145,0)="""RTN"",""SDES2UTDT"",217,0)"
^XMB(3.9,145833,2,1146,0)=" Q:SDFMDTM<0 SDFMDTM ;error occurred in conversion"
^XMB(3.9,145833,2,1147,0)="""RTN"",""SDES2UTDT"",218,0)"
^XMB(3.9,145833,2,1148,0)=" ;check validity of date (including leap year check)"
^XMB(3.9,145833,2,1149,0)="""RTN"",""SDES2UTDT"",219,0)"
^XMB(3.9,145833,2,1150,0)=" S X=$$FMTE^XLFDT(SDFMDTM)"
^XMB(3.9,145833,2,1151,0)="""RTN"",""SDES2UTDT"",220,0)"
^XMB(3.9,145833,2,1152,0)=" D ^%DT"
^XMB(3.9,145833,2,1153,0)="""RTN"",""SDES2UTDT"",221,0)"
^XMB(3.9,145833,2,1154,0)=" Q:Y<0 -1 ;date(/time) not valid"
^XMB(3.9,145833,2,1155,0)="""RTN"",""SDES2UTDT"",222,0)"
^XMB(3.9,145833,2,1156,0)=" Q SDFMDTM"
^XMB(3.9,145833,2,1157,0)="""RTN"",""SDES2UTDT"",223,0)"
^XMB(3.9,145833,2,1158,0)=" ;"
^XMB(3.9,145833,2,1159,0)="""RTN"",""SDES2UTDT"",224,0)"
^XMB(3.9,145833,2,1160,0)="VALIDFMFORMAT(VALID,DATE) ;Is DATE a valind FileMan format"
^XMB(3.9,145833,2,1161,0)="""RTN"",""SDES2UTDT"",225,0)"
^XMB(3.9,145833,2,1162,0)=" ;Return 1=Yes"
^XMB(3.9,145833,2,1163,0)="""RTN"",""SDES2UTDT"",226,0)"
^XMB(3.9,145833,2,1164,0)=" ;       0=No"
^XMB(3.9,145833,2,1165,0)="""RTN"",""SDES2UTDT"",227,0)"
^XMB(3.9,145833,2,1166,0)=" N X,Y,%DT"
^XMB(3.9,145833,2,1167,0)="""RTN"",""SDES2UTDT"",228,0)"
^XMB(3.9,145833,2,1168,0)=" S %DT=""T"",VALID=0"
^XMB(3.9,145833,2,1169,0)="""RTN"",""SDES2UTDT"",229,0)"
^XMB(3.9,145833,2,1170,0)=" I $G(DATE)="""" Q"
^XMB(3.9,145833,2,1171,0)="""RTN"",""SDES2UTDT"",230,0)"
^XMB(3.9,145833,2,1172,0)=" I $$FR^XLFDT(DATE) Q"
^XMB(3.9,145833,2,1173,0)="""RTN"",""SDES2UTDT"",231,0)"
^XMB(3.9,145833,2,1174,0)=" S X=DATE D ^%DT"
^XMB(3.9,145833,2,1175,0)="""RTN"",""SDES2UTDT"",232,0)"
^XMB(3.9,145833,2,1176,0)=" I Y=-1 Q"
^XMB(3.9,145833,2,1177,0)="""RTN"",""SDES2UTDT"",233,0)"
^XMB(3.9,145833,2,1178,0)=" S VALID=1"
^XMB(3.9,145833,2,1179,0)="""RTN"",""SDES2UTDT"",234,0)"
^XMB(3.9,145833,2,1180,0)=" Q"
^XMB(3.9,145833,2,1181,0)="""RTN"",""SDES2UTDT"",235,0)"
^XMB(3.9,145833,2,1182,0)=" ;"
^XMB(3.9,145833,2,1183,0)="""RTN"",""SDES2UTDT"",236,0)"
^XMB(3.9,145833,2,1184,0)="VALIDISO(VALID,DATE) ;Is DATE a valid ISO8601 format (e.g., 2022-01-12T13:21)"
^XMB(3.9,145833,2,1185,0)="""RTN"",""SDES2UTDT"",237,0)"
^XMB(3.9,145833,2,1186,0)=" ; Return"
^XMB(3.9,145833,2,1187,0)="""RTN"",""SDES2UTDT"",238,0)"
^XMB(3.9,145833,2,1188,0)=" ; 0 = not ISO8601 format"
^XMB(3.9,145833,2,1189,0)="""RTN"",""SDES2UTDT"",239,0)"
^XMB(3.9,145833,2,1190,0)=" ; 1 = ISO8601 format"
^XMB(3.9,145833,2,1191,0)="""RTN"",""SDES2UTDT"",240,0)"
^XMB(3.9,145833,2,1192,0)=" N SDDATE,SDTIME,SDOFFSET,KEEPSDTIME"
^XMB(3.9,145833,2,1193,0)="""RTN"",""SDES2UTDT"",241,0)"
^XMB(3.9,145833,2,1194,0)=" S VALID=0"
^XMB(3.9,145833,2,1195,0)="""RTN"",""SDES2UTDT"",242,0)"
^XMB(3.9,145833,2,1196,0)=" I $G(DATE)="""" Q"
^XMB(3.9,145833,2,1197,0)="""RTN"",""SDES2UTDT"",243,0)"
^XMB(3.9,145833,2,1198,0)=" S SDDATE=$P(DATE,""T"")"
^XMB(3.9,145833,2,1199,0)="""RTN"",""SDES2UTDT"",244,0)"
^XMB(3.9,145833,2,1200,0)=" I SDDATE D"
^XMB(3.9,145833,2,1201,0)="""RTN"",""SDES2UTDT"",245,0)"
^XMB(3.9,145833,2,1202,0)=" .;Validate date"
^XMB(3.9,145833,2,1203,0)="""RTN"",""SDES2UTDT"",246,0)"
^XMB(3.9,145833,2,1204,0)=" .;   YYYYMMDD, YYYY-MM-DD or YYYY-MM"
^XMB(3.9,145833,2,1205,0)="""RTN"",""SDES2UTDT"",247,0)"
^XMB(3.9,145833,2,1206,0)=" .I SDDATE?6N Q  ;YYYY-MM is not allowed"
^XMB(3.9,145833,2,1207,0)="""RTN"",""SDES2UTDT"",248,0)"
^XMB(3.9,145833,2,1208,0)=" .S SDDATE=$TR(SDDATE,""-"")"
^XMB(3.9,145833,2,1209,0)="""RTN"",""SDES2UTDT"",249,0)"
^XMB(3.9,145833,2,1210,0)=" .I SDDATE?8N!(SDDATE?6N) S VALID=1"
^XMB(3.9,145833,2,1211,0)="""RTN"",""SDES2UTDT"",250,0)"
^XMB(3.9,145833,2,1212,0)=" ;"
^XMB(3.9,145833,2,1213,0)="""RTN"",""SDES2UTDT"",251,0)"
^XMB(3.9,145833,2,1214,0)=" S (SDTIME,KEEPSDTIME)=$P(DATE,""T"",2)"
^XMB(3.9,145833,2,1215,0)="""RTN"",""SDES2UTDT"",252,0)"
^XMB(3.9,145833,2,1216,0)=" I VALID,SDTIME'="""" D"
^XMB(3.9,145833,2,1217,0)="""RTN"",""SDES2UTDT"",253,0)"
^XMB(3.9,145833,2,1218,0)=" .;Validate time (ignore seconds)"
^XMB(3.9,145833,2,1219,0)="""RTN"",""SDES2UTDT"",254,0)"
^XMB(3.9,145833,2,1220,0)=" .;  THH"
^XMB(3.9,145833,2,1221,0)="""RTN"",""SDES2UTDT"",255,0)"
^XMB(3.9,145833,2,1222,0)=" .;  THHMM or THH:MM"
^XMB(3.9,145833,2,1223,0)="""RTN"",""SDES2UTDT"",256,0)"
^XMB(3.9,145833,2,1224,0)=" .;  THHMMSS or THH:MM:SS"
^XMB(3.9,145833,2,1225,0)="""RTN"",""SDES2UTDT"",257,0)"
^XMB(3.9,145833,2,1226,0)=" .S SDTIME=$P(SDTIME,""-"")"
^XMB(3.9,145833,2,1227,0)="""RTN"",""SDES2UTDT"",258,0)"
^XMB(3.9,145833,2,1228,0)=" .S SDTIME=$P(SDTIME,""+"")"
^XMB(3.9,145833,2,1229,0)="""RTN"",""SDES2UTDT"",259,0)"
^XMB(3.9,145833,2,1230,0)=" .S SDTIME=$P(SDTIME,""Z"")"
^XMB(3.9,145833,2,1231,0)="""RTN"",""SDES2UTDT"",260,0)"
^XMB(3.9,145833,2,1232,0)=" .S SDTIME=$P(SDTIME,""."")  ;Ignore seconds"
^XMB(3.9,145833,2,1233,0)="""RTN"",""SDES2UTDT"",261,0)"
^XMB(3.9,145833,2,1234,0)=" .S SDTIME=$TR(SDTIME,"":"")"
^XMB(3.9,145833,2,1235,0)="""RTN"",""SDES2UTDT"",262,0)"
^XMB(3.9,145833,2,1236,0)=" .I SDTIME'?6N,SDTIME'?4N,SDTIME'?2N S VALID=0 Q"
^XMB(3.9,145833,2,1237,0)="""RTN"",""SDES2UTDT"",263,0)"
^XMB(3.9,145833,2,1238,0)=" .;Validate offset"
^XMB(3.9,145833,2,1239,0)="""RTN"",""SDES2UTDT"",264,0)"
^XMB(3.9,145833,2,1240,0)=" .;   Z"
^XMB(3.9,145833,2,1241,0)="""RTN"",""SDES2UTDT"",265,0)"
^XMB(3.9,145833,2,1242,0)=" .;   + or - followed by HH"
^XMB(3.9,145833,2,1243,0)="""RTN"",""SDES2UTDT"",266,0)"
^XMB(3.9,145833,2,1244,0)=" .;   + or - followed by HHMM or HH:MM"
^XMB(3.9,145833,2,1245,0)="""RTN"",""SDES2UTDT"",267,0)"
^XMB(3.9,145833,2,1246,0)=" .I $E(DATE,$L(DATE))=""Z"" S VALID=1 Q"
^XMB(3.9,145833,2,1247,0)="""RTN"",""SDES2UTDT"",268,0)"
^XMB(3.9,145833,2,1248,0)=" .S SDTIME=$TR(KEEPSDTIME,"":"")"
^XMB(3.9,145833,2,1249,0)="""RTN"",""SDES2UTDT"",269,0)"
^XMB(3.9,145833,2,1250,0)=" .S SDOFFSET=$P(SDTIME,""+"",2)"
^XMB(3.9,145833,2,1251,0)="""RTN"",""SDES2UTDT"",270,0)"
^XMB(3.9,145833,2,1252,0)=" .I SDOFFSET'="""" D  Q"
^XMB(3.9,145833,2,1253,0)="""RTN"",""SDES2UTDT"",271,0)"
^XMB(3.9,145833,2,1254,0)=" ..I SDOFFSET'?2N,SDOFFSET'?4N S VALID=0"
^XMB(3.9,145833,2,1255,0)="""RTN"",""SDES2UTDT"",272,0)"
^XMB(3.9,145833,2,1256,0)=" .S SDOFFSET=$P(SDTIME,""-"",2)"
^XMB(3.9,145833,2,1257,0)="""RTN"",""SDES2UTDT"",273,0)"
^XMB(3.9,145833,2,1258,0)=" .I SDOFFSET'="""" D  Q"
^XMB(3.9,145833,2,1259,0)="""RTN"",""SDES2UTDT"",274,0)"
^XMB(3.9,145833,2,1260,0)=" ..I SDOFFSET'?2N,SDOFFSET'?4N S VALID=0"
^XMB(3.9,145833,2,1261,0)="""RTN"",""SDES2UTDT"",275,0)"
^XMB(3.9,145833,2,1262,0)=" Q"
^XMB(3.9,145833,2,1263,0)="""RTN"",""SDES2UTIL"")"
^XMB(3.9,145833,2,1264,0)="0^5^B166385697"
^XMB(3.9,145833,2,1265,0)="""RTN"",""SDES2UTIL"",1,0)"
^XMB(3.9,145833,2,1266,0)="SDES2UTIL ;ALB/MGD,ANU,TJB,BWF,MGD,MCB,JHV,MCB,LAB,TAW - SDES2 UTILITIES ;OCT 14, 2025"
^XMB(3.9,145833,2,1267,0)="""RTN"",""SDES2UTIL"",2,0)"
^XMB(3.9,145833,2,1268,0)=" ;;5.3;Scheduling;**853,857,864,877,887,897,910,907,922**;Aug 13, 1993;Build 0"
^XMB(3.9,145833,2,1269,0)="""RTN"",""SDES2UTIL"",3,0)"
^XMB(3.9,145833,2,1270,0)=" ;;Per VHA Directive 6402, this routine should not be modified"
^XMB(3.9,145833,2,1271,0)="""RTN"",""SDES2UTIL"",4,0)"
^XMB(3.9,145833,2,1272,0)=" ;"
^XMB(3.9,145833,2,1273,0)="""RTN"",""SDES2UTIL"",5,0)"
^XMB(3.9,145833,2,1274,0)=" ; Reference to INSTITUTION in #2251"
^XMB(3.9,145833,2,1275,0)="""RTN"",""SDES2UTIL"",6,0)"
^XMB(3.9,145833,2,1276,0)=" ; Reference to KERNEL SYSTEM PARAMETERS in #1518"
^XMB(3.9,145833,2,1277,0)="""RTN"",""SDES2UTIL"",7,0)"
^XMB(3.9,145833,2,1278,0)=" ; Reference to ^ECX(728.44 in #7340"
^XMB(3.9,145833,2,1279,0)="""RTN"",""SDES2UTIL"",8,0)"
^XMB(3.9,145833,2,1280,0)=" ; Reference to OWNREC^DGSEC4 in ICR #7036"
^XMB(3.9,145833,2,1281,0)="""RTN"",""SDES2UTIL"",9,0)"
^XMB(3.9,145833,2,1282,0)=" ; Reference to SENS^DGSEC4 in ICR #7036"
^XMB(3.9,145833,2,1283,0)="""RTN"",""SDES2UTIL"",10,0)"
^XMB(3.9,145833,2,1284,0)=" Q"
^XMB(3.9,145833,2,1285,0)="""RTN"",""SDES2UTIL"",11,0)"
^XMB(3.9,145833,2,1286,0)=" ;"
^XMB(3.9,145833,2,1287,0)="""RTN"",""SDES2UTIL"",12,0)"
^XMB(3.9,145833,2,1288,0)="PADCLTIME(TIME) ;"
^XMB(3.9,145833,2,1289,0)="""RTN"",""SDES2UTIL"",13,0)"
^XMB(3.9,145833,2,1290,0)=" ; TIME - Time to Pad"
^XMB(3.9,145833,2,1291,0)="""RTN"",""SDES2UTIL"",14,0)"
^XMB(3.9,145833,2,1292,0)=" S TIME=$S($G(TIME)'="""":TIME,1:8)"
^XMB(3.9,145833,2,1293,0)="""RTN"",""SDES2UTIL"",15,0)"
^XMB(3.9,145833,2,1294,0)=" I TIME'?1.2N Q -1"
^XMB(3.9,145833,2,1295,0)="""RTN"",""SDES2UTIL"",16,0)"
^XMB(3.9,145833,2,1296,0)=" S TIME=TIME_""00"""
^XMB(3.9,145833,2,1297,0)="""RTN"",""SDES2UTIL"",17,0)"
^XMB(3.9,145833,2,1298,0)=" Q TIME"
^XMB(3.9,145833,2,1299,0)="""RTN"",""SDES2UTIL"",18,0)"
^XMB(3.9,145833,2,1300,0)=" ;"
^XMB(3.9,145833,2,1301,0)="""RTN"",""SDES2UTIL"",19,0)"
^XMB(3.9,145833,2,1302,0)="PADFMTIME(TIME) ;"
^XMB(3.9,145833,2,1303,0)="""RTN"",""SDES2UTIL"",20,0)"
^XMB(3.9,145833,2,1304,0)=" ; TIME - Time to Pad"
^XMB(3.9,145833,2,1305,0)="""RTN"",""SDES2UTIL"",21,0)"
^XMB(3.9,145833,2,1306,0)=" I TIME'?1.4N Q -1"
^XMB(3.9,145833,2,1307,0)="""RTN"",""SDES2UTIL"",22,0)"
^XMB(3.9,145833,2,1308,0)=" S TIME=$E(TIME_""0000"",1,4)"
^XMB(3.9,145833,2,1309,0)="""RTN"",""SDES2UTIL"",23,0)"
^XMB(3.9,145833,2,1310,0)=" Q TIME"
^XMB(3.9,145833,2,1311,0)="""RTN"",""SDES2UTIL"",24,0)"
^XMB(3.9,145833,2,1312,0)=" ;"
^XMB(3.9,145833,2,1313,0)="""RTN"",""SDES2UTIL"",25,0)"
^XMB(3.9,145833,2,1314,0)="PADLENGTH(STRING,CHAR,LENGTH,WHERE) ;"
^XMB(3.9,145833,2,1315,0)="""RTN"",""SDES2UTIL"",26,0)"
^XMB(3.9,145833,2,1316,0)=" N PAD,PADST"
^XMB(3.9,145833,2,1317,0)="""RTN"",""SDES2UTIL"",27,0)"
^XMB(3.9,145833,2,1318,0)=" I $L(STRING)'<LENGTH Q STRING"
^XMB(3.9,145833,2,1319,0)="""RTN"",""SDES2UTIL"",28,0)"
^XMB(3.9,145833,2,1320,0)=" S PADST=LENGTH-$L(STRING)"
^XMB(3.9,145833,2,1321,0)="""RTN"",""SDES2UTIL"",29,0)"
^XMB(3.9,145833,2,1322,0)=" S $P(PAD,CHAR,PADST)=CHAR"
^XMB(3.9,145833,2,1323,0)="""RTN"",""SDES2UTIL"",30,0)"
^XMB(3.9,145833,2,1324,0)=" I WHERE=""F"" S STRING=PAD_STRING"
^XMB(3.9,145833,2,1325,0)="""RTN"",""SDES2UTIL"",31,0)"
^XMB(3.9,145833,2,1326,0)=" I WHERE=""E"" S STRING=STRING_PAD"
^XMB(3.9,145833,2,1327,0)="""RTN"",""SDES2UTIL"",32,0)"
^XMB(3.9,145833,2,1328,0)=" Q STRING"
^XMB(3.9,145833,2,1329,0)="""RTN"",""SDES2UTIL"",33,0)"
^XMB(3.9,145833,2,1330,0)=" ;"
^XMB(3.9,145833,2,1331,0)="""RTN"",""SDES2UTIL"",34,0)"
^XMB(3.9,145833,2,1332,0)="VALACHERONID(SDACHERONID) ;"
^XMB(3.9,145833,2,1333,0)="""RTN"",""SDES2UTIL"",35,0)"
^XMB(3.9,145833,2,1334,0)=" I SDACHERONID="""" S SDACHERONID=-1 Q SDACHERONID"
^XMB(3.9,145833,2,1335,0)="""RTN"",""SDES2UTIL"",36,0)"
^XMB(3.9,145833,2,1336,0)=" S SDACHERONID=$$STRIP(SDACHERONID)"
^XMB(3.9,145833,2,1337,0)="""RTN"",""SDES2UTIL"",37,0)"
^XMB(3.9,145833,2,1338,0)=" I $L(SDACHERONID)>40 S SDACHERONID=-1"
^XMB(3.9,145833,2,1339,0)="""RTN"",""SDES2UTIL"",38,0)"
^XMB(3.9,145833,2,1340,0)=" Q SDACHERONID"
^XMB(3.9,145833,2,1341,0)="""RTN"",""SDES2UTIL"",39,0)"
^XMB(3.9,145833,2,1342,0)=" ;"
^XMB(3.9,145833,2,1343,0)="""RTN"",""SDES2UTIL"",40,0)"
^XMB(3.9,145833,2,1344,0)="STRIP(SDECZ) ;Replace control characters with spaces"
^XMB(3.9,145833,2,1345,0)="""RTN"",""SDES2UTIL"",41,0)"
^XMB(3.9,145833,2,1346,0)=" N SDECI"
^XMB(3.9,145833,2,1347,0)="""RTN"",""SDES2UTIL"",42,0)"
^XMB(3.9,145833,2,1348,0)=" F SDECI=1:1:$L(SDECZ) I (32>$A($E(SDECZ,SDECI))) S SDECZ=$E(SDECZ,1,SDECI-1)_"" ""_$E(SDECZ,SDECI+1,999)"
^XMB(3.9,145833,2,1349,0)="""RTN"",""SDES2UTIL"",43,0)"
^XMB(3.9,145833,2,1350,0)=" Q SDECZ"
^XMB(3.9,145833,2,1351,0)="""RTN"",""SDES2UTIL"",44,0)"
^XMB(3.9,145833,2,1352,0)=" ;"
^XMB(3.9,145833,2,1353,0)="""RTN"",""SDES2UTIL"",45,0)"
^XMB(3.9,145833,2,1354,0)="ISDATEDST(DATE,DSTSUM,VALIDATE) ;Does this date use Daylight Savings"
^XMB(3.9,145833,2,1355,0)="""RTN"",""SDES2UTIL"",46,0)"
^XMB(3.9,145833,2,1356,0)=" ; DATE -    FM format"
^XMB(3.9,145833,2,1357,0)="""RTN"",""SDES2UTIL"",47,0)"
^XMB(3.9,145833,2,1358,0)=" ; DSTSUM - ""DST"" or ""SUM"""
^XMB(3.9,145833,2,1359,0)="""RTN"",""SDES2UTIL"",48,0)"
^XMB(3.9,145833,2,1360,0)=" ; Return 1 = DATE is considered DST or SUM"
^XMB(3.9,145833,2,1361,0)="""RTN"",""SDES2UTIL"",49,0)"
^XMB(3.9,145833,2,1362,0)=" ;        0 = DATE is not DST and not SUM"
^XMB(3.9,145833,2,1363,0)="""RTN"",""SDES2UTIL"",50,0)"
^XMB(3.9,145833,2,1364,0)=" ;       -1 = DATE is not FM format"
^XMB(3.9,145833,2,1365,0)="""RTN"",""SDES2UTIL"",51,0)"
^XMB(3.9,145833,2,1366,0)=" N YR"
^XMB(3.9,145833,2,1367,0)="""RTN"",""SDES2UTIL"",52,0)"
^XMB(3.9,145833,2,1368,0)=" S DATE=$G(DATE),DSTSUM=$G(DSTSUM)"
^XMB(3.9,145833,2,1369,0)="""RTN"",""SDES2UTIL"",53,0)"
^XMB(3.9,145833,2,1370,0)=" I '$G(VALIDATE) Q:'$$VALIDFMFORMAT^SDECDATE(DATE) -1"
^XMB(3.9,145833,2,1371,0)="""RTN"",""SDES2UTIL"",54,0)"
^XMB(3.9,145833,2,1372,0)=" S YR=$E(DATE,2,3)"
^XMB(3.9,145833,2,1373,0)="""RTN"",""SDES2UTIL"",55,0)"
^XMB(3.9,145833,2,1374,0)=" I DATE<$$DSTSTART(YR,DSTSUM) Q 0"
^XMB(3.9,145833,2,1375,0)="""RTN"",""SDES2UTIL"",56,0)"
^XMB(3.9,145833,2,1376,0)=" I DATE>$$DSTEND(YR,DSTSUM) Q 0"
^XMB(3.9,145833,2,1377,0)="""RTN"",""SDES2UTIL"",57,0)"
^XMB(3.9,145833,2,1378,0)=" Q 1"
^XMB(3.9,145833,2,1379,0)="""RTN"",""SDES2UTIL"",58,0)"
^XMB(3.9,145833,2,1380,0)="DSTSTART(YR,DSTSUM) ;Daylight Savings or Summer start date"
^XMB(3.9,145833,2,1381,0)="""RTN"",""SDES2UTIL"",59,0)"
^XMB(3.9,145833,2,1382,0)=" ; countries that observe DST or Summer ST (e.g., USA observes DST and Europe observes SUM ST)"
^XMB(3.9,145833,2,1383,0)="""RTN"",""SDES2UTIL"",60,0)"
^XMB(3.9,145833,2,1384,0)=" ; YR - 2 digit year"
^XMB(3.9,145833,2,1385,0)="""RTN"",""SDES2UTIL"",61,0)"
^XMB(3.9,145833,2,1386,0)=" ; DSTSUM - ""DST"" or ""SUM"""
^XMB(3.9,145833,2,1387,0)="""RTN"",""SDES2UTIL"",62,0)"
^XMB(3.9,145833,2,1388,0)=" ; Return is the FM date for the FIRST day of DST or SUM"
^XMB(3.9,145833,2,1389,0)="""RTN"",""SDES2UTIL"",63,0)"
^XMB(3.9,145833,2,1390,0)=" N DSTMONTH,DOW,DSTDT,SUNDAY"
^XMB(3.9,145833,2,1391,0)="""RTN"",""SDES2UTIL"",64,0)"
^XMB(3.9,145833,2,1392,0)=" S DSTMONTH=""0301"",DSTSUM=$G(DSTSUM)"
^XMB(3.9,145833,2,1393,0)="""RTN"",""SDES2UTIL"",65,0)"
^XMB(3.9,145833,2,1394,0)=" ; SUNDAY will be 2nd Sunday in March OR Last Sunday in March"
^XMB(3.9,145833,2,1395,0)="""RTN"",""SDES2UTIL"",66,0)"
^XMB(3.9,145833,2,1396,0)=" S SUNDAY=$S(DSTSUM=""DST"":2,DSTSUM=""SUM"":""4,5"",1:2) ;if not DST or SUM, treat as DST"
^XMB(3.9,145833,2,1397,0)="""RTN"",""SDES2UTIL"",67,0)"
^XMB(3.9,145833,2,1398,0)=" S YR=$G(YR)"
^XMB(3.9,145833,2,1399,0)="""RTN"",""SDES2UTIL"",68,0)"
^XMB(3.9,145833,2,1400,0)=" I YR="""" S DSTDT=$E(DT,1,3)_DSTMONTH"
^XMB(3.9,145833,2,1401,0)="""RTN"",""SDES2UTIL"",69,0)"
^XMB(3.9,145833,2,1402,0)=" E  S DSTDT=$E(DT)_YR_DSTMONTH"
^XMB(3.9,145833,2,1403,0)="""RTN"",""SDES2UTIL"",70,0)"
^XMB(3.9,145833,2,1404,0)=" S DOW=$$DOW^XLFDT(DSTDT,1)"
^XMB(3.9,145833,2,1405,0)="""RTN"",""SDES2UTIL"",71,0)"
^XMB(3.9,145833,2,1406,0)=" I DOW D"
^XMB(3.9,145833,2,1407,0)="""RTN"",""SDES2UTIL"",72,0)"
^XMB(3.9,145833,2,1408,0)=" .I DSTSUM=""DST"" S DSTDT=DSTDT+(SUNDAY*7)-DOW"
^XMB(3.9,145833,2,1409,0)="""RTN"",""SDES2UTIL"",73,0)"
^XMB(3.9,145833,2,1410,0)=" .E  S DSTDT=$$SUMMER(DSTDT,DOW,SUNDAY)"
^XMB(3.9,145833,2,1411,0)="""RTN"",""SDES2UTIL"",74,0)"
^XMB(3.9,145833,2,1412,0)=" I (DSTSUM=""DST"")&(DOW=0) S DSTDT=DSTDT+(7)-DOW"
^XMB(3.9,145833,2,1413,0)="""RTN"",""SDES2UTIL"",75,0)"
^XMB(3.9,145833,2,1414,0)=" Q DSTDT"
^XMB(3.9,145833,2,1415,0)="""RTN"",""SDES2UTIL"",76,0)"
^XMB(3.9,145833,2,1416,0)="DSTEND(YR,DSTSUM) ;Daylight Savings END date"
^XMB(3.9,145833,2,1417,0)="""RTN"",""SDES2UTIL"",77,0)"
^XMB(3.9,145833,2,1418,0)=" ; YR - 2 digit year"
^XMB(3.9,145833,2,1419,0)="""RTN"",""SDES2UTIL"",78,0)"
^XMB(3.9,145833,2,1420,0)=" ; DSTSUM - ""DST"" or ""SUM"""
^XMB(3.9,145833,2,1421,0)="""RTN"",""SDES2UTIL"",79,0)"
^XMB(3.9,145833,2,1422,0)=" ; Return is the FM date for the LAST day of DST or SUM"
^XMB(3.9,145833,2,1423,0)="""RTN"",""SDES2UTIL"",80,0)"
^XMB(3.9,145833,2,1424,0)=" N DSTMONTH,DOW,DSTDT,SUNDAY"
^XMB(3.9,145833,2,1425,0)="""RTN"",""SDES2UTIL"",81,0)"
^XMB(3.9,145833,2,1426,0)=" S DSTSUM=$G(DSTSUM)"
^XMB(3.9,145833,2,1427,0)="""RTN"",""SDES2UTIL"",82,0)"
^XMB(3.9,145833,2,1428,0)=" S DSTMONTH=$S(DSTSUM=""DST"":""1101"",DSTSUM=""SUM"":""1001"",1:""1101"")"
^XMB(3.9,145833,2,1429,0)="""RTN"",""SDES2UTIL"",83,0)"
^XMB(3.9,145833,2,1430,0)=" ; SUNDAY will be first Sunday in November or last Sunday in October"
^XMB(3.9,145833,2,1431,0)="""RTN"",""SDES2UTIL"",84,0)"
^XMB(3.9,145833,2,1432,0)=" S SUNDAY=$S(DSTSUM=""DST"":1,DSTSUM=""SUM"":""4,5"",1:1)  ; if not DST or SUM treat as DST"
^XMB(3.9,145833,2,1433,0)="""RTN"",""SDES2UTIL"",85,0)"
^XMB(3.9,145833,2,1434,0)=" S YR=$G(YR)"
^XMB(3.9,145833,2,1435,0)="""RTN"",""SDES2UTIL"",86,0)"
^XMB(3.9,145833,2,1436,0)=" I YR="""" S DSTDT=$E(DT,1,3)_DSTMONTH"
^XMB(3.9,145833,2,1437,0)="""RTN"",""SDES2UTIL"",87,0)"
^XMB(3.9,145833,2,1438,0)=" E  S DSTDT=$E(DT)_YR_DSTMONTH"
^XMB(3.9,145833,2,1439,0)="""RTN"",""SDES2UTIL"",88,0)"
^XMB(3.9,145833,2,1440,0)=" S DOW=$$DOW^XLFDT(DSTDT,1)"
^XMB(3.9,145833,2,1441,0)="""RTN"",""SDES2UTIL"",89,0)"
^XMB(3.9,145833,2,1442,0)=" I DOW D"
^XMB(3.9,145833,2,1443,0)="""RTN"",""SDES2UTIL"",90,0)"
^XMB(3.9,145833,2,1444,0)=" .I DSTSUM=""DST"" S DSTDT=DSTDT+(SUNDAY*7)-DOW"
^XMB(3.9,145833,2,1445,0)="""RTN"",""SDES2UTIL"",91,0)"
^XMB(3.9,145833,2,1446,0)=" .E  S DSTDT=$$SUMMER(DSTDT,DOW,SUNDAY)"
^XMB(3.9,145833,2,1447,0)="""RTN"",""SDES2UTIL"",92,0)"
^XMB(3.9,145833,2,1448,0)=" Q DSTDT"
^XMB(3.9,145833,2,1449,0)="""RTN"",""SDES2UTIL"",93,0)"
^XMB(3.9,145833,2,1450,0)=" ;"
^XMB(3.9,145833,2,1451,0)="""RTN"",""SDES2UTIL"",94,0)"
^XMB(3.9,145833,2,1452,0)="SUMMER(DSTDT,DOW,SUNDAY) ; determine last Sunday of MARCH or OCTOBER"
^XMB(3.9,145833,2,1453,0)="""RTN"",""SDES2UTIL"",95,0)"
^XMB(3.9,145833,2,1454,0)=" ; DSTDT - March or October (e.g, CYY0301 or CYY1001)"
^XMB(3.9,145833,2,1455,0)="""RTN"",""SDES2UTIL"",96,0)"
^XMB(3.9,145833,2,1456,0)=" ; DOW - 1, 2, 3, 4, 5, or 6"
^XMB(3.9,145833,2,1457,0)="""RTN"",""SDES2UTIL"",97,0)"
^XMB(3.9,145833,2,1458,0)=" ; SUNDAY - ""4,5"" representing 4th or 5th Sunday of March or October"
^XMB(3.9,145833,2,1459,0)="""RTN"",""SDES2UTIL"",98,0)"
^XMB(3.9,145833,2,1460,0)=" ; Returns the date when SUMMER offset begins or ends (e.g., eastern Europe uses Summer offset)"
^XMB(3.9,145833,2,1461,0)="""RTN"",""SDES2UTIL"",99,0)"
^XMB(3.9,145833,2,1462,0)=" N X,VALIDSUNDAY,LASTSUNDAY"
^XMB(3.9,145833,2,1463,0)="""RTN"",""SDES2UTIL"",100,0)"
^XMB(3.9,145833,2,1464,0)=" S DSTDT=$G(DSTDT),DOW=$G(DOW),SUNDAY=$G(SUNDAY)"
^XMB(3.9,145833,2,1465,0)="""RTN"",""SDES2UTIL"",101,0)"
^XMB(3.9,145833,2,1466,0)=" S LASTSUNDAY=0"
^XMB(3.9,145833,2,1467,0)="""RTN"",""SDES2UTIL"",102,0)"
^XMB(3.9,145833,2,1468,0)=" F X=1,2 S VALIDSUNDAY=DSTDT+($P(SUNDAY,"","",X)*7)-DOW I $$VALIDFMFORMAT^SDECDATE(VALIDSUNDAY) S LASTSUNDAY=VALIDSUNDAY"
^XMB(3.9,145833,2,1469,0)="""RTN"",""SDES2UTIL"",103,0)"
^XMB(3.9,145833,2,1470,0)=" Q LASTSUNDAY"
^XMB(3.9,145833,2,1471,0)="""RTN"",""SDES2UTIL"",104,0)"
^XMB(3.9,145833,2,1472,0)=" ;"
^XMB(3.9,145833,2,1473,0)="""RTN"",""SDES2UTIL"",105,0)"
^XMB(3.9,145833,2,1474,0)="TIMEZONEDATA(CLINICIEN) ;Get timezone and offsets"
^XMB(3.9,145833,2,1475,0)="""RTN"",""SDES2UTIL"",106,0)"
^XMB(3.9,145833,2,1476,0)=" ; CLINIC - IEN from Hospital Location #44"
^XMB(3.9,145833,2,1477,0)="""RTN"",""SDES2UTIL"",107,0)"
^XMB(3.9,145833,2,1478,0)=" ;    If clinic is not passed, use default Facility/Institution"
^XMB(3.9,145833,2,1479,0)="""RTN"",""SDES2UTIL"",108,0)"
^XMB(3.9,145833,2,1480,0)=" ; Output:"
^XMB(3.9,145833,2,1481,0)="""RTN"",""SDES2UTIL"",109,0)"
^XMB(3.9,145833,2,1482,0)=" ;   Returns TimeZone Name ^ TimeZone IEN ^ TimeZone Exception ^ Offset for Standard Time ^ Offset for DST or SUMMER ^"
^XMB(3.9,145833,2,1483,0)="""RTN"",""SDES2UTIL"",110,0)"
^XMB(3.9,145833,2,1484,0)=" N SDINST,SDDIV,SDTIMEZONEE,SDTIMEZONEI,TIMEZONEEXECPT,X,POP,TIMEFRAMEARY,OFFSET,OFFSETDSTSUM,DSTSUM,RETURN,TIMEFRAMEIEN,SDMSG"
^XMB(3.9,145833,2,1485,0)="""RTN"",""SDES2UTIL"",111,0)"
^XMB(3.9,145833,2,1486,0)=" N EXECPTFLG"
^XMB(3.9,145833,2,1487,0)="""RTN"",""SDES2UTIL"",112,0)"
^XMB(3.9,145833,2,1488,0)=" S (POP,SDINST,DSTSUM,EXECPTFLG,SDTIMEZONEI)="""",(OFFSET,OFFSETDSTSUM)=-9999"
^XMB(3.9,145833,2,1489,0)="""RTN"",""SDES2UTIL"",113,0)"
^XMB(3.9,145833,2,1490,0)=" I $G(CLINICIEN) D"
^XMB(3.9,145833,2,1491,0)="""RTN"",""SDES2UTIL"",114,0)"
^XMB(3.9,145833,2,1492,0)=" .S SDDIV=$$GET1^DIQ(44,CLINICIEN_"","",3.5,""I"")"
^XMB(3.9,145833,2,1493,0)="""RTN"",""SDES2UTIL"",115,0)"
^XMB(3.9,145833,2,1494,0)=" .S:SDDIV SDINST=$$GET1^DIQ(40.8,SDDIV_"","",.07,""I"")"
^XMB(3.9,145833,2,1495,0)="""RTN"",""SDES2UTIL"",116,0)"
^XMB(3.9,145833,2,1496,0)=" .I SDINST S SDTIMEZONEI=$$GET1^DIQ(4,SDINST,800,""I"") S:SDTIMEZONEI="""" SDINST="""",SDTIMEZONEI=0"
^XMB(3.9,145833,2,1497,0)="""RTN"",""SDES2UTIL"",117,0)"
^XMB(3.9,145833,2,1498,0)=" I SDINST="""" S SDINST=$$GET1^DIQ(8989.3,1,217,""I"")"
^XMB(3.9,145833,2,1499,0)="""RTN"",""SDES2UTIL"",118,0)"
^XMB(3.9,145833,2,1500,0)=" S SDTIMEZONEE=$$GET1^DIQ(4,SDINST,800,""E"")"
^XMB(3.9,145833,2,1501,0)="""RTN"",""SDES2UTIL"",119,0)"
^XMB(3.9,145833,2,1502,0)=" S:'SDTIMEZONEI SDTIMEZONEI=$$GET1^DIQ(4,SDINST,800,""I"")"
^XMB(3.9,145833,2,1503,0)="""RTN"",""SDES2UTIL"",120,0)"
^XMB(3.9,145833,2,1504,0)=" S EXECPTFLG=$$GET1^DIQ(4,SDINST,802,""I"")"
^XMB(3.9,145833,2,1505,0)="""RTN"",""SDES2UTIL"",121,0)"
^XMB(3.9,145833,2,1506,0)=" S TIMEZONEEXECPT=$S(EXECPTFLG=0:1,1:0) ;if except value = 0 then exception is present"
^XMB(3.9,145833,2,1507,0)="""RTN"",""SDES2UTIL"",122,0)"
^XMB(3.9,145833,2,1508,0)=" ;"
^XMB(3.9,145833,2,1509,0)="""RTN"",""SDES2UTIL"",123,0)"
^XMB(3.9,145833,2,1510,0)=" F X=1:1:3 D  Q:POP"
^XMB(3.9,145833,2,1511,0)="""RTN"",""SDES2UTIL"",124,0)"
^XMB(3.9,145833,2,1512,0)=" .S TIMEFRAMEIEN=X_"",""_SDTIMEZONEI_"","""
^XMB(3.9,145833,2,1513,0)="""RTN"",""SDES2UTIL"",125,0)"
^XMB(3.9,145833,2,1514,0)=" .D GETS^DIQ(1.711,TIMEFRAMEIEN,"".01;.02"",""IE"",""TIMEFRAMEARY"",""SDMSG"") ;Data from WORLD TIMEZONE file"
^XMB(3.9,145833,2,1515,0)="""RTN"",""SDES2UTIL"",126,0)"
^XMB(3.9,145833,2,1516,0)=" .I '$D(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01)) S POP=1 Q"
^XMB(3.9,145833,2,1517,0)="""RTN"",""SDES2UTIL"",127,0)"
^XMB(3.9,145833,2,1518,0)=" .I $G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01,""I""))=""SST"" S OFFSET=$G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.02,""E""))"
^XMB(3.9,145833,2,1519,0)="""RTN"",""SDES2UTIL"",128,0)"
^XMB(3.9,145833,2,1520,0)=" .I $G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01,""I""))=""DST"" S DSTSUM=""DST"",OFFSETDSTSUM=$G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.02,""E"")) ;vse-2705"
^XMB(3.9,145833,2,1521,0)="""RTN"",""SDES2UTIL"",129,0)"
^XMB(3.9,145833,2,1522,0)=" .I $G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.01,""I""))=""SUM"" S DSTSUM=""SUM"",OFFSETDSTSUM=$G(TIMEFRAMEARY(1.711,TIMEFRAMEIEN,.02,""E"")) ;vse-2705"
^XMB(3.9,145833,2,1523,0)="""RTN"",""SDES2UTIL"",130,0)"
^XMB(3.9,145833,2,1524,0)=" ;"
^XMB(3.9,145833,2,1525,0)="""RTN"",""SDES2UTIL"",131,0)"
^XMB(3.9,145833,2,1526,0)=" Q SDTIMEZONEE_""^""_SDTIMEZONEI_""^""_TIMEZONEEXECPT_""^""_OFFSET_""^""_OFFSETDSTSUM_""^""_DSTSUM  ;vse-2705"
^XMB(3.9,145833,2,1527,0)="""RTN"",""SDES2UTIL"",132,0)"
^XMB(3.9,145833,2,1528,0)=" ;"
^XMB(3.9,145833,2,1529,0)="""RTN"",""SDES2UTIL"",133,0)"
^XMB(3.9,145833,2,1530,0)="GETTZOFFSET(OFFSET,SDDATE,VALIDATEDT,SDCLINIC) ;Get Time Zone offset based on clinic and daylight savings"
^XMB(3.9,145833,2,1531,0)="""RTN"",""SDES2UTIL"",134,0)"
^XMB(3.9,145833,2,1532,0)=" ; SDCLINIC - OPT - IEN from Hospital Location #44"
^XMB(3.9,145833,2,1533,0)="""RTN"",""SDES2UTIL"",135,0)"
^XMB(3.9,145833,2,1534,0)=" ; SDDATE   - REQ - FM formatted date"
^XMB(3.9,145833,2,1535,0)="""RTN"",""SDES2UTIL"",136,0)"
^XMB(3.9,145833,2,1536,0)=" ; VALIDATEDT - OPT - Should SDDATE be validated (1=Pre-validated)"
^XMB(3.9,145833,2,1537,0)="""RTN"",""SDES2UTIL"",137,0)"
^XMB(3.9,145833,2,1538,0)=" ; Return OFFSET"
^XMB(3.9,145833,2,1539,0)="""RTN"",""SDES2UTIL"",138,0)"
^XMB(3.9,145833,2,1540,0)=" ;   If clinic is passed in get Division then Institution"
^XMB(3.9,145833,2,1541,0)="""RTN"",""SDES2UTIL"",139,0)"
^XMB(3.9,145833,2,1542,0)=" ;   Otherwise get Institution from Kernel System Parameters"
^XMB(3.9,145833,2,1543,0)="""RTN"",""SDES2UTIL"",140,0)"
^XMB(3.9,145833,2,1544,0)=" ;   Get the Time Zone and Time Zone Exception from the Institution"
^XMB(3.9,145833,2,1545,0)="""RTN"",""SDES2UTIL"",141,0)"
^XMB(3.9,145833,2,1546,0)=" N TZINFO"
^XMB(3.9,145833,2,1547,0)="""RTN"",""SDES2UTIL"",142,0)"
^XMB(3.9,145833,2,1548,0)=" S (OFFSET,TZINFO)="""""
^XMB(3.9,145833,2,1549,0)="""RTN"",""SDES2UTIL"",143,0)"
^XMB(3.9,145833,2,1550,0)=" S SDDATE=$G(SDDATE)"
^XMB(3.9,145833,2,1551,0)="""RTN"",""SDES2UTIL"",144,0)"
^XMB(3.9,145833,2,1552,0)=" S VALIDATEDT=$G(VALIDATEDT)"
^XMB(3.9,145833,2,1553,0)="""RTN"",""SDES2UTIL"",145,0)"
^XMB(3.9,145833,2,1554,0)=" I 'VALIDATEDT Q:'$$VALIDFMFORMAT^SDECDATE(SDDATE)"
^XMB(3.9,145833,2,1555,0)="""RTN"",""SDES2UTIL"",146,0)"
^XMB(3.9,145833,2,1556,0)=" S SDCLINIC=$G(SDCLINIC)"
^XMB(3.9,145833,2,1557,0)="""RTN"",""SDES2UTIL"",147,0)"
^XMB(3.9,145833,2,1558,0)=" S TZINFO=$$TIMEZONEDATA(SDCLINIC)"
^XMB(3.9,145833,2,1559,0)="""RTN"",""SDES2UTIL"",148,0)"
^XMB(3.9,145833,2,1560,0)=" S OFFSET=$P(TZINFO,""^"",4)   ;assume non DST"
^XMB(3.9,145833,2,1561,0)="""RTN"",""SDES2UTIL"",149,0)"
^XMB(3.9,145833,2,1562,0)=" ; If the Institution uses DST or SUMMER & SDDATE is in the daylight savings period, then send the DST/SUMMER Offset"
^XMB(3.9,145833,2,1563,0)="""RTN"",""SDES2UTIL"",150,0)"
^XMB(3.9,145833,2,1564,0)=" I $P(TZINFO,""^"",3)=0 S OFFSET=$S($$ISDATEDST(SDDATE,$P(TZINFO,""^"",6),1):$P(TZINFO,""^"",5),1:OFFSET)"
^XMB(3.9,145833,2,1565,0)="""RTN"",""SDES2UTIL"",151,0)"
^XMB(3.9,145833,2,1566,0)=" Q"
^XMB(3.9,145833,2,1567,0)="""RTN"",""SDES2UTIL"",152,0)"
^XMB(3.9,145833,2,1568,0)=" ;"
^XMB(3.9,145833,2,1569,0)="""RTN"",""SDES2UTIL"",153,0)"
^XMB(3.9,145833,2,1570,0)="CHAR4(CLINNAME) ;"
^XMB(3.9,145833,2,1571,0)="""RTN"",""SDES2UTIL"",154,0)"
^XMB(3.9,145833,2,1572,0)=" ; CLINNAME - REQ - Name of clinic from #44"
^XMB(3.9,145833,2,1573,0)="""RTN"",""SDES2UTIL"",155,0)"
^XMB(3.9,145833,2,1574,0)=" ; Return"
^XMB(3.9,145833,2,1575,0)="""RTN"",""SDES2UTIL"",156,0)"
^XMB(3.9,145833,2,1576,0)=" ;  The CODE (#.01) field from NATIONAL CLINIC (#728.411) file or null"
^XMB(3.9,145833,2,1577,0)="""RTN"",""SDES2UTIL"",157,0)"
^XMB(3.9,145833,2,1578,0)=" N IEN,NATLCODE"
^XMB(3.9,145833,2,1579,0)="""RTN"",""SDES2UTIL"",158,0)"
^XMB(3.9,145833,2,1580,0)=" I CLINNAME="""" Q """""
^XMB(3.9,145833,2,1581,0)="""RTN"",""SDES2UTIL"",159,0)"
^XMB(3.9,145833,2,1582,0)=" I '$D(^SC(""B"",CLINNAME)) Q """""
^XMB(3.9,145833,2,1583,0)="""RTN"",""SDES2UTIL"",160,0)"
^XMB(3.9,145833,2,1584,0)=" S IEN=$$FIND1^DIC(728.44,"""",""X"",CLINNAME)"
^XMB(3.9,145833,2,1585,0)="""RTN"",""SDES2UTIL"",161,0)"
^XMB(3.9,145833,2,1586,0)=" I 'IEN Q """""
^XMB(3.9,145833,2,1587,0)="""RTN"",""SDES2UTIL"",162,0)"
^XMB(3.9,145833,2,1588,0)=" S NATLCODE=$$GET1^DIQ(728.44,IEN_"","",7,""E"")"
^XMB(3.9,145833,2,1589,0)="""RTN"",""SDES2UTIL"",163,0)"
^XMB(3.9,145833,2,1590,0)=" Q NATLCODE"
^XMB(3.9,145833,2,1591,0)="""RTN"",""SDES2UTIL"",164,0)"
^XMB(3.9,145833,2,1592,0)=" ;"
^XMB(3.9,145833,2,1593,0)="""RTN"",""SDES2UTIL"",165,0)"
^XMB(3.9,145833,2,1594,0)="TELEPHONE(PHONE) ; Format all numeric Telephone Number"
^XMB(3.9,145833,2,1595,0)="""RTN"",""SDES2UTIL"",166,0)"
^XMB(3.9,145833,2,1596,0)=" ; PHONE - The Telephone Number"
^XMB(3.9,145833,2,1597,0)="""RTN"",""SDES2UTIL"",167,0)"
^XMB(3.9,145833,2,1598,0)=" ; Return"
^XMB(3.9,145833,2,1599,0)="""RTN"",""SDES2UTIL"",168,0)"
^XMB(3.9,145833,2,1600,0)=" ; If PHONE is all numeric it will be formatted as follows"
^XMB(3.9,145833,2,1601,0)="""RTN"",""SDES2UTIL"",169,0)"
^XMB(3.9,145833,2,1602,0)=" ; 1234567890 will be formatted as (123)456-7890"
^XMB(3.9,145833,2,1603,0)="""RTN"",""SDES2UTIL"",170,0)"
^XMB(3.9,145833,2,1604,0)=" ; otherwise the passed in PHONE is returned."
^XMB(3.9,145833,2,1605,0)="""RTN"",""SDES2UTIL"",171,0)"
^XMB(3.9,145833,2,1606,0)=" S PHONE=$G(PHONE,"""")"
^XMB(3.9,145833,2,1607,0)="""RTN"",""SDES2UTIL"",172,0)"
^XMB(3.9,145833,2,1608,0)=" I PHONE?10N S PHONE=""(""_$E(PHONE,1,3)_"")""_$E(PHONE,4,6)_""-""_$E(PHONE,7,10)"
^XMB(3.9,145833,2,1609,0)="""RTN"",""SDES2UTIL"",173,0)"
^XMB(3.9,145833,2,1610,0)=" Q PHONE"
^XMB(3.9,145833,2,1611,0)="""RTN"",""SDES2UTIL"",174,0)"
^XMB(3.9,145833,2,1612,0)=" ;"
^XMB(3.9,145833,2,1613,0)="""RTN"",""SDES2UTIL"",175,0)"
^XMB(3.9,145833,2,1614,0)="EXT(EXT) ; Add an x to the beginning of an all numeric Telephone Extension field."
^XMB(3.9,145833,2,1615,0)="""RTN"",""SDES2UTIL"",176,0)"
^XMB(3.9,145833,2,1616,0)=" ; EXT - The Telephone Extension."
^XMB(3.9,145833,2,1617,0)="""RTN"",""SDES2UTIL"",177,0)"
^XMB(3.9,145833,2,1618,0)=" ; Return"
^XMB(3.9,145833,2,1619,0)="""RTN"",""SDES2UTIL"",178,0)"
^XMB(3.9,145833,2,1620,0)=" ; If EXT is all numeric, a lowercase x concantenated to the passed in EXT."
^XMB(3.9,145833,2,1621,0)="""RTN"",""SDES2UTIL"",179,0)"
^XMB(3.9,145833,2,1622,0)=" ; otherwise the passed in EXT is returned."
^XMB(3.9,145833,2,1623,0)="""RTN"",""SDES2UTIL"",180,0)"
^XMB(3.9,145833,2,1624,0)=" S EXT=$G(EXT,"""")"
^XMB(3.9,145833,2,1625,0)="""RTN"",""SDES2UTIL"",181,0)"
^XMB(3.9,145833,2,1626,0)=" I EXT?1.N S EXT=""x""_EXT"
^XMB(3.9,145833,2,1627,0)="""RTN"",""SDES2UTIL"",182,0)"
^XMB(3.9,145833,2,1628,0)=" Q EXT"
^XMB(3.9,145833,2,1629,0)="""RTN"",""SDES2UTIL"",183,0)"
^XMB(3.9,145833,2,1630,0)=" ;"
^XMB(3.9,145833,2,1631,0)="""RTN"",""SDES2UTIL"",184,0)"
^XMB(3.9,145833,2,1632,0)="INACTIVE(SDCL,SDDT) ; determine if clinic is active"
^XMB(3.9,145833,2,1633,0)="""RTN"",""SDES2UTIL"",185,0)"
^XMB(3.9,145833,2,1634,0)=" ; Input:"
^XMB(3.9,145833,2,1635,0)="""RTN"",""SDES2UTIL"",186,0)"
^XMB(3.9,145833,2,1636,0)=" ;  SDCL = (Req) IEN of Clinic from file #44."
^XMB(3.9,145833,2,1637,0)="""RTN"",""SDES2UTIL"",187,0)"
^XMB(3.9,145833,2,1638,0)=" ;  SDDT = (Opt) Date to use for determining Status. If not passed in, defaults to DT."
^XMB(3.9,145833,2,1639,0)="""RTN"",""SDES2UTIL"",188,0)"
^XMB(3.9,145833,2,1640,0)=" ; Return:"
^XMB(3.9,145833,2,1641,0)="""RTN"",""SDES2UTIL"",189,0)"
^XMB(3.9,145833,2,1642,0)=" ;  0=ACTIVE"
^XMB(3.9,145833,2,1643,0)="""RTN"",""SDES2UTIL"",190,0)"
^XMB(3.9,145833,2,1644,0)=" ;  1=INACTIVE"
^XMB(3.9,145833,2,1645,0)="""RTN"",""SDES2UTIL"",191,0)"
^XMB(3.9,145833,2,1646,0)=" N SDNODEI,INACTIVEDATE,REACTIVEDATE,STATUS"
^XMB(3.9,145833,2,1647,0)="""RTN"",""SDES2UTIL"",192,0)"
^XMB(3.9,145833,2,1648,0)=" S SDDT=$G(SDDT) I SDDT="""" S SDDT=DT"
^XMB(3.9,145833,2,1649,0)="""RTN"",""SDES2UTIL"",193,0)"
^XMB(3.9,145833,2,1650,0)=" S SDDT=$P(SDDT,""."",1)"
^XMB(3.9,145833,2,1651,0)="""RTN"",""SDES2UTIL"",194,0)"
^XMB(3.9,145833,2,1652,0)=" S STATUS=1"
^XMB(3.9,145833,2,1653,0)="""RTN"",""SDES2UTIL"",195,0)"
^XMB(3.9,145833,2,1654,0)=" S SDNODEI=$G(^SC(SDCL,""I""))"
^XMB(3.9,145833,2,1655,0)="""RTN"",""SDES2UTIL"",196,0)"
^XMB(3.9,145833,2,1656,0)=" I SDNODEI="""" S STATUS=0 Q STATUS"
^XMB(3.9,145833,2,1657,0)="""RTN"",""SDES2UTIL"",197,0)"
^XMB(3.9,145833,2,1658,0)=" S INACTIVEDATE=$P(SDNODEI,U,1)   ;inactive date/time"
^XMB(3.9,145833,2,1659,0)="""RTN"",""SDES2UTIL"",198,0)"
^XMB(3.9,145833,2,1660,0)=" S REACTIVEDATE=$P(SDNODEI,U,2)   ;reactive date/time"
^XMB(3.9,145833,2,1661,0)="""RTN"",""SDES2UTIL"",199,0)"
^XMB(3.9,145833,2,1662,0)=" I (INACTIVEDATE="""") S STATUS=0 Q STATUS"
^XMB(3.9,145833,2,1663,0)="""RTN"",""SDES2UTIL"",200,0)"
^XMB(3.9,145833,2,1664,0)=" I (REACTIVEDATE>=INACTIVEDATE)&(REACTIVEDATE<=SDDT) S STATUS=0 Q STATUS"
^XMB(3.9,145833,2,1665,0)="""RTN"",""SDES2UTIL"",201,0)"
^XMB(3.9,145833,2,1666,0)=" I INACTIVEDATE>SDDT S STATUS=0 Q STATUS"
^XMB(3.9,145833,2,1667,0)="""RTN"",""SDES2UTIL"",202,0)"
^XMB(3.9,145833,2,1668,0)=" Q STATUS"
^XMB(3.9,145833,2,1669,0)="""RTN"",""SDES2UTIL"",203,0)"
^XMB(3.9,145833,2,1670,0)=" ;"
^XMB(3.9,145833,2,1671,0)="""RTN"",""SDES2UTIL"",204,0)"
^XMB(3.9,145833,2,1672,0)="STATIONNUMBER(CLINICIEN) ;"
^XMB(3.9,145833,2,1673,0)="""RTN"",""SDES2UTIL"",205,0)"
^XMB(3.9,145833,2,1674,0)=" ; Input:"
^XMB(3.9,145833,2,1675,0)="""RTN"",""SDES2UTIL"",206,0)"
^XMB(3.9,145833,2,1676,0)=" ; CLINICIEN (Opt) = IEN of the Clinic from File #44. If not passed in, the default"
^XMB(3.9,145833,2,1677,0)="""RTN"",""SDES2UTIL"",207,0)"
^XMB(3.9,145833,2,1678,0)=" ;   Institution for the VistA Instance it used."
^XMB(3.9,145833,2,1679,0)="""RTN"",""SDES2UTIL"",208,0)"
^XMB(3.9,145833,2,1680,0)=" ; Output: The STATION NUMBER (#99) field from the INSTITUTION (#4) file."
^XMB(3.9,145833,2,1681,0)="""RTN"",""SDES2UTIL"",209,0)"
^XMB(3.9,145833,2,1682,0)=" N DIVISION,INSTIEN,STATIONNUMBER"
^XMB(3.9,145833,2,1683,0)="""RTN"",""SDES2UTIL"",210,0)"
^XMB(3.9,145833,2,1684,0)=" I $G(CLINICIEN)="""" D  Q STATIONNUMBER"
^XMB(3.9,145833,2,1685,0)="""RTN"",""SDES2UTIL"",211,0)"
^XMB(3.9,145833,2,1686,0)=" . S STATIONNUMBER=$$KSP^XUPARAM(""INST"")_"","""
^XMB(3.9,145833,2,1687,0)="""RTN"",""SDES2UTIL"",212,0)"
^XMB(3.9,145833,2,1688,0)=" . S STATIONNUMBER=$$GET1^DIQ(4,STATIONNUMBER,99)"
^XMB(3.9,145833,2,1689,0)="""RTN"",""SDES2UTIL"",213,0)"
^XMB(3.9,145833,2,1690,0)=" I +$G(CLINICIEN) D  Q STATIONNUMBER"
^XMB(3.9,145833,2,1691,0)="""RTN"",""SDES2UTIL"",214,0)"
^XMB(3.9,145833,2,1692,0)=" . S DIVISION=$$GET1^DIQ(44,CLINICIEN,3.5,""I"")"
^XMB(3.9,145833,2,1693,0)="""RTN"",""SDES2UTIL"",215,0)"
^XMB(3.9,145833,2,1694,0)=" . S INSTIEN=$$GET1^DIQ(40.8,DIVISION,.07,""I"")"
^XMB(3.9,145833,2,1695,0)="""RTN"",""SDES2UTIL"",216,0)"
^XMB(3.9,145833,2,1696,0)=" . S STATIONNUMBER=$$GET1^DIQ(4,INSTIEN,99,""I"")"
^XMB(3.9,145833,2,1697,0)="""RTN"",""SDES2UTIL"",217,0)"
^XMB(3.9,145833,2,1698,0)=" Q"
^XMB(3.9,145833,2,1699,0)="""RTN"",""SDES2UTIL"",218,0)"
^XMB(3.9,145833,2,1700,0)=" ;"
^XMB(3.9,145833,2,1701,0)="""RTN"",""SDES2UTIL"",219,0)"
^XMB(3.9,145833,2,1702,0)="VALIDATEAMIS(AMIS,RESTYP) ;"
^XMB(3.9,145833,2,1703,0)="""RTN"",""SDES2UTIL"",220,0)"
^XMB(3.9,145833,2,1704,0)=" ; Input:"
^XMB(3.9,145833,2,1705,0)="""RTN"",""SDES2UTIL"",221,0)"
^XMB(3.9,145833,2,1706,0)=" ;  AMIS: The AMIS Stop Code to validate"
^XMB(3.9,145833,2,1707,0)="""RTN"",""SDES2UTIL"",222,0)"
^XMB(3.9,145833,2,1708,0)=" ;  RESTYP: P:Primary, C:Credit"
^XMB(3.9,145833,2,1709,0)="""RTN"",""SDES2UTIL"",223,0)"
^XMB(3.9,145833,2,1710,0)=" ; Output:"
^XMB(3.9,145833,2,1711,0)="""RTN"",""SDES2UTIL"",224,0)"
^XMB(3.9,145833,2,1712,0)=" ;  0 = AMIS Stop Code is Valid"
^XMB(3.9,145833,2,1713,0)="""RTN"",""SDES2UTIL"",225,0)"
^XMB(3.9,145833,2,1714,0)=" ;  # = Error number to log"
^XMB(3.9,145833,2,1715,0)="""RTN"",""SDES2UTIL"",226,0)"
^XMB(3.9,145833,2,1716,0)=" S AMIS=$G(AMIS),RESTYP=$G(RESTYP)"
^XMB(3.9,145833,2,1717,0)="""RTN"",""SDES2UTIL"",227,0)"
^XMB(3.9,145833,2,1718,0)=" N ERRORNUM"
^XMB(3.9,145833,2,1719,0)="""RTN"",""SDES2UTIL"",228,0)"
^XMB(3.9,145833,2,1720,0)=" S ERRORNUM="""""
^XMB(3.9,145833,2,1721,0)="""RTN"",""SDES2UTIL"",229,0)"
^XMB(3.9,145833,2,1722,0)=" I RESTYP=""P"" D PRIMARYAMIS(.AMIS,.ERRORNUM)"
^XMB(3.9,145833,2,1723,0)="""RTN"",""SDES2UTIL"",230,0)"
^XMB(3.9,145833,2,1724,0)=" I RESTYP=""C"" D SECONDARYAMIS(.AMIS,.ERRORNUM)"
^XMB(3.9,145833,2,1725,0)="""RTN"",""SDES2UTIL"",231,0)"
^XMB(3.9,145833,2,1726,0)=" Q +ERRORNUM"
^XMB(3.9,145833,2,1727,0)="""RTN"",""SDES2UTIL"",232,0)"
^XMB(3.9,145833,2,1728,0)=" ;"
^XMB(3.9,145833,2,1729,0)="""RTN"",""SDES2UTIL"",233,0)"
^XMB(3.9,145833,2,1730,0)="PRIMARYAMIS(PRIAMIS,ERRORNUM) ;"
^XMB(3.9,145833,2,1731,0)="""RTN"",""SDES2UTIL"",234,0)"
^XMB(3.9,145833,2,1732,0)=" I +PRIAMIS=0 S ERRORNUM=270 Q"
^XMB(3.9,145833,2,1733,0)="""RTN"",""SDES2UTIL"",235,0)"
^XMB(3.9,145833,2,1734,0)=" I $L(PRIAMIS) D"
^XMB(3.9,145833,2,1735,0)="""RTN"",""SDES2UTIL"",236,0)"
^XMB(3.9,145833,2,1736,0)=" . I +PRIAMIS=0 S ERRORNUM=270 Q"
^XMB(3.9,145833,2,1737,0)="""RTN"",""SDES2UTIL"",237,0)"
^XMB(3.9,145833,2,1738,0)=" . I +PRIAMIS=900 S ERRORNUM=273 Q"
^XMB(3.9,145833,2,1739,0)="""RTN"",""SDES2UTIL"",238,0)"
^XMB(3.9,145833,2,1740,0)=" . S PRIAMIS=$$AMISTOSTOPCODE(.PRIAMIS)"
^XMB(3.9,145833,2,1741,0)="""RTN"",""SDES2UTIL"",239,0)"
^XMB(3.9,145833,2,1742,0)=" . I +PRIAMIS=0 S ERRORNUM=270 Q"
^XMB(3.9,145833,2,1743,0)="""RTN"",""SDES2UTIL"",240,0)"
^XMB(3.9,145833,2,1744,0)=" . I $$RESCHKFAILED(+PRIAMIS,""P"") S ERRORNUM=287 Q"
^XMB(3.9,145833,2,1745,0)="""RTN"",""SDES2UTIL"",241,0)"
^XMB(3.9,145833,2,1746,0)=" . I $$STOPCODEINACTIVE(+PRIAMIS,""P"") S ERRORNUM=512 Q"
^XMB(3.9,145833,2,1747,0)="""RTN"",""SDES2UTIL"",242,0)"
^XMB(3.9,145833,2,1748,0)=" Q"
^XMB(3.9,145833,2,1749,0)="""RTN"",""SDES2UTIL"",243,0)"
^XMB(3.9,145833,2,1750,0)=" ;"
^XMB(3.9,145833,2,1751,0)="""RTN"",""SDES2UTIL"",244,0)"
^XMB(3.9,145833,2,1752,0)="SECONDARYAMIS(CREDITAMIS,ERRORNUM) ;"
^XMB(3.9,145833,2,1753,0)="""RTN"",""SDES2UTIL"",245,0)"
^XMB(3.9,145833,2,1754,0)=" I +CREDITAMIS=0 S ERRORNUM=271 Q"
^XMB(3.9,145833,2,1755,0)="""RTN"",""SDES2UTIL"",246,0)"
^XMB(3.9,145833,2,1756,0)=" I $L(CREDITAMIS) D"
^XMB(3.9,145833,2,1757,0)="""RTN"",""SDES2UTIL"",247,0)"
^XMB(3.9,145833,2,1758,0)=" . I +CREDITAMIS=0 S ERRORNUM=271 Q"
^XMB(3.9,145833,2,1759,0)="""RTN"",""SDES2UTIL"",248,0)"
^XMB(3.9,145833,2,1760,0)=" . I +CREDITAMIS=900 S ERRORNUM=273 Q"
^XMB(3.9,145833,2,1761,0)="""RTN"",""SDES2UTIL"",249,0)"
^XMB(3.9,145833,2,1762,0)=" . S CREDITAMIS=$$AMISTOSTOPCODE(.CREDITAMIS)"
^XMB(3.9,145833,2,1763,0)="""RTN"",""SDES2UTIL"",250,0)"
^XMB(3.9,145833,2,1764,0)=" . I +CREDITAMIS=0 S ERRORNUM=271 Q"
^XMB(3.9,145833,2,1765,0)="""RTN"",""SDES2UTIL"",251,0)"
^XMB(3.9,145833,2,1766,0)=" . I $$RESCHKFAILED(+CREDITAMIS,""S"") S ERRORNUM=288 Q"
^XMB(3.9,145833,2,1767,0)="""RTN"",""SDES2UTIL"",252,0)"
^XMB(3.9,145833,2,1768,0)=" . I $$STOPCODEINACTIVE(+CREDITAMIS,""C"") S ERRORNUM=513 Q"
^XMB(3.9,145833,2,1769,0)="""RTN"",""SDES2UTIL"",253,0)"
^XMB(3.9,145833,2,1770,0)=" Q"
^XMB(3.9,145833,2,1771,0)="""RTN"",""SDES2UTIL"",254,0)"
^XMB(3.9,145833,2,1772,0)=" ;"
^XMB(3.9,145833,2,1773,0)="""RTN"",""SDES2UTIL"",255,0)"
^XMB(3.9,145833,2,1774,0)="AMISTOSTOPCODE(AMIS) ; Map from AMIS to Stop Code"
^XMB(3.9,145833,2,1775,0)="""RTN"",""SDES2UTIL"",256,0)"
^XMB(3.9,145833,2,1776,0)=" ; Input: AMIS = (Req) the AMIS REPORTING STOP CODE (#1) field from the CLINIC STOP (#40.7) file."
^XMB(3.9,145833,2,1777,0)="""RTN"",""SDES2UTIL"",257,0)"
^XMB(3.9,145833,2,1778,0)=" ; Output: 0:validation failed, IEN for the Stop Code that matches to the passed in AMIS code."
^XMB(3.9,145833,2,1779,0)="""RTN"",""SDES2UTIL"",258,0)"
^XMB(3.9,145833,2,1780,0)=" N STOPIEN,STOPINACTDT,STOPCOUNT,STOPFOUND"
^XMB(3.9,145833,2,1781,0)="""RTN"",""SDES2UTIL"",259,0)"
^XMB(3.9,145833,2,1782,0)=" I '$G(AMIS) Q 0"
^XMB(3.9,145833,2,1783,0)="""RTN"",""SDES2UTIL"",260,0)"
^XMB(3.9,145833,2,1784,0)=" S (STOPIEN,STOPCOUNT,STOPFOUND)=0"
^XMB(3.9,145833,2,1785,0)="""RTN"",""SDES2UTIL"",261,0)"
^XMB(3.9,145833,2,1786,0)=" F  S STOPIEN=$O(^DIC(40.7,""C"",AMIS,STOPIEN)) Q:'STOPIEN  D"
^XMB(3.9,145833,2,1787,0)="""RTN"",""SDES2UTIL"",262,0)"
^XMB(3.9,145833,2,1788,0)=" .S STOPINACTDT=$$GET1^DIQ(40.7,STOPIEN,2,""I"")"
^XMB(3.9,145833,2,1789,0)="""RTN"",""SDES2UTIL"",263,0)"
^XMB(3.9,145833,2,1790,0)=" .I STOPINACTDT,STOPINACTDT<DT!(STOPINACTDT=DT) Q"
^XMB(3.9,145833,2,1791,0)="""RTN"",""SDES2UTIL"",264,0)"
^XMB(3.9,145833,2,1792,0)=" .S STOPCOUNT=STOPCOUNT+1"
^XMB(3.9,145833,2,1793,0)="""RTN"",""SDES2UTIL"",265,0)"
^XMB(3.9,145833,2,1794,0)=" .S STOPFOUND=STOPIEN"
^XMB(3.9,145833,2,1795,0)="""RTN"",""SDES2UTIL"",266,0)"
^XMB(3.9,145833,2,1796,0)=" I STOPCOUNT>1 Q 0"
^XMB(3.9,145833,2,1797,0)="""RTN"",""SDES2UTIL"",267,0)"
^XMB(3.9,145833,2,1798,0)=" Q STOPFOUND"
^XMB(3.9,145833,2,1799,0)="""RTN"",""SDES2UTIL"",268,0)"
^XMB(3.9,145833,2,1800,0)=" ;"
^XMB(3.9,145833,2,1801,0)="""RTN"",""SDES2UTIL"",269,0)"
^XMB(3.9,145833,2,1802,0)="STOPCODETOAMIS(STOPIEN) ; Map from Stop Code IEN to AMIS Stop Code Number"
^XMB(3.9,145833,2,1803,0)="""RTN"",""SDES2UTIL"",270,0)"
^XMB(3.9,145833,2,1804,0)=" ;  Input: STOPIEN = (Req) The IEN of the Stop Code in the CLINIC STOP (#40.7) file."
^XMB(3.9,145833,2,1805,0)="""RTN"",""SDES2UTIL"",271,0)"
^XMB(3.9,145833,2,1806,0)=" ; Output: """": validation failed, IEN for the AMIS REPORTING STOP CODE (#1)."
^XMB(3.9,145833,2,1807,0)="""RTN"",""SDES2UTIL"",272,0)"
^XMB(3.9,145833,2,1808,0)=" N STOPCODE"
^XMB(3.9,145833,2,1809,0)="""RTN"",""SDES2UTIL"",273,0)"
^XMB(3.9,145833,2,1810,0)=" S STOPCODE="""",STOPIEN=$G(STOPIEN,"""")"
^XMB(3.9,145833,2,1811,0)="""RTN"",""SDES2UTIL"",274,0)"
^XMB(3.9,145833,2,1812,0)=" Q:STOPIEN<1 STOPCODE"
^XMB(3.9,145833,2,1813,0)="""RTN"",""SDES2UTIL"",275,0)"
^XMB(3.9,145833,2,1814,0)=" Q:'$D(^DIC(40.7,STOPIEN,0)) STOPCODE"
^XMB(3.9,145833,2,1815,0)="""RTN"",""SDES2UTIL"",276,0)"
^XMB(3.9,145833,2,1816,0)=" S STOPCODE=$$GET1^DIQ(40.7,STOPIEN,1,""I"")"
^XMB(3.9,145833,2,1817,0)="""RTN"",""SDES2UTIL"",277,0)"
^XMB(3.9,145833,2,1818,0)=" Q STOPCODE"
^XMB(3.9,145833,2,1819,0)="""RTN"",""SDES2UTIL"",278,0)"
^XMB(3.9,145833,2,1820,0)=" ;"
^XMB(3.9,145833,2,1821,0)="""RTN"",""SDES2UTIL"",279,0)"
^XMB(3.9,145833,2,1822,0)="RESCHKFAILED(STOPCODEIEN,RESTYPE) ;"
^XMB(3.9,145833,2,1823,0)="""RTN"",""SDES2UTIL"",280,0)"
^XMB(3.9,145833,2,1824,0)=" ; Input: STOPCODEIEN (Req) IEN from CLINIC STOP (#40.7) file."
^XMB(3.9,145833,2,1825,0)="""RTN"",""SDES2UTIL"",281,0)"
^XMB(3.9,145833,2,1826,0)=" ;        RESTYPE (Req) P for Primary or S for Credit"
^XMB(3.9,145833,2,1827,0)="""RTN"",""SDES2UTIL"",282,0)"
^XMB(3.9,145833,2,1828,0)=" ; Output: 0: Restriction checks passed, 1: Restriction checks failed"
^XMB(3.9,145833,2,1829,0)="""RTN"",""SDES2UTIL"",283,0)"
^XMB(3.9,145833,2,1830,0)=" I '+STOPCODEIEN Q 1"
^XMB(3.9,145833,2,1831,0)="""RTN"",""SDES2UTIL"",284,0)"
^XMB(3.9,145833,2,1832,0)=" I ""^P^S^""'[(""^""_RESTYPE_""^"") Q 1"
^XMB(3.9,145833,2,1833,0)="""RTN"",""SDES2UTIL"",285,0)"
^XMB(3.9,145833,2,1834,0)=" N RESTRICTION"
^XMB(3.9,145833,2,1835,0)="""RTN"",""SDES2UTIL"",286,0)"
^XMB(3.9,145833,2,1836,0)=" S RESTRICTION=$$GET1^DIQ(40.7,STOPCODEIEN,5,""I"")"
^XMB(3.9,145833,2,1837,0)="""RTN"",""SDES2UTIL"",287,0)"
^XMB(3.9,145833,2,1838,0)=" I RESTRICTION=""E"" Q 0"
^XMB(3.9,145833,2,1839,0)="""RTN"",""SDES2UTIL"",288,0)"
^XMB(3.9,145833,2,1840,0)=" I RESTRICTION'=RESTYPE Q 1"
^XMB(3.9,145833,2,1841,0)="""RTN"",""SDES2UTIL"",289,0)"
^XMB(3.9,145833,2,1842,0)=" Q 0"
^XMB(3.9,145833,2,1843,0)="""RTN"",""SDES2UTIL"",290,0)"
^XMB(3.9,145833,2,1844,0)=" ;"
^XMB(3.9,145833,2,1845,0)="""RTN"",""SDES2UTIL"",291,0)"
^XMB(3.9,145833,2,1846,0)="STOPCODEINACTIVE(SDAMISSTOPCODE,SDTYPE) ;"
^XMB(3.9,145833,2,1847,0)="""RTN"",""SDES2UTIL"",292,0)"
^XMB(3.9,145833,2,1848,0)=" ; SDAMISSTOPCODE = IEN of Stop Code"
^XMB(3.9,145833,2,1849,0)="""RTN"",""SDES2UTIL"",293,0)"
^XMB(3.9,145833,2,1850,0)=" N SDSTOPCODE,SDINACTIVEDATE"
^XMB(3.9,145833,2,1851,0)="""RTN"",""SDES2UTIL"",294,0)"
^XMB(3.9,145833,2,1852,0)=" S SDINACTIVEDATE=$$GET1^DIQ(40.7,SDAMISSTOPCODE,2,""I"")"
^XMB(3.9,145833,2,1853,0)="""RTN"",""SDES2UTIL"",295,0)"
^XMB(3.9,145833,2,1854,0)=" I SDINACTIVEDATE="""" Q 0"
^XMB(3.9,145833,2,1855,0)="""RTN"",""SDES2UTIL"",296,0)"
^XMB(3.9,145833,2,1856,0)=" I SDINACTIVEDATE>DT Q 0"
^XMB(3.9,145833,2,1857,0)="""RTN"",""SDES2UTIL"",297,0)"
^XMB(3.9,145833,2,1858,0)=" I SDTYPE=""P"" Q 512"
^XMB(3.9,145833,2,1859,0)="""RTN"",""SDES2UTIL"",298,0)"
^XMB(3.9,145833,2,1860,0)=" I SDTYPE=""C"" Q 513"
^XMB(3.9,145833,2,1861,0)="""RTN"",""SDES2UTIL"",299,0)"
^XMB(3.9,145833,2,1862,0)=" Q 0"
^XMB(3.9,145833,2,1863,0)="""RTN"",""SDES2UTIL"",300,0)"
^XMB(3.9,145833,2,1864,0)=" ; Set of codes internal to external"
^XMB(3.9,145833,2,1865,0)="""RTN"",""SDES2UTIL"",301,0)"
^XMB(3.9,145833,2,1866,0)="SOCINT2EXT(FILE,FLD,INTVAL) ;"
^XMB(3.9,145833,2,1867,0)="""RTN"",""SDES2UTIL"",302,0)"
^XMB(3.9,145833,2,1868,0)=" N FOUND,ITEM,CODE,EXTCODE,RETURN,INTCODE,RESULTS"
^XMB(3.9,145833,2,1869,0)="""RTN"",""SDES2UTIL"",303,0)"
^XMB(3.9,145833,2,1870,0)=" I '$L($G(INTVAL)) Q """""
^XMB(3.9,145833,2,1871,0)="""RTN"",""SDES2UTIL"",304,0)"
^XMB(3.9,145833,2,1872,0)=" S INTVAL=$$UP^XLFSTR(INTVAL)"
^XMB(3.9,145833,2,1873,0)="""RTN"",""SDES2UTIL"",305,0)"
^XMB(3.9,145833,2,1874,0)=" D FIELD^DID(FILE,FLD,"""",""SET OF CODES"",""RESULTS"")"
^XMB(3.9,145833,2,1875,0)="""RTN"",""SDES2UTIL"",306,0)"
^XMB(3.9,145833,2,1876,0)=" S FOUND=0"
^XMB(3.9,145833,2,1877,0)="""RTN"",""SDES2UTIL"",307,0)"
^XMB(3.9,145833,2,1878,0)=" F ITEM=1:1:$L(RESULTS(""SET OF CODES""),"";"") D  Q:FOUND"
^XMB(3.9,145833,2,1879,0)="""RTN"",""SDES2UTIL"",308,0)"
^XMB(3.9,145833,2,1880,0)=" .S CODE=$P(RESULTS(""SET OF CODES""),"";"",ITEM) Q:'$L(CODE)"
^XMB(3.9,145833,2,1881,0)="""RTN"",""SDES2UTIL"",309,0)"
^XMB(3.9,145833,2,1882,0)=" .S INTCODE=$P(CODE,"":""),EXTCODE=$P(CODE,"":"",2)"
^XMB(3.9,145833,2,1883,0)="""RTN"",""SDES2UTIL"",310,0)"
^XMB(3.9,145833,2,1884,0)=" .I INTVAL=INTCODE S RETURN=EXTCODE,FOUND=1"
^XMB(3.9,145833,2,1885,0)="""RTN"",""SDES2UTIL"",311,0)"
^XMB(3.9,145833,2,1886,0)=" Q $G(RETURN)"
^XMB(3.9,145833,2,1887,0)="""RTN"",""SDES2UTIL"",312,0)"
^XMB(3.9,145833,2,1888,0)=" ; Set of codes external to internal"
^XMB(3.9,145833,2,1889,0)="""RTN"",""SDES2UTIL"",313,0)"
^XMB(3.9,145833,2,1890,0)="SOCEXT2INT(FILE,FLD,EXTVAL) ;"
^XMB(3.9,145833,2,1891,0)="""RTN"",""SDES2UTIL"",314,0)"
^XMB(3.9,145833,2,1892,0)=" N FOUND,ITEM,CODE,EXTCODE,RETURN,INTCODE,RESULTS"
^XMB(3.9,145833,2,1893,0)="""RTN"",""SDES2UTIL"",315,0)"
^XMB(3.9,145833,2,1894,0)=" I '$L($G(EXTVAL)) Q """""
^XMB(3.9,145833,2,1895,0)="""RTN"",""SDES2UTIL"",316,0)"
^XMB(3.9,145833,2,1896,0)=" S EXTVAL=$$UP^XLFSTR(EXTVAL)"
^XMB(3.9,145833,2,1897,0)="""RTN"",""SDES2UTIL"",317,0)"
^XMB(3.9,145833,2,1898,0)=" D FIELD^DID(FILE,FLD,"""",""SET OF CODES"",""RESULTS"")"
^XMB(3.9,145833,2,1899,0)="""RTN"",""SDES2UTIL"",318,0)"
^XMB(3.9,145833,2,1900,0)=" S FOUND=0"
^XMB(3.9,145833,2,1901,0)="""RTN"",""SDES2UTIL"",319,0)"
^XMB(3.9,145833,2,1902,0)=" F ITEM=1:1:$L(RESULTS(""SET OF CODES""),"";"") D  Q:FOUND"
^XMB(3.9,145833,2,1903,0)="""RTN"",""SDES2UTIL"",320,0)"
^XMB(3.9,145833,2,1904,0)=" .S CODE=$P(RESULTS(""SET OF CODES""),"";"",ITEM) Q:'$L(CODE)"
^XMB(3.9,145833,2,1905,0)="""RTN"",""SDES2UTIL"",321,0)"
^XMB(3.9,145833,2,1906,0)=" .S INTCODE=$P(CODE,"":""),EXTCODE=$P(CODE,"":"",2)"
^XMB(3.9,145833,2,1907,0)="""RTN"",""SDES2UTIL"",322,0)"
^XMB(3.9,145833,2,1908,0)=" .I EXTCODE=EXTVAL S RETURN=INTCODE,FOUND=1"
^XMB(3.9,145833,2,1909,0)="""RTN"",""SDES2UTIL"",323,0)"
^XMB(3.9,145833,2,1910,0)=" Q $G(RETURN)"
^XMB(3.9,145833,2,1911,0)="""RTN"",""SDES2UTIL"",324,0)"
^XMB(3.9,145833,2,1912,0)=" ;"
^XMB(3.9,145833,2,1913,0)="""RTN"",""SDES2UTIL"",325,0)"
^XMB(3.9,145833,2,1914,0)="CHECKYN(VAR) ;"
^XMB(3.9,145833,2,1915,0)="""RTN"",""SDES2UTIL"",326,0)"
^XMB(3.9,145833,2,1916,0)=" I VAR'=""Y"",VAR'=""N"" Q 0"
^XMB(3.9,145833,2,1917,0)="""RTN"",""SDES2UTIL"",327,0)"
^XMB(3.9,145833,2,1918,0)=" Q 1"
^XMB(3.9,145833,2,1919,0)="""RTN"",""SDES2UTIL"",328,0)"
^XMB(3.9,145833,2,1920,0)=" ;"
^XMB(3.9,145833,2,1921,0)="""RTN"",""SDES2UTIL"",329,0)"
^XMB(3.9,145833,2,1922,0)="CHECKYNBLANKDEL(VAR) ;"
^XMB(3.9,145833,2,1923,0)="""RTN"",""SDES2UTIL"",330,0)"
^XMB(3.9,145833,2,1924,0)=" I VAR'=""Y"",VAR'=""N"",VAR'="""",VAR'=""@"" Q 0"
^XMB(3.9,145833,2,1925,0)="""RTN"",""SDES2UTIL"",331,0)"
^XMB(3.9,145833,2,1926,0)=" Q 1"
^XMB(3.9,145833,2,1927,0)="""RTN"",""SDES2UTIL"",332,0)"
^XMB(3.9,145833,2,1928,0)=" ;"
^XMB(3.9,145833,2,1929,0)="""RTN"",""SDES2UTIL"",333,0)"
^XMB(3.9,145833,2,1930,0)="YNTOBOOL(VAR) ;convert a Y/N input param to 1 or 0"
^XMB(3.9,145833,2,1931,0)="""RTN"",""SDES2UTIL"",334,0)"
^XMB(3.9,145833,2,1932,0)=" Q $S(VAR=""Y"":1,VAR=""N"":0,1:VAR)"
^XMB(3.9,145833,2,1933,0)="""RTN"",""SDES2UTIL"",335,0)"
^XMB(3.9,145833,2,1934,0)=" ;"
^XMB(3.9,145833,2,1935,0)="""RTN"",""SDES2UTIL"",336,0)"
^XMB(3.9,145833,2,1936,0)="CHECKFORDEL(SDERRORS,SDINPUTARRAY) ; Check top level array entries for @"
^XMB(3.9,145833,2,1937,0)="""RTN"",""SDES2UTIL"",337,0)"
^XMB(3.9,145833,2,1938,0)=" N SDSUB"
^XMB(3.9,145833,2,1939,0)="""RTN"",""SDES2UTIL"",338,0)"
^XMB(3.9,145833,2,1940,0)=" S SDSUB="""""
^XMB(3.9,145833,2,1941,0)="""RTN"",""SDES2UTIL"",339,0)"
^XMB(3.9,145833,2,1942,0)=" F  S SDSUB=$O(SDINPUTARRAY(SDSUB)) Q:SDSUB=""""  D"
^XMB(3.9,145833,2,1943,0)="""RTN"",""SDES2UTIL"",340,0)"
^XMB(3.9,145833,2,1944,0)=" .I $G(SDINPUTARRAY(SDSUB))=""@""  D ERRLOG^SDES2JSON(.SDERRORS,459,SDSUB)"
^XMB(3.9,145833,2,1945,0)="""RTN"",""SDES2UTIL"",341,0)"
^XMB(3.9,145833,2,1946,0)=" Q"
^XMB(3.9,145833,2,1947,0)="""RTN"",""SDES2UTIL"",342,0)"
^XMB(3.9,145833,2,1948,0)=" ;"
^XMB(3.9,145833,2,1949,0)="""RTN"",""SDES2UTIL"",343,0)"
^XMB(3.9,145833,2,1950,0)="CHECKFORDELMULT(SDERRORS,SDINPUTARRAY) ; Check subfile array entries for @"
^XMB(3.9,145833,2,1951,0)="""RTN"",""SDES2UTIL"",344,0)"
^XMB(3.9,145833,2,1952,0)=" N SDSUBFILE,SDIEN"
^XMB(3.9,145833,2,1953,0)="""RTN"",""SDES2UTIL"",345,0)"
^XMB(3.9,145833,2,1954,0)=" F SDSUBFILE=""DIAGNOSIS"",""PROVIDER"",""PRIVILEGED USER"",""SPECIAL INSTRUCTIONS"" D"
^XMB(3.9,145833,2,1955,0)="""RTN"",""SDES2UTIL"",346,0)"
^XMB(3.9,145833,2,1956,0)=" .S SDIEN="""""
^XMB(3.9,145833,2,1957,0)="""RTN"",""SDES2UTIL"",347,0)"
^XMB(3.9,145833,2,1958,0)=" .F  S SDIEN=$O(SDINPUTARRAY(SDSUBFILE,SDIEN)) Q:SDIEN=""""  D"
^XMB(3.9,145833,2,1959,0)="""RTN"",""SDES2UTIL"",348,0)"
^XMB(3.9,145833,2,1960,0)=" ..I $G(SDINPUTARRAY(SDSUBFILE,SDIEN))=""@""  D ERRLOG^SDES2JSON(.SDERRORS,459,SDSUBFILE_"": ""_SDIEN)"
^XMB(3.9,145833,2,1961,0)="""RTN"",""SDES2UTIL"",349,0)"
^XMB(3.9,145833,2,1962,0)=" ..I SDSUBFILE=""SPECIAL INSTRUCTIONS"",$P($G(SDINPUTARRAY(SDSUBFILE,SDIEN)),""|"",2)=""@"" D ERRLOG^SDES2JSON(.SDERRORS,459,SDSUBFILE_"": ""_SDIEN)"
^XMB(3.9,145833,2,1963,0)="""RTN"",""SDES2UTIL"",350,0)"
^XMB(3.9,145833,2,1964,0)=" ..I $G(SDINPUTARRAY(SDSUBFILE,SDIEN,""DEFAULT""))=""@"" D ERRLOG^SDES2JSON(.SDERRORS,459,SDSUBFILE_"" DEFAULT: ""_SDIEN)"
^XMB(3.9,145833,2,1965,0)="""RTN"",""SDES2UTIL"",351,0)"
^XMB(3.9,145833,2,1966,0)=" Q"
^XMB(3.9,145833,2,1967,0)="""RTN"",""SDES2UTIL"",352,0)"
^XMB(3.9,145833,2,1968,0)=" ; 862"
^XMB(3.9,145833,2,1969,0)="""RTN"",""SDES2UTIL"",353,0)"
^XMB(3.9,145833,2,1970,0)="SENSITIVE(RESULT,DFN,SDDUZ,DGMSG,DGOPT) ;RPC/API entry point for patient sensitive & record access checks"
^XMB(3.9,145833,2,1971,0)="""RTN"",""SDES2UTIL"",354,0)"
^XMB(3.9,145833,2,1972,0)=" ;Output array (Required)"
