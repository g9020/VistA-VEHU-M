^XMB(3.9,144654,2,472,0)=" .S CLD=1 F DR=0:0 S DR=$O(OSGY(DR)) Q:'DR  D"
^XMB(3.9,144654,2,473,0)="""RTN"",""PSOHLDS2"",117,0)"
