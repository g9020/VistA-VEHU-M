^XMB(3.9,145833,2,2886,0)=" I $G(RESULT(""DISCONTINUE""))'=1 D VALIDATE(.RESULT,.ERROR)"
^XMB(3.9,145833,2,2887,0)="""RTN"",""SDHL7"",52,0)"
