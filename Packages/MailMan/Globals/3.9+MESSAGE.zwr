^XMB(3.9,145833,2,810,0)=" S SDCLINIC=$G(SDCLINIC)"
^XMB(3.9,145833,2,811,0)="""RTN"",""SDES2UTDT"",50,0)"
^XMB(3.9,145833,2,812,0)=" ;extract out date, removing punctuation"
^XMB(3.9,145833,2,813,0)="""RTN"",""SDES2UTDT"",51,0)"
