^XMB(3.9,144659,2,247,0)="""RTN"",""IBCRHBRV"")"
^XMB(3.9,144659,2,248,0)="0^1^B58168913"
^XMB(3.9,144659,2,249,0)="""RTN"",""IBCRHBRV"",1,0)"
^XMB(3.9,144659,2,250,0)="IBCRHBRV ;ALB/ARH - RATES: UPLOAD (RC) VERSION FUNCTIONS ; 14-FEB-01"
^XMB(3.9,144659,2,251,0)="""RTN"",""IBCRHBRV"",2,0)"
^XMB(3.9,144659,2,252,0)=" ;;2.0;INTEGRATED BILLING;**148,169,245,270,285,298,325,334,355,360,365,382,390,408,412,423,427,439,445,462,468,484,491,508,520,536,542,556,559,573,584,600,612,628,634,658,667,683,693,719,724,744,755,783,809,814,835**;21-MAR-94;Build 0"
^XMB(3.9,144659,2,253,0)="""RTN"",""IBCRHBRV"",3,0)"
^XMB(3.9,144659,2,254,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144659,2,255,0)="""RTN"",""IBCRHBRV"",4,0)"
^XMB(3.9,144659,2,256,0)=" ;"
^XMB(3.9,144659,2,257,0)="""RTN"",""IBCRHBRV"",5,0)"
^XMB(3.9,144659,2,258,0)=" ; RC functions related to Version.  Update VLIST with new versions.  Update FTYPE if new types of files."
^XMB(3.9,144659,2,259,0)="""RTN"",""IBCRHBRV"",6,0)"
^XMB(3.9,144659,2,260,0)=" ;"
^XMB(3.9,144659,2,261,0)="""RTN"",""IBCRHBRV"",7,0)"
^XMB(3.9,144659,2,262,0)="SELVERS() ; get version to upload from user"
^XMB(3.9,144659,2,263,0)="""RTN"",""IBCRHBRV"",8,0)"
^XMB(3.9,144659,2,264,0)=" N DIR,DIRUT,DTOUT,DUOUT,IBVLIST,IBQUIT,IBVERS,IBI,IBJ,IBX,X,Y"
^XMB(3.9,144659,2,265,0)="""RTN"",""IBCRHBRV"",9,0)"
^XMB(3.9,144659,2,266,0)=" ;"
^XMB(3.9,144659,2,267,0)="""RTN"",""IBCRHBRV"",10,0)"
^XMB(3.9,144659,2,268,0)=" S IBVLIST=$$VERSTR(),IBQUIT=0,IBVERS=0"
^XMB(3.9,144659,2,269,0)="""RTN"",""IBCRHBRV"",11,0)"
^XMB(3.9,144659,2,270,0)=" ;"
^XMB(3.9,144659,2,271,0)="""RTN"",""IBCRHBRV"",12,0)"
^XMB(3.9,144659,2,272,0)=" W !!,""Select the version of Reasonable Charges to upload."""
^XMB(3.9,144659,2,273,0)="""RTN"",""IBCRHBRV"",13,0)"
^XMB(3.9,144659,2,274,0)=" S DIR(""?"",1)=""Enter the code from the list corresponding to the version of Reasonable Charges"""
^XMB(3.9,144659,2,275,0)="""RTN"",""IBCRHBRV"",14,0)"
^XMB(3.9,144659,2,276,0)=" S DIR(""?"",2)=""to upload.  There are no version 1.3, 2.2, or 2.10 (ten) RC charges."" S DIR(""?"",3)="" """
^XMB(3.9,144659,2,277,0)="""RTN"",""IBCRHBRV"",15,0)"
^XMB(3.9,144659,2,278,0)=" S DIR(""?"",4)=""Versions: ""_IBVLIST S DIR(""?"",5)="" "" S DIR(""?"")=""Enter version number to upload."""
^XMB(3.9,144659,2,279,0)="""RTN"",""IBCRHBRV"",16,0)"
^XMB(3.9,144659,2,280,0)=" ;"
^XMB(3.9,144659,2,281,0)="""RTN"",""IBCRHBRV"",17,0)"
^XMB(3.9,144659,2,282,0)=" F IBI=1:1 D  I +IBQUIT Q"
^XMB(3.9,144659,2,283,0)="""RTN"",""IBCRHBRV"",18,0)"
^XMB(3.9,144659,2,284,0)=" . W !!,?5,""Select one of the following:"",!"
^XMB(3.9,144659,2,285,0)="""RTN"",""IBCRHBRV"",19,0)"
^XMB(3.9,144659,2,286,0)=" . F IBJ=1:1 S IBX=$P(IBVLIST,"","",IBJ) Q:'IBX  W !,?10,IBX,?20,""Reasonable Charges version "",IBX"
^XMB(3.9,144659,2,287,0)="""RTN"",""IBCRHBRV"",20,0)"
^XMB(3.9,144659,2,288,0)=" . ;"
^XMB(3.9,144659,2,289,0)="""RTN"",""IBCRHBRV"",21,0)"
^XMB(3.9,144659,2,290,0)=" . W ! S DIR(""A"")=""Enter Version"" S DIR(0)=""FO^1:5"" D ^DIR I $D(DIRUT) S IBQUIT=1"
^XMB(3.9,144659,2,291,0)="""RTN"",""IBCRHBRV"",22,0)"
^XMB(3.9,144659,2,292,0)=" . I Y>0,("",""_IBVLIST_"","")[("",""_Y_"","") S IBVERS=Y,IBQUIT=1 W ""  Reasonable Charges version "",IBVERS"
^XMB(3.9,144659,2,293,0)="""RTN"",""IBCRHBRV"",23,0)"
^XMB(3.9,144659,2,294,0)=" ;"
^XMB(3.9,144659,2,295,0)="""RTN"",""IBCRHBRV"",24,0)"
^XMB(3.9,144659,2,296,0)=" Q IBVERS"
^XMB(3.9,144659,2,297,0)="""RTN"",""IBCRHBRV"",25,0)"
^XMB(3.9,144659,2,298,0)=" ;"
^XMB(3.9,144659,2,299,0)="""RTN"",""IBCRHBRV"",26,0)"
^XMB(3.9,144659,2,300,0)="VERSION() ; return currently loaded version of RC files (1, 1.1, ...)"
^XMB(3.9,144659,2,301,0)="""RTN"",""IBCRHBRV"",27,0)"
^XMB(3.9,144659,2,302,0)=" N IBX S IBX=$G(^XTMP(""IBCR RC SITE"",""VERSION""))"
^XMB(3.9,144659,2,303,0)="""RTN"",""IBCRHBRV"",28,0)"
^XMB(3.9,144659,2,304,0)=" Q IBX"
^XMB(3.9,144659,2,305,0)="""RTN"",""IBCRHBRV"",29,0)"
^XMB(3.9,144659,2,306,0)=" ;"
^XMB(3.9,144659,2,307,0)="""RTN"",""IBCRHBRV"",30,0)"
^XMB(3.9,144659,2,308,0)="VERSDT(VERS) ; return Effective Date of a version of RC files, either version passed in or currently loaded version"
^XMB(3.9,144659,2,309,0)="""RTN"",""IBCRHBRV"",31,0)"
^XMB(3.9,144659,2,310,0)=" N IBI,LINE,IBX S IBX="""" S VERS=+$G(VERS) I 'VERS S VERS=$$VERSION"
^XMB(3.9,144659,2,311,0)="""RTN"",""IBCRHBRV"",32,0)"
^XMB(3.9,144659,2,312,0)=" I +VERS F IBI=1:1 S LINE=$P($T(VLIST+IBI),"";;"",2,99) Q:'LINE  I VERS=+LINE S IBX=$P(LINE,U,3)"
^XMB(3.9,144659,2,313,0)="""RTN"",""IBCRHBRV"",33,0)"
^XMB(3.9,144659,2,314,0)=" Q IBX"
^XMB(3.9,144659,2,315,0)="""RTN"",""IBCRHBRV"",34,0)"
^XMB(3.9,144659,2,316,0)=" ;"
^XMB(3.9,144659,2,317,0)="""RTN"",""IBCRHBRV"",35,0)"
^XMB(3.9,144659,2,318,0)="VERSEDT(VERS) ; return Inactive Date of a version of RC files, either version passed in or currently loaded version"
^XMB(3.9,144659,2,319,0)="""RTN"",""IBCRHBRV"",36,0)"
^XMB(3.9,144659,2,320,0)=" N IBI,LINE,IBX S IBX="""" S VERS=+$G(VERS) I 'VERS S VERS=$$VERSION"
^XMB(3.9,144659,2,321,0)="""RTN"",""IBCRHBRV"",37,0)"
^XMB(3.9,144659,2,322,0)=" I +VERS F IBI=1:1 S LINE=$P($T(VLIST+IBI),"";;"",2,99) Q:'LINE  I VERS=+LINE S IBX=$P(LINE,U,4)"
^XMB(3.9,144659,2,323,0)="""RTN"",""IBCRHBRV"",38,0)"
^XMB(3.9,144659,2,324,0)=" Q IBX"
^XMB(3.9,144659,2,325,0)="""RTN"",""IBCRHBRV"",39,0)"
^XMB(3.9,144659,2,326,0)=" ;"
^XMB(3.9,144659,2,327,0)="""RTN"",""IBCRHBRV"",40,0)"
^XMB(3.9,144659,2,328,0)="VERSALL() ; return all RC versions and corresponding effective date 'VERS;EFFDT^VERS;EFFDT^...'"
^XMB(3.9,144659,2,329,0)="""RTN"",""IBCRHBRV"",41,0)"
^XMB(3.9,144659,2,330,0)=" N IBI,LINE,IBX,IBC S IBX="""",IBC="""""
^XMB(3.9,144659,2,331,0)="""RTN"",""IBCRHBRV"",42,0)"
