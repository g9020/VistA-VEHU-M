^XMB(3.9,144654,2,593,0)="""RTN"",""PSOHLDS2"",177,0)"
^XMB(3.9,144654,2,594,0)=" N NTE6"
^XMB(3.9,144654,2,595,0)="""RTN"",""PSOHLDS2"",178,0)"
^XMB(3.9,144654,2,596,0)=" Q:'$G(DAW)"
^XMB(3.9,144654,2,597,0)="""RTN"",""PSOHLDS2"",179,0)"
^XMB(3.9,144654,2,598,0)=" D START3^PSOHLDS3"
