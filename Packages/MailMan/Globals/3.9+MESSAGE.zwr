^XMB(3.9,145834,2,2845,0)="""RTN"",""MAGDSTA1"",99,0)"
^XMB(3.9,145834,2,2846,0)=" . . . D COPYPARM(1)"
^XMB(3.9,145834,2,2847,0)="""RTN"",""MAGDSTA1"",100,0)"
