^XMB(3.9,145839,2,1099,0)="""RTN"",""TIUCCRHL7P4"",54,0)"
^XMB(3.9,145839,2,1100,0)=" ;CCPN Number:?2 ?  CONSULT AND REFERRAL INFORMATION"
^XMB(3.9,145839,2,1101,0)="""RTN"",""TIUCCRHL7P4"",55,0)"
