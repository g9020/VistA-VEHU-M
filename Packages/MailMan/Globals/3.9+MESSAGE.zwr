^XMB(3.9,145831,2,1061,0)="""RTN"",""EDPVIT"",98,0)"
^XMB(3.9,145831,2,1062,0)=" .. D XML^EDPX(""</vitalMsmt>"")"
^XMB(3.9,145831,2,1063,0)="""RTN"",""EDPVIT"",99,0)"
^XMB(3.9,145831,2,1064,0)=" . I $G(EDPBMI) D  K EDPBMI"
