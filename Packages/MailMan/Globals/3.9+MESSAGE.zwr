^XMB(3.9,144657,2,10190,0)=" S IBADT=+$G(IBD(""DOS"")) I 'IBADT S IBY=""0^Missing Date of Service"" G REVQ"
^XMB(3.9,144657,2,10191,0)="""RTN"",""IBNCPDP3"",38,0)"
^XMB(3.9,144657,2,10192,0)=" S IBRXN=+$G(IBD(""PRESCRIPTION"")) I 'IBRXN S IBY=""0^No Rx IEN"" G REVQ"
^XMB(3.9,144657,2,10193,0)="""RTN"",""IBNCPDP3"",39,0)"
^XMB(3.9,144657,2,10194,0)=" S IBFIL=+$G(IBD(""FILL NUMBER""),-1) I IBFIL<0 S IBY=""0^No fill number"" G REVQ"
