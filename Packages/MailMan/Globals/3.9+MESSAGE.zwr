^XMB(3.9,145831,2,917,0)="""RTN"",""EDPVIT"",26,0)"
^XMB(3.9,145831,2,918,0)=" S X=$G(^EDP(230,LOG,7)) I X D  ;schedule"
^XMB(3.9,145831,2,919,0)="""RTN"",""EDPVIT"",27,0)"
^XMB(3.9,145831,2,920,0)=" . K EDPX S EDPX(""frequency"")=$P(X,U),EDPX(""frequencyUnits"")=""mins"""
^XMB(3.9,145831,2,921,0)="""RTN"",""EDPVIT"",28,0)"
^XMB(3.9,145831,2,922,0)=" . ;S:$P(X,U,2) EDPX(""duration"")=$P(X,U,2),EDPX(""durationUnits"")=""mins"""
^XMB(3.9,145831,2,923,0)="""RTN"",""EDPVIT"",29,0)"
^XMB(3.9,145831,2,924,0)=" . S:$G(LAST) EDPX(""lastUpdated"")=LAST"
