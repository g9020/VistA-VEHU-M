^XMB(3.9,145834,2,7297,0)="""RTN"",""MAGDSTQ8"",151,0)"
^XMB(3.9,145834,2,7298,0)=" I CODE=""A801"" D  Q ""Failure"""
^XMB(3.9,145834,2,7299,0)="""RTN"",""MAGDSTQ8"",152,0)"
^XMB(3.9,145834,2,7300,0)=" . S MEANING=""Refused: Move Destination unknown"""
