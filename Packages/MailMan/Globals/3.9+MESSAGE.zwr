^XMB(3.9,145834,2,7244,0)=" ;"
^XMB(3.9,145834,2,7245,0)="""RTN"",""MAGDSTQ8"",125,0)"
^XMB(3.9,145834,2,7246,0)="DISPLAY(REDISPLAY) ; refresh the top of the screen"
^XMB(3.9,145834,2,7247,0)="""RTN"",""MAGDSTQ8"",126,0)"
^XMB(3.9,145834,2,7248,0)=" D DISPLAY^MAGDSTQ"
^XMB(3.9,145834,2,7249,0)="""RTN"",""MAGDSTQ8"",127,0)"
^XMB(3.9,145834,2,7250,0)=" W !!!"
^XMB(3.9,145834,2,7251,0)="""RTN"",""MAGDSTQ8"",128,0)"
^XMB(3.9,145834,2,7252,0)=" S REDISPLAY=0"
^XMB(3.9,145834,2,7253,0)="""RTN"",""MAGDSTQ8"",129,0)"
^XMB(3.9,145834,2,7254,0)=" Q"
^XMB(3.9,145834,2,7255,0)="""RTN"",""MAGDSTQ8"",130,0)"
^XMB(3.9,145834,2,7256,0)=" ;"
^XMB(3.9,145834,2,7257,0)="""RTN"",""MAGDSTQ8"",131,0)"
^XMB(3.9,145834,2,7258,0)="STATUS(CODE,MEANING) ; return status codes"
^XMB(3.9,145834,2,7259,0)="""RTN"",""MAGDSTQ8"",132,0)"
^XMB(3.9,145834,2,7260,0)=" ; from Table C.4-2 C-MOVE Response Status Values PS3.4 2108b"
^XMB(3.9,145834,2,7261,0)="""RTN"",""MAGDSTQ8"",133,0)"
^XMB(3.9,145834,2,7262,0)=" I CODE=""FF00"" D  Q ""Pending"""
^XMB(3.9,145834,2,7263,0)="""RTN"",""MAGDSTQ8"",134,0)"
^XMB(3.9,145834,2,7264,0)=" . S MEANING=""Sub-operations are continuing"""
^XMB(3.9,145834,2,7265,0)="""RTN"",""MAGDSTQ8"",135,0)"
^XMB(3.9,145834,2,7266,0)=" . Q"
^XMB(3.9,145834,2,7267,0)="""RTN"",""MAGDSTQ8"",136,0)"
^XMB(3.9,145834,2,7268,0)=" I CODE=""FF01"" D  Q ""Pending"""
^XMB(3.9,145834,2,7269,0)="""RTN"",""MAGDSTQ8"",137,0)"
^XMB(3.9,145834,2,7270,0)=" . S MEANING=""Sub-operations are continuing but one or more Optional Keys were not supported"""
^XMB(3.9,145834,2,7271,0)="""RTN"",""MAGDSTQ8"",138,0)"
^XMB(3.9,145834,2,7272,0)=" . Q"
^XMB(3.9,145834,2,7273,0)="""RTN"",""MAGDSTQ8"",139,0)"
^XMB(3.9,145834,2,7274,0)=" I (CODE=""0000"")!(CODE=0) D  Q ""Success"""
^XMB(3.9,145834,2,7275,0)="""RTN"",""MAGDSTQ8"",140,0)"
^XMB(3.9,145834,2,7276,0)=" . S MEANING=""Sub-operations Complete - No Failures"""
^XMB(3.9,145834,2,7277,0)="""RTN"",""MAGDSTQ8"",141,0)"
^XMB(3.9,145834,2,7278,0)=" . Q"
^XMB(3.9,145834,2,7279,0)="""RTN"",""MAGDSTQ8"",142,0)"
^XMB(3.9,145834,2,7280,0)=" I CODE=""A700"" D  Q ""Failure"""
^XMB(3.9,145834,2,7281,0)="""RTN"",""MAGDSTQ8"",143,0)"
^XMB(3.9,145834,2,7282,0)=" . S MEANING=""Refused: Out of Resources"""
^XMB(3.9,145834,2,7283,0)="""RTN"",""MAGDSTQ8"",144,0)"
