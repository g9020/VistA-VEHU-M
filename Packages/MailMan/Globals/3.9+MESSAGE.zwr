^XMB(3.9,144657,2,7146,0)=" . ;"
^XMB(3.9,144657,2,7147,0)="""RTN"",""IBCNEUT2"",82,0)"
^XMB(3.9,144657,2,7148,0)=" . ;If foreign chars encountered clear field and continue with msg"
^XMB(3.9,144657,2,7149,0)="""RTN"",""IBCNEUT2"",83,0)"
