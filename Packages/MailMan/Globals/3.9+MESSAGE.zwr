^XMB(3.9,145833,2,2618,0)="STOPCODETOAMIS(STOPIEN) ; Map from Stop Code IEN to AMIS Stop Code Number"
^XMB(3.9,145833,2,2619,0)="""RTN"",""SDESUTIL"",256,0)"
^XMB(3.9,145833,2,2620,0)=" ;  Input: STOPIEN = (Req) The IEN of the Stop Code in the CLINIC STOP (#40.7) file."
^XMB(3.9,145833,2,2621,0)="""RTN"",""SDESUTIL"",257,0)"
