^XMB(3.9,145834,2,3776,0)=" . W !?18,""M12345678901N12345678901 (M=midnight, N=noon)"""
^XMB(3.9,145834,2,3777,0)="""RTN"",""MAGDSTA2"",196,0)"
^XMB(3.9,145834,2,3778,0)=" . W !,""Active hours are: "",DEFAULT"
^XMB(3.9,145834,2,3779,0)="""RTN"",""MAGDSTA2"",197,0)"
^XMB(3.9,145834,2,3780,0)=" . W !?15,""// "" R X:DTIME E  S OK=-1 Q"
^XMB(3.9,145834,2,3781,0)="""RTN"",""MAGDSTA2"",198,0)"
^XMB(3.9,145834,2,3782,0)=" . I X[""^"" S OK=-1 Q"
^XMB(3.9,145834,2,3783,0)="""RTN"",""MAGDSTA2"",199,0)"
^XMB(3.9,145834,2,3784,0)=" . I X="""" S X=DEFAULT W X"
^XMB(3.9,145834,2,3785,0)="""RTN"",""MAGDSTA2"",200,0)"
^XMB(3.9,145834,2,3786,0)=" . S X=$TR(X,""yn"",""YN"")"
^XMB(3.9,145834,2,3787,0)="""RTN"",""MAGDSTA2"",201,0)"
^XMB(3.9,145834,2,3788,0)=" . I $TR(X,""YN"")="""" D"
^XMB(3.9,145834,2,3789,0)="""RTN"",""MAGDSTA2"",202,0)"
^XMB(3.9,145834,2,3790,0)=" . . S X=$E(X_FULLDAY,1,24)"
^XMB(3.9,145834,2,3791,0)="""RTN"",""MAGDSTA2"",203,0)"
^XMB(3.9,145834,2,3792,0)=" . . S OK=1"
^XMB(3.9,145834,2,3793,0)="""RTN"",""MAGDSTA2"",204,0)"
^XMB(3.9,145834,2,3794,0)=" . . S ^TMP(""MAG"",$J,""BATCH Q/R"",""HOURS OF OPERATION"")=X"
^XMB(3.9,145834,2,3795,0)="""RTN"",""MAGDSTA2"",205,0)"
^XMB(3.9,145834,2,3796,0)=" . . W "" -- changed"""
^XMB(3.9,145834,2,3797,0)="""RTN"",""MAGDSTA2"",206,0)"
^XMB(3.9,145834,2,3798,0)=" . . Q"
^XMB(3.9,145834,2,3799,0)="""RTN"",""MAGDSTA2"",207,0)"
^XMB(3.9,145834,2,3800,0)=" . E  D"
^XMB(3.9,145834,2,3801,0)="""RTN"",""MAGDSTA2"",208,0)"
^XMB(3.9,145834,2,3802,0)=" . . W !,?18 F I=1:1:24 S Z=$E(X,I) W $S(""YN""'[Z:""^"",1:"" "")"
^XMB(3.9,145834,2,3803,0)="""RTN"",""MAGDSTA2"",209,0)"
^XMB(3.9,145834,2,3804,0)=" . . W !!,""Enter a sequence of (up to) 24 """"Y's"""" and """"N's""""."""
^XMB(3.9,145834,2,3805,0)="""RTN"",""MAGDSTA2"",210,0)"
^XMB(3.9,145834,2,3806,0)=" . . W !,""Every """"Y"""" represents an hour when DICOM Query/Retrieve will be active."""
^XMB(3.9,145834,2,3807,0)="""RTN"",""MAGDSTA2"",211,0)"
^XMB(3.9,145834,2,3808,0)=" . . W !,""Every """"N"""" represents an hour when DICOM Query/Retrieve will not be active."",!"
^XMB(3.9,145834,2,3809,0)="""RTN"",""MAGDSTA2"",212,0)"
^XMB(3.9,145834,2,3810,0)=" . . Q"
^XMB(3.9,145834,2,3811,0)="""RTN"",""MAGDSTA2"",213,0)"
^XMB(3.9,145834,2,3812,0)=" . Q"
^XMB(3.9,145834,2,3813,0)="""RTN"",""MAGDSTA2"",214,0)"
^XMB(3.9,145834,2,3814,0)=" I OK=-1 S QUIT=1"
^XMB(3.9,145834,2,3815,0)="""RTN"",""MAGDSTA2"",215,0)"
^XMB(3.9,145834,2,3816,0)=" Q"
^XMB(3.9,145834,2,3817,0)="""RTN"",""MAGDSTA2"",216,0)"
^XMB(3.9,145834,2,3818,0)=" ;"
^XMB(3.9,145834,2,3819,0)="""RTN"",""MAGDSTA2"",217,0)"
^XMB(3.9,145834,2,3820,0)="ACNUM ; get the accession number"
^XMB(3.9,145834,2,3821,0)="""RTN"",""MAGDSTA2"",218,0)"
^XMB(3.9,145834,2,3822,0)=" N GMRCIEN,HOURS,OK,RADPT1,RADPT2,RADPT3,RARPT1,RUNNUMBER,X,Y,Z,ZTDESC"
^XMB(3.9,145834,2,3823,0)="""RTN"",""MAGDSTA2"",219,0)"
^XMB(3.9,145834,2,3824,0)=" S HOURS=""YYYYYYYYYYYYYYYYYYYYYYYY"""
^XMB(3.9,145834,2,3825,0)="""RTN"",""MAGDSTA2"",220,0)"
^XMB(3.9,145834,2,3826,0)=" S RUNNUMBER=0 ; not interested in this"
^XMB(3.9,145834,2,3827,0)="""RTN"",""MAGDSTA2"",221,0)"
^XMB(3.9,145834,2,3828,0)=" S FIRSTTIME=1"
^XMB(3.9,145834,2,3829,0)="""RTN"",""MAGDSTA2"",222,0)"
^XMB(3.9,145834,2,3830,0)=" D TASKINIT^MAGDSTA1"
^XMB(3.9,145834,2,3831,0)="""RTN"",""MAGDSTA2"",223,0)"
^XMB(3.9,145834,2,3832,0)=" S X=MAGIOM X ^%ZOSF(""RM"") ; set right margin to 80 or 132"
^XMB(3.9,145834,2,3833,0)="""RTN"",""MAGDSTA2"",224,0)"
^XMB(3.9,145834,2,3834,0)=" S OK=0  F  D  Q:OK"
^XMB(3.9,145834,2,3835,0)="""RTN"",""MAGDSTA2"",225,0)"
^XMB(3.9,145834,2,3836,0)=" . I ^TMP(""MAG"",$J,""BATCH Q/R"",""IMAGING SERVICE"")=""RADIOLOGY"" D"
^XMB(3.9,145834,2,3837,0)="""RTN"",""MAGDSTA2"",226,0)"
^XMB(3.9,145834,2,3838,0)=" . . S OK=$$ACNUMRAD"
^XMB(3.9,145834,2,3839,0)="""RTN"",""MAGDSTA2"",227,0)"
^XMB(3.9,145834,2,3840,0)=" . . Q"
^XMB(3.9,145834,2,3841,0)="""RTN"",""MAGDSTA2"",228,0)"
^XMB(3.9,145834,2,3842,0)=" . E  D  ; consults"
^XMB(3.9,145834,2,3843,0)="""RTN"",""MAGDSTA2"",229,0)"
^XMB(3.9,145834,2,3844,0)=" . . S OK=$$ACNUMCON"
^XMB(3.9,145834,2,3845,0)="""RTN"",""MAGDSTA2"",230,0)"
^XMB(3.9,145834,2,3846,0)=" . . K ^TMP(""MAG"",$J,""BATCH Q/R"",""CONSULT SERVICES"") ; remove old ones"
^XMB(3.9,145834,2,3847,0)="""RTN"",""MAGDSTA2"",231,0)"
^XMB(3.9,145834,2,3848,0)=" . . Q"
^XMB(3.9,145834,2,3849,0)="""RTN"",""MAGDSTA2"",232,0)"
^XMB(3.9,145834,2,3850,0)=" . Q"
^XMB(3.9,145834,2,3851,0)="""RTN"",""MAGDSTA2"",233,0)"
^XMB(3.9,145834,2,3852,0)=" Q"
^XMB(3.9,145834,2,3853,0)="""RTN"",""MAGDSTA2"",234,0)"
^XMB(3.9,145834,2,3854,0)=" ;"
^XMB(3.9,145834,2,3855,0)="""RTN"",""MAGDSTA2"",235,0)"
^XMB(3.9,145834,2,3856,0)="ACNUMRAD() ; get and process a radiology study"
^XMB(3.9,145834,2,3857,0)="""RTN"",""MAGDSTA2"",236,0)"
^XMB(3.9,145834,2,3858,0)=" W !!!!,""Enter the accession number: """
^XMB(3.9,145834,2,3859,0)="""RTN"",""MAGDSTA2"",237,0)"
^XMB(3.9,145834,2,3860,0)=" R X:DTIME E  Q -1"
^XMB(3.9,145834,2,3861,0)="""RTN"",""MAGDSTA2"",238,0)"
^XMB(3.9,145834,2,3862,0)=" I ""^""[X Q -1"
^XMB(3.9,145834,2,3863,0)="""RTN"",""MAGDSTA2"",239,0)"
^XMB(3.9,145834,2,3864,0)=" I X?1""?"".E D  Q 0"
^XMB(3.9,145834,2,3865,0)="""RTN"",""MAGDSTA2"",240,0)"
^XMB(3.9,145834,2,3866,0)=" . W !,""Enter either the site-specific accession number (sss-MMDDYY-nnnn),"""
^XMB(3.9,145834,2,3867,0)="""RTN"",""MAGDSTA2"",241,0)"
^XMB(3.9,145834,2,3868,0)=" . W !,""or just the legacy accession number (MMDDYY-nnnn) portion."""
^XMB(3.9,145834,2,3869,0)="""RTN"",""MAGDSTA2"",242,0)"
^XMB(3.9,145834,2,3870,0)=" . Q"
^XMB(3.9,145834,2,3871,0)="""RTN"",""MAGDSTA2"",243,0)"
^XMB(3.9,145834,2,3872,0)=" S X=$$ACCFIND^RAAPI(X,.RAA)"
^XMB(3.9,145834,2,3873,0)="""RTN"",""MAGDSTA2"",244,0)"
^XMB(3.9,145834,2,3874,0)=" I X'=1 D  Q 0"
^XMB(3.9,145834,2,3875,0)="""RTN"",""MAGDSTA2"",245,0)"
^XMB(3.9,145834,2,3876,0)=" . W "" ??? not on file"""
^XMB(3.9,145834,2,3877,0)="""RTN"",""MAGDSTA2"",246,0)"
^XMB(3.9,145834,2,3878,0)=" . Q"
^XMB(3.9,145834,2,3879,0)="""RTN"",""MAGDSTA2"",247,0)"
^XMB(3.9,145834,2,3880,0)=" S RADPT1=$P(RAA(1),""^"",1),RADPT2=$P(RAA(1),""^"",2),RADPT3=$P(RAA(1),""^"",3)"
^XMB(3.9,145834,2,3881,0)="""RTN"",""MAGDSTA2"",248,0)"
^XMB(3.9,145834,2,3882,0)=" S Y=$G(^RADPT(RADPT1,""DT"",RADPT2,""P"",RADPT3,0))"
^XMB(3.9,145834,2,3883,0)="""RTN"",""MAGDSTA2"",249,0)"
^XMB(3.9,145834,2,3884,0)=" S RARPT1=$P(Y,""^"",17) ; REPORT TEXT"
^XMB(3.9,145834,2,3885,0)="""RTN"",""MAGDSTA2"",250,0)"
^XMB(3.9,145834,2,3886,0)=" D HEADER^MAGDSTAA(0,0)"
^XMB(3.9,145834,2,3887,0)="""RTN"",""MAGDSTA2"",251,0)"
^XMB(3.9,145834,2,3888,0)=" S Z=$$RADLKUP1^MAGDSTA5(RARPT1)"
^XMB(3.9,145834,2,3889,0)="""RTN"",""MAGDSTA2"",252,0)"
^XMB(3.9,145834,2,3890,0)=" Q 0"
^XMB(3.9,145834,2,3891,0)="""RTN"",""MAGDSTA2"",253,0)"
^XMB(3.9,145834,2,3892,0)=" ;"
^XMB(3.9,145834,2,3893,0)="""RTN"",""MAGDSTA2"",254,0)"
^XMB(3.9,145834,2,3894,0)="ACNUMCON() ; get and process a consult study"
^XMB(3.9,145834,2,3895,0)="""RTN"",""MAGDSTA2"",255,0)"
^XMB(3.9,145834,2,3896,0)=" N CONSULTSERVICES,LIST,PICK,SERVICE,SERVICENAME"
^XMB(3.9,145834,2,3897,0)="""RTN"",""MAGDSTA2"",256,0)"
^XMB(3.9,145834,2,3898,0)=" ;"
^XMB(3.9,145834,2,3899,0)="""RTN"",""MAGDSTA2"",257,0)"
^XMB(3.9,145834,2,3900,0)=" ; build the list of all consult services"
^XMB(3.9,145834,2,3901,0)="""RTN"",""MAGDSTA2"",258,0)"
^XMB(3.9,145834,2,3902,0)=" S SERVICE="""""
^XMB(3.9,145834,2,3903,0)="""RTN"",""MAGDSTA2"",259,0)"
^XMB(3.9,145834,2,3904,0)=" F I=1:1 S SERVICE=$O(^MAG(2006.5831,""B"",SERVICE)) Q:'SERVICE  D"
^XMB(3.9,145834,2,3905,0)="""RTN"",""MAGDSTA2"",260,0)"
^XMB(3.9,145834,2,3906,0)=" . S SERVICENAME=$$GET1^DIQ(123.5,SERVICE,.01,""E"")"
^XMB(3.9,145834,2,3907,0)="""RTN"",""MAGDSTA2"",261,0)"
^XMB(3.9,145834,2,3908,0)=" . S LIST(I)=SERVICENAME_""^""_SERVICE,PICK(I)=1"
^XMB(3.9,145834,2,3909,0)="""RTN"",""MAGDSTA2"",262,0)"
^XMB(3.9,145834,2,3910,0)=" . Q"
^XMB(3.9,145834,2,3911,0)="""RTN"",""MAGDSTA2"",263,0)"
^XMB(3.9,145834,2,3912,0)=" D SERVICE4^MAGDSTA8(.CONSULTSERVICES,""YES"",.LIST,.PICK)"
^XMB(3.9,145834,2,3913,0)="""RTN"",""MAGDSTA2"",264,0)"
^XMB(3.9,145834,2,3914,0)=" K ^TMP(""MAG"",$J,""BATCH Q/R"",""CONSULT SERVICES"") ; remove old ones"
^XMB(3.9,145834,2,3915,0)="""RTN"",""MAGDSTA2"",265,0)"
^XMB(3.9,145834,2,3916,0)=" M ^TMP(""MAG"",$J,""BATCH Q/R"",""CONSULT SERVICES"")=CONSULTSERVICES"
^XMB(3.9,145834,2,3917,0)="""RTN"",""MAGDSTA2"",266,0)"
^XMB(3.9,145834,2,3918,0)=" ;"
^XMB(3.9,145834,2,3919,0)="""RTN"",""MAGDSTA2"",267,0)"
^XMB(3.9,145834,2,3920,0)=" W !!!!,""Enter the accession number: """
^XMB(3.9,145834,2,3921,0)="""RTN"",""MAGDSTA2"",268,0)"
^XMB(3.9,145834,2,3922,0)=" R X:DTIME E  Q -1"
^XMB(3.9,145834,2,3923,0)="""RTN"",""MAGDSTA2"",269,0)"
^XMB(3.9,145834,2,3924,0)=" I ""^""[X Q -1"
^XMB(3.9,145834,2,3925,0)="""RTN"",""MAGDSTA2"",270,0)"
^XMB(3.9,145834,2,3926,0)=" I X?1""?"".E D  Q 0"
^XMB(3.9,145834,2,3927,0)="""RTN"",""MAGDSTA2"",271,0)"
^XMB(3.9,145834,2,3928,0)=" . W !,""The consult accession number has two formats: """"sss-GMR-nnnn"""" and """"GMRC-nnnn""""."""
^XMB(3.9,145834,2,3929,0)="""RTN"",""MAGDSTA2"",272,0)"
^XMB(3.9,145834,2,3930,0)=" . W !,""Enter the accession number or just the digits following the """"GMR-"""" or """"GMRC-""""."""
^XMB(3.9,145834,2,3931,0)="""RTN"",""MAGDSTA2"",273,0)"
^XMB(3.9,145834,2,3932,0)=" . Q"
^XMB(3.9,145834,2,3933,0)="""RTN"",""MAGDSTA2"",274,0)"
^XMB(3.9,145834,2,3934,0)=" S GMRCIEN=$P(X,""-"",$L(X,""-""))"
^XMB(3.9,145834,2,3935,0)="""RTN"",""MAGDSTA2"",275,0)"
^XMB(3.9,145834,2,3936,0)=" I '$D(^GMR(123,GMRCIEN)) D  Q 0"
^XMB(3.9,145834,2,3937,0)="""RTN"",""MAGDSTA2"",276,0)"
^XMB(3.9,145834,2,3938,0)=" . W "" ??? not on file"""
^XMB(3.9,145834,2,3939,0)="""RTN"",""MAGDSTA2"",277,0)"
^XMB(3.9,145834,2,3940,0)=" . Q"
^XMB(3.9,145834,2,3941,0)="""RTN"",""MAGDSTA2"",278,0)"
^XMB(3.9,145834,2,3942,0)=" D HEADER^MAGDSTAA(0,0)"
^XMB(3.9,145834,2,3943,0)="""RTN"",""MAGDSTA2"",279,0)"
^XMB(3.9,145834,2,3944,0)=" S Z=$$CONLKUP1^MAGDSTA7(GMRCIEN)"
^XMB(3.9,145834,2,3945,0)="""RTN"",""MAGDSTA2"",280,0)"
^XMB(3.9,145834,2,3946,0)=" Q 0"
^XMB(3.9,145834,2,3947,0)="""RTN"",""MAGDSTA5"")"
^XMB(3.9,145834,2,3948,0)="0^7^B25524370"
