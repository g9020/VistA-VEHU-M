^XMB(3.9,145834,2,6433,0)="""RTN"",""MAGDSTAS"",106,0)"
^XMB(3.9,145834,2,6434,0)=" . I '$D(^TMP(""MAG"",$J,""BATCH Q/R"",""DATE"")) D"
^XMB(3.9,145834,2,6435,0)="""RTN"",""MAGDSTAS"",107,0)"
^XMB(3.9,145834,2,6436,0)=" . . W !,""The DATE scan has been run for the entire date interval from "",$$HTE^XLFDT(HDATE1),"" to today."""
