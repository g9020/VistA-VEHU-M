^XMB(3.9,144657,2,6954,0)="CODECK(VAL) ; validate the response for the output transforms on the CODE (.01) field in the IIV Status Table (#365.15) file."
^XMB(3.9,144657,2,6955,0)="""RTN"",""IBCNEUT1"",227,0)"
^XMB(3.9,144657,2,6956,0)=" ; VAL - value to translate"
^XMB(3.9,144657,2,6957,0)="""RTN"",""IBCNEUT1"",228,0)"
^XMB(3.9,144657,2,6958,0)=" ; OUT - output value based up the value entered."
^XMB(3.9,144657,2,6959,0)="""RTN"",""IBCNEUT1"",229,0)"
^XMB(3.9,144657,2,6960,0)=" ;"
^XMB(3.9,144657,2,6961,0)="""RTN"",""IBCNEUT1"",230,0)"
^XMB(3.9,144657,2,6962,0)=" N IN,OUT,STR1,STR2,IP,AP"
^XMB(3.9,144657,2,6963,0)="""RTN"",""IBCNEUT1"",231,0)"
^XMB(3.9,144657,2,6964,0)=" S IN=$E(VAL)"
^XMB(3.9,144657,2,6965,0)="""RTN"",""IBCNEUT1"",232,0)"
^XMB(3.9,144657,2,6966,0)=" S STR1=""Response Received"""
^XMB(3.9,144657,2,6967,0)="""RTN"",""IBCNEUT1"",233,0)"
^XMB(3.9,144657,2,6968,0)=" S STR2=""Problem Identified"""
^XMB(3.9,144657,2,6969,0)="""RTN"",""IBCNEUT1"",234,0)"
^XMB(3.9,144657,2,6970,0)=" S IP=""Inactive Policy"""
^XMB(3.9,144657,2,6971,0)="""RTN"",""IBCNEUT1"",235,0)"
^XMB(3.9,144657,2,6972,0)=" S AP=""Active Policy"""
^XMB(3.9,144657,2,6973,0)="""RTN"",""IBCNEUT1"",236,0)"
^XMB(3.9,144657,2,6974,0)=" ; IB*2*601/DM added IN=""M"""
^XMB(3.9,144657,2,6975,0)="""RTN"",""IBCNEUT1"",237,0)"
^XMB(3.9,144657,2,6976,0)=" S OUT=$S(IN=""D"":STR1_"", ""_IP,IN=""B"":STR2,IN=""A"":STR1_"", ""_AP,IN=""E"":STR1_"", ""_AP_"" (Escalated)"",IN=""Q"":""Inquiry Sent, Awaiting Response"",IN=""U"":STR1_"", Ambiguous Answer"",IN=""C"":STR2_"", Communication Failure"",IN=""M"":STR1_"", MBI Received"",1:"""")"
^XMB(3.9,144657,2,6977,0)="""RTN"",""IBCNEUT1"",238,0)"
^XMB(3.9,144657,2,6978,0)="CODECKX ;"
^XMB(3.9,144657,2,6979,0)="""RTN"",""IBCNEUT1"",239,0)"
