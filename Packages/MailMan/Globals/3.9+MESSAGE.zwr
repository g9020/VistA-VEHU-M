^XMB(3.9,144657,2,5175,0)="""RTN"",""IBCNEQU"",234,0)"
^XMB(3.9,144657,2,5176,0)=" S DIR(0)=""Y"""
^XMB(3.9,144657,2,5177,0)="""RTN"",""IBCNEQU"",235,0)"
^XMB(3.9,144657,2,5178,0)=" S DIR(""A"")=""Are you sure you want to request an insurance inquiry"""
^XMB(3.9,144657,2,5179,0)="""RTN"",""IBCNEQU"",236,0)"
