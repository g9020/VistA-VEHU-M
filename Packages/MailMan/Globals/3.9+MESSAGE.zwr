^XMB(3.9,144653,2,732,0)=" I $P(XQY0,""^"")=""PSO LM BACKDOOR ORDERS""!($P(XQY0,""^"")=""PSO LMOE FINISH"")!($P(XQY0,""^"")=""PSO PMP""),$P(VALMKEY,""^"",2)=""PSO HIDDEN ACTIONS #3""!($P(VALMKEY,""^"",2)=""PSO HIDDEN ACTIONS #4""),$G(ORD) Q +$$GET1^DIQ(52.41,+ORD,.01)"
