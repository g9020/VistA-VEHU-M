^XMB(3.9,144657,2,10513,0)="""RTN"",""IBNCPDP3"",199,0)"
^XMB(3.9,144657,2,10514,0)=" S BUFF(355.33,BUDA,20.02)=$$GET1^DIQ(36,ICDA,.131,""I"")"
^XMB(3.9,144657,2,10515,0)="""RTN"",""IBNCPDP3"",200,0)"
^XMB(3.9,144657,2,10516,0)=" S BUFF(355.33,BUDA,20.05)=$$GET1^DIQ(36,ICDA,1,""I"")"
^XMB(3.9,144657,2,10517,0)="""RTN"",""IBNCPDP3"",201,0)"
^XMB(3.9,144657,2,10518,0)=" S BUFF(355.33,BUDA,21.01)=$$GET1^DIQ(36,ICDA,.111,""I"")"
^XMB(3.9,144657,2,10519,0)="""RTN"",""IBNCPDP3"",202,0)"
^XMB(3.9,144657,2,10520,0)=" S BUFF(355.33,BUDA,21.02)=$$GET1^DIQ(36,ICDA,.112,""I"")"
^XMB(3.9,144657,2,10521,0)="""RTN"",""IBNCPDP3"",203,0)"
^XMB(3.9,144657,2,10522,0)=" S BUFF(355.33,BUDA,21.03)=$$GET1^DIQ(36,ICDA,.113,""I"")"
^XMB(3.9,144657,2,10523,0)="""RTN"",""IBNCPDP3"",204,0)"
^XMB(3.9,144657,2,10524,0)=" S BUFF(355.33,BUDA,21.04)=$$GET1^DIQ(36,ICDA,.114,""I"")"
^XMB(3.9,144657,2,10525,0)="""RTN"",""IBNCPDP3"",205,0)"
^XMB(3.9,144657,2,10526,0)=" S BUFF(355.33,BUDA,21.05)=$$GET1^DIQ(36,ICDA,.115,""I"")"
^XMB(3.9,144657,2,10527,0)="""RTN"",""IBNCPDP3"",206,0)"
^XMB(3.9,144657,2,10528,0)=" S BUFF(355.33,BUDA,21.06)=$$GET1^DIQ(36,ICDA,.116,""I"")"
^XMB(3.9,144657,2,10529,0)="""RTN"",""IBNCPDP3"",207,0)"
^XMB(3.9,144657,2,10530,0)=" ;"
^XMB(3.9,144657,2,10531,0)="""RTN"",""IBNCPDP3"",208,0)"
^XMB(3.9,144657,2,10532,0)=" ; update buffer entry with some additional information"
^XMB(3.9,144657,2,10533,0)="""RTN"",""IBNCPDP3"",209,0)"
^XMB(3.9,144657,2,10534,0)=" S BUFF(355.33,BUDA,.03)=EPHSRC      ; source of info"
^XMB(3.9,144657,2,10535,0)="""RTN"",""IBNCPDP3"",210,0)"
^XMB(3.9,144657,2,10536,0)=" S BUFF(355.33,BUDA,.12)=""""          ; make sure eIV related fields are blank"
^XMB(3.9,144657,2,10537,0)="""RTN"",""IBNCPDP3"",211,0)"
^XMB(3.9,144657,2,10538,0)=" S BUFF(355.33,BUDA,.13)="""""
^XMB(3.9,144657,2,10539,0)="""RTN"",""IBNCPDP3"",212,0)"
^XMB(3.9,144657,2,10540,0)=" S BUFF(355.33,BUDA,.14)="""""
^XMB(3.9,144657,2,10541,0)="""RTN"",""IBNCPDP3"",213,0)"
^XMB(3.9,144657,2,10542,0)=" S BUFF(355.33,BUDA,.15)="""""
^XMB(3.9,144657,2,10543,0)="""RTN"",""IBNCPDP3"",214,0)"
^XMB(3.9,144657,2,10544,0)=" S BUFF(355.33,BUDA,.17)=BPRIEN      ; BPS response file ien"
^XMB(3.9,144657,2,10545,0)="""RTN"",""IBNCPDP3"",215,0)"
^XMB(3.9,144657,2,10546,0)=" ;"
^XMB(3.9,144657,2,10547,0)="""RTN"",""IBNCPDP3"",216,0)"
^XMB(3.9,144657,2,10548,0)=" ; update buffer entry with data pulled from BPS response file"
^XMB(3.9,144657,2,10549,0)="""RTN"",""IBNCPDP3"",217,0)"
^XMB(3.9,144657,2,10550,0)=" ; only 2 fields are applicable here:  group# and cardholder ID"
^XMB(3.9,144657,2,10551,0)="""RTN"",""IBNCPDP3"",218,0)"
^XMB(3.9,144657,2,10552,0)=" ;"
^XMB(3.9,144657,2,10553,0)="""RTN"",""IBNCPDP3"",219,0)"
^XMB(3.9,144657,2,10554,0)=" S BPRSUB=$G(BPSR(9002313.03,ZR,302,""E""))         ; subscriber/cardholder ID"
^XMB(3.9,144657,2,10555,0)="""RTN"",""IBNCPDP3"",220,0)"
^XMB(3.9,144657,2,10556,0)=" ;I BPRSUB'="""" S BUFF(355.33,BUDA,60.04)=BPRSUB    ; update buffer if field exists"
^XMB(3.9,144657,2,10557,0)="""RTN"",""IBNCPDP3"",221,0)"
^XMB(3.9,144657,2,10558,0)=" I BPRSUB'="""" S BUFF(355.33,BUDA,90.03)=BPRSUB    ; update new field - 516 - baa"
^XMB(3.9,144657,2,10559,0)="""RTN"",""IBNCPDP3"",222,0)"
^XMB(3.9,144657,2,10560,0)=" ;"
^XMB(3.9,144657,2,10561,0)="""RTN"",""IBNCPDP3"",223,0)"
^XMB(3.9,144657,2,10562,0)=" S BPRGRP=$G(BPSR(9002313.03,ZR,301,""E""))         ; group number"
^XMB(3.9,144657,2,10563,0)="""RTN"",""IBNCPDP3"",224,0)"
^XMB(3.9,144657,2,10564,0)=" ;I BPRGRP'="""" S BUFF(355.33,BUDA,40.03)=BPRGRP    ; update buffer if field exists"
^XMB(3.9,144657,2,10565,0)="""RTN"",""IBNCPDP3"",225,0)"
^XMB(3.9,144657,2,10566,0)=" I BPRGRP'="""" S BUFF(355.33,BUDA,90.02)=BPRGRP    ; update new field - 516 - baa"
^XMB(3.9,144657,2,10567,0)="""RTN"",""IBNCPDP3"",226,0)"
^XMB(3.9,144657,2,10568,0)=" ;"
^XMB(3.9,144657,2,10569,0)="""RTN"",""IBNCPDP3"",227,0)"
^XMB(3.9,144657,2,10570,0)=" D FILE^DIE(,""BUFF"")"
^XMB(3.9,144657,2,10571,0)="""RTN"",""IBNCPDP3"",228,0)"
^XMB(3.9,144657,2,10572,0)=" ;"
^XMB(3.9,144657,2,10573,0)="""RTN"",""IBNCPDP3"",229,0)"
^XMB(3.9,144657,2,10574,0)=" S IBRES=1  ; all good"
^XMB(3.9,144657,2,10575,0)="""RTN"",""IBNCPDP3"",230,0)"
^XMB(3.9,144657,2,10576,0)=" ;"
^XMB(3.9,144657,2,10577,0)="""RTN"",""IBNCPDP3"",231,0)"
^XMB(3.9,144657,2,10578,0)="ELIGX ;"
^XMB(3.9,144657,2,10579,0)="""RTN"",""IBNCPDP3"",232,0)"
^XMB(3.9,144657,2,10580,0)=" Q IBRES"
^XMB(3.9,144657,2,10581,0)="""RTN"",""IBNCPDP3"",233,0)"
^XMB(3.9,144657,2,10582,0)=" ;"
^XMB(3.9,144657,2,10583,0)="""RTN"",""IBNCPDP3"",234,0)"
^XMB(3.9,144657,2,10584,0)=" ;IBNCPDP3"
^XMB(3.9,144657,2,10585,0)="""RTN"",""IBNCPIV"")"
^XMB(3.9,144657,2,10586,0)="0^14^B54224856"
^XMB(3.9,144657,2,10587,0)="""RTN"",""IBNCPIV"",1,0)"
^XMB(3.9,144657,2,10588,0)="IBNCPIV ;ALB/ESG - Manual Rx Eligibility Verification ;23-SEP-2010"
^XMB(3.9,144657,2,10589,0)="""RTN"",""IBNCPIV"",2,0)"
^XMB(3.9,144657,2,10590,0)=" ;;2.0;INTEGRATED BILLING;**435,452**;21-MAR-94;Build 0"
^XMB(3.9,144657,2,10591,0)="""RTN"",""IBNCPIV"",3,0)"
^XMB(3.9,144657,2,10592,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,144657,2,10593,0)="""RTN"",""IBNCPIV"",4,0)"
^XMB(3.9,144657,2,10594,0)=" ;"
^XMB(3.9,144657,2,10595,0)="""RTN"",""IBNCPIV"",5,0)"
^XMB(3.9,144657,2,10596,0)=" ; Reference to EN^BPSNCPD9 supported by IA# 5576"
^XMB(3.9,144657,2,10597,0)="""RTN"",""IBNCPIV"",6,0)"
^XMB(3.9,144657,2,10598,0)=" ; Reference to PID^VADPT6 supported by IA# 10062"
^XMB(3.9,144657,2,10599,0)="""RTN"",""IBNCPIV"",7,0)"
^XMB(3.9,144657,2,10600,0)=" ; Reference to DT^DICRW supported by IA# 10005"
^XMB(3.9,144657,2,10601,0)="""RTN"",""IBNCPIV"",8,0)"
^XMB(3.9,144657,2,10602,0)=" ;"
^XMB(3.9,144657,2,10603,0)="""RTN"",""IBNCPIV"",9,0)"
^XMB(3.9,144657,2,10604,0)=" Q"
^XMB(3.9,144657,2,10605,0)="""RTN"",""IBNCPIV"",10,0)"
^XMB(3.9,144657,2,10606,0)=" ;"
^XMB(3.9,144657,2,10607,0)="""RTN"",""IBNCPIV"",11,0)"
^XMB(3.9,144657,2,10608,0)="EN ; -- main entry point for IBNCPDP INS ELIG VER INQ"
^XMB(3.9,144657,2,10609,0)="""RTN"",""IBNCPIV"",12,0)"
^XMB(3.9,144657,2,10610,0)=" N IBNCPIVD,DFN"
^XMB(3.9,144657,2,10611,0)="""RTN"",""IBNCPIV"",13,0)"
^XMB(3.9,144657,2,10612,0)=" D DT^DICRW"
^XMB(3.9,144657,2,10613,0)="""RTN"",""IBNCPIV"",14,0)"
^XMB(3.9,144657,2,10614,0)=" S IBNCPIVD=DT      ; first time in compile Active Rx ins as of today"
^XMB(3.9,144657,2,10615,0)="""RTN"",""IBNCPIV"",15,0)"
^XMB(3.9,144657,2,10616,0)=" D EN^VALM(""IBNCPDP INS ELIG VER INQ"")"
^XMB(3.9,144657,2,10617,0)="""RTN"",""IBNCPIV"",16,0)"
^XMB(3.9,144657,2,10618,0)=" Q"
^XMB(3.9,144657,2,10619,0)="""RTN"",""IBNCPIV"",17,0)"
^XMB(3.9,144657,2,10620,0)=" ;"
^XMB(3.9,144657,2,10621,0)="""RTN"",""IBNCPIV"",18,0)"
^XMB(3.9,144657,2,10622,0)="HDR ; -- header code"
^XMB(3.9,144657,2,10623,0)="""RTN"",""IBNCPIV"",19,0)"
^XMB(3.9,144657,2,10624,0)=" N VA,NAME"
^XMB(3.9,144657,2,10625,0)="""RTN"",""IBNCPIV"",20,0)"
^XMB(3.9,144657,2,10626,0)=" D PID^VADPT6"
^XMB(3.9,144657,2,10627,0)="""RTN"",""IBNCPIV"",21,0)"
^XMB(3.9,144657,2,10628,0)=" S NAME=$P($G(^DPT($G(DFN),0)),U,1)"
^XMB(3.9,144657,2,10629,0)="""RTN"",""IBNCPIV"",22,0)"
^XMB(3.9,144657,2,10630,0)=" S VALMHDR(1)=""Perform Rx Eligibility Insurance Inquiry"""
^XMB(3.9,144657,2,10631,0)="""RTN"",""IBNCPIV"",23,0)"
^XMB(3.9,144657,2,10632,0)=" S VALMHDR(2)=""   Patient: ""_$E(NAME,1,20)_""  (""_$E(NAME)_$G(VA(""BID""))_"")"""
^XMB(3.9,144657,2,10633,0)="""RTN"",""IBNCPIV"",24,0)"
^XMB(3.9,144657,2,10634,0)=" S VALMHDR(3)=""   Showing: All Insurance Policies on File"""
^XMB(3.9,144657,2,10635,0)="""RTN"",""IBNCPIV"",25,0)"
^XMB(3.9,144657,2,10636,0)=" I $G(IBNCPIVD) S VALMHDR(3)=""   Showing: Active Rx Policies as of Effective Date ""_$$FMTE^XLFDT(IBNCPIVD,""2Z"")"
^XMB(3.9,144657,2,10637,0)="""RTN"",""IBNCPIV"",26,0)"
^XMB(3.9,144657,2,10638,0)=" S VALMHDR(4)="" """
^XMB(3.9,144657,2,10639,0)="""RTN"",""IBNCPIV"",27,0)"
^XMB(3.9,144657,2,10640,0)=" I +$$BUFFER^IBCNBU1($G(DFN)) S VALMHDR(4)=""    Buffer: *** Patient has Insurance Buffer Records ***"""
^XMB(3.9,144657,2,10641,0)="""RTN"",""IBNCPIV"",28,0)"
^XMB(3.9,144657,2,10642,0)=" Q"
^XMB(3.9,144657,2,10643,0)="""RTN"",""IBNCPIV"",29,0)"
^XMB(3.9,144657,2,10644,0)=" ;"
^XMB(3.9,144657,2,10645,0)="""RTN"",""IBNCPIV"",30,0)"
^XMB(3.9,144657,2,10646,0)="INIT ; Build the list of valid insurance policies"
^XMB(3.9,144657,2,10647,0)="""RTN"",""IBNCPIV"",31,0)"
^XMB(3.9,144657,2,10648,0)=" D INIT^IBCNSM4"
^XMB(3.9,144657,2,10649,0)="""RTN"",""IBNCPIV"",32,0)"
^XMB(3.9,144657,2,10650,0)=" Q"
^XMB(3.9,144657,2,10651,0)="""RTN"",""IBNCPIV"",33,0)"
^XMB(3.9,144657,2,10652,0)=" ;"
^XMB(3.9,144657,2,10653,0)="""RTN"",""IBNCPIV"",34,0)"
^XMB(3.9,144657,2,10654,0)="HELP ; -- help code"
^XMB(3.9,144657,2,10655,0)="""RTN"",""IBNCPIV"",35,0)"
^XMB(3.9,144657,2,10656,0)=" S X=""?"" D DISP^XQORM1 W !!"
^XMB(3.9,144657,2,10657,0)="""RTN"",""IBNCPIV"",36,0)"
^XMB(3.9,144657,2,10658,0)=" Q"
^XMB(3.9,144657,2,10659,0)="""RTN"",""IBNCPIV"",37,0)"
^XMB(3.9,144657,2,10660,0)=" ;"
^XMB(3.9,144657,2,10661,0)="""RTN"",""IBNCPIV"",38,0)"
^XMB(3.9,144657,2,10662,0)="EXIT ; -- exit code"
^XMB(3.9,144657,2,10663,0)="""RTN"",""IBNCPIV"",39,0)"
^XMB(3.9,144657,2,10664,0)=" K ^TMP(""IBNSM"",$J),^TMP(""IBNSMDX"",$J)"
^XMB(3.9,144657,2,10665,0)="""RTN"",""IBNCPIV"",40,0)"
^XMB(3.9,144657,2,10666,0)=" D CLEAN^VALM10"
^XMB(3.9,144657,2,10667,0)="""RTN"",""IBNCPIV"",41,0)"
^XMB(3.9,144657,2,10668,0)=" Q"
^XMB(3.9,144657,2,10669,0)="""RTN"",""IBNCPIV"",42,0)"
^XMB(3.9,144657,2,10670,0)=" ;"
^XMB(3.9,144657,2,10671,0)="""RTN"",""IBNCPIV"",43,0)"
^XMB(3.9,144657,2,10672,0)="SEND ; send the ELIG inquiry"
^XMB(3.9,144657,2,10673,0)="""RTN"",""IBNCPIV"",44,0)"
^XMB(3.9,144657,2,10674,0)=" N VALMY,IBDATA,IBRES,IBX,IBY,IBPPOL,INSIEN,INSNM,GENERR,IBPL,IBCDFN,EPHPLAN,IBSTL,LIST,G,IBSTA,TXT,DEFDT"
^XMB(3.9,144657,2,10675,0)="""RTN"",""IBNCPIV"",45,0)"
^XMB(3.9,144657,2,10676,0)=" N X,Y,DIR,DTOUT,DUOUT,DIRUT,DIROUT,DIC,LOCKFLG,IBREL,IBPER"
^XMB(3.9,144657,2,10677,0)="""RTN"",""IBNCPIV"",46,0)"
^XMB(3.9,144657,2,10678,0)=" D FULL^VALM1"
^XMB(3.9,144657,2,10679,0)="""RTN"",""IBNCPIV"",47,0)"
^XMB(3.9,144657,2,10680,0)=" D EN^VALM2($G(XQORNOD(0)),""S"")    ; user selection - 1 entry from the list"
^XMB(3.9,144657,2,10681,0)="""RTN"",""IBNCPIV"",48,0)"
^XMB(3.9,144657,2,10682,0)=" I '$D(VALMY) G SENDX"
^XMB(3.9,144657,2,10683,0)="""RTN"",""IBNCPIV"",49,0)"
^XMB(3.9,144657,2,10684,0)=" S IBX=$O(VALMY(0)) I 'IBX G SENDX"
^XMB(3.9,144657,2,10685,0)="""RTN"",""IBNCPIV"",50,0)"
^XMB(3.9,144657,2,10686,0)=" S IBPPOL=$G(^TMP(""IBNSMDX"",$J,+$O(^TMP(""IBNSM"",$J,""IDX"",IBX,0))))"
^XMB(3.9,144657,2,10687,0)="""RTN"",""IBNCPIV"",51,0)"
^XMB(3.9,144657,2,10688,0)=" I IBPPOL="""" W !!,$T(+0)_"" - System error - policy data not found!"" D PAUSE^VALM1 G SENDX"
^XMB(3.9,144657,2,10689,0)="""RTN"",""IBNCPIV"",52,0)"
^XMB(3.9,144657,2,10690,0)=" S INSIEN=+$P(IBPPOL,U,5)                ; file 36 ien"
^XMB(3.9,144657,2,10691,0)="""RTN"",""IBNCPIV"",53,0)"
^XMB(3.9,144657,2,10692,0)=" S INSNM=$P($G(^DIC(36,INSIEN,0)),U,1)   ; ins company name"
^XMB(3.9,144657,2,10693,0)="""RTN"",""IBNCPIV"",54,0)"
^XMB(3.9,144657,2,10694,0)=" S GENERR=""Unable to submit Eligibility Verification Inquiry to ""_INSNM_""."""
^XMB(3.9,144657,2,10695,0)="""RTN"",""IBNCPIV"",55,0)"
^XMB(3.9,144657,2,10696,0)=" S IBPL=+$P(IBPPOL,U,22)                 ; plan file 355.3 ien"
^XMB(3.9,144657,2,10697,0)="""RTN"",""IBNCPIV"",56,0)"
^XMB(3.9,144657,2,10698,0)=" I 'IBPL W !!,GENERR,!,""This policy has no plan."" D PAUSE^VALM1 G SENDX"
^XMB(3.9,144657,2,10699,0)="""RTN"",""IBNCPIV"",57,0)"
^XMB(3.9,144657,2,10700,0)=" S IBDATA(""PLAN"")=IBPL                   ; plan file 355.3 ien"
^XMB(3.9,144657,2,10701,0)="""RTN"",""IBNCPIV"",58,0)"
^XMB(3.9,144657,2,10702,0)=" S IBCDFN=+$P(IBPPOL,U,4)                ; subfile 2.312 ien"
^XMB(3.9,144657,2,10703,0)="""RTN"",""IBNCPIV"",59,0)"
^XMB(3.9,144657,2,10704,0)=" ;"
^XMB(3.9,144657,2,10705,0)="""RTN"",""IBNCPIV"",60,0)"
^XMB(3.9,144657,2,10706,0)=" ; lock check"
^XMB(3.9,144657,2,10707,0)="""RTN"",""IBNCPIV"",61,0)"
^XMB(3.9,144657,2,10708,0)=" L +^IBDPTL(DFN,IBCDFN):$G(DILOCKTM,3)"
^XMB(3.9,144657,2,10709,0)="""RTN"",""IBNCPIV"",62,0)"
^XMB(3.9,144657,2,10710,0)=" E  W !!,GENERR,!,""Another user is currently processing the same patient and policy!"" D PAUSE^VALM1 G SENDX"
^XMB(3.9,144657,2,10711,0)="""RTN"",""IBNCPIV"",63,0)"
^XMB(3.9,144657,2,10712,0)=" S LOCKFLG=1"
^XMB(3.9,144657,2,10713,0)="""RTN"",""IBNCPIV"",64,0)"
^XMB(3.9,144657,2,10714,0)=" ;"
^XMB(3.9,144657,2,10715,0)="""RTN"",""IBNCPIV"",65,0)"
^XMB(3.9,144657,2,10716,0)=" S EPHPLAN=+$P($G(^IBA(355.3,IBPL,6)),U,1)   ; epharmacy plan ien"
^XMB(3.9,144657,2,10717,0)="""RTN"",""IBNCPIV"",66,0)"
^XMB(3.9,144657,2,10718,0)=" I 'EPHPLAN W !!,GENERR,!,""This policy's plan is not linked with an ePharmacy plan."" D PAUSE^VALM1 G SENDX"
^XMB(3.9,144657,2,10719,0)="""RTN"",""IBNCPIV"",67,0)"
^XMB(3.9,144657,2,10720,0)=" ;"
^XMB(3.9,144657,2,10721,0)="""RTN"",""IBNCPIV"",68,0)"
^XMB(3.9,144657,2,10722,0)=" ; scan for any other errors and display them all"
^XMB(3.9,144657,2,10723,0)="""RTN"",""IBNCPIV"",69,0)"
^XMB(3.9,144657,2,10724,0)=" K IBY D STCHK^IBCNRU1(EPHPLAN,.IBY,1)"
^XMB(3.9,144657,2,10725,0)="""RTN"",""IBNCPIV"",70,0)"
^XMB(3.9,144657,2,10726,0)=" I $E($G(IBY(1)))'=""A"" D  G SENDX"
^XMB(3.9,144657,2,10727,0)="""RTN"",""IBNCPIV"",71,0)"
^XMB(3.9,144657,2,10728,0)=" . S IBSTL=$G(IBY(6))         ; list of error msg code#'s"
^XMB(3.9,144657,2,10729,0)="""RTN"",""IBNCPIV"",72,0)"
^XMB(3.9,144657,2,10730,0)=" . K LIST"
^XMB(3.9,144657,2,10731,0)="""RTN"",""IBNCPIV"",73,0)"
^XMB(3.9,144657,2,10732,0)=" . D STATAR^IBCNRU1(.LIST)    ; build the list of error messages"
^XMB(3.9,144657,2,10733,0)="""RTN"",""IBNCPIV"",74,0)"
^XMB(3.9,144657,2,10734,0)=" . W !!,GENERR"
^XMB(3.9,144657,2,10735,0)="""RTN"",""IBNCPIV"",75,0)"
^XMB(3.9,144657,2,10736,0)=" . F G=1:1:$L(IBSTL,"","") S IBSTA=+$P(IBSTL,"","",G),TXT=$G(LIST(IBSTA)) I TXT'="""" W !,TXT"
^XMB(3.9,144657,2,10737,0)="""RTN"",""IBNCPIV"",76,0)"
^XMB(3.9,144657,2,10738,0)=" . D PAUSE^VALM1"
^XMB(3.9,144657,2,10739,0)="""RTN"",""IBNCPIV"",77,0)"
^XMB(3.9,144657,2,10740,0)=" . Q"
^XMB(3.9,144657,2,10741,0)="""RTN"",""IBNCPIV"",78,0)"
^XMB(3.9,144657,2,10742,0)=" ;"
^XMB(3.9,144657,2,10743,0)="""RTN"",""IBNCPIV"",79,0)"
^XMB(3.9,144657,2,10744,0)=" ; Ask for Effective Date for the ELIG transmission"
^XMB(3.9,144657,2,10745,0)="""RTN"",""IBNCPIV"",80,0)"
^XMB(3.9,144657,2,10746,0)=" S DEFDT=$G(IBNCPIVD)"
^XMB(3.9,144657,2,10747,0)="""RTN"",""IBNCPIV"",81,0)"
^XMB(3.9,144657,2,10748,0)=" I 'DEFDT S DEFDT=DT   ; default date"
^XMB(3.9,144657,2,10749,0)="""RTN"",""IBNCPIV"",82,0)"
^XMB(3.9,144657,2,10750,0)=" S DIR(0)=""D"""
^XMB(3.9,144657,2,10751,0)="""RTN"",""IBNCPIV"",83,0)"
^XMB(3.9,144657,2,10752,0)=" S DIR(""A"")=""Effective Date"""
^XMB(3.9,144657,2,10753,0)="""RTN"",""IBNCPIV"",84,0)"
^XMB(3.9,144657,2,10754,0)=" S DIR(""?"")=""Enter the Date for which to perform the Eligibility Verification check."""
^XMB(3.9,144657,2,10755,0)="""RTN"",""IBNCPIV"",85,0)"
^XMB(3.9,144657,2,10756,0)=" S DIR(""B"")=$$FMTE^XLFDT(DEFDT,""2Z"")"
^XMB(3.9,144657,2,10757,0)="""RTN"",""IBNCPIV"",86,0)"
^XMB(3.9,144657,2,10758,0)=" W ! D ^DIR K DIR"
^XMB(3.9,144657,2,10759,0)="""RTN"",""IBNCPIV"",87,0)"
^XMB(3.9,144657,2,10760,0)=" I $D(DTOUT)!$D(DUOUT)!('Y) G SENDX"
^XMB(3.9,144657,2,10761,0)="""RTN"",""IBNCPIV"",88,0)"
^XMB(3.9,144657,2,10762,0)=" ;"
^XMB(3.9,144657,2,10763,0)="""RTN"",""IBNCPIV"",89,0)"
^XMB(3.9,144657,2,10764,0)=" ; check for pharmacy coverage as of this date"
^XMB(3.9,144657,2,10765,0)="""RTN"",""IBNCPIV"",90,0)"
^XMB(3.9,144657,2,10766,0)=" I '$$PLCOV^IBCNSU3(IBPL,Y,3) W !!,GENERR,!,""This policy has no Active Pharmacy Coverage on this date."" D PAUSE^VALM1 G SENDX"
^XMB(3.9,144657,2,10767,0)="""RTN"",""IBNCPIV"",91,0)"
^XMB(3.9,144657,2,10768,0)=" S IBDATA(""DOS"")=Y"
^XMB(3.9,144657,2,10769,0)="""RTN"",""IBNCPIV"",92,0)"
^XMB(3.9,144657,2,10770,0)=" ;"
^XMB(3.9,144657,2,10771,0)="""RTN"",""IBNCPIV"",93,0)"
^XMB(3.9,144657,2,10772,0)=" ; Ask for Relationship Code"
^XMB(3.9,144657,2,10773,0)="""RTN"",""IBNCPIV"",94,0)"
^XMB(3.9,144657,2,10774,0)=" S IBREL=+$P($G(^DPT(DFN,.312,IBCDFN,0)),U,16)    ; pt. relationship to insured (2.312,16)"
^XMB(3.9,144657,2,10775,0)="""RTN"",""IBNCPIV"",95,0)"
^XMB(3.9,144657,2,10776,0)=" I IBREL'<4 S IBREL=4"
^XMB(3.9,144657,2,10777,0)="""RTN"",""IBNCPIV"",96,0)"
^XMB(3.9,144657,2,10778,0)=" S DIC=9002313.19"
^XMB(3.9,144657,2,10779,0)="""RTN"",""IBNCPIV"",97,0)"
^XMB(3.9,144657,2,10780,0)=" S DIC(0)=""AEQZ"""
^XMB(3.9,144657,2,10781,0)="""RTN"",""IBNCPIV"",98,0)"
^XMB(3.9,144657,2,10782,0)=" S DIC(""A"")=""Relationship Code: """
^XMB(3.9,144657,2,10783,0)="""RTN"",""IBNCPIV"",99,0)"
^XMB(3.9,144657,2,10784,0)=" S DIC(""B"")=IBREL"
^XMB(3.9,144657,2,10785,0)="""RTN"",""IBNCPIV"",100,0)"
^XMB(3.9,144657,2,10786,0)=" W ! D ^DIC K DIC"
^XMB(3.9,144657,2,10787,0)="""RTN"",""IBNCPIV"",101,0)"
^XMB(3.9,144657,2,10788,0)=" I $D(DTOUT)!$D(DUOUT)!(Y'>0) G SENDX"
^XMB(3.9,144657,2,10789,0)="""RTN"",""IBNCPIV"",102,0)"
^XMB(3.9,144657,2,10790,0)=" S IBDATA(""REL CODE"")=$P(Y,U,2)"
^XMB(3.9,144657,2,10791,0)="""RTN"",""IBNCPIV"",103,0)"
