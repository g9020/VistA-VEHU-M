^XMB(3.9,145837,2,219,0)="""QUES"",""XPZ1"",""??"")"
^XMB(3.9,145837,2,220,0)="^D OPT^XPDH"
^XMB(3.9,145837,2,221,0)="""QUES"",""XPZ1"",""A"")"
^XMB(3.9,145837,2,222,0)="Want to DISABLE Scheduled Options, Menu Options, and Protocols"
^XMB(3.9,145837,2,223,0)="""QUES"",""XPZ1"",""B"")"
