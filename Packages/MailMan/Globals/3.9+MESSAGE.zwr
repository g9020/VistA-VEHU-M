^XMB(3.9,144657,2,1077,0)="""RTN"",""IBCNBAA"",242,0)"
^XMB(3.9,144657,2,1078,0)=" S DIR(""?"")=""Enter Yes to replace existing Eligibility/Benefits data with one from eIV response."""
^XMB(3.9,144657,2,1079,0)="""RTN"",""IBCNBAA"",243,0)"
