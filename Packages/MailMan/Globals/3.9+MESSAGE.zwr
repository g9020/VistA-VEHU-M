^XMB(3.9,144657,2,1140,0)=" ;"
^XMB(3.9,144657,2,1141,0)="""RTN"",""IBCNBAA"",274,0)"
^XMB(3.9,144657,2,1142,0)="READ(IBRTYP,IBPROM,IBDFLT,IBHELP,IBSCRN) ; Reader that will returns a response to user input"
^XMB(3.9,144657,2,1143,0)="""RTN"",""IBCNBAA"",275,0)"
^XMB(3.9,144657,2,1144,0)=" ; Input:"
