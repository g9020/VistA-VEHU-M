^XMB(3.9,144661,2,538,0)=" . S ORAMDT=$P(ORAMINR,""^"",ORAMPI+1) I $L(ORAMDT) D DT^DILF(""E"",ORAMDT,.ORAMZANY) S X=ORAMZANY D H^%DTC S ORAMHDT=%H,ORAMNDT=$$FMTE^XLFDT(X,""2P"")"
