^XMB(3.9,144657,2,7066,0)=" ;    BUFF = Buffer internal entry number"
^XMB(3.9,144657,2,7067,0)="""RTN"",""IBCNEUT2"",42,0)"
^XMB(3.9,144657,2,7068,0)=" ;    BNG = Buffer Symbol IEN"
^XMB(3.9,144657,2,7069,0)="""RTN"",""IBCNEUT2"",43,0)"
^XMB(3.9,144657,2,7070,0)=" I 'BUFF!'BNG Q"
^XMB(3.9,144657,2,7071,0)="""RTN"",""IBCNEUT2"",44,0)"
^XMB(3.9,144657,2,7072,0)=" I +$P($G(^IBA(355.33,BUFF,0)),U,17) Q    ; .12 field not for ePharmacy IB*2*435"
^XMB(3.9,144657,2,7073,0)="""RTN"",""IBCNEUT2"",45,0)"
^XMB(3.9,144657,2,7074,0)=" NEW DIE,DA,DR,D,D0,DI,DIC,DQ,X,DISYS"
^XMB(3.9,144657,2,7075,0)="""RTN"",""IBCNEUT2"",46,0)"
