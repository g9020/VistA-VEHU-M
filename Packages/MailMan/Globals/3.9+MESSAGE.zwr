^XMB(3.9,145839,2,359,0)="""RTN"",""TIUCCHL7UT"",56,0)"
^XMB(3.9,145839,2,360,0)=" S CS=$E($G(HL(""ECH"")),1) S:CS="""" CS=""^"""
^XMB(3.9,145839,2,361,0)="""RTN"",""TIUCCHL7UT"",57,0)"
^XMB(3.9,145839,2,362,0)=" S RS=$E($G(HL(""ECH"")),2) S:RS="""" RS=""~"""
^XMB(3.9,145839,2,363,0)="""RTN"",""TIUCCHL7UT"",58,0)"
^XMB(3.9,145839,2,364,0)=" S ES=$E($G(HL(""ECH"")),3) S:ES="""" ES=""\"""
^XMB(3.9,145839,2,365,0)="""RTN"",""TIUCCHL7UT"",59,0)"
^XMB(3.9,145839,2,366,0)=" S SS=$E($G(HL(""ECH"")),4) S:SS="""" SS=""&"""
^XMB(3.9,145839,2,367,0)="""RTN"",""TIUCCHL7UT"",60,0)"
^XMB(3.9,145839,2,368,0)=" Q:$G(MSGTEXT)="""""
^XMB(3.9,145839,2,369,0)="""RTN"",""TIUCCHL7UT"",61,0)"
^XMB(3.9,145839,2,370,0)=" Q:$G(CONID)="""""
^XMB(3.9,145839,2,371,0)="""RTN"",""TIUCCHL7UT"",62,0)"
^XMB(3.9,145839,2,372,0)=" S CONPAT=$$GET1^DIQ(123,CONID_"","",.02,""I"")"
^XMB(3.9,145839,2,373,0)="""RTN"",""TIUCCHL7UT"",63,0)"
^XMB(3.9,145839,2,374,0)=" S:$G(CONPAT)>0 PATNAME=$$GET1^DIQ(123,CONID_"","",.02,""E"")"
^XMB(3.9,145839,2,375,0)="""RTN"",""TIUCCHL7UT"",64,0)"
^XMB(3.9,145839,2,376,0)=" S:$G(CONPAT)'>0 PATNAME=$$GET1^DIQ(123,$G(DFN)_"","",.02,""E"")"
^XMB(3.9,145839,2,377,0)="""RTN"",""TIUCCHL7UT"",65,0)"
^XMB(3.9,145839,2,378,0)=" S SITE=$$KSP^XUPARAM(""INST"")"
^XMB(3.9,145839,2,379,0)="""RTN"",""TIUCCHL7UT"",66,0)"
^XMB(3.9,145839,2,380,0)=" S:$G(ICN)="""" ICN=$$GET1^DIQ(2,CONPAT_"","",991.1,""E"")"
^XMB(3.9,145839,2,381,0)="""RTN"",""TIUCCHL7UT"",67,0)"
^XMB(3.9,145839,2,382,0)=" I $G(ICN)="""" S ICN=""NOT IN MSG"""
^XMB(3.9,145839,2,383,0)="""RTN"",""TIUCCHL7UT"",68,0)"
^XMB(3.9,145839,2,384,0)=" S EID=$G(HL(""EID""))"
^XMB(3.9,145839,2,385,0)="""RTN"",""TIUCCHL7UT"",69,0)"
