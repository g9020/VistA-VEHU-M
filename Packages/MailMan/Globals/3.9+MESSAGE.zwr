^XMB(3.9,145831,2,274,0)=" D READU^EDPBLK(AREA,""selection"",.TOKEN) ; read selection config -- UNLOCK"
^XMB(3.9,145831,2,275,0)="""RTN"",""EDPBSL"",14,0)"
^XMB(3.9,145831,2,276,0)=" Q"
^XMB(3.9,145831,2,277,0)="""RTN"",""EDPBSL"",15,0)"
^XMB(3.9,145831,2,278,0)="LIST(NM,TITLE) ; build XML for selection list"
^XMB(3.9,145831,2,279,0)="""RTN"",""EDPBSL"",16,0)"
^XMB(3.9,145831,2,280,0)=" N SETNM S SETNM=EDPSTA_"".""_NM"
^XMB(3.9,145831,2,281,0)="""RTN"",""EDPBSL"",17,0)"
^XMB(3.9,145831,2,282,0)=" I '$D(^EDPB(233.2,""B"",SETNM)) S SETNM=""edp.""_NM"
^XMB(3.9,145831,2,283,0)="""RTN"",""EDPBSL"",18,0)"
^XMB(3.9,145831,2,284,0)=" D XML^EDPX(""<""_NM_"" title='""_TITLE_""'>"")"
^XMB(3.9,145831,2,285,0)="""RTN"",""EDPBSL"",19,0)"
^XMB(3.9,145831,2,286,0)=" N IEN,SEQ,DA,X0"
^XMB(3.9,145831,2,287,0)="""RTN"",""EDPBSL"",20,0)"
^XMB(3.9,145831,2,288,0)=" S IEN=$O(^EDPB(233.2,""B"",SETNM,0))"
^XMB(3.9,145831,2,289,0)="""RTN"",""EDPBSL"",21,0)"
^XMB(3.9,145831,2,290,0)=" S SEQ=0 F  S SEQ=$O(^EDPB(233.2,IEN,1,""B"",SEQ)) Q:'SEQ  D"
^XMB(3.9,145831,2,291,0)="""RTN"",""EDPBSL"",22,0)"
^XMB(3.9,145831,2,292,0)=" . S DA=0 F  S DA=$O(^EDPB(233.2,IEN,1,""B"",SEQ,DA)) Q:'DA  D"
^XMB(3.9,145831,2,293,0)="""RTN"",""EDPBSL"",23,0)"
^XMB(3.9,145831,2,294,0)=" . . S X0=^EDPB(233.2,IEN,1,DA,0)"
^XMB(3.9,145831,2,295,0)="""RTN"",""EDPBSL"",24,0)"
^XMB(3.9,145831,2,296,0)=" . . N X"
^XMB(3.9,145831,2,297,0)="""RTN"",""EDPBSL"",25,0)"
^XMB(3.9,145831,2,298,0)=" . . S X(""seq"")=SEQ"
^XMB(3.9,145831,2,299,0)="""RTN"",""EDPBSL"",26,0)"
^XMB(3.9,145831,2,300,0)=" . . S X(""id"")=$P(X0,U,2)"
^XMB(3.9,145831,2,301,0)="""RTN"",""EDPBSL"",27,0)"
^XMB(3.9,145831,2,302,0)=" . . S X(""inact"")=$P(X0,U,3)"
^XMB(3.9,145831,2,303,0)="""RTN"",""EDPBSL"",28,0)"
^XMB(3.9,145831,2,304,0)=" . . S X(""show"")=$P(X0,U,4)"
^XMB(3.9,145831,2,305,0)="""RTN"",""EDPBSL"",29,0)"
^XMB(3.9,145831,2,306,0)=" . . S X(""abbr"")=$P(X0,U,5)"
^XMB(3.9,145831,2,307,0)="""RTN"",""EDPBSL"",30,0)"
^XMB(3.9,145831,2,308,0)=" . . ; switch to entry in 233.1 now"
^XMB(3.9,145831,2,309,0)="""RTN"",""EDPBSL"",31,0)"
^XMB(3.9,145831,2,310,0)=" . . S X0=^EDPB(233.1,X(""id""),0)"
^XMB(3.9,145831,2,311,0)="""RTN"",""EDPBSL"",32,0)"
^XMB(3.9,145831,2,312,0)=" . . I X(""show"")="""" S X(""show"")=$P(X0,U,2)"
^XMB(3.9,145831,2,313,0)="""RTN"",""EDPBSL"",33,0)"
^XMB(3.9,145831,2,314,0)=" . . I X(""abbr"")="""" S X(""abbr"")=$P(X0,U,3)"
^XMB(3.9,145831,2,315,0)="""RTN"",""EDPBSL"",34,0)"
^XMB(3.9,145831,2,316,0)=" . . S X(""flag"")=$P(X0,U,5)"
^XMB(3.9,145831,2,317,0)="""RTN"",""EDPBSL"",35,0)"
^XMB(3.9,145831,2,318,0)=" . . S X(""natl"")=$S($E(X0,1,3)=""edp"":$P(X0,U,2),1:""(local)"")"
^XMB(3.9,145831,2,319,0)="""RTN"",""EDPBSL"",36,0)"
^XMB(3.9,145831,2,320,0)=" . . D XML^EDPX($$XMLA^EDPX(""code"",.X))"
^XMB(3.9,145831,2,321,0)="""RTN"",""EDPBSL"",37,0)"
^XMB(3.9,145831,2,322,0)=" D XML^EDPX(""</""_NM_"">"")"
^XMB(3.9,145831,2,323,0)="""RTN"",""EDPBSL"",38,0)"
^XMB(3.9,145831,2,324,0)=" Q"
^XMB(3.9,145831,2,325,0)="""RTN"",""EDPBSL"",39,0)"
^XMB(3.9,145831,2,326,0)="SAVE(EDPAREA,REQ) ; save the selection changes"
^XMB(3.9,145831,2,327,0)="""RTN"",""EDPBSL"",40,0)"
^XMB(3.9,145831,2,328,0)=" N CTYP,SET,SETNM,CODE,X,EDPERR,TOKEN,LOCKERR"
^XMB(3.9,145831,2,329,0)="""RTN"",""EDPBSL"",41,0)"
^XMB(3.9,145831,2,330,0)=" ;"
^XMB(3.9,145831,2,331,0)="""RTN"",""EDPBSL"",42,0)"
^XMB(3.9,145831,2,332,0)=" S TOKEN=$G(REQ(""selectionToken"",1))"
^XMB(3.9,145831,2,333,0)="""RTN"",""EDPBSL"",43,0)"
^XMB(3.9,145831,2,334,0)=" D SAVEL^EDPBLK(EDPAREA,""selection"",.TOKEN,.LOCKERR) ; save selection config -- LOCK"
^XMB(3.9,145831,2,335,0)="""RTN"",""EDPBSL"",44,0)"
