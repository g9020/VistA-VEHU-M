^XMB(3.9,145836,2,323,0)="""RTN"",""GMTSPST1"",40,0)"
^XMB(3.9,145836,2,324,0)=" S LIST=2 D OUTPUT"
^XMB(3.9,145836,2,325,0)="""RTN"",""GMTSPST1"",41,0)"
^XMB(3.9,145836,2,326,0)=" D FOOTER"
