^XMB(3.9,145837,2,199,0)="""QUES"",""XPM1"",""??"")"
^XMB(3.9,145837,2,200,0)="^D MG^XPDH"
^XMB(3.9,145837,2,201,0)="""QUES"",""XPM1"",""A"")"
^XMB(3.9,145837,2,202,0)="Enter the Coordinator for Mail Group '|FLAG|'"
