^XMB(3.9,145838,2,660,0)="0^9^B36872113"
^XMB(3.9,145838,2,661,0)="""RTN"",""FBAAUTL"",1,0)"
^XMB(3.9,145838,2,662,0)="FBAAUTL ;AISC/GRR,SBW-Fee Basis Utility Routine ; 4/23/10 3:06pm"
^XMB(3.9,145838,2,663,0)="""RTN"",""FBAAUTL"",2,0)"
^XMB(3.9,145838,2,664,0)=" ;;3.5;FEE BASIS;**101,114,108,124,127,158**;JAN 30, 1995;Build 0"
^XMB(3.9,145838,2,665,0)="""RTN"",""FBAAUTL"",3,0)"
^XMB(3.9,145838,2,666,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,145838,2,667,0)="""RTN"",""FBAAUTL"",4,0)"
^XMB(3.9,145838,2,668,0)="DATE N FBDT S FBPOP=0 K BEGDATE,ENDDATE K:$G(%DT)'[""A"" %DT W !!,""**** Date Range Selection ****"""
^XMB(3.9,145838,2,669,0)="""RTN"",""FBAAUTL"",5,0)"
^XMB(3.9,145838,2,670,0)=" S FBDT=$S($D(%DT):1,1:0) W ! S %DT=$S(FBDT:%DT,1:""APEX""),%DT(""A"")=""   Beginning DATE : "" D ^%DT S:Y<0 FBPOP=1 Q:Y<0  S (%DT(0),BEGDATE)=Y"
^XMB(3.9,145838,2,671,0)="""RTN"",""FBAAUTL"",6,0)"
^XMB(3.9,145838,2,672,0)=" W ! S %DT=$S(FBDT:%DT,1:""AEX""),%DT(""A"")=""   Ending    DATE : "" D ^%DT K %DT S:Y<0 FBPOP=1 Q:Y<0  W ! S ENDDATE=Y"
^XMB(3.9,145838,2,673,0)="""RTN"",""FBAAUTL"",7,0)"
^XMB(3.9,145838,2,674,0)=" Q"
^XMB(3.9,145838,2,675,0)="""RTN"",""FBAAUTL"",8,0)"
^XMB(3.9,145838,2,676,0)=" ;"
^XMB(3.9,145838,2,677,0)="""RTN"",""FBAAUTL"",9,0)"
^XMB(3.9,145838,2,678,0)="ZIS S ZTRTN=PGM,ZTSAVE="""",FBPOP=0 F I=1:1 Q:$P(VAR,""^"",I)']""""  S ZTSAVE($P(VAR,""^"",I))="""""
^XMB(3.9,145838,2,679,0)="""RTN"",""FBAAUTL"",10,0)"
^XMB(3.9,145838,2,680,0)=" I '$D(ZTDESC) S ZTDESC=$S($D(PGM):PGM,1:""UNKNOWN OPTION"")"
^XMB(3.9,145838,2,681,0)="""RTN"",""FBAAUTL"",11,0)"
^XMB(3.9,145838,2,682,0)=" W ! S %ZIS=""QMP"" D ^%ZIS S:POP FBPOP=1 Q:POP  I $D(IO(""Q"")) K IO(""Q""),ZTIO D ^%ZTLOAD W:$D(ZTSK) !,*7,""REQUEST QUEUED"",!,""Task #: "",$G(ZTSK) K I,ZTSK,ZTIO,ZTSAVE,ZTRTN D HOME^%ZIS S FBPOP=1 Q"
^XMB(3.9,145838,2,683,0)="""RTN"",""FBAAUTL"",12,0)"
^XMB(3.9,145838,2,684,0)=" Q"
^XMB(3.9,145838,2,685,0)="""RTN"",""FBAAUTL"",13,0)"
^XMB(3.9,145838,2,686,0)=" ;"
^XMB(3.9,145838,2,687,0)="""RTN"",""FBAAUTL"",14,0)"
^XMB(3.9,145838,2,688,0)="CLOSE I '$D(ZTQUEUED) D ^%ZISC"
^XMB(3.9,145838,2,689,0)="""RTN"",""FBAAUTL"",15,0)"
^XMB(3.9,145838,2,690,0)=" K IOP,ZTDESC,ZTRTN,ZTSAVE,ZTDTH,VAR,VAL,PGM,FBPOP,POP Q"
^XMB(3.9,145838,2,691,0)="""RTN"",""FBAAUTL"",16,0)"
^XMB(3.9,145838,2,692,0)=" ;"
^XMB(3.9,145838,2,693,0)="""RTN"",""FBAAUTL"",17,0)"
^XMB(3.9,145838,2,694,0)="D S Y=$P(""JAN^FEB^MAR^APR^MAY^JUN^JUL^AUG^SEP^OCT^NOV^DEC"",""^"",$E(Y,4,5))_"" ""_$S(Y#100:$J(Y#100\1,2)_"","",1:"""")_(Y\10000+1700)_$S(Y#1:""  ""_$E(Y_0,9,10)_"":""_$E(Y_""000"",11,12),1:"""") Q"
^XMB(3.9,145838,2,695,0)="""RTN"",""FBAAUTL"",18,0)"
^XMB(3.9,145838,2,696,0)="SITEP ;SET FBSITE(0),FBSITE(1) VARIABLE TO FEE SITE PARAMETERS"
^XMB(3.9,145838,2,697,0)="""RTN"",""FBAAUTL"",19,0)"
^XMB(3.9,145838,2,698,0)=" S FBPOP=0,FBSITE(0)=$G(^FBAA(161.4,1,0)) S:FBSITE(0)']"""" FBPOP=1"
^XMB(3.9,145838,2,699,0)="""RTN"",""FBAAUTL"",20,0)"
^XMB(3.9,145838,2,700,0)=" S FBSITE(1)=$G(^FBAA(161.4,1,1)) S:FBSITE(1)']"""" FBPOP=1"
^XMB(3.9,145838,2,701,0)="""RTN"",""FBAAUTL"",21,0)"
^XMB(3.9,145838,2,702,0)=" S FBSITE(""FBNUM"")=$G(^FBAA(161.4,1,""FBNUM"")) S:FBSITE(""FBNUM"")']"""" FBPOP=1"
^XMB(3.9,145838,2,703,0)="""RTN"",""FBAAUTL"",22,0)"
^XMB(3.9,145838,2,704,0)=" W:FBPOP !,*7,""Fee Basis Site Parameters must be entered to proceed"",!"
^XMB(3.9,145838,2,705,0)="""RTN"",""FBAAUTL"",23,0)"
^XMB(3.9,145838,2,706,0)=" Q"
^XMB(3.9,145838,2,707,0)="""RTN"",""FBAAUTL"",24,0)"
^XMB(3.9,145838,2,708,0)="TM S X=$E($P(X,""."",2)_""0000"",1,4),%=X>1159 S:X>1259 X=X-1200 S X=X\100_"":""_$E(X#100+100,2,3)_"" ""_$E(""AP"",%+1)_""M"" Q"
^XMB(3.9,145838,2,709,0)="""RTN"",""FBAAUTL"",25,0)"
^XMB(3.9,145838,2,710,0)="PDF S:Y Y=$E(Y,4,5)_""/""_$E(Y,6,7)_""/""_$E(Y,2,3) Q"
^XMB(3.9,145838,2,711,0)="""RTN"",""FBAAUTL"",26,0)"
^XMB(3.9,145838,2,712,0)="GETNXB ;GET NEXT AVAILABLE BATCH NUMBER"
^XMB(3.9,145838,2,713,0)="""RTN"",""FBAAUTL"",27,0)"
^XMB(3.9,145838,2,714,0)=" L +^FBAA(161.4):$G(DILOCKTM,3) I '$T D  G GETNXB"
^XMB(3.9,145838,2,715,0)="""RTN"",""FBAAUTL"",28,0)"
^XMB(3.9,145838,2,716,0)=" .W !,""Another user is opening a batch.  Trying again."",!"
^XMB(3.9,145838,2,717,0)="""RTN"",""FBAAUTL"",29,0)"
^XMB(3.9,145838,2,718,0)=" I '$D(^FBAA(161.4,1,""FBNUM"")) S ^FBAA(161.4,1,""FBNUM"")=""1^1"""
^XMB(3.9,145838,2,719,0)="""RTN"",""FBAAUTL"",30,0)"
^XMB(3.9,145838,2,720,0)=" I '$P($G(^FBAA(161.4,1,""FBNUM"")),""^"") S $P(^(""FBNUM""),""^"")=1"
^XMB(3.9,145838,2,721,0)="""RTN"",""FBAAUTL"",31,0)"
^XMB(3.9,145838,2,722,0)=" S FBBN=$P(^FBAA(161.4,1,""FBNUM""),""^"")"
^XMB(3.9,145838,2,723,0)="""RTN"",""FBAAUTL"",32,0)"
^XMB(3.9,145838,2,724,0)=" N FBBATLT ;Batches Left *127"
^XMB(3.9,145838,2,725,0)="""RTN"",""FBAAUTL"",33,0)"
^XMB(3.9,145838,2,726,0)=" S FBBATLT=$P($G(^FBAA(161.7,0)),U,4)"
^XMB(3.9,145838,2,727,0)="""RTN"",""FBAAUTL"",34,0)"
^XMB(3.9,145838,2,728,0)=" I FBBATLT>9999499 D WARNBT ;*114,127,FB*3.5*158"
^XMB(3.9,145838,2,729,0)="""RTN"",""FBAAUTL"",35,0)"
^XMB(3.9,145838,2,730,0)=" S $P(^FBAA(161.4,1,""FBNUM""),""^"",1)=$S(FBBN+1>9999999:1,1:FBBN+1) I '$$CHKBI^FBAAUTL4(FBBN,1) L -^FBAA(161.4) G GETNXB"
^XMB(3.9,145838,2,731,0)="""RTN"",""FBAAUTL"",36,0)"
^XMB(3.9,145838,2,732,0)=" L -^FBAA(161.4) Q"
^XMB(3.9,145838,2,733,0)="""RTN"",""FBAAUTL"",37,0)"
^XMB(3.9,145838,2,734,0)="WARNBT W !,*7,""There are "",9999999-FBBATLT,"" batches left before the BATCH PURGE routine"",!,""needs to be run. Contact your IRM Service!"",!!"
^XMB(3.9,145838,2,735,0)="""RTN"",""FBAAUTL"",38,0)"
^XMB(3.9,145838,2,736,0)=" Q"
^XMB(3.9,145838,2,737,0)="""RTN"",""FBAAUTL"",39,0)"
^XMB(3.9,145838,2,738,0)="GETNXI ;GET NEXT AVAILABLE INVOICE NUMBER "
^XMB(3.9,145838,2,739,0)="""RTN"",""FBAAUTL"",40,0)"
^XMB(3.9,145838,2,740,0)=" L +^FBAA(161.4):$G(DILOCKTM,3) I '$T D  G GETNXI"
^XMB(3.9,145838,2,741,0)="""RTN"",""FBAAUTL"",41,0)"
^XMB(3.9,145838,2,742,0)=" .W !,""Another user is obtaining an invoice number.  Trying again."",!"
^XMB(3.9,145838,2,743,0)="""RTN"",""FBAAUTL"",42,0)"
^XMB(3.9,145838,2,744,0)=" I '$D(^FBAA(161.4,1,""FBNUM"")) S ^FBAA(161.4,1,""FBNUM"")=""1^1"""
^XMB(3.9,145838,2,745,0)="""RTN"",""FBAAUTL"",43,0)"
^XMB(3.9,145838,2,746,0)=" I '$P($G(^FBAA(161.4,1,""FBNUM"")),U,2) S $P(^(""FBNUM""),U,2)=1"
^XMB(3.9,145838,2,747,0)="""RTN"",""FBAAUTL"",44,0)"
^XMB(3.9,145838,2,748,0)=" S FBAAIN=$P(^FBAA(161.4,1,""FBNUM""),""^"",2),$P(^(""FBNUM""),""^"",2)=$S(FBAAIN+1>9999999:1,1:FBAAIN+1) I '$$CHKBI^FBAAUTL4(FBAAIN) L -^FBAA(161.4) G GETNXI"
^XMB(3.9,145838,2,749,0)="""RTN"",""FBAAUTL"",45,0)"
^XMB(3.9,145838,2,750,0)=" L -^FBAA(161.4) Q"
^XMB(3.9,145838,2,751,0)="""RTN"",""FBAAUTL"",46,0)"
^XMB(3.9,145838,2,752,0)="PDATE S FBPDT=$P(""January^February^March^April^May^June^July^August^September^October^November^December"",""^"",$E(Y,4,5))_"" ""_$S(Y#100:$J(Y#100\1,2)_"", "",1:"""")_(Y\10000+1700)_$S(Y#1:""  ""_$E(Y_0,9,10)_"":""_$E(Y_""000"",11,12),1:"""") Q"
^XMB(3.9,145838,2,753,0)="""RTN"",""FBAAUTL"",47,0)"
^XMB(3.9,145838,2,754,0)="DATCK S HOLDY=Y,HOLDY=$S($P(HOLDY,""^"",2):$P(HOLDY,""^"",2),1:HOLDY)"
^XMB(3.9,145838,2,755,0)="""RTN"",""FBAAUTL"",48,0)"
^XMB(3.9,145838,2,756,0)=" I $D(FBAAID),Y>FBAAID D  K X Q"
^XMB(3.9,145838,2,757,0)="""RTN"",""FBAAUTL"",49,0)"
^XMB(3.9,145838,2,758,0)=" .N SHODAT S SHODAT=$E(FBAAID,4,5)_""/""_$E(FBAAID,6,7)_""/""_$E(FBAAID,2,3)"
^XMB(3.9,145838,2,759,0)="""RTN"",""FBAAUTL"",50,0)"
^XMB(3.9,145838,2,760,0)=" .W !!,*7,?5,""*** Date of Service cannot be later than"",!?8,"" Invoice Received Date (""_SHODAT_"") !!!"",!"
^XMB(3.9,145838,2,761,0)="""RTN"",""FBAAUTL"",51,0)"
^XMB(3.9,145838,2,762,0)=" I $D(FBAABDT),$D(FBAAEDT),(Y<FBAABDT!(Y>FBAAEDT)) D  K X"
^XMB(3.9,145838,2,763,0)="""RTN"",""FBAAUTL"",52,0)"
^XMB(3.9,145838,2,764,0)=" .N PRIORLAT,AUTHDAT,SHODAT"
^XMB(3.9,145838,2,765,0)="""RTN"",""FBAAUTL"",53,0)"
^XMB(3.9,145838,2,766,0)=" .S PRIORLAT=$S($P(Y,""^"",2)<FBAABDT:""prior to "",1:""later than "")"
^XMB(3.9,145838,2,767,0)="""RTN"",""FBAAUTL"",54,0)"
^XMB(3.9,145838,2,768,0)=" .S AUTHDAT=$S($P(Y,""^"",2)<FBAABDT:FBAABDT,1:FBAAEDT)"
^XMB(3.9,145838,2,769,0)="""RTN"",""FBAAUTL"",55,0)"
^XMB(3.9,145838,2,770,0)=" .S SHODAT=$E(AUTHDAT,4,5)_""/""_$E(AUTHDAT,6,7)_""/""_$E(AUTHDAT,2,3)"
^XMB(3.9,145838,2,771,0)="""RTN"",""FBAAUTL"",56,0)"
^XMB(3.9,145838,2,772,0)=" .W !!,*7,?5,""*** Date of Service cannot be "",PRIORLAT"
^XMB(3.9,145838,2,773,0)="""RTN"",""FBAAUTL"",57,0)"
^XMB(3.9,145838,2,774,0)=" .W !?8,"" Authorization period (""_SHODAT_"") !!!"",!"
^XMB(3.9,145838,2,775,0)="""RTN"",""FBAAUTL"",58,0)"
^XMB(3.9,145838,2,776,0)=" S Y=HOLDY Q"
^XMB(3.9,145838,2,777,0)="""RTN"",""FBAAUTL"",59,0)"
^XMB(3.9,145838,2,778,0)=" ;"
^XMB(3.9,145838,2,779,0)="""RTN"",""FBAAUTL"",60,0)"
^XMB(3.9,145838,2,780,0)="DATX(X) ;external output function for date format"
^XMB(3.9,145838,2,781,0)="""RTN"",""FBAAUTL"",61,0)"
^XMB(3.9,145838,2,782,0)=" ;INPUT = FM internal date format (time optional)"
^XMB(3.9,145838,2,783,0)="""RTN"",""FBAAUTL"",62,0)"
^XMB(3.9,145838,2,784,0)=" ;OUTPUT = date/time with slashes"
^XMB(3.9,145838,2,785,0)="""RTN"",""FBAAUTL"",63,0)"
^XMB(3.9,145838,2,786,0)=" Q $$FMTE^XLFDT(X,2)"
^XMB(3.9,145838,2,787,0)="""RTN"",""FBAAUTL"",64,0)"
^XMB(3.9,145838,2,788,0)=" ;"
^XMB(3.9,145838,2,789,0)="""RTN"",""FBAAUTL"",65,0)"
^XMB(3.9,145838,2,790,0)="STATION ;GET STATION NUMBER FROM INSTITUTION FILE"
^XMB(3.9,145838,2,791,0)="""RTN"",""FBAAUTL"",66,0)"
^XMB(3.9,145838,2,792,0)=" I '$D(FBSITE(1)) D SITEP"
^XMB(3.9,145838,2,793,0)="""RTN"",""FBAAUTL"",67,0)"
^XMB(3.9,145838,2,794,0)=" I $S('$D(FBSITE(1)):1,$P(FBSITE(1),""^"",3)="""":1,'$D(^DIC(4,$P(FBSITE(1),""^"",3),0)):1,'$D(^DIC(4,$P(FBSITE(1),""^"",3),99)):1,'+$P(^DIC(4,$P(FBSITE(1),""^"",3),99),""^""):1,1:0) G NOSTA"
^XMB(3.9,145838,2,795,0)="""RTN"",""FBAAUTL"",68,0)"
^XMB(3.9,145838,2,796,0)=" S (FBSN,FBAASN)=$S($D(^DIC(4,$P(FBSITE(1),""^"",3),99)):$E(^(99),1,3),1:999)"
^XMB(3.9,145838,2,797,0)="""RTN"",""FBAAUTL"",69,0)"
^XMB(3.9,145838,2,798,0)=" Q"
^XMB(3.9,145838,2,799,0)="""RTN"",""FBAAUTL"",70,0)"
^XMB(3.9,145838,2,800,0)="NOSTA S FB(""ERROR"")=1 I '$D(ZTQUEUED) W !!,*7,""Unable to determine Station Number. Check Fee Site Parameters or Station Number in the Institution File."",!!"
^XMB(3.9,145838,2,801,0)="""RTN"",""FBAAUTL"",71,0)"
^XMB(3.9,145838,2,802,0)=" Q"
^XMB(3.9,145838,2,803,0)="""RTN"",""FBAAUTL"",72,0)"
^XMB(3.9,145838,2,804,0)=" ;"
^XMB(3.9,145838,2,805,0)="""RTN"",""FBAAUTL"",73,0)"
^XMB(3.9,145838,2,806,0)="HD ;set transmission header"
^XMB(3.9,145838,2,807,0)="""RTN"",""FBAAUTL"",74,0)"
^XMB(3.9,145838,2,808,0)=" I '$D(FBSITE(1)) S FBSITE(1)=$G(^FBAA(161.4,1,1))"
^XMB(3.9,145838,2,809,0)="""RTN"",""FBAAUTL"",75,0)"
^XMB(3.9,145838,2,810,0)=" S FBHD=$$HDR^FBAAUTL3() I FBHD']"""" S FB(""ERROR"")=1 W !,""Transmission header must exist in FEE BASIS SITE PARAMETER file"",!,""before you can proceed."",*7,!"
^XMB(3.9,145838,2,811,0)="""RTN"",""FBAAUTL"",76,0)"
^XMB(3.9,145838,2,812,0)=" Q"
^XMB(3.9,145838,2,813,0)="""RTN"",""FBAAUTL"",77,0)"
^XMB(3.9,145838,2,814,0)=" ;"
^XMB(3.9,145838,2,815,0)="""RTN"",""FBAAUTL"",78,0)"
^XMB(3.9,145838,2,816,0)="SSN(PID,BID,DOD) ;"
^XMB(3.9,145838,2,817,0)="""RTN"",""FBAAUTL"",79,0)"
^XMB(3.9,145838,2,818,0)=" ;PID = DFN of Patient. If this is all that is past,"
^XMB(3.9,145838,2,819,0)="""RTN"",""FBAAUTL"",80,0)"
^XMB(3.9,145838,2,820,0)=" ;full Pt.ID (000-00-0000) will be returned."
^XMB(3.9,145838,2,821,0)="""RTN"",""FBAAUTL"",81,0)"
^XMB(3.9,145838,2,822,0)=" ;If BID = 1 the call will return last 4 of Pt.ID only."
^XMB(3.9,145838,2,823,0)="""RTN"",""FBAAUTL"",82,0)"
^XMB(3.9,145838,2,824,0)=" ;If DOD is defined to internal entry # of eligibility the appropriate"
^XMB(3.9,145838,2,825,0)="""RTN"",""FBAAUTL"",83,0)"
^XMB(3.9,145838,2,826,0)=" ;Pt.ID will be returned."
^XMB(3.9,145838,2,827,0)="""RTN"",""FBAAUTL"",84,0)"
^XMB(3.9,145838,2,828,0)=" N DFN,FBSSN"
^XMB(3.9,145838,2,829,0)="""RTN"",""FBAAUTL"",85,0)"
^XMB(3.9,145838,2,830,0)=" S DFN=PID"
^XMB(3.9,145838,2,831,0)="""RTN"",""FBAAUTL"",86,0)"
^XMB(3.9,145838,2,832,0)=" I 'DFN Q ""Unknown"""
^XMB(3.9,145838,2,833,0)="""RTN"",""FBAAUTL"",87,0)"
^XMB(3.9,145838,2,834,0)=" S:'$D(BID) BID="""" S:$D(DOD) VAPTYP=DOD"
^XMB(3.9,145838,2,835,0)="""RTN"",""FBAAUTL"",88,0)"
^XMB(3.9,145838,2,836,0)=" D PID^VADPT6 I VAERR K VAERR Q ""Unknown"""
^XMB(3.9,145838,2,837,0)="""RTN"",""FBAAUTL"",89,0)"
^XMB(3.9,145838,2,838,0)=" S FBSSN=$S(BID:VA(""BID""),1:VA(""PID""))"
^XMB(3.9,145838,2,839,0)="""RTN"",""FBAAUTL"",90,0)"
^XMB(3.9,145838,2,840,0)=" K VA(""BID""),VA(""PID""),VAERR,VAPTYP"
^XMB(3.9,145838,2,841,0)="""RTN"",""FBAAUTL"",91,0)"
^XMB(3.9,145838,2,842,0)=" Q FBSSN"
^XMB(3.9,145838,2,843,0)="""RTN"",""FBAAUTL"",92,0)"
^XMB(3.9,145838,2,844,0)=" ;"
^XMB(3.9,145838,2,845,0)="""RTN"",""FBAAUTL"",93,0)"
^XMB(3.9,145838,2,846,0)="SSNL4(SSN) ;Convert 1st 5 digits of SSN to X (Only print last 4 digits of SSN)"
^XMB(3.9,145838,2,847,0)="""RTN"",""FBAAUTL"",94,0)"
^XMB(3.9,145838,2,848,0)=" ;Input:"
^XMB(3.9,145838,2,849,0)="""RTN"",""FBAAUTL"",95,0)"
^XMB(3.9,145838,2,850,0)=" ;   SSN - SSN in 9 digit or ###-##-#### format"
^XMB(3.9,145838,2,851,0)="""RTN"",""FBAAUTL"",96,0)"
^XMB(3.9,145838,2,852,0)=" ;     Pseudo SSN is also allowed as input"
^XMB(3.9,145838,2,853,0)="""RTN"",""FBAAUTL"",97,0)"
^XMB(3.9,145838,2,854,0)=" ;Output"
^XMB(3.9,145838,2,855,0)="""RTN"",""FBAAUTL"",98,0)"
^XMB(3.9,145838,2,856,0)=" ;   SSN - SSN in XXXXX#### or XXX-XX-#### format"
^XMB(3.9,145838,2,857,0)="""RTN"",""FBAAUTL"",99,0)"
^XMB(3.9,145838,2,858,0)=" ;     Pseudo SSN will be changed as above with passed ""P"" at end"
^XMB(3.9,145838,2,859,0)="""RTN"",""FBAAUTL"",100,0)"
^XMB(3.9,145838,2,860,0)=" ; X represent actual X and # represent digit"
^XMB(3.9,145838,2,861,0)="""RTN"",""FBAAUTL"",101,0)"
^XMB(3.9,145838,2,862,0)=" ;"
^XMB(3.9,145838,2,863,0)="""RTN"",""FBAAUTL"",102,0)"
^XMB(3.9,145838,2,864,0)=" S SSN=$G(SSN)"
^XMB(3.9,145838,2,865,0)="""RTN"",""FBAAUTL"",103,0)"
^XMB(3.9,145838,2,866,0)=" ;Change SSN ######### to XXXXX####"
^XMB(3.9,145838,2,867,0)="""RTN"",""FBAAUTL"",104,0)"
^XMB(3.9,145838,2,868,0)=" S:SSN?9N0.1""P"" $E(SSN,1,5)=""XXXXX"""
^XMB(3.9,145838,2,869,0)="""RTN"",""FBAAUTL"",105,0)"
^XMB(3.9,145838,2,870,0)=" ;Change SSN ###-##-#### to XXX-XX-####"
^XMB(3.9,145838,2,871,0)="""RTN"",""FBAAUTL"",106,0)"
^XMB(3.9,145838,2,872,0)=" S:SSN?3N1""-""2N1""-""4N0.1""P"" $E(SSN,1,7)=""XXX-XX-"""
^XMB(3.9,145838,2,873,0)="""RTN"",""FBAAUTL"",107,0)"
^XMB(3.9,145838,2,874,0)=" Q SSN"
^XMB(3.9,145838,2,875,0)="""RTN"",""FBAAUTL"",108,0)"
^XMB(3.9,145838,2,876,0)=" ;"
^XMB(3.9,145838,2,877,0)="""RTN"",""FBAAUTL"",109,0)"
^XMB(3.9,145838,2,878,0)="PYMTH(CODE) ; Payment Methodology Processing (FB*3.5*158)"
^XMB(3.9,145838,2,879,0)="""RTN"",""FBAAUTL"",110,0)"
^XMB(3.9,145838,2,880,0)=" ; input --> CODE: Fee Schedule/Payment Methodology code"
^XMB(3.9,145838,2,881,0)="""RTN"",""FBAAUTL"",111,0)"
^XMB(3.9,145838,2,882,0)=" ; output --> Payment methodology name or '@' to delete existing value"
^XMB(3.9,145838,2,883,0)="""RTN"",""FBAAUTL"",112,0)"
^XMB(3.9,145838,2,884,0)=" ;"
^XMB(3.9,145838,2,885,0)="""RTN"",""FBAAUTL"",113,0)"
^XMB(3.9,145838,2,886,0)=" ;S CODE=""F"" ;debug"
^XMB(3.9,145838,2,887,0)="""RTN"",""FBAAUTL"",114,0)"
^XMB(3.9,145838,2,888,0)=" Q:CODE']"""" ""@"""
^XMB(3.9,145838,2,889,0)="""RTN"",""FBAAUTL"",115,0)"
^XMB(3.9,145838,2,890,0)=" N IEN"
^XMB(3.9,145838,2,891,0)="""RTN"",""FBAAUTL"",116,0)"
^XMB(3.9,145838,2,892,0)=" S IEN=$O(^FBAA(163.98,""C"",CODE,""""))"
^XMB(3.9,145838,2,893,0)="""RTN"",""FBAAUTL"",117,0)"
^XMB(3.9,145838,2,894,0)=" Q $S(IEN:$P(^FBAA(163.98,IEN,0),U),1:""@"")"
^XMB(3.9,145838,2,895,0)="""RTN"",""FBAAUTL"",118,0)"
^XMB(3.9,145838,2,896,0)=" ;"
^XMB(3.9,145838,2,897,0)="""RTN"",""FBAAUTL"",119,0)"
^XMB(3.9,145838,2,898,0)="CRARC(FBADJ,FBRRMK,FBCRARC) ; compile CARCs and RARCs into an array for batch processing"
^XMB(3.9,145838,2,899,0)="""RTN"",""FBAAUTL"",120,0)"
^XMB(3.9,145838,2,900,0)=" ;"
^XMB(3.9,145838,2,901,0)="""RTN"",""FBAAUTL"",121,0)"
^XMB(3.9,145838,2,902,0)=" N I,J,K,FBADJGI,FBADJGE,FBADJRI,FBADJRE,FBADJA,FBADJAE,FBRRMKI,FBRRMKE,CNT"
^XMB(3.9,145838,2,903,0)="""RTN"",""FBAAUTL"",122,0)"
^XMB(3.9,145838,2,904,0)=" S (I,CNT)=0"
^XMB(3.9,145838,2,905,0)="""RTN"",""FBAAUTL"",123,0)"
^XMB(3.9,145838,2,906,0)=" F  S I=$O(FBADJ(I)) Q:'I  D"
^XMB(3.9,145838,2,907,0)="""RTN"",""FBAAUTL"",124,0)"
^XMB(3.9,145838,2,908,0)=" . S CNT=I"
^XMB(3.9,145838,2,909,0)="""RTN"",""FBAAUTL"",125,0)"
^XMB(3.9,145838,2,910,0)=" . S X=$P(FBADJ(I),U,2)_U_$P(FBADJ(I),U)_U_$P(FBADJ(I),U,3)"
^XMB(3.9,145838,2,911,0)="""RTN"",""FBAAUTL"",126,0)"
^XMB(3.9,145838,2,912,0)=" . S FBADJGI=$P(FBADJ(I),U,2)"
^XMB(3.9,145838,2,913,0)="""RTN"",""FBAAUTL"",127,0)"
^XMB(3.9,145838,2,914,0)=" . S FBADJGE=$S(FBADJGI:$P($G(^FB(161.92,FBADJGI,0)),U),1:"""")"
^XMB(3.9,145838,2,915,0)="""RTN"",""FBAAUTL"",128,0)"
^XMB(3.9,145838,2,916,0)=" . S FBADJRI=$P(FBADJ(I),U)"
^XMB(3.9,145838,2,917,0)="""RTN"",""FBAAUTL"",129,0)"
^XMB(3.9,145838,2,918,0)=" . S FBADJRE=$S(FBADJRI:$P($G(^FB(161.91,FBADJRI,0)),U),1:"""")"
^XMB(3.9,145838,2,919,0)="""RTN"",""FBAAUTL"",130,0)"
^XMB(3.9,145838,2,920,0)=" . S FBADJA=$P(FBADJ(I),U,3)"
^XMB(3.9,145838,2,921,0)="""RTN"",""FBAAUTL"",131,0)"
^XMB(3.9,145838,2,922,0)=" . S FBADJAE=$FN(FBADJA,"""",2)"
^XMB(3.9,145838,2,923,0)="""RTN"",""FBAAUTL"",132,0)"
^XMB(3.9,145838,2,924,0)=" . S FBCRARC(I)=FBADJGE_U_FBADJRE_U_FBADJAE_U"
^XMB(3.9,145838,2,925,0)="""RTN"",""FBAAUTL"",133,0)"
^XMB(3.9,145838,2,926,0)=" . ; RARCs"
^XMB(3.9,145838,2,927,0)="""RTN"",""FBAAUTL"",134,0)"
^XMB(3.9,145838,2,928,0)=" . S J=0"
^XMB(3.9,145838,2,929,0)="""RTN"",""FBAAUTL"",135,0)"
^XMB(3.9,145838,2,930,0)=" . F  S J=$O(FBRRMK(FBADJRI,J)) Q:'J  D"
^XMB(3.9,145838,2,931,0)="""RTN"",""FBAAUTL"",136,0)"
^XMB(3.9,145838,2,932,0)=" . . S FBRRMKI=FBRRMK(FBADJRI,J)"
^XMB(3.9,145838,2,933,0)="""RTN"",""FBAAUTL"",137,0)"
^XMB(3.9,145838,2,934,0)=" . . S FBRRMKE=$S(FBRRMKI:$P($G(^FB(161.93,FBRRMKI,0)),U),1:"""")"
^XMB(3.9,145838,2,935,0)="""RTN"",""FBAAUTL"",138,0)"
^XMB(3.9,145838,2,936,0)=" . . S FBCRARC(I)=FBCRARC(I)_FBRRMKE_U"
^XMB(3.9,145838,2,937,0)="""RTN"",""FBAAUTL"",139,0)"
^XMB(3.9,145838,2,938,0)=" ; CARCless RARCs"
^XMB(3.9,145838,2,939,0)="""RTN"",""FBAAUTL"",140,0)"
^XMB(3.9,145838,2,940,0)=" S FBADJRI=999,J=0,(FBADJGE,FBADJRE,FBADJAE)="""",DONE=0,I=CNT"
^XMB(3.9,145838,2,941,0)="""RTN"",""FBAAUTL"",141,0)"
^XMB(3.9,145838,2,942,0)=" F  D  Q:DONE"
^XMB(3.9,145838,2,943,0)="""RTN"",""FBAAUTL"",142,0)"
^XMB(3.9,145838,2,944,0)=" . S I=I+1"
^XMB(3.9,145838,2,945,0)="""RTN"",""FBAAUTL"",143,0)"
^XMB(3.9,145838,2,946,0)=" . F K=1:1:2 D  I 'J S DONE=1 Q"
^XMB(3.9,145838,2,947,0)="""RTN"",""FBAAUTL"",144,0)"
^XMB(3.9,145838,2,948,0)=" . . S J=$O(FBRRMK(FBADJRI,J)) Q:'J  D"
^XMB(3.9,145838,2,949,0)="""RTN"",""FBAAUTL"",145,0)"
^XMB(3.9,145838,2,950,0)=" . . S:K=1 FBCRARC(I)=FBADJGE_U_FBADJRE_U_FBADJAE_U"
^XMB(3.9,145838,2,951,0)="""RTN"",""FBAAUTL"",146,0)"
^XMB(3.9,145838,2,952,0)=" . . S FBRRMKI=FBRRMK(FBADJRI,J)"
^XMB(3.9,145838,2,953,0)="""RTN"",""FBAAUTL"",147,0)"
^XMB(3.9,145838,2,954,0)=" . . S FBRRMKE=$S(FBRRMKI:$P($G(^FB(161.93,FBRRMKI,0)),U),1:"""")"
^XMB(3.9,145838,2,955,0)="""RTN"",""FBAAUTL"",148,0)"
^XMB(3.9,145838,2,956,0)=" . . S FBCRARC(I)=FBCRARC(I)_FBRRMKE_U"
^XMB(3.9,145838,2,957,0)="""RTN"",""FBAAUTL"",149,0)"
^XMB(3.9,145838,2,958,0)=" Q"
^XMB(3.9,145838,2,959,0)="""RTN"",""FBAAUTL"",150,0)"
^XMB(3.9,145838,2,960,0)=" ;"
^XMB(3.9,145838,2,961,0)="""RTN"",""FBP192R"")"
^XMB(3.9,145838,2,962,0)="0^^B3729813"
^XMB(3.9,145838,2,963,0)="""RTN"",""FBP192R"",1,0)"
^XMB(3.9,145838,2,964,0)="FBP192R ;CAN/EJD - FB*3.5*192 Rollback Routine ; Dec 17, 2025@14:32"
^XMB(3.9,145838,2,965,0)="""RTN"",""FBP192R"",2,0)"
^XMB(3.9,145838,2,966,0)=" ;;3.5;FEE BASIS;**192**;JAN 30, 1995;Build 18"
^XMB(3.9,145838,2,967,0)="""RTN"",""FBP192R"",3,0)"
^XMB(3.9,145838,2,968,0)=" ;"
^XMB(3.9,145838,2,969,0)="""RTN"",""FBP192R"",4,0)"
^XMB(3.9,145838,2,970,0)=" Q   ;Force call at tag"
^XMB(3.9,145838,2,971,0)="""RTN"",""FBP192R"",5,0)"
^XMB(3.9,145838,2,972,0)=" ;"
^XMB(3.9,145838,2,973,0)="""RTN"",""FBP192R"",6,0)"
^XMB(3.9,145838,2,974,0)="ROLLBACK ;Rollback the Options delivered in FB 35 192"
^XMB(3.9,145838,2,975,0)="""RTN"",""FBP192R"",7,0)"
^XMB(3.9,145838,2,976,0)=" N DA,DIE,DR,LIST,OPT"
^XMB(3.9,145838,2,977,0)="""RTN"",""FBP192R"",8,0)"
^XMB(3.9,145838,2,978,0)=" ;"
^XMB(3.9,145838,2,979,0)="""RTN"",""FBP192R"",9,0)"
^XMB(3.9,145838,2,980,0)=" D SETUP"
^XMB(3.9,145838,2,981,0)="""RTN"",""FBP192R"",10,0)"
^XMB(3.9,145838,2,982,0)=" ;"
^XMB(3.9,145838,2,983,0)="""RTN"",""FBP192R"",11,0)"
^XMB(3.9,145838,2,984,0)=" S OPT="""""
^XMB(3.9,145838,2,985,0)="""RTN"",""FBP192R"",12,0)"
^XMB(3.9,145838,2,986,0)=" F  S OPT=$O(LIST(OPT)) Q:OPT=""""  D"
^XMB(3.9,145838,2,987,0)="""RTN"",""FBP192R"",13,0)"
^XMB(3.9,145838,2,988,0)=" . S DA=$$FIND1^DIC(19,"""",""B"",OPT)"
^XMB(3.9,145838,2,989,0)="""RTN"",""FBP192R"",14,0)"
^XMB(3.9,145838,2,990,0)=" . I $TR(LIST(OPT),""@"")=$$GET1^DIQ(19,DA,20) Q    ;Already rolled back"
^XMB(3.9,145838,2,991,0)="""RTN"",""FBP192R"",15,0)"
^XMB(3.9,145838,2,992,0)=" . S DIE=""^DIC(19,"",DR=""20///""_LIST(OPT) D ^DIE"
^XMB(3.9,145838,2,993,0)="""RTN"",""FBP192R"",16,0)"
^XMB(3.9,145838,2,994,0)=" Q"
^XMB(3.9,145838,2,995,0)="""RTN"",""FBP192R"",17,0)"
^XMB(3.9,145838,2,996,0)=" ;"
^XMB(3.9,145838,2,997,0)="""RTN"",""FBP192R"",18,0)"
^XMB(3.9,145838,2,998,0)="SETUP ;Set up the list of options with the original setting"
^XMB(3.9,145838,2,999,0)="""RTN"",""FBP192R"",19,0)"
^XMB(3.9,145838,2,1000,0)=" ;Format is LIST(OPT)=Original Entry Action setting"
^XMB(3.9,145838,2,1001,0)="""RTN"",""FBP192R"",20,0)"
^XMB(3.9,145838,2,1002,0)=" ;  OPT is the internal number of the option in File 19"
^XMB(3.9,145838,2,1003,0)="""RTN"",""FBP192R"",21,0)"
^XMB(3.9,145838,2,1004,0)=" ;  Entry Action = @ to delete the entry if the original is NULL"
^XMB(3.9,145838,2,1005,0)="""RTN"",""FBP192R"",22,0)"
^XMB(3.9,145838,2,1006,0)=" ;"
^XMB(3.9,145838,2,1007,0)="""RTN"",""FBP192R"",23,0)"
^XMB(3.9,145838,2,1008,0)=" S LIST(""FBCH PRINT 7078"")=""@"""
^XMB(3.9,145838,2,1009,0)="""RTN"",""FBP192R"",24,0)"
^XMB(3.9,145838,2,1010,0)=" S LIST(""FBCH ANCILLARY REIMBURSEMENT"")=""@"""
^XMB(3.9,145838,2,1011,0)="""RTN"",""FBP192R"",25,0)"
^XMB(3.9,145838,2,1012,0)=" S LIST(""FBCNH CENSUS REPORT"")=""S FBI=7"""
^XMB(3.9,145838,2,1013,0)="""RTN"",""FBP192R"",26,0)"
^XMB(3.9,145838,2,1014,0)=" S LIST(""FB PROJECT ARCH MENU"")=""@"""
^XMB(3.9,145838,2,1015,0)="""RTN"",""FBP192R"",27,0)"
^XMB(3.9,145838,2,1016,0)=" S LIST(""FB ADD ARCH ELIGIBILITY"")=""@"""
^XMB(3.9,145838,2,1017,0)="""RTN"",""FBP192R"",28,0)"
^XMB(3.9,145838,2,1018,0)=" S LIST(""FB ARCH DATA UPLOAD"")=""@"""
^XMB(3.9,145838,2,1019,0)="""RTN"",""FBP192R"",29,0)"
^XMB(3.9,145838,2,1020,0)=" S LIST(""FB ARCH REMINDER DELAY"")=""@"""
^XMB(3.9,145838,2,1021,0)="""RTN"",""FBP192R"",30,0)"
^XMB(3.9,145838,2,1022,0)=" S LIST(""FB VIEW ARCH ELIGIBILITY"")=""@"""
^XMB(3.9,145838,2,1023,0)="""RTN"",""FBP192R"",31,0)"
^XMB(3.9,145838,2,1024,0)=" S LIST(""FBAA MRA VETERAN DELETE TYPE"")=""S FBMTYPE=""""D"""" D ^FBAAPM"""
^XMB(3.9,145838,2,1025,0)="""RTN"",""FBP192R"",32,0)"
^XMB(3.9,145838,2,1026,0)=" S LIST(""FBAA MRA VETERAN REINSTATE"")=""S FBMTYPE=""""R"""" D ^FBAAPM"""
^XMB(3.9,145838,2,1027,0)="""RTN"",""FBP192R"",33,0)"
^XMB(3.9,145838,2,1028,0)=" S LIST(""FBAA PRINT 7079 GROUP"")=""@"""
^XMB(3.9,145838,2,1029,0)="""RTN"",""FBP192R"",34,0)"
^XMB(3.9,145838,2,1030,0)=" S LIST(""FBCH COST REPORT"")=""S FBTP=6,FBREF=""""FB7078"""""""
^XMB(3.9,145838,2,1031,0)="""RTN"",""FBP192R"",35,0)"
