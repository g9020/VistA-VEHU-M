^XMB(3.9,145833,2,2852,0)=" S MSH=0 F  S MSH=$O(@SDMSG@(MSH)) Q:MSH'>0  Q:$E(@SDMSG@(MSH),1,3)=""MSH"""
^XMB(3.9,145833,2,2853,0)="""RTN"",""SDHL7"",35,0)"
^XMB(3.9,145833,2,2854,0)=" I 'MSH S ERROR=""Missing or invalid MSH segment"" Q"
^XMB(3.9,145833,2,2855,0)="""RTN"",""SDHL7"",36,0)"
^XMB(3.9,145833,2,2856,0)=" S X=0,FAILMSA=0,HASMSA=0 F  S X=$O(@SDMSG@(X)) Q:X'>0!(ERROR'="""")!(HASMSA=1)  D"
^XMB(3.9,145833,2,2857,0)="""RTN"",""SDHL7"",37,0)"
^XMB(3.9,145833,2,2858,0)=" .S SEG=$P(@SDMSG@(X),""|""),NODE=$P(@SDMSG@(X),""|"",2,99)"
^XMB(3.9,145833,2,2859,0)="""RTN"",""SDHL7"",38,0)"
^XMB(3.9,145833,2,2860,0)=" .I SEG=""MSA"" S HASMSA=1"
