^XMB(3.9,145834,2,653,0)="""RTN"",""MAGBRTE4"",1,0)"
^XMB(3.9,145834,2,654,0)="MAGBRTE4 ;WOIFO/EdM,DAC,gek - Process Routing Rule Evaluation Queue ;"
