^XMB(3.9,145839,2,959,0)="""RTN"",""TIUCCRHL7P1"",206,0)"
^XMB(3.9,145839,2,960,0)=" K T2 S T2(""PLAN:"")=$C(10)_""PLAN:"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,961,0)="""RTN"",""TIUCCRHL7P1"",207,0)"
^XMB(3.9,145839,2,962,0)=" K T2,T4 S T4=""*** CC Plan may include specialty and associated appointment information, date of surgery, post-op needs, post d/c appointment, and any other care coordination plan ***"" D"
^XMB(3.9,145839,2,963,0)="""RTN"",""TIUCCRHL7P1"",208,0)"
^XMB(3.9,145839,2,964,0)=" .S T2(T4)=$C(10)_T4 S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,965,0)="""RTN"",""TIUCCRHL7P1"",209,0)"
^XMB(3.9,145839,2,966,0)=" K T2 S T2(""ADDITIONAL NOTES:"")=$C(10)_""ADDITIONAL NOTES:"" S WORDS=$$REPLACE^XLFSTR(WORDS,.T2)"
^XMB(3.9,145839,2,967,0)="""RTN"",""TIUCCRHL7P1"",210,0)"
^XMB(3.9,145839,2,968,0)=" S LEN=$L(WORDS),I1=1,XX=1,CNT=0,LCNT=0"
^XMB(3.9,145839,2,969,0)="""RTN"",""TIUCCRHL7P1"",211,0)"
^XMB(3.9,145839,2,970,0)=" F I=1:1:LEN D"
^XMB(3.9,145839,2,971,0)="""RTN"",""TIUCCRHL7P1"",212,0)"
^XMB(3.9,145839,2,972,0)=" .S LCNT=LCNT+1"
^XMB(3.9,145839,2,973,0)="""RTN"",""TIUCCRHL7P1"",213,0)"
^XMB(3.9,145839,2,974,0)=" .I LCNT>100&($E(WORDS,I)="" "")!($E(WORDS,I)=$C(160))!($E(WORDS,I)=$C(10)) D"
^XMB(3.9,145839,2,975,0)="""RTN"",""TIUCCRHL7P1"",214,0)"
^XMB(3.9,145839,2,976,0)=" ..S:XX=1 LINES(""TEXT"",XX,0)=$$TRIM^XLFSTR($E(WORDS,1,63),""LR""),XX=XX+1,I=64,LCNT=0,I1=I"
^XMB(3.9,145839,2,977,0)="""RTN"",""TIUCCRHL7P1"",215,0)"
^XMB(3.9,145839,2,978,0)=" ..Q:XX=1"
^XMB(3.9,145839,2,979,0)="""RTN"",""TIUCCRHL7P1"",216,0)"
^XMB(3.9,145839,2,980,0)=" ..S LINES(""TEXT"",XX,0)=$TR($E(WORDS,I1,I-1),$C(160),"" ""),LINES(""TEXT"",XX,0)=$$TRIM^XLFSTR(LINES(""TEXT"",XX,0),""LR""),XX=XX+1,LCNT=0  ;,I1=I"
^XMB(3.9,145839,2,981,0)="""RTN"",""TIUCCRHL7P1"",217,0)"
^XMB(3.9,145839,2,982,0)=" ..S I1=I"
^XMB(3.9,145839,2,983,0)="""RTN"",""TIUCCRHL7P1"",218,0)"
^XMB(3.9,145839,2,984,0)=" I I1'=LEN N LASTLINES S LASTLINES=$E(WORDS,I1,I) K T2 S T2($C(160)_"" "")="""" S LINES(""TEXT"",XX,0)=$$REPLACE^XLFSTR(LASTLINES,.T2)"
^XMB(3.9,145839,2,985,0)="""RTN"",""TIUCCRHL7P1"",219,0)"
^XMB(3.9,145839,2,986,0)=" M TIUZ(""TEXT"")=LINES(""TEXT"")"
^XMB(3.9,145839,2,987,0)="""RTN"",""TIUCCRHL7P1"",220,0)"
^XMB(3.9,145839,2,988,0)=" K LINES(""TEXT"")"
^XMB(3.9,145839,2,989,0)="""RTN"",""TIUCCRHL7P1"",221,0)"
^XMB(3.9,145839,2,990,0)=" Q"
^XMB(3.9,145839,2,991,0)="""RTN"",""TIUCCRHL7P4"")"
^XMB(3.9,145839,2,992,0)="0^4^B110218366"
^XMB(3.9,145839,2,993,0)="""RTN"",""TIUCCRHL7P4"",1,0)"
^XMB(3.9,145839,2,994,0)="TIUCCRHL7P4 ; CCRA/PB - TIU CCRA HL7 Msg Processing; January 6, 2006"
^XMB(3.9,145839,2,995,0)="""RTN"",""TIUCCRHL7P4"",2,0)"
^XMB(3.9,145839,2,996,0)=" ;;1.0;TEXT INTEGRATION UTILITIES;**344,356,371**;Sep 27, 2023;Build 0"
^XMB(3.9,145839,2,997,0)="""RTN"",""TIUCCRHL7P4"",3,0)"
^XMB(3.9,145839,2,998,0)=" ;"
^XMB(3.9,145839,2,999,0)="""RTN"",""TIUCCRHL7P4"",4,0)"
^XMB(3.9,145839,2,1000,0)=" ;PB - Patch 344 to modify how the note and addendum text is formatted"
^XMB(3.9,145839,2,1001,0)="""RTN"",""TIUCCRHL7P4"",5,0)"
^XMB(3.9,145839,2,1002,0)=" ;PB - Patch 356 modifications to file the note as a stand-alone note and not linked to a consult"
^XMB(3.9,145839,2,1003,0)="""RTN"",""TIUCCRHL7P4"",6,0)"
^XMB(3.9,145839,2,1004,0)=" ;PB - Patch 371 removes unused code"
^XMB(3.9,145839,2,1005,0)="""RTN"",""TIUCCRHL7P4"",7,0)"
^XMB(3.9,145839,2,1006,0)=" Q"
^XMB(3.9,145839,2,1007,0)="""RTN"",""TIUCCRHL7P4"",8,0)"
^XMB(3.9,145839,2,1008,0)="WORD ;"
^XMB(3.9,145839,2,1009,0)="""RTN"",""TIUCCRHL7P4"",9,0)"
^XMB(3.9,145839,2,1010,0)=" K I1,CNT,LCNT,LEN,I,LINES,T2,LASTWORDS,TEST1,WORDS,WORDSLEN,XX"
^XMB(3.9,145839,2,1011,0)="""RTN"",""TIUCCRHL7P4"",10,0)"
^XMB(3.9,145839,2,1012,0)=" S WORDS=$G(TIUZ(""TEXT"",1,0)),WORDSLEN=$L(TIUZ(""TEXT"",1,0))"
^XMB(3.9,145839,2,1013,0)="""RTN"",""TIUCCRHL7P4"",11,0)"
^XMB(3.9,145839,2,1014,0)=" I $G(ADDENDUM)'="""" D"
^XMB(3.9,145839,2,1015,0)="""RTN"",""TIUCCRHL7P4"",12,0)"
^XMB(3.9,145839,2,1016,0)=" .S:$G(NOTEDATE)="""" NOTEDATE=$$GETDATE"
^XMB(3.9,145839,2,1017,0)="""RTN"",""TIUCCRHL7P4"",13,0)"
^XMB(3.9,145839,2,1018,0)=" .S:$G(NOTENUM)="""" NOTENUM=$$NOTENUM"
^XMB(3.9,145839,2,1019,0)="""RTN"",""TIUCCRHL7P4"",14,0)"
^XMB(3.9,145839,2,1020,0)=" .S TIUIEN=$$TIULKUP^TIUCCHL7UT(CONSULTID,TIU(""TDA""),$G(NOTEDATE),$G(NOTENUM)) ;Patch 344 lookup the note in the consult to file the addendum with, Patch 356, changed VNUM to CONSULTID"
^XMB(3.9,145839,2,1021,0)="""RTN"",""TIUCCRHL7P4"",15,0)"
^XMB(3.9,145839,2,1022,0)=" F TEST1=1:1:WORDSLEN S LASTWORDS=$E(TIUZ(""TEXT"",1,0),WORDSLEN,(WORDSLEN-25))"
^XMB(3.9,145839,2,1023,0)="""RTN"",""TIUCCRHL7P4"",16,0)"
^XMB(3.9,145839,2,1024,0)=" I $G(ADDENDUM)[""ADDENDUM"" D"
^XMB(3.9,145839,2,1025,0)="""RTN"",""TIUCCRHL7P4"",17,0)"
^XMB(3.9,145839,2,1026,0)=" .I ADDENDUM[""APPOINTMENT MANAGEMENT ADDENDUM"" D AMA^TIUCCRHL7P5,FORMAT  ;done"
^XMB(3.9,145839,2,1027,0)="""RTN"",""TIUCCRHL7P4"",18,0)"
^XMB(3.9,145839,2,1028,0)=" .I ADDENDUM[""CARE COORDINATION FOLLOW UP ADDENDUM"" D CCFUA^TIUCCRHL7P6,FORMAT  ;done"
^XMB(3.9,145839,2,1029,0)="""RTN"",""TIUCCRHL7P4"",19,0)"
^XMB(3.9,145839,2,1030,0)=" .I ADDENDUM[""CASE MANAGEMENT ADDENDUM"" D CMA^TIUCCRHL7P6,FORMAT  ;done"
^XMB(3.9,145839,2,1031,0)="""RTN"",""TIUCCRHL7P4"",20,0)"
^XMB(3.9,145839,2,1032,0)=" .I ADDENDUM[""CONTINUED STAY REVIEW ADDENDUM"" D CSRA,FORMAT  ;done"
^XMB(3.9,145839,2,1033,0)="""RTN"",""TIUCCRHL7P4"",21,0)"
