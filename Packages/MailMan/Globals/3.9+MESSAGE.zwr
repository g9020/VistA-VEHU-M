^XMB(3.9,145831,2,1093,0)="""RTN"",""EDPVIT"",114,0)"
^XMB(3.9,145831,2,1094,0)=" N DFN,LOG,ADD,DEL,SCH,EDPI,LOC,TIME,ID,X1,X2"
^XMB(3.9,145831,2,1095,0)="""RTN"",""EDPVIT"",115,0)"
^XMB(3.9,145831,2,1096,0)=" S DFN=+$G(ARRAY(""context"",1,""/dfn"")) ;?!?"
^XMB(3.9,145831,2,1097,0)="""RTN"",""EDPVIT"",116,0)"
^XMB(3.9,145831,2,1098,0)=" I DFN<1 D ERR(""Missing or invalid patient DFN"") Q"
^XMB(3.9,145831,2,1099,0)="""RTN"",""EDPVIT"",117,0)"
^XMB(3.9,145831,2,1100,0)=" S LOG=+$G(ARRAY(""context"",1,""/log"")) ;?!?"
^XMB(3.9,145831,2,1101,0)="""RTN"",""EDPVIT"",118,0)"
^XMB(3.9,145831,2,1102,0)=" ; entered in error"
^XMB(3.9,145831,2,1103,0)="""RTN"",""EDPVIT"",119,0)"
^XMB(3.9,145831,2,1104,0)=" M DEL=ARRAY(""removeVitals"",1,""vitalMsmt"")"
^XMB(3.9,145831,2,1105,0)="""RTN"",""EDPVIT"",120,0)"
^XMB(3.9,145831,2,1106,0)=" F EDPI=1:1 S ID=$G(DEL(EDPI,""/id"")) Q:ID=""""  D"
^XMB(3.9,145831,2,1107,0)="""RTN"",""EDPVIT"",121,0)"
^XMB(3.9,145831,2,1108,0)=" . N DATA,EDPRES S DATA=ID_U_DUZ_U_$G(DEL(EDPI,""/reason""))"
^XMB(3.9,145831,2,1109,0)="""RTN"",""EDPVIT"",122,0)"
^XMB(3.9,145831,2,1110,0)=" . D ERROR^GMVUTL1(.EDPRES,DATA)"
^XMB(3.9,145831,2,1111,0)="""RTN"",""EDPVIT"",123,0)"
^XMB(3.9,145831,2,1112,0)=" ; add a new measurement"
^XMB(3.9,145831,2,1113,0)="""RTN"",""EDPVIT"",124,0)"
^XMB(3.9,145831,2,1114,0)=" M ADD=ARRAY(""addVital"",1,""vitalMsmt"")"
^XMB(3.9,145831,2,1115,0)="""RTN"",""EDPVIT"",125,0)"
^XMB(3.9,145831,2,1116,0)=" S LOC=$$DFLTLOC^EDPLPCE(DFN),TIME=$$NOW^XLFDT"
^XMB(3.9,145831,2,1117,0)="""RTN"",""EDPVIT"",126,0)"
^XMB(3.9,145831,2,1118,0)=" I LOC<1 D ERR(""Missing default ED Hospital Location"") Q"
^XMB(3.9,145831,2,1119,0)="""RTN"",""EDPVIT"",127,0)"
^XMB(3.9,145831,2,1120,0)=" F EDPI=1:1 S TYPE=$G(ADD(EDPI,""/name"")) Q:TYPE=""""  D"
^XMB(3.9,145831,2,1121,0)="""RTN"",""EDPVIT"",128,0)"
^XMB(3.9,145831,2,1122,0)=" . N IEN,DATA,EDPY,X"
^XMB(3.9,145831,2,1123,0)="""RTN"",""EDPVIT"",129,0)"
^XMB(3.9,145831,2,1124,0)=" . S X=$G(ADD(EDPI,""/value"")) Q:'$L(X)"
^XMB(3.9,145831,2,1125,0)="""RTN"",""EDPVIT"",130,0)"
^XMB(3.9,145831,2,1126,0)=" . ;ck /units, convert if necessary ??"
^XMB(3.9,145831,2,1127,0)="""RTN"",""EDPVIT"",131,0)"
^XMB(3.9,145831,2,1128,0)=" . S IEN=+$O(^GMRD(120.51,""C"",TYPE,0))"
^XMB(3.9,145831,2,1129,0)="""RTN"",""EDPVIT"",132,0)"
^XMB(3.9,145831,2,1130,0)=" . S DATA=TIME_U_DFN_U_IEN_"";""_X_U_LOC_U_DUZ"
^XMB(3.9,145831,2,1131,0)="""RTN"",""EDPVIT"",133,0)"
^XMB(3.9,145831,2,1132,0)=" . D EN1^GMVDCSAV(.EDPY,DATA) ;IA #4815"
^XMB(3.9,145831,2,1133,0)="""RTN"",""EDPVIT"",134,0)"
^XMB(3.9,145831,2,1134,0)=" ; save frequency"
^XMB(3.9,145831,2,1135,0)="""RTN"",""EDPVIT"",135,0)"
^XMB(3.9,145831,2,1136,0)=" M SCH=ARRAY(""schedule"",1) I $D(SCH),LOG D"
^XMB(3.9,145831,2,1137,0)="""RTN"",""EDPVIT"",136,0)"
^XMB(3.9,145831,2,1138,0)=" . S X1=+$G(SCH(""/frequency"")) ;ck units?"
^XMB(3.9,145831,2,1139,0)="""RTN"",""EDPVIT"",137,0)"
^XMB(3.9,145831,2,1140,0)=" . S X2=$S($G(SCH(""/repeatVitals""))=""true"":1,1:0)"
^XMB(3.9,145831,2,1141,0)="""RTN"",""EDPVIT"",138,0)"
^XMB(3.9,145831,2,1142,0)=" . S ^EDP(230,LOG,7)=X1_U_X2"
^XMB(3.9,145831,2,1143,0)="""RTN"",""EDPVIT"",139,0)"
^XMB(3.9,145831,2,1144,0)=" Q"
^XMB(3.9,145831,2,1145,0)="""VER"")"
^XMB(3.9,145831,2,1146,0)="8.0^22.2"
