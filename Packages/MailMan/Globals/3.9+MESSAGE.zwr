^XMB(3.9,145836,2,752,0)=" D CKP Q:$D(GMTSQIT)  W !"
^XMB(3.9,145836,2,753,0)="""RTN"",""GMTSPST1"",255,0)"
^XMB(3.9,145836,2,754,0)=" D TEXTPRNT(""FOOTER1"")"
^XMB(3.9,145836,2,755,0)="""RTN"",""GMTSPST1"",256,0)"
^XMB(3.9,145836,2,756,0)=" Q"
^XMB(3.9,145836,2,757,0)="""RTN"",""GMTSPST1"",257,0)"
^XMB(3.9,145836,2,758,0)="OPTFOOT ;Actual display for outpatient footer"
^XMB(3.9,145836,2,759,0)="""RTN"",""GMTSPST1"",258,0)"
^XMB(3.9,145836,2,760,0)=" N LASTREL,FOOTTXT,DAYSSUPP,STATUS"
^XMB(3.9,145836,2,761,0)="""RTN"",""GMTSPST1"",259,0)"
^XMB(3.9,145836,2,762,0)=" K ^TMP($J,""GMTSPST1"")"
^XMB(3.9,145836,2,763,0)="""RTN"",""GMTSPST1"",260,0)"
^XMB(3.9,145836,2,764,0)=" S PACKREF=$$PKGID^ORX8(ORDER)"
^XMB(3.9,145836,2,765,0)="""RTN"",""GMTSPST1"",261,0)"
^XMB(3.9,145836,2,766,0)=" S LASTREL=$$LRD(PACKREF)"
^XMB(3.9,145836,2,767,0)="""RTN"",""GMTSPST1"",262,0)"
^XMB(3.9,145836,2,768,0)=" Q:LASTREL<$$FMADD^XLFDT(DT,-365)"
^XMB(3.9,145836,2,769,0)="""RTN"",""GMTSPST1"",263,0)"
^XMB(3.9,145836,2,770,0)=" Q:$P(PSNUM,"";"")[""N"""
^XMB(3.9,145836,2,771,0)="""RTN"",""GMTSPST1"",264,0)"
^XMB(3.9,145836,2,772,0)=" D CKP Q:$D(GMTSQIT)"
^XMB(3.9,145836,2,773,0)="""RTN"",""GMTSPST1"",265,0)"
^XMB(3.9,145836,2,774,0)=" W !,""OPT ""_DRUGNM D CKP Q:$D(GMTSQIT)"
^XMB(3.9,145836,2,775,0)="""RTN"",""GMTSPST1"",266,0)"
^XMB(3.9,145836,2,776,0)=" D RX^PSO52API(DFN,""GMTSPST1"",PACKREF)"
^XMB(3.9,145836,2,777,0)="""RTN"",""GMTSPST1"",267,0)"
^XMB(3.9,145836,2,778,0)=" S STATUS=$P($G(^TMP($J,""GMTSPST1"",DFN,PACKREF,100)),U,2)"
^XMB(3.9,145836,2,779,0)="""RTN"",""GMTSPST1"",268,0)"
^XMB(3.9,145836,2,780,0)=" S DAYSSUPP=$G(^TMP($J,""GMTSPST1"",DFN,PACKREF,8))"
^XMB(3.9,145836,2,781,0)="""RTN"",""GMTSPST1"",269,0)"
^XMB(3.9,145836,2,782,0)=" S FOOTTXT=""(""_STATUS_""/""_DAYSSUPP_"" Days Supply Last Released: ""_$$FMTE^XLFDT(LASTREL,""2D"")_"")"""
^XMB(3.9,145836,2,783,0)="""RTN"",""GMTSPST1"",270,0)"
^XMB(3.9,145836,2,784,0)=" W $$RJ^XLFSTR(FOOTTXT,74) D CKP Q:$D(GMTSQIT)"
^XMB(3.9,145836,2,785,0)="""RTN"",""GMTSPST1"",271,0)"
^XMB(3.9,145836,2,786,0)=" S SIGLINE=0 F  S SIGLINE=$O(^TMP($J,""GMTSPST1"",DFN,PACKREF,""M"",SIGLINE)) Q:'+SIGLINE  D  Q:$D(GMTSQIT)"
^XMB(3.9,145836,2,787,0)="""RTN"",""GMTSPST1"",272,0)"
^XMB(3.9,145836,2,788,0)=" . W !?IND1,$G(^TMP($J,""GMTSPST1"",DFN,PACKREF,""M"",SIGLINE,0))"
^XMB(3.9,145836,2,789,0)="""RTN"",""GMTSPST1"",273,0)"
^XMB(3.9,145836,2,790,0)=" . D CKP"
^XMB(3.9,145836,2,791,0)="""RTN"",""GMTSPST1"",274,0)"
^XMB(3.9,145836,2,792,0)=" D CKP"
^XMB(3.9,145836,2,793,0)="""RTN"",""GMTSPST1"",275,0)"
^XMB(3.9,145836,2,794,0)=" Q"
^XMB(3.9,145836,2,795,0)="""RTN"",""GMTSPST1"",276,0)"
^XMB(3.9,145836,2,796,0)="NVADT() ;Replaces call previously in ^PSOQCF04"
^XMB(3.9,145836,2,797,0)="""RTN"",""GMTSPST1"",277,0)"
^XMB(3.9,145836,2,798,0)=" N NVAL,NVARR"
^XMB(3.9,145836,2,799,0)="""RTN"",""GMTSPST1"",278,0)"
^XMB(3.9,145836,2,800,0)=" D ^PSOHCSUM"
^XMB(3.9,145836,2,801,0)="""RTN"",""GMTSPST1"",279,0)"
^XMB(3.9,145836,2,802,0)=" Q:'$D(^TMP(""PSOO"",$J,""NVA"")) """""
^XMB(3.9,145836,2,803,0)="""RTN"",""GMTSPST1"",280,0)"
^XMB(3.9,145836,2,804,0)=" S NVAL=0 F  S NVAL=$O(^TMP(""PSOO"",$J,""NVA"",NVAL)) Q:'+NVAL  D"
^XMB(3.9,145836,2,805,0)="""RTN"",""GMTSPST1"",281,0)"
^XMB(3.9,145836,2,806,0)=" . S NVADT=9999999-$P($G(^TMP(""PSOO"",$J,""NVA"",NVAL,0)),""^"",5)"
^XMB(3.9,145836,2,807,0)="""RTN"",""GMTSPST1"",282,0)"
^XMB(3.9,145836,2,808,0)=" . S NVARR(NVADT)="""""
^XMB(3.9,145836,2,809,0)="""RTN"",""GMTSPST1"",283,0)"
^XMB(3.9,145836,2,810,0)=" S NVADT=$O(NVARR(0)) Q:NVADT=9999999 """""
^XMB(3.9,145836,2,811,0)="""RTN"",""GMTSPST1"",284,0)"
^XMB(3.9,145836,2,812,0)=" Q 9999999-NVADT"
^XMB(3.9,145836,2,813,0)="""RTN"",""GMTSPST1"",285,0)"
^XMB(3.9,145836,2,814,0)="LSIG(SIG) ;Expand a SIG"
^XMB(3.9,145836,2,815,0)="""RTN"",""GMTSPST1"",286,0)"
^XMB(3.9,145836,2,816,0)=" N P,SGY,X,%"
^XMB(3.9,145836,2,817,0)="""RTN"",""GMTSPST1"",287,0)"
^XMB(3.9,145836,2,818,0)=" S SGY="""" F P=1:1:$L(SIG,"" "") S X=$P(SIG,"" "",P) D:X]""""  ;"
^XMB(3.9,145836,2,819,0)="""RTN"",""GMTSPST1"",288,0)"
^XMB(3.9,145836,2,820,0)=" .I $D(^PS(51,""A"",X)) S %=^(X),X=$P(%,""^"") I $P(%,""^"",2)]"""" S Y=$P(SIG,"" "",P-1),Y=$E(Y,$L(Y)) S:Y>1 X=$P(%,""^"",2)"
^XMB(3.9,145836,2,821,0)="""RTN"",""GMTSPST1"",289,0)"
^XMB(3.9,145836,2,822,0)=" .S SGY=SGY_X_"" """
^XMB(3.9,145836,2,823,0)="""RTN"",""GMTSPST1"",290,0)"
^XMB(3.9,145836,2,824,0)=" Q SGY"
^XMB(3.9,145836,2,825,0)="""RTN"",""GMTSPST1"",291,0)"
^XMB(3.9,145836,2,826,0)="LRD(PACKREF) ;Calculate LAST RELEASE DATE as latest of original + refill relDates"
^XMB(3.9,145836,2,827,0)="""RTN"",""GMTSPST1"",292,0)"
^XMB(3.9,145836,2,828,0)=" N RELDT,REFDT,CTR,ANS"
^XMB(3.9,145836,2,829,0)="""RTN"",""GMTSPST1"",293,0)"
^XMB(3.9,145836,2,830,0)=" K ^TMP($J,""GMTSLRD"")"
^XMB(3.9,145836,2,831,0)="""RTN"",""GMTSPST1"",294,0)"
^XMB(3.9,145836,2,832,0)=" S ANS="""""
^XMB(3.9,145836,2,833,0)="""RTN"",""GMTSPST1"",295,0)"
^XMB(3.9,145836,2,834,0)=" D RX^PSO52API(DFN,""GMTSLRD"",PACKREF,,""3,R"")"
^XMB(3.9,145836,2,835,0)="""RTN"",""GMTSPST1"",296,0)"
^XMB(3.9,145836,2,836,0)=" S RELDT=$G(^TMP($J,""GMTSLRD"",DFN,PACKREF,31))"
^XMB(3.9,145836,2,837,0)="""RTN"",""GMTSPST1"",297,0)"
^XMB(3.9,145836,2,838,0)=" S ANS=RELDT"
^XMB(3.9,145836,2,839,0)="""RTN"",""GMTSPST1"",298,0)"
^XMB(3.9,145836,2,840,0)=" S CTR=0 F  S CTR=$O(^TMP($J,""GMTSLRD"",DFN,PACKREF,""RF"",CTR)) Q:'+CTR  D  ;"
^XMB(3.9,145836,2,841,0)="""RTN"",""GMTSPST1"",299,0)"
^XMB(3.9,145836,2,842,0)=" . S REFDT=$G(^TMP($J,""GMTSLRD"",DFN,PACKREF,""RF"",CTR,17))"
^XMB(3.9,145836,2,843,0)="""RTN"",""GMTSPST1"",300,0)"
^XMB(3.9,145836,2,844,0)=" . I REFDT>ANS S ANS=REFDT"
^XMB(3.9,145836,2,845,0)="""RTN"",""GMTSPST1"",301,0)"
^XMB(3.9,145836,2,846,0)=" K ^TMP($J,""GMTSLRD"")"
^XMB(3.9,145836,2,847,0)="""RTN"",""GMTSPST1"",302,0)"
^XMB(3.9,145836,2,848,0)=" Q ANS"
^XMB(3.9,145836,2,849,0)="""RTN"",""GMTSPST1"",303,0)"
^XMB(3.9,145836,2,850,0)=" ;"
^XMB(3.9,145836,2,851,0)="""RTN"",""GMTSPST1"",304,0)"
^XMB(3.9,145836,2,852,0)="CKP D CKP^GMTSUP Q"
^XMB(3.9,145836,2,853,0)="""RTN"",""GMTSPST1"",305,0)"
^XMB(3.9,145836,2,854,0)=" ;"
^XMB(3.9,145836,2,855,0)="""RTN"",""GMTSPST1"",306,0)"
^XMB(3.9,145836,2,856,0)="HEADTXT1 ;;"
^XMB(3.9,145836,2,857,0)="""RTN"",""GMTSPST1"",307,0)"
^XMB(3.9,145836,2,858,0)=" ;;INCLUDED IN THIS LIST:  Alphabetical list of active outpatient"
^XMB(3.9,145836,2,859,0)="""RTN"",""GMTSPST1"",308,0)"
^XMB(3.9,145836,2,860,0)=" ;;prescriptions dispensed from this VA (local) and dispensed from another"
^XMB(3.9,145836,2,861,0)="""RTN"",""GMTSPST1"",309,0)"
^XMB(3.9,145836,2,862,0)=" ;;VA or DoD facility (remote) as well as inpatient orders (local pending and"
^XMB(3.9,145836,2,863,0)="""RTN"",""GMTSPST1"",310,0)"
^XMB(3.9,145836,2,864,0)=" ;;active), local clinic medications, locally documented non-VA medications,"
^XMB(3.9,145836,2,865,0)="""RTN"",""GMTSPST1"",311,0)"
^XMB(3.9,145836,2,866,0)=" ;;and local prescriptions that have expired or been discontinued in the past"
^XMB(3.9,145836,2,867,0)="""RTN"",""GMTSPST1"",312,0)"
^XMB(3.9,145836,2,868,0)=" ;;90 days."
^XMB(3.9,145836,2,869,0)="""RTN"",""GMTSPST1"",313,0)"
^XMB(3.9,145836,2,870,0)=" ;;"
^XMB(3.9,145836,2,871,0)="""RTN"",""GMTSPST1"",314,0)"
^XMB(3.9,145836,2,872,0)=" ;;$$END"
^XMB(3.9,145836,2,873,0)="""RTN"",""GMTSPST1"",315,0)"
^XMB(3.9,145836,2,874,0)="HEADTXT2 ;;"
^XMB(3.9,145836,2,875,0)="""RTN"",""GMTSPST1"",316,0)"
^XMB(3.9,145836,2,876,0)=" ;;***NOTE*** The display of VA prescriptions dispensed from another VA or"
^XMB(3.9,145836,2,877,0)="""RTN"",""GMTSPST1"",317,0)"
^XMB(3.9,145836,2,878,0)=" ;;DoD facility (remote) is limited to active outpatient prescription entries"
^XMB(3.9,145836,2,879,0)="""RTN"",""GMTSPST1"",318,0)"
^XMB(3.9,145836,2,880,0)=" ;;matched to National Drug File at the originating site and may not include"
^XMB(3.9,145836,2,881,0)="""RTN"",""GMTSPST1"",319,0)"
^XMB(3.9,145836,2,882,0)=" ;;some items such as investigational drugs, compounds, etc."
^XMB(3.9,145836,2,883,0)="""RTN"",""GMTSPST1"",320,0)"
^XMB(3.9,145836,2,884,0)=" ;;"
^XMB(3.9,145836,2,885,0)="""RTN"",""GMTSPST1"",321,0)"
^XMB(3.9,145836,2,886,0)=" ;;NOT INCLUDED IN THIS LIST: Medications self-entered by the patient into"
^XMB(3.9,145836,2,887,0)="""RTN"",""GMTSPST1"",322,0)"
^XMB(3.9,145836,2,888,0)=" ;;personal health records (i.e. My HealtheVet) are NOT included in this"
^XMB(3.9,145836,2,889,0)="""RTN"",""GMTSPST1"",323,0)"
^XMB(3.9,145836,2,890,0)=" ;;list. Non-VA medications documented outside this VA, remote inpatient"
^XMB(3.9,145836,2,891,0)="""RTN"",""GMTSPST1"",324,0)"
^XMB(3.9,145836,2,892,0)=" ;;orders (regardless of status) and remote clinic medications are NOT"
^XMB(3.9,145836,2,893,0)="""RTN"",""GMTSPST1"",325,0)"
^XMB(3.9,145836,2,894,0)=" ;;included in this list. The patient and provider must always discuss"
^XMB(3.9,145836,2,895,0)="""RTN"",""GMTSPST1"",326,0)"
^XMB(3.9,145836,2,896,0)=" ;;medications the patient is taking, regardless of where the medication was"
^XMB(3.9,145836,2,897,0)="""RTN"",""GMTSPST1"",327,0)"
^XMB(3.9,145836,2,898,0)=" ;;dispensed or obtained."
^XMB(3.9,145836,2,899,0)="""RTN"",""GMTSPST1"",328,0)"
^XMB(3.9,145836,2,900,0)=" ;;$$END"
^XMB(3.9,145836,2,901,0)="""RTN"",""GMTSPST2"")"
