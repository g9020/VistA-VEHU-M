^XMB(3.9,145836,2,330,0)=" ;"
^XMB(3.9,145836,2,331,0)="""RTN"",""GMTSPST1"",44,0)"
^XMB(3.9,145836,2,332,0)="ADDREM ;USES RDI - REMOTE DATA INTEROPERABILITY TO INCORPORATE OUTSIDE MEDS"
^XMB(3.9,145836,2,333,0)="""RTN"",""GMTSPST1"",45,0)"
^XMB(3.9,145836,2,334,0)=" N DOWN,MED,RDI,RNAM,RNUM,STAT,ISSUE"
^XMB(3.9,145836,2,335,0)="""RTN"",""GMTSPST1"",46,0)"
^XMB(3.9,145836,2,336,0)=" Q:'$$HAVEHDR^ORRDI1"
^XMB(3.9,145836,2,337,0)="""RTN"",""GMTSPST1"",47,0)"
^XMB(3.9,145836,2,338,0)=" D  Q:$G(DOWN)  ;Check for outage of RDI"
^XMB(3.9,145836,2,339,0)="""RTN"",""GMTSPST1"",48,0)"
^XMB(3.9,145836,2,340,0)=" . I $D(^XTMP(""ORRDI"",""OUTAGE INFO"",""DOWN"")) H $$GET^XPAR(""ALL"",""ORRDI PING FREQ"")/2"
^XMB(3.9,145836,2,341,0)="""RTN"",""GMTSPST1"",49,0)"
^XMB(3.9,145836,2,342,0)=" . I $D(^XTMP(""ORRDI"",""OUTAGE INFO"",""DOWN"")) S DOWN=1 D  Q:$D(GMTSQIT)"
^XMB(3.9,145836,2,343,0)="""RTN"",""GMTSPST1"",50,0)"
^XMB(3.9,145836,2,344,0)=" .. D CKP Q:$D(GMTSQIT)"
^XMB(3.9,145836,2,345,0)="""RTN"",""GMTSPST1"",51,0)"
^XMB(3.9,145836,2,346,0)=" .. W !,""WARNING: Connection to Remote Data Currently Down"",!"
^XMB(3.9,145836,2,347,0)="""RTN"",""GMTSPST1"",52,0)"
^XMB(3.9,145836,2,348,0)=" .. D CKP"
^XMB(3.9,145836,2,349,0)="""RTN"",""GMTSPST1"",53,0)"
^XMB(3.9,145836,2,350,0)=" Q:$D(GMTSQIT)"
^XMB(3.9,145836,2,351,0)="""RTN"",""GMTSPST1"",54,0)"
^XMB(3.9,145836,2,352,0)=" ;Get data for HFS file structure"
^XMB(3.9,145836,2,353,0)="""RTN"",""GMTSPST1"",55,0)"
^XMB(3.9,145836,2,354,0)=" D SAVDEV^%ZISUTL(""GMTSHFS"")"
^XMB(3.9,145836,2,355,0)="""RTN"",""GMTSPST1"",56,0)"
^XMB(3.9,145836,2,356,0)=" S RDI=$$GET^ORRDI1(DFN,""PSOO"")"
^XMB(3.9,145836,2,357,0)="""RTN"",""GMTSPST1"",57,0)"
^XMB(3.9,145836,2,358,0)=" D USE^%ZISUTL(""GMTSHFS"")"
^XMB(3.9,145836,2,359,0)="""RTN"",""GMTSPST1"",58,0)"
^XMB(3.9,145836,2,360,0)=" D RMDEV^%ZISUTL(""GMTSHFS"")"
^XMB(3.9,145836,2,361,0)="""RTN"",""GMTSPST1"",59,0)"
^XMB(3.9,145836,2,362,0)=" ;"
^XMB(3.9,145836,2,363,0)="""RTN"",""GMTSPST1"",60,0)"
^XMB(3.9,145836,2,364,0)=" H 1 ;One extra second to allow ^XTMP replication across nodes"
