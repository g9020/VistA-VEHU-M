^XMB(3.9,144657,2,898,0)=" ;IB*737/CKB - IBBUFABORT is Newed in ACCEPT^IBCNBLA1"
^XMB(3.9,144657,2,899,0)="""RTN"",""IBCNBAA"",153,0)"
^XMB(3.9,144657,2,900,0)=" D ACCEPT^IBCNBAR(IBBUFDA,DFN,IBINSDA,IBGRPDA,.IBPOLDA,IBMVINS,IBMVGRP,IBMVPOL,IBMVSUB,IBNEWINS,IBNEWGRP,IBNEWPOL,IBELIG,IBSEL,IBRIEN,.IBSIEN,IBFNAM,IBVAL,.IBHOLD,.IBXHOLD)"
