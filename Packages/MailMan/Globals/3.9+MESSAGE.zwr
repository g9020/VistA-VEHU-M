^XMB(3.9,145831,2,1007,0)="""RTN"",""EDPVIT"",71,0)"
^XMB(3.9,145831,2,1008,0)=" S DFN=+$G(CTXT(""dfn"")),LOG=+$G(CTXT(""log""))"
^XMB(3.9,145831,2,1009,0)="""RTN"",""EDPVIT"",72,0)"
^XMB(3.9,145831,2,1010,0)=" I DFN<1 D ERR(""Missing or invalid patient DFN"") G RQ"
^XMB(3.9,145831,2,1011,0)="""RTN"",""EDPVIT"",73,0)"
^XMB(3.9,145831,2,1012,0)=" S END=9999999 D"
^XMB(3.9,145831,2,1013,0)="""RTN"",""EDPVIT"",74,0)"
^XMB(3.9,145831,2,1014,0)=" . I LOG S BEG=+$P($G(^EDP(230,LOG,0)),U,8) ;Time In"
^XMB(3.9,145831,2,1015,0)="""RTN"",""EDPVIT"",75,0)"
^XMB(3.9,145831,2,1016,0)=" . E  S BEG=$$FMADD^XLFDT($$NOW^XLFDT,-1)   ;Last 24 hours"
^XMB(3.9,145831,2,1017,0)="""RTN"",""EDPVIT"",76,0)"
^XMB(3.9,145831,2,1018,0)=" S GMRVSTR=""BP;T;R;P;HT;WT;CVP;CG;PO2;PN"",GMRVSTR(0)=BEG_U_END_""^9999999^1"""
^XMB(3.9,145831,2,1019,0)="""RTN"",""EDPVIT"",77,0)"
