^XMB(3.9,145834,2,6586,0)=" S J=0"
^XMB(3.9,145834,2,6587,0)="""RTN"",""MAGDSTAS"",183,0)"
^XMB(3.9,145834,2,6588,0)=" F  S J=$O(^MAGDSTT(2006.543,I,2,J)) Q:'J  D"
^XMB(3.9,145834,2,6589,0)="""RTN"",""MAGDSTAS"",184,0)"
^XMB(3.9,145834,2,6590,0)=" . S X=^MAGDSTT(2006.543,I,2,J,0)"
^XMB(3.9,145834,2,6591,0)="""RTN"",""MAGDSTAS"",185,0)"
^XMB(3.9,145834,2,6592,0)=" . S NAME=$P(X,""^"",1),VALUE=$P(X,""^"",2)"
^XMB(3.9,145834,2,6593,0)="""RTN"",""MAGDSTAS"",186,0)"
^XMB(3.9,145834,2,6594,0)=" . S ISTATS=$G(STATS(""XREF"",NAME))"
