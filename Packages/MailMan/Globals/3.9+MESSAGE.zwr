^XMB(3.9,144661,2,554,0)=" S R=0,ORAMGOOD=0,ORAMDATE=0"
^XMB(3.9,144661,2,555,0)="""RTN"",""ORAM1"",158,0)"
^XMB(3.9,144661,2,556,0)=" S ORAMSNO=0 F  S ORAMSNO=$O(^ORAM(103,DFN,3,ORAMSNO)) Q:'ORAMSNO  D"
^XMB(3.9,144661,2,557,0)="""RTN"",""ORAM1"",159,0)"
^XMB(3.9,144661,2,558,0)=" . N ORAMD0,ORAMINR,ORAMGOAL,ORAMGLOW,ORAMHIGH,LCNT,ORAMND"
^XMB(3.9,144661,2,559,0)="""RTN"",""ORAM1"",160,0)"
^XMB(3.9,144661,2,560,0)=" . S ORAMD0=$G(^ORAM(103,DFN,3,ORAMSNO,0)),LCNT=$P($G(^ORAM(103,DFN,3,ORAMSNO,1,0)),""^"",3)-1"
^XMB(3.9,144661,2,561,0)="""RTN"",""ORAM1"",161,0)"
^XMB(3.9,144661,2,562,0)=" . I $G(CMPLX)=1,$G(^ORAM(103,DFN,3,ORAMSNO,1,LCNT,0))[""COMPLEX PATIENT"" Q"
^XMB(3.9,144661,2,563,0)="""RTN"",""ORAM1"",162,0)"
^XMB(3.9,144661,2,564,0)=" . S ORAMND=$P(ORAMD0,""^""),ORAMINR=$P(ORAMD0,""^"",3),ORAMGOAL=$P(ORAMD0,""^"",12),ORAMGLOW=$P(ORAMGOAL,""-""),ORAMHIGH=$P(ORAMGOAL,""-"",2) S:ORAMHIGH["" "" ORAMHIGH=$P(ORAMHIGH,"" "",2)"
^XMB(3.9,144661,2,565,0)="""RTN"",""ORAM1"",163,0)"
^XMB(3.9,144661,2,566,0)=" . S ORAMGLOW=ORAMGLOW-(.1*ORAMGLOW),ORAMHIGH=ORAMHIGH+(.1*ORAMHIGH)"
^XMB(3.9,144661,2,567,0)="""RTN"",""ORAM1"",164,0)"
^XMB(3.9,144661,2,568,0)=" . I (ORAMND'=ORAMDATE)&(ORAMINR) S R=R+1,ORAMDATE=ORAMND I ((ORAMINR'<ORAMGLOW)&(ORAMINR'>ORAMHIGH)) S ORAMGOOD=ORAMGOOD+1"
^XMB(3.9,144661,2,569,0)="""RTN"",""ORAM1"",165,0)"
^XMB(3.9,144661,2,570,0)=" I R>0 S ORAMPC=(ORAMGOOD/R)*100,ORAMPC=$E(ORAMPC,1,4)"
^XMB(3.9,144661,2,571,0)="""RTN"",""ORAM1"",166,0)"
^XMB(3.9,144661,2,572,0)=" S RESULT=$G(ORAMPC)_""^""_$G(R)"
^XMB(3.9,144661,2,573,0)="""RTN"",""ORAM1"",167,0)"
^XMB(3.9,144661,2,574,0)="PCGOALQ Q"
^XMB(3.9,144661,2,575,0)="""RTN"",""ORAM1"",168,0)"
^XMB(3.9,144661,2,576,0)=" ;"
^XMB(3.9,144661,2,577,0)="""RTN"",""ORAM1"",169,0)"
^XMB(3.9,144661,2,578,0)="COMPTEST(RESULT,COMMARR) ; File Flow Sheet Data"
^XMB(3.9,144661,2,579,0)="""RTN"",""ORAM1"",170,0)"
^XMB(3.9,144661,2,580,0)=" ; RPC: ORAM1 COMPTEST"
^XMB(3.9,144661,2,581,0)="""RTN"",""ORAM1"",171,0)"
^XMB(3.9,144661,2,582,0)=" N ORAMDFN,ORAMZERO,ORAMCOMM,ORAMDT,ORAMX,ORAMCL,ORAMTEMP,ORAMSAVE,ORAMRD,ORAMCOMPL,ORAMCCNT,DA,DIK,R,X"
^XMB(3.9,144661,2,583,0)="""RTN"",""ORAM1"",172,0)"
^XMB(3.9,144661,2,584,0)=" N ORAMICNT,ORAMIOFF"
^XMB(3.9,144661,2,585,0)="""RTN"",""ORAM1"",173,0)"
^XMB(3.9,144661,2,586,0)=" S ORAMDFN=COMMARR(0),ORAMZERO=COMMARR(1),ORAMSAVE=COMMARR(2),ORAMRD=COMMARR(3),ORAMCOMPL=COMMARR(4),ORAMCCNT=COMMARR(5)"
^XMB(3.9,144661,2,587,0)="""RTN"",""ORAM1"",174,0)"
^XMB(3.9,144661,2,588,0)=" S ORAMIOFF=+ORAMCCNT+6,ORAMICNT=COMMARR(ORAMIOFF)"
^XMB(3.9,144661,2,589,0)="""RTN"",""ORAM1"",175,0)"
^XMB(3.9,144661,2,590,0)=" S ORAMTEMP=$P(ORAMZERO,""^"",1) D DT^DILF(,ORAMTEMP,.X) S $P(ORAMZERO,""^"",1)=$S($G(X)]"""":$G(X),1:DT)"
^XMB(3.9,144661,2,591,0)="""RTN"",""ORAM1"",176,0)"
^XMB(3.9,144661,2,592,0)=" S ORAMDT=$$NOW^XLFDT"
^XMB(3.9,144661,2,593,0)="""RTN"",""ORAM1"",177,0)"
^XMB(3.9,144661,2,594,0)=" S:$P(ORAMZERO,""^"",9)="""" $P(ORAMZERO,""^"",9)=ORAMDT"
^XMB(3.9,144661,2,595,0)="""RTN"",""ORAM1"",178,0)"
^XMB(3.9,144661,2,596,0)=" S ORAMX=$O(^ORAM(103,ORAMDFN,3,"" ""),-1)"
^XMB(3.9,144661,2,597,0)="""RTN"",""ORAM1"",179,0)"
^XMB(3.9,144661,2,598,0)=" I 'ORAMX S ORAMX=0"
^XMB(3.9,144661,2,599,0)="""RTN"",""ORAM1"",180,0)"
^XMB(3.9,144661,2,600,0)=" I $P(^ORAM(103,ORAMDFN,0),""^"",13)=""TEMPSAVE"" K DIK,DA S DIK=""^ORAM(103,""_ORAMDFN_"",3,"",DA(1)=ORAMDFN,DA=ORAMX D ^DIK"
^XMB(3.9,144661,2,601,0)="""RTN"",""ORAM1"",181,0)"
^XMB(3.9,144661,2,602,0)=" I $P(^ORAM(103,ORAMDFN,0),""^"",13)=""SAVE"" S ORAMX=ORAMX+1"
^XMB(3.9,144661,2,603,0)="""RTN"",""ORAM1"",182,0)"
^XMB(3.9,144661,2,604,0)=" ; Execute KILL Logic for cross-refs on update"
^XMB(3.9,144661,2,605,0)="""RTN"",""ORAM1"",183,0)"
^XMB(3.9,144661,2,606,0)=" I $D(^ORAM(103,ORAMDFN)) D"
^XMB(3.9,144661,2,607,0)="""RTN"",""ORAM1"",184,0)"
^XMB(3.9,144661,2,608,0)=" . S DIK=""^ORAM(103,"""
^XMB(3.9,144661,2,609,0)="""RTN"",""ORAM1"",185,0)"
^XMB(3.9,144661,2,610,0)=" . S DA=ORAMDFN"
^XMB(3.9,144661,2,611,0)="""RTN"",""ORAM1"",186,0)"
^XMB(3.9,144661,2,612,0)=" . D IX2^DIK"
^XMB(3.9,144661,2,613,0)="""RTN"",""ORAM1"",187,0)"
^XMB(3.9,144661,2,614,0)=" S ^ORAM(103,ORAMDFN,3,0)=""^103.011DA^""_ORAMX_""^""_ORAMX"
^XMB(3.9,144661,2,615,0)="""RTN"",""ORAM1"",188,0)"
^XMB(3.9,144661,2,616,0)=" S ^ORAM(103,ORAMDFN,3,ORAMX,0)=ORAMZERO"
^XMB(3.9,144661,2,617,0)="""RTN"",""ORAM1"",189,0)"
^XMB(3.9,144661,2,618,0)=" I $P(ORAMRD,U,4)]"""" S $P(^ORAM(103,ORAMDFN,6),U,1,4)=ORAMRD"
^XMB(3.9,144661,2,619,0)="""RTN"",""ORAM1"",190,0)"
^XMB(3.9,144661,2,620,0)=" E  S $P(^ORAM(103,ORAMDFN,6),U,1,3)=$P(ORAMRD,U,1,3)"
^XMB(3.9,144661,2,621,0)="""RTN"",""ORAM1"",191,0)"
^XMB(3.9,144661,2,622,0)=" ; If there are comments, file them"
^XMB(3.9,144661,2,623,0)="""RTN"",""ORAM1"",192,0)"
^XMB(3.9,144661,2,624,0)=" I +ORAMCCNT>0 F R=1:1:(ORAMCCNT) D"
^XMB(3.9,144661,2,625,0)="""RTN"",""ORAM1"",193,0)"
^XMB(3.9,144661,2,626,0)=" . S ^ORAM(103,ORAMDFN,3,ORAMX,1,R,0)=COMMARR(R+5)"
^XMB(3.9,144661,2,627,0)="""RTN"",""ORAM1"",194,0)"
^XMB(3.9,144661,2,628,0)=" . S ^ORAM(103,ORAMDFN,3,ORAMX,1,0)=""^^""_ORAMCCNT_""^""_ORAMCCNT_""^""_$P(ORAMZERO,""^"",1)_""^"""
^XMB(3.9,144661,2,629,0)="""RTN"",""ORAM1"",195,0)"
^XMB(3.9,144661,2,630,0)=" ; If there are complications, file them"
^XMB(3.9,144661,2,631,0)="""RTN"",""ORAM1"",196,0)"
^XMB(3.9,144661,2,632,0)=" I $L(ORAMCOMPL)>0 D"
^XMB(3.9,144661,2,633,0)="""RTN"",""ORAM1"",197,0)"
^XMB(3.9,144661,2,634,0)=" . N P1,P2,X"
^XMB(3.9,144661,2,635,0)="""RTN"",""ORAM1"",198,0)"
^XMB(3.9,144661,2,636,0)=" . S P1=$P(ORAMCOMPL,""|""),P2=$P(ORAMCOMPL,""|"",2)"
^XMB(3.9,144661,2,637,0)="""RTN"",""ORAM1"",199,0)"
^XMB(3.9,144661,2,638,0)=" . I P1>99 S P1=2 ;CLOT in the 100 range..."
^XMB(3.9,144661,2,639,0)="""RTN"",""ORAM1"",200,0)"
^XMB(3.9,144661,2,640,0)=" . E  I P1#10>0 S P1=1 ;MAJOR BLEED"
^XMB(3.9,144661,2,641,0)="""RTN"",""ORAM1"",201,0)"
^XMB(3.9,144661,2,642,0)=" . E  I P1=10 S P1=3 ;MINOR BLEED"
^XMB(3.9,144661,2,643,0)="""RTN"",""ORAM1"",202,0)"
^XMB(3.9,144661,2,644,0)=" . S:+$G(P1) $P(^ORAM(103,ORAMDFN,3,ORAMX,0),""^"",2)=P1"
^XMB(3.9,144661,2,645,0)="""RTN"",""ORAM1"",203,0)"
^XMB(3.9,144661,2,646,0)=" . F X=1:1:$L(P2,""^"") D"
^XMB(3.9,144661,2,647,0)="""RTN"",""ORAM1"",204,0)"
^XMB(3.9,144661,2,648,0)=" .. S ^ORAM(103,ORAMDFN,3,ORAMX,2,X,0)=$P(P2,""^"",X)"
^XMB(3.9,144661,2,649,0)="""RTN"",""ORAM1"",205,0)"
^XMB(3.9,144661,2,650,0)=" . S ^ORAM(103,ORAMDFN,3,ORAMX,2,0)=""^^""_$L(P2,""^"")-1_""^""_$L(P2,""^"")-1_""^""_$P(ORAMZERO,""^"",1)_""^"""
^XMB(3.9,144661,2,651,0)="""RTN"",""ORAM1"",206,0)"
^XMB(3.9,144661,2,652,0)=" ; If there are Patient Instructions, file them"
^XMB(3.9,144661,2,653,0)="""RTN"",""ORAM1"",207,0)"
^XMB(3.9,144661,2,654,0)=" I +ORAMICNT>0 F R=1:1:(ORAMICNT) D"
^XMB(3.9,144661,2,655,0)="""RTN"",""ORAM1"",208,0)"
^XMB(3.9,144661,2,656,0)=" . N ORLINE S ORLINE=COMMARR(R+ORAMIOFF)"
^XMB(3.9,144661,2,657,0)="""RTN"",""ORAM1"",209,0)"
^XMB(3.9,144661,2,658,0)=" . S ^ORAM(103,ORAMDFN,3,ORAMX,3,R,0)=$S(ORLINE="""":"" "",1:ORLINE)"
^XMB(3.9,144661,2,659,0)="""RTN"",""ORAM1"",210,0)"
^XMB(3.9,144661,2,660,0)=" . S ^ORAM(103,ORAMDFN,3,ORAMX,3,0)=""^^""_ORAMICNT_""^""_ORAMICNT_""^""_$P(ORAMZERO,""^"",1)_""^"""
^XMB(3.9,144661,2,661,0)="""RTN"",""ORAM1"",211,0)"
^XMB(3.9,144661,2,662,0)=" S ^ORAM(103,ORAMDFN,3,""B"",$P(ORAMZERO,""^"",1),ORAMX)="""""
^XMB(3.9,144661,2,663,0)="""RTN"",""ORAM1"",212,0)"
^XMB(3.9,144661,2,664,0)=" S $P(^ORAM(103,ORAMDFN,0),""^"",13)=ORAMSAVE"
^XMB(3.9,144661,2,665,0)="""RTN"",""ORAM1"",213,0)"
^XMB(3.9,144661,2,666,0)=" ; Update all cross-refs for Flow Sheet entry"
^XMB(3.9,144661,2,667,0)="""RTN"",""ORAM1"",214,0)"
^XMB(3.9,144661,2,668,0)=" S DIK=""^ORAM(103,"""
^XMB(3.9,144661,2,669,0)="""RTN"",""ORAM1"",215,0)"
^XMB(3.9,144661,2,670,0)=" S DA=ORAMDFN"
^XMB(3.9,144661,2,671,0)="""RTN"",""ORAM1"",216,0)"
^XMB(3.9,144661,2,672,0)=" D IX^DIK"
^XMB(3.9,144661,2,673,0)="""RTN"",""ORAM1"",217,0)"
^XMB(3.9,144661,2,674,0)=" S RESULT=1"
^XMB(3.9,144661,2,675,0)="""RTN"",""ORAM1"",218,0)"
^XMB(3.9,144661,2,676,0)=" Q"
^XMB(3.9,144661,2,677,0)="""RTN"",""ORAM1"",219,0)"
^XMB(3.9,144661,2,678,0)=" ;"
^XMB(3.9,144661,2,679,0)="""RTN"",""ORAM1"",220,0)"
^XMB(3.9,144661,2,680,0)="FLOWTT(RESULT,DFN) ; GETS ANTICOAG FLOWSHEET DATA"
^XMB(3.9,144661,2,681,0)="""RTN"",""ORAM1"",221,0)"
^XMB(3.9,144661,2,682,0)=" N FSARR,COMARR,ORAMI,ORI,ORX"
^XMB(3.9,144661,2,683,0)="""RTN"",""ORAM1"",222,0)"
^XMB(3.9,144661,2,684,0)=" S (ORI,ORAMI,ORX)=0"
^XMB(3.9,144661,2,685,0)="""RTN"",""ORAM1"",223,0)"
^XMB(3.9,144661,2,686,0)=" F  S ORI=$O(^ORAM(103,DFN,3,""B"",ORI)) Q:+ORI'>0  D"
^XMB(3.9,144661,2,687,0)="""RTN"",""ORAM1"",224,0)"
^XMB(3.9,144661,2,688,0)=" . N ORJ S ORJ=0"
^XMB(3.9,144661,2,689,0)="""RTN"",""ORAM1"",225,0)"
^XMB(3.9,144661,2,690,0)=" . F  S ORJ=$O(^ORAM(103,DFN,3,""B"",ORI,ORJ)) Q:+ORJ'>0  D"
^XMB(3.9,144661,2,691,0)="""RTN"",""ORAM1"",226,0)"
^XMB(3.9,144661,2,692,0)=" .. N ORAMACFS,ORAMCOM,ORAMCOMP,ORAMCC,ORAMPROV,ORAMLCNT,ORAMTOT,ORAMT,OUTSIDEHCT"
^XMB(3.9,144661,2,693,0)="""RTN"",""ORAM1"",227,0)"
^XMB(3.9,144661,2,694,0)=" .. S ORAMACFS=^ORAM(103,DFN,3,ORJ,0),ORAMCC=$P(ORAMACFS,U,2)"
^XMB(3.9,144661,2,695,0)="""RTN"",""ORAM1"",228,0)"
^XMB(3.9,144661,2,696,0)=" .. S OUTSIDEHCT=$P(^ORAM(103,DFN,6),U,4)"
^XMB(3.9,144661,2,697,0)="""RTN"",""ORAM1"",229,0)"
^XMB(3.9,144661,2,698,0)=" .. S ORAMCOM=$P(ORAMACFS,U),$P(ORAMACFS,U)=$$FMTE^XLFDT(ORAMCOM,""2P""),$P(ORAMACFS,U,2)=ORJ"
^XMB(3.9,144661,2,699,0)="""RTN"",""ORAM1"",230,0)"
^XMB(3.9,144661,2,700,0)=" .. S ORAMPROV=$P(ORAMACFS,U,10) I +$G(ORAMPROV) S $P(ORAMACFS,U,10)=$P(^VA(200,+ORAMPROV,0),U)"
^XMB(3.9,144661,2,701,0)="""RTN"",""ORAM1"",231,0)"
^XMB(3.9,144661,2,702,0)=" .. S ORAMLCNT=+$O(^ORAM(103,DFN,3,ORJ,1,""""),-1)"
^XMB(3.9,144661,2,703,0)="""RTN"",""ORAM1"",232,0)"
^XMB(3.9,144661,2,704,0)=" .. S ORAMCOMP=$O(^ORAM(103,DFN,3,ORJ,2,""""),-1)"
^XMB(3.9,144661,2,705,0)="""RTN"",""ORAM1"",233,0)"
^XMB(3.9,144661,2,706,0)=" .. S ORAMT=ORAMLCNT"
^XMB(3.9,144661,2,707,0)="""RTN"",""ORAM1"",234,0)"
^XMB(3.9,144661,2,708,0)=" .. S:+$G(ORAMCC) ORAMT=$G(ORAMLCNT)_"",""_$G(ORAMCOMP)"
^XMB(3.9,144661,2,709,0)="""RTN"",""ORAM1"",235,0)"
^XMB(3.9,144661,2,710,0)=" .. S ORAMTOT=$G(ORAMLCNT)+$G(ORAMCOMP)"
^XMB(3.9,144661,2,711,0)="""RTN"",""ORAM1"",236,0)"
^XMB(3.9,144661,2,712,0)=" .. I +$G(ORAMTOT) D"
^XMB(3.9,144661,2,713,0)="""RTN"",""ORAM1"",237,0)"
^XMB(3.9,144661,2,714,0)=" ... S RESULT(ORAMI)=$G(ORAMT)_""|""_$G(ORAMACFS)_U_OUTSIDEHCT"
^XMB(3.9,144661,2,715,0)="""RTN"",""ORAM1"",238,0)"
^XMB(3.9,144661,2,716,0)=" ... I +$G(ORAMLCNT) F ORX=(ORAMI+1):1:(ORAMLCNT+ORAMI) S RESULT(ORX)=$G(^ORAM(103,DFN,3,ORJ,1,(ORX-ORAMI),0))"
^XMB(3.9,144661,2,717,0)="""RTN"",""ORAM1"",239,0)"
^XMB(3.9,144661,2,718,0)=" ... I +$G(ORAMCC),+$G(ORAMCOMP) D"
^XMB(3.9,144661,2,719,0)="""RTN"",""ORAM1"",240,0)"
^XMB(3.9,144661,2,720,0)=" .... S ORAMI=ORX+2,RESULT(ORAMI)=""Complications noted:"""
^XMB(3.9,144661,2,721,0)="""RTN"",""ORAM1"",241,0)"
^XMB(3.9,144661,2,722,0)=" .... F ORX=(ORAMI+2):1:(ORAMCOMP+ORAMI) D"
^XMB(3.9,144661,2,723,0)="""RTN"",""ORAM1"",242,0)"
^XMB(3.9,144661,2,724,0)=" ..... N ORAMCMPL"
^XMB(3.9,144661,2,725,0)="""RTN"",""ORAM1"",243,0)"
^XMB(3.9,144661,2,726,0)=" ..... S ORAMCMPL=$G(^ORAM(103,DFN,3,ORJ,2,(ORX-ORAMI),0))"
^XMB(3.9,144661,2,727,0)="""RTN"",""ORAM1"",244,0)"
^XMB(3.9,144661,2,728,0)=" ..... S RESULT(ORX)=$S((ORAMCMPL[""MB:"")!(ORAMCMPL[""C:""):$P(ORAMCMPL,"":"",2),1:ORAMCMPL)"
^XMB(3.9,144661,2,729,0)="""RTN"",""ORAM1"",245,0)"
^XMB(3.9,144661,2,730,0)=" .. E  S RESULT(ORAMI+1)=""0|""_$G(ORAMACFS)"
^XMB(3.9,144661,2,731,0)="""RTN"",""ORAM1"",246,0)"
^XMB(3.9,144661,2,732,0)=" .. S ORAMI=ORX+1"
^XMB(3.9,144661,2,733,0)="""RTN"",""ORAM1"",247,0)"
^XMB(3.9,144661,2,734,0)=" Q"
^XMB(3.9,144661,2,735,0)="""RTN"",""ORAM1"",248,0)"
^XMB(3.9,144661,2,736,0)=" ;"
^XMB(3.9,144661,2,737,0)="""RTN"",""ORAM1"",249,0)"
^XMB(3.9,144661,2,738,0)="LOGIT(RESULT,FSARRAY,ORAMCOMP) ; RPC= ORAM1 LOG"
^XMB(3.9,144661,2,739,0)="""RTN"",""ORAM1"",250,0)"
^XMB(3.9,144661,2,740,0)=" N ORAMDATE,ORAMINR,ORAMPTN,ORAMTWD,ORAMLOG,ORAMLOGN,TODAY,TTIME,COUNT,ORAMODFN,ORAMOD,ORAMND,ORAMNEWD,AROW"
^XMB(3.9,144661,2,741,0)="""RTN"",""ORAM1"",251,0)"
^XMB(3.9,144661,2,742,0)=" N %,DA,DIK,ORAMDFN,ORAMRSF,R,X"
^XMB(3.9,144661,2,743,0)="""RTN"",""ORAM1"",252,0)"
^XMB(3.9,144661,2,744,0)=" S RESULT=0"
^XMB(3.9,144661,2,745,0)="""RTN"",""ORAM1"",253,0)"
^XMB(3.9,144661,2,746,0)=" D NOW^%DTC S TODAY=X,TTIME=%"
^XMB(3.9,144661,2,747,0)="""RTN"",""ORAM1"",254,0)"
^XMB(3.9,144661,2,748,0)=" ;FIRST GET THE OLD FLOW SHEET DATA AND SAVE TO THE LOG FILE"
^XMB(3.9,144661,2,749,0)="""RTN"",""ORAM1"",255,0)"
^XMB(3.9,144661,2,750,0)=" S ORAMDFN=$G(FSARRAY(0)),AROW=$G(FSARRAY(1))"
^XMB(3.9,144661,2,751,0)="""RTN"",""ORAM1"",256,0)"
^XMB(3.9,144661,2,752,0)=" S ORAMDATE=$P($G(^ORAM(103,ORAMDFN,3,AROW,0)),""^""),ORAMINR=$P($G(^ORAM(103,ORAMDFN,3,AROW,0)),""^"",3),ORAMPTN=$P($G(^ORAM(103,ORAMDFN,3,AROW,0)),""^"",8),ORAMTWD=$P($G(^ORAM(103,ORAMDFN,3,AROW,0)),""^"",6)"
^XMB(3.9,144661,2,753,0)="""RTN"",""ORAM1"",257,0)"
^XMB(3.9,144661,2,754,0)=" S ORAMODFN=$P($G(^ORAM(103,ORAMDFN,3,AROW,0)),""^"",10),ORAMOD=$P($G(^ORAM(103,ORAMDFN,3,AROW,0)),""^"",9)"
^XMB(3.9,144661,2,755,0)="""RTN"",""ORAM1"",258,0)"
^XMB(3.9,144661,2,756,0)=" S ORAMLOG=""Original FS ""_AROW_"": DATE=""_$G(ORAMDATE)_"", INR=""_$G(ORAMINR)_"", PT NOTIFIED=""_$G(ORAMPTN)_"", TWD=""_$G(ORAMTWD)_""; ""_ORAMODFN_"" (""_ORAMOD_""): EDITED: ""_FSARRAY(6)_""(""_TODAY_"")"""
^XMB(3.9,144661,2,757,0)="""RTN"",""ORAM1"",259,0)"
^XMB(3.9,144661,2,758,0)=" S ORAMLOGN=$P($G(^ORAM(103,ORAMDFN,3,AROW,""LOG"",0)),""^"",3)+1"
^XMB(3.9,144661,2,759,0)="""RTN"",""ORAM1"",260,0)"
^XMB(3.9,144661,2,760,0)=" S ^ORAM(103,ORAMDFN,3,AROW,""LOG"",ORAMLOGN,0)=ORAMLOG"
^XMB(3.9,144661,2,761,0)="""RTN"",""ORAM1"",261,0)"
^XMB(3.9,144661,2,762,0)=" K ^ORAM(103,ORAMDFN,3,""B"",$G(ORAMDATE),AROW)"
^XMB(3.9,144661,2,763,0)="""RTN"",""ORAM1"",262,0)"
^XMB(3.9,144661,2,764,0)=" F ORAMRSF=1:1:$P($G(^ORAM(103,ORAMDFN,3,AROW,1,0)),""^"",3) S COUNT=ORAMLOGN+ORAMRSF,^ORAM(103,ORAMDFN,3,AROW,""LOG"",COUNT,0)=^ORAM(103,ORAMDFN,3,AROW,1,ORAMRSF,0)"
^XMB(3.9,144661,2,765,0)="""RTN"",""ORAM1"",263,0)"
^XMB(3.9,144661,2,766,0)=" S ^ORAM(103,ORAMDFN,3,AROW,""LOG"",0)=""^^""_$G(COUNT)_""^""_$G(COUNT)_""^""_TODAY"
^XMB(3.9,144661,2,767,0)="""RTN"",""ORAM1"",264,0)"
^XMB(3.9,144661,2,768,0)=" ;NOW SET NEW INFO FOR THE FLOW SHEET ENTRY"
^XMB(3.9,144661,2,769,0)="""RTN"",""ORAM1"",265,0)"
^XMB(3.9,144661,2,770,0)=" ;Array order is: DFN;ARow;date;inr;ptnotified;twd;DUZ;#comment lines;comments"
^XMB(3.9,144661,2,771,0)="""RTN"",""ORAM1"",266,0)"
^XMB(3.9,144661,2,772,0)=" S ORAMNEWD=$G(FSARRAY(2)) D DT^DILF(,ORAMNEWD,.X) S ORAMNEWD=X"
^XMB(3.9,144661,2,773,0)="""RTN"",""ORAM1"",267,0)"
^XMB(3.9,144661,2,774,0)=" S $P(^ORAM(103,ORAMDFN,3,AROW,0),""^"")=$G(ORAMNEWD),$P(^ORAM(103,ORAMDFN,3,AROW,0),""^"",3)=$G(FSARRAY(3)),$P(^ORAM(103,ORAMDFN,3,AROW,0),""^"",8)=$G(FSARRAY(4)),$P(^ORAM(103,ORAMDFN,3,AROW,0),""^"",6)=$G(FSARRAY(5))"
^XMB(3.9,144661,2,775,0)="""RTN"",""ORAM1"",268,0)"
^XMB(3.9,144661,2,776,0)=" I $G(ORAMCOMP)=0 S $P(^ORAM(103,ORAMDFN,3,AROW,0),""^"",2)=0"
^XMB(3.9,144661,2,777,0)="""RTN"",""ORAM1"",269,0)"
^XMB(3.9,144661,2,778,0)=" S $P(^ORAM(103,ORAMDFN,3,AROW,0),""^"",10)=$G(FSARRAY(6)),$P(^ORAM(103,ORAMDFN,3,AROW,0),""^"",9)=TTIME"
^XMB(3.9,144661,2,779,0)="""RTN"",""ORAM1"",270,0)"
^XMB(3.9,144661,2,780,0)=" I $G(FSARRAY(7))'="""" K ^ORAM(103,ORAMDFN,3,AROW,1) F R=1:1:$G(FSARRAY(7)) D"
^XMB(3.9,144661,2,781,0)="""RTN"",""ORAM1"",271,0)"
^XMB(3.9,144661,2,782,0)=" . S ^ORAM(103,ORAMDFN,3,AROW,1,R,0)=$G(FSARRAY(R+7))"
^XMB(3.9,144661,2,783,0)="""RTN"",""ORAM1"",272,0)"
^XMB(3.9,144661,2,784,0)=" S ^ORAM(103,ORAMDFN,3,AROW,1,0)=""^^""_$G(FSARRAY(7))_""^""_$G(FSARRAY(7))_""^""_TODAY_""^""  ;$E(ORAMDT,1,7)_""^"""
^XMB(3.9,144661,2,785,0)="""RTN"",""ORAM1"",273,0)"
^XMB(3.9,144661,2,786,0)=" S ^ORAM(103,ORAMDFN,3,""B"",$G(ORAMNEWD),AROW)="""""
^XMB(3.9,144661,2,787,0)="""RTN"",""ORAM1"",274,0)"
^XMB(3.9,144661,2,788,0)=" S DIK=""^ORAM(103,"""
^XMB(3.9,144661,2,789,0)="""RTN"",""ORAM1"",275,0)"
^XMB(3.9,144661,2,790,0)=" S DA(1)=ORAMDFN,DA=AROW"
^XMB(3.9,144661,2,791,0)="""RTN"",""ORAM1"",276,0)"
^XMB(3.9,144661,2,792,0)=" D IX^DIK"
^XMB(3.9,144661,2,793,0)="""RTN"",""ORAM1"",277,0)"
^XMB(3.9,144661,2,794,0)=" S RESULT=1"
^XMB(3.9,144661,2,795,0)="""RTN"",""ORAM1"",278,0)"
^XMB(3.9,144661,2,796,0)=" Q"
^XMB(3.9,144661,2,797,0)="""RTN"",""ORAM1"",279,0)"
^XMB(3.9,144661,2,798,0)=" ;"
^XMB(3.9,144661,2,799,0)="""RTN"",""ORAM1"",280,0)"
^XMB(3.9,144661,2,800,0)="LOCK(RESULT,DATA) ; Locks form   RPC=ORAM1 LOCK"
^XMB(3.9,144661,2,801,0)="""RTN"",""ORAM1"",281,0)"
^XMB(3.9,144661,2,802,0)=" N X"
^XMB(3.9,144661,2,803,0)="""RTN"",""ORAM1"",282,0)"
^XMB(3.9,144661,2,804,0)=" S RESULT=0"
^XMB(3.9,144661,2,805,0)="""RTN"",""ORAM1"",283,0)"
^XMB(3.9,144661,2,806,0)=" Q:$P($G(DATA),""^"")="""""
^XMB(3.9,144661,2,807,0)="""RTN"",""ORAM1"",284,0)"
^XMB(3.9,144661,2,808,0)=" Q:$D(^ORAM(103,$P(DATA,""^"")))=0"
^XMB(3.9,144661,2,809,0)="""RTN"",""ORAM1"",285,0)"
^XMB(3.9,144661,2,810,0)=" D NOW^%DTC N ORAMTDAY S ORAMTDAY=X"
^XMB(3.9,144661,2,811,0)="""RTN"",""ORAM1"",286,0)"
^XMB(3.9,144661,2,812,0)=" I $P(^ORAM(103,$P(DATA,""^""),0),""^"",18,19)="""" S $P(^ORAM(103,$P(DATA,""^""),0),""^"",18)=""^"""
^XMB(3.9,144661,2,813,0)="""RTN"",""ORAM1"",287,0)"
^XMB(3.9,144661,2,814,0)=" S $P(^ORAM(103,$P(DATA,""^""),0),""^"",19)=1_""|""_$P(^VA(200,$P(DATA,""^"",2),0),""^"")_""|""_ORAMTDAY,RESULT=1"
^XMB(3.9,144661,2,815,0)="""RTN"",""ORAM1"",288,0)"
^XMB(3.9,144661,2,816,0)=" Q"
^XMB(3.9,144661,2,817,0)="""RTN"",""ORAM1"",289,0)"
^XMB(3.9,144661,2,818,0)=" ;"
^XMB(3.9,144661,2,819,0)="""RTN"",""ORAM1"",290,0)"
^XMB(3.9,144661,2,820,0)="UNLOCK(RESULT,DFN) ; Unlocks form  RPC=ORAM1 UNLOCK"
^XMB(3.9,144661,2,821,0)="""RTN"",""ORAM1"",291,0)"
^XMB(3.9,144661,2,822,0)=" S RESULT=0"
^XMB(3.9,144661,2,823,0)="""RTN"",""ORAM1"",292,0)"
^XMB(3.9,144661,2,824,0)=" Q:DFN<1"
^XMB(3.9,144661,2,825,0)="""RTN"",""ORAM1"",293,0)"
^XMB(3.9,144661,2,826,0)=" Q:$D(^ORAM(103,DFN))=0"
^XMB(3.9,144661,2,827,0)="""RTN"",""ORAM1"",294,0)"
^XMB(3.9,144661,2,828,0)=" S $P(^ORAM(103,DFN,0),""^"",19)=0,RESULT=1"
^XMB(3.9,144661,2,829,0)="""RTN"",""ORAM1"",295,0)"
^XMB(3.9,144661,2,830,0)=" Q"
^XMB(3.9,144661,2,831,0)="""RTN"",""ORAM1"",296,0)"
^XMB(3.9,144661,2,832,0)=" ;"
^XMB(3.9,144661,2,833,0)="""RTN"",""ORAM1"",297,0)"
^XMB(3.9,144661,2,834,0)="GETPT(RESULT) ; Get Pt list  RPC=ORAM1 PT LIST"
^XMB(3.9,144661,2,835,0)="""RTN"",""ORAM1"",298,0)"
^XMB(3.9,144661,2,836,0)=" N ORAMPT"
^XMB(3.9,144661,2,837,0)="""RTN"",""ORAM1"",299,0)"
^XMB(3.9,144661,2,838,0)=" S ORAMPT=0 F  S ORAMPT=$O(^ORAM(103,""B"",ORAMPT)) Q:ORAMPT=""""  D"
^XMB(3.9,144661,2,839,0)="""RTN"",""ORAM1"",300,0)"
^XMB(3.9,144661,2,840,0)=" . S RESULT($G(ORAMPT))=$G(ORAMPT)_""^""_$P(^DPT(ORAMPT,0),""^"")_""^""_$E($P(^DPT(ORAMPT,0),""^"",9),6,9)"
^XMB(3.9,144661,2,841,0)="""RTN"",""ORAM1"",301,0)"
^XMB(3.9,144661,2,842,0)=" Q"
^XMB(3.9,144661,2,843,0)="""RTN"",""ORAM1"",302,0)"
^XMB(3.9,144661,2,844,0)=" ;"
^XMB(3.9,144661,2,845,0)="""RTN"",""ORAM1"",303,0)"
^XMB(3.9,144661,2,846,0)="SETHCT(RESULT,ORAMORD) ; SET HCT LAB ITEM NUMBER"
^XMB(3.9,144661,2,847,0)="""RTN"",""ORAM1"",304,0)"
^XMB(3.9,144661,2,848,0)=" Q:'+$G(ORAMORD)"
^XMB(3.9,144661,2,849,0)="""RTN"",""ORAM1"",305,0)"
^XMB(3.9,144661,2,850,0)=" N ORAMX,ORAML60,ORAMCH S ORAMX=0 F  S ORAMX=$O(^ORD(101.43,$G(ORAMORD),10,ORAMX)) Q:'+$G(ORAMX)!+$G(ORAMCH)  D"
^XMB(3.9,144661,2,851,0)="""RTN"",""ORAM1"",306,0)"
^XMB(3.9,144661,2,852,0)=" . I $P(^ORD(101.43,$G(ORAMORD),10,ORAMX,0),""^"")[""HCT"" S ORAML60=+$P(^(0),""^"",2)"
^XMB(3.9,144661,2,853,0)="""RTN"",""ORAM1"",307,0)"
^XMB(3.9,144661,2,854,0)=" . I +$G(ORAML60) S ORAMCH=$P($P(^LAB(60,ORAML60,0),""^"",5),"";"",2) S RESULT=ORAMCH"
^XMB(3.9,144661,2,855,0)="""RTN"",""ORAM1"",308,0)"
^XMB(3.9,144661,2,856,0)=" Q"
^XMB(3.9,144661,2,857,0)="""RTN"",""ORAM1"",309,0)"
^XMB(3.9,144661,2,858,0)=" ;"
^XMB(3.9,144661,2,859,0)="""RTN"",""ORAMR617"")"
^XMB(3.9,144661,2,860,0)="0^^B930599"
^XMB(3.9,144661,2,861,0)="""RTN"",""ORAMR617"",1,0)"
^XMB(3.9,144661,2,862,0)="ORAMR617 ;SLC/MWA - Post Installation Tasks ; Oct 04, 2024@08:13:13"
^XMB(3.9,144661,2,863,0)="""RTN"",""ORAMR617"",2,0)"
^XMB(3.9,144661,2,864,0)=" ;;3.0;ORDER ENTRY/RESULTS REPORTING;**617**;Dec 17, 1997;Build 5"
^XMB(3.9,144661,2,865,0)="""RTN"",""ORAMR617"",3,0)"
^XMB(3.9,144661,2,866,0)=" ;;Per VA Directive 6402, this routine should not be modified."
^XMB(3.9,144661,2,867,0)="""RTN"",""ORAMR617"",4,0)"
^XMB(3.9,144661,2,868,0)=" ;"
^XMB(3.9,144661,2,869,0)="""RTN"",""ORAMR617"",5,0)"
^XMB(3.9,144661,2,870,0)=" ; This routine uses the following IAs:"
^XMB(3.9,144661,2,871,0)="""RTN"",""ORAMR617"",6,0)"
^XMB(3.9,144661,2,872,0)=" ; #10141 - MES^XPDUTL Kernel (supported)"
^XMB(3.9,144661,2,873,0)="""RTN"",""ORAMR617"",7,0)"
^XMB(3.9,144661,2,874,0)=" ; #2263 - EN^XPAR Kernel (supported)"
^XMB(3.9,144661,2,875,0)="""RTN"",""ORAMR617"",8,0)"
^XMB(3.9,144661,2,876,0)=" ;"
^XMB(3.9,144661,2,877,0)="""RTN"",""ORAMR617"",9,0)"
^XMB(3.9,144661,2,878,0)=" Q"
^XMB(3.9,144661,2,879,0)="""RTN"",""ORAMR617"",10,0)"
^XMB(3.9,144661,2,880,0)="EN ;"
^XMB(3.9,144661,2,881,0)="""RTN"",""ORAMR617"",11,0)"
^XMB(3.9,144661,2,882,0)=" ; Installing commands in the command file..."
^XMB(3.9,144661,2,883,0)="""RTN"",""ORAMR617"",12,0)"
^XMB(3.9,144661,2,884,0)=" D MES^XPDUTL(""OR*3.0*617 restore to OR*3.0*600 starting...."")"
^XMB(3.9,144661,2,885,0)="""RTN"",""ORAMR617"",13,0)"
^XMB(3.9,144661,2,886,0)=" ;"
^XMB(3.9,144661,2,887,0)="""RTN"",""ORAMR617"",14,0)"
^XMB(3.9,144661,2,888,0)=" D MES^XPDUTL(""Updating parameters..."")"
^XMB(3.9,144661,2,889,0)="""RTN"",""ORAMR617"",15,0)"
^XMB(3.9,144661,2,890,0)=" ; Update ORAM GUI VERSION with new build number for AntiCoagulate.exe."
^XMB(3.9,144661,2,891,0)="""RTN"",""ORAMR617"",16,0)"
^XMB(3.9,144661,2,892,0)=" D EN^XPAR(""SYS"",""ORAM GUI VERSION"",,""1.0.600.2"")"
^XMB(3.9,144661,2,893,0)="""RTN"",""ORAMR617"",17,0)"
^XMB(3.9,144661,2,894,0)=" D MES^XPDUTL(""Parameters updated."")"
^XMB(3.9,144661,2,895,0)="""RTN"",""ORAMR617"",18,0)"
^XMB(3.9,144661,2,896,0)=" ;"
^XMB(3.9,144661,2,897,0)="""RTN"",""ORAMR617"",19,0)"
^XMB(3.9,144661,2,898,0)=" D MES^XPDUTL(""OR*3.0*617 restore to OR*3.0*600 complete"")"
^XMB(3.9,144661,2,899,0)="""RTN"",""ORAMR617"",20,0)"
^XMB(3.9,144661,2,900,0)=" ;"
^XMB(3.9,144661,2,901,0)="""RTN"",""ORAMR617"",21,0)"
^XMB(3.9,144661,2,902,0)=" Q"
^XMB(3.9,144661,2,903,0)="""VER"")"
^XMB(3.9,144661,2,904,0)="8.0^22.2"
^XMB(3.9,144661,2,905,0)="$END KID OR*3.0*617b"
