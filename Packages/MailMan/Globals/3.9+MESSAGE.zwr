^XMB(3.9,145834,2,6351,0)="""RTN"",""MAGDSTAS"",65,0)"
^XMB(3.9,145834,2,6352,0)=" I $D(S2) D"
^XMB(3.9,145834,2,6353,0)="""RTN"",""MAGDSTAS"",66,0)"
^XMB(3.9,145834,2,6354,0)=" . W !,""The above statistics are only an estimate.  If the same scans are run"""
