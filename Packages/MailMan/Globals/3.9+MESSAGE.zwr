^XMB(3.9,144657,2,2578,0)=" I 'RESP G ECERRX"
^XMB(3.9,144657,2,2579,0)="""RTN"",""IBCNBLE1"",114,0)"
^XMB(3.9,144657,2,2580,0)=" S RESPDATA=$G(^IBCN(365,RESP,1))"
^XMB(3.9,144657,2,2581,0)="""RTN"",""IBCNBLE1"",115,0)"
^XMB(3.9,144657,2,2582,0)=" S ERRTXT=$P($G(^IBCN(365,RESP,4)),U,1)"
^XMB(3.9,144657,2,2583,0)="""RTN"",""IBCNBLE1"",116,0)"
^XMB(3.9,144657,2,2584,0)=" S TQIEN=+$P($G(^IBCN(365,RESP,0)),U,5)    ; Trans Queue file ien"
^XMB(3.9,144657,2,2585,0)="""RTN"",""IBCNBLE1"",117,0)"
^XMB(3.9,144657,2,2586,0)=" S FUTDT=$P($G(^IBCN(365.1,TQIEN,0)),U,9)  ; Future date to transmit"
