^XMB(3.9,145834,2,6520,0)=" W ! I $Y>(IOSL-4) D CONTINUE^MAGDSTQ(1)"
^XMB(3.9,145834,2,6521,0)="""RTN"",""MAGDSTAS"",150,0)"
^XMB(3.9,145834,2,6522,0)=" W ?15,ZEROIEN1,"" to "",ZEROIEN2"
^XMB(3.9,145834,2,6523,0)="""RTN"",""MAGDSTAS"",151,0)"
