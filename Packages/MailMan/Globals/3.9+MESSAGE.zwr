^XMB(3.9,145834,2,6343,0)="""RTN"",""MAGDSTAS"",61,0)"
^XMB(3.9,145834,2,6344,0)=" . F  S S2=$O(^MAGDSTT(2006.543,""C"",MENUOPTION,S2)) Q:S2=""""  D"
^XMB(3.9,145834,2,6345,0)="""RTN"",""MAGDSTAS"",62,0)"
^XMB(3.9,145834,2,6346,0)=" . . D OPTION(MENUOPTION,S2)"
^XMB(3.9,145834,2,6347,0)="""RTN"",""MAGDSTAS"",63,0)"
^XMB(3.9,145834,2,6348,0)=" . . Q"
^XMB(3.9,145834,2,6349,0)="""RTN"",""MAGDSTAS"",64,0)"
