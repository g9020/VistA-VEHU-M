^XMB(3.9,144656,2,243,0)="""RTN"",""IBAMTS1"")"
^XMB(3.9,144656,2,244,0)="0^1^B27614945"
^XMB(3.9,144656,2,245,0)="""RTN"",""IBAMTS1"",1,0)"
^XMB(3.9,144656,2,246,0)="IBAMTS1 ;ALB/CPM - PROCESS NEW OUTPATIENT ENCOUNTERS ; 22-JUL-93"
^XMB(3.9,144656,2,247,0)="""RTN"",""IBAMTS1"",2,0)"
^XMB(3.9,144656,2,248,0)=" ;;2.0;INTEGRATED BILLING;**20,52,132,153,166,156,167,247,339,614,760,817**;21-MAR-94;Build 0"
^XMB(3.9,144656,2,249,0)="""RTN"",""IBAMTS1"",3,0)"
^XMB(3.9,144656,2,250,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,144656,2,251,0)="""RTN"",""IBAMTS1"",4,0)"
^XMB(3.9,144656,2,252,0)=" ;"
^XMB(3.9,144656,2,253,0)="""RTN"",""IBAMTS1"",5,0)"
^XMB(3.9,144656,2,254,0)="NEW ; Appointment fully processed - prepare a new charge."
^XMB(3.9,144656,2,255,0)="""RTN"",""IBAMTS1"",6,0)"
^XMB(3.9,144656,2,256,0)=" ;"
^XMB(3.9,144656,2,257,0)="""RTN"",""IBAMTS1"",7,0)"
^XMB(3.9,144656,2,258,0)=" ;  ibbilled is set to 1 if the patient has already been billed on this"
^XMB(3.9,144656,2,259,0)="""RTN"",""IBAMTS1"",8,0)"
^XMB(3.9,144656,2,260,0)=" ;  date.  if the date is after 12/5/01, check the type of bill to see"
^XMB(3.9,144656,2,261,0)="""RTN"",""IBAMTS1"",9,0)"
^XMB(3.9,144656,2,262,0)=" ;  if it is an upgrade from primary (1st bill) to specialty (new bill)"
^XMB(3.9,144656,2,263,0)="""RTN"",""IBAMTS1"",10,0)"
^XMB(3.9,144656,2,264,0)=" I IBBILLED D:IBDAT'<3011206 CHKPRIM I IBBILLED G NEWQ"
^XMB(3.9,144656,2,265,0)="""RTN"",""IBAMTS1"",11,0)"
^XMB(3.9,144656,2,266,0)=" ;"
^XMB(3.9,144656,2,267,0)="""RTN"",""IBAMTS1"",12,0)"
^XMB(3.9,144656,2,268,0)=" ; - for registrations, get disposition, and use log-out date/time"
^XMB(3.9,144656,2,269,0)="""RTN"",""IBAMTS1"",13,0)"
^XMB(3.9,144656,2,270,0)=" I IBORG=3 D  G:'IBDISP NEWQ"
^XMB(3.9,144656,2,271,0)="""RTN"",""IBAMTS1"",14,0)"
^XMB(3.9,144656,2,272,0)=" .S IBDISP=+$P($G(^TMP(""SDEVT"",$J,SDHDL,IBORG,""DIS"",0,""AFTER"")),""^"",7)"
^XMB(3.9,144656,2,273,0)="""RTN"",""IBAMTS1"",15,0)"
^XMB(3.9,144656,2,274,0)=" .Q:'IBDISP"
^XMB(3.9,144656,2,275,0)="""RTN"",""IBAMTS1"",16,0)"
^XMB(3.9,144656,2,276,0)=" .S IBTEMP=+$P($G(^TMP(""SDEVT"",$J,SDHDL,IBORG,""DIS"",0,""AFTER"")),""^"",6)"
^XMB(3.9,144656,2,277,0)="""RTN"",""IBAMTS1"",17,0)"
^XMB(3.9,144656,2,278,0)=" .S:IBTEMP IBDT=IBTEMP,IBDAT=$P(IBDT,""."")"
^XMB(3.9,144656,2,279,0)="""RTN"",""IBAMTS1"",18,0)"
^XMB(3.9,144656,2,280,0)=" ;"
^XMB(3.9,144656,2,281,0)="""RTN"",""IBAMTS1"",19,0)"
^XMB(3.9,144656,2,282,0)=" I '$$BIL^DGMTUB(DFN,IBDT) G NEWQ ; patient is not Means Test billable"
^XMB(3.9,144656,2,283,0)="""RTN"",""IBAMTS1"",20,0)"
^XMB(3.9,144656,2,284,0)=" ;"
^XMB(3.9,144656,2,285,0)="""RTN"",""IBAMTS1"",21,0)"
^XMB(3.9,144656,2,286,0)=" ; - perform batch of edits"
^XMB(3.9,144656,2,287,0)="""RTN"",""IBAMTS1"",22,0)"
^XMB(3.9,144656,2,288,0)=" I '$$CHKS G NEWQ"
^XMB(3.9,144656,2,289,0)="""RTN"",""IBAMTS1"",23,0)"
^XMB(3.9,144656,2,290,0)=" ;"
^XMB(3.9,144656,2,291,0)="""RTN"",""IBAMTS1"",24,0)"
^XMB(3.9,144656,2,292,0)=" ; - quit if AO/IR/SWA/MST/HNC/CV/SHAD exposure is indicated, or SC related"
^XMB(3.9,144656,2,293,0)="""RTN"",""IBAMTS1"",25,0)"
^XMB(3.9,144656,2,294,0)=" D CLSF(0,.IBCLSF)"
^XMB(3.9,144656,2,295,0)="""RTN"",""IBAMTS1"",26,0)"
^XMB(3.9,144656,2,296,0)=" I IBCLSF[1 G NEWQ"
^XMB(3.9,144656,2,297,0)="""RTN"",""IBAMTS1"",27,0)"
^XMB(3.9,144656,2,298,0)=" ;"
^XMB(3.9,144656,2,299,0)="""RTN"",""IBAMTS1"",28,0)"
^XMB(3.9,144656,2,300,0)=" ; - quit if the Pt is Visit Copay exempt based on HRfS flag  (IB*2.0*614)"
^XMB(3.9,144656,2,301,0)="""RTN"",""IBAMTS1"",29,0)"
^XMB(3.9,144656,2,302,0)=" I $$CHKHRFS^IBAMTS3(DFN,IBDAT) G NEWQ"
^XMB(3.9,144656,2,303,0)="""RTN"",""IBAMTS1"",30,0)"
^XMB(3.9,144656,2,304,0)=" ;"
^XMB(3.9,144656,2,305,0)="""RTN"",""IBAMTS1"",31,0)"
^XMB(3.9,144656,2,306,0)=" I '$$CHKELIG(DFN) G NEWQ  ; quit if patient is exempt based on eligibility  IB*2.0*817"
^XMB(3.9,144656,2,307,0)="""RTN"",""IBAMTS1"",32,0)"
^XMB(3.9,144656,2,308,0)=" ;"
^XMB(3.9,144656,2,309,0)="""RTN"",""IBAMTS1"",33,0)"
^XMB(3.9,144656,2,310,0)=" S IBSL=""409.68:""_IBOE"
^XMB(3.9,144656,2,311,0)="""RTN"",""IBAMTS1"",34,0)"
^XMB(3.9,144656,2,312,0)=" ;"
^XMB(3.9,144656,2,313,0)="""RTN"",""IBAMTS1"",35,0)"
^XMB(3.9,144656,2,314,0)="BLD ; - build the charge. May also enter from IBAMTS2 (requires IBSL)"
^XMB(3.9,144656,2,315,0)="""RTN"",""IBAMTS1"",36,0)"
^XMB(3.9,144656,2,316,0)=" ;"
^XMB(3.9,144656,2,317,0)="""RTN"",""IBAMTS1"",37,0)"
^XMB(3.9,144656,2,318,0)=" ;  find the clinic stop code in 409.68 (dbia402) and find the matching"
^XMB(3.9,144656,2,319,0)="""RTN"",""IBAMTS1"",38,0)"
^XMB(3.9,144656,2,320,0)=" ;  entry in file 352.5.  the 352.5 entry is populated in the 350 field"
^XMB(3.9,144656,2,321,0)="""RTN"",""IBAMTS1"",39,0)"
^XMB(3.9,144656,2,322,0)=" ;  for reference using the ibstopda variable"
^XMB(3.9,144656,2,323,0)="""RTN"",""IBAMTS1"",40,0)"
^XMB(3.9,144656,2,324,0)=" N %,IBSTOPDA,IBTYPE"
^XMB(3.9,144656,2,325,0)="""RTN"",""IBAMTS1"",41,0)"
^XMB(3.9,144656,2,326,0)=" S %=$$GETSC^IBEMTSCU(IBSL,IBDAT) I % S IBSTOPDA=%"
^XMB(3.9,144656,2,327,0)="""RTN"",""IBAMTS1"",42,0)"
^XMB(3.9,144656,2,328,0)=" ;"
^XMB(3.9,144656,2,329,0)="""RTN"",""IBAMTS1"",43,0)"
^XMB(3.9,144656,2,330,0)=" ;  get the rate, ibtype = primary or specialty"
^XMB(3.9,144656,2,331,0)="""RTN"",""IBAMTS1"",44,0)"
^XMB(3.9,144656,2,332,0)=" S IBTYPE=$P($G(^IBE(352.5,+$G(IBSTOPDA),0)),""^"",3) I IBTYPE=0 Q"
^XMB(3.9,144656,2,333,0)="""RTN"",""IBAMTS1"",45,0)"
^XMB(3.9,144656,2,334,0)=" ;  if the type is not defined, must be a local created sc, set it to primary"
^XMB(3.9,144656,2,335,0)="""RTN"",""IBAMTS1"",46,0)"
^XMB(3.9,144656,2,336,0)=" I 'IBTYPE S IBTYPE=1"
^XMB(3.9,144656,2,337,0)="""RTN"",""IBAMTS1"",47,0)"
^XMB(3.9,144656,2,338,0)=" S IBX=""O"" D TYPE^IBAUTL2 G:IBY<0 NEWQ"
^XMB(3.9,144656,2,339,0)="""RTN"",""IBAMTS1"",48,0)"
^XMB(3.9,144656,2,340,0)=" S IBUNIT=1,(IBFR,IBTO)=IBDAT,IBEVDA=""*"""
^XMB(3.9,144656,2,341,0)="""RTN"",""IBAMTS1"",49,0)"
^XMB(3.9,144656,2,342,0)=" D ADD^IBECEAU3 G:IBY<0 NEWQ"
^XMB(3.9,144656,2,343,0)="""RTN"",""IBAMTS1"",50,0)"
^XMB(3.9,144656,2,344,0)=" ;"
^XMB(3.9,144656,2,345,0)="""RTN"",""IBAMTS1"",51,0)"
^XMB(3.9,144656,2,346,0)=" ; - if enctr is exempt from classification, but patient isn't, send msg"
^XMB(3.9,144656,2,347,0)="""RTN"",""IBAMTS1"",52,0)"
^XMB(3.9,144656,2,348,0)=" I $$EXOE^SDCOU2($S($G(IBOEN):IBOEN,1:IBOE)),$$CLPT(DFN,IBDAT) D BULL^IBAMTS"
^XMB(3.9,144656,2,349,0)="""RTN"",""IBAMTS1"",53,0)"
^XMB(3.9,144656,2,350,0)=" ;"
^XMB(3.9,144656,2,351,0)="""RTN"",""IBAMTS1"",54,0)"
^XMB(3.9,144656,2,352,0)=" ; - if the opt billing rate is over a year old, place the charge on hold"
^XMB(3.9,144656,2,353,0)="""RTN"",""IBAMTS1"",55,0)"
^XMB(3.9,144656,2,354,0)=" ;I $$OLDRATE(IBRTED,IBFR) D  G CLOCK"
^XMB(3.9,144656,2,355,0)="""RTN"",""IBAMTS1"",56,0)"
^XMB(3.9,144656,2,356,0)=" ;.S DIE=""^IB("",DA=IBN,DR="".05////20"" D ^DIE K DIE,DA,DR"
^XMB(3.9,144656,2,357,0)="""RTN"",""IBAMTS1"",57,0)"
^XMB(3.9,144656,2,358,0)=" ;"
^XMB(3.9,144656,2,359,0)="""RTN"",""IBAMTS1"",58,0)"
^XMB(3.9,144656,2,360,0)=" ; - drop the charge into the background filer"
^XMB(3.9,144656,2,361,0)="""RTN"",""IBAMTS1"",59,0)"
^XMB(3.9,144656,2,362,0)=" D IBFLR G:IBY<0 NEWQ"
^XMB(3.9,144656,2,363,0)="""RTN"",""IBAMTS1"",60,0)"
^XMB(3.9,144656,2,364,0)=" ;"
^XMB(3.9,144656,2,365,0)="""RTN"",""IBAMTS1"",61,0)"
^XMB(3.9,144656,2,366,0)=" ; - if there is no active billing clock, add one"
^XMB(3.9,144656,2,367,0)="""RTN"",""IBAMTS1"",62,0)"
^XMB(3.9,144656,2,368,0)="CLOCK I '$D(^IBE(351,""ACT"",DFN)) S IBCLDT=IBDAT D CLADD^IBAUTL3"
^XMB(3.9,144656,2,369,0)="""RTN"",""IBAMTS1"",63,0)"
^XMB(3.9,144656,2,370,0)=" ;"
^XMB(3.9,144656,2,371,0)="""RTN"",""IBAMTS1"",64,0)"
^XMB(3.9,144656,2,372,0)="NEWQ I IBY<0 D ^IBAERR1"
^XMB(3.9,144656,2,373,0)="""RTN"",""IBAMTS1"",65,0)"
^XMB(3.9,144656,2,374,0)=" K IBDISP,IBCLSF,IBCLDA,IBMED,IBCLDT,IBN,IBBS,IBTEMP"
^XMB(3.9,144656,2,375,0)="""RTN"",""IBAMTS1"",66,0)"
^XMB(3.9,144656,2,376,0)=" K IBUNIT,IBFR,IBTO,IBSL,IBEVDA,IBX,IBDESC,IBATYP,IBCHG"
^XMB(3.9,144656,2,377,0)="""RTN"",""IBAMTS1"",67,0)"
^XMB(3.9,144656,2,378,0)=" Q"
^XMB(3.9,144656,2,379,0)="""RTN"",""IBAMTS1"",68,0)"
^XMB(3.9,144656,2,380,0)=" ;"
^XMB(3.9,144656,2,381,0)="""RTN"",""IBAMTS1"",69,0)"
^XMB(3.9,144656,2,382,0)="CHKS() ; Perform a batch of edits to determine whether to bill."
^XMB(3.9,144656,2,383,0)="""RTN"",""IBAMTS1"",70,0)"
^XMB(3.9,144656,2,384,0)=" ;  Input variables required:   IBEVT  --  encounter"
^XMB(3.9,144656,2,385,0)="""RTN"",""IBAMTS1"",71,0)"
^XMB(3.9,144656,2,386,0)=" ;                             IBAPTY  --  appt type"
^XMB(3.9,144656,2,387,0)="""RTN"",""IBAMTS1"",72,0)"
^XMB(3.9,144656,2,388,0)=" ;                              IBDAT  --  appt date"
^XMB(3.9,144656,2,389,0)="""RTN"",""IBAMTS1"",73,0)"
^XMB(3.9,144656,2,390,0)=" ;                               IBDT  --  appt date/time"
^XMB(3.9,144656,2,391,0)="""RTN"",""IBAMTS1"",74,0)"
^XMB(3.9,144656,2,392,0)=" ;                              IBORG  --  originating process"
^XMB(3.9,144656,2,393,0)="""RTN"",""IBAMTS1"",75,0)"
^XMB(3.9,144656,2,394,0)=" ;                             IBDISP  --  disposition (if registration)"
^XMB(3.9,144656,2,395,0)="""RTN"",""IBAMTS1"",76,0)"
^XMB(3.9,144656,2,396,0)=" N IBRESULT"
^XMB(3.9,144656,2,397,0)="""RTN"",""IBAMTS1"",77,0)"
^XMB(3.9,144656,2,398,0)=" ;"
^XMB(3.9,144656,2,399,0)="""RTN"",""IBAMTS1"",78,0)"
^XMB(3.9,144656,2,400,0)=" ;  default is fail the checks"
^XMB(3.9,144656,2,401,0)="""RTN"",""IBAMTS1"",79,0)"
^XMB(3.9,144656,2,402,0)=" S IBRESULT=0"
^XMB(3.9,144656,2,403,0)="""RTN"",""IBAMTS1"",80,0)"
^XMB(3.9,144656,2,404,0)=" ;"
^XMB(3.9,144656,2,405,0)="""RTN"",""IBAMTS1"",81,0)"
^XMB(3.9,144656,2,406,0)=" ;  for appts prior to 12/6/2001"
^XMB(3.9,144656,2,407,0)="""RTN"",""IBAMTS1"",82,0)"
^XMB(3.9,144656,2,408,0)=" I IBDAT<3011206 D  Q IBRESULT"
^XMB(3.9,144656,2,409,0)="""RTN"",""IBAMTS1"",83,0)"
^XMB(3.9,144656,2,410,0)=" .   ; - non-count clinic"
^XMB(3.9,144656,2,411,0)="""RTN"",""IBAMTS1"",84,0)"
^XMB(3.9,144656,2,412,0)=" .   I $P($G(^SC(+$P(IBEVT,""^"",4),0)),""^"",17)=""Y"" Q"
^XMB(3.9,144656,2,413,0)="""RTN"",""IBAMTS1"",85,0)"
^XMB(3.9,144656,2,414,0)=" .   ;"
^XMB(3.9,144656,2,415,0)="""RTN"",""IBAMTS1"",86,0)"
^XMB(3.9,144656,2,416,0)=" .   ; - non-billable appointment type"
^XMB(3.9,144656,2,417,0)="""RTN"",""IBAMTS1"",87,0)"
^XMB(3.9,144656,2,418,0)=" .   I $$IGN^IBEFUNC(IBAPTY,IBDAT) Q"
^XMB(3.9,144656,2,419,0)="""RTN"",""IBAMTS1"",88,0)"
^XMB(3.9,144656,2,420,0)=" .   ;"
^XMB(3.9,144656,2,421,0)="""RTN"",""IBAMTS1"",89,0)"
^XMB(3.9,144656,2,422,0)=" .   ; - non-billable disposition/stop code/clinic"
^XMB(3.9,144656,2,423,0)="""RTN"",""IBAMTS1"",90,0)"
^XMB(3.9,144656,2,424,0)=" .   I IBORG=1!(IBORG=2),$$NBCL^IBEFUNC(+$P(IBEVT,""^"",4),IBDT) Q"
^XMB(3.9,144656,2,425,0)="""RTN"",""IBAMTS1"",91,0)"
^XMB(3.9,144656,2,426,0)=" .   I IBORG=1!(IBORG=2),$$NBCSC^IBEFUNC(+$P(IBEVT,""^"",3),IBDT) Q"
^XMB(3.9,144656,2,427,0)="""RTN"",""IBAMTS1"",92,0)"
^XMB(3.9,144656,2,428,0)=" .   I IBORG=3,$$NBDIS^IBEFUNC(IBDISP,IBDT) Q"
^XMB(3.9,144656,2,429,0)="""RTN"",""IBAMTS1"",93,0)"
^XMB(3.9,144656,2,430,0)=" .   ;"
^XMB(3.9,144656,2,431,0)="""RTN"",""IBAMTS1"",94,0)"
^XMB(3.9,144656,2,432,0)=" .   ; - ignore if checked out late and pt was an inpatient at midnight"
^XMB(3.9,144656,2,433,0)="""RTN"",""IBAMTS1"",95,0)"
^XMB(3.9,144656,2,434,0)=" .   I DT>IBDAT,$$INPT(DFN,IBDAT_"".2359"") Q"
^XMB(3.9,144656,2,435,0)="""RTN"",""IBAMTS1"",96,0)"
^XMB(3.9,144656,2,436,0)=" .   ;"
^XMB(3.9,144656,2,437,0)="""RTN"",""IBAMTS1"",97,0)"
^XMB(3.9,144656,2,438,0)=" .   ;  pass the checks"
^XMB(3.9,144656,2,439,0)="""RTN"",""IBAMTS1"",98,0)"
^XMB(3.9,144656,2,440,0)=" .   S IBRESULT=1"
^XMB(3.9,144656,2,441,0)="""RTN"",""IBAMTS1"",99,0)"
^XMB(3.9,144656,2,442,0)=" ;"
^XMB(3.9,144656,2,443,0)="""RTN"",""IBAMTS1"",100,0)"
^XMB(3.9,144656,2,444,0)=" ;  for appts on or after 12/6/2001"
^XMB(3.9,144656,2,445,0)="""RTN"",""IBAMTS1"",101,0)"
^XMB(3.9,144656,2,446,0)=" ;"
^XMB(3.9,144656,2,447,0)="""RTN"",""IBAMTS1"",102,0)"
^XMB(3.9,144656,2,448,0)=" ; - non-billable appointment type"
^XMB(3.9,144656,2,449,0)="""RTN"",""IBAMTS1"",103,0)"
^XMB(3.9,144656,2,450,0)=" I $$IGN^IBEFUNC(IBAPTY,IBDAT) Q 0"
^XMB(3.9,144656,2,451,0)="""RTN"",""IBAMTS1"",104,0)"
^XMB(3.9,144656,2,452,0)=" ;"
^XMB(3.9,144656,2,453,0)="""RTN"",""IBAMTS1"",105,0)"
^XMB(3.9,144656,2,454,0)=" ; - non-count clinic"
^XMB(3.9,144656,2,455,0)="""RTN"",""IBAMTS1"",106,0)"
^XMB(3.9,144656,2,456,0)=" I $P($G(^SC(+$P(IBEVT,""^"",4),0)),""^"",17)=""Y"" Q 0"
^XMB(3.9,144656,2,457,0)="""RTN"",""IBAMTS1"",107,0)"
^XMB(3.9,144656,2,458,0)=" ;"
^XMB(3.9,144656,2,459,0)="""RTN"",""IBAMTS1"",108,0)"
^XMB(3.9,144656,2,460,0)=" ; - ignore if checked out late and pt was an inpatient at midnight"
^XMB(3.9,144656,2,461,0)="""RTN"",""IBAMTS1"",109,0)"
^XMB(3.9,144656,2,462,0)=" I DT>IBDAT,$$INPT(DFN,IBDAT_"".2359"") Q 0"
^XMB(3.9,144656,2,463,0)="""RTN"",""IBAMTS1"",110,0)"
^XMB(3.9,144656,2,464,0)=" ;"
^XMB(3.9,144656,2,465,0)="""RTN"",""IBAMTS1"",111,0)"
^XMB(3.9,144656,2,466,0)=" ;  pass the checks"
^XMB(3.9,144656,2,467,0)="""RTN"",""IBAMTS1"",112,0)"
^XMB(3.9,144656,2,468,0)=" Q 1"
^XMB(3.9,144656,2,469,0)="""RTN"",""IBAMTS1"",113,0)"
^XMB(3.9,144656,2,470,0)=" ;"
^XMB(3.9,144656,2,471,0)="""RTN"",""IBAMTS1"",114,0)"
^XMB(3.9,144656,2,472,0)=" ;"
^XMB(3.9,144656,2,473,0)="""RTN"",""IBAMTS1"",115,0)"
^XMB(3.9,144656,2,474,0)="IBFLR ; Drop the charge into the IB Background filer."
^XMB(3.9,144656,2,475,0)="""RTN"",""IBAMTS1"",116,0)"
^XMB(3.9,144656,2,476,0)=" N IBSEQNO,IBNOS,IBNOW,IBTOTL,IBSERV,IBWHER,IBFAC,IBSITE,IBAFY,IBARTYP,IBIL,IBTRAN"
^XMB(3.9,144656,2,477,0)="""RTN"",""IBAMTS1"",117,0)"
^XMB(3.9,144656,2,478,0)=" D NOW^%DTC S IBNOW=%,IBNOS=IBN"
^XMB(3.9,144656,2,479,0)="""RTN"",""IBAMTS1"",118,0)"
^XMB(3.9,144656,2,480,0)=" S IBSEQNO=$P($G(^IBE(350.1,+IBATYP,0)),""^"",5) I 'IBSEQNO S IBY=""-1^IB023"""
^XMB(3.9,144656,2,481,0)="""RTN"",""IBAMTS1"",119,0)"
^XMB(3.9,144656,2,482,0)=" I IBY>0 D ^IBAFIL"
^XMB(3.9,144656,2,483,0)="""RTN"",""IBAMTS1"",120,0)"
^XMB(3.9,144656,2,484,0)=" Q"
^XMB(3.9,144656,2,485,0)="""RTN"",""IBAMTS1"",121,0)"
^XMB(3.9,144656,2,486,0)=" ;"
^XMB(3.9,144656,2,487,0)="""RTN"",""IBAMTS1"",122,0)"
^XMB(3.9,144656,2,488,0)="CLPT(DFN,VDATE) ; Should the patient be asked the classification questions?"
^XMB(3.9,144656,2,489,0)="""RTN"",""IBAMTS1"",123,0)"
^XMB(3.9,144656,2,490,0)=" ;  Input:     DFN  --  Pointer to the patient in file #2"
^XMB(3.9,144656,2,491,0)="""RTN"",""IBAMTS1"",124,0)"
^XMB(3.9,144656,2,492,0)=" ;           VDATE  --  Visit date"
^XMB(3.9,144656,2,493,0)="""RTN"",""IBAMTS1"",125,0)"
^XMB(3.9,144656,2,494,0)=" N IBARR D CL^SDCO21(DFN,VDATE,"""",.IBARR)"
^XMB(3.9,144656,2,495,0)="""RTN"",""IBAMTS1"",126,0)"
^XMB(3.9,144656,2,496,0)=" Q $D(IBARR)>0"
^XMB(3.9,144656,2,497,0)="""RTN"",""IBAMTS1"",127,0)"
^XMB(3.9,144656,2,498,0)=" ;"
^XMB(3.9,144656,2,499,0)="""RTN"",""IBAMTS1"",128,0)"
^XMB(3.9,144656,2,500,0)="INPT(DFN,VAINDT) ; Was the patient an inpatient at VAINDT?"
^XMB(3.9,144656,2,501,0)="""RTN"",""IBAMTS1"",129,0)"
^XMB(3.9,144656,2,502,0)=" ;  Input:     DFN  --  Pointer to the patient in file #2"
^XMB(3.9,144656,2,503,0)="""RTN"",""IBAMTS1"",130,0)"
^XMB(3.9,144656,2,504,0)=" ;          VAINDT  --  Date/time to check for inpatient status"
^XMB(3.9,144656,2,505,0)="""RTN"",""IBAMTS1"",131,0)"
^XMB(3.9,144656,2,506,0)=" ; Output:       1 - inpatient | 0 - not an inpatient"
^XMB(3.9,144656,2,507,0)="""RTN"",""IBAMTS1"",132,0)"
^XMB(3.9,144656,2,508,0)=" N VADMVT D ADM^VADPT2"
^XMB(3.9,144656,2,509,0)="""RTN"",""IBAMTS1"",133,0)"
^XMB(3.9,144656,2,510,0)=" Q VADMVT>0"
^XMB(3.9,144656,2,511,0)="""RTN"",""IBAMTS1"",134,0)"
^XMB(3.9,144656,2,512,0)=" ;"
^XMB(3.9,144656,2,513,0)="""RTN"",""IBAMTS1"",135,0)"
^XMB(3.9,144656,2,514,0)="CLSF(IBUPD,Y) ; Examine classification questions."
^XMB(3.9,144656,2,515,0)="""RTN"",""IBAMTS1"",136,0)"
^XMB(3.9,144656,2,516,0)=" ;  Input:   IBUPD  --  0 if event just checked out"
^XMB(3.9,144656,2,517,0)="""RTN"",""IBAMTS1"",137,0)"
^XMB(3.9,144656,2,518,0)=" ;                      1 if event is being updated"
^XMB(3.9,144656,2,519,0)="""RTN"",""IBAMTS1"",138,0)"
^XMB(3.9,144656,2,520,0)=" ;               Y  --  array to place output"
^XMB(3.9,144656,2,521,0)="""RTN"",""IBAMTS1"",139,0)"
^XMB(3.9,144656,2,522,0)=" ;  Output:  indicators returned as  ao^ir^sc^swa^mst^hnc^cv^shad [1|yes, 0|no]"
^XMB(3.9,144656,2,523,0)="""RTN"",""IBAMTS1"",140,0)"
^XMB(3.9,144656,2,524,0)=" ;             if IBUPD=0, Y is returned as a single string"
^XMB(3.9,144656,2,525,0)="""RTN"",""IBAMTS1"",141,0)"
^XMB(3.9,144656,2,526,0)=" ;             if IBUPD=1, Y(""BEFORE""),Y(""AFTER"") are defined."
^XMB(3.9,144656,2,527,0)="""RTN"",""IBAMTS1"",142,0)"
^XMB(3.9,144656,2,528,0)=" N X,ZA,ZB S:'$G(IBUPD) Y="""" S:$G(IBUPD) (Y(""BEFORE""),Y(""AFTER""))="""""
^XMB(3.9,144656,2,529,0)="""RTN"",""IBAMTS1"",143,0)"
^XMB(3.9,144656,2,530,0)=" S X=0 F  S X=$O(^TMP(""SDEVT"",$J,SDHDL,IBORG,""SDOE"",IBOE,""CL"",X)) Q:'X  S ZB=$G(^(X,0,""BEFORE"")),ZA=$G(^(""AFTER"")) D"
^XMB(3.9,144656,2,531,0)="""RTN"",""IBAMTS1"",144,0)"
^XMB(3.9,144656,2,532,0)=" .I '$G(IBUPD) S:ZA $P(Y,""^"",+ZA)=+$P(ZA,""^"",3) Q"
^XMB(3.9,144656,2,533,0)="""RTN"",""IBAMTS1"",145,0)"
^XMB(3.9,144656,2,534,0)=" .S $P(Y(""BEFORE""),""^"",+ZB)=+$P(ZB,""^"",3),$P(Y(""AFTER""),""^"",+ZA)=+$P(ZA,""^"",3)"
^XMB(3.9,144656,2,535,0)="""RTN"",""IBAMTS1"",146,0)"
^XMB(3.9,144656,2,536,0)=" Q"
^XMB(3.9,144656,2,537,0)="""RTN"",""IBAMTS1"",147,0)"
^XMB(3.9,144656,2,538,0)=" ;"
^XMB(3.9,144656,2,539,0)="""RTN"",""IBAMTS1"",148,0)"
^XMB(3.9,144656,2,540,0)="OLDRATE(IBRTED,IBFR) ; See if the copay rate effective date is too old."
^XMB(3.9,144656,2,541,0)="""RTN"",""IBAMTS1"",149,0)"
^XMB(3.9,144656,2,542,0)=" ;  Input:   IBRTED  --  Charge Effective Date"
^XMB(3.9,144656,2,543,0)="""RTN"",""IBAMTS1"",150,0)"
^XMB(3.9,144656,2,544,0)=" ;             IBFR  --  Visit Date"
^XMB(3.9,144656,2,545,0)="""RTN"",""IBAMTS1"",151,0)"
^XMB(3.9,144656,2,546,0)=" ;  Output:       1  --  Effective Date is too old"
^XMB(3.9,144656,2,547,0)="""RTN"",""IBAMTS1"",152,0)"
^XMB(3.9,144656,2,548,0)=" ;                0  --  Not"
^XMB(3.9,144656,2,549,0)="""RTN"",""IBAMTS1"",153,0)"
^XMB(3.9,144656,2,550,0)=" ;"
^XMB(3.9,144656,2,551,0)="""RTN"",""IBAMTS1"",154,0)"
^XMB(3.9,144656,2,552,0)=" N IBNUM,IBYR"
^XMB(3.9,144656,2,553,0)="""RTN"",""IBAMTS1"",155,0)"
^XMB(3.9,144656,2,554,0)=" S IBNUM=$$FMDIFF^XLFDT(IBFR,IBRTED),IBYR=$E(IBFR,1,3)"
^XMB(3.9,144656,2,555,0)="""RTN"",""IBAMTS1"",156,0)"
^XMB(3.9,144656,2,556,0)=" Q IBYR#4&(IBNUM>364)!(IBYR#4=0&(IBNUM>365))"
^XMB(3.9,144656,2,557,0)="""RTN"",""IBAMTS1"",157,0)"
^XMB(3.9,144656,2,558,0)=" ;"
^XMB(3.9,144656,2,559,0)="""RTN"",""IBAMTS1"",158,0)"
^XMB(3.9,144656,2,560,0)=" ;"
^XMB(3.9,144656,2,561,0)="""RTN"",""IBAMTS1"",159,0)"
^XMB(3.9,144656,2,562,0)="CHKPRIM ;  check to see if patient has been billed for primary"
^XMB(3.9,144656,2,563,0)="""RTN"",""IBAMTS1"",160,0)"
^XMB(3.9,144656,2,564,0)=" ;  and this is a specialty stop.  if so, cancel the primary"
^XMB(3.9,144656,2,565,0)="""RTN"",""IBAMTS1"",161,0)"
^XMB(3.9,144656,2,566,0)=" ;  bill and let the software create the new specialty charge"
^XMB(3.9,144656,2,567,0)="""RTN"",""IBAMTS1"",162,0)"
^XMB(3.9,144656,2,568,0)=" ;  input ibbilled  = last parent bill to check (ien 350)"
^XMB(3.9,144656,2,569,0)="""RTN"",""IBAMTS1"",163,0)"
^XMB(3.9,144656,2,570,0)=" ;                    used to check the rate"
^XMB(3.9,144656,2,571,0)="""RTN"",""IBAMTS1"",164,0)"
^XMB(3.9,144656,2,572,0)=" ;  output ibbilled = last parent bill number to prevent"
^XMB(3.9,144656,2,573,0)="""RTN"",""IBAMTS1"",165,0)"
^XMB(3.9,144656,2,574,0)=" ;                    adding specialty charge"
^XMB(3.9,144656,2,575,0)="""RTN"",""IBAMTS1"",166,0)"
^XMB(3.9,144656,2,576,0)=" N %,IBSTOPDA,IBTYPE,IBCRES,IBI,IBS"
^XMB(3.9,144656,2,577,0)="""RTN"",""IBAMTS1"",167,0)"
^XMB(3.9,144656,2,578,0)=" ;"
^XMB(3.9,144656,2,579,0)="""RTN"",""IBAMTS1"",168,0)"
^XMB(3.9,144656,2,580,0)=" ;  get the stop code for the 2nd visit on the same day"
^XMB(3.9,144656,2,581,0)="""RTN"",""IBAMTS1"",169,0)"
^XMB(3.9,144656,2,582,0)=" S IBSTOPDA=$$GETSC^IBEMTSCU(""409.68:""_IBOE,IBDAT) I 'IBSTOPDA Q"
^XMB(3.9,144656,2,583,0)="""RTN"",""IBAMTS1"",170,0)"
^XMB(3.9,144656,2,584,0)=" ;"
^XMB(3.9,144656,2,585,0)="""RTN"",""IBAMTS1"",171,0)"
^XMB(3.9,144656,2,586,0)=" ;  get the rate, ibtype = primary or specialty"
^XMB(3.9,144656,2,587,0)="""RTN"",""IBAMTS1"",172,0)"
^XMB(3.9,144656,2,588,0)=" S IBTYPE=$P(^IBE(352.5,IBSTOPDA,0),""^"",3)"
^XMB(3.9,144656,2,589,0)="""RTN"",""IBAMTS1"",173,0)"
^XMB(3.9,144656,2,590,0)=" ;  if the new appt is not specialty, quit ... no need to create"
^XMB(3.9,144656,2,591,0)="""RTN"",""IBAMTS1"",174,0)"
^XMB(3.9,144656,2,592,0)=" ;  a new charge"
^XMB(3.9,144656,2,593,0)="""RTN"",""IBAMTS1"",175,0)"
^XMB(3.9,144656,2,594,0)=" I IBTYPE'=2 Q"
^XMB(3.9,144656,2,595,0)="""RTN"",""IBAMTS1"",176,0)"
^XMB(3.9,144656,2,596,0)=" ;"
^XMB(3.9,144656,2,597,0)="""RTN"",""IBAMTS1"",177,0)"
^XMB(3.9,144656,2,598,0)=" ;  if the last charge was billed at specialty, quit"
^XMB(3.9,144656,2,599,0)="""RTN"",""IBAMTS1"",178,0)"
^XMB(3.9,144656,2,600,0)=" I $P($G(^IBE(352.5,+$P($G(^IB(+IBBILLED,0)),""^"",20),0)),""^"",3)=2 Q"
^XMB(3.9,144656,2,601,0)="""RTN"",""IBAMTS1"",179,0)"
^XMB(3.9,144656,2,602,0)=" ;"
^XMB(3.9,144656,2,603,0)="""RTN"",""IBAMTS1"",180,0)"
^XMB(3.9,144656,2,604,0)=" ;  cancel the charge"
^XMB(3.9,144656,2,605,0)="""RTN"",""IBAMTS1"",181,0)"
^XMB(3.9,144656,2,606,0)=" ;  cancellation reason = billed at higher tier rate"
^XMB(3.9,144656,2,607,0)="""RTN"",""IBAMTS1"",182,0)"
^XMB(3.9,144656,2,608,0)=" S IBCRES=6,IBS=$P($G(^IB(+IBBILLED,0)),""^"",5)"
^XMB(3.9,144656,2,609,0)="""RTN"",""IBAMTS1"",183,0)"
^XMB(3.9,144656,2,610,0)=" ;"
^XMB(3.9,144656,2,611,0)="""RTN"",""IBAMTS1"",184,0)"
^XMB(3.9,144656,2,612,0)=" ; if not billed, on hold, or cancelled wait"
^XMB(3.9,144656,2,613,0)="""RTN"",""IBAMTS1"",185,0)"
^XMB(3.9,144656,2,614,0)=" I IBS'=3!(IBS'=8)!(IBS'=10) F IBI=1:1:10 H 1 S IBS=$P($G(^IB(+IBBILLED,0)),""^"",5) I IBS=3!(IBS=8)!(IBS=10) Q"
^XMB(3.9,144656,2,615,0)="""RTN"",""IBAMTS1"",186,0)"
^XMB(3.9,144656,2,616,0)=" ;"
^XMB(3.9,144656,2,617,0)="""RTN"",""IBAMTS1"",187,0)"
^XMB(3.9,144656,2,618,0)=" D CANC^IBAMTS2"
^XMB(3.9,144656,2,619,0)="""RTN"",""IBAMTS1"",188,0)"
^XMB(3.9,144656,2,620,0)=" D UPDCANC^IBAMTC(+IBBILLED)  ; update MH visit tracking for cancelled charge  IB*2.0*760"
^XMB(3.9,144656,2,621,0)="""RTN"",""IBAMTS1"",189,0)"
^XMB(3.9,144656,2,622,0)=" ;"
^XMB(3.9,144656,2,623,0)="""RTN"",""IBAMTS1"",190,0)"
^XMB(3.9,144656,2,624,0)=" ;  set ibbilled = 0 to create the specialty charge"
^XMB(3.9,144656,2,625,0)="""RTN"",""IBAMTS1"",191,0)"
^XMB(3.9,144656,2,626,0)=" S IBBILLED=0"
^XMB(3.9,144656,2,627,0)="""RTN"",""IBAMTS1"",192,0)"
^XMB(3.9,144656,2,628,0)=" Q"
^XMB(3.9,144656,2,629,0)="""RTN"",""IBAMTS1"",193,0)"
^XMB(3.9,144656,2,630,0)=" ;"
^XMB(3.9,144656,2,631,0)="""RTN"",""IBAMTS1"",194,0)"
^XMB(3.9,144656,2,632,0)="CHKELIG(DFN) ; check if patient eligibilities prevent billing  IB*2.0*817"
^XMB(3.9,144656,2,633,0)="""RTN"",""IBAMTS1"",195,0)"
^XMB(3.9,144656,2,634,0)=" ;"
^XMB(3.9,144656,2,635,0)="""RTN"",""IBAMTS1"",196,0)"
^XMB(3.9,144656,2,636,0)=" ; DFN - patient's DFN"
^XMB(3.9,144656,2,637,0)="""RTN"",""IBAMTS1"",197,0)"
^XMB(3.9,144656,2,638,0)=" ;"
^XMB(3.9,144656,2,639,0)="""RTN"",""IBAMTS1"",198,0)"
^XMB(3.9,144656,2,640,0)=" ; Reurns 1 if patient should be billed, 0 otherwise"
^XMB(3.9,144656,2,641,0)="""RTN"",""IBAMTS1"",199,0)"
^XMB(3.9,144656,2,642,0)=" N ELSTR,RES,VAEL,Z"
^XMB(3.9,144656,2,643,0)="""RTN"",""IBAMTS1"",200,0)"
^XMB(3.9,144656,2,644,0)=" S ELSTR=""^WORLD WAR II^"""
^XMB(3.9,144656,2,645,0)="""RTN"",""IBAMTS1"",201,0)"
^XMB(3.9,144656,2,646,0)=" S RES=1"
^XMB(3.9,144656,2,647,0)="""RTN"",""IBAMTS1"",202,0)"
^XMB(3.9,144656,2,648,0)=" D ELIG^VADPT"
^XMB(3.9,144656,2,649,0)="""RTN"",""IBAMTS1"",203,0)"
^XMB(3.9,144656,2,650,0)=" S Z=0 F  S Z=$O(VAEL(1,Z)) Q:'Z  I ELSTR[(U_$P(VAEL(1,Z),U,2)_U) S RES=0 Q"
^XMB(3.9,144656,2,651,0)="""RTN"",""IBAMTS1"",204,0)"
^XMB(3.9,144656,2,652,0)=" Q RES"
^XMB(3.9,144656,2,653,0)="""RTN"",""IBAMTS2"")"
^XMB(3.9,144656,2,654,0)="0^2^B9767783"
^XMB(3.9,144656,2,655,0)="""RTN"",""IBAMTS2"",1,0)"
^XMB(3.9,144656,2,656,0)="IBAMTS2 ;ALB/CPM - PROCESS UPDATED OUTPATIENT ENCOUNTERS ; 25-AUG-93"
^XMB(3.9,144656,2,657,0)="""RTN"",""IBAMTS2"",2,0)"
^XMB(3.9,144656,2,658,0)=" ;;2.0;INTEGRATED BILLING;**52,91,117,132,153,156,167,247,339**;21-MAR-94;Build 0"
^XMB(3.9,144656,2,659,0)="""RTN"",""IBAMTS2"",3,0)"
^XMB(3.9,144656,2,660,0)=" ;;Per VHA Directive 2004-038, this routine should not be modified."
^XMB(3.9,144656,2,661,0)="""RTN"",""IBAMTS2"",4,0)"
^XMB(3.9,144656,2,662,0)=" ;"
^XMB(3.9,144656,2,663,0)="""RTN"",""IBAMTS2"",5,0)"
^XMB(3.9,144656,2,664,0)="UPD ; Perform encounter update actions."
^XMB(3.9,144656,2,665,0)="""RTN"",""IBAMTS2"",6,0)"
^XMB(3.9,144656,2,666,0)=" N IBCBK,IBFILTER,IBVAL"
^XMB(3.9,144656,2,667,0)="""RTN"",""IBAMTS2"",7,0)"
^XMB(3.9,144656,2,668,0)=" ;"
^XMB(3.9,144656,2,669,0)="""RTN"",""IBAMTS2"",8,0)"
^XMB(3.9,144656,2,670,0)=" ; - was check out deleted?"
^XMB(3.9,144656,2,671,0)="""RTN"",""IBAMTS2"",9,0)"
^XMB(3.9,144656,2,672,0)=" I IBAST'=2,IBBST=2 S IBCRES=$S(IBAST=8:5,1:1)"
^XMB(3.9,144656,2,673,0)="""RTN"",""IBAMTS2"",10,0)"
^XMB(3.9,144656,2,674,0)=" ;"
^XMB(3.9,144656,2,675,0)="""RTN"",""IBAMTS2"",11,0)"
^XMB(3.9,144656,2,676,0)=" ; - see if checked out appt classifications were changed"
^XMB(3.9,144656,2,677,0)="""RTN"",""IBAMTS2"",12,0)"
^XMB(3.9,144656,2,678,0)=" I IBAST=2,IBBST=2 D CLSF^IBAMTS1(1,.IBCLSF) S IBACT=$$CLUPD() G:'IBACT UPDQ D  I IBACT'=1 G UPDQ"
^XMB(3.9,144656,2,679,0)="""RTN"",""IBAMTS2"",13,0)"
^XMB(3.9,144656,2,680,0)=" .I IBACT=1 S IBCRES=2 Q"
^XMB(3.9,144656,2,681,0)="""RTN"",""IBAMTS2"",14,0)"
^XMB(3.9,144656,2,682,0)=" .I IBACT=2 N IBCLSF D NEW^IBAMTS1"
^XMB(3.9,144656,2,683,0)="""RTN"",""IBAMTS2"",15,0)"
^XMB(3.9,144656,2,684,0)=" ;"
^XMB(3.9,144656,2,685,0)="""RTN"",""IBAMTS2"",16,0)"
^XMB(3.9,144656,2,686,0)=" ; - cancel charge if there is a cancellation reason, and the billed"
^XMB(3.9,144656,2,687,0)="""RTN"",""IBAMTS2"",17,0)"
^XMB(3.9,144656,2,688,0)=" ; - charge was for the appointment that is no longer billable"
^XMB(3.9,144656,2,689,0)="""RTN"",""IBAMTS2"",18,0)"
^XMB(3.9,144656,2,690,0)=" I '$G(IBCRES) G UPDQ"
^XMB(3.9,144656,2,691,0)="""RTN"",""IBAMTS2"",19,0)"
^XMB(3.9,144656,2,692,0)=" I '$$LINK(IBOE,$S(IBEVT:IBEVT,1:IBEV0),IBBILLED) G UPDQ"
^XMB(3.9,144656,2,693,0)="""RTN"",""IBAMTS2"",20,0)"
^XMB(3.9,144656,2,694,0)=" D CANC G:IBY<0 UPDQ"
^XMB(3.9,144656,2,695,0)="""RTN"",""IBAMTS2"",21,0)"
^XMB(3.9,144656,2,696,0)=" ;"
^XMB(3.9,144656,2,697,0)="""RTN"",""IBAMTS2"",22,0)"
^XMB(3.9,144656,2,698,0)=" ; - look for other billable visits if Means Test billable"
^XMB(3.9,144656,2,699,0)="""RTN"",""IBAMTS2"",23,0)"
^XMB(3.9,144656,2,700,0)=" I '$$BIL^DGMTUB(DFN,IBDT) G UPDQ"
^XMB(3.9,144656,2,701,0)="""RTN"",""IBAMTS2"",24,0)"
^XMB(3.9,144656,2,702,0)=" S IBBILLED=0"
^XMB(3.9,144656,2,703,0)="""RTN"",""IBAMTS2"",25,0)"
^XMB(3.9,144656,2,704,0)=" ;"
^XMB(3.9,144656,2,705,0)="""RTN"",""IBAMTS2"",26,0)"
^XMB(3.9,144656,2,706,0)=" S IBVAL(""DFN"")=DFN,IBVAL(""BDT"")=IBDAT-.1,IBVAL(""EDT"")=IBDAT_.99"
^XMB(3.9,144656,2,707,0)="""RTN"",""IBAMTS2"",27,0)"
^XMB(3.9,144656,2,708,0)=" S IBFILTER="""""
^XMB(3.9,144656,2,709,0)="""RTN"",""IBAMTS2"",28,0)"
^XMB(3.9,144656,2,710,0)=" ; Skip encounter just cancelled,"
^XMB(3.9,144656,2,711,0)="""RTN"",""IBAMTS2"",29,0)"
^XMB(3.9,144656,2,712,0)=" ;  consider only parent encounters, appts checked out"
^XMB(3.9,144656,2,713,0)="""RTN"",""IBAMTS2"",30,0)"
^XMB(3.9,144656,2,714,0)=" S IBCBK=""I Y'=IBOE,'$P(Y0,U,6),$P(Y0,U,12)=2 D BEDIT^IBAMTS2(Y,Y0) S:IBBILLED SDSTOP=1"""
^XMB(3.9,144656,2,715,0)="""RTN"",""IBAMTS2"",31,0)"
^XMB(3.9,144656,2,716,0)=" D SCAN^IBSDU(""PATIENT/DATE"",.IBVAL,IBFILTER,IBCBK,1) K ^TMP(""DIERR"",$J)"
^XMB(3.9,144656,2,717,0)="""RTN"",""IBAMTS2"",32,0)"
^XMB(3.9,144656,2,718,0)=" ;"
^XMB(3.9,144656,2,719,0)="""RTN"",""IBAMTS2"",33,0)"
^XMB(3.9,144656,2,720,0)="UPDQ K IBCLSF,IBACT,IBC,IBOEN,IBEVT"
^XMB(3.9,144656,2,721,0)="""RTN"",""IBAMTS2"",34,0)"
^XMB(3.9,144656,2,722,0)=" Q"
^XMB(3.9,144656,2,723,0)="""RTN"",""IBAMTS2"",35,0)"
^XMB(3.9,144656,2,724,0)=" ;"
^XMB(3.9,144656,2,725,0)="""RTN"",""IBAMTS2"",36,0)"
^XMB(3.9,144656,2,726,0)="BEDIT(IBOEN,IBEVT) ; - perform batch edit"
^XMB(3.9,144656,2,727,0)="""RTN"",""IBAMTS2"",37,0)"
^XMB(3.9,144656,2,728,0)=" I $P(IBEVT,U,10)=1 S UNBILLED=1 Q  ; C&P exam -- stop looking"
^XMB(3.9,144656,2,729,0)="""RTN"",""IBAMTS2"",38,0)"
^XMB(3.9,144656,2,730,0)=" S IBORG=+$P(IBEVT,U,8),IBAPTY=+$P(IBEVT,U,10)"
^XMB(3.9,144656,2,731,0)="""RTN"",""IBAMTS2"",39,0)"
^XMB(3.9,144656,2,732,0)=" I IBORG=3 S IBDISP=+$$DISND^IBSDU(IBOEN,IBEVT,7) Q:'IBDISP"
^XMB(3.9,144656,2,733,0)="""RTN"",""IBAMTS2"",40,0)"
^XMB(3.9,144656,2,734,0)=" Q:'$$CHKS^IBAMTS1"
^XMB(3.9,144656,2,735,0)="""RTN"",""IBAMTS2"",41,0)"
^XMB(3.9,144656,2,736,0)=" ;"
^XMB(3.9,144656,2,737,0)="""RTN"",""IBAMTS2"",42,0)"
^XMB(3.9,144656,2,738,0)=" ; - check classifications"
^XMB(3.9,144656,2,739,0)="""RTN"",""IBAMTS2"",43,0)"
^XMB(3.9,144656,2,740,0)=" S IBCLSF=$$ENCL(IBOEN)"
^XMB(3.9,144656,2,741,0)="""RTN"",""IBAMTS2"",44,0)"
^XMB(3.9,144656,2,742,0)=" I IBCLSF[1 Q  ; care was related to ao/ir/swa/sc/mst/hnc/cv/shad"
^XMB(3.9,144656,2,743,0)="""RTN"",""IBAMTS2"",45,0)"
^XMB(3.9,144656,2,744,0)=" S IBSL=""409.68:""_IBOEN ; set softlink"
^XMB(3.9,144656,2,745,0)="""RTN"",""IBAMTS2"",46,0)"
^XMB(3.9,144656,2,746,0)=" ;"
^XMB(3.9,144656,2,747,0)="""RTN"",""IBAMTS2"",47,0)"
^XMB(3.9,144656,2,748,0)=" ; - ready to bill another encounter"
^XMB(3.9,144656,2,749,0)="""RTN"",""IBAMTS2"",48,0)"
^XMB(3.9,144656,2,750,0)=" D BLD^IBAMTS1 S IBBILLED=1"
^XMB(3.9,144656,2,751,0)="""RTN"",""IBAMTS2"",49,0)"
^XMB(3.9,144656,2,752,0)=" Q"
^XMB(3.9,144656,2,753,0)="""RTN"",""IBAMTS2"",50,0)"
^XMB(3.9,144656,2,754,0)=" ;"
^XMB(3.9,144656,2,755,0)="""RTN"",""IBAMTS2"",51,0)"
^XMB(3.9,144656,2,756,0)="CRES ; List of cancellation reasons"
^XMB(3.9,144656,2,757,0)="""RTN"",""IBAMTS2"",52,0)"
^XMB(3.9,144656,2,758,0)=" ;;CHECK OUT DELETED"
^XMB(3.9,144656,2,759,0)="""RTN"",""IBAMTS2"",53,0)"
^XMB(3.9,144656,2,760,0)=" ;;CLASSIFICATION CHANGED"
^XMB(3.9,144656,2,761,0)="""RTN"",""IBAMTS2"",54,0)"
^XMB(3.9,144656,2,762,0)=" ;;MT OP APPT NO-SHOW"
^XMB(3.9,144656,2,763,0)="""RTN"",""IBAMTS2"",55,0)"
^XMB(3.9,144656,2,764,0)=" ;;MT OP APPT CANCELLED"
^XMB(3.9,144656,2,765,0)="""RTN"",""IBAMTS2"",56,0)"
^XMB(3.9,144656,2,766,0)=" ;;RECD INPATIENT CARE"
^XMB(3.9,144656,2,767,0)="""RTN"",""IBAMTS2"",57,0)"
^XMB(3.9,144656,2,768,0)=" ;;BILLED AT HIGHER TIER RATE"
^XMB(3.9,144656,2,769,0)="""RTN"",""IBAMTS2"",58,0)"
^XMB(3.9,144656,2,770,0)=" ;"
^XMB(3.9,144656,2,771,0)="""RTN"",""IBAMTS2"",59,0)"
^XMB(3.9,144656,2,772,0)="LINK(IBOE,IBEVT,IBN) ; Was the billed charge for the current appointment?"
^XMB(3.9,144656,2,773,0)="""RTN"",""IBAMTS2"",60,0)"
^XMB(3.9,144656,2,774,0)=" ;  Input:     IBOE  --  Pointer to outpatient encounter in file #409.68"
^XMB(3.9,144656,2,775,0)="""RTN"",""IBAMTS2"",61,0)"
^XMB(3.9,144656,2,776,0)=" ;            IBEVT  --  Zeroth node of encounter in file #409.68"
^XMB(3.9,144656,2,777,0)="""RTN"",""IBAMTS2"",62,0)"
^XMB(3.9,144656,2,778,0)=" ;              IBN  --  Pointer to charge in file #350"
^XMB(3.9,144656,2,779,0)="""RTN"",""IBAMTS2"",63,0)"
^XMB(3.9,144656,2,780,0)=" ;  Output:       0  --  Charge was not for current appointment"
^XMB(3.9,144656,2,781,0)="""RTN"",""IBAMTS2"",64,0)"
^XMB(3.9,144656,2,782,0)=" ;                1  --  Charge was for current appointment"
^XMB(3.9,144656,2,783,0)="""RTN"",""IBAMTS2"",65,0)"
^XMB(3.9,144656,2,784,0)=" N IBSL,Y"
^XMB(3.9,144656,2,785,0)="""RTN"",""IBAMTS2"",66,0)"
^XMB(3.9,144656,2,786,0)=" I '$G(IBOE)!'$G(IBEVT)!'$G(IBN) G LINKQ"
^XMB(3.9,144656,2,787,0)="""RTN"",""IBAMTS2"",67,0)"
^XMB(3.9,144656,2,788,0)=" S IBSL=$P($G(^IB(IBN,0)),""^"",4)"
^XMB(3.9,144656,2,789,0)="""RTN"",""IBAMTS2"",68,0)"
^XMB(3.9,144656,2,790,0)=" I +IBSL=44 S Y=$P(IBSL,"";"",1,2)=(""44:""_$P(IBEVT,""^"",4)_"";S:""_+IBEVT) G LINKQ"
^XMB(3.9,144656,2,791,0)="""RTN"",""IBAMTS2"",69,0)"
^XMB(3.9,144656,2,792,0)=" I +IBSL=409.68 S Y=IBSL=(""409.68:""_IBOE)"
^XMB(3.9,144656,2,793,0)="""RTN"",""IBAMTS2"",70,0)"
^XMB(3.9,144656,2,794,0)="LINKQ Q +$G(Y)"
^XMB(3.9,144656,2,795,0)="""RTN"",""IBAMTS2"",71,0)"
^XMB(3.9,144656,2,796,0)=" ;"
^XMB(3.9,144656,2,797,0)="""RTN"",""IBAMTS2"",72,0)"
^XMB(3.9,144656,2,798,0)="CLUPD() ; Examine changes in the classification."
^XMB(3.9,144656,2,799,0)="""RTN"",""IBAMTS2"",73,0)"
^XMB(3.9,144656,2,800,0)=" ;  Output:    0  --  no changes"
^XMB(3.9,144656,2,801,0)="""RTN"",""IBAMTS2"",74,0)"
^XMB(3.9,144656,2,802,0)=" ;             1  --  changes require charges to be cancelled"
^XMB(3.9,144656,2,803,0)="""RTN"",""IBAMTS2"",75,0)"
^XMB(3.9,144656,2,804,0)=" ;             2  --  changes require appt to be billed"
^XMB(3.9,144656,2,805,0)="""RTN"",""IBAMTS2"",76,0)"
^XMB(3.9,144656,2,806,0)=" ;             3  --  [ec/swa] cancel charge, create deferred charge"
^XMB(3.9,144656,2,807,0)="""RTN"",""IBAMTS2"",77,0)"
^XMB(3.9,144656,2,808,0)=" ;             4  --  [ec/swa] pass deferred charge, disposition case"
^XMB(3.9,144656,2,809,0)="""RTN"",""IBAMTS2"",78,0)"
^XMB(3.9,144656,2,810,0)=" N I,Y S Y=0"
^XMB(3.9,144656,2,811,0)="""RTN"",""IBAMTS2"",79,0)"
^XMB(3.9,144656,2,812,0)=" I IBCLSF(""BEFORE"")=IBCLSF(""AFTER"") G CLUPDQ"
^XMB(3.9,144656,2,813,0)="""RTN"",""IBAMTS2"",80,0)"
^XMB(3.9,144656,2,814,0)=" F I=1,2,3,4,5,6,7,8 I '$P(IBCLSF(""BEFORE""),U,I),$P(IBCLSF(""AFTER""),U,I) S Y=$S(I=4:3,1:1) G CLUPDQ"
^XMB(3.9,144656,2,815,0)="""RTN"",""IBAMTS2"",81,0)"
^XMB(3.9,144656,2,816,0)=" F I=1,2,3,4,5,6,7,8 I $P(IBCLSF(""BEFORE""),U,I),'$P(IBCLSF(""AFTER""),U,I) S Y=$S(I=4:4,1:2) Q"
^XMB(3.9,144656,2,817,0)="""RTN"",""IBAMTS2"",82,0)"
^XMB(3.9,144656,2,818,0)="CLUPDQ Q Y"
^XMB(3.9,144656,2,819,0)="""RTN"",""IBAMTS2"",83,0)"
^XMB(3.9,144656,2,820,0)=" ;"
^XMB(3.9,144656,2,821,0)="""RTN"",""IBAMTS2"",84,0)"
^XMB(3.9,144656,2,822,0)="CANC ; Determine cancellation reason and cancel charge"
^XMB(3.9,144656,2,823,0)="""RTN"",""IBAMTS2"",85,0)"
^XMB(3.9,144656,2,824,0)=" ;  Input variables:   IBCRES  --  Code for reason to be determined"
^XMB(3.9,144656,2,825,0)="""RTN"",""IBAMTS2"",86,0)"
^XMB(3.9,144656,2,826,0)=" ;                   IBBILLED  --  Charge to be cancelled"
^XMB(3.9,144656,2,827,0)="""RTN"",""IBAMTS2"",87,0)"
^XMB(3.9,144656,2,828,0)=" S IBCRES=$P($T(CRES+IBCRES),"";;"",2),IBCRES=+$O(^IBE(350.3,""B"",IBCRES,0))"
^XMB(3.9,144656,2,829,0)="""RTN"",""IBAMTS2"",88,0)"
^XMB(3.9,144656,2,830,0)=" D CANCH^IBECEAU4(IBBILLED,IBCRES)"
^XMB(3.9,144656,2,831,0)="""RTN"",""IBAMTS2"",89,0)"
^XMB(3.9,144656,2,832,0)=" Q"
^XMB(3.9,144656,2,833,0)="""RTN"",""IBAMTS2"",90,0)"
^XMB(3.9,144656,2,834,0)=" ;"
^XMB(3.9,144656,2,835,0)="""RTN"",""IBAMTS2"",91,0)"
^XMB(3.9,144656,2,836,0)="ENCL(IBOE) ; Return classification results for an encounter."
^XMB(3.9,144656,2,837,0)="""RTN"",""IBAMTS2"",92,0)"
^XMB(3.9,144656,2,838,0)=" ;  Input:    IBOE  --  Pointer to outpatient encounter in file #409.68"
^XMB(3.9,144656,2,839,0)="""RTN"",""IBAMTS2"",93,0)"
^XMB(3.9,144656,2,840,0)=" ;  Output:   ao^ir^sc^swa^mst^hnc^cv^shad, where, for each piece,"
^XMB(3.9,144656,2,841,0)="""RTN"",""IBAMTS2"",94,0)"
^XMB(3.9,144656,2,842,0)=" ;                      1 - care was related to condition, and"
^XMB(3.9,144656,2,843,0)="""RTN"",""IBAMTS2"",95,0)"
^XMB(3.9,144656,2,844,0)=" ;                      0 (or null) - care not related to condition"
^XMB(3.9,144656,2,845,0)="""RTN"",""IBAMTS2"",96,0)"
^XMB(3.9,144656,2,846,0)=" N CL,CLD,X,Y S Y="""""
^XMB(3.9,144656,2,847,0)="""RTN"",""IBAMTS2"",97,0)"
^XMB(3.9,144656,2,848,0)=" S CL=0 F  S CL=$O(^SDD(409.42,""OE"",+$G(IBOE),CL)) Q:'CL  S CLD=$G(^SDD(409.42,CL,0)) I CLD S $P(Y,U,+CLD)=+$P(CLD,U,3)"
^XMB(3.9,144656,2,849,0)="""RTN"",""IBAMTS2"",98,0)"
^XMB(3.9,144656,2,850,0)=" Q Y"
^XMB(3.9,144656,2,851,0)="""VER"")"
^XMB(3.9,144656,2,852,0)="8.0^22.2"
^XMB(3.9,144656,2,853,0)="$END KID IB*2.0*795b"
