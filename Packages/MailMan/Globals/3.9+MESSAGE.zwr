^XMB(3.9,144657,2,7170,0)=" ; EICD-Identifications (aka A1 msgs)"
^XMB(3.9,144657,2,7171,0)="""RTN"",""IBCNEUT2"",94,0)"
^XMB(3.9,144657,2,7172,0)=" ; [Asking clearinghouse if they know insurance for this patient]"
^XMB(3.9,144657,2,7173,0)="""RTN"",""IBCNEUT2"",95,0)"
^XMB(3.9,144657,2,7174,0)=" I (EXT=4),(QUERY=""I"") D  G BADMSGX"
^XMB(3.9,144657,2,7175,0)="""RTN"",""IBCNEUT2"",96,0)"
^XMB(3.9,144657,2,7176,0)=" . I $$FOREIGN^IBCNINSU($P(PID,HLFS,6),""1;2;3;4;5;6"") S STOP=1 Q  ;PID-5 PATIENT NAME"
^XMB(3.9,144657,2,7177,0)="""RTN"",""IBCNEUT2"",97,0)"
^XMB(3.9,144657,2,7178,0)=" . ; PID-11 Addr (ignore,ignore,city,state,zip)"
^XMB(3.9,144657,2,7179,0)="""RTN"",""IBCNEUT2"",98,0)"
^XMB(3.9,144657,2,7180,0)=" . I $$FOREIGN^IBCNINSU($P(PID,HLFS,12),""3;4;5"") S STOP=1 Q       ;PID-11"
^XMB(3.9,144657,2,7181,0)="""RTN"",""IBCNEUT2"",99,0)"
^XMB(3.9,144657,2,7182,0)=" . ;"
^XMB(3.9,144657,2,7183,0)="""RTN"",""IBCNEUT2"",100,0)"
^XMB(3.9,144657,2,7184,0)=" . ;If foreign chars encountered clear field and continue with msg"
^XMB(3.9,144657,2,7185,0)="""RTN"",""IBCNEUT2"",101,0)"
^XMB(3.9,144657,2,7186,0)=" . ;"
^XMB(3.9,144657,2,7187,0)="""RTN"",""IBCNEUT2"",102,0)"
^XMB(3.9,144657,2,7188,0)=" . S FLD=$P(PID,HLFS,12) I $$FOREIGN^IBCNINSU(.FLD,1,1) S $P(PID,HLFS,12)=FLD ;PID-11-1 ADDR STREET"
^XMB(3.9,144657,2,7189,0)="""RTN"",""IBCNEUT2"",103,0)"
^XMB(3.9,144657,2,7190,0)=" ;"
^XMB(3.9,144657,2,7191,0)="""RTN"",""IBCNEUT2"",104,0)"
^XMB(3.9,144657,2,7192,0)=" ; EICD-Verification (aka A2 msgs)"
^XMB(3.9,144657,2,7193,0)="""RTN"",""IBCNEUT2"",105,0)"
^XMB(3.9,144657,2,7194,0)=" ; [Confirming policies clearinghouse found for VA]"
^XMB(3.9,144657,2,7195,0)="""RTN"",""IBCNEUT2"",106,0)"
^XMB(3.9,144657,2,7196,0)=" I (EXT=4),(QUERY=""V"") D  G BADMSGX"
^XMB(3.9,144657,2,7197,0)="""RTN"",""IBCNEUT2"",107,0)"
^XMB(3.9,144657,2,7198,0)=" . I $$FOREIGN^IBCNINSU($P(PID,HLFS,6),""1;2;3;4;5;6"") S STOP=1 Q  ;PID-5 PATIENT NAME"
^XMB(3.9,144657,2,7199,0)="""RTN"",""IBCNEUT2"",108,0)"
^XMB(3.9,144657,2,7200,0)=" . I $$FOREIGN^IBCNINSU($P(IN1,HLFS,3)) S STOP=1 Q                ;IN1-2 PATIENT/SUBSCRIBER ID"
^XMB(3.9,144657,2,7201,0)="""RTN"",""IBCNEUT2"",109,0)"
^XMB(3.9,144657,2,7202,0)=" . I $D(GT1) D  I STOP Q"
^XMB(3.9,144657,2,7203,0)="""RTN"",""IBCNEUT2"",110,0)"
^XMB(3.9,144657,2,7204,0)=" .. I $$FOREIGN^IBCNINSU($P(GT1,HLFS,3)) S STOP=1 Q                ;GT1-2 SUBSCRIBER ID"
^XMB(3.9,144657,2,7205,0)="""RTN"",""IBCNEUT2"",111,0)"
^XMB(3.9,144657,2,7206,0)=" .. I $$FOREIGN^IBCNINSU($P(GT1,HLFS,4),""1;2;3;4;5;6"") S STOP=1 Q  ;GT1-3 SUBSCRIBER NAME"
^XMB(3.9,144657,2,7207,0)="""RTN"",""IBCNEUT2"",112,0)"
^XMB(3.9,144657,2,7208,0)=" . ;"
^XMB(3.9,144657,2,7209,0)="""RTN"",""IBCNEUT2"",113,0)"
^XMB(3.9,144657,2,7210,0)=" . ;If foreign chars encountered clear field and continue with msg"
^XMB(3.9,144657,2,7211,0)="""RTN"",""IBCNEUT2"",114,0)"
^XMB(3.9,144657,2,7212,0)=" . ;"
^XMB(3.9,144657,2,7213,0)="""RTN"",""IBCNEUT2"",115,0)"
^XMB(3.9,144657,2,7214,0)=" . ; PID-11 Addr (street,ignore,city,state,zip)"
^XMB(3.9,144657,2,7215,0)="""RTN"",""IBCNEUT2"",116,0)"
^XMB(3.9,144657,2,7216,0)=" . S FLD=$P(PID,HLFS,12) I $$FOREIGN^IBCNINSU(.FLD,""1;3;4;5"",1) S $P(PID,HLFS,12)=FLD ;PID-11"
^XMB(3.9,144657,2,7217,0)="""RTN"",""IBCNEUT2"",117,0)"
^XMB(3.9,144657,2,7218,0)=" . S FLD=$P(IN1,HLFS,9) I $$FOREIGN^IBCNINSU(.FLD,1,1) S $P(IN1,HLFS,9)=FLD ;IN1-8 GROUP NUMBER"
^XMB(3.9,144657,2,7219,0)="""RTN"",""IBCNEUT2"",118,0)"
^XMB(3.9,144657,2,7220,0)=" . S FLD=$P(IN1,HLFS,10) I $$FOREIGN^IBCNINSU(.FLD,1,1) S $P(IN1,HLFS,10)=FLD ;IN1-9 GROUP NAME"
^XMB(3.9,144657,2,7221,0)="""RTN"",""IBCNEUT2"",119,0)"
^XMB(3.9,144657,2,7222,0)=" . I $D(GT1) D"
^XMB(3.9,144657,2,7223,0)="""RTN"",""IBCNEUT2"",120,0)"
^XMB(3.9,144657,2,7224,0)=" .. ; GT1-6 Addr (street,ignore,city,state,zip)"
^XMB(3.9,144657,2,7225,0)="""RTN"",""IBCNEUT2"",121,0)"
^XMB(3.9,144657,2,7226,0)=" .. S FLD=$P(GT1,HLFS,7) I $$FOREIGN^IBCNINSU(.FLD,""1;3;4;5"",1) S $P(GT1,HLFS,7)=FLD ;GT1-6"
^XMB(3.9,144657,2,7227,0)="""RTN"",""IBCNEUT2"",122,0)"
^XMB(3.9,144657,2,7228,0)=" ;"
^XMB(3.9,144657,2,7229,0)="""RTN"",""IBCNEUT2"",123,0)"
^XMB(3.9,144657,2,7230,0)=" ; MBI REQUEST"
^XMB(3.9,144657,2,7231,0)="""RTN"",""IBCNEUT2"",124,0)"
^XMB(3.9,144657,2,7232,0)=" I EXT=7 D  G BADMSGX"
^XMB(3.9,144657,2,7233,0)="""RTN"",""IBCNEUT2"",125,0)"
^XMB(3.9,144657,2,7234,0)=" . I $$FOREIGN^IBCNINSU($P(PID,HLFS,6),""1;2;3;4;5;6"") S STOP=1 Q  ;PID-5 SUBSCRIBER NAME"
^XMB(3.9,144657,2,7235,0)="""RTN"",""IBCNEUT2"",126,0)"
^XMB(3.9,144657,2,7236,0)=" . ;"
^XMB(3.9,144657,2,7237,0)="""RTN"",""IBCNEUT2"",127,0)"
^XMB(3.9,144657,2,7238,0)=" . ;If foreign chars encountered clear field and continue with msg"
^XMB(3.9,144657,2,7239,0)="""RTN"",""IBCNEUT2"",128,0)"
^XMB(3.9,144657,2,7240,0)=" . ;"
^XMB(3.9,144657,2,7241,0)="""RTN"",""IBCNEUT2"",129,0)"
^XMB(3.9,144657,2,7242,0)=" . ; PID-11 Addr (street,ignore,city,state,zip)"
^XMB(3.9,144657,2,7243,0)="""RTN"",""IBCNEUT2"",130,0)"
^XMB(3.9,144657,2,7244,0)=" . S FLD=$P(PID,HLFS,12) I $$FOREIGN^IBCNINSU(.FLD,""1;3;4;5"",1) S $P(PID,HLFS,12)=FLD   ;PID-11"
^XMB(3.9,144657,2,7245,0)="""RTN"",""IBCNEUT2"",131,0)"
^XMB(3.9,144657,2,7246,0)=" ;"
^XMB(3.9,144657,2,7247,0)="""RTN"",""IBCNEUT2"",132,0)"
^XMB(3.9,144657,2,7248,0)="BADMSGX ;Exit BADMSG"
^XMB(3.9,144657,2,7249,0)="""RTN"",""IBCNEUT2"",133,0)"
^XMB(3.9,144657,2,7250,0)=" I 'STOP D"
^XMB(3.9,144657,2,7251,0)="""RTN"",""IBCNEUT2"",134,0)"
^XMB(3.9,144657,2,7252,0)=" . S HCT=$G(TMP(""PID"")) I HCT S ^TMP(""HLS"",$J,HCT)=PID"
^XMB(3.9,144657,2,7253,0)="""RTN"",""IBCNEUT2"",135,0)"
^XMB(3.9,144657,2,7254,0)=" . S HCT=$G(TMP(""IN1"")) I HCT S ^TMP(""HLS"",$J,HCT)=IN1"
^XMB(3.9,144657,2,7255,0)="""RTN"",""IBCNEUT2"",136,0)"
^XMB(3.9,144657,2,7256,0)=" . S HCT=$G(TMP(""GT1"")) I HCT S ^TMP(""HLS"",$J,HCT)=GT1"
^XMB(3.9,144657,2,7257,0)="""RTN"",""IBCNEUT2"",137,0)"
^XMB(3.9,144657,2,7258,0)=" Q STOP"
^XMB(3.9,144657,2,7259,0)="""RTN"",""IBCNEUT2"",138,0)"
^XMB(3.9,144657,2,7260,0)=" ;"
^XMB(3.9,144657,2,7261,0)="""RTN"",""IBCNEUT2"",139,0)"
^XMB(3.9,144657,2,7262,0)="EBSUMMARY(DFN,RIEN,SOI,ARRAY) ; Added IB*806"
^XMB(3.9,144657,2,7263,0)="""RTN"",""IBCNEUT2"",140,0)"
^XMB(3.9,144657,2,7264,0)=" ;"
^XMB(3.9,144657,2,7265,0)="""RTN"",""IBCNEUT2"",141,0)"
^XMB(3.9,144657,2,7266,0)=" ; ***********************"
^XMB(3.9,144657,2,7267,0)="""RTN"",""IBCNEUT2"",142,0)"
^XMB(3.9,144657,2,7268,0)=" ; DO NOT change this code without careful consideration !!!"
^XMB(3.9,144657,2,7269,0)="""RTN"",""IBCNEUT2"",143,0)"
^XMB(3.9,144657,2,7270,0)=" ; It is called by IBCNEHL5A to Auto-load policies as eIV Responses are processed"
^XMB(3.9,144657,2,7271,0)="""RTN"",""IBCNEUT2"",144,0)"
^XMB(3.9,144657,2,7272,0)=" ; Also, it is called by IBCNES for the ELIG. Benefits (from both file #2 and #365 perspectives)"
^XMB(3.9,144657,2,7273,0)="""RTN"",""IBCNEUT2"",145,0)"
^XMB(3.9,144657,2,7274,0)=" ; ***********************"
^XMB(3.9,144657,2,7275,0)="""RTN"",""IBCNEUT2"",146,0)"
^XMB(3.9,144657,2,7276,0)=" ;"
^XMB(3.9,144657,2,7277,0)="""RTN"",""IBCNEUT2"",147,0)"
^XMB(3.9,144657,2,7278,0)=" ; Example:"
^XMB(3.9,144657,2,7279,0)="""RTN"",""IBCNEUT2"",148,0)"
^XMB(3.9,144657,2,7280,0)=" ; Insurance Type: Medicare Part A Elig/Ben Info: Active Coverage "
^XMB(3.9,144657,2,7281,0)="""RTN"",""IBCNEUT2"",149,0)"
^XMB(3.9,144657,2,7282,0)=" ; Date/Time Qual: Plan D/T Period: 05/01/2019 "
^XMB(3.9,144657,2,7283,0)="""RTN"",""IBCNEUT2"",150,0)"
^XMB(3.9,144657,2,7284,0)=" ;"
^XMB(3.9,144657,2,7285,0)="""RTN"",""IBCNEUT2"",151,0)"
^XMB(3.9,144657,2,7286,0)=" ; Returns ARRAY(EBCNT,""Medicare Part A"")=DFN^""Medicare Part A""^3190501^SOI^""Active Coverage"""
^XMB(3.9,144657,2,7287,0)="""RTN"",""IBCNEUT2"",152,0)"
^XMB(3.9,144657,2,7288,0)=" ; - if Other Potential Insurance - ARRAY(""OHI)=1"
^XMB(3.9,144657,2,7289,0)="""RTN"",""IBCNEUT2"",153,0)"
^XMB(3.9,144657,2,7290,0)=" ; - if the Effective Date for an Active policy is missing - ARRAY(""MISSING_EFFDT"")=1"
^XMB(3.9,144657,2,7291,0)="""RTN"",""IBCNEUT2"",154,0)"
^XMB(3.9,144657,2,7292,0)=" ;"
^XMB(3.9,144657,2,7293,0)="""RTN"",""IBCNEUT2"",155,0)"
^XMB(3.9,144657,2,7294,0)=" ; How to determine effective date:"
^XMB(3.9,144657,2,7295,0)="""RTN"",""IBCNEUT2"",156,0)"
^XMB(3.9,144657,2,7296,0)=" ;   1st attempt to pull from EB loop "
^XMB(3.9,144657,2,7297,0)="""RTN"",""IBCNEUT2"",157,0)"
^XMB(3.9,144657,2,7298,0)=" ;      Loop must have:(INSTYP'="""") & ELGBENINFO=""Active Coverage"" or ""Inactive"""
^XMB(3.9,144657,2,7299,0)="""RTN"",""IBCNEUT2"",158,0)"
^XMB(3.9,144657,2,7300,0)=" ;        If Medicare pull the 1st date where qualifier = ""PLAN"""
^XMB(3.9,144657,2,7301,0)="""RTN"",""IBCNEUT2"",159,0)"
^XMB(3.9,144657,2,7302,0)=" ;        If not Medicare pull 1st date where qualifier =""PLAN"" or ""PLAN BEGIN"""
^XMB(3.9,144657,2,7303,0)="""RTN"",""IBCNEUT2"",160,0)"
^XMB(3.9,144657,2,7304,0)=" ;           check all dates as ""PLAN BEGIN"" trumps ""PLAN"""
^XMB(3.9,144657,2,7305,0)="""RTN"",""IBCNEUT2"",161,0)"
^XMB(3.9,144657,2,7306,0)=" ;   if no eff dt then continue other attempts"
^XMB(3.9,144657,2,7307,0)="""RTN"",""IBCNEUT2"",162,0)"
^XMB(3.9,144657,2,7308,0)=" ;      2nd attempt - If not Medicare pull from Subscriber dates (#365.28,.02)"
^XMB(3.9,144657,2,7309,0)="""RTN"",""IBCNEUT2"",163,0)"
^XMB(3.9,144657,2,7310,0)=" ;         pull 1st date where qualifier =""PLAN"" or ""PLAN BEGIN"""
^XMB(3.9,144657,2,7311,0)="""RTN"",""IBCNEUT2"",164,0)"
^XMB(3.9,144657,2,7312,0)=" ;           check all dates as ""PLAN BEGIN"" trumps ""PLAN"""
^XMB(3.9,144657,2,7313,0)="""RTN"",""IBCNEUT2"",165,0)"
^XMB(3.9,144657,2,7314,0)=" ;   if no eff dt then continue other attempts"
^XMB(3.9,144657,2,7315,0)="""RTN"",""IBCNEUT2"",166,0)"
^XMB(3.9,144657,2,7316,0)=" ;      LAST attempt - pull from Effective date (#365,1.11)"
^XMB(3.9,144657,2,7317,0)="""RTN"",""IBCNEUT2"",167,0)"
^XMB(3.9,144657,2,7318,0)=" ;        applies to both Medicare and non Medicare"
^XMB(3.9,144657,2,7319,0)="""RTN"",""IBCNEUT2"",168,0)"
^XMB(3.9,144657,2,7320,0)=" ;   Otherwise effective date is ""Unknown"""
^XMB(3.9,144657,2,7321,0)="""RTN"",""IBCNEUT2"",169,0)"
^XMB(3.9,144657,2,7322,0)=" ;"
^XMB(3.9,144657,2,7323,0)="""RTN"",""IBCNEUT2"",170,0)"
^XMB(3.9,144657,2,7324,0)=" ;"
^XMB(3.9,144657,2,7325,0)="""RTN"",""IBCNEUT2"",171,0)"
^XMB(3.9,144657,2,7326,0)=" N DTQUAL,EBCNT,ELGBENINFO,EXTELIG,FSCSTAT,HLDT,HLDNDT"
^XMB(3.9,144657,2,7327,0)="""RTN"",""IBCNEUT2"",172,0)"
^XMB(3.9,144657,2,7328,0)=" N IBA,IBBERR,IBCHK,IBEFFDT,IBEINFO,IBELGINF,IBNOTCOV,IBNOTDT,IBNOTTYP,IBPEDT,IBSPDT,IBSUSCT"
^XMB(3.9,144657,2,7329,0)="""RTN"",""IBCNEUT2"",173,0)"
^XMB(3.9,144657,2,7330,0)=" N IBVIENS,INSTYP,MWNRTYP,TMP,XXDT,ZIEN"
^XMB(3.9,144657,2,7331,0)="""RTN"",""IBCNEUT2"",174,0)"
^XMB(3.9,144657,2,7332,0)=" K ARRAY,^TMP(""EBSUMEUT2"",$J)"
^XMB(3.9,144657,2,7333,0)="""RTN"",""IBCNEUT2"",175,0)"
^XMB(3.9,144657,2,7334,0)=" ;"
^XMB(3.9,144657,2,7335,0)="""RTN"",""IBCNEUT2"",176,0)"
^XMB(3.9,144657,2,7336,0)=" I '$D(^IBCN(365,RIEN,2)) G XEBSUM  ; NO Benefits received"
^XMB(3.9,144657,2,7337,0)="""RTN"",""IBCNEUT2"",177,0)"
^XMB(3.9,144657,2,7338,0)=" ;"
^XMB(3.9,144657,2,7339,0)="""RTN"",""IBCNEUT2"",178,0)"
^XMB(3.9,144657,2,7340,0)=" S (IBSPDT,IBSUSCT,IBPEDT,IBELGINF)="""""
^XMB(3.9,144657,2,7341,0)="""RTN"",""IBCNEUT2"",179,0)"
^XMB(3.9,144657,2,7342,0)=" ; determine the default date if the HLDT is not there"
^XMB(3.9,144657,2,7343,0)="""RTN"",""IBCNEUT2"",180,0)"
^XMB(3.9,144657,2,7344,0)=" ;use the subscriber date plan date if it is a plan, or the Effective date, Unknown if still not found"
^XMB(3.9,144657,2,7345,0)="""RTN"",""IBCNEUT2"",181,0)"
^XMB(3.9,144657,2,7346,0)=" ;  this is to calculate the default eff date if it can't be determined by the EB loops from the response"
^XMB(3.9,144657,2,7347,0)="""RTN"",""IBCNEUT2"",182,0)"
^XMB(3.9,144657,2,7348,0)=" K IBCHK,IBBERR D GETS^DIQ(365,RIEN_"","",""7*"",""IEN"",""IBCHK"",""IBBERR"")"
^XMB(3.9,144657,2,7349,0)="""RTN"",""IBCNEUT2"",183,0)"
^XMB(3.9,144657,2,7350,0)=" I $D(IBCHK(365.07)) D  ; loop through for Subscribers collect the 'plan' and 'plan begin' dates"
^XMB(3.9,144657,2,7351,0)="""RTN"",""IBCNEUT2"",184,0)"
^XMB(3.9,144657,2,7352,0)=" . N DQUAL,DTYP,IBA,IBB,IBL,IBOK,IBP,IBPB,IBTDT,IBTDT1"
^XMB(3.9,144657,2,7353,0)="""RTN"",""IBCNEUT2"",185,0)"
^XMB(3.9,144657,2,7354,0)=" . K IBP,IBPB"
^XMB(3.9,144657,2,7355,0)="""RTN"",""IBCNEUT2"",186,0)"
^XMB(3.9,144657,2,7356,0)=" . S IBB="""",(IBOK,IBP,IBPB)=0"
^XMB(3.9,144657,2,7357,0)="""RTN"",""IBCNEUT2"",187,0)"
^XMB(3.9,144657,2,7358,0)=" . F  S IBB=$O(IBCHK(365.07,IBB)) Q:IBB=""""  D  Q:IBOK"
^XMB(3.9,144657,2,7359,0)="""RTN"",""IBCNEUT2"",188,0)"
^XMB(3.9,144657,2,7360,0)=" . . S DTYP=$G(IBCHK(365.07,IBB,.04,""E"")) Q:DTYP'[""C""  ; C is for Subscriber"
^XMB(3.9,144657,2,7361,0)="""RTN"",""IBCNEUT2"",189,0)"
^XMB(3.9,144657,2,7362,0)=" . . S DQUAL=$G(IBCHK(365.07,IBB,.03,""I"")) Q:'DQUAL  S IBA=$$X12^IBCNERP2(365.026,DQUAL)"
^XMB(3.9,144657,2,7363,0)="""RTN"",""IBCNEUT2"",190,0)"
^XMB(3.9,144657,2,7364,0)=" . . I IBA'=""Plan""&(IBA'=""Plan Begin"") Q  ; Must be Plan or Plan Begin"
^XMB(3.9,144657,2,7365,0)="""RTN"",""IBCNEUT2"",191,0)"
^XMB(3.9,144657,2,7366,0)=" . . S IBTDT=$G(IBCHK(365.07,IBB,.02,""I"")),IBTDT=$P(IBTDT,""-"",1),IBTDT=$TR(IBTDT,"" "","""")"
^XMB(3.9,144657,2,7367,0)="""RTN"",""IBCNEUT2"",192,0)"
^XMB(3.9,144657,2,7368,0)=" . . I IBTDT="""" Q  ; must have a date"
^XMB(3.9,144657,2,7369,0)="""RTN"",""IBCNEUT2"",193,0)"
^XMB(3.9,144657,2,7370,0)=" . . S IBTDT1=$$HL7TFM^XLFDT(IBTDT)"
^XMB(3.9,144657,2,7371,0)="""RTN"",""IBCNEUT2"",194,0)"
^XMB(3.9,144657,2,7372,0)=" . . I IBTDT1=""""!(IBTDT1=""-1"") Q  ;must be valid date"
^XMB(3.9,144657,2,7373,0)="""RTN"",""IBCNEUT2"",195,0)"
^XMB(3.9,144657,2,7374,0)=" . . I IBA=""Plan"" I IBSPDT="""" S IBSPDT=IBTDT1"
^XMB(3.9,144657,2,7375,0)="""RTN"",""IBCNEUT2"",196,0)"
^XMB(3.9,144657,2,7376,0)=" . . I IBA=""Plan Begin"" S IBSPDT=IBTDT1,IBOK=1"
^XMB(3.9,144657,2,7377,0)="""RTN"",""IBCNEUT2"",197,0)"
^XMB(3.9,144657,2,7378,0)=" ;"
^XMB(3.9,144657,2,7379,0)="""RTN"",""IBCNEUT2"",198,0)"
^XMB(3.9,144657,2,7380,0)=" I IBSPDT="""" S IBSPDT=$$GET1^DIQ(365,RIEN,""1.11"",""I"")  ; get Effective dt from top display as 2nd default (from IN1 segment)"
^XMB(3.9,144657,2,7381,0)="""RTN"",""IBCNEUT2"",199,0)"
^XMB(3.9,144657,2,7382,0)=" I IBSPDT="""" S IBSPDT=""Unknown""  ;  eff dt default to use for non medicare policies if not found in EB loops"
^XMB(3.9,144657,2,7383,0)="""RTN"",""IBCNEUT2"",200,0)"
^XMB(3.9,144657,2,7384,0)=" ;"
^XMB(3.9,144657,2,7385,0)="""RTN"",""IBCNEUT2"",201,0)"
^XMB(3.9,144657,2,7386,0)=" S IBEFFDT="""",IBEFFDT=$$GET1^DIQ(365,RIEN,""1.11"",""I"") S:'IBEFFDT IBEFFDT=""Unknown"""
^XMB(3.9,144657,2,7387,0)="""RTN"",""IBCNEUT2"",202,0)"
^XMB(3.9,144657,2,7388,0)=" ;"
^XMB(3.9,144657,2,7389,0)="""RTN"",""IBCNEUT2"",203,0)"
^XMB(3.9,144657,2,7390,0)=" S MWNRTYP=$$ISMCARE(RIEN) ; is the payer medicare"
^XMB(3.9,144657,2,7391,0)="""RTN"",""IBCNEUT2"",204,0)"
^XMB(3.9,144657,2,7392,0)=" ;"
^XMB(3.9,144657,2,7393,0)="""RTN"",""IBCNEUT2"",205,0)"
^XMB(3.9,144657,2,7394,0)=" S EBCNT=0 F  S EBCNT=$O(^IBCN(365,RIEN,2,EBCNT)) Q:'EBCNT  D"
^XMB(3.9,144657,2,7395,0)="""RTN"",""IBCNEUT2"",206,0)"
^XMB(3.9,144657,2,7396,0)=" . S IBVIENS=EBCNT_"",""_RIEN_"","""
^XMB(3.9,144657,2,7397,0)="""RTN"",""IBCNEUT2"",207,0)"
^XMB(3.9,144657,2,7398,0)=" . K EB,ERROR"
^XMB(3.9,144657,2,7399,0)="""RTN"",""IBCNEUT2"",208,0)"
^XMB(3.9,144657,2,7400,0)=" . D GETS^DIQ(365.02,IBVIENS,"".02;.03;.04;.05;.06;8*"",""IEN"",""EB"",""EBERR"")"
^XMB(3.9,144657,2,7401,0)="""RTN"",""IBCNEUT2"",209,0)"
^XMB(3.9,144657,2,7402,0)=" . ;"
^XMB(3.9,144657,2,7403,0)="""RTN"",""IBCNEUT2"",210,0)"
^XMB(3.9,144657,2,7404,0)=" . I (EBCNT=1),($G(EB(365.02,IBVIENS,.06,""E""))=""eIV Eligibility Determination"") D  Q  ; use EB loop 1 only to pull FSC's determination and nothing else"
^XMB(3.9,144657,2,7405,0)="""RTN"",""IBCNEUT2"",211,0)"
^XMB(3.9,144657,2,7406,0)=" . . S FSCSTAT=$G(EB(365.02,IBVIENS,.02,""E""))"
^XMB(3.9,144657,2,7407,0)="""RTN"",""IBCNEUT2"",212,0)"
^XMB(3.9,144657,2,7408,0)=" . . S FSCSTAT=$S((FSCSTAT'=1&(FSCSTAT'=6)):""Unknown"",1:FSCSTAT) ; this is what FSC said (Active, Inactive, Ambiguous)"
^XMB(3.9,144657,2,7409,0)="""RTN"",""IBCNEUT2"",213,0)"
^XMB(3.9,144657,2,7410,0)=" . . S IBELGINF=$S(FSCSTAT=1:""ACTIVE Coverage"",FSCSTAT=6:""INACTIVE Coverage"",1:""Unknown"")"
^XMB(3.9,144657,2,7411,0)="""RTN"",""IBCNEUT2"",214,0)"
^XMB(3.9,144657,2,7412,0)=" . ;"
^XMB(3.9,144657,2,7413,0)="""RTN"",""IBCNEUT2"",215,0)"
^XMB(3.9,144657,2,7414,0)=" . S INSTYP=$P($G(^IBE(365.014,+$G(EB(365.02,IBVIENS,.05,""I"")),0)),U,2)"
^XMB(3.9,144657,2,7415,0)="""RTN"",""IBCNEUT2"",216,0)"
^XMB(3.9,144657,2,7416,0)=" . ;"
^XMB(3.9,144657,2,7417,0)="""RTN"",""IBCNEUT2"",217,0)"
^XMB(3.9,144657,2,7418,0)=" . ; X12 271 ELIGIBILITY/BENEFIT file #365.011 - this tag only uses the following codes below:"
^XMB(3.9,144657,2,7419,0)="""RTN"",""IBCNEUT2"",218,0)"
^XMB(3.9,144657,2,7420,0)=" . ; 1=""Active coverage"""
^XMB(3.9,144657,2,7421,0)="""RTN"",""IBCNEUT2"",219,0)"
^XMB(3.9,144657,2,7422,0)=" . ; 2=""Active - Full Risk Capitation"""
^XMB(3.9,144657,2,7423,0)="""RTN"",""IBCNEUT2"",220,0)"
^XMB(3.9,144657,2,7424,0)=" . ; 3=""Active - Services Capitated"""
^XMB(3.9,144657,2,7425,0)="""RTN"",""IBCNEUT2"",221,0)"
^XMB(3.9,144657,2,7426,0)=" . ; 4=""Active - Services Capitated to Primary Care Physician"""
^XMB(3.9,144657,2,7427,0)="""RTN"",""IBCNEUT2"",222,0)"
^XMB(3.9,144657,2,7428,0)=" . ; 6=""Inactive"""
^XMB(3.9,144657,2,7429,0)="""RTN"",""IBCNEUT2"",223,0)"
^XMB(3.9,144657,2,7430,0)=" . ; R=""Other or Additional Payor"""
^XMB(3.9,144657,2,7431,0)="""RTN"",""IBCNEUT2"",224,0)"
^XMB(3.9,144657,2,7432,0)=" . ; U=""Contract Following Entity for Eligibility or Benefit Information"""
^XMB(3.9,144657,2,7433,0)="""RTN"",""IBCNEUT2"",225,0)"
^XMB(3.9,144657,2,7434,0)=" . S EXTELIG=$G(EB(365.02,IBVIENS,.02,""E""))"
^XMB(3.9,144657,2,7435,0)="""RTN"",""IBCNEUT2"",226,0)"
^XMB(3.9,144657,2,7436,0)=" . ;"
^XMB(3.9,144657,2,7437,0)="""RTN"",""IBCNEUT2"",227,0)"
^XMB(3.9,144657,2,7438,0)=" . ; Indicates potential Other Health Insurance (OHI) do OHI checks before quits"
^XMB(3.9,144657,2,7439,0)="""RTN"",""IBCNEUT2"",228,0)"
^XMB(3.9,144657,2,7440,0)=" . I (EXTELIG=2)!(EXTELIG=3)!(EXTELIG=4)!(EXTELIG=""R"")!(EXTELIG=""U"") S ARRAY(""OHI"")=1"
^XMB(3.9,144657,2,7441,0)="""RTN"",""IBCNEUT2"",229,0)"
^XMB(3.9,144657,2,7442,0)=" . ;"
^XMB(3.9,144657,2,7443,0)="""RTN"",""IBCNEUT2"",230,0)"
^XMB(3.9,144657,2,7444,0)=" . I INSTYP="""" Q  ; moved quit to after the OHI check"
^XMB(3.9,144657,2,7445,0)="""RTN"",""IBCNEUT2"",231,0)"
^XMB(3.9,144657,2,7446,0)=" . ;"
^XMB(3.9,144657,2,7447,0)="""RTN"",""IBCNEUT2"",232,0)"
^XMB(3.9,144657,2,7448,0)=" . I (EXTELIG'=1)&(EXTELIG'=6)&(EXTELIG'=2)&(EXTELIG'=3)&(EXTELIG'=4)&(EXTELIG'=""R"")&(EXTELIG'=""U"") Q"
^XMB(3.9,144657,2,7449,0)="""RTN"",""IBCNEUT2"",233,0)"
^XMB(3.9,144657,2,7450,0)=" . ;"
^XMB(3.9,144657,2,7451,0)="""RTN"",""IBCNEUT2"",234,0)"
^XMB(3.9,144657,2,7452,0)=" . S ELGBENINFO=$P($G(^IBE(365.011,+$G(EB(365.02,IBVIENS,.02,""I"")),0)),U,2)"
^XMB(3.9,144657,2,7453,0)="""RTN"",""IBCNEUT2"",235,0)"
^XMB(3.9,144657,2,7454,0)=" . I ELGBENINFO'=""Active Coverage""&(ELGBENINFO'=""Inactive"") Q"
^XMB(3.9,144657,2,7455,0)="""RTN"",""IBCNEUT2"",236,0)"
^XMB(3.9,144657,2,7456,0)=" . ;"
^XMB(3.9,144657,2,7457,0)="""RTN"",""IBCNEUT2"",237,0)"
^XMB(3.9,144657,2,7458,0)=" . S HLDT="""""
^XMB(3.9,144657,2,7459,0)="""RTN"",""IBCNEUT2"",238,0)"
^XMB(3.9,144657,2,7460,0)=" . S ZIEN=""0,""_IBVIENS,IBOK=0"
^XMB(3.9,144657,2,7461,0)="""RTN"",""IBCNEUT2"",239,0)"
^XMB(3.9,144657,2,7462,0)=" . F  S ZIEN=$O(EB(365.28,ZIEN)) Q:ZIEN=""""  D  Q:IBOK=1"
^XMB(3.9,144657,2,7463,0)="""RTN"",""IBCNEUT2"",240,0)"
^XMB(3.9,144657,2,7464,0)=" . . S DTQUAL=$P($G(^IBE(365.026,+$G(EB(365.28,ZIEN,.03,""I"")),0)),U,2)"
^XMB(3.9,144657,2,7465,0)="""RTN"",""IBCNEUT2"",241,0)"
^XMB(3.9,144657,2,7466,0)=" . . I (MWNRTYP),(DTQUAL'=""Plan"") Q  ; Medicare policies are only looking for ""Plan"""
^XMB(3.9,144657,2,7467,0)="""RTN"",""IBCNEUT2"",242,0)"
^XMB(3.9,144657,2,7468,0)=" . . I ('MWNRTYP),((DTQUAL'=""Plan"")&(DTQUAL'=""Plan Begin"")) Q  ; Non Medicare policies look for ""Plan"" & ""Plan Begin"""
^XMB(3.9,144657,2,7469,0)="""RTN"",""IBCNEUT2"",243,0)"
^XMB(3.9,144657,2,7470,0)=" . . S XXDT=$$HL7TFM^XLFDT($G(EB(365.28,ZIEN,.02,""E"")))"
^XMB(3.9,144657,2,7471,0)="""RTN"",""IBCNEUT2"",244,0)"
^XMB(3.9,144657,2,7472,0)=" . . I MWNRTYP S HLDT=XXDT,IBOK=1 Q  ;Medicare will not have multiple plan dates in same EB loop"
^XMB(3.9,144657,2,7473,0)="""RTN"",""IBCNEUT2"",245,0)"
^XMB(3.9,144657,2,7474,0)=" . . I DTQUAL=""Plan"" I HLDT="""" S HLDT=XXDT"
^XMB(3.9,144657,2,7475,0)="""RTN"",""IBCNEUT2"",246,0)"
^XMB(3.9,144657,2,7476,0)=" . . I DTQUAL=""Plan Begin"" S HLDT=XXDT,IBOK=1"
^XMB(3.9,144657,2,7477,0)="""RTN"",""IBCNEUT2"",247,0)"
^XMB(3.9,144657,2,7478,0)=" . ;"
^XMB(3.9,144657,2,7479,0)="""RTN"",""IBCNEUT2"",248,0)"
^XMB(3.9,144657,2,7480,0)=" . I HLDT="""",ELGBENINFO'=""Inactive"" S ARRAY(""MISSING_EFFDT"")=1"
^XMB(3.9,144657,2,7481,0)="""RTN"",""IBCNEUT2"",249,0)"
^XMB(3.9,144657,2,7482,0)=" . ;"
^XMB(3.9,144657,2,7483,0)="""RTN"",""IBCNEUT2"",250,0)"
^XMB(3.9,144657,2,7484,0)=" . I HLDT=""""&('MWNRTYP) D  ; Non Medicare and no eff dt found in EB loop use default from above"
^XMB(3.9,144657,2,7485,0)="""RTN"",""IBCNEUT2"",251,0)"
^XMB(3.9,144657,2,7486,0)=" . . S HLDT=IBSPDT"
^XMB(3.9,144657,2,7487,0)="""RTN"",""IBCNEUT2"",252,0)"
^XMB(3.9,144657,2,7488,0)=" . ;  "
^XMB(3.9,144657,2,7489,0)="""RTN"",""IBCNEUT2"",253,0)"
^XMB(3.9,144657,2,7490,0)=" . S HLDNDT=$S('HLDT:IBEFFDT,1:HLDT)"
^XMB(3.9,144657,2,7491,0)="""RTN"",""IBCNEUT2"",254,0)"
^XMB(3.9,144657,2,7492,0)=" . ;"
^XMB(3.9,144657,2,7493,0)="""RTN"",""IBCNEUT2"",255,0)"
^XMB(3.9,144657,2,7494,0)=" . ;  TMP array used to avoid repeating duplicate data in summary section (payers repeat themselves)"
^XMB(3.9,144657,2,7495,0)="""RTN"",""IBCNEUT2"",256,0)"
^XMB(3.9,144657,2,7496,0)=" . I $D(^TMP(""EBSUMEUT2"",$J,$S(INSTYP="""":"" "",1:INSTYP),$S(ELGBENINFO="""":"" "",1:ELGBENINFO),HLDNDT)) Q"
^XMB(3.9,144657,2,7497,0)="""RTN"",""IBCNEUT2"",257,0)"
^XMB(3.9,144657,2,7498,0)=" . ;"
^XMB(3.9,144657,2,7499,0)="""RTN"",""IBCNEUT2"",258,0)"
^XMB(3.9,144657,2,7500,0)=" . S ARRAY(EBCNT,INSTYP)=DFN_U_INSTYP_U_HLDT_U_SOI_U_ELGBENINFO"
^XMB(3.9,144657,2,7501,0)="""RTN"",""IBCNEUT2"",259,0)"
^XMB(3.9,144657,2,7502,0)=" . ;"
^XMB(3.9,144657,2,7503,0)="""RTN"",""IBCNEUT2"",260,0)"
^XMB(3.9,144657,2,7504,0)=" . S ^TMP(""EBSUMEUT2"",$J,$S(INSTYP="""":"" "",1:INSTYP),$S(ELGBENINFO="""":"" "",1:ELGBENINFO),HLDNDT)="""""
^XMB(3.9,144657,2,7505,0)="""RTN"",""IBCNEUT2"",261,0)"
^XMB(3.9,144657,2,7506,0)=" ;"
^XMB(3.9,144657,2,7507,0)="""RTN"",""IBCNEUT2"",262,0)"
^XMB(3.9,144657,2,7508,0)=" ;"
^XMB(3.9,144657,2,7509,0)="""RTN"",""IBCNEUT2"",263,0)"
^XMB(3.9,144657,2,7510,0)=" I '$O(ARRAY(0))&('MWNRTYP) D  ; not for medicare payer"
^XMB(3.9,144657,2,7511,0)="""RTN"",""IBCNEUT2"",264,0)"
^XMB(3.9,144657,2,7512,0)=" . S ARRAY(1,""Unknown"")=$G(DFN)_U_""Unknown""_U_$G(IBSPDT)_U_$G(SOI)_U_$G(IBELGINF)"
^XMB(3.9,144657,2,7513,0)="""RTN"",""IBCNEUT2"",265,0)"
^XMB(3.9,144657,2,7514,0)=" ;"
^XMB(3.9,144657,2,7515,0)="""RTN"",""IBCNEUT2"",266,0)"
^XMB(3.9,144657,2,7516,0)="XEBSUM ;"
^XMB(3.9,144657,2,7517,0)="""RTN"",""IBCNEUT2"",267,0)"
^XMB(3.9,144657,2,7518,0)=" ;"
^XMB(3.9,144657,2,7519,0)="""RTN"",""IBCNEUT2"",268,0)"
^XMB(3.9,144657,2,7520,0)=" K ^TMP(""EBSUMEUT2"",$J)"
^XMB(3.9,144657,2,7521,0)="""RTN"",""IBCNEUT2"",269,0)"
^XMB(3.9,144657,2,7522,0)=" Q"
^XMB(3.9,144657,2,7523,0)="""RTN"",""IBCNEUT2"",270,0)"
^XMB(3.9,144657,2,7524,0)=" ;"
^XMB(3.9,144657,2,7525,0)="""RTN"",""IBCNEUT2"",271,0)"
^XMB(3.9,144657,2,7526,0)="ISMCARE(RIEN) ;check if response is from eIV Medicare Payer defined in file 350.9"
^XMB(3.9,144657,2,7527,0)="""RTN"",""IBCNEUT2"",272,0)"
^XMB(3.9,144657,2,7528,0)=" ; new tag with IB*806"
^XMB(3.9,144657,2,7529,0)="""RTN"",""IBCNEUT2"",273,0)"
^XMB(3.9,144657,2,7530,0)=" N IB3650,IBPIEN,MWNRIEN,MWNRTYPA"
^XMB(3.9,144657,2,7531,0)="""RTN"",""IBCNEUT2"",274,0)"
^XMB(3.9,144657,2,7532,0)=" S IB3650=$G(^IBCN(365,RIEN,0)),IBPIEN=$P(IB3650,U,3)"
^XMB(3.9,144657,2,7533,0)="""RTN"",""IBCNEUT2"",275,0)"
^XMB(3.9,144657,2,7534,0)=" S MWNRIEN=$P($G(^IBE(350.9,1,51)),U,25),MWNRTYPA=0"
^XMB(3.9,144657,2,7535,0)="""RTN"",""IBCNEUT2"",276,0)"
^XMB(3.9,144657,2,7536,0)=" I IBPIEN=MWNRIEN S MWNRTYPA=1"
^XMB(3.9,144657,2,7537,0)="""RTN"",""IBCNEUT2"",277,0)"
^XMB(3.9,144657,2,7538,0)=" Q MWNRTYPA"
