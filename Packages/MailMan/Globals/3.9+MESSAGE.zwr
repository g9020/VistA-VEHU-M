^XMB(3.9,145834,2,6558,0)=" N I,IEN,MOD100,REMAINDER,ZEROS"
^XMB(3.9,145834,2,6559,0)="""RTN"",""MAGDSTAS"",169,0)"
^XMB(3.9,145834,2,6560,0)=" S ZEROS=$TR($J("""",100),"" "",""0"")"
^XMB(3.9,145834,2,6561,0)="""RTN"",""MAGDSTAS"",170,0)"
^XMB(3.9,145834,2,6562,0)=" F IEN=IEN1:1:IEN2 D"
^XMB(3.9,145834,2,6563,0)="""RTN"",""MAGDSTAS"",171,0)"
^XMB(3.9,145834,2,6564,0)=" . S MOD100=(IEN\100)"
^XMB(3.9,145834,2,6565,0)="""RTN"",""MAGDSTAS"",172,0)"
^XMB(3.9,145834,2,6566,0)=" . I '$D(^TMP(""MAG"",$J,""BATCH Q/R"",""NUMBER"",MOD100)) S ^(MOD100)=ZEROS"
^XMB(3.9,145834,2,6567,0)="""RTN"",""MAGDSTAS"",173,0)"
^XMB(3.9,145834,2,6568,0)=" . S REMAINDER=IEN-(MOD100*100)"
^XMB(3.9,145834,2,6569,0)="""RTN"",""MAGDSTAS"",174,0)"
^XMB(3.9,145834,2,6570,0)=" . S $E(^TMP(""MAG"",$J,""BATCH Q/R"",""NUMBER"",MOD100),REMAINDER+1)=""1"""
^XMB(3.9,145834,2,6571,0)="""RTN"",""MAGDSTAS"",175,0)"
^XMB(3.9,145834,2,6572,0)=" . ; set the first zero to one, for completeness"
^XMB(3.9,145834,2,6573,0)="""RTN"",""MAGDSTAS"",176,0)"
^XMB(3.9,145834,2,6574,0)=" . I MOD100=0 S $E(^TMP(""MAG"",$J,""BATCH Q/R"",""NUMBER"",MOD100),1)=""1"""
