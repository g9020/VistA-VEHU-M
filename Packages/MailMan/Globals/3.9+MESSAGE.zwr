^XMB(3.9,145833,2,2742,0)=" S SLOTLENGTH=$S($$GET1^DIQ(44,CLINICIEN,1917,""I""):$$GET1^DIQ(44,CLINICIEN,1917,""I""),1:4)"
^XMB(3.9,145833,2,2743,0)="""RTN"",""SDESUTIL"",318,0)"
