^XMB(3.9,145834,2,3416,0)=" ;; | to be a violation of US Federal Statutes.                     |"
^XMB(3.9,145834,2,3417,0)="""RTN"",""MAGDSTA2"",16,0)"
^XMB(3.9,145834,2,3418,0)=" ;; +---------------------------------------------------------------+"
^XMB(3.9,145834,2,3419,0)="""RTN"",""MAGDSTA2"",17,0)"
^XMB(3.9,145834,2,3420,0)=" ;;"
^XMB(3.9,145834,2,3421,0)="""RTN"",""MAGDSTA2"",18,0)"
^XMB(3.9,145834,2,3422,0)=" ;"
^XMB(3.9,145834,2,3423,0)="""RTN"",""MAGDSTA2"",19,0)"
^XMB(3.9,145834,2,3424,0)=" ; Supported IA #10003 reference ^%DT subroutine call"
^XMB(3.9,145834,2,3425,0)="""RTN"",""MAGDSTA2"",20,0)"
^XMB(3.9,145834,2,3426,0)=" ; Supported IA #10103 reference $$FMTE^XLFDT function call"
^XMB(3.9,145834,2,3427,0)="""RTN"",""MAGDSTA2"",21,0)"
^XMB(3.9,145834,2,3428,0)=" ; Supported IA #10000 reference NOW^%DTC subroutine call"
^XMB(3.9,145834,2,3429,0)="""RTN"",""MAGDSTA2"",22,0)"
^XMB(3.9,145834,2,3430,0)=" ;"
^XMB(3.9,145834,2,3431,0)="""RTN"",""MAGDSTA2"",23,0)"
^XMB(3.9,145834,2,3432,0)=" Q"
^XMB(3.9,145834,2,3433,0)="""RTN"",""MAGDSTA2"",24,0)"
^XMB(3.9,145834,2,3434,0)=" ;"
^XMB(3.9,145834,2,3435,0)="""RTN"",""MAGDSTA2"",25,0)"
^XMB(3.9,145834,2,3436,0)="QRSCP ; get the PACS DICOM Q/R SCP for the retrieve"
^XMB(3.9,145834,2,3437,0)="""RTN"",""MAGDSTA2"",26,0)"
^XMB(3.9,145834,2,3438,0)=" N DEFAULT,TITLE,X"
^XMB(3.9,145834,2,3439,0)="""RTN"",""MAGDSTA2"",27,0)"
^XMB(3.9,145834,2,3440,0)=" ;"
^XMB(3.9,145834,2,3441,0)="""RTN"",""MAGDSTA2"",28,0)"
^XMB(3.9,145834,2,3442,0)=" I IMAGINGSERVICE=""RADIOLOGY"" D"
^XMB(3.9,145834,2,3443,0)="""RTN"",""MAGDSTA2"",29,0)"
^XMB(3.9,145834,2,3444,0)=" . S TITLE=""Radiology PACS"""
^XMB(3.9,145834,2,3445,0)="""RTN"",""MAGDSTA2"",30,0)"
^XMB(3.9,145834,2,3446,0)=" . Q"
^XMB(3.9,145834,2,3447,0)="""RTN"",""MAGDSTA2"",31,0)"
^XMB(3.9,145834,2,3448,0)=" E  D"
^XMB(3.9,145834,2,3449,0)="""RTN"",""MAGDSTA2"",32,0)"
^XMB(3.9,145834,2,3450,0)=" . S TITLE=""Default Consult"""
^XMB(3.9,145834,2,3451,0)="""RTN"",""MAGDSTA2"",33,0)"
^XMB(3.9,145834,2,3452,0)=" . Q"
^XMB(3.9,145834,2,3453,0)="""RTN"",""MAGDSTA2"",34,0)"
^XMB(3.9,145834,2,3454,0)=" ;"
^XMB(3.9,145834,2,3455,0)="""RTN"",""MAGDSTA2"",35,0)"
^XMB(3.9,145834,2,3456,0)=" K ^TMP(""MAG"",$J,""BATCH Q/R"",""PACS Q/R RETRIEVE SCP"") ; first remove the old value"
^XMB(3.9,145834,2,3457,0)="""RTN"",""MAGDSTA2"",36,0)"
^XMB(3.9,145834,2,3458,0)=" ;"
^XMB(3.9,145834,2,3459,0)="""RTN"",""MAGDSTA2"",37,0)"
^XMB(3.9,145834,2,3460,0)=" ; now get the new value"
^XMB(3.9,145834,2,3461,0)="""RTN"",""MAGDSTA2"",38,0)"
^XMB(3.9,145834,2,3462,0)=" S DEFAULT=$G(^TMP(""MAG"",$J,""Q/R PARAM"",""QUERY USER APPLICATION""))"
^XMB(3.9,145834,2,3463,0)="""RTN"",""MAGDSTA2"",39,0)"
^XMB(3.9,145834,2,3464,0)=" I $L(DEFAULT) D"
^XMB(3.9,145834,2,3465,0)="""RTN"",""MAGDSTA2"",40,0)"
^XMB(3.9,145834,2,3466,0)=" . W !!,""The "",TITLE,"" Query/Retrieve Provider is """""",DEFAULT,""""""."""
^XMB(3.9,145834,2,3467,0)="""RTN"",""MAGDSTA2"",41,0)"
^XMB(3.9,145834,2,3468,0)=" . I $$YESNO^MAGDSTQ(""Do you wish to change it?"",""n"",.X)<0 Q"
^XMB(3.9,145834,2,3469,0)="""RTN"",""MAGDSTA2"",42,0)"
^XMB(3.9,145834,2,3470,0)=" . I X=""YES"" D"
^XMB(3.9,145834,2,3471,0)="""RTN"",""MAGDSTA2"",43,0)"
^XMB(3.9,145834,2,3472,0)=" . . D QRSCP1"
^XMB(3.9,145834,2,3473,0)="""RTN"",""MAGDSTA2"",44,0)"
^XMB(3.9,145834,2,3474,0)=" . . Q"
^XMB(3.9,145834,2,3475,0)="""RTN"",""MAGDSTA2"",45,0)"
^XMB(3.9,145834,2,3476,0)=" . E  D"
^XMB(3.9,145834,2,3477,0)="""RTN"",""MAGDSTA2"",46,0)"
^XMB(3.9,145834,2,3478,0)=" . . S ^TMP(""MAG"",$J,""BATCH Q/R"",""PACS Q/R RETRIEVE SCP"")=DEFAULT"
^XMB(3.9,145834,2,3479,0)="""RTN"",""MAGDSTA2"",47,0)"
^XMB(3.9,145834,2,3480,0)=" . . Q"
^XMB(3.9,145834,2,3481,0)="""RTN"",""MAGDSTA2"",48,0)"
^XMB(3.9,145834,2,3482,0)=" . Q"
^XMB(3.9,145834,2,3483,0)="""RTN"",""MAGDSTA2"",49,0)"
^XMB(3.9,145834,2,3484,0)=" E  D QRSCP1"
^XMB(3.9,145834,2,3485,0)="""RTN"",""MAGDSTA2"",50,0)"
^XMB(3.9,145834,2,3486,0)=" Q"
^XMB(3.9,145834,2,3487,0)="""RTN"",""MAGDSTA2"",51,0)"
^XMB(3.9,145834,2,3488,0)=" ;"
^XMB(3.9,145834,2,3489,0)="""RTN"",""MAGDSTA2"",52,0)"
^XMB(3.9,145834,2,3490,0)="QRSCP1 ; get new value"
^XMB(3.9,145834,2,3491,0)="""RTN"",""MAGDSTA2"",53,0)"
^XMB(3.9,145834,2,3492,0)=" N OK,QRSCP"
^XMB(3.9,145834,2,3493,0)="""RTN"",""MAGDSTA2"",54,0)"
^XMB(3.9,145834,2,3494,0)=" S OK=0 F  D  Q:OK"
^XMB(3.9,145834,2,3495,0)="""RTN"",""MAGDSTA2"",55,0)"
^XMB(3.9,145834,2,3496,0)=" . W !!,""Please select the "",TITLE,"" Query/Retrieve Provider"""
^XMB(3.9,145834,2,3497,0)="""RTN"",""MAGDSTA2"",56,0)"
^XMB(3.9,145834,2,3498,0)=" . S QRSCP=$$PICKSCP^MAGDSTQ9(DEFAULT,""Q/R"")"
^XMB(3.9,145834,2,3499,0)="""RTN"",""MAGDSTA2"",57,0)"
^XMB(3.9,145834,2,3500,0)=" . I QRSCP="""" W !!,""No "",TITLE,"" query/retrieve SCP was selected"" S OK=-1 Q"
^XMB(3.9,145834,2,3501,0)="""RTN"",""MAGDSTA2"",58,0)"
^XMB(3.9,145834,2,3502,0)=" . S ^TMP(""MAG"",$J,""Q/R PARAM"",""QUERY USER APPLICATION"")=QRSCP"
^XMB(3.9,145834,2,3503,0)="""RTN"",""MAGDSTA2"",59,0)"
^XMB(3.9,145834,2,3504,0)=" . S ^TMP(""MAG"",$J,""BATCH Q/R"",""PACS Q/R RETRIEVE SCP"")=QRSCP"
^XMB(3.9,145834,2,3505,0)="""RTN"",""MAGDSTA2"",60,0)"
^XMB(3.9,145834,2,3506,0)=" . S OK=1"
^XMB(3.9,145834,2,3507,0)="""RTN"",""MAGDSTA2"",61,0)"
^XMB(3.9,145834,2,3508,0)=" . Q"
^XMB(3.9,145834,2,3509,0)="""RTN"",""MAGDSTA2"",62,0)"
^XMB(3.9,145834,2,3510,0)=" Q"
^XMB(3.9,145834,2,3511,0)="""RTN"",""MAGDSTA2"",63,0)"
^XMB(3.9,145834,2,3512,0)=" ;"
^XMB(3.9,145834,2,3513,0)="""RTN"",""MAGDSTA2"",64,0)"
^XMB(3.9,145834,2,3514,0)=" ;"
^XMB(3.9,145834,2,3515,0)="""RTN"",""MAGDSTA2"",65,0)"
^XMB(3.9,145834,2,3516,0)=" ;"
^XMB(3.9,145834,2,3517,0)="""RTN"",""MAGDSTA2"",66,0)"
^XMB(3.9,145834,2,3518,0)="SORTORDR ; get the direction for the ^RARPT OR ^GMR search"
^XMB(3.9,145834,2,3519,0)="""RTN"",""MAGDSTA2"",67,0)"
^XMB(3.9,145834,2,3520,0)=" N X"
^XMB(3.9,145834,2,3521,0)="""RTN"",""MAGDSTA2"",68,0)"
^XMB(3.9,145834,2,3522,0)=" S SORTORDER=$G(^TMP(""MAG"",$J,""BATCH Q/R"",""SORT ORDER""))"
^XMB(3.9,145834,2,3523,0)="""RTN"",""MAGDSTA2"",69,0)"
^XMB(3.9,145834,2,3524,0)=" I $L(SORTORDER) D"
^XMB(3.9,145834,2,3525,0)="""RTN"",""MAGDSTA2"",70,0)"
^XMB(3.9,145834,2,3526,0)=" . W !!,""The studies will be scanned in the """""",SORTORDER,"""""" order."""
^XMB(3.9,145834,2,3527,0)="""RTN"",""MAGDSTA2"",71,0)"
^XMB(3.9,145834,2,3528,0)=" . I $$YESNO^MAGDSTQ(""Do you wish to change it?"",""n"",.X)<0 S QUIT=1 Q"
^XMB(3.9,145834,2,3529,0)="""RTN"",""MAGDSTA2"",72,0)"
^XMB(3.9,145834,2,3530,0)=" . I X=""YES"" D SORTORD1"
^XMB(3.9,145834,2,3531,0)="""RTN"",""MAGDSTA2"",73,0)"
^XMB(3.9,145834,2,3532,0)=" . Q"
^XMB(3.9,145834,2,3533,0)="""RTN"",""MAGDSTA2"",74,0)"
^XMB(3.9,145834,2,3534,0)=" E  D SORTORD1"
^XMB(3.9,145834,2,3535,0)="""RTN"",""MAGDSTA2"",75,0)"
^XMB(3.9,145834,2,3536,0)=" Q"
^XMB(3.9,145834,2,3537,0)="""RTN"",""MAGDSTA2"",76,0)"
^XMB(3.9,145834,2,3538,0)=" ;"
^XMB(3.9,145834,2,3539,0)="""RTN"",""MAGDSTA2"",77,0)"
^XMB(3.9,145834,2,3540,0)="SORTORD1 ; get new value"
^XMB(3.9,145834,2,3541,0)="""RTN"",""MAGDSTA2"",78,0)"
^XMB(3.9,145834,2,3542,0)=" N OK"
^XMB(3.9,145834,2,3543,0)="""RTN"",""MAGDSTA2"",79,0)"
^XMB(3.9,145834,2,3544,0)=" S OK=0 F  D  Q:OK"
^XMB(3.9,145834,2,3545,0)="""RTN"",""MAGDSTA2"",80,0)"
^XMB(3.9,145834,2,3546,0)=" . I SORTORDER="""" S SORTORDER=""ASCENDING"""
^XMB(3.9,145834,2,3547,0)="""RTN"",""MAGDSTA2"",81,0)"
^XMB(3.9,145834,2,3548,0)=" . W !!,""Enter the scanning order for studies: "",SORTORDER,""// """
^XMB(3.9,145834,2,3549,0)="""RTN"",""MAGDSTA2"",82,0)"
^XMB(3.9,145834,2,3550,0)=" . R X:DTIME E  S OK=-1 Q"
^XMB(3.9,145834,2,3551,0)="""RTN"",""MAGDSTA2"",83,0)"
^XMB(3.9,145834,2,3552,0)=" . I X[""^"" S OK=-1 Q"
