^XMB(3.9,145837,2,510,0)=" S XQA2=XQA1 I XQA2["","",$P(XQA2,"","",3)'="""" S XQA2=$P(XQA2,"","")_"",""_$P(XQA2,"","",3)"
^XMB(3.9,145837,2,511,0)="""RTN"",""XQALSET"",136,0)"
^XMB(3.9,145837,2,512,0)=" F  D  Q:'$D(DIERR)  Q:'$D(^TMP(""DIERR"",$J,""E"",111))"
